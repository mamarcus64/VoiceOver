{
  "stem": "27543.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I got a passport with a white band that I got a right to go to the movie and buy pastries.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But when I go to the movie, it was written, [GERMAN], just for German soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "My God, I coming to see the movie.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Every morning, they give us a black coffee and a piece of black bread.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And 12 people in the truck-- this was January or February.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And how we were going, going, going up, the truck hardly could go.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Then they put us back in the truck.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They called up 10 people, bang, bang, bang, bang, bang, bang, bang, bang, And they called two of us up.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And we had to bury them.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "That went 10 days.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In Lemberg.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In the Jewish-- where was the truck?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We were taking to the sanitarium there-- it wasn't a sanitarium.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "There was a Jewish sanitarium there in Lemberg.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And we had to dig them.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And then, you know, they send us back to the car.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "That was-- God was with me twice in my life.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] They sent back all of us.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "They called up ten.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "They shot them.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "We had to bury them.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "The next day, we went back.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "That went for 10 days there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "It was left over, 10 of us.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we said, some way, now, we're going to get-- we're going to die.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They don't want us no more.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "He says, [SPEAKING GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I fainted-- excuse me-- I shit all over-- From the faint, and from the fear.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 17 SECONDS] They went out.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They wash me up.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They took me out of there.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They took me a bath.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They shave me.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "For three days, I didn't even have to go to work.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "When they came, you know, they said I'm sick.",
      "word_count": 9
    }
  ],
