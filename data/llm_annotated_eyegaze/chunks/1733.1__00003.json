{
  "stem": "1733.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We had the Shabbos meal.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "We were singing zemiros and so forth.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We always had somebody, some poor person that came into the village to make some collections for their sustenance.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "We had them for the guest for Shabbos.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "As a matter of fact we had a special room that was held for them for every Shabbos, to have a guest in the house.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And then in the morning we went to shul.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "We came home from shul again.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "We had a meal.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And then the test-- the test was going on that I mentioned before.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "My grandfather laid down and everybody rested, until Saturday night.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "It was Shabbos was over.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "They made havdalah and the businesses were open again.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather was a very respected man in the community.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He was like an elder of the community.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He was known by the name of [?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Reb ?] Mordechai, which means he had a title of [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He was a follower of the Munkacs [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We had no rabbi in our community.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But our community belonged-- I mean, the overseer of the community, the rabbinic overseer of the community, was the Munkacs [INAUDIBLE], which is a very famous [INAUDIBLE], and his name was Rabbi Shapiro.",
      "word_count": 33
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And he occasionally came to visit our community.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And when he came to visit our community, he stayed in our house.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, the school-- the school life for us was very-- a very happy life.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "As a mother of fact, my present wife, Etta, she was my childhood sweetheart.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And we were always picked to perform in the same plays, in the same dances.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Somehow we were always paired up together.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We had a happy childhood.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We had a very good life in those days.",
      "word_count": 9
    }
  ],
