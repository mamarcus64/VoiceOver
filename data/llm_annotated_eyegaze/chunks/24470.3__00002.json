{
  "stem": "24470.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 33,
      "text": "And I used to sit-- put it in that tank and rinse it and, uh-- and-- and dry it where the-- where the ammunition was dried, where the shells were dried.",
      "word_count": 31
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 34,
      "text": "And put it on while she was waiting in a little room-- at work was a bathroom-- uh, until I'm ready.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 35,
      "text": "I put it on.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 36,
      "text": "She used to do that.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So that's the only way we washed it, and very seldom.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "In the snow outside, we could wash our faces and bodies.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Uh, conditions were very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Food that we got was one piece of bread-- I don't know how many grams-- which was supposed to last us for three portions a day.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "For lunch we had, uh, soup made of potato skin with water.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And for at night, we got some Ersatzkaffee.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Uh, that's a substitute for coffee, some kind of dark liquid.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And that's what we lived on.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We were supposed to have that piece of bread that we were given a ration.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "But some of us could not hold it till the end.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "After the war-- I was very sick in camp too, very sick.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I contracted some kind of a disease of the skin, where the whole skin was in-- in furun-- furuncles.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Um, wounds with pus erupting from me everywhere-- on my breasts, on my feet, on my body.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And it was itching terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "It was like, uh, a itching disease that was contracted from somebody else and from dirt.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Two girls-- I was the youngest in camp.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Another one was young too-- 15.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Other women were a little bit older.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My friends with whom I made a very deep friendship in-- in the labor camp were maybe a year or two older than I was.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And then the rest were in their 30s.",
      "word_count": 8
    }
  ],
