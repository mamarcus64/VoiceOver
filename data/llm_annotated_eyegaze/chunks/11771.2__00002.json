{
  "stem": "11771.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "They were not-- I mean, they put me in there.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "And the same scenery, what happened to me happened to the next one, too.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "But I was released already.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "We were sitting there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "That was Monday morning.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "Monday and Tuesday, I was laying in the synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "And [PAUSES FOR 3 SECONDS] Tuesday, by the afternoon, late afternoon, came in the commandant.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "And they say we're all going to do the horse market, or from there we're going to a ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "I can show you the picture.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "The horse market is not anymore in existence.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "And we stood up like 50, 100, in a line, to five in a line, and we were marching.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "While we are marching, and I saw the peasants, standing and clapping there.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "And we walked all through the little town, Ejszyszki, and the peasant laughing and clapping for the end, as you went.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "Told me that, give my debt to society.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "Anyway, you're going to be killed.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I came to the market, with all the people.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "There, I see already my father and my brother, my mother, with the whole family, sitting.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We was organizing there-- and the market was a little bigger.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We were happy that we're going out from-- from the room. 500, 600 people in the room.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Can you imagine the air what's happening two days there?",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Where were your sisters, your other sisters at this point?",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We-- we came together when we meet each other on the market.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They were in the other synagogue, in the new synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "One met my father after I left him.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The next day, they met each other.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it was such a hassle there.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't see each other for even for a day or two.",
      "word_count": 12
    }
  ],
