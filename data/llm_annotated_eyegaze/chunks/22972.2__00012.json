{
  "stem": "22972.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "And when she was fired in early-- in '35-- she immediately went to Lo-- to Cambridge and she talked to some of her friends.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "She had friends there.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 46,
      "text": "And she said, I am going to start a private, Jewish school for extra bright Jewish Berlin children.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 47,
      "text": "I am starting the school.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 48,
      "text": "My husband is already negotiating for the building.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 49,
      "text": "I've found the most wonderful building.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 50,
      "text": "I want to become an adjunct of Cambridge.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 51,
      "text": "And she talked them into becoming the Cambridge adjunct for Germany.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 52,
      "text": "Graduating from the Goldschmidt Schule in Berlin meant entering-- the matrix of the Goldschmidt Schule was the entrance exam to Cambridge, which was an enormous achievement.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 53,
      "text": "The school itself was a revolving door.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 54,
      "text": "Every day, a child didn't appear.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 55,
      "text": "Parents would either call and say, so and so is not coming back tomorrow, or the child just wouldn't come.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 56,
      "text": "And if you called the apartment, the phone number, the house, whatever, there was no answer.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 57,
      "text": "And you knew that someone else had either been arrested or hopefully had escaped during the night.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 58,
      "text": "Or parents had a legal quota number and got out with their children.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 59,
      "text": "And every day, somewhere in the school, a child or two did not appear.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 60,
      "text": "That's why I say it was a revolving door.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 61,
      "text": "Frau Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 62,
      "text": "Goldschmidt took one look at me and I was accepted.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 63,
      "text": "I had to get papers from the [INAUDIBLE] schule that I had finished the term, which Frau Dr.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 64,
      "text": "Neumann gladly gave my parents.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 65,
      "text": "And I got straight A's, which she saw to whether I deserved them or not.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 66,
      "text": "And I started the Goldschmidt schule.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
