{
  "stem": "7016.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And she said that uh-- it was a nurse, a doctor-- she said I should come after work, and she's going to clean up my leg after this.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "You know, they operate my leg.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "It came a doctor from the men's, and they cut off and they took it out from my leg.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And I remember the doctor said that I would wait a day, I probably would go, that to my heart I couldn't live.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "I was lucky that the man came.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "I couldn't understand myself.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And I came out, and-- and I went.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "A day, two days, later, the whole-- the hospital, everybody went to the gas chamber.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "They cleaned up.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "And then you-- then you-- it's so much to tell.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "Then you was walking and looking in the sky.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "You could see just faces.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "Heads.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "Eyes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "And always was smoke.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "And it was so-- it smelled from the bones.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "You could feel.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "And every time you could see.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "I remember when the [INAUDIBLE] transport came, and they put-- we went too.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "We walked to work.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "We could see.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "They all went right away to the ga-- the gas chamber.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "He was lucky-- some was lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "They holed up.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "And then later, I was so sick I start to spit with blood.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 46,
      "text": "And I-- and I-- I didn't know what-- what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 47,
      "text": "And I went to the [NON-ENGLISH], to the doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 48,
      "text": "And she said, I'm sorry.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 49,
      "text": "I can do nothing for you.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 50,
      "text": "You have-- you-- you have TB.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 51,
      "text": "You have-- you're spitting from your lungs.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 52,
      "text": "And then I had-- I didn't know what to do, what I can do.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 53,
      "text": "I know I'm not going to live.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 54,
      "text": "And I-- when I see somebody die, I said, oh, he's so lucky.",
      "word_count": 13
    }
  ],
