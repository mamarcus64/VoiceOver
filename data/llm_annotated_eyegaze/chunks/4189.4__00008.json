{
  "stem": "4189.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And they brought us to a convalescent home in nearby Brussels.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "That was a home that was donated by the queen of Belgium.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "The queen mother, Elizabeth, donated that home for people like us to recuperate in.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I was in that home for almost a year to-- because I had to learn how to walk.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And I had to, you know, to get my, my weight back and my strength.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And in that home, of course, we were, we were totally on our own.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "We were free to go in and out like, like anybody else.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "You know, we were not imprisoned in that home.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "The home was very good to us.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And during all that time, we-- of course, I corresponded with my family.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And my brother had decided-- yeah, my uncle that was in America here, he also had another brother that lived here in America.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "He lived in New Jersey.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And he had a farm.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And he sent us papers to come here to the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And my brother did not want to come to the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "He, he became-- while he was in hiding in, in the Ardennes there, he became a Zionist.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "And he wanted to go to Palestine.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "And of course, then in those days, there was no state.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "So the only way you could go to then Palestine was illegally.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So he managed to go to Marseilles, to France.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And they went in one of those illegal boats that went to Palestine.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "That particular boat that he was on got caught by the British, British patrol outside of Haifa.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They, they took the-- all the people that were on that boat.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They were interned in Cyprus.",
      "word_count": 5
    }
  ],
