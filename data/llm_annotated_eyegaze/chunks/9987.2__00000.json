{
  "stem": "9987.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "All of a sudden, the-- the German, I don't know who it was, the commandant of town, whoever it was, [PAUSES FOR 3 SECONDS] let out a report, whatever.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "It was not actually an order.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "It was-- [PAUSES FOR 3 SECONDS] I don't know how to explain that-- that all Jews, that they're willing to leave their homes and cross over to the Soviet side, the other side of the river, they'll be permitted to do that.",
      "word_count": 42
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They won't be stopped by the German army.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "The only thing is, no transportation will be provided, so you got to go by yourself.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we made a decision.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My younger brother and I, my younger brother Mike and I, that we're going back to the Soviet side.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We decided whatever it is, it's always going to be better than-- seeing what we saw, it's going to be better than on the German side.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "My older brother Moses wouldn't go.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "My sister Berta with her husband and the two children wouldn't go.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My parents said, well, children, you go.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "You're young.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We will stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "There's no use to go and-- and uproot ourselves.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Probably the-- the German will leave us alone, the old people.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "But you young people got to save yourself.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So we, the two of us, with a group of other young people and also a family [?",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Mintz ?], which were quite wealthy, and we were quite friendly with them.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They hired a horse and buggy, and we loaded up about 15 people.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And we went over to Sanok, to the river, crossed-- crossed the river.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans let you?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And the Germans did not say anything.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We crossed the river not on a bridge.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We had to cross it on-- in the water.",
      "word_count": 9
    }
  ],
