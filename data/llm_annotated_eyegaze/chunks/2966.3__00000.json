{
  "stem": "2966.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The ghettos-- they-- they formed two ghettos in two different parts of town.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The ghettos were not enclosed.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And the part of town where I lived, we were moved into-- I don't know how to call it.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "It was like a big building where they used to be for factory workers, like in a company town.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And it was like single, one-room apartments.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And we were pushed into that, and some neighboring homes.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "So we got one room.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "We had to leave whatever we have yet.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "All the furniture and everything else, we had to leave behind, because we couldn't take anything with us.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We just took whatever clothes we called and a few towels or sheets or whatever, and we moved in there.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "We moved in there.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And of course there was a lot of people yet left.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And life went on.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Mothers tried to cook whatever they had to cook with to feed the family.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "Used to try to get some bread once in awhile, we used to get, and potatoes and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And we used to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "The mothers stayed home, and we went to work.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I worked in a-- [PAUSES FOR 5 SECONDS] in a cabinet maker shop, because I used to watch him always.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I knew a little bit about it, and that's what I went to work.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And my father worked there, and I worked there.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And it was in a different part of town, but we used to walk there in the morning, come back home in the evening, home to the ghetto.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And life was miserable.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "We were always living in constant fear and not knowing when and what and how is going to happen.",
      "word_count": 19
    }
  ],
