{
  "stem": "12674.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "It was dark.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "It was-- and all of a sudden-- the road makes a bend around the building at that particular point.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "All of a sudden, this house comes rolling down the road, with great big windows like a two story building.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "It was a Russian tank, a great big Russian tank.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "It came around the corner there.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And it, it rolled right in front of us.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And then a second one came.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And those two tanks were held captive.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "There was this throng of people.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "We all went in front of the tank.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "They would've had to make mush out of us.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "We all climbed, climbed up all over the tanks.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "And, and, these, those were Russian soldiers.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And they begged us to please get off the tanks.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "They had to be in Prague at a certain hour.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And we didn't want to go.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "So they went inside the tank.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And they found some cigarettes.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "And they found some bread.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "They didn't have any chocolates.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "Those were not Americans.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "And they do gave us something.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "And they begged us, actually begged us, to get off there.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "And the people that spoke Czech-- and by that time I did-- understood the Russian.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "We couldn't really talk, but we understood what they were saying and to get off the tank so that they could get to their thing.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "There were going to be trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "So we went off the tanks, and that, that was liberation of Theresienstadt.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That was May 8.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "1945.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The, the, the armistice was signed two hours later.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "This was about 10 o'clock at night.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They were told they had to be in Prague by 12:00 It was about 20-- I don't know.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I think so, 12:00 or 1 o'clock.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And it was, like, between 9:30 and 10:00.",
      "word_count": 8
    }
  ],
