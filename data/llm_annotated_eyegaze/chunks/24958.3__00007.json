{
  "stem": "24958.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "They all run away.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "We all on our own.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Nothing!",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "You know, we-- we were-- we were walking around.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what to do!",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "They run away!",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They all run away.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "All the Germans run away.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Then what happened-- the Russian came on horses.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They came in, and they-- they brought us food.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "They feeded us, and then they let us out.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And each of the-- each of us, we went to apartments where the Germans run away.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And we-- I was a dressmaker, so I took down some curtains, and I made some skirts for the girls.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And we-- we spent there a few days.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And then we went-- I had a date with my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "When we live through the war, we're gonna meet in Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "So my-- there was with me was my brother-in-law, my niece, brother-- two brothers, and a sister, and one sister-in-law.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And I said, we go to Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "There were no trains.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "The-- the-- the-- the tracks were bombed.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "So we walked for a while.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And then we saw a horse with a platform-- you know-- this thing.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "So we stole.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We stole this horse on the platform, and we went with this horse.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "We sit on the platform.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "We went with this horse, with this wagon, to-- till we finally came to some little town where was already a train.",
      "word_count": 22
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "So we left the horse on the platform.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "We went on the train.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "We told to the-- what-- who we are.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And on the way there we stopped somewheres.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And we said again we was.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So then they took us to a school-- Red Cross, like, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And they gave us something to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And we went-- it took us about maybe a week.",
      "word_count": 10
    }
  ],
