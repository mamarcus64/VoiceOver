  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "My mother, and my aunties, and my-- on the other side to-- like you say-- to go in the-- in the-- in the-- in the labor camps, was my father, and my two brothers, and my two sisters.",
      "word_count": 38
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And actually, all of them, you know, perish, except for my sister, who lives now in Capetown-- Mrs.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Diamonte Franco-- and myself.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had it.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But when we arrive in Auschwitz, those people who were speaking Spanish, I told you, from Salonika, and they were like interpreter.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Maybe they put it on purpose knowing that we were Spanish-speaking people.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "They say, you must leave your belonging in the train.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "You must leave the-- the belonging in the train.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And then, we came down without nothing.",
      "word_count": 7
    }
  ],
