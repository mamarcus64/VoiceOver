{
  "stem": "18486.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 409.0,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "I wouldn't do a thing like that.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "And I am German, so I wouldn't do it-- again, 'my own people.' You know?",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "I faked all that, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "But I was German.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "And then they asked me, where is your husband?",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't say that I had a second husband.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I said, my husband is away in Russia, fighting.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And I kept my name.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Not officially, but I introduced myself to them.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "My first husband's name was Molenaar, which was a Dutch name.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "His forefathers were Dutch.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it was in my own house.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "No, they never.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "They threatened very often to take me out, but they never did.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "German officers, one or two.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And they started throwing questions, throwing questions, throwing questions till I was so tired that they hoped that I would make a mistake and slip, which I didn't.",
      "word_count": 28
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "My fear was that they would come in a moment that they all were around.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "That we had no warning.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "But we always had a warning.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Were I ever--",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "My husband was.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "My husband, he once took my husband, and he was for three days in jail.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Because they suspected him.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Sure they know.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "They took him from my house.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Oh sure, they knew, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "We married in the war.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "The tunnel was in the atelier, in the back of the house where most of them lived, because it had two bedrooms with it and a living room.",
      "word_count": 28
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "They had built it all out.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Because when I was divorced from my first husband, I lived here.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "So we added some to it.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And the tunnel went from that place.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "The tunnel was not from the house.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "It was from that place.",
      "word_count": 5
    }
  ],
