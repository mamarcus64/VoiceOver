{
  "stem": "16395.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Right away, school started-- well, I graduated, really, school then, because when we were 13, we graduated school-- grammar school.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We went seven years.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And we had to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "My father was older than my mother yet.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "So we didn't want the father was-- to go to school-- to work.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "So I really worked every day.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "One day, I went with my [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And one day I went with his [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And he stayed home.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "He stayed home, and I used to clean by the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "I used to wash the floors.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "And that's what we did.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "We didn't clean them.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "We washed the floors.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "This was my occupation.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "Or we-- we went to a-- to a kitchen where they cooked for the Germans, and we peeled potatoes, carrots, prepared everything.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Only me and my other sister, when she was still not married and she stayed with us.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "For all the time until I got relocated.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS]",
      "word_count": 1
    }
  ],
