{
  "stem": "11998.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "At any rate, when we got to-- before we-- when they embarked us on a-- you know, on a car, they-- they had-- they stuffed us into a-- a-- a cattle car, a closed cattle car.",
      "word_count": 36
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And we were there with my mother, and my sister, and my father.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And we were sort of huddled together.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "We couldn't sit.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "We could almost-- there was not enough room to-- to sit, but we huddled together.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And my father took out whatever money he had.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And he divided the last marks that he had, gave us each five marks.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "I think that was all he had left.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "And my mother said, whoever survives, we'll meet at my mother's-- at my grandmother's neighbor's home.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "And my sister's boyfriend, who was on the-- on that train was at the window, somehow or other.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "Either he shouted something, or he yelled something, and the Nazis opened fire.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "And they-- and they-- he caught a bullet right in between his arm, right in his arm, between his body and his arm.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "And he was bleeding badly.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "And he was trying to look after his wound.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "People were helping him.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "And then, of course, the gates opened.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "We got-- we arrived in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it wasn't long, maybe-- maybe two hours, maybe-- maybe less.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Was only00 Sosnowiec is only about 30 kilometers from-- maybe 30 or 60 kilometers from Auschwitz.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "When we got into Auschwitz, they disembarked us on a-- on a field.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "It was not into the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "They-- you know, they see the-- the train.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "There are tracks going into the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "That-- that was done much later.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "That was done in 1944.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "When we arrived in Auschwitz, the train stopped outside of the camp.",
      "word_count": 12
    }
  ],
