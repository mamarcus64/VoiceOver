{
  "stem": "2568.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "So I had a little money and jewelry that I kept with me, which helped me for some time not too long.",
      "word_count": 22
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "First there was liquidation ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We were laying in a bunker, with uncle, with the aunt, with the kids, and a lot of neighbors.",
      "word_count": 19
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "So how it happened, they opened in the-- in the city, they opened a little labor camp.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "Whoever was left over, they found people to open the labor camp.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And they used the people to work on them.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "So one fellow, he knew me.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "He took me out from that bunker.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "He brought me to that camp.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 8,
      "text": "In that camp, you have to pay-- everything.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 9,
      "text": "I had a lot of Russian gold money.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "So I had one cousin, which I liked very much.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to leave her in the bunker.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "My brother was too young to take in to labor camp.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "They would kill him anyways.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "At the same time, he had typhus in the bunker.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "There was-- I was lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "I was laying with all the people that were sick and I didn't get sick.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "So I paid for her to [INAUDIBLE] Russian, they're called 20 rubles.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "You had to pay to get into the work camp?",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "People, they used to make, like on the side-- you know.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "So I went to that labor camp, and I took my cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "She got sick.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "She had to do with her lung-- she was spitting up blood.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "So when I had been in that labor camp, the same guy, took me out.",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "He said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "For you, it's the best thing to go out every day to work.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "Don't stay in that camp, because one day they're gonna liquidate that camp too.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "I said, that's fine.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "I go out.",
      "word_count": 3
    }
  ],
