{
  "stem": "17337.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 332.2,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Well, some people had some connection with the-- in the-- with the people in the kitchen could get some extra food, naturally, could get an extra-- extra plate of soup, you know?",
      "word_count": 32
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "But I did not have connection, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know the people, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "So I couldn't get extra food.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And I remember one time, I got sick there being in Klaj.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And the ghetto was still-- there was still a ghetto in Bochnia.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And I got the-- the jaundice.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Jaundice is it?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] I was all yellow, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So they send me-- they send me back to Bochnia to a hospital.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "But I went to Bochnia, and I didn't want to go to the hospital, because if I would go to the hospital, I wouldn't be here anymore.",
      "word_count": 27
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So I remember I stayed with my uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "He was still in the ghetto that time.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So I stayed with him for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I remember I couldn't eat nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I didn't no medication, no nothing, because I was afraid to go to the hospital to get medication.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And then after three weeks, I felt better, and I went back to Klaj.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "The hospital that you're talking about, was that inside the ghetto?",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Because a lot of people were killed in the hospitals, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They didn't help you.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They didn't treat you.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I mean, I mean not killed by shotting or something.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They didn't shot them.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't treat them, so they die, you know, from the sickness, whatever they had it, you know, because they didn't medicate you, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "There was medication for-- for jaundice, you know, or other things.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "But they didn't give you that.",
      "word_count": 6
    }
  ],
