    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "They didn't want to give us this, no bread.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "They played football with the-- and they were laughing.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "That I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "And I know we-- I remember we were sitting all the time in-- in the barracks on-- on the floor.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "And like I told you, you know, to do the flies, and talking about food, when we're gonna to be liberated, when we go home, how we gonna to meet each other, and what we gonna to cook.",
      "word_count": 38
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "We asked recipes from each other, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "That was our pastime, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "And some of the girls even think-- we didn't think that was the end, really, that we gonna survive.",
      "word_count": 19
    }
  ],
