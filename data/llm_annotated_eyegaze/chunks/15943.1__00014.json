    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "So I was home on Saturday because it was a Jewish school.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And he was home Sundays.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "So he would come.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "The teachers would say, he's the best student.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "He loved Jewish history.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "And well, and later he was brainwashed.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "But he was my best friend till age 13.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "September 1, 1939 the Nazis conquered to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They came to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And a few months later, the Jews had to-- were put into ghettos.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "At that time, that's where Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Gruber had shown her anti-Semitism.",
      "word_count": 5
    }
