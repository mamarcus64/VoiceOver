  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And I got in-- I got in, [POLISH] stand up.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "He said-- he said to me, you are [POLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "I said, what-- what-- what you came in here?",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "I said, listen, I came from the front and I-- came and I want to see my family and I find out that one of my cousins is in jail.",
      "word_count": 30
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "And I give him the name.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And he said, do you know what you catch him?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "I said, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "They told me that some coins he has got.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "I say, he has got coins from-- from his parents from before.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "And he called in [POLISH] and you tell him, take Mr.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "Reifer-- I mean, you know, he didn't say mister-- and go take out the man from jail.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "He was going to me, I took him out.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "What was his name, do you remember?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "He is still live here in Los Angeles.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I don't want to mention his name-- Germans, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "He's a big shot.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "He is very big.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I will tell you the name privately, I don't want to tell you on--",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I took him out.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I-- I find out that they are not here anymore, the perished in Auschwitz.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "They killed the whole family in Auschwitz.",
      "word_count": 7
    }
  ],
