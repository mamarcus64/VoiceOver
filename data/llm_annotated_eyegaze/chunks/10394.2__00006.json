{
  "stem": "10394.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So she came and bringed me a bottle of water.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And I find a big comb and the [NON-ENGLISH], you know.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I find the comb in your hair-- and they catch you, you have something on your head, some things, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Lice or something.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They cut all the hair.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "In the night-- everybody was sleeping.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Like 2:00, 12:00, 1 o'clock-- I was-- I says to myself, what's going to be is going to be.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I have to wash myself, I have to go in toilet.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I go-- it was a big, big like-- like two rooms here.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "A latrine, what they call it in German.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "It was closet-- the-- the closet.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Then was a shower.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I take a shower, and I take-- what I have to do I did.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "If somebody catch you, no way.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "They kill you.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "I did almost every night.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And I was clean.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "I was very clean.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "And I find a comb-- the smallest, you know, with a comb you have no nothing in your hair.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "The girl-- I-- we got a eight from that bread.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "Eight from that bread-- this was-- like this.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "You know, that piece.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "I couldn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And we had the soup everyday like water.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "But you have to eat, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "And I give her this bread.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "She was pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "Big girl.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 25,
      "text": "By Jewish [INAUDIBLE], policemen are Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "They send her in oven.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "Maybe she was eight months.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 28,
      "text": "But everything was like this.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 29,
      "text": "They sent her in oven.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 30,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 31,
      "text": "This was three weeks.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 32,
      "text": "Between the three weeks, they hear from Krakow-Plaszow, the women came, what they did.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 33,
      "text": "They have to take a half of our liter blood from you.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 34,
      "text": "And I didn't got blood.",
      "word_count": 5
    }
  ],
