{
  "stem": "13623.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 46,
      "text": "But they couldn't because the gag was in their mouth.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 47,
      "text": "Things got worse, where the first time we saw two.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 48,
      "text": "The-- the next time we saw seven guys coming up.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 49,
      "text": "And there was only four gallows.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 50,
      "text": "And the others see the first ones go on and they're waiting to be next.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 51,
      "text": "I can imagine what-- what-- what they thought waiting in a few minutes they'll be dead.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We all had to watch it, the whole camp, everybody.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It was a must.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "This happened several times within a period of a couple of months.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] We are at this point, we're working in the tunnel.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "It's a 12-hour shift.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "We go out every morning, come back 12 hours later.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "It-- it depends-- within the-- within these two kommandos, it depends what work you were given at.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Some of us were-- were working in-- in sort of an assembly line that was pretty good.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "The tunnel had ventilation and everything else.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Some of us were working with those jackhammers, where there was no masks.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And they were-- we were shaking as the-- as the jackhammer went.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And all that dust settled on us.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And when we came home at the end of the day we were all white from the-- from the stone dust.",
      "word_count": 21
    }
  ],
