{
  "stem": "21482.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "So I, I-- so they didn't-- nobody would buy it.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I remember my mother packed a trunk with some linens and stuff-- I don't know what she put it in it-- and gave it to the superintendent of the building to save for us.",
      "word_count": 34
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "But a lot of-- probably she gave her-- a lot-- everything probably that she couldn't take.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "She gave her some clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And, and we just left.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "We just left, walked through the streets of the ghetto, through Cracow.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And we, you know, we couldn't walk on the sidewalk.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "We walked on the street.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "And the streets are very muddy, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "They're not like the streets-- United States.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "It was very muddy.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "And there was a lot of, you know, horses.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "So there's manure.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "And we just walked.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "And the Polish people stood on the sidewalk.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "And they were yelling, says, good riddance.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "Go!",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "Don't come back!",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "Such hate-- there was such hate, such unbelievable hate.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And then when we got into the ghetto, one of my father's brother had an apartment in the ghetto, a very small apartment.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It had two rooms and a kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It was an old building.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Most of the-- most of the places in the ghetto were, you know, old, old places, old building.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So we moved in with my uncle and his wife and a child.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we were in the-- in the one small room.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And they had another room.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And there was a small kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And then we had to share our room with another couple and, and a sister of the man whose name was Marcel Goldberg.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Marcel Goldberg with his wife, Lusza, and his sister, Sitka, lived with us in the ghetto.",
      "word_count": 16
    }
  ],
