{
  "stem": "10839.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Only what he did to me, he took the 200 mark.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And this, this, this [?",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Fall ?] what I got at home.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Only the end was that when they took me, everybody went there-- all nieces, all women, sister-in-laws, all went to the gas chamber.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And this was-- still, I was home there.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "They attacked us night time with the lamp.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Night time, they came-- 3 o'clock, 2 o'clock night time.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And we were packed in, in the shul, in a big place where used to be horses there.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And this was all people from the, from the town.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And they made separate.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Who goes to Auschwitz was on the right side.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Who goes to camp was in the left side.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Who, who stays home is right in the front.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "It was three-- one, two, three.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Only I missed here.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "But I got a argument with a Polack.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "I'm a tailor.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "When I came home, [PAUSES FOR 3 SECONDS] then I worked-- I did some work for the tailor.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And then he didn't want to pay me, the Polack.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "I said, when you will not pay me, I can't work for you.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "I work because I need the money to make a living.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 3 SECONDS] Then he went to the police.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "And he said, I don't want to work.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "Only I was smarter than him.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "I went in the [INAUDIBLE], to the mine, coal mine.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "And I went in the office.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "They hired this time Jewish people who wanted to work on the coal mine.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But in Poland, before the war, a Jew could not work there.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "In the war time, the Nazis hired Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I went in there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I said, I want to work in the coal mine.",
      "word_count": 11
    }
  ],
