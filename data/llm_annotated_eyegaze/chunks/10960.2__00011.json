{
  "stem": "10960.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And she walked in-- and she-- and he walks in and she say, who is that?",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "Who is after you?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He said, Mother, it's a history that you will-- I just wanted to ask you.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "You shall tell me yes or not.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And he told the story.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She said, oy, [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "It's out of control.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH SPEECH] If they will find us a strange woman, you don't have no [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I said, don't worry about that.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Please let me-- let me come.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "I have a baby [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So she said, go home.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We will be going.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I-- she had one son, what I found out and one-- one was the-- the little main landlady's from the building.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It was a large property.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Her daughter was under the roof.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So she said to me, it's very dangerous.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "You will have to be responsible for them.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And in case what, they will kill you too.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "All around.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Go take your baby and come with us where all the Jews are going.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "So I thought to myself, but I cannot see any danger-- more danger than-- than this.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "It's danger to go to the [NON-ENGLISH], but here dangerous.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "OK, we have to stop.",
      "word_count": 5
    }
  ],
