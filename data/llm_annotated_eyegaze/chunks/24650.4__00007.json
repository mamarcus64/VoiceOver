  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Then they said, out all of you.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And so, I tried to go out, and I couldn't.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I got paralyzed lying on the floor, so they took me out.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I says, of course, I will.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "So he asked me everything that I know, and I told him.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And then they took me.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And they took me to wash myself, because I was black.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And my hair was so big.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And the eyes was scared, so I looked like crazy, must be.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And then they took us to the city.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We saw the Germans running and the Russian coming.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We know that it's over, the war.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "But it wasn't over yet.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Just in Riga, it was over.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "In-- in [INAUDIBLE], where we say, a city in Latvia, there wasn't-- the Germans stood there and shot.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Took a couple of weeks to take them in.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "It wasn't so easy.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "But we were free.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So, I sit on a bench.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And a lady came, a Russian lady.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And she said, young man, how old are you?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I say, I'm not a young man, I'm a young lady.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I'm old 19 years.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "She says, why are you here?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "I says, by Hitler.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "You're from concentration camp.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Ah, now I know you wear pants, and a jacket, and boots.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And you don't have hair.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I think you were a-- [LAUGHS] you were a boy.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I wasn't a boy.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "This was the first thing.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Then I had very hard by the Russian, because I write to Wilno to send me papers.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I didn't get an answer.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And the Russian didn't believe me nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "They don't believe their own brothers.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "What they did is they gave me a paper.",
      "word_count": 9
    }
  ],
