{
  "stem": "22086.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "There weren't any homes to go to.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "But we went five, six, maybe even more, families in one house.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And it was like a ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "But it wasn't under wire or we weren't at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I would say maybe in August or so.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Not really, no.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "As I said, we lived in a house there, that-- the area that they told us that we should stay in.",
      "word_count": 21
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We lived with other people, a lot of people, five, six families.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, not really.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "You didn't decide.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "You just went where you had a chance to go, where you had a place to go.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "A lot of people were-- were killed already.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I lost my younger sister.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "So there were just the three of us.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "She was killed the first time when they came in.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "It would be in July of '41.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I know that she got killed.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "She was-- at the time, she was with the people, where hiding.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And they killed all the people.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "She was in town.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "With other people, with my aunt and uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And at that time, I lost my cousins.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I lost a lot of family.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We came back to the town.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And we settled down like in the area where they wanted us to live and stayed and go to-- went to work every day.",
      "word_count": 24
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Fixing the roads, lumber yard.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "There was a plant by us where they were making lumber.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Not making lumber, but cutting the lumber trees to-- to boards and things like that.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So we work there and every day came home at night and had very little to eat.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "They made like a Jewish committee that they took care of us.",
      "word_count": 12
    }
  ],
