  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "And it was closed with a wire on the end.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "So what happened-- I kneeled down and started to open this-- this-- wire.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And the SS man kicked me.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And he said, you son.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "You know, he said, you goddamn Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I show you how to open this.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "He took the-- a shovel and cut this thing through-- 1/2 and 1/2.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And the-- the lime came out.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And he started to-- to show me.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And when he kicked me, I fell in in the-- in the grave there.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And he started to throw the stuff on me.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And I started to sneeze, and cough, and choke because of the dust, you know, from the quicklime.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And I thought they will kill me right there.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't kill me.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And a signal of this chief there of this group-- he sent another fellow to give me the hand.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And they pulled me out from the grave.",
      "word_count": 8
    }
  ],
