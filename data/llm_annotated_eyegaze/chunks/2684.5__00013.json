{
  "stem": "2684.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "So it is-- it is something which I have to live with.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And my conscience is such that I have no bad dreams about it.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "I sheltered my children-- sorry, my child-- and I sheltered my grandchild-- grandchildren.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "They know about it.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "She asked me.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "Maybe what I'm doing is wrong.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "They know.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "They are absolutely familiar, but they are not familiar with my emotional side.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "They familiar with the facts, not with the emotional facts.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So if that tape, and I get it, I will show them, they will know the fact, they will never know the emotional side of it.",
      "word_count": 26
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Because my parents sheltered me when I was little.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I feel my duty shelter them when they are little.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And-- and they have to know.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They wouldn't be able to feel, so they don't have to feel.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They just have to know for future generations to come.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "--Because I sold my business.",
      "word_count": 5
    }
  ],
