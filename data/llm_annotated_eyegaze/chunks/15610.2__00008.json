{
  "stem": "15610.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.3,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "But she say, I have a good feeling that you at Schindler, she say.",
      "word_count": 14
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "So the people say that compared to this, what we are in Auschwitz is like a sanatorium.",
      "word_count": 17
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "She, this is what she says to me.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "This was the last time.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "This was the last time in Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they, when the Russian progress, they have to liquidate.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "They put them on the tracks, took to the Baltic ocean, and sunk them.",
      "word_count": 14
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "I don't know how.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Probably, on a boat, I think so.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "After the war.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "After the war, I was asking and asking.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "I went to the Jewish Community Center in Krakow every day.",
      "word_count": 11
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "I went there every day, ask about.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "About my mother I knew.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't know about my sister and father.",
      "word_count": 9
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "So I find--",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "I told you that he has the carbuncle here and got the--",
      "word_count": 12
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Carbuncle it's called.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "It is growth but is yellow from puss.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "It's infection.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "And so they give him the shot.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I, just I heard.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "I don't know the details.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "That he got the infection.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And instead to heal this what was not a problem, it was not penicillin this time, but still they could help him.",
      "word_count": 22
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Was not during the war.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "And they give him a shot, a poison shot and he passed away.",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "This what I heard.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "I just know that came the trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "They put us on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "It was November, was snowing.",
      "word_count": 5
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 3,
      "text": "And with the train, we went to Brinice, to this place.",
      "word_count": 11
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Brinice it's called this place.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "B-R-I-N-I-C-E.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "This was in Czechoslovakia, Moravia part from Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "There he established another factory.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "But not the enamel factory, but arms.",
      "word_count": 7
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he worked on arms.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was completely different-- different machines and different work.",
      "word_count": 10
    }
  ],
