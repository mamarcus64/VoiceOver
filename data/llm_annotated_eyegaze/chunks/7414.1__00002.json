{
  "stem": "7414.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he was making those.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He was manufacturing those lead seals.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "So it was quite a large business and different-- different directions.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And my mother was helping on the spot when my mother-- father had to go traveling.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And we were at home always, but we had always servants-- maid, cook, handyman around the house, around the properties.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "The children-- all of us-- we went to private schools.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Only one went to high school, public high school.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "We were all-- we had all private lessons-- music lessons, languages, and whatever it was.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I learned German because German was the language most popular in our part of Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Our part was-- before the war-- under Austrian occupation, and that was the official language.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So all-- my parents, and the whole family, and the family which was brought in come to visit us, we all spoke German.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So it was much easier for me after I was in school because the German was our second language.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I chose as a German.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Then we had-- as it was a very big difference between the ages of my sisters and brothers-- so my eldest sister, for example, she acted as a-- really as a mother because she was there always.",
      "word_count": 37
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And my mother was in the business.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "So even when she was married, I got used to it.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "When I needed something, I wrote to her or I told her that I need something.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I did not go to my mother-- only to her.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "That was my father.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "First of all, our family was always Zionist oriented.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was-- as long as I remember, it was a Zionist box at home.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "It was all Zionist [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Officially, when my father was voting, he voted socialist.",
      "word_count": 9
    }
  ],
