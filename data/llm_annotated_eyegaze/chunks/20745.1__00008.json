  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "We went on a horse and buggy, but I don't know what they did-- they did, you know, if they hired-- they told-- they told people to get out of town to go to Miedzyrzec.",
      "word_count": 35
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I guess, everybody hired a-- [PAUSES FOR 3 SECONDS] a horse and buggy, and we went.",
      "word_count": 16
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not much, not much.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have much because we-- everything was burnt, and you could not buy.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "There were no stores.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "In this ghetto, at the end of the ghetto-- or the beginning-- there was a little house, and we stayed there.",
      "word_count": 21
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And we paid somebody to build a double wall in case something will happen, we'll hide there.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "OK, how did I do?",
      "word_count": 5
    }
  ],
