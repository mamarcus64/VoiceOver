  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "You know, I-- I had remembered them.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "And yes, these are the [INAUDIBLE] et cetera, et cetera, et cetera.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And nothing was said and done.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "And then we were-- they invited us to come over for coffee and some cake.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "We went to the house.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "And of course, they had known each other very, very well.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 13,
      "text": "And I saw a picture of my wife, who was working for El Al at the time.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 14,
      "text": "And she was-- you could not fly through the Sinai-- or the Suez or what have you.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 15,
      "text": "So they had to go to Iran and take a base in East Africa, because they were flying to South Africa.",
      "word_count": 21
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 16,
      "text": "So my wife, they would-- they would send you for six weeks there.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 17,
      "text": "So she was stationed six weeks in-- in Kenya at the time.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And I said, well, why don't you come, you know, jokingly, come visit when she comes to New York?",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And so she flies there.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you come look me up?",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "She came and looked me up, and here we are, 30 years, husband and wife.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Wow.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "That's an amazing story.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    }
  ],
