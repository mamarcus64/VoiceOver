{
  "stem": "4160.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And they took me out from that ghetto, and they put me on a farm.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "They called this Tetylkowce.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "This is about 20 kilometer south of Krzemieniec.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And I was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "They feed me.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "And they were supposed to give me, every-- every week they supposed to give me a bread, a whole bread.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And all the people that was working that farm, we used to eat together in a restaurant.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "This is not a restaurant, but this is a-- they-- they cooked for us, for the workers.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So everything is left from them, I ate it.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And the whole bread, what she gave me for the whole week, that-- piece-- that bread is supposed to last, this is supposed to last for a week.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And that bread, every Sunday, I went from Tetylkowce to that ghetto, 2 o'clock in the morning.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I took that bread, whatever I could, a few onions, a few whatever and I went.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I had over there a sister and a little sister.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The younger sister.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The oldest sister, and the youngest sister.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I went there at 2 o'clock, 3 o'clock in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And I went to the ghetto from the side.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And I give it to them, and they divide it between them.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "But that was about three months later, they closed the whole ghetto in Krzemieniec.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I was on the farm, at the farm.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And they closed the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And they took all the people from the ghetto and they got rid of them.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "Some of them they-- they shoveled them in-- and over there is as shifts from-- from coal.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "They put them all in the coals, all the Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "That's the end of Krzemieniec.",
      "word_count": 5
    }
  ],
