{
  "stem": "4967.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "And my late father-- and we were told not to go out of the flat, because it's dangerous.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "And my late father decided to go to buy cigarettes or something like this.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "And he was captured by an ex-employee of his who used to work for him.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "And, and he drove him down to the fort, and he had been in the fort for two weeks, two and a half weeks.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And they used to catch people in the street, used to beat up the people.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And it was unbearable, although I didn't see with my eyes, yet.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And after two weeks-- and those Lithuanian neighbors start to look.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "What happened Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Drehspul?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Where is he?",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Maybe one of his organization picked him up.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And they find out that he is on the Seventh or Ninth Fort.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And in the meantime, my father, while he was on the-- oh, no.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It's a mistake.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "One day, my father decided to buy cigarettes.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And the Lithuanian wife begged him, don't go.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It's too dangerous.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "You can't get cigarettes.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "My husband will bring you cigarettes.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And I [INAUDIBLE] my father walked out.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And he was picked up by the Lithuanian, And they took him to the fort.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And he has been there for two and a half weeks or something like is.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "They used to shoot with a machine gun at random at the people in the yard, in the big fortress yard.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And after these two weeks, he met another Lithuanian, which was actually in charge there.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And they say to him, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Drehspul, you've still got your motorbike?",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "You know what I'll do with you?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "You give me your motorbike, and you go free.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "He say, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And one afternoon came my late father with this Lithuanian.",
      "word_count": 10
    }
  ],
