  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And the oldest sister is born in '16-- 1915 or 1916.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And Pola, about two years.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And the brother, you know, I know he's born in 1932, or '31.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "My father died about '32.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Then maybe he was about three years old.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And went I went away, we was older maybe, yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "All Yiddish.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In the street, Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] I see I Polack sometime, you know, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You know, I spoke Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I spoke Polish really good.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I went to public school, too.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I went four grade.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, me and books, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I got, you know, Jules Verne.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I got Max [INAUDIBLE], I got the Russian Pushkins, Tolstoys, you know, all Yiddish, just I.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "My father, my father, no allowed me to read these books, you understand?",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "He told me this is smut.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "This is no good.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They Yiddish.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Now I used to took them from the library, the books.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "Max [INAUDIBLE], I used to read Tolstoys.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "I was very, since I was 10 years, 11 years, I used to read so many books.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "All to Yiddish, all-- all to Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Even Goethe, [INAUDIBLE], Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Hugo, Hugo, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Maybe it's-- I used to read-- I used to read Dr.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Hugo's books, the French writer.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I used to read in Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And Jean Valjean with this-- it was very interesting in reading.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I was reading a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Even here I used to read, you know, Yiddish books, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "After I learn a little English, and I read English, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I public school four-- four class.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Four, four.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Fourth grade.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "There was Jews and non-Jews together.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
