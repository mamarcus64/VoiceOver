{
  "stem": "3933.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "No-- I went back to the-- OK, now I have to wait for-- for-- this is not-- you couldn't just leave Rovno.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "You have to go to the-- to the city hall, and ask for-- for permission.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And finally I got my permission and we emigrated to Levice.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "This was when they lost the war, the Germans, Poland took over a piece of German, Schlesien.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "This is the thing you have to know, geography.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "They took out-- they claim it-- 200 years ago, it belonged to Poland, anyway.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "They took it over, and then they placed refugees, Polish people there.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And Jewish, too, I mean, automatically.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "We want to survive-- they-- many, many-- They started to come back from Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "The ones who run away started out in '45, '46.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Rented-- they gave me an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "They-- they gave me an apartment with two-- with a couple of Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "They were registered to leave this place.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "They have to leave-- they chased them out, the Polacks, evacuated them to deep Germany, to real Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "This couple, the name was [NON-ENGLISH], [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "I must tell you, they were a darling couple.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I must tell you the truth.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "They were old, and he was a very-- a city hall worker.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "He was retired.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She was so nice.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Would you know, she cleaned up the apartment before they left?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "She cleaned, she cleaned, and I said you don't have to do that Mrs.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I love to leave you everything so nice.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And she was crazy about the attic.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Elderly people, they have some-- someplace in Potsdam, in Potsdam.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Over there they're going to evacuate.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And they were very-- And I told them the story.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He was-- he was-- she was crying.",
      "word_count": 7
    }
  ],
