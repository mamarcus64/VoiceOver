{
  "stem": "6009.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "And he hurt himself, he got blood.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So came a Gestapo man was standing there, he came, what is here going on?",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "So he said, that Jew said that Germany's going to lose the war right away and they're going to kill me.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "So he said, if we lose the war, you're not going to be here anymore, he said to me.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And he took me away from there.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And there was a kommando what's a drop stones-- you know cement, like this long.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "Like for making the sidewalks, for the edge?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "Two people took one and go from one place to another, carrying it.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "No food all day.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "Only the evening, they got a little soup for all that.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "So he said to me, you're going to take alone a stone like this.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "And my nerves, because I was frightened, picked it up-- otherwise, I would never be able to pick it up.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "I picked it up on my shoulder.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "And I was going.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And he was going in the back of me.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And stepped on my shoes, my wooden shoes that were too big on me.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He stepped on my shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And he said, if you drop that stone on my feet, I'm going to shoot you.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Either way you're going to come only to the crematorium.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And a whole day I was going like that.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And on the way back, he chased me, I should run.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Not working.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Run.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And whoever was staying on the way, any German, civvy or soldier, any-- they had, a cane or something-- they hit me over the head.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And in the evening, I came home.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I felt-- my arm, I can't straighten our, because somebody must have hit me here in the bone.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I got an inflammation.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "So I came up.",
      "word_count": 4
    }
  ],
