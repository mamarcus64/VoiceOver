  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 4 SECONDS] So are my two son I lost.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I want to tell you only one thing.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I want to tell the-- not just the Jewish, to all, to all the young-- the young people.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They have-- God gave them brains.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "God gave them talent.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And they have to know one thing, they came into this world for a purpose.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "For a-- for a purpose.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "They should use their talent.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "They should use their brains to make a better world for the next generation, as the previous generation did for me and for them.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I want to also-- also tell them, God created all the people in the same way.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Everybody's equal.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Everybody's equal, regardless of race, regardless of color of the skin, of religion-- of religion.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I want to warn them, don't let nobody poison your mind.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Don't hate people.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Hatred is poison.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "Poison.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "They are-- they are bad people.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "They still are follow it.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "So you-- you [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "You still of-- of Hitler.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "There are still racists.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "And I want to-- I want to just beg them, use your talents.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Use your brains for make a better world for the whole humanity, for-- for everybody.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "Don't-- don't let nobody poison your-- your mind.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "And I'm positively the Jewish people, regardless what did happen, regardless of the persecution during-- during thousands of years, they will still use their talents and their brain for the welfare of the whole world, regardless.",
      "word_count": 36
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "Regardless what they did to us, we will still do it, because it's in, now, our blood.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "It's in our-- it's in our bringing up.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "We-- we were brought up to help your neighbor, be nice to your-- to your neighbor.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "I'm want to just-- I didn't mention after-- after I didn't buy the shop.",
      "word_count": 14
    }
  ],
