{
  "stem": "198.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And we had-- whoever worked got a ration of a little bit of soup.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And who didn't work didn't get any food.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Just in the factory with the Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We were guarded all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We could not speak.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We could not see anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We had no schools.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We just went to work, and we came home.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "We went to work and came home.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Every day for four years.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Never, never.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "We just were like animals.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Went to work, got our soup, went home, went to sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Got up in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Went to work.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I was very young and very talented, so they used me to make the Germans-- how you call what they wear on the shoulders?",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The epaulets.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I was in like in a crib with all the gold threads, and I made the epaulets.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "They used me because I'm very good with my hands.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And so was my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We were [SIGHS] in the Lodz ghetto-- they close the ghetto, 1940 till 1944, around September.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And every day was going to work, coming home, going to work, for 12, 14 hours a day with one little bit of soup.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "No schools, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No way, no way.",
      "word_count": 4
    }
  ],
