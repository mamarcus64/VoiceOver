  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And I got word that they would send up some army hospital as rapidly as they could.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And the-- I got word then from my regimental commander that one of the companies from the reserve battalion, which was our first battalion at that time, would be up to relieve my company so that I could get-- pull my company out and reassemble the battalion to resume the attack into Munich the next morning.",
      "word_count": 56
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "This general came in somewhere around 3:30-- and his party-- that evening.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "So I got word that C Company would be up to relieve me.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And shortly thereafter, C Company arrived.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "Well, I had men scattered all over that area.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And so we were trying-- I was trying to extricate my men.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And the C Company commander came up.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And he established his headquarters in that hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "A little hospital, and took over the guarding.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "Because all we were doing was guarding.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "What we were doing was keeping the prisoners in.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "That was our mission, to not let them get out and run all over the countryside until somebody relieved us.",
      "word_count": 20
    }
  ],
