{
  "stem": "2118.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 32,
      "text": "You had to give him a tip for that after you woke him up.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 33,
      "text": "After 11 o'clock all the houses were closed.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 34,
      "text": "It wasn't that you-- there-- it was no curfew or anything like that.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 35,
      "text": "But that's the way it was.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 36,
      "text": "It was closed.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 37,
      "text": "The city got dead after 11 o'clock, except maybe in the weekend.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And-- I went to-- to the public school a 1/2 a day till 12 o'clock.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I lived on [NON-ENGLISH], which means-- the-- a-- can you cut it a second?",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "What-- what is--",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "The-- you know, the-- the-- the navy.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "How would you say navy street?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The mariner?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Marina [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And-- what was I-- I lost my thought.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And my school was at number two on the same street.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "On the big break at 11 o'clock, I ran home to eat something.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "It was only five, six houses from mine-- from where I lived-- to this-- the school.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "It was another house on the street.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "It was a double house on the front of the same building-- lived people in apartments.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And the next building in the back was the school.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Now in the morning, we all assembled in front in the yard.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "They played the national anthem.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "They raised the flag.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And then-- then we had radio in the school.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "Then the-- the radio spoke to the children every morning.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "They had the-- it-- other-- it came from a central place, not from one school, which was some kind of a speech for the children about the day or-- or little events and things.",
      "word_count": 34
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And then we made about five minutes of exercises.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Then one by one we went into the classes.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "We-- in the school were boys only.",
      "word_count": 7
    }
  ],
