{
  "stem": "10960.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So by going-- so I-- I ripped up my-- I removed my-- the Magen David.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I put it on a white 'scurf'-- scarf-- like this-- you know, like this, that I am sick on my eye.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They shall not recognize my Jewish eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And I walked through the-- in the-- the goyish streets, the [NON-ENGLISH], we used to have.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Here as I walk, I've noticed a [NON-ENGLISH], a-- a wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And an old man walked out the minute he noticed me.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It was wintertime, as I said.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "You know, it was very cold-- with a long [NON-ENGLISH], they used to call it-- a long winter coat.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And he said like this to me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So I thought, well, who know?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Maybe [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I always believed in God.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Someone has-- has-- this is what I prayed for otherwise.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I walked over, and he said, what are you looking for?",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "What [NON-ENGLISH]?",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "What are you looking for?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "What are-- so I said, I'm looking for a [NON-ENGLISH] you know, to take me to Mlynow.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I'll pay 15,000 ruble.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I'll give you my husband's [NON-ENGLISH] and this, [NON-ENGLISH] boots-- leather boots.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, he left them anyhow.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "You know-- [LAUGHS]",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "--I will take you.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I said, you will?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I'm Jewish-- like this.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "He said, this is OK.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Everything was [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH] is OK.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "So he said, but you have to come.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "I'm not going now.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I have a baby, and I-- I would like you to come early in the morning-- early in the morning before the-- the sun raises up.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And I'll show you where to come, because I live in-- in the [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I shall sit down on his wagon, and he'll go with me.",
      "word_count": 12
    }
  ],
