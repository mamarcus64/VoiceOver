  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Very little, virtually nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The one thing, however, that he did talk about was that one day they were called to line up and the, the big metal that was the center of Dachau at the time.",
      "word_count": 33
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And the commandant said, you're going to cut this grass.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And there was a big silence.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And so somebody stepped forward and said, sir, where are the instruments, the scythes?",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the commandant says, you've got teeth, haven't you?",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And so these leaders of the German community had to get down on their hands and knees and crop the meadow with their teeth.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "That was the only thing my father spoke of, really.",
      "word_count": 10
    }
  ],
