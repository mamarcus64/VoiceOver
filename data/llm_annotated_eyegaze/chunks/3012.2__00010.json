  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And also, there were some people there who-- who shouldn't have been suspected of having this or that.",
      "word_count": 22
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "But it was the Hungarian gendarmerie, and they were beasts.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Probably about a week or less.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I'm not sure.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "But by the time they came back, they were mentally, physically, and emotionally broken.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "My father, my uncle, my grandfather, had open wounds-- bleeding wounds-- on their heads.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Lacerations ON all their bodies.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "They could hardly walk because of the beat-- the-- the-- severe beating to the sole of their feet.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "They pushed my aunt's head into a sack filled with horseradish, and they tied a knot around it.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "She just barely escaped.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "She's the aunt who-- who-- who came with us to Auschwitz.",
      "word_count": 11
    }
  ],
