{
  "stem": "27747.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "But then I did not have to have the private lessons at home, because Tarbut school had-- had everything in Hebrew, except the Polish language and Polish history, because this is to be accredited as a-- by the government, the Polish government.",
      "word_count": 42
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "That's why we had to have Polish language as a language and-- and Polish history also in Polish.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "All other subjects were in Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I was friendly there with the Christian children, Ukrainian and Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I visited their homes, and they visited our home.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "So though they were-- lived on the outskirts of the town-- the town.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And I was a little bit uncomfortable there, because especially my name being Shaindel, they made fun of me.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I-- I did have Jewish friends.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "The Jewish girl friends lived very close.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't say an experience that I could remember.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "But I know that they made fun of the Jewish children.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I was never harmed.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I was in very-- I was in very good relations with the non-Jewish children.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The-- and it showed up later on during the Holocaust.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "No one but no one wanted to-- to take-- to hide or to save Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The relationship between the Jews and the Gentiles.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Before-- before the war.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "They had very-- they-- they would come to town to shop.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "In our store-- in my parents' store, they had credit.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And when the harvest would be collected and sold, then they had the money to pay.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Mostly.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Mostly Ukrainians.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Mostly Ukrainians, yes.",
      "word_count": 3
    }
  ],
