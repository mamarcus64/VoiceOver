{
  "stem": "888.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They used to make, like, ski outfits and summer bathing suits, mainly ladies' bathing suits, and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The cloth-- they would buy the cloth.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "You know, matter of fact, I had an uncle who used to manufacture the cloth.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And we just-- you know, they used to cut it and sew it, you know-- that type of operation.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They were-- actually, my mother's parents, the eldest grandson was named after him.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So he died approximately in 1923 or so. '21 or '23, I don't exactly remember.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather's name was Nachmen, Nachmen Braun.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And they lived in Kisvarda, you know, also a Hungarian city.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And my grandmother's name was Faigl.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I never-- matter of fact, I don't think I've ever seen a picture of my grandmother.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was-- also he was a-- manufacturing, I think, if I'm not mistaken.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He was a manufacturer, like military-- what do you call it?",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Military, the--",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Uniforms.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And also he owned also a farm in the place that I was born.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But they died, you know, during the-- in the early 1920s.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But I also remember my father, my father's grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I remember quite well.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He was a man-- at that time he must have been-- they said that he was about 105 when he passed on.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And that was in 1941. '40 or '41, thereabouts.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was a quiet, quiet man.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I remember when, you know, I used to go, you know, to synagogue, you know, when we came to that particular town.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And we went to the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And kids liked to go out to play.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And of course, my father was the type-- he always used to like to keep us right next.",
      "word_count": 18
    }
  ],
