{
  "stem": "10960.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Most of those people who didn't trust them, those tried away how to hide themselves, how to run away.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "As I was told when I was young, [PAUSES FOR 3 SECONDS] you can't trust everybody especial a [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "A [NON-ENGLISH] is a-- [PAUSES FOR 3 SECONDS] you know, who is-- who is not-- who is not a friend.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "What is the opposite way?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Enemy.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Enemy.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Don't trust the enemy.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Run away from him.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And this is what remained in my memory.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "From the first time whatever-- OK.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "In that time-- [PAUSES FOR 4 SECONDS] in that time when we had those trunks to be able to go to Russia, Harry said he wants to see how his mother is.",
      "word_count": 32
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "He went back to Stavische, and I gave birth to the little baby.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Before he left, he told me if I'll-- if I'll give birth to-- there will be a boy, I shall name him after his father, [?",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Olaf ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "Asholam, ?] and this what I have done.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I gave birth to the baby by closed windows in my house.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And before-- about a day or two days before, I went to the Jewish hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And I talked to one of the doctors who he used to teach me.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And I said within a day or two, I-- I will have to, but I can't go to a hospital.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I have to give birth for-- to my baby in my house.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So he said, I'll send her.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "She came twice, once was the orderly, the other one, she came, a Jewish, a mother, in my house.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But she said she's afraid the Germans shall not see us.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    }
  ],
