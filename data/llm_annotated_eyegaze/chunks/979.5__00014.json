{
  "stem": "979.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And a  year later, they asked me-- that was five years later-- if we want to come back with us to be here with them.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And [? my heart ?] says yes, we want.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Because in England it was very difficult to get a house, to get everything, with the food, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "British.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And so my brother says, why don't you all come here?",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And my husband says, yeah, I want to  go to the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So-- and then we all reunited ourselves here.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And he got a job, my husband, here in the place-- he used to work for Kodak in England.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And they transferred-- no, they transfer him.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He worked for photography again.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I mean, in the office, not, not just--",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "--pictures.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "But he loves it.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Because he is used to taking pictures, a lot of pictures, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And, and then we're all here, in the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My son became a, a-- my son is-- goes on tour for the-- with the-- to Japan and East Asia.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He plays the viola.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And he's, he's joined the New York Symphonic Ensemble, with members of the New York Philharmonic and the Metropolitan Opera.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "That's part of the tour.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Then he goes to East Asia.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Then he goes-- he plays three months on tour.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "He's now on tour.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "That's why he's not here.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "With the New York City Opera-- he plays.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And he lived in, in Manhattan.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "But now he moved to St.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Paul.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "He wants to get into the-- probably he'd like to be in the Chamber Ensemble from Saint Paul.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "But, you know, that's a very nice, well-known orchestra.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And, and my daughter got married.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And she lives not far from, from us, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And she had the three kids.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And this is us.",
      "word_count": 4
    }
  ],
