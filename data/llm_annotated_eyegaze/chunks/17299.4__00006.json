{
  "stem": "17299.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 96.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So we got to-- we traded with a farmer for food.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we cooked some food.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And we had plenty to eat-- more than we could eat.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] then we had change the tires on one bus.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And the other one we had to tie-- tie to the truck-- had to be towed in.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And the car we had to load on a truck, because the whole front end was smashed, because he had run into the bus when he was drunk.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And we looked through.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And we saw Stars of David without inscription on it.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And we saw Stars of David, which originated in Germany on the clothing.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Mostly were woolen clothing-- sweaters and things like that.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Jews had been shot.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And they had told us that they liquidated the ghetto in Minsk.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So they were bragging about it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We went-- we went-- next day, we went back to Riga.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And we asked Dausig if you could drop us off on the ghetto, those who were from the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Of course, we would like to take the food in.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We could not be able-- would not be able to take it in.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And he asked, what do you mean you cannot take in?",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "So we told him our Tuchel and Nallmann-- they're the two police officers who shake us when we come in the ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And if we have illegal food, we will be executed.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Now Tuchel and Nallmann were two NCOs from the police.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And they checked every day Jews coming back in the ghetto from the work kommandos.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And when they were drunk, they were molesting the women.",
      "word_count": 10
    }
  ],
