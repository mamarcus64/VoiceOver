{
  "stem": "12674.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And scarlet fever, at that time, was a very serious children's infection.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And it was before sulfas or penicillin, so strep was bad.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So they-- this-- all the other groups, the older children, they were all sent on to Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "None of them came back.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Our group, they wanted to get us out of there.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They didn't want us.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And all the people-- the sanitary conditions were bad.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So we would have been, you know, bad.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They-- everybody where we were made the whole countryside sick.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "So they sent us back to Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "It was a nightmarish trip, took 55 hours where I was sleeping standing up in the train.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "But anyway, we were in a sealed car, and they sent us back to Vienna.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "When I was back in Vienna, they had my name, and they-- I had to work.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And I was assigned to an old paper factory.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "May I ask first, this was forced labor?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "You were taken away to Germany?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "You were [? forced to-- ?]",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely, it was forced labor.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I was 14 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I didn't-- and my parents didn't want me to go and harvest asparagus and break my back and-- and live on asparagus. 90% percent of the food we got was asparagus.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Scary, very scary, but very unavoidable.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And you-- you started, sort of, to live in a-- in a-- in a stupor.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "You did what you were told, because you had absolutely-- what was I going to do?",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "What were my parents going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "If they would say I can't go, somebody was going to kill them.",
      "word_count": 13
    }
  ],
