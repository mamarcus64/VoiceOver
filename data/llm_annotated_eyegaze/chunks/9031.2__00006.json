  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "This was my-- the partisan, the-- the company what-- what they have the special-- a big-- a lot of people were to help kids to survive them.",
      "word_count": 27
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "In 1944.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "In Lithuanian family.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "After-- after the-- the--",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "--oh.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "After, when I came back to Kovno.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I was from Kovno about six, seven hours to drive with the car.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "This was a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "This was not like in the city.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "This is a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And my Lithuanian family, she bring me to Kovno.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And she find out what-- in the big synagogue-- we have a big synagogue in-- in Kovno-- what people, where they survived, they need to have the names, the-- the people.",
      "word_count": 31
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And was came back a lot of kids.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And then the people at the organization, the same partisan organization-- they was-- I will tell you about the partisan.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "They was go out from ghetto in 1944 in-- before the-- the action of the kids.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And-- and they was fighting with the Germans and the Lithuanian polizei in the [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In the?",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In the forest.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And when it's finished, the war, they came back-- not everybody, but a lot of people came back.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "About 200 people was back.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And the organization do what kind peoples came-- survived, except the kids.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And when they have a lot of kids-- about 10 of the 12 kids-- we was thinking that it was a lot of kids.",
      "word_count": 24
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "They open a special kinderheim.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "The orphanage.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And little for little, it came back about 30, 40, 50 kids.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Kids was-- was in Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "The father and the mother, they was in Kovno.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And-- because this was a big panic.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Nobody knows what to do.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Somebody go on outside, they grab kids, and they took them to different places.",
      "word_count": 14
    }
  ],
