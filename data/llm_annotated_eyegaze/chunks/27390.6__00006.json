{
  "stem": "27390.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "So we decided to go over to another room.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And we will stay in that other room where it was more space to move about.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "But we ran out of water.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "So my brother went out to get some water, to a pump.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And they caught him.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So he wouldn't tell them where he came from till they beat him up.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "So finally they came back with him.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And they caught us, the four of us.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I mean the three of us and him.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And they, they didn't beat us or anything.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "They took us out, and they took us to a tram, which wasn't far away.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And they put us on this tram.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And we went to the-- and we drove down to the railways, where the railway  was to be deported.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "And when we came to the railway, they-- each one of us got a loaf of bread, like they promised.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "They kept their word.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And they put us on the carriages.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And we waited in this train, felt the train started moving about six, seven hours.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "And they packed in about 100 people in the carriage.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "There was no room.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "We got tired of standing, so one sat on top of the other.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "And there were no toilet facilities, so-- so you can imagine the stench what went on there.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "Anyway, in the evening we started moving.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "We drove the whole night.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "In the morning we stopped, came to a place.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "We stopped and we managed to look out of the-- through the cracks in the-- they sealed up everywhere these carriages.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "We shouldn't see too much.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "And one of the people managed to look out and saw somebody with a, walking around with a pair, like a pair of pajamas.",
      "word_count": 24
    }
  ],
