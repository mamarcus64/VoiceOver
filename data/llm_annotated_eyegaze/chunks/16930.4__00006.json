{
  "stem": "16930.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 41,
      "text": "And I was teaching-- I was teaching in Toledo, Ohio four years, and one year in Syracuse, New York as a Hebrew teacher.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 42,
      "text": "And then I wanted to get back to New York.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 43,
      "text": "Because there was not much Jewish life in these places, and I got my bachelor's degree in '54 from University of Toledo, going to school-- going to school there in daytime, teaching-- teaching Jewish children, adults in afternoon and at night.",
      "word_count": 41
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So, I got my-- then I went back to New York.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And not mentioning small jobs I had, selling, and this and that, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I got a job at the Department-- New York State Department-- New York City Department of Social Services.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "There are plenty of jobs available.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They were building up a new-- a new welfare center every week, then back in the-- back in those days in '64, almost every week.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "It was biggest industry in New York, welfare, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "So I got a job immediately.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And I went to school at night.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And I got a master's in the-- next following five years, I got a master's in people personnel service from City College.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I was-- and I-- and I transferred then from the city-- from the city social services, after a couple of years I was-- I was already a supervisor for the city-- I got transferred to the state.",
      "word_count": 38
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "The state was a superior job.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was a superior job.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "The state and other agencies used the city for training ground, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So by the time a guy got a few years at the city, a couple of years, he was eligible to take exams for probation officer or social services for the state.",
      "word_count": 32
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "You know, it was a background for the people.",
      "word_count": 9
    }
  ],
