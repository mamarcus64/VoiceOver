  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And so you don't hesitate to be in touch with me.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And he started writing.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "He was a good-- he could write beautifully.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Not just blah, blah, but he had a good style.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "At that time, a little affection, a little appeal.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And he's not a stranger, or else I never saw them and I never knew him.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "But he had the best friend.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So we corresponded.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And once he said, if you would like to come to America, maybe I can help you.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Because there are many doctors from Poland who came before the war or the beginning of the war, the beginning of the war.",
      "word_count": 23
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they all make out some [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And I-- he said, I'm not a rich man.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "But I will be able to give you everyday a lollipop.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He wrote an ice cream, because he didn't know a lollipop.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want to go to America.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I had here an uncle.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't know him, and he never really corresponded.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "So I said, what will I come to America, and I will be his [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "I didn't respond to it.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "But we corresponded.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "You understand, he write letter.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And he wrote, I never hear from my family there.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And in-- this was '45, and in '47, I get from him a letter.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Now cut?",
      "word_count": 2
    }
  ],
