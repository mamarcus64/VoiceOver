{
  "stem": "8854.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "The girls-- the two Russian girls got together in one bed.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They gave me the other bed to sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And they told me don't worry.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "You have food, enough, because we brought food.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And they couldn't take away, from us, the food.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And we heard the news, what's going on, that Russia's here, and America is there, and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "But my heart was very wounded.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "My heart-- I knew that-- who knows if I find some-- I knew that mother and sister, Sarah and Etu, will not be alive.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "That-- because I saw where they went.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "We were there.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "In the middle of the night, in the same night, the lady-- the house lady-- wake-- woke us up.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "Come.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "We come down.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "Three men was brought in.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "What German-- democratic German people find them on the streets.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "They put them in the burl-- while-burrows.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Wheelbarrows.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They put them in the wheelbarrows.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And they brought them in mid-- middle of the night, already almost in the morning, they brought them to this woman.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They were almost dead.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't swallow.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They couldn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "They couldn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "They were all pus running from them.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "They were almost dead.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "She had hidden a doctor, a Czech doctor, not far.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "She called him up to come, right away, over.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "The doctor came over.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "She waked us-- woked us up from sleep, we should help the doctor, give him the cotton, to clean up those three people.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "They gave them those food under the-- not in the mouth, under the [? lip, ?] you know?",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "To-- nourishing, for the nourish.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And those people got better.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "They gave them injections to get better.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And we, the three girls, helped out there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And two, three days later, those three men was alive.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Beautiful.",
      "word_count": 1
    }
  ],
