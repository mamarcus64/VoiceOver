  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And they said, go get your new clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "I opened up the door, and I says, wait a second.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Where should I go?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "There's-- there's snow.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And the next building is 50 feet away.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And I'm-- I'm stark naked.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And they guy by the door, the guard, says, you go to the other building for-- for your clothes.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "I said what?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "He says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "And he kicked me out.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And I had to run through the three feet of snow stark naked.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "To the other building for my-- for my clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "How I survived, God knows only.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It must have been, maybe, 25 degrees outside, or maybe 20 degrees.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But maybe that saved us because we took that hot shower.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "That's what I-- and we ran so fast.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And in that other building, they gave us some rags to-- to new clothes, and new wooden shoes.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And that's where we got dressed.",
      "word_count": 6
    }
  ],
