{
  "stem": "21319.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I remember, I wrote some articles in school.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And they had my picture on one of the walls.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] And-- well.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And then when I was 18 years old, the war broke out, 17.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "The Nazis came and I got married, very early.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "In 1939, when the bombs were falling, you know, I was lying with a tiny little baby, breastfeeding in-- hiding in the-- in the cellar, you know, from the bombs.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh well, my husband was five years-- five or seven years older than me.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I met him through a group of my-- my kids, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And he was very much in love with me.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And I was wearing braids.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I was still a kid, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And we used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "We had dances, you know, from [INAUDIBLE] and from school.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And that's what we used to-- you know, we had all this getting together.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He played beautiful piano.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So he used to sit by the piano.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we used to dance.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "But it's all gone.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It's too-- it's too long ago.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And then nothing is left.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "It's all disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But I had a lot of Christian friends, as well as Jewish friends.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Despite the fact that we weren't religious.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But our friends were a lot of Christian.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We were very in that part where we live was more Christian than Jewish people.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And when my mother used to tell me when the First World War came, all-- Vilna was starving.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "There was no bread.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "There was no food, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And since the-- we had the bakery and the grocery store, and it was against the law if they would catch you in the streets, you know, these Germans, you know, I don't know, they would shoot you.",
      "word_count": 38
    }
  ],
