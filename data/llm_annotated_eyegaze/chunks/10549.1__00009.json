    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "They, they drove over to Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "Plaszow was a concentration camp not far from, from the Cracow ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And was in the That's where it was.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "They took the kids.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "They stopped at, at the field by the concentration, concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "They took the kids out, and my father was left in the truck.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "And he heard when they shot all those 20 kids.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "When my father came in to prison, when I met him, he was in shock.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "He couldn't stand it.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "He says he, he was, he was beside himself.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "And he told me that.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "And [PAUSES FOR 3 SECONDS] he was-- it was terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "And that's how they liquidated the ghetto.",
      "word_count": 7
    }
