{
  "stem": "18294.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 306.0,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And I said, look, we come walking, me and my cousin, if you let us to say here on the floor till tomorrow morning.",
      "word_count": 24
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "She let us.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "So we laid down.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "We was tired.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "We was happy and tired, both things together.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So we was sleeping on the floor.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, we went up.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "It was still not very-- not so light.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And the lady wake up, the Polish, and I said, you didn't hear about a Jewish Gemeinde or something.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "She said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "You go there, on this and this street, you find there a Jewish Gemeinde.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "So we went up with my cousin in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "She give us to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And we went up in the morning, and we was walking.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "We was walking up the street to the Gemeinde.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I come.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I was looking like that, without hair.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I'm not tall today.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I was not-- I was so skinny.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Only my eyes you can see in a coat from a-- from a German soldier, and shoes like that.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "A man's shoes, from the men, from the soldiers.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And I'm walking with my cousin like that on the street.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "When my brother-in-law come up, and pass, pass through me, didn't recognize me.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "I recognized him.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "Because he was already liberated one year.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "He was looking terrific.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So I said to him, Fivke, don't you recognize me?",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Then when I said to him, then he stopped.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "He said, look I'm working here on this street.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "But the Russians have to go and take a-- take-- let me go from there.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And I asked him, what-- he said, look we're already a year liberated, and the father is there, and Mulke there, my husband is there.",
      "word_count": 25
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I have my husband.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Yes, I'm liberated.",
      "word_count": 3
    }
  ],
