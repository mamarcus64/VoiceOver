{
  "stem": "6523.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 18,
      "text": "All of the women from the Schindler's list, he brought them from Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 19,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 20,
      "text": "He brought them from Plaszow to-- [INAUDIBLE] to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 21,
      "text": "From Auschwitz, he brought them to Berlitz.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 22,
      "text": "They brought the-- the men brought the women.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 23,
      "text": "And Schindler brought them, [INAUDIBLE] the men.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "She couldn't go because the transport-- they canceled the transport.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "It was off.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "The reason, don't ask me.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "They got off.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Is she went back to [? her ?] barrack before, the women's barrack.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "In Plaszow.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And later, I don't know what was happened.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "It was a shame.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know until she [INAUDIBLE] over there.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "She went to Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "From Auschwitz, she went to Ravensbruck.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "She went from Ravensbruck.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "She can tell you the story.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES] Uh, when this was?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "If he was around-- and the whole war was all together, it was five, six months [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Just like I said, in January-- In January, we was in transit.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I was only a few days.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "They put us like sardines.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "They-- what--",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "[COUGHS] No, '44.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "There was-- we was in '44 already in Gross-Rosen.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "In Gross-Rosen, he brought us for to [?",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Brenensi, ?] to Brunnlitz.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Brunnlitz, we'd been only-- let's say from January, let's say even a short time in [INAUDIBLE] in Gross-Rosen, uh, maybe five months, six [? months until May. ?]",
      "word_count": 28
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And the war ended.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "'45, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGH] In Brunnlitz, make believe.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "He's so drastic.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "You saw the movie.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "For me, you must believe it's a concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "You must believe.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "He, himself once in a while, one in every week [INAUDIBLE] they used to come to check on Schindler himself-- what he's do and what he produced.",
      "word_count": 27
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "They come through, SS.",
      "word_count": 4
    }
  ],
