  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And then we heard that-- that in a [NON-ENGLISH], in a military barracks, all these Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And we went there, and we tried to give him something, you know, some toiletry, or shirt, or something.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "They were arrested with nothing on their backs.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And the next day, we heard that they were going to be marched to the trains and sent away.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And when I-- we went early to see them again.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And we did see him.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And I saw this young man, Werner Marcus.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I saw him being marched.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "He was arrested on the street.",
      "word_count": 6
    }
  ],
