{
  "stem": "26276.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "My parents were so happy to see me coming home alive from the war.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I was the only son.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "They decided that if you want to come to the United States, they're going to make all the necessary papers for you, which they did.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "And they send me the papers.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "I went over with the papers to the HIAS in Germany, showed it to them, and says well, if you want to go to the United States, you're going to have to go through the consulate.",
      "word_count": 36
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "You're going to have to go through medical things, and all that.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So I sent back and I says, yes, I would like to come to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "But I think it's a joke that you're playing on me because there's no way for me to come to the United States.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Worked out that it was no joke.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Now, when you came here, did you come with the woman who eventually became your wife or did you come alone?",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "She came over two years later on the same ship, which I have the document--",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "It was an old converted army ship.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "It took us 11 days to cross the ocean.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And that-- when I arrived in New York, the whole [NON-ENGLISH], you know, friends, everybody, they were waiting on the dock.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know for who to look at, but they had a picture of me.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "So the--",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "His family.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And all their friends with Jerome.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They took me off the ship right away after I was going through customs and all that.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "They took me to their house.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "They lived in Brooklyn, on Utica Avenue.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And for three months they wouldn't let me do a thing.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They wouldn't let me go look for any work or anything.",
      "word_count": 11
    }
  ],
