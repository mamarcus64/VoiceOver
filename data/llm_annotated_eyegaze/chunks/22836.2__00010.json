    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 8,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "And I figure, maybe that's a wood.",
