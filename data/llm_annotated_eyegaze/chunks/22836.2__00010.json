  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 17,
      "text": "And we was 12 people there-- 6 and 6.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 18,
      "text": "And one shooter is right near a horse.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 19,
      "text": "And we were still sitting.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 20,
      "text": "At that time they-- they were never finding when we-- when we have two boys, where they jump out from the-- from the bunker.",
      "word_count": 24
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 21,
      "text": "And they jump out, and they come.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 22,
      "text": "And we shooting from this side, and he jump out, they went there.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 23,
      "text": "Then we start, everybody go out from that bunker-- to go out.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 24,
      "text": "And I steady-- I-- I never forget that day of my life.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 25,
      "text": "That was seven days before Hanukkah-- seven days before Hanukkah was that.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 26,
      "text": "And the murderers find the place.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 27,
      "text": "They find our place, the murderers, what they were looking for us-- the murderers.",
      "word_count": 14
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Murder.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "The German with Ukraine.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I went-- I went-- let's see.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Shooting from this-- and I went this way.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "I went this way.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Mine brother, the younger brother, why he went that way?",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Everybody went that way-- close.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "And they got him.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "How they get the other bunker?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "The other bunker was far away, and they got the other bunker.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "And I-- in that time-- and I went this way.",
