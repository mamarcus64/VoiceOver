  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And I see the passport in my-- in not my name.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "I am Katz-- Richard Katz on the passport.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "R-A-- R-I-C-H-A-R-D.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Richard.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And last name Katz-- K-A-T-Z.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Actually, I shouldn't say it, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "But it's so many years back that-- not a big problem.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And and I-- you know, I see everything.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And so many visas in the passport.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Unbelievable!",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "This guy who used to have before me, with a different picture, used to travel a lot.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And also, you know, the visa to East Germany was a little bit, you know-- it was an error in spelling.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Because in Russian, they-- they put the date when the visa, not just like a check.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "You have to write the date, the number, even in words.",
      "word_count": 11
    }
  ],
