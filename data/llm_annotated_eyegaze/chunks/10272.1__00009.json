{
  "stem": "10272.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And you mentioned your father, but you didn't say your mother.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So tell me your mother's name. 1 My mother's name was Rachel in Jewish-- [?",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Rkhl ?] in Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And in Hebrew, it's Rachel.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And in non-Jewish, she was Rose.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Her name was Rose in the papers.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And her maiden name?",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Pickel, P-I-C-K-E-L-- Pickel.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "My mother was-- she was housewife all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And sometimes she would step in, and when my father had to go somewhere out of our business with a train or to another, to take care of some business outside.",
      "word_count": 31
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So she would come and give a hand.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She was very efficient in business, even more than my father.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She was very nice and relaxed with people.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My father was more a strict man.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "He didn't have this business talent like my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "He would be more [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "He was a hard worker.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "He used to work very hard in America.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Hannah.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes, two brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My middle brother name was, in Hebrew, [?",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Bezalel. ?] And my father called him Charlie.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And that's how he was listed in school and the papers, Charlie.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Charlie Jacobovitz.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And then the smaller brother was Jewish name [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And when I left home, he didn't go to school yet, so I don't know what in the papers-- what name they gave him in the papers.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I don't--",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, the cheder-- I started in a early age, about 5.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "When I was 5, already I went to Jewish school.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was one room, one large room, with about 20 boys around a big, large table, sitting.",
      "word_count": 17
    }
  ],
