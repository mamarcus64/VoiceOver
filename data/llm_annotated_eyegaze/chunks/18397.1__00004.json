  "model": "openai/gpt-oss-120b",
  "elapsed_s": 110.4,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And he was started [INAUDIBLE] [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And they chose him.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And he was a lot of years over there.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And from-- and from there I think he went to the Dutch shul, you know, the biggest.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And from there, they took him to United States.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] was the name.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And the guy who built the shul, the rich guy, his name was [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "A nice shul, a real nice shul even here in the United States with tall ceilings, yeah.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Women were sitting-- if they had a balcony, they were in the balcony.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "If they hadn't a balcony, they had to sit in the back.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We had a lot of newspapers.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "What's happening?",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We knew everything.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "This was real thing.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] maybe Vilna, like this, Jewish newspapers, had maybe six, seven newspapers, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Not-- not anybody had a telephone.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Telephone are for doctors.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And who needed a telephone?",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "You know, for bankers.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I was the only one.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "You know why?",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "Because I-- I-- I wasn't looking for girls.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHTER] I had a lot of girls.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't [INAUDIBLE] to.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We went to the movies.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "We went to the games.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Soccer.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I play soccer.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I have boxing, too.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "When the Germans came and they moved the cadenza from the wall-- you know, they were looking for something.",
      "word_count": 19
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "They say, who was living here a boxed?",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "It was so many boxing gloves over there.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] Really.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "I'm-- I'm telling just the truth here now.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "It was good for me.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Later on, became worse.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Later on, you couldn't get a job.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "I had a brother five years older.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "He finished gymnasium and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Moshe.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And he couldn't get a Job for nothing, for no money.",
      "word_count": 11
    }
  ],
