{
  "stem": "23278.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] But-- and of course, we are taught French history, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We were-- I remember being five years old and I went to Brittany, and I ate [PAUSES FOR 3 SECONDS] what you call sea food.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And I got a very bad case of yellow jaundice, and I was very ill.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I was taken back home, and I remember feeling well one morning, and waking up, and feeling extremely happy.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And the feeling remains with me to this day, and I was very happy for two reasons.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "The first one that was I was a girl and not a boy.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Here goes for it.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And the second thing that I was French.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I thought with those two things, nobody could be happier than I was.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And I've been living like that since.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "Being happy to be French and being happy to be a woman.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "So.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We didn't-- I didn't have any brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And I have a sister who is-- was a year younger, not quite a year younger.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "We were almost like twins, got along beautifully.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "No problems.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Nice childhood.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Nice school years.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Everything very nice.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Nice grandparents.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Good vacation in the country in Switzerland, and all the nice things.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And besides, we were always raised below our capacity.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My father was an austere man, and we had a seamstress coming to the house for two weeks every summer, and she made our dresses and our underwear.",
      "word_count": 28
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Two dresses for the summer, two dresses for the winter, and that was that.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We were raised in a very strict manner, and to the age of 20, as I had mentioned to you, I never went out after 7:00 in the af-- in the evening.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I never went to a dance.",
      "word_count": 6
    }
  ],
