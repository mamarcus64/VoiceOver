{
  "stem": "188.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Phone's off too, but close it.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The refrigerator gets noisy.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "That door is closed.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I'm Milie Stern, or Emilie Stern.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name was Stofkooper.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I was born in Holland, in a small town called Enschede.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It was an industrial city near the German border.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "It was a truly, truly small town.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents lived in the same town.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I had a lot of relatives there.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "What I know is that my grandfathers were Dutch born, and both my grandmothers were German born.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "The Stofkooper family is written up in the history of Enschede, actually.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "There was a fire at one time, and allegedly somebody ran into the temple and saved the Torahs.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "So this is something we're always very proud of pointing out.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I don't have a year on that, no.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Must have been in the 20th century.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Early 20th century, I would imagine.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "A lot of love.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "A great deal of love.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My father's parents, we visited at least once a week.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And this was done-- we walked or we went on a bicycle that-- And the family would get together.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And my cousins would be there.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We'd sit on a couch together and the adults would visit.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "My other grandfather, I have very few memories of, because I didn't see him past my fifth birthday.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] He and my grandmother divorced in the mid '30s.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "All I remember of him and-- is that this was the man who built a dollhouse for me, which I still want.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "It's-- but he did not survive the Holocaust.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "So I have very vague memories.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "I had some great-grandparents that I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "My father's grandfather I knew who was in his high 70s.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And I was petrified of him.",
      "word_count": 6
    }
  ],
