  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But we were just-- it was just the bedroom.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Most likely the bedroom and the kitchen area was what it contained.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember being treated badly.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I was treated probably like the rest of the kids-- ignored.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We-- we-- we played, we, you know, we played outside and made up our own games and things.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I, I'm sure I was treated like the other children.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] I think basically I was very angry at my mother for sending me away and for abandoning me in a place where I was totally defenseless.",
      "word_count": 27
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And that came out later on when my mother sent for me 'cause things were getting too dangerous and she picked me up.",
      "word_count": 23
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Instead of running into her arms and hugging her, I walked up her and I said, you're getting fat, you're really fat.",
      "word_count": 22
    }
  ],
