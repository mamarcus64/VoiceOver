{
  "stem": "2830.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The one that turned in the other girl, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "That turned in the other one.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And she said she's going to go back to Hitler or Himmler, or any place who takes to get rid of her.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So they picked out the names.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They had already the names, the-- all 13 of us who were Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The one-- the one, she-- that nurse that promised that, she was the first one they took.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "She kept the one-- you know, that nurse and that Jewish girl.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So if she's going to give out the names of the others, either she's going to work with the-- with the Germans together, or they're going to set her free, or what.",
      "word_count": 32
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "That's what she did.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Wait a minute.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "After we were arrested, the Gestapo, they took us in those cars that they take prisoners.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "When they arrest prisoners, those the kind of-- and we went to the headquarters.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We came in one by one.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "She was the first one who went in.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Felix went in, because she was the one--",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "--who was in charge of everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And she was there quite a while.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She came out.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "She was white like a sheet.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I can recognize her face.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And she came out-- that she went in and out.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Finally, she admitted that she is Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "But she is an English citizen, and they have no right.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Somehow, they had a right.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And she told us, it's all over.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They're going to call you, and you tell them.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It's all over.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "They didn't beat her or anything in there.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "There were two officers.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "One was sitting on the desk, and there was chocolate on the desk.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And the other was sitting in a chair.",
      "word_count": 8
    }
  ],
