  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "So she said, well, I'm going with you, I'm going with you and I'm holding Esther.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And as we-- we walked on one side of the street, like in the-- and-- and the Judenrat was-- the building-- the Judenrat was exactly the building where-- where I attended the school, the medical school.",
      "word_count": 36
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I'll never forget that.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And so what did I see?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "We wanted to make sure what is written of the-- people always, they hung up the sign with orders.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "People shall know.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "So what did I notice?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "I notice a man in a dark jacket and the white paint on his back.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "So I said, Esther, [NON-ENGLISH SPEECH].",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "I think I'm helped.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "I got helped.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "She said, Molly, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "I'm not-- I'm not crossing, and I'm not going around.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "I'm going.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "She ran home fast.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I [? walked ?] so.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to make sure that's him.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Maybe somebody else has a-- and I-- as he was sending in a few more people, women and men.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And I was just-- I was lucky.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He was close to the edge reading.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I said to mister-- hello.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I said, [NON-ENGLISH SPEECH].",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "You know, good evening or good afternoon, I don't-- whatever it was.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So he said, oh, [NON-ENGLISH SPEECH].",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "How are you?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I said, do you remember me?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "He said, we met just now, just maybe one hour at the [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I said, I want to ask you a question.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "He said, what is it?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I said, do you have a [NON-ENGLISH]?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Because I see the paint.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "I said, are you married?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Do you have children?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "I have a little child, a little baby boy.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I met her here.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I-- he's from [?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Clevon ?], he told me.",
