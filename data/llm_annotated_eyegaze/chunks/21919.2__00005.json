{
  "stem": "21919.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And the boys realized that I didn't come out.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "They turned around and went back home.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And when her husband came, he said, no way can she have somebody else in the house.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "They don't have enough to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "So he said I should go.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "By that time, it was dark and it was nighttime.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And I-- I was scared.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "I didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "So I ask if I could stay overnight and maybe she can find a job for me somewhere.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "So I stayed with her overnight.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "I actually-- wherever she went, I went with her, because I was scared of her husband.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And she had two children I was playing with, little ones.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And in the morning, [SIGHS] she said she's going to find out, maybe a friend of hers would give me a job.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And she went with me.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And this friend told her that there is somebody else who would give me a job.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "They are rich, because they were half German.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "The woman was Polish and the man was a Volksdeutsch, which is a German.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "And they had more land.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "And they had more cows, because they were favored.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So she went to them.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They were older people.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And she got me a job with them.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So it turned out OK.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I worked for them quite a while.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "[SIGHS] As I-- Were they nice people?",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they were-- I mean, they weren't extremely nice to me, but they were whatever they were.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They didn't do me any harm, as long as I did what I did.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "But I had a lot to do.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And for somebody who didn't know how to do those things, it was double hard, because I had to learn and pretend that I knew it.",
      "word_count": 26
    }
  ],
