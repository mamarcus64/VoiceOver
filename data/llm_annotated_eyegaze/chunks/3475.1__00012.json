  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And on that-- on, on, on the-- on the-- on that lot of that mill, the, the Germans came to recruit people for work in a labor camp.",
      "word_count": 28
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I found out about it because one of the girls that we stayed with, one of the young women, she, she told us about it.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I couldn't go there because I couldn't even walk, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "My fistula was really bothering me.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "So she put me in one of those rickshaws, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "They were like a bicycle-driven rickshaw.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And she, she wheeled me over on that-- on that lot.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And I had my diploma from school that I graduated as a machinist journeyman.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "So when the Germans were selecting the people to go and work in that labor camp, I presented my diploma.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And they took me, which was a big break to get out of the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And, and this way, I saved myself for the time being.",
      "word_count": 11
    }
  ],
