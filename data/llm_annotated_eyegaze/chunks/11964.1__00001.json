{
  "stem": "11964.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I say professors because they were of professorial caliber.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And the teaching there was on a very high level.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I received, for example, my education was in all possible subject matter, including five years of German, five years of Latin and Hebrew.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So that was-- and-- and I studied all kinds of subject, geometry and algebra and psychology and biology and zoology and geography, and, of course, Polish history, Polish literature, and such.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We grew up-- our home was in the center of the town, which used to call-- to be called Rynek, 'rynek' meaning in Polish 'market,' because the marketplace was that square which was Rynek.",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "It was the main square.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Later it was renamed the Square of the 3rd of May, 3rd of May being a very important date in Polish history because Poles received their first constitution as a republic on the 3rd of May.",
      "word_count": 36
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "We lived-- our address was Number 9, the Square, or Platz in Polish, the Square of the 3rd May, or Platz Tazhchego Maya, in-- in Radomsko.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "My father owned the house.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "It was a large corner apartment house.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "We had a department store on the ground floor and we occupied the upstairs home.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Our house was very well appointed.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "We had a private stairway going up to the apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "We had two entrance to the apartment, one leading to a kitchen and one to a den, which was my father's library, which was quite extensive.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "We had a very, very lovely living room.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "I can remember the appointments in our home.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "We had oriental rugs, which stayed only for the winter.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And they were replaced-- put in mothballs, and replaced by lighter rugs in the summer.",
      "word_count": 15
    }
  ],
