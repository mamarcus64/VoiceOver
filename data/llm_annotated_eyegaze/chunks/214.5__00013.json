{
  "stem": "214.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And she is-- you know, we are very proverbial-- what they call?",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Occupations.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And she's a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She's a physician.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "She's has a family practice and also geriatrics.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And she has been-- she never had her own office.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "She was always working with a group.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And she lives in Evanston, Chicago.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "In Evanston, Illinois.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "[CHUCKLES] You know, it's so--",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "She has two children.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Lia, who is-- who is going to be 16 in February, 7-- 11.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Tessa's birthday is on February 7.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And Gabe, Gabriel, Gabe, who is going to be Bar Mitzvah now.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Is it 19th of-- 19th of November.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "So we are going to Chicago for [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No, I have another girl, Karen, who is an over-educated person.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She-- [CHUCKLES] she was in AFSA.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "She speaks fluently Danish.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "She came back here.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She graduated from, got a-- a bachelors at UCLA with cumma sum laude.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Whatever, she's always on the top.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And then she didn't know what to do with herself.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And everybody was telling her, you know, she is such a brain, she should go and apply to a law school.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And she-- you know, for the lack of anything else, she applied to all of the six-- I think this is something interesting-- to all the California law schools.",
      "word_count": 29
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was telling her, why don't you apply to Harvard?",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Why don't they-- and she said, my parents don't have this kind of money.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "California school will be enough.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And she was really accepted to all, to-- to BOLT, to UCLA, to Davis, to I mean, to all of them, whatever there is left, Hasting, everything.",
      "word_count": 27
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And so she went to BOLT and got a law degree and didn't like law.",
      "word_count": 15
    }
  ],
