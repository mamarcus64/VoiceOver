  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 24,
      "text": "He was working with goyim.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 25,
      "text": "He got-- he got jobs from them.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 26,
      "text": "But they was rich, you know, Christian, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 27,
      "text": "They know he was the best-- the best roofer, you know, the best roofer in Zawichost, the shtetl.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 28,
      "text": "And they thought [INAUDIBLE], [INAUDIBLE], all countries what they was [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 29,
      "text": "He was a prince, like prince, rich, very rich.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 30,
      "text": "They have a lot of places.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 31,
      "text": "Now, after this, they, they finished their two months, three months working.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 32,
      "text": "I remember though they give us the prince flower, potatoes, carrots, cabbage, for all winter, you understand?",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 33,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 34,
      "text": "But he was very good to us.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 35,
      "text": "Do you have any desire to visit Poland today?",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "No, no, never.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "My cousin-- my cousin went there, want to take me, you know, to Zawichost.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "She went there.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "I, I not-- I not have nothing, nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "What's the interest?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "They took away everything, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And you see, when the [INAUDIBLE] is here, I know, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I go [INAUDIBLE] with my grandfather, you know, my, my [INAUDIBLE], my this.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "You can.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, this is-- there is.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Maybe, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "He asked me, [INAUDIBLE], last week.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I, I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "There was a bat mitzvah in Pennsylvania, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I was with my family, with the cousins.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "I have cousins, his second cousins, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "They tell me, Samuel, you want go-- you want go to Poland?",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "I said where?",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "They go chase the whole-- they go around, around, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "I tell you, no, I don't feel so good.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "I, I couldn't-- I couldn't go.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "And it's true.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "I got a car, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "I can drive it.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "And I give away the car, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "Now, my arthritis and this.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "And I not feel so good.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "But medicine, [INAUDIBLE].",
      "word_count": 3
    }
  ],
