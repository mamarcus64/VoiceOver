  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] And we lived there for a while, the three of us.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Then there was some kind of agreement that Polish citizens can go to the west, to Lodz or other cities.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "So I went with this Dora Siroka and her daughter, Rita.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "We went to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "And I lived with them again.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And then her husband came back from Russia and lived with them for a while.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "And then I was able to get a job through the Polish friends, the one that helped us during the war.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "I got a job as an interpreter in-- was like an army unit.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "They were interrogating.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "They were arresting Polish underground at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "And I was an interpreter.",
      "word_count": 5
    }
  ],
