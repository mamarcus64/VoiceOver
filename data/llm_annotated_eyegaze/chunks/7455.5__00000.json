{
  "stem": "7455.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Laura was, being a Zionist, joined the organization.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And she went to the hachshara preparing herself for future life in Palestine at the time.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "There was a communal life where they learned to share and to live-- get along together.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "She met a fellow, [?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Motek. ?] He came from [INAUDIBLE], also Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Very handsome, very highly-educated, and from a fine family.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And a romance developed, and they were very much in love.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "When she completed that hachshara, she came home.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "She was quiet, withdrawn.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "You could notice that she was engrossed in-- in some thoughts.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "She was writing letters, and rush-- rushing to the mailman to pick up her correspondence.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "She did not dare to tell us, to tell mother, about her love, because she-- she feared that we may treat it lightly.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And to her, it was so important.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Sometimes she received-- mailman brought mail, and she would sit in the garden and read.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And I, even as younger, noticed tears in her eyes.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "This did not escape my mother's attention.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "She noticed it.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And she said, why don't you invite that young man to the house?",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We should meet him.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And Laura said, you mean it?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You mean it?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And my mother says, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I mean it.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So Laura picked my mother up and whirled her around, laughing and crying.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And it was decided that for the weekend, [?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Motek ?] will come.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And we started cleaning and scrubbing the house from head to toe, and polishing.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And my mother cooked all her delicious food.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And he's going to come for the Sabbath.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Motek ?] arrived.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We awaited him at the station.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Even though I was younger, I was aware of a handsome man.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He was very handsome, tall, the bluest eyes, broad-shouldered.",
      "word_count": 9
    }
  ],
