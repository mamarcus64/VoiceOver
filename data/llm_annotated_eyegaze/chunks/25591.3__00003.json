{
  "stem": "25591.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "There were no long-term plans.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I-- I didn't when-- when dawn broke that I will end that day still alive.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, I did not know.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Protected houses.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Swedish protected houses.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "No, they were gone.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They were gone.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The only person I know-- the two people I knew-- and I lived the last few months of the war period with them-- were my mother's number-- my mother's family had four children.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "My-- her parents had four children.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "The oldest child was a tremendously impressive woman.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Her name was Wilma, and our younger daughter reminds me of her very much-- beautiful, statuesque, decisive, strong.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She perished.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "The number two daughter, Margaret, survived the war in this apartment with me.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Her husband, Alexander, survived the war in this apartment with me.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "The third sister was my mother, who perished.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how and when.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And the fourth one was her younger brother, who perished on the Russian front.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "The only two people from the family that I had contact with-- and it was more than contact with, because after my aunt's husband died, I arranged for her to go to Vienna.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And I flew to Vienna and brought her back with me.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I held her hand in the plane all the way from Vienna to New York.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And she had blind faith in me.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "She was a very-- she was a very-- she was a musician and the teacher of music and a lovely woman.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And I love-- I loved all of them very much.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "There's very, very-- I-- I mean, I really had three mothers, both my mother and her two sisters.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And-- and there was really no difference.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "We were so close.",
      "word_count": 4
    }
  ],
