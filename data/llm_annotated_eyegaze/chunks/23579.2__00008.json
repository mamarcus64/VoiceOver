{
  "stem": "23579.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "So Lea's mother and father-- Lea, that you had the interview with her.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "They had a house, and there were the Judenrat.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Lea [INAUDIBLE] Frydberg.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Her mother her father, they took us in.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And they gave us a small place where we were sleeping on the floor.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They gave us a small piece.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We could already sleep there.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "They took it out, all the Jewish people from the houses from the whole city.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And the put them in a small place they called ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they made a fence.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Sure, they made a fence with this.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And the police, Polish police, and Ukrainian police, and German police were surrounding us.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The fence, a big fence with the [NON-ENGLISH], iron.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't go in.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Wire, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they had big dogs.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Big dogs.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Who was guarding?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I said to you.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "The Polish police, the Ukrainian police, and the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "The worst of all of them, they were the Ukrainian.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The Ukrainian were the-- worse from Hitler's.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I didn't count them, but this was-- you know what?",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Like you see the bees-- bees with the making honey.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "So the whole house was a very small house.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But in one room, maybe it was about 20 people. 20 people, for sure.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And one lived with the other quietly.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And in the morning, they went to work, everybody.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They went out from the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "They took them to the city because the city was ruined by the bombs.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "So they clean up the city.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And they were working there.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "How many?",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "My brother was in the police.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Yankele was in the police, and he was inside the ghetto.",
      "word_count": 11
    }
  ],
