  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And then we had one-- one brush for shaving.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "He had only one brush.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And one day, he-- he comes to my room.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And we shared the brush.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And he said, I am going to town.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Give me the brush.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And I have to shave.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So I gave him the brush.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And after five minutes, I hear the voice of Liza, one of this-- Grisha, Grisha, Grisha.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I come in, into the room.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And this young man is lying.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He got a heart attack.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And he was dead.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And then the whole people from the neighborhood came in, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "It's [NON-ENGLISH], a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And the doctor didn't come.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And the doctor came in.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Then I was scolding him.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "Why did it take him so long?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I completely forgot at the time I was Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "I completely forgot that.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "I didn't-- you know, the only thing was [?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Lonya. ?] Because I realized if [?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "Lonya ?] is not alive, I cannot be alive.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Lonya ?] was this man who had died.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "His name, [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Lonya, ?] yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And well, later, the doctor went.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And the neighbors went.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And-- and yeah, and I ran away from Lodz in one shirt.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But it happened to be a shirt that [?",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Lonya ?] once expressed his opinion that he liked the shirt.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And then Zoya came in and asked me whether I'll allow to use this shirt to prepare [?",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Lonya ?] for the funeral.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And you can imagine that I didn't refuse.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, so they-- they dressed him into my shirt.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And then they dressed him up.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And then she comes in, and said to me, Grisha, you would like to see how [?",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Lonya ?] looks now?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And I went to the room, where he was lying.",
      "word_count": 10
    }
  ],
