{
  "stem": "9489.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So he took a photograph from our whole unit, a girl.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "She made the pictures.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Somehow, I don't know, she's dead and no pictures.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And that was in 1950.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In time for our wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Three days after that, they find you dead-- burnt, you know, in your apartment and no pictures.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if yes was pictures.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I don't know-- no pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't get the pictures.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And the girl, poor girl-- they kill you.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And that was my present.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And we were-- we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "We went to the centers to [INAUDIBLE] beautiful home-- in Hadera, excuse me.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "In Hadera, they remodeled a beautiful apartment for us in the police station, just eight apartments, something.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And the chief police, we got-- only-- I got off in a few days for honeymoon like.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't have honeymoon.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have money or nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have a place to go.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "So the chief of police have us his limousine, give it to me a gift for two weeks to travel Israel.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Give me three-- two weeks off, his limousine, to go with my wife.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So we went to Tel Aviv.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We went places.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "You know, family we find, friends.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We spend the two weeks with this limousine.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "We come back and our apartment was beautiful apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And my wife got pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "She got a job, kindergarten.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "We were making-- there was 28 pounds a month.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Was for one week to buy food-- her wages, my wages.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "So we couldn't survive.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I went to work in [? parks, ?] for a taxi driver, you name it-- with permission.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And my wife got a beautiful job.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "But she got pregnant, and she couldn't carry on.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "It was very heavy pregnancy.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So then they transferred me to [?",
      "word_count": 7
    }
  ],
