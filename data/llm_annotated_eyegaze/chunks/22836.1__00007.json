{
  "stem": "22836.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And they put me in like I'm a communist.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And they come in, and they put in a communist.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "We don't know what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And the police coming in and start looking the house.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And they find under the-- under the-- where we keep always for the cows.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "It's a big, big cans to feed them, the cows.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And he put in that thing under that-- under that bucket.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And we don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "The police come in and start looking.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "They're looking all over.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "They can't find it.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "Then they went out back and ask the man, you say he's a communist.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "We can't find it.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "He says, go under the barrel, and you'll find it.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "Then they went in the barrel, and they took me, and they arrest me.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "They say a document, and paper, I'm a communist.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Like UGA or something.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "They put it in.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And they took me away.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "You know, that time it was a big shock.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "They took me away to the police, and the police there took me to Kolki that time.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And there was all in the whole town, the whole Kolki was mixed up.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "They know I'm not a Communist.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "I'm, I'm a religious man.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "I'm my religious-- all of a sudden I'm a Communist.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "They keep me there for a week, and after that, then they let me out, and I come back home.",
      "word_count": 20
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 11,
      "text": "That's-- the Polish people was more against than the Ukraine at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I confront him, but I couldn't-- I couldn't do nothing to him.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "He was a Polack and the police Polacks.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I just took-- one Ukraine was mixed up too with them.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "The Ukraine, it'd-- and one of them a Polack, I sued him later.",
      "word_count": 13
    }
  ],
