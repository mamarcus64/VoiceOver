{
  "stem": "2226.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We were in the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "There was-- there was-- was  a factory, the union-- union.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "An ammunition factory-- the union.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So the girls worked over there.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So-- and I had my girlfriend from Ciecanhow.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we were talking.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And she-- she-- the girl's brother-- that, I told you.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And-- that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And she gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And if I was in nighttime, if she went, she didn't give it to me.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "She give it to my wife.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And she gave it that girl from Degania in Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "But she had a stroke, no?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I could have created only hand grenade.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "So, yes--",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I-- OK.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "See I-- like, I was mechanic.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So I had a little shack.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I would say, I have-- I have that room.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I have the-- I have the-- the-- this-- this room.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Had over there welding.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "See, my job in-- in-- in Birkenau was to hang lamps and shades.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "You have a-- you ever been in Birkenau?",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Anybody was in Birkenau?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "To hang the lead-- to make the shades.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "You know where the crematorium is-- the-- the poles.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "It was our-- the pole-- the poles from-- from the-- from Birkenau?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "The cement poles, like you hang the shades?",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Can I use my hand?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So the shade is here.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Here is the shade.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "That's a shade.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "In here, goes the socket.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "This lit around all the camps with the number A, B, C, like that.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "They were lit around the camps.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So I made the shades.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And here had to be a piece of pipe, like this, like a handle to hold on.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "So there was the cement poles.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "In the cement pole was two-- two-- two holes.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And see, I weld up two brackets.",
      "word_count": 7
    }
  ],
