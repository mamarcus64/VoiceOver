{
  "stem": "3928.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I can tell when-- that-- when they brought over the dive bomber from Germany, you know, the parts and everything and assembled it, right there, in Csepel Island, which information was important, for instance, for the air force to know what to bomb and where to bomb.",
      "word_count": 47
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "You know, then that's the information I was giving to the underground.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes,",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Bela Vanczak.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Bela, B-A-L-A-- B-E-L-A, and Vanczak, just like I-- the factory I-- that Vanczak.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He-- he is-- he owned the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He is the one who owned the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And his-- his father was the Janos Vanczak, who was the head of the Social Democratic Party.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he was the head of the-- the-- he was a senator and so on, You know",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The people who raised me was my aunt, Margaret Vanczak, who was a mother-- a-- a-- a sister of my mother, and her husband.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] they were the people that really raised me.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Not much.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My father-- I-- I loved my father, very much, you know, because I was-- he was very good to me when we came together.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "You know, he came to Budapest in business, quite a few times, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I had a good relation with my father.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Then vacations, sometime, I went down and spent a vacation down with them.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But I, as such a real, close relations, I did not have with my father, because my stepmother, for some reason, wasn't exactly-- I wasn't exactly her favorite, you know?",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And despite the fact that my stepbrother and I, we were very-- we loved each other.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "You know, real brothers couldn't love each other than we did, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "But it's-- my stepmother did not expect it.",
      "word_count": 8
    }
  ],
