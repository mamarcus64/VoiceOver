  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I-- I never remember getting a-- ever getting another uniform.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I mean-- so maybe-- I don't know-- but at least you could take a shower.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A constant.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That was a constant process of delousing.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But I would not even-- many times I would-- I would take my-- I would strip, and it was under freezing conditions.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Because they had showers on the outside, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So the water became ice-- icicles.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But at least I was able to spread my shirt and take off my trousers and spread it out so that the lice would freeze.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And-- [PAUSES FOR 4 SECONDS] and so this also helped.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Because you were eaten alive from-- from the bugs.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And then what happened to you next?",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I kept working on the same-- but we had a-- a-- a lagerfuhrer.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] Maybe he was the reportfuhrer.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "His name was Schamal.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He was a sadist, a murderer.",
      "word_count": 6
    }
  ],
