{
  "stem": "9230.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He came from France, from Paris, to visit his mother.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "In the meantime, he was working on the beach, a safeguard.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Before the war.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And they-- he fall in love with me.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And he didn't want to go back to France.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And we thought everything will be OK.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We've made it.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And when the time-- when the German came in, he run away to Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And after he came back, we married and went back to Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And the Russian soldier, they catch us on the border.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And they keep us the whole night in like a ice box.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And next day in the morning, they send us back.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "To Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And my husband, he got pictures.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And they was checking everything.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "If we have jewelry, we have money, they want to take us-- they want to take away from us.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And he found a picture, my husband, in the same club with him.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "The SS man.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "SS man.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Because he grow up in Frankfurt in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "After they moved to France because his sister married from the Singer factory, a son.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And that's why they moved back to-- from Germany they moved to France.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And in France, you can never get citizen papers.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "You can live your whole life, only when you have a son in the army.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So she went also to concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And she came from France to make for her daughter a birth certificate, to take out the birth certificate.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Her daughter used to live in, in-- my nephew lives there now-- in Portugal.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Came to make a pass-- take, take out-- to make a passport and a birth certificate for her daughter from Portugal.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And he came to visit his mother, and he fall in love with me.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
