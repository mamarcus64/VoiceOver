{
  "stem": "1316.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And we left on the second hour.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "We left the school without permission, and we joined the protest strike, to attend the protest strike.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And later, we were in trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We were-- the principal inquired who was the organizer?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Who was behind it?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We were all solidized.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "The whole class left except one.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And-- but they forgave-- they forgave us.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We graduated.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We graduated the school in 1936.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And then I-- a few weeks after, under the influence of a friend, he enrolled me, or he told me to come to a-- a-- a meeting of the illegal communist youth organizations.",
      "word_count": 33
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Those were a small groups, underground groups.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I was appointed secretary.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "We met each week or each two weeks in a park or in-- somewhere else at illegal meetings.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And soon, I was arrested with a friend.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I was 15 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "The other one was maybe younger, from 14 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And we went-- we went outside or towards the-- a [? resort ?] place [POLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And we passed by the police station.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Police was suspicious.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "He came out.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "He took us in, and he advised us.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And he found [? those ?] lists for Spain, collect-- to collect more for the Republicans in Spain and some illegal paper.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And they took us back to Otwock for the jail, to the police station a few days.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And then they sent us--",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was the-- it was the office of the police.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And behind were two-- two rooms, dark rooms, with the-- with the cots.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And we laid there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we were-- we were investigated.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And we told them, we didn't know.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Somebody gave us and so on.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "But they sent us-- they said to send us to Warsaw.",
      "word_count": 11
    }
  ],
