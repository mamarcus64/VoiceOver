{
  "stem": "16571.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 378.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And I've read since that 55% to 60% were chosen for work.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Previously there was less than 35%.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So that is-- what can I say.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "A bit of luck in our respect for our villages from where we came from, our part of Romania.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "As far-- as far as I know, that's what I read.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Whether it's true-- or must be true if it was in the library, in the books and all that.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So-- So the first night you were there, and you were taken to--",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I was together-- it was two or three nights.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We were together in the Block 55, which was right down at the bottom of Buchenwald-- of Auschwitz.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We were taken-- my brother was called out first, about three days later.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I've not-- I have not seen him until first time we met in '55.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "That what I'm talking about, '44.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Or 11 years I've never-- I haven't seen him.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "My father was called out about three-- two or three days later, and I was left on my own.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I remember I was a very fussy eater, and my father was begging me to eat the soup.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And it was ghastly.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And he said, you won't get another one here.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "You got to eat it.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "It's not-- you're not at home.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And I was nearly sick, just drank that soup down like I gulped it down.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And then as I said, two or three days later my father was called out and taken away.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And I was left on my own.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And then a week, 10 days later, I myself was taken all the way to Buchenwald.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And I finished up Block 8 in Buchenwald, which was a children's block.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "It was run-- run by a Russian kapo.",
      "word_count": 8
    }
  ],
