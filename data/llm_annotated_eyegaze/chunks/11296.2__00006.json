{
  "stem": "11296.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And there was rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "They told us to undress.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "They put everything neat, and who knew where it would go.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "So everybody put away nice their clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And nobody had nothing already, just the clothes on them.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And they told us to go to another room.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "The other room, there was a lot of steps, and to sit down on the steps.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And they said, here, they're going to shave us, and they're going to do the other things.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "So we went in the other rooms.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "And a few minutes later, the men came in, not women.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "Everybody was naked.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "[BACKGROUND NOISE] And the men came in, they told us to spread our legs, to spread our hands, they shaved us wherever there was a hair on our body.",
      "word_count": 29
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "They shaved us.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "The instruments that they was holding, they were probably used already on thousands and thousands of people.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "The blood that was flowing from everybody-- from their heads, from their arm pits from everybody.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "And the humiliation, the feelings-- this is a most terrible thing that can happen to a young girl.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 30,
      "text": "When somebody-- you know, you've never undressed for nobody, just for yourself, and here comes bullies.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 31,
      "text": "Who knows, maybe not.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 32,
      "text": "I don't know what kind of men these were.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 33,
      "text": "This was the things that they had to do.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 34,
      "text": "They shaved us.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 35,
      "text": "After the shavings, they put some cold water on us.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 36,
      "text": "And after the water, you know, nothing-- nothing to dry up.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 37,
      "text": "No towels, nothing to dry up.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 38,
      "text": "They put some powder.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 39,
      "text": "Oh, they went with a little machine and they was spraying, a sprayer.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 40,
      "text": "A big man was going and pumping and spraying everybody's heads.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 41,
      "text": "And they start giving us clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 42,
      "text": "The clothing was from already people who died.",
      "word_count": 8
    }
  ],
