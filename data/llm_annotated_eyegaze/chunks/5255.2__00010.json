  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And we also had people that came to Warsaw and stayed with us in our apartment from that city.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Back to Plonsk.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "This time I came to Plonsk was in also 1942, around October, the end of October.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Next, we had new things happened in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And The Judenrat announced that the ghetto is being liquidated.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And all the inhabitants will have to leave the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They will be transported someplace, to nobody knew where.",
      "word_count": 9
    }
  ],
