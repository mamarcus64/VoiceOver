{
  "stem": "8725.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My sister did take care of the Swiss for the offices.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And she was not allowed, really.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "She was helping in the  kitchen-- you know, like wash the dishes.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Help a little, but was not allowed to go  herself.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "That was my-- I told Schultz, I don't want her to go into.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So one day, we did have a Jewish man and woman that were assigned to the kitchen-- young couple.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They were just married.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "In a-- in the-- in the war barracks, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And they were helping.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And one day, we prepared big parties.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And who is walking in?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "The Sturmbannfuhrer Keitel with a Ukrainian girl.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And the major told that there is a Polish girl that is working there.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "So she came flying with, oh, oh, so nice to meet you, and this, in Polish.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Oh, I am here.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I wanted to be friends with you, and this.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And then she looks at the Jewish man.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 5 SECONDS] I was trying to know, in a book I have, his name.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "He's looking at him, and he said, what are you doing here?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And he said, he said, you can poison.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "You work in kitchen?",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "You can poison all the officers here.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And the, and the Sturmbannfuhrer Keitel.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "He did have big, big eyes.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "He said-- she started the scream.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "Schultz walked in, and he said fraulein, we set the dinner.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "Would you please go out?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "I felt like to take her by, by the head and really punch in the nose.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "Where would we find out?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "He was in the-- starting in school with that girl.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "And she wanted him to marry her.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "You know, she was a pretty woman, and he-- and he instead-- you know, that was before the war.",
      "word_count": 19
    }
  ],
