{
  "stem": "25288.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "When I came back I asked the town people what happened?",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "You know anything about my family?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "So they told us what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "One day they-- they took all the people to the temple and then a couple days or a week or so they took at the [INAUDIBLE] the [INAUDIBLE] we had from them.",
      "word_count": 32
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "They took them then to concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Not anything from my family.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Nobody knows anything specifically from my family but they-- they were talking generally what happened.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "Then was waiting there when people came home somewhere.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "From-- first was the came back the people from-- from the labor camp.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They couldn't give me any information, and we couldn't get anything.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Then later on people came back from concentration camp, and I asked them, did you know-- do you know-- do you know?",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Do you remember this and this and nobody could tell me anything.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Later on, many years, later and I-- then I find somebody, a woman, who said, I was with your sister and with her daughter.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She said your-- her daughter was very sick and one day she died.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And then couple days after, your sister died.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "She couldn't remember where was, how was.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "That's-- that's all he could tell me.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "That was my older sister.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Ilonna, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Later then I met some gentleman.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So those-- those years whenever you met somebody who came back from concentration, you-- you ask question.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Did you know anything from my family?",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "So then I met one-- one gentleman who said I was with your brother in-law, Katz.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Samuel Katz.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "He was a tall man.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "He was a strong, tall man.",
      "word_count": 6
    }
  ],
