    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "But at least we had an opportunity to swallow a couple of raw potatoes or carrots, whatever was there.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Otto Moll was an individual who was a sadist.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "He was an alcoholic, and most of the time he was drunk.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And that's when I really came eye to eye with executions and violent behavior.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And you see how people were killed and hanged.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And a friend of mine got 30 lashes, because he was caught praying one morning.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And we had to carry him back.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "This was-- [PAUSES FOR 4 SECONDS] you can't describe it with words what we saw there.",
      "word_count": 16
    }
