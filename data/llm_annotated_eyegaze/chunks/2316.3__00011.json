{
  "stem": "2316.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I was so humiliated when I found out that it was me causing my dad to look like that, and everybody else looking at me and staring at me, and even teasing me.",
      "word_count": 33
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "You know, my brother and another boy, same age, they were teasing me, laughing at me.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I was so angry.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "I was angry why it had to happen there.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "I was angry why I wasn't told.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I was angry.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "I was just angry.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Why-- why is it coming to me.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "What do I have.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "What kind of life is it.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "What do I need it for.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Why didn't we go to the ghetto and get killed with the rest of our family.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And I was just so sad.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "I wanted to kill myself.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "I really wanted to kill myself.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And of course, they protected me.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "My parents protected me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And again, they save-- you know, they saved me.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And there was another sad incident in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "There was a cave not far from us.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "And there was a mother-- not a mother.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "There was a father-- a landsman-- a father, a child, and a few other people.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "The little girl couldn't be more than three or four-- three years old.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And the little girl not very, very sick, and she died.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "And we had to leave-- they had to leave their cave because somebody spotted 'em.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "And they spotted us.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "So we all left our caves and we left the little girl under a trash of leaves.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "We covered her with leaves.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "And we figured maybe next night, when it quiets down, in the dark we'll go and bury her.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "Well, we all came back to bury her.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "And she was breathing.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "And my mother put her in her bosom.",
      "word_count": 8
    }
  ],
