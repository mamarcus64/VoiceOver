{
  "stem": "17515.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 99.7,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "There were already architect from Berlin come, they have to take off the roofs, make them two, three story higher.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "One story, like it was, you know, there was-- from before the war.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "On the floor.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "1,100.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Maybe 1,200.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "We sleep like a sardine.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I guess.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "In the summer, there was-- it was very hot.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Impossible to--",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, there-- there-- our clothes take away from us.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "At the beginning, we-- we be in our clothes, but when we went to take shower, I don't know when, next day maybe, they take away our clothes.",
      "word_count": 28
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We get the prisoner clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Like you saw [INAUDIBLE], blue and white, on some like that.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Stripes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "In the winter time, we got different clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They were more heavy.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "In the summertime, you had the more light, blue, white, a little bit lighter.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was a cook-- cooks, there was-- there was kitchen already made.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "They made us some kind of soup.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Prisoner.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "There was already prisoner already.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "There was first prison, there was from Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "In the-- [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "They coming from [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "There a-- a couple hundred people, Polish people already from [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We were big-- big-- were the first transport from the Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "From Krakow and [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Because the number, there was one number, Polish man was number one.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "They had 2,000.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "That was-- he was before me.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Number one, number three, number four.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Because there was-- start from number one.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "On the uniform, on a small cloth.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Whatever the [INAUDIBLE], and I believe Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] I was a political prisoner, because-- which-- I belonged to no [INAUDIBLE] organization because I was too young.",
      "word_count": 19
    }
  ],
