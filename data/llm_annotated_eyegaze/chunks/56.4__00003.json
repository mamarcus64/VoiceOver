{
  "stem": "56.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And they-- they put us on a high bunk that was maybe two feet from the ceiling.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And it was so hot there.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "There was no air.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't breathe.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And I said to my cousin, I'm not gonna stay on this bunk because I'm gonna choke.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And she says, there's no place you can go.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "I said, yes, there's a big oven in the middle of the-- of the--",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Barrack.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "There was a huge cement block, which was a oven.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I said, there's no one the-- down there.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I'm gonna sit down there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And she said, they're gonna kill you.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I said, I'd rather die down here than-- I'd rather they kill me than die here.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And I jumped down, and I sat down there.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And immediately, a-- a couple of the girls that were working there came running and they said, you can't sit here.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "You've got to go back up or you're gonna get beaten till you go up.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And just then, there was a little girl that came over.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And she was maybe six years old.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And she went away, and she came back after a while.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And sure enough, she brought a pillow and a blanket, and she brought me a sandwich.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't a covered sandwich, but she brought me a bread and butter, and I think there was cheese on it.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And she sat down, and she told me, don't be scared.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "As long as I'm here, nobody's gonna hurt you.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The blockalteste, in each cell block, you had a head.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She was the head of the cell block.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, she had-- oh, she had all the privileges.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She was the one that dealt with the Germans when they came in.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And she had privileges.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And she had boyfriends.",
      "word_count": 4
    }
  ],
