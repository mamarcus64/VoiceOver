{
  "stem": "365.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The blue cards I was getting when I worked in the glass house, before I was in the camp, not in the camp.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "At first, the first months or so, I worked cleaning up the construction sites where previously they were building the Reis Autobahn, the superhighways.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Then I was chosen into the burial brigade to bury the dead, which we had, every week, about a dozen to bury.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So we go twice weekly or so, load up the wagon with the dead, take them to the neighboring town, which was called Falkenberg.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "There was an old Jewish cemetery in town with Jewish headstones.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "It was pretty well full.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "So we filled up that cemetery.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And then we were burying the remainder of the dead on top of the old graves.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "You only dug out four to five feet and put the corpses in on top of the old graves.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Within a couple of months-- by about 10th of March, April-- we had completely filled up that cemetery with the dead.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Then the last months-- like in April, May when I was there-- we buried the other dead in a clearing in the forest beside the camp, taking them out and burying them there.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They were no humans.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "In Brande, I remember burying two of my Jewish friends.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "One's name was Korszu Gershon.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And other, I don't remember even his first name.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Kava was the second.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Now, Kava was the son of a wealthy Jew, the son of an engineer.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "His father was employed in the huge steel mill, the only Jew that worked in that steel mill.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I believe they were French citizens.",
      "word_count": 6
    }
  ],
