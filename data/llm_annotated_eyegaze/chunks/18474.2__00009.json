{
  "stem": "18474.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 438.0,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "My sister Jean went over there three days later at night, in evening.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Everything was on at night, not during the day.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Nothing was-- and sure enough, he had a-- a pot full of that stuff.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "He brought back, we put that stuff on.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And this spring start to come already.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "We put it on like somebody peeled her a banana.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "The stuff disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "Then we figure at night, we're going to take a bath.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "We took like a big-- from wood, you know, they used to-- they wash clothes in it.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "We got some water in the middle of the-- of that barn.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "Took a bath, and that was a big mistake.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "The disease came right back.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "We didn't have no clean clothes and stuff like that.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Anyway, put on that stuff again.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "We didn't wash ourselves no more.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "Didn't get washed for God knows how long.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And it helped us.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "And they never find out that we were diseased.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "And that went away.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "During that time, he didn't have enough to give us to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My sister used to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "That was daytime, used to sneak out, put on a scarf, look like the peasants, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We knew certain people we could go to, pick up couple of breads, a bread, or whatever.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And sure enough, and I used to go out once in a while to [INAUDIBLE], certain people.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And we-- one time we didn't have no-- didn't have enough food in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We-- we brought them in from a different farm.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We stole that, brought it into, and they never knew.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Never-- he never asked where it came from.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "In the wintertime, in the spring already, didn't have enough to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "A little further up there was a little creek going there.",
      "word_count": 11
    }
  ],
