{
  "stem": "3757.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I am a long-time customer of yours.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We sold wholesale [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I ordered always by mail.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I say, were you in 1944 in the sanatorium in Budakeszi.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "He says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "But how do you know?",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I ask, do you remember there was there a girl, Irene from [NON-ENGLISH]?",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "I said, but how do you know all of this?",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "I say, because I was this girl.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And I want to find out-- you didn't want-- once I talked to you, you never asked me to talk to me again.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I thought now he will tell, because I recognize.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He said, I am a pharmacist.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I have a lot of friends doctors.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I didn't want to go to the army.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And I got from them a certificate that I have tuberculosis.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And they had a friend in this sanatorium.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And they kept me there as sick.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So I didn't want to talk too much.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] So, again, I was afraid of him.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He was afraid of me.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "This was the second.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And the third was, a man came to the business and said, I came to say thank you for you.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "What for?",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "You saved my life.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was a long-time customer in your store.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And you made for me an arch support.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And I came that it no good, hurts.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Only I wanted to see you.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I was in Ukraine.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And was this very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And I always saw your face and to tell me, hold on.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Hold on.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Hold on.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And so I feel that you saved my life.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Never this man came again.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "Only came to thank me for his life.",
      "word_count": 8
    }
  ],
