{
  "stem": "1965.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 77.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "It was That's how-- that was my first movie in my life, at age nine.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So that was quite an experience right there, fantasyland.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "--and father--",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "--and my two brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my sister, Sara-Golde, she was born in 1950, after the war.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We all lived at 32 Van Diepenbeeckstraat.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We stayed there until 1953.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And on June 3, 1953, with the help of the Jewish Joint, we migrated to the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Would you believe the coincidence?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Zurenborgstraat before the war is, and still is a one-block street, located between Lange Leemstraat and Mercatorstraat.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And Van Diepenbeeckstraat is adjacent to Zurenborgstraat, which is also one street, one-block street, located between Lange Leem and Mercator.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "We lived before the war on one side, on the left side, and by dividing by-- by a block, on the other side, which was Van Diepenbeeckstraat.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And the house we lived in, which was donated by the Belgian government, we paid the minimum of 500 Belgian francs a month in rent.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Many times we didn't have the rent, and the Jewish Joint helped us to pay the rent.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Many times when we did not have the funds to eat, my brothers and I would go to the Jewish Joint and eat a meal.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Many times if we couldn't afford certain clothes, the Jewish Joint would always clothe us, when my father didn't have the money to clothe us.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "As much as he fed us and dressed us, there were times where he could not.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "The Jewish Joint was always there to help.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "The organization is unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "In the Jewish life, we were-- we are taught from the beginning always to do tzedakah.",
      "word_count": 16
    }
  ],
