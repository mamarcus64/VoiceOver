{
  "stem": "11175.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Out of the camp.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Out of the camp, and walked, you know, about-- it's the place where the graves were there, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Walked about 300 feet, 300 feet, maybe more.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Well, somewhere around there, to the [NON-ENGLISH] and we were working.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And the SS man took us there to work.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I had-- had Stubel.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I had [INAUDIBLE] I-- I have the whole-- I have the whole name from-- a list of-- you wouldn't believe it.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I have the names from all the-- I have it somewhere.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I-- my mind-- [LAUGHS]",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Was a kapo.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] it's-- was a Jewish boy.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Or he was not-- he was not a kapo from that camp.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He was a gruppenfuhrer from that group.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I don't-- I-- he-- I know he was from-- from Sokolov.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I know the-- the town from where he was there.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember the-- the-- a Jewish-- I-- a boy.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "That's all right. yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We brought it to the-- to the camp, you see, because the-- the cooks, they had to cook the soup there.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They didn't have electricity with-- they had to have that wood, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The outside from the camp, when we went out from that camp, was a-- a-- field.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Going to that-- to that forest was also about 300 feet, more than 300 feet there, going over to that.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We walked from-- we passed by the holtzplatz, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The holtzplatz is the place where we brought that wood.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We chopped up wood in pieces and put them together.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And this was-- this was-- we had to pass by this-- this place, go out a gate, which was a guard there.",
      "word_count": 22
    }
  ],
