{
  "stem": "13395.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "First night of Passover.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My mother says, stay indoors.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "All winter you are sleeping, hiding in the barn in that cold.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I hear a rumor that they don't need anybody anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "The camps are full.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And so I listened to my mother, like a good girl.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And in the middle of the night, banging on the door, yelling and screaming outside.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And my mother opened the door and they took me.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] My sister's gone.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "My father stand still.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "My mother, they cannot protect her.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "The youngest child is taken away.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "There is nothing they can do.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And I'll never forget the look in my father's eyes.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "He came to be reunited with us.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And now, one by one, is being taken away.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "The next day, they marched us to the station.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "There must have been about 80 or 100, I don't really know.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And the mothers were standing on the sidewalk to wave their last goodbyes.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And some of them, most of them, would throw little parcels.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "My mother threw something at me and I picked it up.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And when we came to a holding camp in a neighboring town, [PAUSES FOR 3 SECONDS] they-- we opened it, what the parents gave us.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "So some mothers sent the kids acid, muriatic acid, with a little note.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Put it on your hands or your feet.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Then when the doctor examines you, if you are capable of working, and he'll see all those burns, he'll send you home.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "My mother gave me a bottle of what we called here Tylenol or aspirin.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Called Togal at that time.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I think the Germans still manufacture it.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And she asked me in the little note to take it all at once.",
      "word_count": 14
    }
  ],
