{
  "stem": "2097.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "Not in Romania, in Hungary, Hungary.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "He wrote to us that we should go to his place.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "They-- the-- almost the whole family remained alive because of the Red Cross, what Wallenburg sponsored in Budapest.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "And the whole family, they could return.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "They had a farm.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "So they had food and they could have-- host us.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "But only this girl went there, one of my cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "And later on, she married another-- some, another Jewish young fellow.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "And both of them, they converted to Christianity.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "Their children, grandchildren, they grow up as Christians.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "With my other two cousins, Eva and Yboia, we remain at my grandfather's house.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "My mother's brother married my husband aunt.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "We were not related.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "But the family was-- inter-- had intermarriage.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So my first cousin, they were first cousin to my husband too.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "One of his older brother who returned from the Holocaust came there and took the-- the first-- they asked the first two cousins, Eva and Yboia, to go to their house.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Because they-- already, they had settled somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And because I would have remained there alone, he said, no, we can't leave Elly by herself.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Especially he knew my mother and my father and one of my older brother who never returned.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He was courting my mother much longer than I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I mean, I wasn't alive at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And we-- I went with them there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They returned to Marghita, but I didn't.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I remained there.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And later on, my husband-- at the time a young fellow-- he also, after four years of suffering, he survived.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "We got engaged and later on got married.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed there in Varviz until 1959 or '60.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Then we moved to Oradea.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "I realize that I have two Jewish children.",
      "word_count": 8
    }
  ],
