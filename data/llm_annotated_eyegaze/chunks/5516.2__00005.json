{
  "stem": "5516.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But we couldn't have connection, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No radios.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No papers.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if we could have even a pen or pencil.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We was in ghetto, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I was living in the ghetto, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "With police-- the Lithuanian police.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Barbed wires, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "They used to allow to go just to work.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They used to take people factories used to call up.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And they used to send them out to work.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Or the military-- the German military.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I was out to work in my little shop.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We worked for the-- the city took over.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "A Jew couldn't have it-- the city, when I was managing with my brother, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "But I used to take out from the ghetto 60 people to go to work every day to the shop.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No, we made rope, too, because my brother come over from Panevezys, where they was holding him in the factory.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "One was a small little shop from rope in a Jewish man had.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He come over before the German come in.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And he worked with him, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Because I was allowed to have a little shop in the Russian's atmosphere, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But after this, when the German come in, we used to make in the same place, we used to make the-- because the city put a-- the brush shop was in my house.",
      "word_count": 33
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And I couldn't live there.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "They took out this, and they, they give a place, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And there's a bigger place, they used to make rope, too.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "Not in big scale, but we used to make it.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto maybe was-- there was two  halves of the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They not in one place.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Over the street was another part, near the cemetery.",
      "word_count": 9
    }
  ],
