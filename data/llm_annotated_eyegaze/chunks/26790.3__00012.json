{
  "stem": "26790.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They used to spray it, spray it, infections, you know, a-- against the sickness.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I was working.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "How long?",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Till I was call up in the army.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Few months.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "She--, she--, she--, she-- stopped there and she was working.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "She stopped there.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't know what she was working.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She was doing work.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "She was making dresses, and this and that.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In this-- in this village?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Shocking place.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Our house is built not of bricks, not of wood.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Just some pieces of-- of-- of-- of-- of dirt.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Make into like bricks, and they-- but that, that's what build the house.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I remember one day I was sleeping, and the rain was coming on, and we took a-- we got a-- a big piece of plaster we put on the, on the ceiling.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "The rain not come on on the bed.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And there was a-- that was so much water come on out on-- on this plaster, a big, big piece, a big piece, it fall on us.",
      "word_count": 27
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] [PAUSES FOR 5 SECONDS] And then I was called up in the Red Army.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "'43.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "In January, '43.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Stayed there, stopped there, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I-- what unit?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "For two weeks, I got training.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "What training?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Just to learn how to shoot with a gun, and how to shoot with a machine gun.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Two weeks.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have anything else, just to know the-- because in the army, you learn this, you do that.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Just how to shoot with the machine gun, and how to shoot with the gun, that's all.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- I was put up to the first White Russian front, under the command, Marshal Rokossovskii.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "For sure.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "R-O-K-O-W-S-K-I-E, Rokossovskii.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Verify his name, that I was, Marshal Rokossovskii.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not his.",
      "word_count": 3
    }
  ],
