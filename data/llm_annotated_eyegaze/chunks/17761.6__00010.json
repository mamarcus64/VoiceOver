  "elapsed_s": 122.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And then, after three or three and a half years, I left and I became an educator in a village for mentally impaired and mentally disturbed children.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There I worked another three or four years.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And there I got my educational [PAUSES FOR 4 SECONDS] taste.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And since then, since 1954, I'm in education until nowadays.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "It makes already about 42 years.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "After working there, I was sent as a delegate of the Jewish Agency to Paris to lead and to organize the movement of Bnei Akiva.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And I worked there [PAUSES FOR 3 SECONDS] close to three years.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "There's one little thing which I feel it's-- gives me a lot of satisfaction.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Years later, one of the guys that I worked with them in Paris [PAUSES FOR 3 SECONDS] made an integration to his new house in the Old City of Jerusalem.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And he found, by moving from one place to the other-- he found the regulations of the first [INAUDIBLE] that I organized for aliyah signed by 20 members.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Out of these 20, 18 are living in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And that's, I think, something which is rare.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They are living and they're happy-- their families and their grandchildren, everything.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "So that's a little satisfaction of this time.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And in 1960, I came back to Israel and started to work as a teacher in the agricultural school of Mikveh Israel.",
      "word_count": 22
    }
  ],
