{
  "stem": "3040.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Of course, during the-- the four years in Germany, there were a lot of Zionist organizations at work, trying to get people to go to Israel, particularly the Revisionist Zionists.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And-- but I had two uncles, my brothers-- my my father's brothers, in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They came here in 1912 and 1914, respectively.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And we got in touch with them after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We were able to-- because I-- I-- I remembered their addresses.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Not the-- the-- the exact addresses, but I remembered they lived in the Bronx.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And somehow my letters reached them.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "The name-- and-- and in the Bronx, the letters reached them.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And we got in touch, and they sent us-- one of them sent us affidavits to come to the United States.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "But unfortunately, I did not meet any of those.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "They both died before I came to this country.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And they were young men.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "They probably died in the-- one died in his 50s.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I came to America--",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In October 26, 1949.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Not ship.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "By plane.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Why did I come by plane?",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because we had a daughter, five-- five-months-old daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And at this time, they started to use planes also for transportation, but they gave preference for people who had very small infants.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And we belonged to this category, because she was only five months old.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And we got here-- this is another story, how we got here by plane.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We boarded the plane in Munich.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And there was a stopover in Shannon, in Ireland.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And then the next stopover was in Greenland.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "It took us 30 hours to come from Munich to the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "It was a propeller train-- a plane.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And in Greenland, we-- there was a stopover of a few hours, and there was a-- no-- a blizzard.",
      "word_count": 19
    }
  ],
