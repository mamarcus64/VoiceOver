{
  "stem": "3973.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "I didn't know yet what is normal or not normal.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "I was functioning in every way, having fun, doing things, making progress.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We met through the-- her brother, who worked in the same company.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "So he arranged for a blind date with her.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "She was German.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "In the 1930's-- you may know about this-- that England arranged to allow a number of Jewish children from Germany to go to England and to be taken into various foster homes as a means or ways of escaping from Germany.",
      "word_count": 41
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans let the kids go.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So she was taken from Germany, stayed with a family in Coventry.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "She was bombed twice.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "She-- her life was saved, because the ceiling collapsed as a bomb hit the house.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Because she had a dog, a German shepherd, who just before the ceiling collapsed, jumped on top of her.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And it was killed, but saved her.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She gave birth [PAUSES FOR 3 SECONDS] to a daughter in '55 [PAUSES FOR 3 SECONDS] in May and never left the hospital.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The disease progressed worse and worse.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And finally, she died the following year at 23 years of age.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] I couldn't take the-- my daughter, I didn't know what to do with her.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I was working.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I had nobody to take care of her.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I put her in orphanage, who worked on me continuous to give her away for adoption.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Says, you don't want that.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Give her away, give her away.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "I couldn't do that.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "In the meantime, my sister remarried.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "She lived in Denver, Colorado, had a nice life.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And she had-- couldn't have any children.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "So she says, I'll take her for you.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "As it turned out later on, she was growing up.",
      "word_count": 10
    }
  ],
