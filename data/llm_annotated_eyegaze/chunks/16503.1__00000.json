{
  "stem": "16503.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Vera Eden.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Prague, Czechoslovakia, which now is the Czech Republic.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born on 7th of July 1930.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In Prague we lived on Vinohrady, which is-- Prague is not that big, and it is a sort of a part-- it was sort of a part of suburb.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We lived in a big apartment in a apartment building.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In our home, my father, mother, my older sister, and myself, and we had a live-in girl from a farm whom I remember very fondly because she apparently was hired when I was born.",
      "word_count": 34
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Anthony.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My name-- my mother's name was Francesca.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Peresles.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father was a representative of a textile firm in Prague, and he was [PAUSES FOR 3 SECONDS] traveling a lot.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He had a car even in those days with a chauffeur because he did not drive.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he was doing textile firms in the Czech Republic and taking the orders.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Whatever title it had, I couldn't tell you.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My mother was at home.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She looked after us, and she was a great mother.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My, my sister was born on the 9th of April in 1926, and she was-- she is four years older.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And she is quite the opposite of me in a way that she is very-- I'm more easygoing.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if you know the, the difference between Cancer and Aries.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "There is a huge difference, and I do believe it.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And we both represent that, that category.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was a very-- it was a very warm family life.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Though my father wasn't home, he was-- he certainly-- he left Monday mornings and came back Friday nights.",
      "word_count": 18
    }
  ],
