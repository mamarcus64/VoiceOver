  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I cannot forget because everybody knew this was the 6th of May, 1919.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "6Th of May, 1919.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And special for me, it's a very significant date because I was born on the 6th of May, but 1920, a year later.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And the reason we-- everybody remembers, because till the Second World War, the Poles composed a song.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "There is a very famous song, a church song that the Poles sing when in May.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And this song is named [POLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "It means the happy song of the 3rd of May.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Because the 3rd of May was the anniversary of the Polish constitution.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And this was the, the more important-- most important holiday, national holiday, like we have here the 4th of July.",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
