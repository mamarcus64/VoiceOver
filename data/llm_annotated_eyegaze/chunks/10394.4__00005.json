  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "When I have to go on bus that my daughter daughter wrote me, where I have to go.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And I came over there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "There was the Italian people.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "They work.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And I talked to them, I arrive, I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And my husband didn't know anything.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "He doesn't want to teach the language, nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "He's didn't work for a long time.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "Because I worked, and he stays in the home, he couldn't take this anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "And I was in the school, too, over there.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "They let-- don't let me out from the school.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "They said, Gienia, stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "You are so good.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "And I was laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "They don't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "[LAUGHS] My daughter came, she sat with me, she pitched me, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "And for three months I was sewing.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "And I got money some.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "The Jewish organization gave me some money.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 42,
      "text": "It wasn't so bad.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 43,
      "text": "Then I don't want to stay in Hartford in this section.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 44,
      "text": "I was afraid to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 45,
      "text": "And the school, my daughter went with me to the school.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 46,
      "text": "I was afraid to go.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 47,
      "text": "Everybody was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 48,
      "text": "But it wasn't so bad like now.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 49,
      "text": "Now is very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 50,
      "text": "Then my cousin says, I have a nice apartment for you.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 51,
      "text": "The section this time wasn't so bad.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 52,
      "text": "But this time now, it is very, very bad.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 53,
      "text": "I went over there, and I take this room.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 54,
      "text": "It was so bad, this room, for Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 55,
      "text": "I remember I put $500 for our rent in this apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 56,
      "text": "And I didn't know nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 57,
      "text": "They didn't tell me that I can't have for the taxes the $500.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 58,
      "text": "I gave them Leonard.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 59,
      "text": "He was a Jewish guy.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 60,
      "text": "He took from me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 61,
      "text": "And I arrived, and I work right away.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 62,
      "text": "You remember-- I don't remember shirt factory.",
      "word_count": 7
