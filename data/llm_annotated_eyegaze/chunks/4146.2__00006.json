  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] She was looking if we need some medication or something else like this.",
      "word_count": 17
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "She was doing very much a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "I-- when I saw her here, I call her-- I ask her if I can call her 'second mother.' It's marked on there.",
      "word_count": 23
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "She remembered me when she-- she saw my blue eyes.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "When she saw your blue eyes.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "When she was younger, she was a beauty.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "She was a beauty.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Beside this, [PAUSES FOR 4 SECONDS] he has a SS man what was the top from-- from the-- from the-- from this-- this camp.",
      "word_count": 24
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] He wants to kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] He wants to kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 4,
      "text": "He make in the wood a grave for 1,200 people.",
      "word_count": 10
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] There was already a few-- very short with the Russian when they come.",
      "word_count": 17
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 6,
      "text": "So he give us ammunition, guns.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 7,
      "text": "In case he cannot stop him to kill us, we should fight for our life.",
      "word_count": 15
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] In time, he talk him in to throw hand grenades.",
      "word_count": 14
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 9,
      "text": "And he throw to the next building, the next factory.",
      "word_count": 10
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 10,
      "text": "And there started to be a fire.",
      "word_count": 7
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 11,
      "text": "In not long, a couple of hours, two or three hours, they came from Berlin, and they took him away, because we was free.",
      "word_count": 24
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "First of all, I was knit sweaters.",
      "word_count": 7
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "I learned, and I know that.",
      "word_count": 6
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "I make for myself a sweater.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Knit.",
      "word_count": 1
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "So I used to work at night, and the machine is automatic.",
      "word_count": 12
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 60 SECONDS]",
      "word_count": 4
    }
  ],
