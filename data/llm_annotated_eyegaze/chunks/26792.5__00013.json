      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And in the meantime, Vaboulis got 10 years.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I was in the tribunal.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't-- there was no access.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "So I took off my gold bracelet, gave to a Russian soldier, and he gave me the opportunity to see him for two or three minutes.",
      "word_count": 26
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "So I found out that he got 10 years.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "Now, [INAUDIBLE] is a terrible camp, one of the most terrible camps in the Soviet Union.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
