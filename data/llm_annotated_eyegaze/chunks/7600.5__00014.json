{
  "stem": "7600.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.8,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 28,
      "text": "I sent it registered, I think, sent it all over.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 29,
      "text": "And of course then, I had another problem.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 30,
      "text": "How am I going to tell my uncle that I went behind his back?",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 31,
      "text": "I went behind his back.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 32,
      "text": "And I figured, well maybe if he hasn't seen him, maybe he won't find out.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "But then, when I went to-- I still went to visit, visit them.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Because they were my only family, I figured I shouldn't break up, you know, even though they were mad at me, mostly my aunt.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "She got friendlier with me than he did.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "He, he sort of kept his distance.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Because he used to take me to the pool hall.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And the guys would talk to me and make faces at me.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And I was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I went back--",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Never made it here to the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I went-- one day I went back.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he asked me for quite a consistent amount of money.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He asked me for a lot of money.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "He says, I have to take him out.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Otherwise, he's not going to.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So that's when I had to tell him.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I said, you know, I already went there.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Well, he was, he was so furious, I thought he was going to hit me.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He just went into a total rage, in such a rage.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "You went behind my back?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "This is what you get when you-- this is the thanks I get for bringing you over here?",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "You go behind my back.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And you, you make appointments behind my back to people that you don't even know?",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I mean, he was-- and then he threatened me.",
      "word_count": 9
    }
  ],
