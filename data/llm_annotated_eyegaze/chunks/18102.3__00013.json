  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "It's a train ride that's supposed to take about nine or 10 days, but it took two weeks.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "It's a single line from Moscow to Vladivostok.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "It was a single line so that you would have layovers in big cities for the southbound train to pass you by.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] We, we, of course, [PAUSES FOR 3 SECONDS] would spend countless hours [PAUSES FOR 3 SECONDS] sitting around or watching through the window or-- what the older folk did, the men's folk, certainly-- play chess.",
      "word_count": 39
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I learned to play chess by watching them play.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Much to my father's surprise, by the time we hit Japan, I could play chess, which he didn't realize happened.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] He was a very good chess player.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't until many years later that I could play as well as he could.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But [PAUSES FOR 3 SECONDS] it was-- the things I did on that train was watch out the window or watch chess.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "That was about it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Except that there was always this constant unknown that I knew my parents had, that at any time, at any place, someone could connect up who my father was and arrest us.",
      "word_count": 32
    }
  ],
