  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "They were able to secure Aryan papers.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And they did.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And I got myself, with-- you know, with his influence, I got myself a little room in a basement.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "But I didn't stay there long, because in the beginning-- on the 1st of March, two auxiliary policemen came down to that basement room where I stayed, and they told me to pack whatever I had.",
      "word_count": 36
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "And [PAUSES FOR 3 SECONDS] they needed 80 people to go to this place called Blizyn to start a new concentration camp.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "I was among the 80, and this is the new setting that I was sent.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "That was Blizyn, about 20 kilometers from Radom.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "A new concentration camp was being built there, and I was part of the 80 people who went there to actually open it.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "B-L-I-Z-Y-N.",
      "word_count": 1
    }
  ],
