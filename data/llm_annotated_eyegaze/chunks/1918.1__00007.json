{
  "stem": "1918.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And I went to public school because I did not go to the Jewish school as most of the Jewish children went because my father was-- believed in the Messiah.",
      "word_count": 30
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And Israel was not based on the-- you know, the new Israel that came-- Palestine-- he was--",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "He was anti-Zionist, so he wouldn't let us go to the Hebrew school.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So we went to the public school.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And he had a Hebrew teacher come and teach us how to pray from the Hebrew books.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Always.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "From the teachers.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "From the students.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Always.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Mainly, walking down the street after school, walking down main street, just going for a stroll and bumping into the same kids I went to school with during the day.",
      "word_count": 30
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And calling me a dirty Jew, but very quietly so that I might-- you know, they knew I-- they wanted me to hear it, but they did it sort of discreetly, whispering between their teeth.",
      "word_count": 35
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I was afraid of them.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid of my teachers.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "There was corporal punishment.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "You know, they were hitting us.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "The teachers would hit us.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And there was-- it was no fun-- not only not fun, but threatening.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And but we never knew that-- you know, nobody imagined that anything like Auschwitz can happen.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And because we were fairly safe in our homes in Hungary after-- you know, in the Hitler years.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "Not until Hitler actually marched into Hungary did everything happen with such incredible speed because by that time, the system was so highly developed that it was a push-button system.",
      "word_count": 30
    }
  ],
