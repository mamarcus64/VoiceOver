{
  "stem": "19502.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 450.8,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "You're not a human.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "I can't believe it, that I could see all that.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Then she-- then they told us-- they come out, and they said, you people are left in here to work.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And you've got to keep us-- our places clean, and so on.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And they left that time seventy women and some men, so we would do all the cleaning for them, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And-- but, and tomorrow we have to report to this and this place, which was also [NON-ENGLISH] Street.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So I went home.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Where would I go?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "People which knew what was going on, which they heard already, it was late.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They went in the attics and pulled up the ladders, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "It was a mass killing till about 4:00. 4:00, it stopped.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "They-- they were-- the old people that couldn't walk, either they shot them on the road or they put them on wagons, on the wagons, and they were going over there.",
      "word_count": 31
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Wagons, small children. 04:00 finished the mass killing.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "Go home.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And tomorrow report to there.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "What home?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "Was nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "They robbed everything.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "Everything was taken out of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "All our clothing, the furniture, everything.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "They went-- where just one lady saved me a sweater, which was Pascha.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I had no place to go.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I came to next door, and I said, Pania Anitska, I don't have a mother.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I've nobody.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "She turns around-- our curtains were hanging there already in her house.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "She says, get out from here, you dirty Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Now it's my time.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Your time is over.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I says Pania Anitska, I mean, I grew up in her home.",
      "word_count": 12
    }
  ],
