  "elapsed_s": 2.0,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 15,
      "text": "The next day I was on the train-- the whole family, two people.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 16,
      "text": "And then they tell me, it was a hoax.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 17,
      "text": "It was a hoax.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My second wife, I met at a dance in  1945-- September 1945.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "She was only with her sister, and I was all by myself.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "She was a survivor- yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "She and her sister were both survivors.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "How long did I what?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Court her?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Oh-- [PAUSES FOR 5 SECONDS] from September to-- in a different kind of courting than it is now.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I mean, we both had sores, we both had pains.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have any money to our accounts.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "When I came back from Poland I was penniless-- not even a penny to my account.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] And I got a hold of some money-- one way or another.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "I-- we start living together, even though it was with her sister, in her sister's house.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Because those two sisters were-- were married to two brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And those two brothers didn't come back, but the third brother came back. my sister-in-law married her brother-in-law.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And those two sisters who were almost always together, [PAUSES FOR 4 SECONDS] we moved in with-- moved in with them.",
      "word_count": 21
    }
  ],
