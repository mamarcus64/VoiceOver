{
  "stem": "5225.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Dankowitz.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "D-A-N-K-O-W-I-T-Z.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In Czestochowa, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in May 24, 1920.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Now I'm 75.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Uh-huh.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In Europe?",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I have-- when I was born, my mother died.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was 11 weeks old, and my mother passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And my father didn't plan to remarry.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So they try to-- I have a older brother, three years older for me.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So they tried to give away to the grandparents.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "But meanwhile, the-- one grandparents passed away [PAUSES FOR 3 SECONDS] a son-in-law.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And they got two children.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So they took it already, the two children.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They said they couldn't take a third one.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So they give me away for-- to raise me.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But it didn't help I got always sick.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "So after two years, my father remarried.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And they took me home.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "That's what I was told the story.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Well, let's just go back for a minute.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Because I want to get it clear.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "After your mother died, they gave you away to be raised to whom?",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I don't know to whom.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "For money, for money, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Right, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "To sleep over there and eat over there.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, and they paid.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I was too small to say-- tell you.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was with my grandparents, with the father's parents.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Did already have two children.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because I was-- I have a big belly.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I couldn't walk.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I got crooked legs, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They call-- they called it some sickness.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "By us they call it the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The English Sickness, right.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So they took me-- my father remarried, and they took me home.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't remember anything.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "But I remember when I was already five, and I started going to cheder.",
      "word_count": 14
    }
  ],
