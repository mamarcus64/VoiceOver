{
  "stem": "6525.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 19,
      "text": "And men were holding bodies by the legs, some by the hands, made like this and into the fire.",
      "word_count": 19
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 20,
      "text": "And we stopped and started to scream.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 21,
      "text": "It was such a shock.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 22,
      "text": "And we didn't move.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 23,
      "text": "And this picture is in front of my eyes as long as I live.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 24,
      "text": "And we didn't want to move.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 25,
      "text": "And then the girls started to scream, Go on!",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 26,
      "text": "Go on!",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 27,
      "text": "If you don't go on to the showers, you will be thrown into the fires too.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Our girls who was there for a few years already.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "You can say kapos.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And they said that they are throwing into the fires dead people.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "They are dead.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "And then we went into the showers, OK?",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "And in the showers, the brain doesn't work like it worked before.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "I had the feeling I died.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "And this is-- this is hell.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "And I live with this since then.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Later on-- we didn't believe that our parents are dead.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "They told us, 'You see the flames?",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "They are all in the flames.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "They are all burned.' But we didn't believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "We didn't take it in.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "The old people and the children went to the gas chambers, right?",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "So my mother probably was with the rabbi and the rebbetzin.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "They had to undress and to go into the gas chambers.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And they were gassed and burned, right?",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Guess so.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "My mother didn't have the dignity to die like a person.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "She had to undress in front of the rabbi.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "I will never, ever forgive the Germans for this.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "Because I was working in a munitions factory.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "I was making ammunition.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "And they didn't want to spend one bullet to kill my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "She should die in dignity.",
      "word_count": 5
    }
  ],
