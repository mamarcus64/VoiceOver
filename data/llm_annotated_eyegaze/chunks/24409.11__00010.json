  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "And we drove down the street.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And I saw a girl with a baby in her arm.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And she looked at me like [INAUDIBLE] had been her last ever.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And I [? said, ?] to the woman, says, [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "She has a baby from somebody else.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "I said, [INAUDIBLE], don't make any difference to me.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "But with me, [? she's harmless. ?]",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And we came to another house was bombed out.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The windows were-- no glass is but wooden [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I knocked at the door.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And there was-- who was answering, [? anybody ?] don't know.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I ask, I want to speak to Lore [?",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Rollig. ?] And she said, she isn't here right now.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I said, where is she?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "She said, she left in the afternoon.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "She had some errand.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Now at least she's alive.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "She got here.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "And when-- when I came out, when I spoke to her, Lore, where did you go?",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "See him running down the street.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "She has been together-- the guy who was standing with her was a son of a woman who had been her teacher.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And she said, when the jeep passed, she said, these [? aren't Russians. ?] And she said, no, these aren't Russians.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "These are either Americans or British.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And she said, Americans, that's for me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And she run down.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "She had so much confidence it was me.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "She was all packed.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "She was all packed because she knew within two weeks of the surrender, I will come.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And it took longer.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "It was six weeks.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "But I came in the [INAUDIBLE] unfortunately found out that his parents had been deported.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And she left the same evening to Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "It was a fascinating trip.",
      "word_count": 5
    }
  ],
