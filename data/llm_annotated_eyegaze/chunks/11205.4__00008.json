  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "It was a map hanging, and knowing this-- you know, my geography, they used to discuss with me to show which-- which city which is where, especially on the Ukraine side.",
      "word_count": 31
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And then-- [PAUSES FOR 4 SECONDS] when they took Chelm, I was-- I didn't-- I was still-- I was pregnant.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And to be pregnant, they had you-- you had all this-- eight months pregnant, I didn't have not one day free, not-- because they say we had to replace like a soldier on the front-- we on the back.",
      "word_count": 39
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But I got the last month.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I-- they allowed 30 days before.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And I just got it free.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "When-- and I went to visit my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "My sister didn't work.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "She had two children.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And when I went to my sister came and letter from my cousin.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "He-- they were three brothers on the front.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "One got killed, and this one-- the oldest one-- he was-- entered Chelm with the-- the army.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And he went to look for-- for family.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "For--",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Meyer.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Meyer Appelbaum.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "That was my cousin's husband.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And he sent a letter to my sister, and she didn't want to-- to read in front of me.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I was the last month pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And I said, you can-- [CRYING] That's when he-- he said [PAUSES FOR 4 SECONDS] no longer they lived.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[CRYING] But what it was when my daughter was born, I-- you know, they say in Jewish you can't name if you're not sure.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So I didn't know if my mother was [INAUDIBLE] so I called her Ann [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "It will be like similar.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "[CRYING] And then-- so we-- then we start to find out things.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And also it start already in Russia-- Russian towns.",
      "word_count": 9
    }
  ],
