{
  "stem": "7302.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Two girls, they did live close to us-- which, I spent a lot of time in their house, because they was having the mother at home.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "My mother used to be in the store with my brother, you know, helping him out.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "So I didn't have much to talk to.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "My sisters, you know, they were always busy, this and that.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So I used to spend a lot of time with them.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they have been very, very religious, those people.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They owned a store, and I went to school with them.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Did you have any non-Jewish friends?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Not exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "At school, maybe?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "It's-- where I went, it was the most Jewish kids.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And this school-- the name of the school was Kazimierz after a king, a Polish king.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Kazimierz Wielki.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Do you ever remember any anti-Semitic incidents happening as you were growing up?",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "I don't mean in 1939, but in the '20s, and-- let's say.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "In the evenings, we used to be afraid to go out, like in the dark places.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, they, they, they didn't do any big harms, but they have been drunk, and you know--",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "The Gentiles.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "So we avoided them.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "But like I'm saying, we didn't have too many Christian people in our city.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It was a strictly Yiddish, Jewish place.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "My mother's-- my father's side-- yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "He was having one sister, who lived in [NON-ENGLISH] too.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She was having, I think, to some site.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember them, because it's not where I lived.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I visited them, in all my life, once.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "But my mother was having two sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "One was [?",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "Tzirl. ?] And their name was Feldman.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "No, I'm sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "I, I have been mistaken.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "Feldman was my grandfather's name.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "Zuberman.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Zuberman.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Zuberman.",
      "word_count": 1
    }
  ],
