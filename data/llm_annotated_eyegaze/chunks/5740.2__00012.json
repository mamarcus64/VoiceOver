{
  "stem": "5740.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't allowed to go out, because anybody ask me who I am, they-- they put me into jail.",
      "word_count": 19
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 7,
      "text": "I thought the worst thing what can happen is to go to jail.",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 8,
      "text": "I didn't know about extermination then-- camps.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "I-- I remained hidden.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Sometime I used to go out with my girlfriends, you know, they hid me.",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And I was nine weeks with my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "And one night, after the nine weeks-- knock on the door-- the police.",
      "word_count": 13
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "They took me away.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "They took only me.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And they took me into a big-- that-- I remember that it used to be a orphanage, this hole that they took me there.",
      "word_count": 24
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "And there, I saw lots of people-- girls about my age, and older women, and men.",
      "word_count": 16
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "And straight away was a segregation-- like a girls my-- my-- you know, not married girls, and the married women, and the men till 40, and after 40.",
      "word_count": 28
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "And they segregated us.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Young women.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "And they took us to the next city, the-- the one-- the-- the-- the young girls and the younger men-- the not married girls and the younger mens-- went to another city, to Sosnowiec again, where we went to-- like, into a camp in between.",
      "word_count": 45
    }
  ],
