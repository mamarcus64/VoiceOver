  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "Everywhere-- and that was our bathroom.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "It was-- Oh, I remember once I was in an old house.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "I went to the bathroom.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "And the German was staying in back of me, a Polish soldier was staying in back of me.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "It was just-- it was so primitive in these villages.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "It was middle-- and we had no water.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "And [INAUDIBLE] in the little town w water.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "And in the winter, was snow and ice.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "And you had to go very far to get a little bit of water.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And I come from Holland.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Holland is very modern and-- Sure.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "You know, we had warm water.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We had showers.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We had baths.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And, and I had a-- I didn't know how to dress a baby.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And I had to sew-- I had to sew clothes for the baby.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I had to sew it myself from my own underwear, what I-- little bit what we had.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And the windows were such holes in that in the morning, when we woke up, everything was ice.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And, and so we had to take-- had-- we got a little-- made a little bed for the baby from the bed-- for the baby that she had warmer.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Ugh, it was a-- it was a miserable time.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And we had a-- an-- and where we heating with was from the dust from wood.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And, and when they put it on, then it--",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sawdust.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And it went open and everything was full of it.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Ugh.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It-- but still, we were alive.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We were alive.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And one day in January--",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "That is in 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "In January-- [PAUSES FOR 3 SECONDS] Yeah, but it was almost [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Because the uprising was '43.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "It was January '44.",
      "word_count": 4
    }
  ],
