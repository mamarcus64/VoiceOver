{
  "stem": "26609.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "My mother was in Grodek.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "He took me to Lwow and wrote me.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "He was with me there and said, that girl will be a good nurse.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "And I was.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "And that because of this.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Now, they put me to bed.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And my mother came back, and he told her about it.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He said, that girl will be a nurse.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I'll make from her a nurse.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I didn't think of it then.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He put me to bed, and I had to stay in bed until it heals and the muscles heal together.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And I had to take-- he said, it will take about-- until she will be a little better-- two or three weeks.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But two days later, we had a woman-- a peasant woman-- coming, because there were floors-- wooden floors only polished, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She did the floor, and I was in bed, and I looked at her.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And she left.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I said, Mom, would you give me a bucket of water and a rag?",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "She didn't clean enough, so it was easy floor.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] What are you doing?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "You can't go with that like that.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I said it again.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I can't-- she went-- she said, no, I won't let you.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And I said, and I will cry until you let me.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And my mother went out, and I took the rag.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And the leg-- it was after the operation-- I hold it like this, and the other one on the knee, and went down the bed, and I washed the floor.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "That's me.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "I can't stand it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "That's why I haven't got a helper here.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "And I did it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "And when he came back, my mother told him what she did.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "I will kill her.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I didn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "He laughed.",
      "word_count": 2
    }
  ],
