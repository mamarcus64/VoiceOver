  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Yesterday, at the first day, he read the-- read the hof Torah and the Torah reading during the services here, the first day of Pesach.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So in a way, I'm proud of it.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "But to be honest, if that's what he was making for a living, I wouldn't be so happy.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "But if he makes a living as being a specialist, or doctor, to do something extra in the religious field, I am proud of it.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "So I fly in each time.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "But the only problem, as I told you, I don't know if I should say it on the-- I will say it on the tape, because it bothers me, bitterly, that the rabbi, the shul he goes and belongs and supports and gives tells me that he doesn't observe the Holocaust.",
      "word_count": 51
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "He combines it with [HEBREW].",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "That is killing me.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "That is killing me.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And the problem is it bothers me more so that he has all the young people.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "The whole synagogue is only young people.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "You wouldn't find a real old person of my age.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "No-- not one Holocaust survivor is a member of that synagogue.",
      "word_count": 11
    }
  ],
