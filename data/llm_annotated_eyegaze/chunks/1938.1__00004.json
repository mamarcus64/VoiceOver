  "elapsed_s": 124.3,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "--by train, by, by-- I, I don't remember exactly how they took us, because it was a time that the emotion, stress, and, and-- all young girls.",
      "word_count": 27
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "We were just starting life.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And my parents were still home.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "But when we were working to go there to this, I remember my mother running after us and, and, and handing me a piece of cheesecake.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And then the SS man, I saw how he beat her up very badly.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "She was falling.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And then she was spending all the time-- was January, was wintertime.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Was standing down, down there to look up.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And from all of this, she got pneumonia.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "She was very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Because I was already in concentration camp when other people came and told me this.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Grunberg Schlesien by Breslau.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "My mother was taken to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "She was 55.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "My father was, my father was 55.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "My mother, 50.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They were taken to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "That's all I know.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That was probably [BACKGROUND NOISE] a year after I was taken.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "A year, probably, after I was taken.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "They were taken to a ghetto first.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't there.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That was, I think, '40, '41, '42.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "'42, 1941-- Yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "It was, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Between Dabrowa and Bedzin was very, very short distance.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] And all-- in the beginning, my-- when I was in-- my parents still send me once in a while a piece of bread.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "But it never reached me.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Because it was taken away or it was already stale.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I know, I know because the [NON-ENGLISH] what was leading us and was chosen to, to take care of us was a neighbor of, of ours.",
      "word_count": 26
    }
  ],
