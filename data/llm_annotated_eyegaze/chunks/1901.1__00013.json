  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "I went in the train, and then--",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No, I wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "You see, I didn't look real Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I mean, obviously looking Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "We were not outspoken.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "Our-- our accent was the same.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "We had no-- no-- no-- no one else would know I have a Jewish accent.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "It was not existing.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "We spoke Amsterdam, more or less there.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "No-- you see, like in many countries, they have the second language, and they could pick out that they came from somewhere.",
      "word_count": 22
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "But no, we didn't have it.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And--",
      "word_count": 1
    }
  ],
