  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "The other woman had two little, two little girls who would run around and play.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "So one funny thing was that Martin and I would be together and they would come and bother us.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And so Martin would say, [FRENCH].",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "Just go up on deck and see if I'm there.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And they went running up on the deck and they would go-- I think one was five years old.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "And they would come back after a little while and say, no, you're not there.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "So there were light moments.",
      "word_count": 5
    }
  ],
