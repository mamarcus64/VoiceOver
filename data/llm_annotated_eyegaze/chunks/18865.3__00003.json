{
  "stem": "18865.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 552.3,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And they brought all of this the following day.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Somebody brought all the-- all the equipment.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to a life that was unimaginable for me before I got there.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Big farm, and--",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "In Frinton-on-Sea, on a-- on a little hill called Great Holland Hall, next to a church and a cemetery.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And there was nothing else.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And there I was.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "When I walked into the kitchen, the half of pigs were-- were on-- hanging from the ceiling.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And no heat anywhere, just fireplaces in every room.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And then I was told what I had to do.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And their little girl, Jill, she was two years old.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And from the second I laid eyes on her, I was in love with her, and we-- she with me.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And that was my only consolation that whole time in that house.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Was enormous.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "The kitchen was I think as big as my whole house.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I had to scrub it every day on my hands and knees.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "It was very strict.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "I had to get up very early.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And sometimes after it was all finished with the-- with cleaning the house, and the kitchen, and the hearth had to be made with the white on the bottom, and the stove was one of those old fashioned ones, black on the top.",
      "word_count": 43
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And I had to do all that.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And sometimes the farmer came in, if there was a cow was calving or whatever, or a baby horse was born.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "He came in with his dirty shoes and went right through the kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And I don't-- didn't matter what time of the day or night it was, I had to clean that kitchen again.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "It was hard.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "It was hard work.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And I was lonely, very lonely.",
      "word_count": 6
    }
  ],
