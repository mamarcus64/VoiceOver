  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Until [PAUSES FOR 3 SECONDS] just the time of my birthday, which was 23rd of December, they came-- some of the relative, in which I had to perform a concert my little violin.",
      "word_count": 33
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And the same night, my mother suicides, the night after my birthday.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 3 SECONDS] many things started to change, of course, in this situation.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The first things what-- concern was-- basically was with the baby.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And this baby was taken by the-- my relatives, the sisters of my mother, and given to family, the-- just at that time was preparing their emigration to Israel.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] [SIGHS]",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So [SIGHS] I continued my studies.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And this was kind of two lines of my life that are going simultaneously.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "One line was the tragedy of my family.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "My father become even more depressed and secluded.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And it's not very far after that, he, he died.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And the other side, my successes as a young musician.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I [PAUSES FOR 3 SECONDS] become [PAUSES FOR 4 SECONDS] stipendium bearer.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I mean, I start to receive stipendium from the, the government for my studies.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS] I finish the lyceum, the-- with top grades there at the time.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And little before that I finished the lyceum, there was one competition-- national competition inside of the country in which I took the golden medal and first prize.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "17 years old.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] This is what eventually after that prepare my first big trip outside of the country.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Of course, immediately after that, I, I had to finish lyceum and to enter in the state conservatory as part of the university.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I, I, I started there, started my studies in the Bulgarian Conservatory.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Who Who were you-- I--",
      "word_count": 5
    }
  ],
