{
  "stem": "107.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 82.3,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And you can get in-- into last work transport, which will save your life, suddenly save your life.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "So everybody knew what will happen with the others.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Two women did it.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They gave the children to the neighbor.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "One of the women I knew and was not too surprised about, and one other one.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "All the other women went with their children in a slow [TAPPING RHYTHM] march to the gas chambers, and were never seen again.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Then we knew what will happen with our camp.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "I-- again, I expected that this will be my end too.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Unsure.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Maybe it was the 12th of July.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I don't know exactly-- 11th, 12th of July.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "One SS guard with a bicycle came to the hospital and called a few names-- Otto Heller.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Hans Hellman was not there anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "He already went with work, sneaked into one of the work transports.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "He was-- [COUGHING] Excuse me.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And he was gone.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "Otto Heller, his wife who was a nurse, I, maybe one other doctor-- what's his name?",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Bernie-- Bernie-- Bernie Pollack.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And he said, come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And he went up on his bicycle, and we walked.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He went rather slow.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Gave us some kind of piece of probably what will happen to us.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We know too much.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We had seen too much.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "That might be our end.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He went with us out of our sector of the camp and in direction to the end of the camp where the crematorium and gas chambers were.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "That was pretty much-- he didn't talk to us.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "There was no way to ask him what was happening.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You don't ask questions.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "You know, you'll get beaten or something.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And then we passed a gate, which was a gate to the central hospital.",
      "word_count": 14
    }
  ],
