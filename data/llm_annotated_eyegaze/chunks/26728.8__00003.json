{
  "stem": "26728.8",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Really, really proud being-- so anyhow, they put us in this half track and they take us to a shack out there away from the main part of the airport, which is a big airport.",
      "word_count": 35
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "American airplanes over the damn place, which we had Lend Leased to the Russians.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "Everything except B-29s they had-- fighters, bombers, medium, light, heavy bombers, everything.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "C-47s.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "Millions of dollars worth of airplanes.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "American trucks, American jeeps.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So they stuck us in this place.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They took our guns away, took our wallets away, took our-- I had a charm-- an ID bracelet, sterling silver on, and they took that away.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Uh, I had my-- oh, I didn't have my-- I did.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I had my dad's ring on.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They took that away.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "It's in the picture of me with that airplane.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And Snyder had fly glasses.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They took this fly glasses away and I think I had-- I didn't have any-- mine was on my helmet, my flight helmet.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they put us in this damn place, which was like a big box really.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "It was a room, a crate kind of, with a little window, homemade window.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And they left us in there for about an hour.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Then here comes some Russian guys, officers, and they we wondering what the hell we were doing.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And he got belligerent, and I was trying-- and they spoke English.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And these were from the intelligence.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I said, we just came up here to sell these watches.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And Snyder was getting mad and acting mad because they were holding us.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And he thought, you know, we were allies and you guys, we helped you win the war and blah, blah, blah, blah.",
      "word_count": 22
    }
  ],
