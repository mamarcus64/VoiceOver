{
  "stem": "2996.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, I left Chicago in 19-- probably in the spring of 1934.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I left Chicago going for to do a story, a criminal story, a man accused of murder.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "It was a German aristocrat who was accused of having killed his wife.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And there were two sons who lived in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And sent me to get to those two sons, figuring being able to talk German, so that I can loosen those two sons up, hoping to find something that would give them some sensational front page headlines.",
      "word_count": 37
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "That's how I got to Los Angeles.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Some time earlier the leader of the Bund in Los Angeles and the West Coast spoke to the Nazis in Chicago.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And among other of things, the man said that the Jewish-- the dirty Jew lawyers are giving us trouble in Los Angeles.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "He went into some details, which I'll skip.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "When I got that report from one of our undercover guys, I went to my aunt, who was a president of a synagogue in Chicago.",
      "word_count": 25
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I said, look, will you talk to your rabbi?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Find out whether he knows a rabbi in Los Angeles to whom I can talk.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So in due time, I got the name of the rabbi to whom I could talk.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "He's like, call Rabbi Edgar Magnin at Wilshire Boulevard Temple.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "The telephone number is such and such.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So I called him and told him what I was doing.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And I told him what this Nazi leader from Los Angeles was telling to the Nazis in Chicago.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "So I asked him, do you know anything about it?",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "He says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We have a little committee.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We call it the community committee.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "This committee is concerned about some of the Nazi activities.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He described them to me.",
      "word_count": 5
    }
  ],
