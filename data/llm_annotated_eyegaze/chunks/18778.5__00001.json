{
  "stem": "18778.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 316.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And I explained to her that I was coming to Germany with my children, I would very much appreciate if she would allow me one more time to show my children the house where I was born and raised.",
      "word_count": 39
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And she wrote back to me that by now she wasn't living there herself anymore, that she had converted the house into two apartments, but that she would instruct her tenants to allow us to come in and see the house.",
      "word_count": 41
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So when we came to Rheydt-- by the way, in Andernach, we also went to the cemeteries.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish cemetery in Andernach was beautifully kept by the-- by the town.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And the children could see the Loeb family burial grounds and-- and have a reality of their heritage and of their roots.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We did the same thing in-- in Rheydt.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Actually, my mother's family was buried in the next little town, Odenkirchen, which is where my-- my mother was born.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "That cemetery was not in such in a great condition, unfortunately.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But we were able, again, to show them the family names, Salmon family and Simon family, other family names that were of the parents and grandparents and great-grandparents and so on.",
      "word_count": 31
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "My mother's family was in that town for several generations, whereas my father had moved into the area from southern Germany.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I took the children into the house.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And we took some pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "The house had undergone some changes inside, decorating and architecture, since it was now a two-family house.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "It is in beautiful condition.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "It is a house of a particular architectural style and they really put it into pristine condition.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Also, the garden was, again, very nice.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "We had a big garden at one time.",
      "word_count": 8
    }
  ],
