{
  "stem": "1873.5",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So they put, the Nazis put [PAUSES FOR 3 SECONDS] soldiers on the corner roads and close to the forest, yeah, there.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't think that the  Jews would be stupid, going-- they're stupid, simple.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And we were right, nobody-- I mean, we didn't plan this, because but is so happened, that they didn't watch the main roads, only the crossroads.",
      "word_count": 26
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, we made it close to Izbica.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "We had a few problems on the way, which I want to skip, because telling about everything will take time.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "We made it  close to Izbica.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "We are hiding in a ditch.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "And I told them, I'm going to Izbica to a Polish friend, ask him to hide us.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And they told me-- they took away all the money from me.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "They told me to leave all the money, so I shouldn't hide by myself.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "Anyway, this-- this is the way it was.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "I left everything with them.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "And I went to Izbica.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] I went into Izbica.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "It was evening.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "It was evening.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 20,
      "text": "I didn't recognize the town, because, already, many houses were taken apart by Poles looking for gold.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I went to this lady, knocked on the door.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "She opens.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "She see me, immediately crossed herself.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "God, what do you want?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I said, listen, you are a friend of our family.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Could you hide us?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "No, She refused to hide us.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "OK.",
      "word_count": 1
    }
  ],
