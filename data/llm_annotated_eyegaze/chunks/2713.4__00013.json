{
  "stem": "2713.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] They didn't have work to send us.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "One day, they sent us into work, and there were young Germans-- their age maybe was 15 or 16-- they were guarding us outside the camp.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And they called us in to remove rocks.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And the rocks could have been as big as the wall here.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "And it was impossible to move.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "They didn't really need those rocks to move.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "But they just wanted to have fun with us.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "So they asked us to move the rocks.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "So they started hitting us.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "And you couldn't hit them back.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "Though, you could if you had the strength to do it, most probably.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "But you'd be killed for it.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "So that's the fun  they had.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So after a few days or so, we were transported again.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We went on a transport.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "From there, they sent us to a place called Mauthausen.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We might just leave it there.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "End of tape 4.",
      "word_count": 4
    }
  ],
