{
  "stem": "18474.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 368.9,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "We were on-- on the watch all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Then we were brought back and I was in the ghetto for a while-- not long.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And they create-- they sent some people to a place called Studanka.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "S-T-U-D-A-N-K-A, Studanka.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "That was near a town Kremenents and [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But There was a town, [INAUDIBLE], and a town, Kremements.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "This was in between.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "This was-- we were digging there peat moss.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And the women, the girls, we used to dig with a certain shovel.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "It came out like a brick.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And then-- then with-- with wheelbarrows, we used to spread them out all over the place and the girls used to put them to dry.",
      "word_count": 25
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "The air should be able to get in, like stacks, high stacks.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And they dried them.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And I was working there for quite a while.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "They used to keep us in-- in barns, the men separate and the women separate, under the Ukrainian-- under the Ukrainian guards.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "One day, I decided I had enough of it.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And [INAUDIBLE] after that round everybody up, they're taken back to the barns, I decided I'm not going back.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "I crawled into one of those stacks, inside.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "And I stayed there and they rounded everybody up.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "I-- got away with it because I made believe I was working there and I crawled in there and that-- that was the end of me.",
      "word_count": 26
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "They took everybody away.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "I knew my way around all over there, the roads, because-- and-- and I run away from there.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "This was about 50 kilometers, different ways.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "I came back-- came back to the ghetto and I-- and-- and this was already in '42.",
      "word_count": 17
    }
  ],
