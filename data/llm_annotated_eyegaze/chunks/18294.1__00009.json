{
  "stem": "18294.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 153.0,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And to get for I or my brother or my father or my mother, we went in.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And did you or your family ever attempt to run away?",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We had-- they used, in 1939, that a load of Poland arrived to Vilna because the Germans were there.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And they used to come, one, to make some handbags to my father because he had the machine.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So he come off and said to my father, you know what, I'm going to Shanghai.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We are allowed to go.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Are you want me your older daughter to go with me?",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "My father said, what?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "You take a girl from me to go like that with you?",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "No way.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "This was the only opportunity what I had, could stay alive, not to go to Germany.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And your parents weren't offered.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "He only offered to take you.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yes, only-- you couldn't.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He take-- could take me like a bride because he was a single man.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The conditions there was like that.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Like I-- person like me.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We was in one big room.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "There used to be a high school there, they call [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And in this room was my mother's three sisters and another-- another two families.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "So we was altogether, six families in a one room.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And everyone of us had two children then.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "So we all stayed in the same room.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "And the facility-- there was one little oven in the passage.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "And everybody has his turn when he can cook because six families together.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And you have nothing in there really.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "The-- in the ghetto they make theatres, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "You could go if you would wanted.",
      "word_count": 7
    }
  ],
