{
  "stem": "9262.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we had Jewish butchers.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When the Germans were forbidding the shechita laws, we were not anymore able to attain Jewish-killed meat or chickens.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And these were sent in from Denmark.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And sometimes we used to get the supply from Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "But slowly, slowly, this dried up as well.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And then when we were deported, there was nothing at all, as far as Jewish meat and poultry was concerned.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Before you were deported, how did you celebrate the festival, Shabbat, at home?",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, Shabbat was normal.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We had [PAUSES FOR 3 SECONDS] just like a normal Shabbat.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We had challah bread.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We had fish.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We had chicken, mainly chicken.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Not so much meat, because meat became scarce.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But chicken we had.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "My mother made some beautiful lokshen soup.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And we had chopped liver, which was homemade.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Everything was homemade.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "My mother used to bake and cook and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And it was a real delight to eat at home.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We had Shabbas candle, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But this was [LAUGHS] Friday night.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "On Shabbat, of course, you see, you can't light candles.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "You can only light it the night before.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So we had a nice, traditional Jewish life.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We spoke German.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "My father, who was born in Poland, came to Germany as a young man.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He was about 19 or 20 at the time, which was just after the First World War-- 1914, '18.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "My mother was already living in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Her parents came from Austria, which was called a part of Galicia, which is the Ukraine today.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And she grew up in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "She went to school in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And my parents married in March, 1920.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We were four brothers at home.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "My brother Max, who is living in Florida-- he's alive.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Then there was my brother Isidor.",
      "word_count": 6
    }
  ],
