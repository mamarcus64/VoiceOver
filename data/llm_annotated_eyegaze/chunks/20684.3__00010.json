{
  "stem": "20684.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So I was looking at it, that short auntie-- she was six foot wide and five foot tall-- she ran across the passage.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She must have broken the-- the-- the 20 meters world record.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "She ran across the passage so quickly, grabbed the money out of my hand as I was looking at it, turned around to my uncle.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He says, why do he give you money?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Nobody else got money in the orphanage.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Why should you be any different?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't understand.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "But the penny dropped.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Did she cover those 10 meters fast.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You've never seen a-- a fat lady that big running that quickly.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Shit, she got the money so quickly-- unbelievable.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Oh, pardon me.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I use bad language sometimes.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Still my bad manners.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I had-- I had-- I just had bad luck there in France.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Things weren't right.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Just things were rotten in France.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "The war was bad, but at least there was reason for it.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "But after the war, it was bad for no reason.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "An orphanage, that was bad news.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to school, played basketball, played chess.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I was doing all right.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "There was no problem, I was just growing up.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We had lots of games.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I remember I had a friend who was so much smarter than me, Michel.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I don't know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I said there were two things would happen to him.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "He'll either get his-- three things.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "He'll either get his neck cut by somebody, he'll become the prime minister of France, or he will spend the rest of his days in jail.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I don't know which three of the things happened.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "He didn't become the prime minister of France and I don't know what happened to Michel.",
      "word_count": 16
    }
  ],
