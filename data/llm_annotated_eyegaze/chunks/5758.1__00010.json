  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And [PAUSES FOR 3 SECONDS] on the 11th of March, as the Germans entered, we-- [PAUSES FOR 3 SECONDS] I was once in the street, and I saw the German Army or troops or [?",
      "word_count": 35
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "SR ?] parading, marching, in our street, which was the Untere Augartenstrasse.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "We lived number 32.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And you saw hundreds of people, just right after the invasion, the-- the people who were left wing with their arms stretch out-- Heil Hitler, et cetera, becoming Nazi.",
      "word_count": 29
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "And the people were in the streets, you know, all swastika.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "All-- every house had a swastika.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "You know, it-- it seemed to me so unrealistic that one day they were socialists, the next day they were Nazis.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "And they were-- enjoyed the troops and the [?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "SR ?] from Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "A very frightening time.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "My parents wanted to make sure, at that time, because we knew exactly what has happened in Germany with the Jews, you know, how they were persecuted.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And they couldn't have businesses, et cetera, and-- and they were arrested and taken to camps.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And-- and somehow or other, they told us, when we had me at home, that, look, you children, you got to go.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "You have to leave the country.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "There's no doubt you have to leave.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Our closest friend, my parents' closest friend, Erna Schiff, who lived absolutely right next door to our apartment on the same floor, she says, look, I have a brother-- no, I have a cousin, not a brother, but I have a cousin in America.",
      "word_count": 44
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "I'm going to ask him to send for one of the children a-- an affidavit for him to come.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And she put things in-- in motion, and it was decided that my middle brother, Eric, was the first one to go.",
      "word_count": 22
    }
  ],
