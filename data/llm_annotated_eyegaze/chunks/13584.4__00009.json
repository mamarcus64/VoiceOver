{
  "stem": "13584.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So it was all together.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And in the 18th of June of '67, a week or 10 days after the Six-Day War, we got married in a very hot summer day.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "We-- we wanted to invite a lot of people, a lot of friends.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Some of them were afraid to come.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Some of them could not come.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So, but we got married.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And since then, we are together.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We raised two children.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "My-- my son was a year and a half old when we came to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We came to the United States exactly the same day when the Americans were shot off to the moon, the 16th of July, 1969.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We settled in-- in Atlanta.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And since then, we're living in Atlanta.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I'm curious-- I'm sorry-- I'm curious about your wedding.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Was it a Jewish wedding?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It was a semi-Jewish wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It was not the-- the full Jewish wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But it was-- it had, you know, because of the situation after the Six-Day War in a communist society, it-- it was-- it was very hard.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It was not in a synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It was in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "It was in the house, in her parents' house was the wedding, yes.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But-- but we did, in Beth Jacob-- we belonged to Beth Jacob-- we received our [NON-ENGLISH], [NON-ENGLISH], from Rabbi Emanuel Feldman, officially that we are married, you know.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We did it all in the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "When we came here, my daughter was born here already, Chana.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "My son, Steve, was a year and a half old.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They went to Hebrew academy.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "They finished Hebrew academy.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And now, they are adults.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "We're waiting for a right [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "You know what I'm talking about, for a right marriage, you know.",
      "word_count": 12
    }
  ],
