{
  "stem": "26609.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "But where we lived, there were a lot of Ukrainians.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No, not that label.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I know what you mean.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "No, they didn't mention that.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They just said, you killed our Christ, Jesus Christ.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "My mother's brother-- my little brother Wolf was named after him, after my uncle, my mother's brother.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He was married, was older than my mother with two married sons in Lwow [? where he ?] lived.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He dealt in-- how do you say [NON-ENGLISH]?",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Money, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how they call it here.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I forgot it.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "I will recall it.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And he used to smuggle from Grodek to Lwow.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "People gave him money, or he paid for it.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Or he bought it up.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "But he smuggled-- smuggled to a bank in Lwow huge amounts of money.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "He carried that money in a bag.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "There was special bags around, bags like the doctors carry a bag sometimes, full of money.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "He didn't expect anything.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "But the Ukrainians-- there were two brothers and their father.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "I remember them-- tall, very tall.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "They were young people and their father, the older father.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "The father used-- the Ukrainian men.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "And they lived not far.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 17,
      "text": "I remember that [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 18,
      "text": "If I would go there, I would go straight to that place opposite where we lived, everything like yesterday.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 19,
      "text": "They lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 20,
      "text": "The name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 21,
      "text": "Skotnik ?], [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 22,
      "text": "It's said, you know, every city has a place, [NON-ENGLISH SPEECH].",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 23,
      "text": "It means as they lived.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 24,
      "text": "That father spied out-- actually, the two sons.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 25,
      "text": "They were grown up.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 26,
      "text": "The sons could be about from 20 to 30.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 27,
      "text": "They spied on my uncle, my mother's brother, who smuggled the money, carried a lot of money-- I don't know how much exactly-- to Lwow by train.",
      "word_count": 27
    }
  ],
