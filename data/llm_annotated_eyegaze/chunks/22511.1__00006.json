{
  "stem": "22511.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And then we find out that that girl father was also a-- a robber.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He used to go to houses.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So that guy was from-- kids got families.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Some of them learned good things.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Some of them take what they see at home.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And we used to share every little bits what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And when-- when I come back to the childhood, when the-- what I really remember is when the bombs start run-- flying.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They were-- next door was absolutely collapse.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "The house collapse.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And we were lucky we're alive.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And there was very shortage of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "We had to run.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And I always save my mother, my father, because I loved them so much.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And I used to run very early.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And I was the first to get bread, not only for my family.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "I did for the lot, because we all was in cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And I collect so much bread.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "And I gived a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "They always liked me.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "There was mix crowd, because that was in a normal time.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "We still didn't have the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "We had the Russian coming.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "Only before they come, we-- you need to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "And people was frightened to go out, because it was bombs.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "And I used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "My father didn't know where I am.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "He was very upset.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "Only I brought it.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "I was lucky, because I could be killed too at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "1939.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I had so many good people-- the Ukraine, the [NON-ENGLISH], she like me.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "There was [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They all like me.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I never had this feeling.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I cannot say what I don't.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "No one did me wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have that.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Just the boys, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "My brother used to come from school.",
      "word_count": 7
    }
  ],
