{
  "stem": "8679.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And my first husband had told me when we were told to leave the ghetto, if something happens we will-- let's say we both survive-- we will meet in Prague.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "He had a close friend with whom he went to university together, who was married to a non-Jewish woman, so he figured he might be safe.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And he gave me the address.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I memorized it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And that was my first step, to knock on that man's door.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And luckily for me, he spoke German, because I didn't speak a word of Czech either.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And I only told him I was [INAUDIBLE] wife.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I couldn't believe that he would believe me, the way I looked.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Still in rags-- clean, but in rags.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Hair was still short.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "But he believed me.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And slowly-- slowly-- I started to work in a factory where I put vanilla powder into little packages, together with my mother, on the assembly line.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I was able-- in the beginning, I had nowhere to go to sleep.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "A convent took me in.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "We had mattresses-- we were given mattresses and a sheet, and we could sleep.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And in order to have a shower-- finally, a shower again-- we could go to train stations.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And they gave us food, as well.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In-- not a shelter.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was a real, down-to-earth convent.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They took in people like us.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I do not remember the name.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I talked very little.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I didn't speak Czech.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But all I said-- I asked, you know, Jewish koncentracni camp.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "You know, it sounds like Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And they took us in.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In Prague?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I stayed in Prague four years.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I got-- after-- I worked side by side with my mother in the factory with the baking powder--",
      "word_count": 18
    }
  ],
