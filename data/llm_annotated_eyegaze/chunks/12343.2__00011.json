{
  "stem": "12343.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "The only thing, later on, the people-- a lot the people work with transport-- [INAUDIBLE] trains, put the ammunition on the trains to the war.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "They die fast.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Some people work [INAUDIBLE], some other work in factory was some [INAUDIBLE] like green stuff.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "This is poison.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "They die fast.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] they die fast, they take-- they take people from the easy work back to this.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "That's-- then one night, I see-- working over there in the factory, I see camps of Gestapo in the night.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "You know, it's [INAUDIBLE] like this.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "The first night, they took me to [?",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "Colditz. ?] Yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "This is what happened-- because after my mind comes back to tell you the truth, because I don't know what's happen.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "It goes back.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In the night, they come over there, looking for other people out for the hard labor on the trains.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "The people that were working with me was from Lodz.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They know me-- all girls know me.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They said, [INAUDIBLE]!",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE]!",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Run away.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] [? hiding ?] [? you. ?] They can't find us.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "But what can I do?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Where can I hide them?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "We cannot move no place.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They pick me up.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They pick me because I was young, looking good.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They pick me to the work.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And this was hard labor.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The same night, they took me to the-- to working, and I wait from this place.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I work [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "This work was-- the name from this factory was [?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Schmitz ?] Company, [?",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Schmitz ?] Factory, was OK.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Over there, at-- at the front-- [PAUSES FOR 3 SECONDS] he was a policeman, a Jewish policeman, [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "He was from [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "He was very good to me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "He liked me.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "He asked me to [INAUDIBLE] because I did work for him.",
      "word_count": 11
    }
  ],
