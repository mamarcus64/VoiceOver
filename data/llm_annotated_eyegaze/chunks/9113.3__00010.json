{
  "stem": "9113.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "[DRINKS] We didn't-- we couldn't go so fast away to leave everything.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "What-- we wanted to see, maybe somebody's alive.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "Maybe somebody's still living.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "Then we fooled around two or three days.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "During those two or three days, came where we used to station, that room in that apartment, came in friends which I used to go to school with in Poland.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "They said, you I wouldn't kill, you I wouldn't kill.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "Don't worry about it, you can stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "The same night, those same fellows which they said they wouldn't kill me, they wouldn't kill you, they killed two of our fellows.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "The same day.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "The same night.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "I was lucky to escape.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "Not to escape, I walked up on the-- on the roof and I-- and I-- I ran away to-- to another Polack.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "The next day-- morning, I came down, was two people dead already.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "Was another two people dead.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "Then my brother said to me, you know, Hyman, we have to leave this place too.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "Then we went to Kielce.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We went to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We went to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We found ourself an apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And we start to live already, to work, to-- to do something.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And everyone's start to-- start to live.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I didn't have a profession.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- I was good in-- in doing-- how to do business.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And I am trying to do business.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I was trying to do businesses with my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I went to-- [PAUSES FOR 3 SECONDS] then I went to do business.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And I was trying to find my family.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "I was trying to go, let's say somebody told me that Bergen-Belsen was liberated.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "I said that we're gonna go to Bergen-Belsen I'm going to find somebody.",
      "word_count": 13
    }
  ],
