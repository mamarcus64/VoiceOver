{
  "stem": "23498.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Not a revolver, but they were picking into the wall because they suspect that it could be double wall, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And luckily, they did not assess, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Was it a knife on the end of the--",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Very, very sharp.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No, because they were doing it on the other side, not on-- on our side.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "In the meantime, the child started to cry, so they all ran over there.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "But my father was a victim, because he was responsible, and they started to beat him up.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And maybe it was a few minutes, and my mother knew about it.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And my mother said, I'm going.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I can't stand it.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "They beating him.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And my grandfather said, no, it's not him-- because he wanted to save us, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "It was hard to hold my-- my mother quiet, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And they were beating with like horses [NON-ENGLISH], yes?",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "They were beating in one direction in that eye.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "You know, all the time, maybe 12 times or I-- I can't recall.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And my father had blood everywhere coming, and they took him-- and also I don't know whether he lost I think some front teeth.",
      "word_count": 24
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And they took him to Umschlagplatz from where it was already late.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "At that stage no one could get out.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "From Umschlagplatz.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "It was-- I tell you what it was.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was a station.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "They-- they kept thousands of people next to each other until the-- the cattle trains came.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they put the people in and took them to-- to their destination.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Alright.",
      "word_count": 1
    }
  ],
