{
  "stem": "7506.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And I told her the address, which I had memorized.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And to this day, of course, I know that.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "It is Number 2 Devon Rise, East Finchley, London Northwest, I think it was.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I remember being for some time in that hospital and then being out of the hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Although before I was out, she-- a person-- a person came to my bed in the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I don't remember exactly, although I know the date.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And they came to tell me that my sister had died while in the hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "I remember, at that time, crying about that.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "When I was better, or when I was let out of the hospital-- and I don't remember where I slept when I was out of the hospital-- one of the children that was with me as part of the [? transport ?] she was older than me.",
      "word_count": 47
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "She was about 15 at that time when I was still 13.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "Her name was Hetty and her last name is Werkendum.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And she has two brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "She had two brothers with her in the camp-- one called Jackie and one called Max, or he called himself Max.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "And I remember her very much.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "She always stood out in my mind when we were in the barrack with Luba and indeed, when she came to me, and she took me to the place where my sister was buried.",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "At that time, or rather soon after that time, I, in a way, tried to erase that out of my mind.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "I remember, thereafter, that one day we all got into army vehicles-- all us children who were no longer in the hospital-- and went to look at the last guard tower of Belsen being set alight by an army flamethrower.",
      "word_count": 40
    }
  ],
