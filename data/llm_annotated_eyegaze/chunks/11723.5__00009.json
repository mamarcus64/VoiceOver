{
  "stem": "11723.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And I started trading.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And this is how I supported my sister and myself.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And, uh, we by chance were taken in by a family, uh, to live with.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Because I met a friend of my father's on the street, and he said to me, oh, where-- where's your father?",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I said, back home.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "He says, what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Where are you living?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "I said, no place, on the street.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And he said, oh, you can't do that.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "I tell you what.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "I'm going to call an employee of mine who used to run my Viennese, uh, store.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And he's a very nice guide, not rich, but very nice.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "He'll take you in.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "And that's where we were.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And then I, uh, found somebody who had a very sure way of, uh, getting people across the border.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And it cost $400 for my parents and my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And I, uh, put the money down at a third party.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I wouldn't give them the money.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I told them, when you bring my parents, you'll get the money.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And again, I sent something in Hebrew to tell my parents that it is me, indeed, and it's not a trick.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And they came.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And when they arrived to that Weihburggasse restaurant, and I saw two crying people, whom I thought were going to take care of me, I was very disappointed, in a sense.",
      "word_count": 31
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "But, uh, from then on, the-- the Joint took care of us.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "They gave us money to live in a hotel as a family.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And, uh, my brother was in the hospital, where he also caught, uh, encephalitis.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And I think that he eventually died of the complications from that.",
      "word_count": 12
    }
  ],
