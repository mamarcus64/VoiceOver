{
  "stem": "24125.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And after a while, seeing that we really cannot survive together, we started to go places.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "My young brother joined Polish Army.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "My sister was with my older sister, [?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "Jean. ?] Manya [?",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "Jean. ?] I took off to Rowne-- Rowne.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "And I got a nice position in [INAUDIBLE], which is a very high judge-- judges and lawyers place.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "And I could go get there that position, it's through [INAUDIBLE], a woman.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "Again, a woman that lived in our study.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "I came.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "I saw her.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "She accepted me like her daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "As a matter of fact, she treated me like her daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "She advised me, she did things.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "To be young and, you know, pretty during the war, it wasn't easy.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "She was like my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "She was protecting me and doing things for me.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "I had a very good job.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "They gave me a room, and I was situated very nicely there.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "After that, I met a young gentleman that was a partisan too.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "And we decided that we want to get out of all of it.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "And we moved to Lwow.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "I took my younger sister with me, and we decided to marry.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "Then from Lwow, in Lwow I got married.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "I decided that my sister lived in-- in Russia-- in Ukraine.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "I left her in Ukraine.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "And my brother was in the army.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "I had-- I could move further without having them.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 39,
      "text": "I took my older sister in.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 40,
      "text": "When she came in to Lwow, then we, two of us, went to the Polish Army and over there I had a few dollars paid off to call my brother.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 41,
      "text": "So I had all the family, and we moved to Byten.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 42,
      "text": "In Byten, I had a house with my husband.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My first husband.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Mischa ?] Steinberg.",
      "word_count": 3
    }
  ],
