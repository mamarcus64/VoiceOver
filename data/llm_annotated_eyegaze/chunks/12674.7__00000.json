{
  "stem": "12674.7",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, the-- I have one-- one funny experience to tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to come here.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "But my father insisted that we came here.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So of course, we did.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So where we-- they put us up on Lafayette Street, which is near Astor Place.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And on the first day that I was there, I went outside.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I wanted to look at America.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And I walked-- I made a right turn at the street.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And I walked over to the Bowery.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I saw all these bums lying there in the streets, soiling themselves, and all these winos.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And I went back to-- to-- to the-- to the HIAS building.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And I said to my father, what have you done to us?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "The people sleep in the street.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "They are dirty.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They are disgusting.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "How can we live here?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "Well, then I found out later that it was the Bowery, and it was all right.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- we got a room-- we got a room from the Joint Distribution Committee.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We got an apartment someplace.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We stayed in-- in that place, on Astor Place, we had beds there for about four weeks.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Then they found us an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They found us two furnished rooms out in Brooklyn someplace, with a Jewish woman.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And we went out there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And they found me a job as an alteration hand.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "They asked me, can I sew?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I said yes, I can sew.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They found me a job in a dress shop, as an-- altering, women.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So I worked there for four weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I guess I wasn't fast enough or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And I worked someplace else, and making underwear and things.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I worked on a sewing machine for a while.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And-- and-- and-- and then I met a girl.",
      "word_count": 9
    }
  ],
