  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Somebody brought me in a bit of water in a bucket.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I put the bread in the water, eat it.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "In the nighttime, they took us to the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Where the hospital, because they are not allowed to travel with the trucks in the nighttime, because the bombs, they can drop bombs, the Germans, all in the nighttime.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "They come in our place in the nighttime and lay down to sleep on the ground.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "It was not bad, on the ground.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Straw covered with a little blanket.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And that's how we sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Next morning, I'm up.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "Got, I got, I got breakfast.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I told myself, I can walk.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "I want go have a look where we are, where we are.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I walk on the, on the, I walk out to the yard.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And I see outside, gymnasium, a high school, a Polish high school.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "The Polish government, when the German took over, they make a hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "When the German left, the Russian took over for hospital.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "I told myself, I'll go have a look where I at-- Lublin, the town Lubin.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "Let me say, I have wanted to see [? how it ?] is going on.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "I went to the front gate.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "I see on the other side from the, from the gate, on the other side from the fence.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "Was not a fence from broads.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "It was from, from pieces of iron, something we can see what's going on over the other side.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "I see Polish people standing.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "And they're discussing, like two parties, like the liberal, the labor, something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "He was like, he's right.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "And he was like, he's right.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 32,
      "text": "And I, and I see they are-- got papers.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 33,
      "text": "They're selling the papers.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I can read Polish.",
      "word_count": 4
    }
