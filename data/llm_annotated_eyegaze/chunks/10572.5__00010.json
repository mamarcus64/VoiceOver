  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Later on, the majority of the 5,000 in this camp became part of the British forces and furnished very, very valuable-- many of them got into the intelligence service.",
      "word_count": 29
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I-- I left-- I left-- I finally got my invitation to come to the American embassy in London to get my immigration visa to the United States.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I couldn't-- couldn't fathom that, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "This was-- and it was 'the' day' for me.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was 'the' door.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I said in my story, I walked through many, many doors to come to this point.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "But this was 'the' door.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And I hoped and prayed that I would meet the conditions or the things that were necessary to meet the qualifications of the American consulate.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They left.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They left much later.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I came to America first.",
      "word_count": 5
    }
  ],
