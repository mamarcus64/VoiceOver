{
  "stem": "7358.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we used to stay there only five days a week.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And Friday, we would go back to the kibbutz.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So I worked at this job till October, practically till before I left for the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "In, in, in between my family here, I discovered that I have here a grandfather and two of my father's brothers, uncles.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And one of the uncles lived in Argentina.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And by this time, my aunt and my uncle that saved my life had moved to Canada.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "So they, they wanted me very much to come and live in the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I had refused to do that.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So at some point, we agree that I will come for a visit.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So on October 1926, I came to visit. 19--",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "In October 24, 1954, I came to the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And while I was here visiting, I met my lovely wife Ruth.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And I decided to stay in the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "So that's sort of part, part of my life.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Are you interested to know--",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "We, we-- I, I got a job.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I was always gainfully employed all my life.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I never was unemployed here for a single day.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "My wife also worked for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "But when we had-- we have-- we had two children.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We have two children.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And when we had the kids, she stopped working.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "I have a son, which is 38 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And I have a daughter, which is 33 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "My son is a graduate from MIT.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "He has a PhD in applied economics, and a very successful young man.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "He's very much involved in Jewish affairs.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "He's a major contributor to UJA.",
      "word_count": 6
    }
  ],
