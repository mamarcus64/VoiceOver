{
  "stem": "8725.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "I was so scared.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "We were scared so we start running.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And there was an empty house.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "And we got-- from the back was open and the window were broken and we were on the first floor.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "And instead run out completely, we were in that house.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "So we witnessed a nightmare.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "We witnessed that SS were really pushing, and beating, and kicking a mass of people.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "And it was unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "And we did even see the SS.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "A man, probably the wife was Jewish and he was not, he was running.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "It was a beautiful blonde woman with a little tiny girl, maybe three-years old.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "And she was holding her by the hand.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "The child was yelling, screaming.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "And the man was trying to get to it, Well, the SS shot him and people with walking-- you know, trying to walk around him, but laying.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "There was another woman that I'll never forget.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "She did a little-- she was wounded in her leg and the little girl was screaming, crying.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "She was trying to protect her.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "There was a old man with a white beard, white head-- it looks like a rabbi to me.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "You know, unbelievable pictures.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "And we were just standing there and watching.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "And then I did see a SS man pull a baby from mother's arm.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "It was a little infant.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 48,
      "text": "The baby was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "And he just took the baby and threw it head to the ground.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 50,
      "text": "I did see another man.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 51,
      "text": "He put the baby in the air and shot like a bird.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 52,
      "text": "[PAUSES FOR 4 SECONDS] It was unbelievable.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 53,
      "text": "Jeanina-- my sister was crying.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 54,
      "text": "I was standing there bewildered.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 55,
      "text": "We were scared to go out or anything.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 56,
      "text": "Finally, we did see the procession leaving.",
      "word_count": 7
    }
  ],
