{
  "stem": "979.4",
  "chunk_idx": 18,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "So anyway, when-- in the meantime, my sister, a woman, who used to be a doctor, says, your sister will have only one week to live.",
      "word_count": 26
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "She will die.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "She needs more food.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "And I said, what shall I do?",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And I said-- my sister told me, listen.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Say you remember Irma Grese, she says.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Now she says, why don't you go and ask her for-- to give you a job.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Maybe you get a bit more food from anywhere, the kitchen, or whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I said, what-- what does she care about me now?",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "She says, you go.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Go. tell her that I'm sick.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I went all the way to the office-- which I'm not allowed to go as far as the office-- but I went.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And she saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "She came up.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And I was wearing a scarf.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I was very-- I don't know how thin.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "They didn't even ?] have mirrors, but I was like the skeletons.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And she-- she gave me a slap in the face.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And I went running back.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And I said to her, see, she knows me.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "She says she didn't see you well.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "She says because you were wearing a scarf.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "I say you have to go again.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "I say, come quickly what is she gonna do to me?",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "So she says-- and then I sat outside, because we have no more work.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "Because the British were coming closer and closer.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 13,
      "text": "So they all knew that.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 14,
      "text": "So the work-- they stopped the work.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 15,
      "text": "So I was sitting outdoors there in the-- in the-- there was a little grass.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 16,
      "text": "And I saw her passing-- Irma Grese.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 17,
      "text": "She-- I saw her walking in the main road.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 18,
      "text": "And I say, now I'm gonna face her face-to-face.",
      "word_count": 9
    }
  ],
