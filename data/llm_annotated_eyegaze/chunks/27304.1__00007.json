  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 2,
      "text": "And wherever the train went, that's where we went.",
      "word_count": 9
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "At first, we went Kiev.",
      "word_count": 5
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 1,
      "text": "Kid From Kiev, we went on a boat on the Dnieper.",
      "word_count": 11
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 2,
      "text": "There's a river, Dnieper, between Kiev and Dnepropetrovsk.",
      "word_count": 8
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 3,
      "text": "We got on that boat.",
      "word_count": 5
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 4,
      "text": "And from that boat, we went on a train again.",
      "word_count": 10
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 5,
      "text": "We went to--",
      "word_count": 3
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "--Rostov Oblast.",
      "word_count": 2
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 1,
      "text": "That's on the Don.",
      "word_count": 4
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if you know it or not.",
      "word_count": 9
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 3,
      "text": "On the Don, we went to Taganrog.",
      "word_count": 7
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 4,
      "text": "We been in a [NON-ENGLISH] there.",
      "word_count": 6
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 5,
      "text": "You know what a [NON-ENGLISH] is?",
      "word_count": 6
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "It's something like a kolkhoz.",
      "word_count": 5
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 1,
      "text": "But a kolkhoz, the people control themselves.",
      "word_count": 7
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 2,
      "text": "A [NON-ENGLISH], everything belonged to the government.",
      "word_count": 7
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 3,
      "text": "But you worked like a defector for the government.",
      "word_count": 9
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 4,
      "text": "But it's farms.",
      "word_count": 3
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "That's how you had to support yourselves by working like that.",
      "word_count": 11
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Yeah-- yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
