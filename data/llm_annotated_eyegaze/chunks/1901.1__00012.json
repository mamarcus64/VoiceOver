  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "And that day, they round the whole lot up.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, playing there.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "In '42, end of '42.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We know they were picked up.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "Never heard of him since.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And my mother, they came at home for my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And we told her, no.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "We say, she have to look after us, because I got my diamond spare.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "And they kept her.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "I was shocked.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I mean, it was-- but he was not the only one that left around-- around us.",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "It started in '42.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "You see, in 19-- the first Jewish people in Holland were picked up.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "It must have been June, May, June, '42.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And they start rolling them up more and more.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "People were in panic.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I was home.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "It was shock.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "My father was a very good man, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "We knew it straightaway because the news, they worked very fast, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "We knew it in two hours later.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] picked up.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "They're gone.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Where to?",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "Don't know.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "Camp?",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "Westerbork?",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I knew nothing about the camps till I was in it.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Oh, very, very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "My mother they did-- I can tell a lot of it later when my mother came to in camp where I was for a while.",
      "word_count": 25
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "She insisted going there.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "More it was voluntary, she went there.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "In Holland, in camp.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "I was in camp in Holland.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "But till--",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "We had to wear a star.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "But that didn't bother us.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "You know, in the city, there was no one bothers you to.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "I walked without star too many times, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "It was-- oh, yes, it was dangerous to.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "I even had to go to outside Amsterdam.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "I had to, but no star.",
      "word_count": 6
    }
  ],
