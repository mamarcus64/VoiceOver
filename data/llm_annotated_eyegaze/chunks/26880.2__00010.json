{
  "stem": "26880.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And I think with I being in the ground, I-- every day I was digging.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And I was making so-- so big the-- the ground, I have a hole in the ground.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "But I put over there 40 piece potatoes.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I went in the field for more potatoes, potatoes and onions.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "These two things we was eating.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "In the hole.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "See, I want-- the-- the-- the-- the Polish people were running the-- the Ukrainians continued going is of the place where they [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I find over there a pail-- pail, pots and pan.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I bought four pots and pans and a pail.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And a pail what they used to kept milk, in the-- the farmers, in the-- in there, milk for-- and this, we used to make in, in nighttime, when it was dark.",
      "word_count": 32
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Not when-- not it was not snowing.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "When it was snowing, then goes in the-- the-- the snow.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "No, when-- when you still stand to snowing, that time, I used to take up everything, all the garbage from this.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I used to take old-- old pans, pots and pans, with water, should I have water in-- I was in the hole.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The potatoes, I had, like I say, I had four jars-- four big-- like, what were-- what-- yeah, to cook in.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And I used to two-- with two holes.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I just took cook them up [INAUDIBLE] two jar of potatoes.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I add already, the water, putting it in the under tap and putting-- again, to cook the onions.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And I used to make in 40-- like, four plates potatoes in one evening.",
      "word_count": 14
    }
  ],
