{
  "stem": "7684.10",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "They made the fire out, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "So, we went to Lublin.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And it was one Polish Jew that first run away from Sobibor at least about perhaps few months before.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And he-- Portlevnik was his name.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And he made it.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "Now, after that 13 Jews were killed because he run away.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And he and a friend run away.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And they made it.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They made it to America.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And they died very young.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Both of them died very young.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Not-- we never met them, I think, till we came here to America.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And I was 35 when I came to America.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And we went to his house.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "Chaim asked if we could stay with him.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And he say, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "A lot of Jews lived there already.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "It was very-- he made a lot of money.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "He handled with the Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "He bought loads of-- truck loads of sugar, and salt, and something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "He made big, big business.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "So we stayed there together, in that house.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Now, Chaim went away when somebody owned him some money.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And he went-- one night he went away.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And that night somebody-- he went a few nights away.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "Some man came and-- Polish Jew and he hit on the door and said, Portlevnik!",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "Portlevnik!",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And he knows that it was not kosher.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "There was somebody wanted to kill--",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The Poles want to kill the Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And he went to our door and they put the lights out.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And everybody put the money-- we had on the baby already.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Put the money under the baby's mattress.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't say anything.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And somehow they went away.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And for the few people, the very few mostly went away.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "But they killed a few-- they killed some Jews in the same building where we were at.",
      "word_count": 17
    }
  ],
