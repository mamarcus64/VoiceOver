{
  "stem": "2230.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "I am a Zyd.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "So that was part of life I guess.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "At that time?",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "We wouldn't talk about it.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "My parents wouldn't talk about it.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No, they would say, we are Jewish, we are Orthodox.",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "We are religious.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "We believe in God.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "And when you go to cheder, they teach you things.",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "But it was-- my parents, I guess they-- now I know they never philosophised.",
      "word_count": 14
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "They never said anything.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "They had to read.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "They-- they were there reading in Hebrew, reading the Bible.",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "My father-- I don't know if he went to [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if my mother did, but I know my sisters did.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "My mother had a fixation I guess-- [PAUSES FOR 3 SECONDS] that you must learn.",
      "word_count": 15
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "You must learn.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "She put importance on that?",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No matter what, she says, you must learn.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] If it's Jewish, or Hebrew, or Polish-- learn.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Did I learn?",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "What did I learn?",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Do I read Polish?",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "I read Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "I wrote Polish, Yiddish, Hebrew.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "I could [PAUSES FOR 3 SECONDS] say the morning prayers by heart.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "In Hebrew.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] I could say-- I could speak a little Hebrew.",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "I could say evening prayers almost by heart, I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I spoke Polish pretty good.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I still do.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "But I don't speak it.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] I don't think I should.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] I should not categorize it as all of Poland, but most of the Polish people don't deserve to have me speak their language.",
      "word_count": 27
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] But that's my feeling.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Did I learn some from the Polish?",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Yes I did.",
      "word_count": 3
    }
  ],
