{
  "stem": "22856.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No, that was in the beginning, [GERMAN], which means that was a-- a camp where people were compelled to work and stay.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Later on, it was renamed to koncentrationslager, which means stricter, much stricter than in the normal lager conditions.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "It was a rigor, a time for everything.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You had to comply with these things.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Otherwise, you were punished.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So far, men were separated from women.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But we were allowed to contact after hours, after work.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "You had very little space for you to sit or lie or keep your goods, whatever you wanted.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It was different in Plaszow than it was in ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I know exactly, about 20,000 people.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And there were some.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Outside the living quarters, there were some workshops or workplaces.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They were different according to people who are giving their occupation.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "There was tailor, [INAUDIBLE], machine specialist, [GERMAN], which means boot repairers, even brush manufacturing.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And they were two, also, big firms, like [INAUDIBLE] who worked for the army.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "We received some orders to supply.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "There was a-- quite an organization administration in the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we used to go out to work in Cracow.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Of course, in groups, always surrounded by Ukrainians or German people, German soldiers, in different areas of Cracow.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The food was distributed by barracks of officials.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They were always people-- they called it barrack alteste, or the oldest one.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Sometimes it was a man.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes it was a woman.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And all these things were rationed according to the amount of people.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Every morning, we had appells.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "We had to count all persons who are in the sick rooms in the hospital, or he couldn't stay on the appellplatz.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "It was in the-- in the hands of Jews, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    }
  ],
