{
  "stem": "24466.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And I was fine them-- find them, take them, to be able to leave.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "There was another one, [PAUSES FOR 5 SECONDS] Chelmecka-- Chelmecka.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "She was the wife of one of a captain from the Polish army.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And she was with her daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I helped them, too.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Chelmecka, C-H-E-L-M-E-C-K-A.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Financially, because I was in earning so much money.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "But before, when Lithuania was free, not involved in the war, and I was working for that firm, Omeiga.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So I was able to help people.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I helped, also, I would like also to come back to other people, like from Radom, that they have been, that was one Dudek.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "D-U-D-E-K, Golberg, G-O-L-B-E-R-G, Golberg.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It was another [NON-ENGLISH], because they were from Radom.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And they know me from Radom.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So I was helping him a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "His brother is still alive in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Dudek Golberg, was his name, Moses Goldberg-- [NON-ENGLISH] Golberg.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "The brother is still alive in Tel Aviv.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "From my savings, mostly, because I earned a lot of money for my own saving at that time.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I helped them, really, and my home was open for them.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was married in 1941, two months before the invasion of the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "My wife was Alla.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Lichtenstein.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "That was the daughter of the gentleman who was-- [PAUSES FOR 12 SECONDS] who helped me when I came to Vilna.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I was living in-- in [NON-ENGLISH], in two rooms by a Polish family, and I was working at that time for the-- when the Germans took over, that combined.",
      "word_count": 29
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I was-- before, I was working for the nationalists combined.",
      "word_count": 10
    }
  ],
