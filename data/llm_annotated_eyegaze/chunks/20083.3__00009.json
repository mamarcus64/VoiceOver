{
  "stem": "20083.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.9,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden, we had no idea what was going to happen to us while we were in one of these youth hostels in the Midlands in Evesham, outside Worcestershire.",
      "word_count": 31
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We were-- our entire building, our entire hostel, was surrounded by Tommies, by British soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "We had no idea why.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And then we were told since we were enemy aliens, we had to be interned because England would be next on Hitler's list.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And they did not want us to be-- to fight for Hitler's fifth columnists.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And the fact, of course, that we couldn't because of our religion that were actually expelled from Nazi Germany made no difference to them because they couldn't trust us.",
      "word_count": 29
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Maybe we were fifth columnists after all.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "But then finally, we were taken to a number of internment camps.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "One of these camps was in Yorkshire.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "It was a pretty nice camp.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "It was racecourse.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "It used to be a racecourse.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And they had converted it somehow, even though we still had to sleep on the straw that the horses also used.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "But we cleaned it up considerably and stayed there.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "Then, the next camp after-- we stayed there for about four or five weeks or so.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "We were taken to a camp in Lancashire called Warth Mill which used to be a run-down, totally obsolete, filthy textile factory.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "You could still see these huge-- the huge machinery stuck to the wall with clods of wool hanging from it-- filthy wool.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "And rats running around, and mice running around.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "And we were all given our sleeping bags and had to sleep on the concrete floor with the mice running around us.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "And finally, we got hold of some cheese which they had poisoned.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "And a number of them died.",
      "word_count": 6
    }
  ],
