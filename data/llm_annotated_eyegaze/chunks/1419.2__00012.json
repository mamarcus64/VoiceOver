{
  "stem": "1419.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They were not the guards-- they, they didn't watch us at work, but they would just march us to, to work from our-- from our quarters.",
      "word_count": 26
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they were guards at our quarters.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And they-- and they shot two guys right on the-- right at the quarters.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "What happened, the way-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "We ?] [? knew ?] that they were paid off to-- for the-- from some people, which they lived in Rabka.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "The Jews lived in Rabka, and they were with us in the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "We were from Nowy Targ.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "They were from Rabka.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And they knew some Polacks outside of, of the-- of the camp to go and to organize something, to buy something.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And then we are-- we know that they, you know, they give him some kind of zlotys or something or gold or watches or whatever, to let him go out at night or something and to, to organize something.",
      "word_count": 39
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And they killed two people.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "The way-- the way we knew later on that they were paid off-- the guard was paid off by the, by the Jews.",
      "word_count": 23
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And then he came back and he shot him anyway, outside of the-- of the-- of the barbed wire.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "The name was a guy which, which was-- which was known for cruelty, was-- I forget his name.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "Young, young Ukrainians, mostly all Ukrainians.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "They were in uniforms, in SS uniforms.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "They were just born anti-Semites, I guess.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "They were-- they were trained by the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "They were born-- they were Jew haters.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] They could kick you, they could kick you.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They hit you with, with the-- with the thing they did.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And they were just guards.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "They were guards just for the-- for the-- for the houses we were in.",
      "word_count": 14
    }
  ],
