{
  "stem": "54.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And we didn't know what's going to happen.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "So they came one morning, and they told us that we have to go down this ship and going to transfer on the other ship.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "Because this ship is going to make another aliyah.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "It's going to go back to Marseille.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "You can imagine, in the middle of the ocean, five days being on the ocean, with those ladders going down into the small, you know, little boats.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "Brought us to the other ship-- we came over there to the other ship wet-- soaking wet-- all of us.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "And this-- the-- they transferred the whole ship to the other ship.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "We came on the other ship up there.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "I got-- it was dark in my eyes-- dirty, filthy ship.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "It was not a passenger ship-- a transport ship, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "The ship was bringing to the other ships, probably, coals, woods, whatever they needed, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "But I said, never mind.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "Five days, we were on the ship.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "We're going to go on this ship another five days.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "Somehow, we're going to make it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "We were on this ship for last six days-- no food, no water, nothing whatsoever.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We were drinking the water from the ocean, can you imagine?",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It's just like somebody give you to eat herring and no water.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "That's how we were there.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Finally, we came close to Haifa port.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The ship starts sinking.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So our captain was an Israeli from a kibbutz.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He asked for help from the English people.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So they said-- because this was at that time all English people, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "They said, go back from where you came.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We didn't send for you.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "They didn't want to let us into Haifa.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Don't you think that they'll-- they came with open arms for us?",
      "word_count": 12
    }
  ],
