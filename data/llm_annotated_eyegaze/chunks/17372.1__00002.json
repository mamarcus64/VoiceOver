{
  "stem": "17372.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Francesca ?] Grunberg from-- born.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "A little--",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Grunberg-- G-R-- it was spelled with, with umlaut.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "This is German.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So U with two line over, you read it E.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "G-R-U-N-B-E-R-G, Grunberg.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She was a little woman.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And she had nine children.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I live in Cracow before the beginning of the war.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We don't-- we didn't come from-- we haven't been rich.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It is such a big family.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "We had only a big kitchen and big room.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "In that big room was a great piano-- grand piano.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And my parents slept in bed.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I think I slept with them.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Another bed, two sisters slept.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And two younger brother, one slept on the piano, one under the piano, [LAUGHS] typical musical background.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And my older brother usually were interstate or overseas.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "See, such a big family, so I had to start to work to upkeep the family.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "So I didn't have time to study to go to school.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I had just elementary state school.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And I had to work first with my father and then with my brothers.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "In Cracow, in Warsaw, in Zakopane, in Krynica, [PAUSES FOR 3 SECONDS] in all different town.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't have a clue.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "See, I was-- I was very, very young.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But I had to wear dinner suit and atmosphere and all the smoke and drunkards.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Some better restaurants was-- I would work in Warsaw in Adria, one of the best restaurant.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "In-- in Lodz, very big restaurant, well known.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Casanova in Lodz.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I beg your pardon-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Tabarin, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Tabarin. ?] Casanova is in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And you didn't work long-- many, many months.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And there is usually two or three months.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And then you have to change.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Not-- with, with, with father and brother, never together-- or with my father, or with my brothers.",
      "word_count": 17
    }
  ],
