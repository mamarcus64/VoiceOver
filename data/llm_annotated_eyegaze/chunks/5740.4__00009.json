{
  "stem": "5740.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Everything-- the bedspread, the furniture-- it was beautiful.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And we were supposed to stay there the three days till our, our transport to Vienna goes.",
      "word_count": 17
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed in, in that hotel the three days.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And on the third day, he was supposed to come and pay for us.",
      "word_count": 14
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "The third day comes, he doesn't come.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And we can't get out of here.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have any luggage.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "We had a toothbrush.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "And my husband, I think, had a tie.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "And that's all that we possessed.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And [PAUSES FOR 3 SECONDS] he didn't come, and he didn't come.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "In the evening, suddenly, he is here.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So he says to my husband, I lost all my money.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "I went to the races or-- I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "I haven't got any money, but don't worry.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "So he went to the, to the, to the counter and said, I'm taking over the room of Mr. and Mrs.",
      "word_count": 21
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "That was our name then.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "But they knew, already, what it is.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "So they said, no, that room is taken.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "So he took out his identification [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "And he was one of the top men in the underground.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 7,
      "text": "So they let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "As it happened, we never reached Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Because we went on the train to Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "We sit, sat in the train.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "It was hours and hours that we sat there.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And we were waiting for the, for the papers to come.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And after hours, the papers came.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "Everybody's came.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "There was a big transport to Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "Everybody's papers came, but not mine.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "So I said to my husband, you go, and I'll go by the next transport to Vienna.",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "But he wouldn't leave me.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "So we went back to the German-- Austrian consulate.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "We got there a little room.",
      "word_count": 6
    }
  ],
