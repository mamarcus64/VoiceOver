  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "Did-- were you able to maintain contact with your father?",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, not at that stage.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Not at that stage.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "We were completely cut off.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was no problem.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "None whatsoever.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "My uncle took-- the only thing which he took with him was the money, right?",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "So he kept us going.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "My mother had very little, and he kept us going.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "My mother had some, and he kept us going.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "But there was no food to buy, because you couldn't buy it.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "You know, you couldn't buy it.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "But look, it was bearable.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "I was hungry, but I-- it was bearable.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "The only thing which I suffered from is I terribly, terribly missed my father and my brother.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "That was the-- the hardest part of the lot in Lwow.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "Otherwise I was running around on the-- on the trams, and I was running into-- into the theaters and the cinemas, and so forth.",
      "word_count": 24
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And the Russians were jolly, you know, and-- and there was no problem.",
      "word_count": 13
    }
  ],
