{
  "stem": "25912.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 46,
      "text": "He was Jewish but he was a member of the commission for the codification of Polish law after the formation of the Polish state.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 47,
      "text": "His son was a top criminal lawyer in the war, yes.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 48,
      "text": "In any case she knew then of my origin.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 49,
      "text": "She also knew that my father was in the Polish army.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 50,
      "text": "And subsequently she agreed to let a room to my mother who stayed there up to the time of the Warsaw rising.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 51,
      "text": "It wasn't done for money.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 52,
      "text": "When my mother had no more money to pay for her room, her rent, which was normal rent, she was told there was no problem.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 53,
      "text": "All accounts could be settle after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 54,
      "text": "She was not only prepared to let my mother live there but she really kept her morale up by letting her go out with her youngest daughter who was only about four at the time.",
      "word_count": 35
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 55,
      "text": "Taking all these risks.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 56,
      "text": "Also, as I said, she was a member of this political prisoners relief association, and they organized clandestine concerts to raise funds for the prisoners.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 57,
      "text": "And on one or two occasions when her daughter was selling programs at one of the concerts, she suggested I should go with them as well.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 58,
      "text": "My mother was very apprehensive.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 59,
      "text": "She said too many people in Warsaw know Barbara.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 60,
      "text": "And she said if she's with me she's all right.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 61,
      "text": "So I did which was a great morale booster.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 62,
      "text": "We were also visiting and being helped by a family whose sons were at school with my brother.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 63,
      "text": "It was Professor Leonard of the Academy of Fine Arts in Warsaw and his wife.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 64,
      "text": "They had two sons who were involved in the underground.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 65,
      "text": "In fact, the boys from my brother's secondary school formed one of the elite resistance units.",
      "word_count": 16
    }
  ],
