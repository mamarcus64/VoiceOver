  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Nobody was hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Per zimlanka.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Per zimlanka.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Separate.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Beginning it was communal.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "But then they begin to cook by themselves.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Everybody, like the cooking, other ones.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "The young didn't have the job.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Because the young would always, for food, the young, the capable.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "The older people, they were working the jobs.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "They were making salamis.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "They were baking bread.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "They were making shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They were making pants.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Even the Russian partisan, they were coming to Tuvia, there to the [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "And they were fixing everything for them.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The pants, the shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "This was called, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "They were calling [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And they were fixing the thing.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "If they want something, they were coming.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "They said OK.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "I wanted a salami, a good one.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "They were making salamis there.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "We had people that came from the ghettos.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "And they knew how to make salamis, and made salamis.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "They were not kosher, but they were making.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "My mother, three and a half years didn't have a piece of meat.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They were working the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They were working in the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH] is where the whole partisan, they were working there.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Administration, right.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Not too many work.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Because when they went already to the puszta.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Everything was already done.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "They knew who is in the administration.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And they knew how to work.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "Everybody was working for themselves in their place, in the zimlanka.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "They were cooking.",
