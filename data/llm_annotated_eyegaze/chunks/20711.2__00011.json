  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And they going to pick her up and put her into the Miskolc ghetto because the Miskolc ghetto is going to be picked up the next day.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "So before the parents find out-- before that wise mother off her vin-- find out where is her daughter, the ghetto is going to disappear.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And when the priest heard that, he became kind of panicky.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And he didn't know what to do, but he came up with a solution.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "You see, one of the problem was the commuting because our town had no bus, no train service, and nobody had cars.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "It was almost impossible to make any arrangement.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "But he knew a family friend who lived in a other town who had a car and asked him--",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I'd be glad to.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    }
  ],
