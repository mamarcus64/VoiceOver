  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So I found this cousin, and I talked to her.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Everything is fine.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I say I would take you with your nephew if you have money, because without money it's no use.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "It's not good for you.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "It's not good for me.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We don't know when the war is going to be finished.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So she said I've got 12 20 gold dollar bills, I got.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "This is what she got.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I say, all right, you got it.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So I say where's your nephew-- where's your husband's nephew?",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "He say he is out.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I'm going to let my friends find him and bring him here.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And they found them, and they brought them here.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "So she tells me a story.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "I tell you, does anybody know where you have the money?",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "She say no, only I'm sorry I had to tell my nephew.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "I have to tell him, because he bothered me.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "They told him if we cannot draw no way together, maybe I'll be alive or you'll be alive, I would like to know where you have the money, Tante.",
      "word_count": 29
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "He called her Tante-- aunt.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "I have to know where you have the money.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She didn't want to tell him, but later she figures maybe he's right.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "So she had under the window in the ground, digged in, the money.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The 12 20 gold dollar bills.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "So I say [PAUSES FOR 3 SECONDS] does-- so you sure [?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Belcher ?] was his name.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Belcher ?] Schtramer.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "So and then he walks in.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Somebody brought him.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "He walks in, and I said [?",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Belcher, ?] you know you want to go.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I want to take you and your aunt.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "When want to take you to our gentleman, to our nice man, a farmer.",
      "word_count": 14
    }
