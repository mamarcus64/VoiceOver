{
  "stem": "17299.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "He was from [GERMAN], a city on the Rhine River.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And then we had to line up.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "We got told first that our luggage stays behind, except the knapsacks we can carry along.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We have a couple of hours' march ahead.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "We had to line up five in a row, and for-- I would say for every 10 or 15 Jews was one armed rifleman who was in khaki uniform with the armband with skull and crossbones and a number.",
      "word_count": 39
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It was the Latvian SS and police.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Then we were marched to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We were marched to a-- a hole in a wooden fence up to a pile of rubble.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And on this pile of rubble was standing a Jew with a Star of David, the SS Obersturmfuhrer, or captain, and an SS NCO.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And we got addressed.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "My name is Max Leiser.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I am the alteste of the Jew of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "This is Obersturmfuhrer [NON-ENGLISH], the commandant of the ghetto, and this is his adjutant, [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And then we heard us a speech.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "You cannot go over the fence.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "You cannot do-- you only can go on certain streets.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "You cannot cross the line of the-- and each sentence ended with the same three words-- will be shot.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] After that we were marched to a street, and we got told that we only can go on the right-hand side of the houses.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And we entered the houses and rooms.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "We were 20 or 25 in two rooms.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And we got the shock of our life.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "The food was frozen on the table.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "Clothing was on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "Blood was on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Blood was on the walls.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "It looked as if a hurricane went through.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "We looked out of the windows.",
      "word_count": 6
    }
  ],
