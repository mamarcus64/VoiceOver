{
  "stem": "6525.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And we were writing letters.",
      "word_count": 9
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "By the Hungarians, yes-- one or two years.",
      "word_count": 8
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "What else changed?",
      "word_count": 3
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "We just have to fight for survival.",
      "word_count": 7
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 2,
      "text": "If my mother walked with me on the sidewalk and then a Hungarian soldier came across, so he pushed her down into the mud because this is his way to walk.",
      "word_count": 31
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 3,
      "text": "And we couldn't go out in the evening.",
      "word_count": 8
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] It got dark, we had to be locked up in the house.",
      "word_count": 16
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 5,
      "text": "We were afraid to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 6,
      "text": "We weren't allowed to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "There was a curfew.",
      "word_count": 4
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "A curfew, right-- curfew.",
      "word_count": 4
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "And some of the Jews-- not all of them-- had to go every month to the police and to sign themselves in.",
      "word_count": 22
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 2,
      "text": "And they were many times beaten up by the police.",
      "word_count": 10
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 3,
      "text": "And if we saw a policeman, we were scared to death.",
      "word_count": 11
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 4,
      "text": "And if we had a little food in the house, we were hiding it because we were afraid of search.",
      "word_count": 20
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we did.",
      "word_count": 3
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "They didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "They left.",
      "word_count": 2
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't many.",
      "word_count": 3
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't many.",
      "word_count": 3
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "There was many young woman who didn't have the husbands with little kids.",
      "word_count": 13
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 1,
      "text": "And they were miserable.",
      "word_count": 4
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 2,
      "text": "They tried to make a living somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 3,
      "text": "All of them became a seamstress and all kind of work so they could maintain to feed the children.",
      "word_count": 19
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 4,
      "text": "It was a big change.",
      "word_count": 5
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "She did, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 1,
      "text": "The Kehillah-- they had-- every day, they give poor people milk and bread.",
      "word_count": 13
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "Sisterhood.",
      "word_count": 1
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 1,
      "text": "Sisterhood.",
      "word_count": 1
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Whoever came.",
      "word_count": 2
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 1,
      "text": "Whoever came for food, for milk and bread, they got it.",
      "word_count": 11
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 3,
      "text": "There were a few rich people.",
      "word_count": 6
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 5,
      "text": "They were.",
      "word_count": 2
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Where to?",
      "word_count": 2
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 2,
      "text": "There was no place to go.",
      "word_count": 6
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 3,
      "text": "We were just hoping God will help.",
      "word_count": 7
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "They didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 1,
      "text": "They prayed.",
      "word_count": 2
    }
  ],
