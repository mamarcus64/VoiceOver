  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And it was not a happy marriage, but at that time you don't divorce.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "You come from a Jewish house, you don't bring shame on the family.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I knew right away it was not-- something was not right, but I stuck with it.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And he was an interior decorator, and absolutely had no concept of money.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Spent money right and left, never worried about if we had to eat or we didn't have to eat at home.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "In any event, I stayed with him, and I opened up a drapery and bedspread shop, and I had about six or seven employees.",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And in 1959, which now was 11 years, I decided there has got to be something else in life.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And the only thing I did was I-- I took a suitcase, I packed the suitcase, and I took my little boy, who was 7 going on 8 at the time, I borrowed money for an airplane ticket.",
      "word_count": 38
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "My sister gave me $50.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "I had an aunt living in-- in Los Angeles.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "I went on a plane, and I landed in Los Angeles in 1959.",
      "word_count": 13
    }
  ],
