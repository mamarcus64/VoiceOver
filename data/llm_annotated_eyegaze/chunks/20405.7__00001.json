{
  "stem": "20405.7",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was sitting somewhere [PAUSES FOR 3 SECONDS] near to the-- those wires, the electric wires.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Over there was some trash.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] that stuff was smelling too bad, because of the potatoes-- [PAUSES FOR 3 SECONDS]",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "--skins.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Was peeling the potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "The skins were put in there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And within two, three days, they smelled so bad.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't care.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I-- I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And the post was not too far away from me.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I was going in-- some-- somehow to go to the trash over there to get some of these potato skin, stinking potato skins.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Over there, some guy was working over there.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Was German, I don't know?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "No soldier.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "One of us.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And he came into near to me and he got the shovel, a heavy shovel, and he hit me.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He wanted to-- to hit me on the head.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I put my hand.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I reached.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I said, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I was screaming like this.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And he hit me like over here and on the sides.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "So right away I couldn't breathe anymore, because he broke some ribs.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "He broke some ribs.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And over here was coming a vein out, so on.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And I went running my tent, those tents over there.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "I went run over there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And I told my friends, I'm dying, so goodbye to everybody and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "But I lived.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] About two, three, four days after that, they took us from Mauthausen and we start walking, walking and walking and walking and to walking and walking.",
      "word_count": 30
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Like I told you, Dario knows the name of this-- of this camp.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] Was a provisionary camp.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "They made it just like that from the trees.",
      "word_count": 9
    }
  ],
