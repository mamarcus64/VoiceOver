    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "And my grandchild sometimes going to the-- [PAUSES FOR 3 SECONDS]",
      "word_count": 11
    },
    {
      "segment_idx": 12,
