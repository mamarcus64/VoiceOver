    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I almost-- I feel very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I look like very nice, and I look like very healthy.",
