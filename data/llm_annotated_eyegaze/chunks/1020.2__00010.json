{
  "stem": "1020.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And Molly was not even 17.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "And I got to take care.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "But Jewish people are very helpful.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "There was already a committee in Bratislava which they helped all the refugees coming in.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "They served soup.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "And they located us where to stay.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "And I think I made a little mention-- I mentioned to you before that communication after the war was on the wall.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 20,
      "text": "Everything was written on the wall-- names.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 21,
      "text": "I'm going there.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 22,
      "text": "And I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 23,
      "text": "And this and this name is in here.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 24,
      "text": "And we start to follow.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 25,
      "text": "So we found out that we're going to leave Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 26,
      "text": "We're going to Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 27,
      "text": "Well them we did tricky.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 28,
      "text": "I had my cousin, the one I took him out from the army, and the two sisters.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 29,
      "text": "Now we had to cross another border-- illegal, Germans, the Americans on one side, Russian and Czechs on one side.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 30,
      "text": "So we were coming to the border.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 31,
      "text": "I said to my cousin, you go first that the girls shouldn't be left alone.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 32,
      "text": "Always should be somebody to overlook.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 33,
      "text": "Men is different.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 34,
      "text": "I sent him first.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 35,
      "text": "I send Molly next across.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 36,
      "text": "Then Annie went.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 37,
      "text": "And I was the last one.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 38,
      "text": "And we crossed.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 39,
      "text": "So we start to walk away from the border.",
      "word_count": 9
    }
  ],
