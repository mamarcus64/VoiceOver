{
  "stem": "3474.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "It was like a-- like a liverwurst.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Like, blood.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "It was made out of blood.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "I don't know what they used call it.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "The German used that a lot-- bloodwurst.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And that was for the whole day.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They-- they made us.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "It was murder in that coal-- in the coal mine.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They used to come around, and they used to chase you.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "The coal mine, when you-- when you blast coal, is like-- over here is the ground, there is stone, and there is coal.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "We used to drill and blast it.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And then we used to put it on little truck-- little cars, you know, to-- on the railroad there's little tracks-- and shove it out.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Then push it out.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And the Steiger, you know, used to come.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "The SS man used to come.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "He didn't have a regular stick.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "He used to have an iron stick, a steel-- it was steel-like.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "Rush, rush, rush, rush.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "Come on, we need the coal.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Rush, rush.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "You know, he used to beat the hell out of us to rush, to rush.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he was-- he was in charge of the coal mine.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I think they called him SS Steiger.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I used to call him [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So we used to have-- they-- when we [INAUDIBLE], we-- they used to give us a lamp we should be able to see where to go to there.",
      "word_count": 28
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And it was murder.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They-- there was one man, he was about six feet tall.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Within two weeks, that guy-- he was about six-- that guy couldn't straighten up.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "He would bend over like this.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "He couldn't walk anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And then they used to give coal soap.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "[SIGHS] They give us soap to wash.",
      "word_count": 7
    }
  ],
