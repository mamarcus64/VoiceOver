{
  "stem": "1721.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 318.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "So, when I was about 14, 13 or 14, I don't remember the day, I just left.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I just-- I just got on a bus, and I left.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And I've been on my own ever since.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to Texas the first time.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Well, I've ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I mean, I've ran away a few times.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, before.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I've ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "You know, I just couldn't take it.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Ran away.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Police would find me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Bring me back home.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Why would they bring me back home?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I told them.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I said, I'm going to run away again next week.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And I, you know, was working part-time.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "I got some money I was able to hide.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And then one day I just my packed my bags, what little bag I had, and I got onto a Greyhound bus, and I went to Fort Worth.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Went to Texas.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh, just deliveries.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You know, whatever I would do after school.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Working for some kind of a delivery service on a bicycle in New York City.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Working for a delicatessen, delivering chickens to somebody, or messenger service, or you know, whatever, typical after-school work that teenage boys would be able to get on a bicycle.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I don't know what I was making. $0.25 an hour or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't getting any allowance.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I had to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So, I was able to-- for some reason, I was able to squirrel away some money, I think, maybe $50 or something.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I had have enough money to buy a bus ticket.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I had enough money to buy a bus ticket to Fort Worth, Texas.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went into the Greyhound bus station, and I laid down whatever money I had, and I said, how far will this take me?",
      "word_count": 25
    }
  ],
