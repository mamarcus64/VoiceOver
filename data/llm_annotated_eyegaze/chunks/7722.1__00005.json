  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Just in the same time he wasn't fanatic.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "He wasn't, he wasn't fanatic.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "My father was, not because he's my father.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] He-- [CRYING] he was-- he was a wise man.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "When-- [PAUSES FOR 5 SECONDS] When people-- when people do you know how he is in business, they had some kind of misunderstanding, they used to come to my father.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "They call this a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "They used to come, and he was the one they used to come to he should straighten them out.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And with--",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My mother was-- doing-- doing-- it was-- this is-- this is about-- so let's say '14, it's about, let's say 80 years ago-- my mother was a plain Jewish girl.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They didn't send them in that time to school.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "My father-- my father was different.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They didn't send her to school.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "She was just brought up to be able to daven, to pray in the temple, in the shul.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And to raise-- And to raise children.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And to raise-- to raise children.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So my father was different.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] So let's say-- he didn't go, like I went to school.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He already didn't go, just because of his ability.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He picked up, he picked up.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "If he would go to school, maybe-- maybe he would be-- [PAUSES FOR 4 SECONDS] a scientist.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Just-- just-- he picked up, and he wasn't-- the main thing he wasn't fanatic.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "How far did you go in school?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And where did you go?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "First of all, there was a law.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "When we worked for the Russians there was a school.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They called this [NON-ENGLISH], means they were four classes more than a public school.",
      "word_count": 14
    }
  ],
