{
  "stem": "22237.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And then they said, you're going to be deported.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And said, just get dressed.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "We give you five minutes.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And we all got dressed.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And we-- my mother tried to make some tea, something warm.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "It was cold and a rainy day.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And we were ready in a few minutes.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And-- and they said nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "My mother-- can we take something with us?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "No, not a thing.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "We couldn't take anything with us.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And we walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "It was a rainy day, and there was a big truck outside with-- with men, women, and children.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And we got into the truck, and-- and they-- and they took us-- they picked up more people, more Jewish people.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I remember my mother couldn't get the steps up quick enough, and he pushed her up, and she hurt her leg.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And they took us to a prison, and they pushed us into a prison cell.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed there all day, and they kept on pushing more, and more, and more people into that cell until we hardly could breathe anymore.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And that was early in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And then in the evening, they-- they let us get out, and we-- we had to get into a truck, that infamous truck.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I remember high truck.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "You had to climb up these high steps to the truck.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And they took us to the railway station, the Frankfurt Hauptbahnhof, and there were many other people there.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And we had to get-- there was a train.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "We had to get into the train.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And only then did we find out.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "I seem to remember that only then did we find out that we are going to be deported to Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "That's what I remember.",
      "word_count": 4
    }
  ],
