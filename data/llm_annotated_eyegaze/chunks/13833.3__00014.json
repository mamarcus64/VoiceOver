    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "We don't give a needle like this sulfa.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "So they found something.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And he said, this child has to get well, and even in a wheelchair, she has to get on a train and get out of here.",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "Anyhow, we told him then that he should work for Raoul, because he needs other doctors.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And I survived, but I could not get out of the house, because it took me quite a while.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "So I only spoke to Raoul on the phone.",
      "word_count": 9
    }
  ],
