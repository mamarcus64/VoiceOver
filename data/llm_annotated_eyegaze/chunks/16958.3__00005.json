{
  "stem": "16958.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You put this on the top, and you put some wood underneath, and this was the cooking.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "With the handle.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So we say-- we set up our cooking there.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Now, we need wood.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So we went outside in the forest at night.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We used to go out, 12 people.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "This was the most dangerous thing.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] We went out.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Two guys used to cut, and you had to cut pieces of wood no more than five-- four, five feet long, because otherwise you couldn't be-- wouldn't able to go in there.",
      "word_count": 32
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So two guys cut trees.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And we used to cut up about 10 trees at night, at least.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "About 10 inches of feet-- thick.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Tall trees.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Hard wood.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "We brought in the-- the trees.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Was like that.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "A team.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Two guys.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Two guys cut the trees with the saw.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Cut pieces.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "One guy or two guys were standing with axes, clearing the branches.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "The other went-- carry inside were young boys.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They took it away.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And inside, we have to cut these trees.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Small pieces like for kindling, how you call it.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Small pieces of wood.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And this was the wood for the cooking.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And this was very danger to go out at night.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And you made so much noise.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And this was going on for six weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We knew that what winter, it was-- but you see, there was-- the fields were very good.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "There was potatoes.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But in June were not-- nothing yet.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "At the end of June, July, it started.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "So we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Nobody knew that he are there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "One day, we want to go out.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "We come out.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "We can't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "The local people find out that we are there.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And they came.",
      "word_count": 3
    }
  ],
