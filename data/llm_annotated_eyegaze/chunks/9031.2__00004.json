{
  "stem": "9031.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And they-- they-- they put in the-- the people when they kill them, when they shoot them, and where they are in life.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They took the people.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And later on, they put it on the ground of the people.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was a big place.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We have different streets.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "When the Germans and the Lithuanian polizei, they came in, they cut up a couple streets from right side.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "From left side, they do anything to somebody else.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "But the people was-- they was in the right side.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "They took them in the-- in the buses.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And later, they took them to the fort number nine to kill them.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Nobody knows.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Later, in 1944, a lot of people knows about this place.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The actions, they do this every two months, sometimes two times in the month, when it's came in a Jewish holiday.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "From my family died about 50 people in the action, a lot of friends, a lot of my friends' friends.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It's difficult to tell how many people.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We know the-- first, in the first time, we did not know nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We know in 1943-- this was in-- in-- in July, in August-- we know was the Russian army, they pushed the Germany's army--",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "--back.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And then the Lithuanians start to help Jewish families.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "We hearing about-- the teacher told us in school what is coming the time to be-- fry?",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Free.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We don't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I was in the Lithuanian family, and in the evening time, we-- we know.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We was hearing it shooting, and the-- and the-- and the noises from the-- from the-- from the bombs, from everything.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And in the-- in the-- maybe about 6, 7 o'clock, it was a little dark.",
      "word_count": 15
    }
  ],
