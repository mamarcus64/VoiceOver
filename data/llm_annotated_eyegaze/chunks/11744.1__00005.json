{
  "stem": "11744.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I mean, it's not-- you-- you have the same title, and you have the same background as any registered nurse, but you don't get paid.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "You can-- you have to sign a paper that you will be in a war, and that you will be-- you will be serving in the war.",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "You can be drafted as soon as the war breaks out.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "But when you have children, you can get out of the draft.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "20-- [PAUSES FOR 3 SECONDS] 19 Or 20.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, I learned one year in first aid, and the second year for first-year-- first-year nursing, and second-year nursing, and third-year nursing.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I mean, regular nursing courses.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I mean, I was ready-- when the world war broke out I was ready to be taken going and go on the Maginot Line.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I never met my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He was a cousin of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We were related.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it-- it happened.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It happened, but we were practically brought up together, so that I mean-- I never had a new family when I married my husband.",
      "word_count": 24
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Did you and your husband decide to marry to each other, or was it something that was somehow decided in the family?",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "No, not.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We were not Arabs.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Only the Arabs are meant to marry the man that-- that they're given to them.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And it usually happen when they're born.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "One family promised a child of another family that they will marry.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And they usually don't even know each other before the day of the wedding.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "That's not happen in France.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "In France, you make your own decision and you do what you want.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "No, the parents are never very happy when you marry a cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "They're always afraid that it might have a repercussion on the children.",
      "word_count": 12
    }
  ],
