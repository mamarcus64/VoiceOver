{
  "stem": "1736.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I became [LAUGHS] expert in-- in building roads and airfields and fish ponds and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And I worked for a cooperative on behalf of the kibbutz for one year, and then joined the cooperative as an independent worker for a while, traveled all over the country.",
      "word_count": 31
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "One of the conditions of my employment was that I work for 12 months for the Arabs.",
      "word_count": 17
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "Because there were-- after the war, there was a shortage of tractors.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And the English government says, OK, we have 24 tractors.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "We will give you 20 off them, providing you use half of them to work half the hours for the Arab population.",
      "word_count": 22
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "And I was one of the guys that used to travel around from place to place doing that.",
      "word_count": 18
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "And in fact, I learned quite a bit of Arabic.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "But I've since forgotten.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No-no-no, this was just- Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "This was '44, '45.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, she-- I knew that she had been sent to Warsaw ghetto and--",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Well, because it was on a letter there.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "But I also know that-- I found out from my aunt who stayed after the war who had been sending her parcels there.",
      "word_count": 23
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "That aunt is still alive today in Cleveland, Ohio.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And my mother actually said to her, don't send us anymore at a certain date, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "Because she still had the children with her.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "We are going.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Don't send us anymore parcels, because we're going to be shipped to-- I forget now she said Auschwitz or one of the camps or, next week.",
      "word_count": 26
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And don't bother, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "So that's all I know.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "I've got not date or time or place of when they actually perished.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "But you found that out later through her sister about your mum and your brother and sister?",
      "word_count": 17
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
