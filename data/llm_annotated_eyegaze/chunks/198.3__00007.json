{
  "stem": "198.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.9,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "They were lined up-- no, it was different.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "Once the camps-- once the war was over, the partisans-- the-- the Czechs and the Russians who liberated us, they gave us a password.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "They opened the camp, it was still going on, war.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "They were fighting from house to house in Bad Kudowa.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And they were hiding us.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "The soldiers were hiding us in basements.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And they said, if they catch you, if they're Russians you have a password.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "So we had a password to say.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "The password was [?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Praha ?] [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "That means, [?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Praha ?] is beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "This was our password.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So we-- we were-- every time the Nazis, the Germans-- this was in the mountains of the border Germany and , Czechoslovakia.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They were fighting in the mountains to the last minute.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They would not surrender.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So the-- the Russians and the-- and the Czechs were hiding us in private homes till everything quiet down.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "So you came out of this camp.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And you were taken to a home?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We were taken to a home.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But the war was still-- the Nazis would not surrender.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They were still shooting from the mountains.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was a mountain country.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The Czech people were very good people.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Thanks to the Czech people, we survived.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I remember incidents when we worked in concentration camp, we worked in Czechoslovakia, the peasant women came out, and they cooked for us food.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And they brought food for us.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "It was almost at the end.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "It was 1944, the end of the war.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "The Germans could not get any food.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] they even took our food, and they [SIGHS] they were sharing with us.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "The Czech people were so wonderful.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "We worked at the end.",
      "word_count": 5
    }
  ],
