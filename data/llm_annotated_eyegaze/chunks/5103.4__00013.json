    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "He-- he-- we came to Australia, and I said I-- I will always be together with my family.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I would have gone through fire to be with them.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I would never have left, or said, I don't want to stay with-- or go with them, because that was everything for me, to have that family unit.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "And still, up till the end, it still was.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "My mother lived to be 81, and I miss her every day, because that unit was there.",
      "word_count": 17
    }
  ],
