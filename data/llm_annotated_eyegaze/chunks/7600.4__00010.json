{
  "stem": "7600.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My mother took me to a doctor, and he said, I don't know what she has, but this is very dangerous.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "She's going to lose all her hair.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And she's going to be very sick.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And my thought was, if I get sick, I won't get a visa.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Because before you got a visa, you had to go to the Consulate and you had to be examined by a doctor.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And if there was anything wrong-- mainly, they wanted not to let people in that had TB and other things like that.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "But I was scared to death something was going to happen.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I wasn't going to get the visa.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So he said, the best thing for me to do is to put you in the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "So I went to a Catholic hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "There was no [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "They took me, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And I was in a ward with, like, maybe 50 other people.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "We were all lined up in one room, a long hall and all these beds.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And I remember they gave me something to put on all-- all the time.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "It had to be in a basin.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "It had to be constantly refreshed, and it has to be wet all the time.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "And they didn't think I was going to do that at home, so they put me there.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "I must say, the-- the Catholic sisters were very nice.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "They were not-- they were sisters, you know, and they-- they were very decent.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And I had a woman next to me, she was a riot.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "She took a liking to me.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "I looked like a mummy, all swathed up in things and, you know, with-- with hair losing-- still coming out.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "Big blotches.",
      "word_count": 2
    }
  ],
