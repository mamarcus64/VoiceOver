{
  "stem": "16571.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Steven Pearl, formerly Solomon Gantz.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Solomon was S-O-L-O-M-O-N, which is-- was easy for me to spell when I was very young.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And Gantz is G-A-N-T-Z.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We were-- when I got naturalized, I changed my name to Steven Pearl, which was our surname from home, which is spelled S-T-E-V-E-N.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "P-E-A-R-L, surname.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My date of birth is 28 of September, 1928.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "26, I'm sorry. 26 of September, 1928.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "67.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a little village called Cuhea, which is in Marmarosch.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The capital of Marmarosch was Siget, and that is in Romania.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Siget.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "S-I-G-E-T.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "That was the capital of our [NON-ENGLISH], [NON-ENGLISH], or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "County.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Couldn't think of that.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Well, I remember when I was very young, we were the same as all the kids, Jewish kids, in Europe.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I used to have to get up in the morning very early, go to cheder, to daven.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Took about 45 minutes.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I didn't go home from there.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I had to go straight to school.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "School was from 9:00 till 1:00.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And in then back to cheder till about 5:00 or 5:30 in the evening.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "So I was virtually away all day from my parents, and all that.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And that's how it was for everybody, not just for me.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "From four or five.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Right up-- right up to your bar mitzvah.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was David Perl.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was without the A.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I added the A when I got naturalized.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He was what I would call today-- we had a kosher butcher shop.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But he was also a dogsbody.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Like my father was one of these people who could lay his hands onto anything.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We laugh at it now.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "When somebody or another had a toothache, they used to call my father.",
      "word_count": 13
    }
  ],
