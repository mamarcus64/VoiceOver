{
  "stem": "17606.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.3,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Then I went down to my father's house.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And first thing I saw the night here.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "First thing next morning, first of all, I-- when I came home, I was-- my weight was about 49 kilo.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And I was-- had a cold from traveling, because it-- a few days it took us to get to Warsaw.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And this-- [PAUSES FOR 4 SECONDS] I-- I got the arm band from my father.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "If you go out, remember we all have the wear the arm band.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "The-- the arm band.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "White with a blue--",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "--star of David.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And then I walked a little [PAUSES FOR 3 SECONDS] while And I saw they're building a wall.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "High, high wall.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And it was-- [PAUSES FOR 3 SECONDS]",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "This had several feet high, several meters high.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "A-- a brick wall.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Brick wall, with cement topped with glass and-- and this barbed wire, with a big sign in German.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "[SPEAKING GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And underneath in Polish, [SPEAKING POLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And in German, [SPEAKING GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Same thing in Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And this was already in March.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Then it was--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Because there was no import.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Was selling out what was in stock.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "But no-- no-- no new thing were coming in.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Food was rationed.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "It was different rations for Jews, different rations for-- for non-Jews, and different nations for Volksdeutsche.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They had different stores.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Had to live from-- for what existed.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "At that time, we were still living in our home.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "You could-- only thing, you could smuggle yourself into Russia, the Soviet Union.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Of course, not-- not-- don't want to mistake that the Soviet Jew-- Russian, or the Soviet Union, ever saved Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "They did not.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Only the Jews smuggled themselves in--",
      "word_count": 6
    }
  ],
