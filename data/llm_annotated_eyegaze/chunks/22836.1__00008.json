{
  "stem": "22836.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And I find him, and I put him in jail.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "The Ukraine.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "One Ukraine and on Polish people, too.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Both in jail.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "There was a court-- because the police was with me.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "The police man, he couldn't stand it.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "He say to me, Louis, wait.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "Just, just wait.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "He knows.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "When he come out back, he told him go under the-- well, how you know he's laying there?",
      "word_count": 18
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "Then he was the witness.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "And he was in court.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "He was saying that, too.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "On my side.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 10,
      "text": "He was a very good officer.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 11,
      "text": "There was a good officer.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "A Polish police.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Good and bad, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "He was a very good one.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And we put him in jail after that.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "One, oh, Polokovsky.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Polokovsky, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Well, yeah, how you spell-- how you spell it is good.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "No difference.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Polokovsky.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "He was mean.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "He was mean, and the woman, too.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "They have to be-- I don't know, maybe they have-- they don't like him.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "The Ukrainian people don't like him.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "I got Polish people not too far.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "They used to go under the lake and come to me to the grocery.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "They don't like them.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "That's not my fault that they like me and I was doing the business.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 9,
      "text": "When they come to business before Passover, I was-- I was selling 20 bags of flour, because everybody buying.",
      "word_count": 19
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 10,
      "text": "He bought three, and he never sell the three, even.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 11,
      "text": "You see, that's-- that's-- he was jealous, and mean, and trying to do something to me.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 12,
      "text": "That's, but-- but the most is the Polish people started up.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 13,
      "text": "They started up against the Jewish, too, that time.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that was not too far before the war, before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "It's not too far before the war, 1935, '36, '37.",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Did",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, every day.",
      "word_count": 3
    }
  ],
