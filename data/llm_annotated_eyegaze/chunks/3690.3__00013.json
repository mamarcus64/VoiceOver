{
  "stem": "3690.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And we'll have a cup of coffee and a piece of cake or something.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Sure enough, she came in.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And she came with a boyfriend.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And the boyfriend was also a tailor.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And he-- he didn't have a job.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He collected unemployment, he sure did.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] And I-- I looked her over.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And she looked like a nice girl.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And-- but I couldn't go out with her, because she was with her boyfriend.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So next day, I called her up on the telephone.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I says-- her name was Anna.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I says, Ann, would you like to get together with me in New York, just you and me, without your boyfriend?",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we'll go out to a nice, kosher Jewish restaurant and go to a show after we have something to eat?",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "She says, sure, yeah, I would love that.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So she came in town and to her cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And I picked her up.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And we went out.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And we had a [?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Lustig's. ?] It was a Hungarian-- Hungarian restaurant on East 10th Avenue there, a very nice, kosher restaurant, Hungarian-style cooking.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "We had a good meal.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And after the-- after we had the meal, we went to the Radio City Music Hall.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I took her back to her cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And she went back to New Jersey.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "We called each other, every second day or every day, on the telephone.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And a few weeks later, I popped the question to her.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I says, Anna, you want to get married?",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Do you want to-- or you want to go out with that schlemiel?",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I says, he-- the guy is a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "He makes [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I says, how can you make a living from that?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I says, he's a tailor.",
      "word_count": 5
    }
  ],
