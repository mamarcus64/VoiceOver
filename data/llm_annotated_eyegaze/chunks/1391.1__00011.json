      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Separate--",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Run away, they told me [SPEAKING NON-ENGLISH] Don't think they're going to [? live ?].",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "You know how I survive?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I go often, often [SPEAKING NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And I see what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So meantime, I took a couple potatoes in my sock.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I was the richest.",
