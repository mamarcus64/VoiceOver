  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I was alone.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, it was maybe 70 people.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Everybody get a room, empty room.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And the people was taken out to Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I didn't know what, what is going-- and he say, you stay there till tomorrow, nine o'clock.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "I come pick you up.",
