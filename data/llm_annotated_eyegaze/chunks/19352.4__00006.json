{
  "stem": "19352.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So I came there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And I work at the machines in the beginning.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And later on, one of another-- my boss came over.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "He asked me, what did you do in, in work B.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I said I was in the office.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "He said, we need somebody-- this was Wagner.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "It was military man, a engineer who was taking a-- he was, he was [INAUDIBLE] controlling the ammunition, what they take, what they buy, from-- this was Wehrmacht to buy from the SS for the factory, It belonged to them.",
      "word_count": 40
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And he took me there to control-- to be a controller at the office.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Before that, he used to come to the office in work B.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "He used to come to work B, to work A, to work C.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "He used to come [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And he used to leave me [PAUSES FOR 3 SECONDS] some little cards.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "He saw there is that don't show you enemies that you are mad, like that.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I was scared of him like crazy.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I didn't know what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But you can't believe a man in a, in a uniform to tell you something like that?",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't react to that.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And one day, I said to him, tell me, what did you mean?",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Why do you want from me, tell me stories like that?",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He said, you have family in-- I was locked up already at the ammunition-- the work B.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And do you have family in the ghetto?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He said, in 10 days is going to be a liquidation of the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Don't tell anybody.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And your obligation is to die together.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You cannot die every time in a life your family is taking away from you, you know?",
      "word_count": 17
    }
  ],
