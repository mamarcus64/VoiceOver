  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "There was-- one of the Anielewicz letter's messages was that it was-- one of the sweetest things in my life was to be able to fight as a free Jew for freedom.",
      "word_count": 32
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I think this message is written in [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I did not.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "This message was sent [INAUDIBLE] to-- [DRINKS].",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "This message was sent to Antek Zuckerman just before the uprising ceased.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was in his bunker quite often and there were other people, [INAUDIBLE] and some of the leaders of the-- of-- [PAUSES FOR 3 SECONDS] some of the leaders who had men, smaller groups to deal with-- to protect the-- certain points of the uprising in Warsaw.",
      "word_count": 47
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They were placed in such way that they could be easily heard or deliver the message.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Messages were not written.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "There was very little bit of written messages sent, so people had to deliver it by mouth and precisely delivering what they wanted to say and how to say it, to who to say it.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They had to know the people and describe the people and know the routes over the-- in the houses, over the attics, over the roofs, back into-- into streets and then under rubbles of houses.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Sometime we-- across the Nalewki Street we build a so-called bridge.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "That was actually not a bridge, but a wall of stones and debris to be able to crawl at-- during the night when the Germans couldn't see us passing to the other side of the street.",
      "word_count": 36
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And on one side, there was the-- part of-- of Nalewki Street that you could crawl to [INAUDIBLE] Street and the other side was the street that was beginning of Franciszkanska Street and the headquarter of Antek Zuckerman.",
      "word_count": 38
    }
  ],
