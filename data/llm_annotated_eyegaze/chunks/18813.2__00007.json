{
  "stem": "18813.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.0,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And I said, you know, let me-- let me rest.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I don't push myself.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And when I finished-- like I said, I don't like to repeat myself.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "So that-- called my name, and I went to, to Brunnlitz-- to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "In Auschwitz, we were hoping that the promises will be there that he would take us out.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And he did-- after three and a half weeks, he did.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "And nobody from us got killed.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And there were elderly womens.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "There were-- one child, as a matter of fact, we were hiding, too, a little girl, what she went with us.",
      "word_count": 21
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "And she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And we went to Brunnlitz.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "And he had a factory for us over there.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "We were working.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "We were working, but nothing was going out.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 18,
      "text": "You know, he used to say to us-- I have to put a nice word for him.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 19,
      "text": "Tomorrow, the inspection is coming, so you better watch it.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 20,
      "text": "Because if they catch you not, not-- doing nothing, I have problems.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 21,
      "text": "And he was-- if he could throw a birthday party for his wife, I wasn't at the birthday party.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 22,
      "text": "But he threw a piece of bread for us, more than usually.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 23,
      "text": "And sometimes, he shared three times a year the birthday party.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 24,
      "text": "He was very good to us.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 25,
      "text": "[PAUSES FOR 3 SECONDS] If not Schindler, I wouldn't be talking to you, to Vancouver, that's for sure.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "One of the--",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "One of the older mans, or whatever, couples, or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I was standing in a lineup.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "You know, they usually put us together-- and counting.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And then my name was called to go there.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "My friends, all the people who were there.",
      "word_count": 8
    }
  ],
