{
  "stem": "9987.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "One day, a policeman comes into my house and says to my wife, we would like your husband to come to the police station.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "She says, he's at work.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "He says, OK, Saturday is OK.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "You'll have him bring all the documents.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Saturday I came into the police station.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I-- and he says to me, you know you're supposed to be a domestic resident couple.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "How come you don't live in the place over there where you-- where you work?",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I said, well, these people have a small house.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They don't have enough room for a family, but they don't mind if I come to work every day.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He says, I know you're going to work every day.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Because he-- they-- they probably watched me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "The bus station was in the front of the house.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Every day in the morning, I used to go up with a brown lunch bag, going to work six days a week.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He asked me some more questions.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He says, please wait.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Came into his office.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Came back 15 minutes later, and he gave me a permanent residence of the United Kingdom.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "In other words, I don't have to register any more.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "I can do anything I please.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "This was unheard of.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "After six months, I got a permanent residency.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And after five years I could have become a citizen, but it took about two years.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "I was called to the English consulate.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "The number that I registered in Italy came up from immigration.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "They called me in.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "They gave me a visa to come to America.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And we left May, 1950.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "We came into New York had a big family in New York, stayed a week.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "Then we went to Chicago for a week, and we came into Los Angeles.",
      "word_count": 14
    }
  ],
