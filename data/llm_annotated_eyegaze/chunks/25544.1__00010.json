{
  "stem": "25544.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "So people would come, like, and put, the-- you know, the walk to the hospital was like from lugs.",
      "word_count": 19
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "And people--",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Wooden, you know, round--",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Logs, right.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "So people would bring in little dishes and she would, like, fill.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And my brother used to go there.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "She would feed him and--",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Watched the children.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "My-- you know, my brother was three years old at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "So since my mother worked, I had to take care of the house and clean.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And you had to clean.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "It was like a commandant would come and inspect, you know, if you washed the floor.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And you were like in a prison.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "It was like a camp, but with families, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "They took people that were single and they put them like in more severe camps.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "But these were people with families, so they were treated a little bit more lenient.",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "My father's sister was-- you know, she went back to the-- they took them separately.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Because when we came back from Russia, she went back to her parents, was like Wlodzimierz.",
      "word_count": 16
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And we were in Lutsk.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "But we all ended up-- you know, my father's brother and another brother and my grandparents, in that neighborhood, you know, in Siberia.",
      "word_count": 23
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "And later my grandparents came to live to our-- you know, to our town.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
