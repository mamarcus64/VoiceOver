{
  "stem": "17337.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Let's say you have to, what they say in Jewish, a shidduch.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And-- and I am sure that's why their marriage didn't work, because they were not matched to each-- with each other or to each other.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And she never remarry, naturally.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And that's what I remember about her, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And when the war started-- it was in 1939-- we moved already out from our house.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "We had to go to another house.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Mhm, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Grandparents and a uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they are very nice people, very lovely people.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He-- he-- he always was saying, I would like to live to be on your-- [CRYING] Sorry.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] He would say he would like to live to be on my bar mitzvah.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] [SOBBING] But he didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING] He died three years before.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And so my grandmother.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "She died four years before my bar mitzvah.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "[CRYING] We lived also together with our uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "He was single.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "He was not married.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "But we were all together in-- in the business.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "That was my mother's brother, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He was her older brother.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] His name was Leon, Leon Wanderer.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we got very well.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I remember we were-- very well life.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Whole family got very well.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I have one sister.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She was two years older from me.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Her name was Emili, Emilia.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, we got very-- we got well along.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "You know, sometime-- you know how it is between a brother and sister.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "You may sometime have some-- may not like, you know-- or something about them.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But we were-- we got along very well.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather was a very religious man.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He was a man-- man with a long white beard.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You know, we lived in-- in-- in southern Poland, what they call Galicia.",
      "word_count": 13
    }
  ],
