  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "We got-- we got a tip from always from the organization, that's tomorrow it will be not too, not too good time.",
      "word_count": 22
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Be careful.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Don't walk.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "Don't go.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "We did have tips from the Christian side-- not me, which had have the tips, but the, the top brass, our brass, our top, they knew about.",
      "word_count": 27
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Not always, but they knew when it was something.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Numbers.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "They took the poorest one.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "The poorest one, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "The poorest one had been taken first, because they went for the three pieces of bread, or three breads, with a little bit of marmalade.",
      "word_count": 25
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "They've been given by the Germans, if they go voluntarily, three piece, three breads, three kilo bread, and some marmalade for the bread.",
      "word_count": 23
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "They been-- they have to go up to the-- to the-- what you call it?",
      "word_count": 15
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "To the wagon.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to the train.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "To the train station.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "To the Umschlagplatz.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "There they are--",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "--getting three pieces, three kilo bread, and marmalade.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "So if you got two children with them, is getting nine bread.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "That's, that's rotten.",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "In the train.",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "But still, he's getting it.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "No, that was given.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No, they wouldn't get the bread--",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "On their own, because they get, and get ready when the go to the Umschlagplatz.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "But they're already locked.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "Closed.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "So they can't give the breads back to the family, and go for Kiddush HaShem.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "No, they can't.",
      "word_count": 3
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "No, they are going to the Umschlagplatz, which is locked.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "The Umschlagplatz is a place--",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "--where is, a square, where is blocked with the high walls, and a gate, and when you go there from there, you can't get out.",
      "word_count": 25
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "With, with, with Ukrainians, and Lithuanians, and they're watching inside, and killing the people already before they go to the train.",
      "word_count": 21
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "They are killed.",
      "word_count": 3
    }
  ],
