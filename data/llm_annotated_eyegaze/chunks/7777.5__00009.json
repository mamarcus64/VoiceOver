{
  "stem": "7777.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "We have two cars.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "My wife have a car.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "I have a car.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "I don't know if you know Chicago Lincolnwood suburb, good suburb.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "Lived over there.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "One day, we lived over there-- we moved in May, and this was in December-- Friday, my wife went-- Friday night.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 29,
      "text": "She went to pick up the boy from the barber, she got killed.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 30,
      "text": "In this time, I was feeling very bad.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 31,
      "text": "I wasn't be able to run the business.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 32,
      "text": "Meantime, my partner start to complain-- I'm stealing.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 33,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "And he pushed me out from the business.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "He pushed me out.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "I went in another business.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "I bought a supermarket with a friend, and we was over there about 10 years at the supermarket.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 39,
      "text": "Later, we sold the market, and I went in clothing business.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 40,
      "text": "When my wife had passed away, got killed, I married a woman.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 41,
      "text": "After a year, I married a woman with a boy.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 42,
      "text": "The marriage was not-- second marriage, if you give, you're a good husband.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 43,
      "text": "If you don't, you're not a good husband.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 44,
      "text": "To the kids, she was good.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 45,
      "text": "For me, she was not so good.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 46,
      "text": "Only I have to stay.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 47,
      "text": "She was for the kids good.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 48,
      "text": "I was just wondering the kids never said a word-- if momma was living, I was having this, I was having this.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 49,
      "text": "When my daughter graduate high school, she want to go away in a college.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 50,
      "text": "I told her, if you want stay in Chicago, I will buy you a car.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 51,
      "text": "I bought her a car, and she went to Northwestern.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 52,
      "text": "Later, my son graduate.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 53,
      "text": "No, he want to go away to Champaign.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 54,
      "text": "He was a year in Champaign.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 55,
      "text": "He don't like it over there.",
      "word_count": 6
    }
  ],
