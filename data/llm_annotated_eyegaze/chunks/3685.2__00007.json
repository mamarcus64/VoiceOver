  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And we were there till February, 1944, approximately, a year and a half, till February, '44.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Now, during-- when, when we were in the, in hiding, was a city named Brody.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Yatsko ?] used to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And every time we used to-- yeah, one of our [INAUDIBLE], he had a friend in that, in that city.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He knew a guy by the name Polak.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "So he used to-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Yatsko ?] used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And he used to see that Polak.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Polak used to give him papers.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "But when that Polak, you know, found out that [?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Yatsko ?] was hiding Jews, he knew that, sooner or later in Brody, the, the ghetto will be liquidated.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So he start asking questions.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Yatsko, ?] where is the address?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Where do you live?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And when it start-- when the, the Germans started liquidating the ghetto, he-- just in the, the daylight-- he came in.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "What are you going do?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "We were four.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "We took him in.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "We took him in.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Took him in, and we were five already.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And we were there but-- till, like I said, till February.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "During-- what-- we didn't depend only on [?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Yatsko's ?] food.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Because that was-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Wygoda ?] was only eight kilometers from Strzemilcze.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "My father used to do business there.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So he used to go out at night, contact farmers.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "He used to bring food, all kinds of food-- bacon, bread, potatoes.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Now, [?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Yatsko ?] was very poor.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "He never had a pair of decent pants.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "Suddenly, [INAUDIBLE] when he start hiding the Jews, he became wealthy.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He got money.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "So he goes on a, on a market.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "A guy meets him there-- says, [?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Yatsko, ?] what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You're dressed so nice.",
      "word_count": 4
    }
  ],
