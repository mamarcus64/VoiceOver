{
  "stem": "9538.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We were the third transport to arrive from Germany to Riga.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "The first one was from Cologne.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "The second one was from Kassel-- I know of that later.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And there was one from Dusseldorf.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And we were Bielefeld.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And they had already established themselves a little, the other-- the people, the Jewish-- German Jews who came before us.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And we had an-- they had an Eldestenrat, you know, a-- somebody in charge.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And, of course, we lived in these rooms.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We were all uncles and aunts of mine and cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We were 11 in one little room in Riga.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And it was-- I mean, I can't describe it.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "The little bit what we had-- the food we found from these poor people, which they left behind.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And we were just-- we were not given any rations or anything.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "But later on, it sort of got a little bit more normal.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Every transport had his elders and also had an Arbeitseinsatz, people that were in charge of sending the Jews to work, to put them into groups and to go to work.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And we had a little nursery for the children.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And we had a hospital, which was, at first, a makeshift hospital, all on straw, and without medicines, without bandages, without anything.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "That's when I encountered these poor people who had frostbite-- third degree-- and lost their limbs and died under terrific, terrific pain.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I worked in there as a nurse.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I was only a trainee nurse.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I never finished.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I never got my diploma as a nurse.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "We had excellent doctors, excellent doctors-- German Jewish doctors and Latvian Jewish doctors.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you in a minute.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They all--",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "--lived within the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They all lived in-- within the ghetto.",
      "word_count": 7
    }
  ],
