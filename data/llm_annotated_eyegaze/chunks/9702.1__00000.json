{
  "stem": "9702.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my name is Sonia Resnick-Tetelbaum.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name, Walter.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The date, 9/16/23.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "This is my-- on the papers that I came to America.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "But my original date is June 30, 1924.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "72, 71, 72, Let's say.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a little town-- little town.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It's a village, a farmer's village, Nowosiolki Czeskie.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I have all the spellings there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Near, well, the town, Sienkiewiczowka where I was really went to school and all my youth was there.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And the biggest, biggest city is Lutsk in Wolyn, Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name is-- Benja-- was Benjamin Walter.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I'm getting-- and my mother's name is Malka Bella.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Krystol.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I don't really recall.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was probably through a shadchan because my father was from another town.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And-- well, it wasn't far.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I really don't know how they met.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, well, see in Poland, you didn't know other way.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was you know, a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "You were an orthodox.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You didn't do anything on the Shabbat or on Yom Tov.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In my-- I had two younger brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My older brother's name was Anchel, and my younger brother [?",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Froim ?] Yonah.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My father-- well, like a merchant.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He was buying off the farmers the wheat and selling it.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And he made a living.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my mother had like a little, little department store in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Everything you could buy, from the needle to, to a piece of cloth.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Little, you know-- they worked very, hard, very hard.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "But for us children, they were trying to give everything that was possible in these times.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They, they were orthodox, but they weren't-- you know, modern.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We would call it here modern orthodox.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, young, naturally.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We had a nice, you know, family life.",
      "word_count": 8
    }
  ],
