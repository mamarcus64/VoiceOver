{
  "stem": "5626.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "She was in Gunskirchen.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "We never met over there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And that's happened seven years later.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 5 SECONDS] 1952-- [PAUSES FOR 3 SECONDS] --we got married.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "We have lots of thing to talk about it, in the past.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "She lost family.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I lost lots-- lots and lots of people from my family, especially from my mother's side, who I didn't have very close contact.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "But they all suffered and they died.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And many of them suffered in the ghetto in Budapest.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Because Budapest was the last bastion.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "The German couldn't put their hand on it.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "They were not put out-- [PAUSES FOR 3 SECONDS] --to-- to the Auschwitz gas chamber.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And from this mutual friend, I-- I-- I heard all the story about my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "Since I mentioned it before, that I saw her last time, it was in 1944, May.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "They were together in this building, the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "And when the time-- time came, they all had to march out to the railroad station.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "They were put in the wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "According to her, they were more than 70.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "And she was a young person that time.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "She went up to the wagon, almost last.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "After her came in the water-- bucket of water, and the empty bucket which they used, whoever used it.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "And they were about four, five days on this road, going from city to city.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "The door never were open.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "And that was hot, in July.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "And finally, they arrived over there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And they saw the sign, 'Arbeit Macht Frei.' They march through this gate.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "And in the same day, in the afternoon, my mother marched into the gas chamber and went through the chimney.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "And this young woman came home and she told me all these stories.",
      "word_count": 13
    }
  ],
