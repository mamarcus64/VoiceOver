{
  "stem": "21611.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "That's one thing I made up my mind when I came here.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "When I'll have two pennies, I'll share the two pennies.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "And that's what I'm doing all my life.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So they always say, for me, giving is a way of life.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And to me-- and to me, duty is joy.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I have a duty to others.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I belong to a Hadassah-- I'm a very active member of Hadassah [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I enjoy the work because I'm helping.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Anything I can help, it makes me very, very happy.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Now, tell us about your grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I have two grandchildren in England.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Justine and Rachel.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I have a granddaughter in Montreal.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "That she keep-- she's my sunshine, and she keeps me going.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "She's 13 years old now.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "That's where it's left after my son, when I lost him.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "She's wonderful.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The names?",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "One is 29, one is 27-- Rachel.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And Justine is the older one.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And Rachel is the younger one, 27.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to tell you the story never, never to forget the 6 million who perished in the most humiliating, inhuman way.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And this should be never, never repeated again.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "That's why I'm telling the story.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But this is not the whole story.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "It's only a drop on the ocean.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "That's not really what I went through.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I feel that I'm deprived by not telling the whole story because it's like three books putting into pages.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "There are so many things that I have to say.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "When I think of all of my friends, they didn't have a chance what I have.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I have a chance to be still alive and to be in a country like Canada, to be free.",
      "word_count": 19
    }
  ],
