  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I cannot remember, you see?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But still, you see the year, then we were-- and then my wife was-- and so we wait.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I was thinking, OK, now it's time for a baby to have, and my wife was pregnant.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Because I think, you see, I was in the war and I know if I will go in the war, at least somebody will be after me, a sentiment.",
      "word_count": 29
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And then comes close-- then I decided when she's pregnant, no, this isn't the place to be.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I make a nice living in the city of Lwow-- of [?",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Lanberg ?] but it is good to go in deep Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid the Germans will attack Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "That was the feelings.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "This is 1939, the end of 1939.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "OK, there was fighting with England.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But I was thinking, I have my mother's sister in England in the city of Bradford.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "If I will go to the other side near China, in Mongolia, I can come close to India.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And if I come close to India, maybe I will come to India, to England with my family.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Because I know in-- in Lodz, the family will be wiped out.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I have nothing to think will be no-- even not-- nobody knows what will be, but my feeling was like that.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And I give a detail to my wife about Bradford 77.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "This is the city where my-- my mother's sister live.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Pisarek.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Her-- Gitel.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Her name was Goldfarb, but they shortened that in Gold or Golden, you see?",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Like that shortened in England the name.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But it was like very nice-- like you tell Eaton or so, everybody knows in the city.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "So Bradford 77, this was the confidence and this is it.",
      "word_count": 11
    }
