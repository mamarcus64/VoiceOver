{
  "stem": "5313.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They just took them away, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So we had to work very, very hard.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And how long do you figure you were at Oranienburg?",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I would say about again a few months.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I didn't stay too long.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "That's why I don't have any number on my arm, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, I just had a neck, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Number on my neck, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Well, I didn't stay enough in one camp, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I was moving from one camp to next camp.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I always thought it will become a better camp than the previous camp.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Did you ever arrive at a camp that you thought was better than the last one?",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They all of them was very bad.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "From Oranienburg, I went to Sachsenhausen.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And that's where I was most the time till I'll get freed.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Sachsenhausen was a camp that they took us in a working to cleaning up bushes and around the camp.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So wasn't any hard work as was in the previous camp.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It was a little better.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But over there, we were sleeping on a floor.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't barracks.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Wasn't beds.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "It was on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "That was strictly on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Was hay and some little blankets on the top of them, and that's the way we were sleeping.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The food wasn't too bad compared to the other camp.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was-- we was getting a couple of slices of bread a day and some hot water.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So the food was a little bit better than previous camps.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was my last camp that I've been freed.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "You know, I was freed in 1945.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, I recall one particular time that a French jeep arrived in a camp.",
      "word_count": 14
    }
  ],
