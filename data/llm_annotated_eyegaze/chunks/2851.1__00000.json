{
  "stem": "2851.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Myself not to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I cried enough--",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Chana Gitalis.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "G-I-T-A-L-I-S.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Melamed.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "M-E-L-A-M-E-D.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm born in 1920.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "June the 10th.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In Luboml.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This is Polish Ukraine.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It was a little city, a lot of Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We went to Hebrew school, to Polish school.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Like in-- in the day time, we went to school, to Polish school.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And Sundays, we went to Hebrew school.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It was half and half.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Like--",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We lived on a street with the Ukrainian people, and they were very good neighbors before the war.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, sometimes.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Like with the Jewish children, we went to [INAUDIBLE], it was an organization.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We had ver-- very good times together.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was-- they lived their life, and we lived our life.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "One respect-- respect each other.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Like in our street, no trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My father sold meat, and my mother was a dressmaker.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I have-- I had two sisters and one brother.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "One sister was married.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Hinda, and my other sister was Esther, and my brother was Samuel.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Hinda was married in-- to Kowel.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Kowel was a bigger city than ours.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She had two children.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Her husband's name was Aaron Fish.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, she wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They have been married after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Very religious.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I remember [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] I remember Saturday, Friday night.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My father--",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My father came from the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He made Kiddush and we had a beautiful supper together.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We sung [NON-ENGLISH] at home, all of us.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "The name of the synagogue was-- I really don't remember the name.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The rabbi was also Malamed.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "His name was Malamed.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Leibel Melamed, this I remember good.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He lived near the synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Not so much.",
      "word_count": 3
    }
  ],
