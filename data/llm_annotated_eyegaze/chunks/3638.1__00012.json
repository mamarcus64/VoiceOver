{
  "stem": "3638.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "That I wouldn't know because-- when was the liquid-- the liquida-- before the liquidation of the ghetto, we came back.",
      "word_count": 20
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "Would be end of-- we were there approximately 12 months.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "He went to-- he went to his brother's-- his widow-- the brothers' wife business.",
      "word_count": 14
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "But there was not enough business over there.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "So he used to come-- he used to travel every day from Velichka to Krakow to look after his business, because we still have the business over there.",
      "word_count": 28
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "We didn't live over there, but the business was still there.",
      "word_count": 11
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "We live Velichka.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "And he used to-- And he used to go in the morning, come back in the evening.",
      "word_count": 17
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "He used to make some business over there.",
      "word_count": 8
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "He used to get some fruit and some other things from the peasant and used to sell it.",
      "word_count": 18
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "And some of them he was to brought back to-- to Krakow-- to Velichka.",
      "word_count": 14
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we lived like free people.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "We even attend to the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "There was a synagogue over there.",
      "word_count": 6
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yes, still open, yes, still allowed.",
      "word_count": 6
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "It was open, but you had to be careful when you go in.",
      "word_count": 13
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "You had to be careful in Velichka also.",
      "word_count": 8
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know where the synagogue-- synagogue was somewhere, you know, on the side street where nobody knew it.",
      "word_count": 19
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't know anything.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "I left Velichka a long time ago.",
      "word_count": 7
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "I left Velichka before the liquidation of Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "No, I wouldn't remember it.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "Because we went-- we went like a freelance.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "We were now on a [? cart, ?] you know.",
      "word_count": 10
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "No, but I understand that Jews were taken from Krakow to Velichka.",
      "word_count": 12
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Some of them, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "But not-- we went-- we went early.",
      "word_count": 7
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 2,
      "text": "Then we went back from Velichka to Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Because Veli--",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "I know from another interview--",
      "word_count": 5
    }
  ],
