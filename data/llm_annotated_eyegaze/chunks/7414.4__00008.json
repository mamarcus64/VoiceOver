  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] After Christmas-- it was, I think, like, February-- two three months later, when I settled in, and the life started to get quite normal for us, I went somewhere with my brother.",
      "word_count": 36
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I don't remember where we were going, but, you see, I was never afraid.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "We had to go, we had to go.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "We were in the train in Lwow, and suddenly he told me, jump out.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "The German came to-- for a control.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "So I jumped out from the running train, not knowing why.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "I had my Kennkarte.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "Afterwards, he told me something is better that they don't see it.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "But he never told me what was wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "When I was standing in front of my death, I-- no.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I got to know what it was.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But when-- then, it was too late to do something about it.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, that time was everything all right.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And then my skirts started to get tight.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So I told my-- my sister, I have to go to a doctor to make sure what's happening to me.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She was panicking.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "She never went out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "She was so afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But my brother-in-law took-- got a name of a gynecologist, and we went to see him.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
