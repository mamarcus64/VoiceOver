{
  "stem": "4662.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "I was so naive.",
      "word_count": 4
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "I was a real child.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "When I was 17, I didn't even know what-- when a woman was pregnant.",
      "word_count": 14
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 2,
      "text": "When she was this big, I didn't even know it was that.",
      "word_count": 12
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 3,
      "text": "I thought it was a sickness.",
      "word_count": 6
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 4,
      "text": "I was 17.",
      "word_count": 3
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "He was a nice guy.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "He's awfully nice to me.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "He was a nice guy.",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "I hadn't ever been out with guys or anything like that, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "So I fell in love with him, I suppose.",
      "word_count": 9
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "If that's love like that, it's love at first sight.",
      "word_count": 10
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "I was Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "I haven't ever even thought of anything like that.",
      "word_count": 9
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "My husband-- my parents were very happy about it.",
      "word_count": 9
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "But if you would have said that you were bringing home someone who was not Jewish--",
      "word_count": 16
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Then they wouldn't have liked it.",
      "word_count": 6
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "They always wanted me to marry a Jewish guy, always.",
      "word_count": 10
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "My parents-in-law.",
      "word_count": 2
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Then I went back home.",
      "word_count": 5
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "I think for a week or two.",
      "word_count": 7
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "And then Louis came over to ask my dad my hand.",
      "word_count": 11
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "You know how that goes years ago?",
      "word_count": 7
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "You had to come and ask for your-- for the girl's hand.",
      "word_count": 12
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "My husband?",
      "word_count": 2
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 2,
      "text": "He was scared, because he tore a pound note in half in his anxiety.",
      "word_count": 14
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "Well, they thought he was a little bit crazy, tearing money in half.",
      "word_count": 13
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "But they liked him.",
      "word_count": 4
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "They liked him.",
      "word_count": 3
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 2,
      "text": "He was a nice guy.",
      "word_count": 5
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 3,
      "text": "He was polite.",
      "word_count": 3
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "Well, that's-- they did really want me to stay by, but things don't go that way.",
      "word_count": 16
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 1,
      "text": "They saw we were going to do it, and that was it.",
      "word_count": 12
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 2,
      "text": "My father was a very sick man.",
      "word_count": 7
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "He had-- my mother would never tell us what it was.",
      "word_count": 11
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "But I guess it was cancer on the liver.",
      "word_count": 9
    }
  ],
