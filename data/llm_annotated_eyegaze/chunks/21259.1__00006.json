  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Eat, ah, dirty Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Very anti-- and every time was fights.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Just, yeah, outside.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And after when we went outside, you know, we got fights.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Me-- I couldn't stand it.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "You had to stand it, but always, you know, this.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And I used to fight.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And they called me my tata should come.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Family, the tata, you know, the mama is coming, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "The teacher send me away from school, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "You know, it's-- I never was right.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "They-- they right, always was right.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "But they start this everything, kids and no.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "It was no good.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "Since the war, [? it change?], no good.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No friends, just we know.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "By my uncle, my father, he was a tinsmith.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "He used to [NON-ENGLISH], big.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "You understand? this is the reason I meet them.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "But I was working with them.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "They used to work, my uncle used to take the Christian, you know, to work for them.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And I used to work too then.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I was working with them.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Yeah, I meet many times, no, always was very big antisemitism.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Since I was-- I tell you-- since I was six years old, seven years old, always even my shtetl, you know, [NON-ENGLISH], don't buy by the Jewish.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "The most Jewish, they got stores, you understand.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "They got-- they got to drink-- how you say-- restaurants with schnapps, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "The goyims would they would come in.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And always when they come in, there's always fights was there.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "In bar, they break everything.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Now in my shtetl, it was real-- I tell you a few boys, you know, become [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "You know what's a [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They got horse buggy.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "A wagon driver.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
