{
  "stem": "14810.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I was-- remember, we were about 300 or 400 inmates.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I was way in the middle.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Something told me-- I remember from school-- any time there's an attack, alarm, don't stay in the building.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Stay by the door.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I just got up quickly and I ran to the door.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "As I got to the door, bombed.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "It was a direct hit on the building, direct hit.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And I got hit-- you can see my neck.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "You see here?",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I had a splinter in my neck about that big.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Of course, at that time I didn't feel it.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "It was-- I could hear the noise-- the noise was terrifying.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "It was a direct hit, and I jumped out.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They would stay right by the door.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And fortunately, another few guys, we ran out the building.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Got away.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And the building literally collapsed under me.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And we ran out, outside, maybe about 10, 15 feet.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And I could see a big crater.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "It must have been a brand-new crater.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "A bomb hit it.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "And I jumped in there and another few guys.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was still hot.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We could feel the ground was still hot from the bomb.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And we laid there for about 10, 15 minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I could see those planes.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "They were flying so low.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And the bombs were falling from every direction.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "The earth was trembling.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "It was terrifying.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I could-- literally, I could see the pilots.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "I could see them from the cockpit, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "They were flying so low.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And from the back you could hear, the screaming and hollering.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There must have been-- most of them were buried alive.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Many of them killed and maimed.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't help them.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "After a while-- and I was laying there.",
      "word_count": 8
    }
  ],
