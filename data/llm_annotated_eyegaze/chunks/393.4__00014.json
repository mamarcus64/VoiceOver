  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "The last one, to the left, is myself, when I was a young girl, about 17.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "This is my picture from right after the liberation, about three months.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You want me to say something else?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Ah ha.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "This picture was made in Hanover, which is near Bergen-Belsen.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "The right side is my son, with his wife Sharon and two children.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "The other picture is my daughter with her family-- Leah, her husband, Larry, and the two children.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It's Ariel and Diana.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And my son's children are Emily and Jacqueline.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] | love them.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] You did [? go ?] [? in? ?]",
      "word_count": 9
    }
