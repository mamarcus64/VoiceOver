  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "From left to right is my sister Ethel, and this is me, and my husband, Mayer, and my mother, Esther, and my oldest son, Sol, and my brother, Martin, and my father, Hersch.",
      "word_count": 33
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And it was taken in Ulm in 1949.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "This is my oldest son, Sol, and my brother Martin.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Martin's about 12 years here and Sol is two.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "It was taken in Ulm, Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In 1949.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "From left to right is my son Jack, and my son Murray, and my son Sol.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And this was taken at-- in 1980, at Murray's wedding.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In 1996.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Da-da.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "This is my family.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "This is my son, Murray.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Hi.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And this is my daughter-in-law, Anne.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And this is my oldest grandson, Daniel.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Hi.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And this is my other grandson, David.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And this is Rebecca.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And this is Benjamin.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I just would like to say that I'm [BACKGROUND NOISE] really proud of my parents.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "They're living examples of the fortitude and perseverance of Jewish values and of the Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Their children and their grandchildren represent the biggest victory over anti-Semitism [BACKGROUND NOISE] and Nazism.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
