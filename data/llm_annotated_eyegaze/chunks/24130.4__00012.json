  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "How can we go in public?",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We were raised, we were so religious.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So-- I would never undress.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "In front of my sister, I would never get undressed.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And here, you'll have to go to the bathroom in public.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Anyhow, my father says, if you have to go, you'll go.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "[SIGHS] It was just-- we were so scared.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "We didn't know where we're going or what's happening.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And my sister, Lilly, was-- couldn't pick up her hand.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "We thought her hand was broken.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "So we-- we [INAUDIBLE]--",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, OK.",
      "word_count": 2
    }
  ],
