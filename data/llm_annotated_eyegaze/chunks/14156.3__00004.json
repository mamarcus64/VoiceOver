{
  "stem": "14156.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was first we stopped, and I think we were laid off.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "They waited until nightfall.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "That's what they always did, I was told.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "At nightfall, finally, the train moved, and we got into Auschwitz itself.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The boxcars opened up, and screams and holler.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Rouse!",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Rouse!",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "Rouse!",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "Hurry up!",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "Fast!",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Make sure!",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "Get out!",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "Get out!",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "All what you-- are in there-- [GERMAN] leave it alone!",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "Don't touch!",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "That will come after.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "First, you get out.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "We'll bring you the other things later.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "Don't worry about it.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "The only thing-- you had your clothes, your shoes, or whatever you had on.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "And loudspeakers started calling, anybody who's sick, women, children, on the right-hand side, over there.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And anybody who feels he's sick, same place.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "Men who are over 45, also over there.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "Others from 18 up, they can stay right here.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So I stood there.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I stood with my fellow men and friends.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And here, I was a little guy, as you can see.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And we come-- we stood in line.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And I was-- I stood in the front line.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Here comes by an SS officer.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He could have been Untersturmfuhrer.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He could have been Obersturmfuhrer.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I mean, I was not that much that I knew what rank he really had.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He came by, and he had good boots on with a-- with a-- with a whip from horse, a horse whip.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And he hit that horse whip, always, on his boots.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And he looked, you know, with a stern look, from one place and one guy to the other.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden, he stopped right in front of me.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[GERMAN]?",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I'm 18.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And I stood in attention.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I clicked my heels, according to the German military way.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And [GERMAN]?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Do you know how to work?",
      "word_count": 6
    }
  ],
