{
  "stem": "21180.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "People keep the corpse for weeks they should get a piece of bread.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But when we bury, we have to give back the card.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We get back the card, we receive the report that this person is canceled, is not born alive.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "This number of the card.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "The name and every name has a number for the card.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It happened.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, we was in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Very little Germans came in the ghetto-- came in.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But the Jewish police-- we had Jewish police-- was not-- we didn't have dogs to go house by house in this.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But people they do all kind of things to-- it was so bad.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They want to live over.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We had a Jewish cemetery, the old Jewish cemetery, which was normal burials.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "It was very strictly-- they controlled it very strictly.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "What it was, you know, black market.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Probably, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "It was.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Very seldom.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It is-- we had-- we could send out and we could receive.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But the-- from outside, when it came letters-- let me see.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "From outside, from America, from where the Germans control it.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "It was schools, yeah, but very little.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "It was very little schools.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And most of the people, schoolchildren, went to work.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They should get a soup.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "When you worked, you get by-- in the work hours, let me see, they have a lunchtime, half an hour with this.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So you got a card where you work.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And you could have a soup.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "So all the people was anxious to do soup.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "So they went to work.",
      "word_count": 5
    }
  ],
