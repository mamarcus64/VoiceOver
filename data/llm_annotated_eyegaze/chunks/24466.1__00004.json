{
  "stem": "24466.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I was already working as a tanner and consulting other firms in Radom.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I have.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Because actually, the technical, the practical part of my knowledge I got from my father.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "But I've done for one and a half years, that was Szkola Garbarska, in Radom.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "S-Z-K-O-L-A.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "G-A-R-B-A-R-S-K-A.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Mostly the theoretical part, in chemistry.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I was working in 1933.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I was already working.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And was cutting on some work in some tanneries in Radom.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "All the time, working.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And consulting.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "Tanneries, and Lublin, and Radom.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "The last one, that was in Lublin, that I consulted.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I went to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "My father, was-- [PAUSES FOR 6 SECONDS] he got a tannery.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "He was renting a tannery in Radom.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "That was on Zgeierska, on that, 4.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Z-G-E-I-E-R-S-K-A, Zgeierska.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And the name of the tanner, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "What the father got, that was [NON-ENGLISH]-- [NON-ENGLISH], K-- J-- Jehuda, K-- Kaufman.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH], J-- K.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "In Lodz.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And I was carrying them all.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Because my father got another tannery in Radom, with partners.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "D-K-D-A, DKDA.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "They were three partners.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "That was Den, D-E-N, K-A-U-F-M-A-N, that was Kaufman.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And Danzinger.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "D-A-N-Z-I-N-G-E-R, Danziger.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I was carrying on as a technical manager and as a director of that.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "In the tannery there was some quarters.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "In front of the tannery, there were some quarters.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And I was living there.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "It was about three years.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "It was quite all right.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I was too busy in my tannery.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Because that was lying on my back, on my shoulders, still work to carry, buying, selling, and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "'35, '36, '37.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I was always in touch with my family.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And my father was always coming to visit me.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Zorkarat, Z-O-R-K-A-R-A-T.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Zorkarat.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Because the tannery, my father closed the firm, closed the tannery.",
      "word_count": 11
    }
  ],
