{
  "stem": "12053.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And our school hours were, like I said, the same as a grammar school, till 1:30.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Now, there were a lot of Jewish parents who were working, businesses perhaps or had to go out to work.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And what you do with the children after half past 1:00?",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "There was a wonderful institution, which is German.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I think England's only just now about to catch up on it.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It was-- I don't, I don't think they've ever really caught up on that system.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "It's called a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "That's an after school.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "We had a Jewish [INAUDIBLE] next to the school.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "It had a little bit of a stigma attached to it.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "So the-- mostly the Polish Jewish children, who were a little bit less affluent than the German-Jewish children, they went to the [INAUDIBLE], where they were very nicely looked after.",
      "word_count": 30
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "We had lunch there, cooked on the premises, very nice.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And then we did our homework under supervision.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "There were people called [GERMAN], who, whose job it was to supervise the homework and look after us.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And there we stayed till about 5:00.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And we went off to cheder.",
      "word_count": 6
    }
  ],
