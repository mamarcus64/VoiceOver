  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And so that is where.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And their name was Mien and Jan Baay.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And that-- we stayed.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "Then, we had to get there.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "Now, in order to get there, we-- my father came back to tell us that we had somewhere to live.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "And it was getting closer to-- this would been, already, 1944 by now.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "So we said, you know, we will have to see how we can do it.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 20,
      "text": "And this Anna and the husband, Neusink, set us up with a cart, one of those carts that you wheel, a three-wheeler cart, and she put an old mattress on it.",
      "word_count": 31
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 21,
      "text": "And so, we looked like evacuees.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 22,
      "text": "And my father put me on top of the mattress, and my mother, and him, and we started walking.",
      "word_count": 19
    }
  ],
