{
  "stem": "19939.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I had little girlfriends, walking.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Public school, elementary school.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Was just one-- one school for girls, and there was another school for boys somewhere.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "There was was no-- I don't remember any distinctions at all.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I always had everything, you know, there was no A's, B's.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "It was very good, good, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I was all very good, had these friends.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't realize that, but they probably spoiled me, you know, the uncles, three uncles and then aunt.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And, you know, they took care of me.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My mother's brothers, yes, I was sick.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Maybe I had-- I don't know-- rubella or something.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I remember myself having a, you know, the normal childhood thing.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And then came vacation in the summer.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And my grandmother, you know, didn't allow me to, you know, to go to visit my father, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "He was coming.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "One day, I was supposed to take this bus that was-- what is the right word?",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Not cruising, when the bus goes from one stop to another.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Well, all right, you know, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "--bus made many stops along the way.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Many stops, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I was told that-- so I was already, I mean, independent.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They were bringing me to the bus.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "The bus driver, they knew the bus driver.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He knew the families.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "It was such a family thing.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "The bus driver, you know, they seated-- they paid my ticket.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They seated next to the bus driver.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I didn't complain.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And I was to going by myself.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The other second town or third town, the other grandparent, somebody waited for me to pick me up.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I was told not to step in Debica, right?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I have to go through and go to [INAUDIBLE] where my father is.",
      "word_count": 13
    }
  ],
