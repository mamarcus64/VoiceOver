{
  "stem": "24814.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Brendan Pearse Phibbs.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "B-R-E-N-D-A-N, first name.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Pearse, P-E-A-R-S-E.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Phibbs, P-H-I-B-B-S.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "The middle name is for Patrick Pearse, the Irish patriot who was killed by the English.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Had to slip that one in.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Just shortening of Brendon to Bren or something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Red, when I was a cowboy at the age of 16 up in Wyoming, when I had red hair.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "December 3rd, 1916.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was 80 last month.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yonkers, New York, outside New York City.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Harry Clandillon Phibbs.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "C-L-A-N-D-I-L-L-O-N, old Irish connection.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He owned an advertising agency in Chicago.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He came here as a young artist from Ireland at the age of 20-some, landed with $25-- the equivalent of $25 in  his pocket.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Didn't know a soul in the Western hemisphere, up in Newfoundland.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And made it-- did many things.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Ended up owning a medical advertising agency that did professional ads in Chicago.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Ah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was short, endlessly enthusiastic, [PAUSES FOR 3 SECONDS] dedicated to arts, culture, the outdoors, imaginative, could be a stern father when he so chose in the old country tradition.",
      "word_count": 30
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Mother's name was Therese Kelly.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "She was from Galway, Lough Corrib, Galway, Ireland.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And she died when I was only eight years old of breast cancer.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No, she was a housewife.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Actually, she did.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "She helped my father start his business.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She was his secretary and entire office staff when they opened the Harry C.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Phibbs Advertising Agency with $200 in the bank, and made it.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Tall, very pretty, dark, very vivacious.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Oh, let me think.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I can remember my mother singing a favorite song to me when I was a little boy and leading me through the forests of a place in Indiana, where we had a cabin on Lake Michigan.",
      "word_count": 36
    }
  ],
