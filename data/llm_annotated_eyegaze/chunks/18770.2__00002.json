{
  "stem": "18770.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 19.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how I get along in that school, but I do.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And everybody is in a waiting mode.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I think we're waiting for passports to get out of there, which is not something you get, you know, overnight.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "What we have going for us is that an uncle of mine-- one of my mother's brothers who had gotten out through Austria and had also been-- not only had his own money, but had married into one of the wealthier Jewish families in Austria who owned the largest Krupnik, which was the department store of Vienna, like the Macy's here.",
      "word_count": 61
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "He gets out with money and, and goes to England and, eventually, South America.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And he's trying to help us.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "So I think we're getting some money from him and some help, you know, financially and maybe trying to get us passports to get us into the United States.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "But meanwhile, we're still stuck in-- Vilnius.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "--Lithuania, in Wilno.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And so that's, that's the life there.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "There for about eight months.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Seems like a very long time.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I mean, like you really settle.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "You have a life, a daily life, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Like I said, all--",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "First school-- Hebrew, Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I have a photo-- I don't have that photograph.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I wish I had it here.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "My sister has a photograph of me in my class with this teacher who I did terrific crush on [LAUGHS] plus all these other kids, sweet kids who, I think, were all killed later on by the Germans.",
      "word_count": 38
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "There also in Lithuania, 95%, 98%, 99% of the Jews were, were murdered.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Very, very few escaped with their lives.",
      "word_count": 7
    }
  ],
