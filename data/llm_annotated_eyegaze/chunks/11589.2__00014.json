  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "He was nice and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "But we said, we have to go and settle down, and say, finally, start a new life.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "So we came here to Los Angeles, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed with her cousin for quite awhile, until we came here in Los Angeles.",
      "word_count": 16
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "She lived at, actually, outside Los Angeles, near the-- near the harbor, you know, she lives, her cousin.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Well, she start working a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I start working for the people and a little bit, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "We made a little money and start living.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And then we opened up a little place, you know, a cafeteria.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "And with that, we stayed for a while, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "That's just about the story.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No, not for me.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Because I knew the language.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I knew the language not bad.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "I knew the language before that.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "I studied before.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "I like languages.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I studied Latin, too, and that's why I made easier for me.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I speak Spanish, too, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So that's easier for me, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "Because a lot of words come from Latin.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "You just spell them different, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "But I-- I didn't have problems, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Citizenship and all that stuff, no.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "So she got it with me.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "Together, you know, we went through the whole thing, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And then we changed our name.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "That's [PAUSES FOR 3 SECONDS] the way it is.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So we bought a little business, a cafeteria.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "We stayed in it, you know, quite a while.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And it was hard.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Was time to leave the job, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Relax.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "We relaxed a little bit, and what am I going to do?",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "I enrolled a health club here, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "Going to the health club, I met, over there, some actors, big actors, you know, and everything.",
      "word_count": 17
    }
  ],
