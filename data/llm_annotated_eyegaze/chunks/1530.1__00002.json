{
  "stem": "1530.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And my little sister, Hannah, Helen, [?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Hannaleh, ?] you know, we were all--",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Everybody, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that's very difficult for me.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't have been more than 24--",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "--I think.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Early '20s, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Well, it just so happens that almost all the children were born two years apart.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So I'd say she was 22.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Young women.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Izabella must've been 20.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Phillip or [?",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Phishel ?] must have been about 19.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "But very bright.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Close to 17.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "She was five years younger than I was.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "13, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My mother and youngest little sister were gassed the night we arrived in Auschwitz, which was May 31, 1944.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "My older sister, Yolan, or [?",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Cipi, ?] was dragged to Belsen-- Bergen-Belsen.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And we heard, from other people, that she died of typhoid when the war ended already.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Until the very bitter end, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "There are four of us alive.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Well, I live in Great Neck.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Izabel lives in Manhattan, on the west side.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "My sister, [?",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Chicha, ?] lives in Binghamton, New York.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And my brother, Phillip, lives in Montreal, Canada.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, I've never been there.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Kisvarda.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Oh, oh, I see.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Kisvarda.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Well, there were a lot of poor people, poor Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And they lived on this Jewish street called Csillag Utca.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Csillag means star.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "It didn't mean Jewish star, just star.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, just star--",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "--street.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And there were a number of-- there was even a banker.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "There were a number of Jewish people who did very well.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "And my father and mother were very well thought of because my mother was an exceptionally intelligent woman.",
      "word_count": 18
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And my father was terribly bright.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "So we were a family with what you would consider [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's very difficult.",
      "word_count": 4
    }
  ],
