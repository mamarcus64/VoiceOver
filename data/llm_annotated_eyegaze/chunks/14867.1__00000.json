{
  "stem": "14867.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Shamai, and my mother's was Miriam.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Her maiden name, Segal.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Ostrog, Poland, a small town on the border of Russia and Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It was January 15, 1923.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My oldest?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Ah, earliest.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Well, my home and my upbringing, and the charming little town that I spent my childhood.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I had two brothers and two sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I was the youngest in the family.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Ostrog was really a cultural center of the entire area.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It had a lot of Jewish scholars, and they had a big yeshiva, and they had a religious school.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of prominent rabbis and scholars would come and study in Ostrog.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It goes back centuries.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Since the eighth-- eighth century, there are documents that Jews came to Ostrog.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "As a matter of fact, they were persecuted by the Germans and tried to escape, and came to the town.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "It was a very cultural town.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We had a Yiddish theatre, a regular theatre.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "It had a movie house.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "It was-- it had a very good high school and two elementary schools.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And even the public school, the public high school, was paid.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "You had to pay tuition.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "So only those kids who could afford would go to that school.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "So the standard was really very high.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And I felt that I had a very good education.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I know that my parents came-- I don't even know if they came from somewhere else, but I know that they were there, already, before 1914.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My family was part in the sense that my father was the honorary president of the synagogue, and he was an honorary chairman of the city council, and he was always involved in helping poor people.",
      "word_count": 36
    }
  ],
