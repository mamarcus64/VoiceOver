{
  "stem": "9601.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "You're washing, you're weighing, you're calculating, you weigh and you wash.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "But I kept hoping this summer, one more year, maybe easier.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "No, it was not easy.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And I made it.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "Let me tell you, when I finally got my license, Mr.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "Samuel Golder told me hang it up, hurry up.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "We had a favorite frame, fancy.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "I'm not going to spend $15 on a fancy frame.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "I went to Kmart and I bought a frame and it's lasted me all this time.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "It was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "I was able to provide very nicely for my family.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "I have a very lovely wife.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "She's very nice to me and she raised very nice children.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "Because I didn't know about raising children and educating.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "I knew how to provide for them, but children need more than just providing.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "And the children are very nice to me.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "In fact, Glenda came.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "When she found out.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "I'm having this taping, she came on her own with her husband.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "He's a very nice young man.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "My son who's a doctor now, he couldn't make it because all this scheduling over there, his wife and two little sons, grandsons, but he's one hell of a guy.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "He became a dentist.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "He was a dentist two years and he didn't like it and he decided to go to med school.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "He had all our support.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "It's a very hard job to become a physician.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "Let me tell you it's a lot of work.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "Not only is it a lot of work, but you have to have the brains for it.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "I could have never made it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 38,
      "text": "That's why I'm not.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 39,
      "text": "He's a bright young man.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 40,
      "text": "And our girls are bright young ladies.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 41,
      "text": "I'm never ashamed of them, always proud of them.",
      "word_count": 9
    }
  ],
