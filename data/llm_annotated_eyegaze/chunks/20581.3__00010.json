{
  "stem": "20581.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "They worked together with the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "What the Russians did to them, they-- when they caught them, is to put them in trucks and bring them right out to the front without any training like chopped meat.",
      "word_count": 31
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "They were the first one in the line to go in the [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So I've been there the whole night.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "There's no-- there's only standing only.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You cannot sit down.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "There was-- the one was so packed, thousands, or hundreds, of people.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "In the morning, it's still dark.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They coming in.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They say, everybody out.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Everybody out.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "This was where-- the jail, where the main jail was also in Przemysl.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "So they take the-- I seen the big trucks, army trucks.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And they take these guys.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They put them up in the truck.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And they're putting them in there.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I'm looking on.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I said, to myself well, if I ever go in this truck, I'll never be alive.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Better stay away [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Well, OK, so in the meantime, I'm looking.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And the guy who's in charge who's giving all this-- this commands, he said, it seems to me like a Jewish officer.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I jump out from the line where I am.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And the soldiers all looked at me.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "He said, where are you going?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I said, I want to see the commander.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So I go over to this man, who I think he was a captain.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And I [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "I said, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I was good in Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "I says, listen, I'm a Jewish survivor.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "I survived the concentration camp.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "I said, now you sending me with all these [INAUDIBLE] you're going to send me to?",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "He's looking at me.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "He says, what are you doing in here?",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "I said, I don't know.",
      "word_count": 5
    }
  ],
