{
  "stem": "14320.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.2,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And they-- they-- it's hard to-- was hard to find a place to live.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "So we find one-room apartment in Rowne.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "So my son, Jack, was born in Rowne.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "I was pregnant in-- under the bombs all the time, the nine months.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And-- and when the time came to-- [INAUDIBLE] to have my baby, my husband put me in a carriage, a horse and wagon.",
      "word_count": 23
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "He took me to a hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "There was no heat and no light.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "And I survived with the baby.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "So and-- what-- what else I want to tell you?",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And this one-room apartment, we took in two orphans.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "The father was killed in-- in the army, in the war, during the war.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "The mother was freeze to death in the forest.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "She went to look for food and she couldn't-- she got lost.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "So we took on those two children, a boy and a girl, sister and brother, and they stayed with us till we came up to Russia.",
      "word_count": 26
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "We came up to Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "We stopped in Boynton, Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "There the [? bruha ?] in [?",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "Nagana, ?] they gathered all the orphaned and they went to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "The children?",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "All the children.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "With the baby, we start-- you know, we told you.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "We plan to go to Palestine.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And we couldn't go through because they didn't give us certificate to go through.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And we stopped.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "We travel, travel all over.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And we stopped in Austria.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "Bindermichl was a camp, displace camp.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "And there--",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Bindermichl.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And there was one of the officers, he was checking, you know, visitors camp.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "He met my husband, and he says-- start asking him questions, from where you come, where you-- what's your plans.",
      "word_count": 20
    }
  ],
