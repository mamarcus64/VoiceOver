  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "Like, for example, from the north side, north of us was the German, German border.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "They came from the south side on the major boulevard.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "Light, tanks drove in.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "And we couldn't understand what's going on.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "Everybody was afraid, for sitting in a home.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "And beginning, we tried to get out of the house, and run to the fields, but it was worse yet.",
      "word_count": 20
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "So we got stuck over there in a farmer's house.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "And that was the beginning of World War II.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "But I, I went through two wars, not more war.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "Because one war started September 1, 1939, and it was-- Poland was partitioned, east and west.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "The eastern part, the Soviet Union took over, and the western part the German took over.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 25,
      "text": "And we were under German occupation already.",
      "word_count": 7
    }
  ],
