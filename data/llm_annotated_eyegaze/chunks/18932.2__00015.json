{
  "stem": "18932.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "It was like a slaughterhouse that-- we worked there.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know whether I should tell you about the incidents with the woman.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Well, everybody of us had a coat.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And inside was cut out a piece of material.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And everybody had a different color, like, in the back of their coats.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And we were in the Rinderhalle.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "And there was a lot of cows and bulls.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And I said to my mom, Mom, I'm going to-- of course, with my little pot-- I said, I'm going to go.",
      "word_count": 22
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And I'm going to get some milk, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "I'm going to go start-- I, I know from milking a cow, like, [LAUGHS] you know.",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "But I went.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "And another-- it was a few other women that went.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 11,
      "text": "And we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 12,
      "text": "And I was looking for a cow to milk.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 13,
      "text": "And there was another woman.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 14,
      "text": "And she was next to a bull.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 15,
      "text": "And she had the, the misfortune of having a red piece of cloth in her back of her coat.",
      "word_count": 19
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 16,
      "text": "And when she went to the cow next to the bull, of course, they're very protective-- must have been his mate or something.",
      "word_count": 23
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 17,
      "text": "And he charged at this woman.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 18,
      "text": "And he-- you know, she opened her mouth to scream.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 19,
      "text": "And the bull just tore up her face.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 20,
      "text": "And I was next to that.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 21,
      "text": "And I started screaming.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 22,
      "text": "And I was running through the-- through the gates.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 23,
      "text": "I don't know what strength-- God must have given me the strength to run over the big gates.",
      "word_count": 18
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 24,
      "text": "And I was-- started running.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 25,
      "text": "Please, help!",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 26,
      "text": "Help!",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 27,
      "text": "A woman is being hurt.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 28,
      "text": "And she's terribly-- she's, she's in trouble.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 29,
      "text": "And I ran and ran and jumped.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 30,
      "text": "And finally, the people came.",
      "word_count": 5
    }
  ],
