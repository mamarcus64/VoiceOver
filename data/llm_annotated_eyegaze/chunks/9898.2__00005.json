{
  "stem": "9898.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Every day at-- after the curfew-- it means after 6 o'clock-- we could see on the street a few kids, 7, 8, 9, 10 years old, dressed in old schmattas, rags, and almost crying in Jewish, [NON-ENGLISH], so hungry, which means, throw down a piece of bread.",
      "word_count": 47
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We are so hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Please have pity on us.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Now, they, those kids, were dying in their infancy.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "They grew old when they were small kids.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "There was no hand, no hand to give them any support where they were dying.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And they were dying from starvation.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And they were-- you could see when you walked-- I walked on the streets-- you could see the kids lying dead there beside grown-up people, dead, lying on the street.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Because they were bringing down from the apartments to the street because they didn't have the money to pay for a funeral.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I forgot to mention one thing, if I may.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "I said that the German was every day on the street and getting thousand of Jews to work for them on the other side, on the Aryan side.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "One day, I was on my way to the hospital on the Leszno Street.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "I was in my white coat with a band here, a Red Cross band.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "They caught me.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And why?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I went with a big group to the Aryan side to work.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I took my coat off first, because I didn't want them to know that I'm a physician.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we were unloading potatoes the whole day, potatoes from trains into sacks.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And during the day, every-- almost every hour or hour and a half, one of them was coming, SS soldiers, says, we know there is a physician here.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Where is he?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I didn't say a word.",
      "word_count": 5
    }
  ],
