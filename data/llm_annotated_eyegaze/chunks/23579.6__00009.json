{
  "stem": "23579.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "He was working in the [NON-ENGLISH], the Szorchnut.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And he said, Boldo's daughter?",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I am taking her to my house.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And he took me and Zusia to his house, gave us a room, and feed us, tille we got-- till we got a [NON-ENGLISH], apartment from the [NON-ENGLISH].",
      "word_count": 28
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "About Bielskis?",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Oh, sure, we came in right away.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "They were writing about us, and they wrote the first book, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "The people of the forest.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And this was written there.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And the whole story.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "He was sitting, writing, and they was telling, day by day, how that happened.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Was special treatment for us.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "They gave us right away [NON-ENGLISH]-- two apartments.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "They give us later to make a living.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "OK, a kitchen and a room.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They give us later-- to make a living, they give us medallions, taxi medallions, that were very expensive.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "They gave us without a penny.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And we made right away a living.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "My husband never was waiting to hand him something.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "He took everything by himself.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "He was working very hard, from the first day what he opened his eyes.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "In Poland, he was working very hard for the family.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "In the mill, in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And then he married the-- the lady-- he was working to her.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And then, when he lost it, the partisan.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And after the partisan, when we came to Israel, he was working very hard, too.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "And he came to something.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "I had right away apartment in Ramat Gan.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "My children went to--",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "My first son was born-- in-- my first son, Jay, was born in-- I came in Israel in 1945.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "My--",
      "word_count": 1
    }
  ],
