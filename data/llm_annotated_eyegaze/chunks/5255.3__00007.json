{
  "stem": "5255.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "A coal miner, that's a hard work.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And they gave you a piece of salami every day.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Maybe like-- 10, I would say, maybe, a quarter of a pound of salami, that was-- and soup, and a piece of bread.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "A soup-- well, it wasn't-- it wasn't too bad.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Soup, you got a good soup.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Soup at night.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Soup, salami, a piece of bread.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And in the morning, you get, like, tea.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Some kind of a tea.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "That's all?",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Because you got the piece of bread in the evening, and you had to-- had-- you had to divide it.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "You had to eat half of it, and then keep-- but you-- nobody kept it, because you were very hungry.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So you ate everything.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So you like, went to work, and you worked without food for eight hours, waiting to get to-- back to the camp to eat.",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "You were-- you got your number in-- at this camp, right?",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "In Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My number?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "When I came to Auschwitz-- and [PAUSES FOR 4 SECONDS] and I think it was in November, 1942.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Or was it in December?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But I was in the end of either November or December.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, probably December.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We-- we were taken to that Auschwitz camp, and waiting to be-- the first thing they took us is to go into showers.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "We had to take everything off, throw away our belongings and our toothbrushes and shoes, and whatever we took with us.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Clothing, nothing counted.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We had to put it in a pile.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "We went into the showers.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "It was lucky that these particular showers didn't contain gas.",
      "word_count": 10
    }
  ],
