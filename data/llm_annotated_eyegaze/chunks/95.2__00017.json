{
  "stem": "95.2",
  "chunk_idx": 17,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 65,
      "text": "And compared to a lot of other camps, even though it was not paradise, it was-- it was not something you loved being in because we worked very hard, and we had very little to eat, but compared to salt mines or quarry mines, or people who had to work really, tremendously hard, we were lucky to be in this camp.",
      "word_count": 61
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 66,
      "text": "Even though I worked in a shoe factory, I had to make 4,000 pairs of wooden heels a day.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 67,
      "text": "But nonetheless, I was inside.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 68,
      "text": "I was not in a quarry mine.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 69,
      "text": "I was not in a salt mine.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 70,
      "text": "I was not in a coal mine.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 71,
      "text": "I didn't have to schlep a lot of things.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 72,
      "text": "I just worked on a machine.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 73,
      "text": "I was doing-- I was putting a little piece of leather, or-- or rubber at the back of the heel so it wouldn't get used too fast.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And do you know what I would do?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "It was so noisy in that factory because of the machines all going together.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "All day long to keep my morale, I would sing.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Nobody could hear me.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I would sing through all the French songs that I knew from when we were entertaining.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "That's how I kept myself alive.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I was also very naive, and a lot of times, ridiculous.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I did-- one day I did something.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I don't know why I did it, how I did it, and how I got away with it, because there was a Gestapo man who was supervising this whole thing.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And he used to be-- he spoke French fluently, and somehow he took a liking to me.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He would stop at my machine and talk to me in French, and one day there was sabotage.",
      "word_count": 18
    }
  ],
