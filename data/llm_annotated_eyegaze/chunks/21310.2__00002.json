{
  "stem": "21310.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I said, you know, Tootie, that's the name of the dog, didn't want to go anymore.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I had a funny feeling.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So she said, well, you may be tired so I go.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And then I got embarrassed about it so I said, no, no, I go.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And I went again, and I only reached the third floor.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And the dog started the same thing-- just wouldn't let me go any higher.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And I got that funny feeling again.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And no sooner did I come to the bathroom when-- when two bombs fell.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And you know, there was a lot of-- of debris and-- and glass and-- and-- and a lot of dust.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "It was very dark.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And my mother had thrown herself-- when the bombs hit, my mother had thrown-- had thrown herself on top of myself and the maid who was in the shelter but also had the funny feeling and came up from the shelter at about the same time that I came and asking my mother to come down in the shelter.",
      "word_count": 59
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So we were-- both the maid and I and my mother were in this rather small bathroom, and my mother threw herself on top of us.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And-- and-- but I was injured.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And she felt something warm.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It was so dark that you-- from all the dust and stuff-- that you couldn't really see.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But she felt something warm and sticky, and she said, did anybody get hurt?",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And I had a pain above my, my eye.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So she says-- so I said, I think I did-- and-- near my eye.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And my mother says, can you see?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And I said, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And she said, what do you-- you mean you don't know?",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Are you crazy?",
      "word_count": 3
    }
  ],
