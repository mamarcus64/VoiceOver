{
  "stem": "3690.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "His name was Louis Moskovitz.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "He was a Jewish boy, a very nice boy.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "But he couldn't get a job.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He was a tailor.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And his mother used to come and shop in my store.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And he says to me, Harry, you look like a nice Jewish boy.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And-- and I have a son who is also a very nice guy.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "He's married.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And he-- he has no job.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "He's a tailor.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "I says to her, I'll tell you what, Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "Moskovitz, bring in your son, and I'll talk to him.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "I'll see what-- If he can help me, I'll give him a job.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "He couldn't get a job.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "So he-- I-- sure enough, she brought him in the next day.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "He was a nice, clean-cut fellow.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "And I gave him a job, for Louis.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 19,
      "text": "And he worked with me for about three months.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 20,
      "text": "And his wife came one day to visit him.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 21,
      "text": "He was married.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So his name-- her name was [?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Gitl. ?] I says, [?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Gitl, ?] that's-- I says to Louis, is your wife, [?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Gitl, ?] has a sister?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "He says, why?",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Because I like-- she looks like a very nice girl.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "If she has a sister, maybe we can get together.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I'm looking to, maybe, get married someday.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "So sure enough, she says, no, I-- she doesn't have a sister.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "But she has a cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And her cousin lives in New Jersey.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And she works in a bakery as a salesgirl.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I says, oh, a cousin is good, too.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "[LAUGHS] So he says, why don't you call up your cousin and tell her to come in, over the weekend, to your house, in New York, from New Jersey?",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "And I'll come over.",
      "word_count": 4
    }
  ],
