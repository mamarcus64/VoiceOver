{
  "stem": "20580.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "They were forced.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They this, they that.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Mommy, is that-- they big like a-- like a mouse, like a kitty?",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "No, they are people.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "And he's laying.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "Suddenly, he comes up.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "He wants to see who's there into the bed.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "One guy sees up-- my end or my brother's end.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Mommy, I see that.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He has hands like a human, like a man.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Five fingers, he's got-- and five fingers over here.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "She-- says the mom-- she says, yeah, he has five fingers.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "He's, like, human, like we are.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "But he killed Jesus Christ.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "They killed Jesus Christ.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] The mother told me.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "She-- Jesus Christ, if they killed.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "Sure, he has to be got-- yeah, yes, they're bad-- killed.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "They have to get killed.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "The government doesn't like them, doesn't want them because they killed Jesus Christ.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "Finally, 6, 7 o'clock, we went out back to the place.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "The kids didn't see it.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And they let us up in the roof.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "In the roof, up into the-- and, oh, we had cherries-- dried cherries and peaches and, and, you know, things like this.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "We eat that.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "We are not hunger-- you know, like this, they should give us a lunch.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "And we couldn't get in bed.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "This day we went up in the roof.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 20,
      "text": "And later, we went out back to the horses, to the cows.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 21,
      "text": "There was two cows.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 22,
      "text": "It was warmer there.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 23,
      "text": "And I was naked.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 24,
      "text": "And they give me a thing to, to put up.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 25,
      "text": "And I took-- had a needle with cotton a little bit.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 26,
      "text": "Then I took-- made by myself a, a sleeve, and make by myself a hat, and tie down the hat, and take myself buttons-- from wood, I make buttons.",
      "word_count": 29
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 27,
      "text": "And I make a coat by myself.",
      "word_count": 7
    }
  ],
