  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Does it have to be included in this conversation or not?",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "They weren't.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They weren't.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we talk and that, and-- I was a couple of days there.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And then he had a woman there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And I left.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I left.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I went back to Leninabad.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "In between time, when I told you, I learned this trade to become a driver, a truck driver.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I was driving there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And I was working for a big state company.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "My boss was a Russian Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "He was like, here, shall we say, state controller.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "That's, that was his job, state controller.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And he used to drive around to the, to the big-- it's not farm but collective points that they-- they used to bring all the grain from rice and everything-- they used to bring there.",
      "word_count": 35
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And from there, there used to be this-- to the military, to the whatever that, the government.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And he was a controller.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "He used to check if the everything's in order, you  know.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And I, the driver and I-- I stayed over there with this driver-- I used to go with him, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "This was-- we didn't have no car, but we drove-- it was a three-ton truck.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And you go over there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "The one [INAUDIBLE] was a very nice, a very nice man.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "He really treat me like, like a son.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "He was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we heard a little bit on the radio.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But it said it was a very big fight, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And then it was the fight in Stalingrad.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They fought house by house and all that.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "But it didn't much-- it wasn't much that-- the Russians didn't give you any news on the radio, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Everything was, was a secret, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No, no, not at all.",
      "word_count": 5
    }
  ],
