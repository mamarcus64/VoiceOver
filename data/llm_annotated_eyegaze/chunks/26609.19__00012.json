{
  "stem": "26609.19",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I went out.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And then I said, no.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I go back.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I can't leave.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Maybe my child is here and I leave and never come back.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "I went back.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And said, why, did you forget something?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I have to make sure.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I have to have a look again at the children.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And it was evening.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I had to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And I had another look.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And then I said, no, no, no.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I can see her.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I don't-- maybe I don't recognize her.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "I can't see her.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Went to another orphanage.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "It's another-- it's the same thing-- until I've seen about three orphanages.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And I haven't seen her, because she wasn't there.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She was there where I found her later.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Later, I gave that advertisement-- and how I found her.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And that's how the story how I found her.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And then I worked there until all those DP camps people left for other countries.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "But I had to work from-- because I worked with the UNRA, you know, the international-- I have the paper from there.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Because I haven't got a paper from [NON-ENGLISH SPEECH], because they sent me-- I couldn't leave.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "They sent me where they wanted, you know, to work.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "So they sent me to Feldafing.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And I have some from Feldafing certificates too.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "I went to work in Feldafing.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And from Feldafing, when the people all left and there was no more people, then they said, now you can go wherever you want.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "And because I worked in the Red Cross, I could go to settle in England, United States.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "I never thought of Australia.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "I thought rather United States or Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "I wanted to go to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "And when Israel was already independent, then I could go legally.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "Before, it was illegal.",
      "word_count": 4
    }
  ],
