{
  "stem": "23942.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "It was so big that I-- it was enough for three or four children.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "There was so much clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "It was a wardrobe of clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "I don't know how I got it.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "Don't ask me.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "At the time, I think I was in Zabrze, I believe.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Because I, I remember there was this [?",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Eva ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Lieberman, ?] and she said I should give some clothes.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't want to part with the clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I didn't want to-- I, I, I was so possessive-- my stuff, the first time I had clothes, you know, that I didn't want to part with it.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I said, how dare she tells me I should give up my clothes?",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was my first possession.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't want to give up.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And [LAUGHS] I, I reminded her.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "When she came to visit me, I reminded her about this incident.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I had beautiful clothes there.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I had jumpers and so much, I didn't know what to put on.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "It was such a big wardrobe.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, so I come back to Przemysl.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And, and my uncle-- I did find him.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And they made me a new skirt.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "It was the-- actually, this was the very first skirt somebody made me since my mother made me clothes.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "It was-- she made it by hand, my-- the aunt, a, a, a, a great aunt.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "He was my great-uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He was my brother-- my, my, my grandmother's brother.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "He survived in Przemysl.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "He was hidden with his son and his daughter.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And they made it.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "So I found them.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And, and--",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No, the other-- my mother's.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My mother's mother.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And this was her brother.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He survived.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And he was-- survived in Przemysl, which was very rare.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Very few people survived hiding, very few.",
      "word_count": 7
    }
  ],
