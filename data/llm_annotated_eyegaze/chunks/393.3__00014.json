{
  "stem": "393.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And the others-- the other row, there was in the middle of the barrack, just a row where to walk.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "So one-- one was the-- with the head to the walkway, and the other one with the head to the wall.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Now, of course, the walkway wasn't good, because they can step on you, you see?",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So some people gave a piece of bread to change.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I-- I never did that-- to go-- to go-- to take the wall.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "But later on, there was no problem, because so many died among us, that that was no problem.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "From the 10 people that our group, we survived two.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Everybody died over there in Bergen-Belsen in a couple of weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "The typhus killed everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I got sick, too.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I-- by miracle, I survived.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Bergen-Belsen, you-- it's-- you cannot describe.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "There is-- you cannot paint it.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "You-- you can--",
      "word_count": 3
    }
  ],
