{
  "stem": "3835.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "The first-- which they make rayons.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "In Poland, rayon came out before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "They were the ones-- the first factory of rayons, employing thousands of people.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "The only son he has, [NON-ENGLISH], who was killed-- went right away.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "And she was the only wife and heiress.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "Her vacation was in French or in England before the war, I want you to know.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "And she was only a professor of languages in the university.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 17,
      "text": "This was-- she was shining my shoes in the morning once a week.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "It was-- one day-- I was, every day, dressed, ready to run.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, I didn't wear my, my house slippers, but my good shoes, always ready.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Because I never know if I'm going to live through the day.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Either-- because I was walking and making noise with the shoe every day, somebody sent the Gestapo up.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Either this [NON-ENGLISH] found out where I am, or a super from the house-- from the building, something-- I cannot tell you how.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Banging at the door, but banging on a big scale-- I see, this is it again.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "This time, no more [?",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Muller, ?] no more Gestapo, no more thing.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I'm dead now.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "What do you do?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "In a split second-- the door was locked.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I ran in to the-- to the bathroom.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "The bathroom had a window, a small window which you could go through to the balcony.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I locked the bathroom.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I went-- it took seconds.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "I went out through the balcony and crossed over the iron gate from the balcony on the fourth floor.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And I hanged myself up-- on the fingers, I hanged myself.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And I jumped into the third-floor balcony.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "I was in the third-floor balcony on somebody's apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "The woman said, oh, who are you?",
      "word_count": 7
    }
  ],
