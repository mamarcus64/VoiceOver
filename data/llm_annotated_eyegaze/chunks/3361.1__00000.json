{
  "stem": "3361.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Sam Carmel, C-A-R-M-E-L.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Szyja Karmiol, S-Z-Y-J-A.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Karmiol is K-A-R-M-I-O-L",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The 9 the 15 1916.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "78.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The city Pinczow, Swietokrzyskie, [?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Gubernd ?] Wojewodztwo.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was three months old when my mother passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was a year and five months old when my father passed away.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And we remain seven brothers and one sister.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name is Sara Karmiol.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "From the home she was [?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Midlash. ?] And my father's name is Tobiasz Karmiol.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I-- and we were eight brothers and one sister.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They-- family want to take us apart.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Everybody want to take a child, so my oldest brother, about 16 years old, he said no.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We are going to live together.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "If I'm going to live, we're going to live.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "If we're going to die, we're all going to die together, but I don't give any child away.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And he was working very hard, and my sister became the housekeeper.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Szabsa was the oldest brother's name, and Hersz Lieb was the second brother's name.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Abraham was the third brother's name.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Then came my sister Alta Karmiol.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Then came Jonas Karmiol, then came Jopsh Karmiol, then Modcha, then me.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I was three months old when my mother passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I was a year and five months old when my father passed away.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We are eight children.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "My sister was eight years old, and she was cooking.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "She couldn't reach to the stove, so my brother made a stool.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And she was standing on that stool, and she could reach the kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And she was working very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And she was cooking, and cleaning, and everything that has to be done.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And she grew up and we didn't have much to eat, actually.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "She cooked a big pot with potato soup.",
      "word_count": 8
    }
  ],
