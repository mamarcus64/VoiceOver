{
  "stem": "21731.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "But then it was our flat when he married.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "And then we went to Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "And I introduced my husband to my grandmother.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 38,
      "text": "I took my mother and grandmother out and had a very good time.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 39,
      "text": "It was for-- more or less for three weeks or four weeks because my husband got a little bit bored with all these women around him.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 40,
      "text": "[PAUSES FOR 3 SECONDS] We came back in May and went straight to Krynica for the summer season.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "That was-- that is '28, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "That is '28.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Just a moment-- [PAUSES FOR 5 SECONDS] yes, it was.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "The wedding, the honeymoon, the first season, and we went to Vienna in '28, and came back for the first summer season.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And we had already in a-- while we were there, we found a kind of flat.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "It was not a real flat because there were no real flats there, but two rooms with a little kitchen where I could more or less be a house-- [PAUSES FOR 5 SECONDS] a-- not a landlady.",
      "word_count": 37
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't a landlady.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "A Hausfrau. 'Hausfrau' is a German word.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "But anyway, it was-- that was quite nice.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "My mother came to visit us because she wanted to know how we-- how we are coping.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was very glad to see her.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She told me sometimes off because I was very stubborn.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "When my husband said something, I didn't want to do it.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And she thought that I should do  as my husband says.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Yeah, but I thought, I will do as I feel like it.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "We went with my mother for long walks.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "We were sitting on the promenade.",
      "word_count": 6
    }
  ],
