  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And then after, you know-- 15-- like you say, one week of this thing, my sister say, you know, that you go every day to find things in the here and there.",
      "word_count": 32
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Can't you find me a piece of fish?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I find like a-- at first she felt like having a piece of fish.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And then, you know, I said, where can I find fish?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "You are in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "There is no sea in that.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Like you say like a miracle, no miracle.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "The next day I went hunting with my friend to look for food in the apartment, I saw in the middle of the snow a tiny fish lying there in the snow.",
      "word_count": 32
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I took the fish.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I took it to my sister and she ate it alive, as it was, you know, frozen and everything.",
      "word_count": 19
    }
  ],
