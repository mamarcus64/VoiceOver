{
  "stem": "16395.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I have a brother-in-law.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "This what you see, he looks like my brother, but he was like my husband.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "He is the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Where I worked was a big place where they had the steel for the-- for the ammunition.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And for some reason, he got two-- three potatoes from our meister.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he came and he said, I have three potatoes.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Can you put it in for me and cook it?",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "This was if you put it into this oven, it took a second and you took it out.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I said, you come in later with the potatoes, I'll cook 'em for you.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I was-- he already knew me from my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I'll cook them for you.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And he bought, it was a little boy, he is a [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "So he's very young.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And he bought it in, the three potatoes.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And I put in the three potatoes in the oven, and believe it or not I couldn't take them out because the meister came in, the German came in, and I had to let 'em burn.",
      "word_count": 36
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And he came for the three potatoes, and I had to tell him that I don't have 'em, they got burnt.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And he start crying, you ate them up!",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "They were my potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "You ate 'em up.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Till two-- till this day, he doesn't believe me that I didn't eat 'em up.",
      "word_count": 15
    }
  ],
