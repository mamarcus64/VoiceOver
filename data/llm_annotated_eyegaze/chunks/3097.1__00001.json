{
  "stem": "3097.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And-- but we didn't keep kosher, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "Our home, we didn't eat any pork products.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "But for me to school, my mother used to prepare food, like a lunch, which she did put in something which was not kosher.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "I used to-- I had a grandfather on my mother's side.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "His name was Lazar Chmielnicki.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "First name was L-A-Z-A-R, last name was C-H-M-I-E-L-N-I-C-K-I.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "He was a lawyer in a small town by the name of the Bodzentin.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "It's spelled B-O-D-Z-E-N-T-I-N.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "It was about two hours away by a horse from the city of Kielce, and he was a president of the Jewish [INAUDIBLE], or Jewish [PAUSES FOR 4 SECONDS] federation, if you can call this, in this town for many, many years, until early '30s, when he [PAUSES FOR 3 SECONDS] got sick.",
      "word_count": 53
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "He got a stroke, and lived another two years, and he did die.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "My grandmother, his wife, after the death of his, came to live with us in Kielce.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "My father's father, Moshe Simcha Zelinger, used to have a farm.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "He was a very strong man, physically, and he was a farmer.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "And he-- I remember him very vaguely because he died very early, as far as my age is concerned.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "When I saw him in the hospital, I remember he-- I was told later on that she did-- he did die of gout.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "This disease runs in our family, and I will come to it later on.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "And I remember him in the hospital when he was dying.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "He was very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "His wife, Perla, P-E-R-L-A , Zelinger was a midwife also.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "But in the '30s, she was [INAUDIBLE] already semi-retired.",
      "word_count": 9
    }
  ],
