  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Uh, [CLEARS THROAT] in Majdanek, we-- we [INAUDIBLE] the continuation, make [CLEARS THROAT] basket grenades, with-- with the same group of people what we've been trained, in a way, trained.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "It's not the big tour or a big spiel.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We done it-- the same thing over there-- over there.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Thousands of basket-- thousands and thousands of basket.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "There's a big grenade, a big-- like a missile.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It's gren-- it's basket to hold a missile.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And we make--",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "This is not.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I worked in-- in-- in-- in, uh, in Berlitz.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I worked by hand grenades.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It's something different.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "This is just the basket to a grenade.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But you put the grenade, you stock the grenade, or you--",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Let's say small bomb, [INAUDIBLE] a small missile.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, like you see in an airplane.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Uh, uh, a basket was so long, and about-- I would say two feet by-- by forty [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Uh, like you make basket, a regular basket, like the [POLISH], you call this in Polish.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Um--",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Woven, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's the [INAUDIBLE]--",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "From grass, from dried grasses.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "W-- from, um--",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how to say in English.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "You know like a regular basket?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Same thing.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] was more [? green, ?] or more-- yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And what did you do?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "What was your part of the work?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Uh, [LAUGH], I got the good part to help my wife.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I-- I take away the-- [CLEARS THROAT] let's say, uh, the woman [? got ?] the commander SS lady brought every day the woman.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "But I would say about 100, 120 woman, the woman been under a different sv-- field.",
