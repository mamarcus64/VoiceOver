{
  "stem": "15017.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Therefore I am a British citizen.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Living in London.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "She wanted to go back to Lodz where her family lived in number 25 [POLISH] In Lodz.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Because of the delay.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes and [NON-ENGLISH] in London.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Brought up in London.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Now, after me comes my sister, Nita.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "My sister, Hanna, who called herself Nita.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "That was the one I told you married a Belgian boy by the name of Leo Van West, and her husband was taken away to the concentration camp at Sachsenhausen.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And she escaped during that.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "She escaped being taken away, and my niece, her daughter Michelle-- who today, in New York, is a doctor.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And she married again in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And she married a man with the name of-- a guy by the name of Cooperman, and her son, who is named after my father, is a dental surgeon doing very well.",
      "word_count": 32
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "After Hanna, came [?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Suma ?], Sid.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "He lives in London at this time.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "He was born Christmas Eve 1916.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "After him, the war finished-- World War I finished in 1918.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And in 1919, my sister, Zelda, Sylvia, was born.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And she died at the age-- she was born in 1919.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And she died at the age of 69, dropped dead outside a supermarket in London.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "After her, there's my brother Herschel Zvi, who lives in Wilmette, Chicago.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And in the wintertime, he lives in Boca Raton in Florida.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "Apart from that family of nine children, we also had added to-- my mothers hard work-- we also had two young men from the [INAUDIBLE], which is a Jewish orphanage home in west Norwood in London.",
      "word_count": 36
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "They came and lived with us because they were apprenticed, and they were told to train to [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "To me, they're like brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Tailoring, yes.",
      "word_count": 2
    }
  ],
