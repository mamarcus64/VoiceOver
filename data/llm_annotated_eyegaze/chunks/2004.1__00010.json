  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "My uncle-- his name is Jacob-- he and his wife and two sons [PAUSES FOR 7 SECONDS] tried to get away from-- they got away from Cieszyn shortly before the war.",
      "word_count": 31
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I would say it must have been-- we left Cieszyn about a month before the war or thereabouts.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "He left about a week before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And they just kept going east.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And my aunt, Jacob's wife, and their youngest son had relatives in the Polish town of Gorlice, so they stayed in Gorlice.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "My father's brother, Jacob, and his son, Josef they kept on going further east and ended up in Lemberg.",
      "word_count": 19
    }
  ],
