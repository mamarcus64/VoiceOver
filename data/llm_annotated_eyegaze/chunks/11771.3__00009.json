{
  "stem": "11771.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "She went to [INAUDIBLE], to the Polish mayor, was-- were appointed from the Germans of the city.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And she said, I'm a refugee of Lida.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And I would like to be registered in Radun.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "My house was bombed.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "She show him the documents.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So he says to her, I'm taking care on the Polish people and the Russian people.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But not on the Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You have an Judenrat.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "You got-- you got to go to register to the Judenrat.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So she said, I went.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "But they refused [PAUSES FOR 3 SECONDS] to register.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "He picks up the telephone.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And he spoke to the Judenrat.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And he says, so I have here in front of me a Halpern from Lida.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Why are you refusing?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "You're denying her residence to give her a place to live, to register her?",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They say, she is not Halpern.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "She is Judith Michalowski from Ejszyszki.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They're looking for her as Communist in Ejszyszki.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And that's why we're not registered.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "They wouldn't let her out already.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "They locked her up.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] They locked her up.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When I came to the Judenrat back, said, what did you do?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "What did you do?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They're going to kill her now.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So they said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "She got to be responsible for herself.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But we don't need to be responsible, our whole community, from 1,000 people, for her.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And one man gave me a [INAUDIBLE] and said, go disappear.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Otherwise, you'll go the same way where your-- your sister.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] That was the end link from Judenrat after I went through in Ejszyszki.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "The [INAUDIBLE] I find a shelter.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "But I couldn't find a shelter in Judenrat in Radun.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] I ran away.",
      "word_count": 7
    }
  ],
