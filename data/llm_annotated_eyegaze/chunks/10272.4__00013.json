  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I myself, remember, I couldn't walk myself either.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I was walking.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "We were walking, sleeping walking.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Or, walking when we sleep, in sleep, one of the two.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Because I remember it.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I was going.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And I couldn't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "I just automatically my-- my legs, my-- my legs were moving.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And when-- and when they saw that I couldn't walk, they would push me.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And when I was seeing that he couldn't walk, I would push my friends.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "We were three guys, hand-to-hand walking.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "But then--",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
