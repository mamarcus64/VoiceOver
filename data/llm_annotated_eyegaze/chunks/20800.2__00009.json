{
  "stem": "20800.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So in May, this girl that I was supposed to go with her to get in Gestapo, she was supposed to provide me with a job, because I didn't have yet the job, and to get me the documents.",
      "word_count": 39
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "So I went--",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Nikolaev, Nikolaev.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So we went in the morning, 10 o'clock or half past 9:00, something like this.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And I walk, and all of a sudden, she was in the back.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I looked behind, and she was-- do some-- do her shoes or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Well, I didn't pay attention.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I went around.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And all of a sudden, I look up, and there's Gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So I screamed to her, come here.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And she got-- and this comes in, and he said, do you have a document that you work?",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I said, no, I'm going now to get the permission to work.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "He said, come in.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "He took me in.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And because I called her, she come in.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "So they took her.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "We was-- that's when-- but as soon as we came in, they took me in one room, and they took her in another room.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I still didn't know what's going on.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I still thought that they need a document that I worked, but I didn't work.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And I explained them that I'm going to get some job.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And that's where it starts the nightmare.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Of course, they didn't believe that I didn't get, and they start to asking me whom else you know, whom else you did.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they said, look, we know you're working for underground.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We know that you're working for underground.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I said, I never worked.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Who told you?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "What if we have a person who will tell?",
      "word_count": 9
    }
  ],
