  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "Would you try to escape again?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "She said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "If I will have a chance, I will escape.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 16,
      "text": "So he gave her to the Gestapo, the Gestapo sent her to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Luckily in Auschwitz, she met old prisoners who had some privileges.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And they helped her out.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Besides that, she was a political prisoner.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "They didn't cut her hair.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She wore the red triangle as a prisoner, because if somebody was a political prisoner in-- in Auschwitz, they-- they didn't kill.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "Because if Gestapo wanted to find out some more from them, they'd have to keep them alive.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And that's why she survived.",
      "word_count": 5
    }
  ],
