{
  "stem": "20084.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 27.5,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He asked me, could you tell me?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Did you see equipment like this?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I said, yes, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "But I said, I did-- we didn't have cogs machines in the plant.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I said, this is the only.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "But otherwise, the equipment, everything is the same.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And he asked me, how much did you make in England?",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "I said, I said about [PAUSES FOR 4 SECONDS] 15 pounds, I think. 15 pounds, I think.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "How much would that be American money?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "I bet $45.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "He said, you, you, you hired.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "By the time I paid for my first and my everything, I didn't anything.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "I had to pay my rent.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "I didn't have any money left.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, anyhow, then we had Ruth.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And Ruth, then Gail was born three years, then Suzanne-- three daughters apart-- three daughters three years apart practically.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And then [PAUSES FOR 3 SECONDS] Helene one day took her high school equivalency test.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "She learned a lot from the kids.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Then she went, then she went to high school, passed the high school equivalency test.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Then she went to college, [PAUSES FOR 3 SECONDS] graduated college.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Then she went to interior, interior decorating school, passed that, and opened up a business, became interior decorator.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And things beginning to get a little better for us.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "She could only go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "My kids never had keys to the house.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "She could go only to school at night when I came home from work and in the daytime up till 3:00.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "I didn't care what she'd done in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "It didn't bother me.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "But as long as the-- when she came home-- she had to be home when the kids came home 3:00.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So she took courses.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "She schedule everything her life.",
      "word_count": 5
    }
  ],
