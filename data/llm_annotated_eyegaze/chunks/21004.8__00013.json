{
  "stem": "21004.8",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So when she came and she was-- they couldn't just go-- and it's going a little bit a-- a hill.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "When they came out across the street over the lake-- over the lake, when she came out they couldn't walk.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Morris couldn't walk at all.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "She was dragging him like on all four, dragging him.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And he came up.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And they later-- and-- and they came up on top, they saw a house.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So they say, must be that's the only house.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "So she came in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "She knocked on the door.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And we were sitting on the opposite way in a shack, not in the bunker.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "We were sitting in a shack.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "We were figuring when to go, when to leave.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Maybe it will start again.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So-- and she came up and she knocked the door.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "An old lady, the babushka, a grandma, came out.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And she asked, babushka, is there my husband with a boy?",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "She said, sh, sh, sh, sh.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "He is here.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "So right away her son came out.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "[POLISH] was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember his second name.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "He came out and he says, come on, I'll take you.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "I'll take you.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "They couldn't go because on account of shooting from the Bandera.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "So-- so later he brought some food.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Right away, he gave my wife and Morris, gave them food.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And then he start-- we wait a whole other day.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We are-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "This was getting dark.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "She was going there.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Soon it get like 11 o'clock, 11:30.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "We picked ourself with all the food, with everything.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And we're crying.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "Crying our heart out as-- how she found us, she never been in this area.",
      "word_count": 15
    }
  ],
