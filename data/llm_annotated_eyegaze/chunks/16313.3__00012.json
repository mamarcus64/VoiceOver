{
  "stem": "16313.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 301.6,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "She tell me Russian goodbye.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "And she write a piece of paper she give to the-- to this girl.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "For the--",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "To the Nurse So anyway, I got the pain.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I laid in paid.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The next day-- the next day came two people, Uzbeks, with a-- with a wagon, it was a flat wagon with two wheels and a small donkey.",
      "word_count": 27
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And they take me out.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And they-- and I was thinking they take me out, outside, to the hall.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And the big hall, they put down everything.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Where they putting the-- the white stuff over there.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "So I was thinking they take me out and put that white stuff and goodbye.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "No, they put me on the -- on the stuff, on this.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And they take me to a couple miles away from this hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "Well, hospital, you can call it hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "You call it a morgue, mostly, like a hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] They take me away.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "They put me under the seat.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "They go and they're on an hour or more.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And there was, over there, a place.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "This-- they called it [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "And this was off-- for officers, for they came from the front with injuries, what they're suppose-- came to itself, this.",
      "word_count": 21
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "And they opened the door over there.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "It was on the-- like, on the hill.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 14,
      "text": "They open the door.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 15,
      "text": "They take me over there.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 16,
      "text": "And there was big things with water, like this.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 17,
      "text": "They put me in the water, two women, naked.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 18,
      "text": "And with big brushes, they brush off the louses.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 19,
      "text": "I got so many louses.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 20,
      "text": "They brush with those heavy louses.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 21,
      "text": "And one woman cut off the hair with the machine.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 22,
      "text": "And the louses, they brush me off good.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 23,
      "text": "And when they brushed more off they put some water, again, on me.",
      "word_count": 13
    }
  ],
