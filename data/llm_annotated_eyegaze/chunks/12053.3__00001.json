{
  "stem": "12053.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "They asked me if I would like to go to Coventry to be near my brother.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And of course, I said yes.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So they allocated me to a family called Sharpe, with an E at the end.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And now I can appreciate that you don't become a slave overnight.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "It was gradual.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "It's a gradual process.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They made me very welcome.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I was, by that time, 16.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I had my 16th birthday in the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I remember how nice the-- we had sort of aunties to look after us-- how nice.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And I still remember what I got for my birthday.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I had a lovely handkerchief and a marzipan pig.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And I had, I think, it was half a crown in English money.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "That was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And I came to that family.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And I didn't realize that they had wanted a maid.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "See, we weren't supposed to come as a labor force.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "We were supposed to be children.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "We were-- sorry, we were supposed to be children, to have an education.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "I am sadly lacking in an English education.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "I have never caught up with it.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "My spelling is atrocious.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "My style of writing is not bad, because it followed me from the German into English.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "I learned English very, very quickly, which was just one of those things as younger people do.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, almost nil, you know, just a sentence or two.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "She spoke-- it was a youngish family.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "She was only, actually, a few years younger than my-- a few years older than myself.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "She was fairly newly married to her husband, who had been married before.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And he was a lot older than her.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "To me, he seemed ancient.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "He-- she was only seven years older than me, which made her 20-- what, 16 and--",
      "word_count": 16
    }
  ],
