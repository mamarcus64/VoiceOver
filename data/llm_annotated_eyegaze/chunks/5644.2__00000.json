{
  "stem": "5644.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "When I went back to Warsaw, I started to look after the family because my brothers hadn't been back.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My mother was very, very ill, cancer.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very sad time.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Mother passed away very soon after my coming back.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "But my brothers, two brothers, came before my mother passed away.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And she was buried without any fuss because we couldn't do anything.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Was just a normal funeral.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Went there to the funeral, and it was a very sad time.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I started to come more to my future wife, which we'd been friends from the childhood.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Leah, Luba.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And we'd been starting to think about getting married but not telling anybody at the moment that we'd like to get married.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I knew-- I knew my wife, I knew from the age of about three, four, when she was three, four year old.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I'd been a friend of her brother as a--",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "--very little kid.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We went and I used to come to the place there.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I used to come very often.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And then we talked and it was already-- I'd been trying to bring food, to buy food from outside Warsaw because I knew people, the Polish people.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I used to bring food mostly for the two families, for the Landaus and for the Goodridges.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And then we decide in 1941, we decide to get married.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And we asked the one to give us the OK, was Luba's sister, Esther, which was the oldest one there.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And she approved of it.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And then we spoke to her mother.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I spoke to my father.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And everybody approved to it, and we did have a wedding.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We got married in Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, at the rabbi's place, because her mother was very religious-- Mrs.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Goodridge.",
      "word_count": 1
    }
  ],
