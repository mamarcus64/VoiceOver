  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And they had these-- these evenings, these literary evenings, and there was a semblance of normal life, though-- even though it really wasn't normal, the make believe made it so, because still there was this exchange of-- of ideas, of-- of culture, you see.",
      "word_count": 44
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "And as long as we were still at home, meaning whichever home it was, whether it was the first or the last, there was this semblance.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "For example, I remember my mother made a-- my-- Regina was engaged and Mother made the party for her.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "And she put little pieces so fern on the table cloth.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "And she made it pretty.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "You know, those things counted.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "Those were the things that really uplifted you.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "And of course, unfortunately, from that last apartment is where we-- everything changed after that.",
      "word_count": 15
    }
  ],
