{
  "stem": "16792.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And-- and I remind myself this city, Krynica, is a beautiful city.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "It's warm always.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Is nice.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And I left to Krynica.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "When I came to Krynica, it was in 1938.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And I look for a job, and I find a job in a hotel.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "The hotel-- I was-- they make me the manager from the hotel, and I was-- the hotel name was [NON-ENGLISH.] It's a nice, beautiful hotel, and I am-- with the hand I'm very good, you know, and I carve everything, and I make ice carvings for the parties every couple days.",
      "word_count": 51
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I make centerpieces.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "I don't know if you saw it, but from fruit I make.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "I make a lot of things.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And I was liked in this particular job.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "They give me good service, good money, and that's all.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And a couple days before 1939, we find out that the Germany will invade Poland, and I traveled to Oswiecim to see my family.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And this is the way it started.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "When the Germans start attacking Poland, we left everybody, all the Jewish people, in Poland including us.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "We left everything.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "Only we take whatever can you take in your hands, and we left.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "And we left in a direction to Lwow.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "It's a little bit far, but this-- in this direction we was going, because in this direction, the Germans must come after us.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "This is-- Lwow was in the-- in the side of Russia, before Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "This is the border from-- after Lwow is the border with the Russian government, the Russian state.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And we left, and I was-- I was-- when I was home, I always take my grandfather with me because he didn't see, and he was going with me all the time.",
      "word_count": 32
    }
  ],
