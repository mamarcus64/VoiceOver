{
  "stem": "21004.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "On the third day, I was going out every-- at night.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Going up.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Listening.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Do I hear-- I hear noises.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "You can't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "You can't go up.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "On the third day right in the early--",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "There was-- at night.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "No we didn't have no food at all.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Nothing at all.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We had just water.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We had just water to drink.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We wouldn't expecting-- they say it's going to be on actions.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It's not going to be an action.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Nobody know.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So we went out at night, like 12 o'clock midnight, or 11 o'clock, I think.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We went out.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I went out.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I listen.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I hear it's nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I went out, checked, quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I tell them, everybody up.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Everybody came up.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "They were 32 people.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "A lot of people-- there was still another ghetto call them with a W.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "There was-- they were working for the Wehrmacht.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "A W means the Wehrmacht, the German government.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They were working, because they had the German government.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "There was another ghetto where they-- where they needed-- those people had a W on their clothes that they can't go out free.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Because they were going out, they took them to work.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They took them to work.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "So-- for the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So they had a W.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "They had 70 people there.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "A lot of people smuggled in, like my-- my father's cousin, a lady what she was with us later.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "She and a boy.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And he was there also.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "But he didn't have the W.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "So there was more than 70 people there.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "People, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So what's happened-- oh, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "When I went out, where do I go?",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "People go-- people go and smuggled into that little ghetto.",
      "word_count": 10
    }
  ],
