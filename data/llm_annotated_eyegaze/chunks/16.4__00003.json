{
  "stem": "16.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 316.8,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And then one day, I went over to him.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I would like to make my way back to my hometown.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "He says, we have trucks leaving every day to Pilsen.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Just get on one of those trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I still have my suit on, the prison suit.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I got into Pilsen.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And there, we ran into a cousin that was just-- he got liberated in, in January already.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "That's Andy's cousin, the one that-- that's coming here.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "He gave us a bunch of money, gave us a bunch of cigarettes.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And he told us, don't go back to Munkacs.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Nobody's going back there because the Russians are occupying it.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "You come to Sighet, which is the place where they took me from.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Two of the Kaufmans-- two of the Kaufmans are, are there.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "They made it.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "Of the three boys-- the three sons-- remember, I told you my aunt was asking my father to send me one of your boys because my three sons were drafted.",
      "word_count": 30
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "The two boys made it back.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "The third one that was with me in concentration camp, he never made it back.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, that-- that's where we went back.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But from Pilsen, I had to get on a train to go to Prague.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I was still alone, not knowing anyone.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Oh, wait a minute.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "That was in Prague where we met my cousin that give us money and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I got on a train in Pilsen going to Prague, which was a few hours' travel.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I was allowed to travel, free of charge.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I laid down in one of those-- it's like-- in, in Europe they have trains, first class, second class, and so on.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I didn't care what class, but it must have been better than third class.",
      "word_count": 14
    }
  ],
