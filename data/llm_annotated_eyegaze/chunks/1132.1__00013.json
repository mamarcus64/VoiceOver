  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I was very worried as to where are these people going.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "It's very scary.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I mean, it's very scary when you look down, and in the middle of this courtyard, you see people being rounded up and people being taken away.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "That's pretty scary.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "This is how my uncle and my cousin was taken away.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I remember everybody being very hushed, and everybody being very worried and crying.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I also remember there was a superintendent in the house-- in the building-- who was very protective of us.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And it was through them that we found out if a raid was coming, or if additional people were coming and we were going to be rounded out.",
      "word_count": 28
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "So that this was something that everybody knew that this superintendent was very friendly towards us.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Whether it was people were jealous of us of that, I don't know.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I would think that they probably were.",
      "word_count": 7
    }
  ],
