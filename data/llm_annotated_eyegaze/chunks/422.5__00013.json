{
  "stem": "422.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't get on the-- being paid under the table.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "So the uncle gave me.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "They want $400 for an apartment full of roaches.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Full of roaches.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Dirty, filthy.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "Took me time until I could clean up.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't clean up, because I was already pregnant.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And my husband got a job right away as a presser.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "Because he didn't-- they took him in, and some friends that he-- his father's friends that they were here-- gave him a job in a factory as a presser.",
      "word_count": 29
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "He never was a presser.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "He was a printer in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "But if you don't know the language, and there is a family with two kids to support-- so he became a presser.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "Worked very hard.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "He had to go for a major operation, because he had that bullet.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 4 SECONDS] And that's how it was.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "First, on the-- first, yeah, the first, the HIAS.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "There was a Jewish organization for refugees, that they were waiting for us.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They were waiting for us by the boat.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And they took us to a dilapidated hotel, the HIAS, they call it.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Somewhere on Lafayette Street, was the hotel.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We were there 10-- 10 weeks, I was living there.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Because they offered me apartments.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And every apartment was on a fifth floor walk-up.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And here I have two little kids.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "One, and one is going to be born soon.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And how I going to walk up five floors?",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And I couldn't accept this.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "It took me 10-- 10 weeks, until somebody came and offered me an apartment in East New York.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "At that time, there was still a lot of Jews there.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It was 1948.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And East New York, on a second floor walk-up.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But I had to give them-- $400 the people want.",
      "word_count": 10
    }
  ],
