{
  "stem": "293.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And the amount of boys gymnasium was three times as many as a girl.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It was difficult to get for my sister to there.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "You had-- you didn't have other brothers or sisters?",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My sister went to the Hebrew gymnasium.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] extremely hard high school and a very high scholastic level.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "You have to be-- because they have to-- to graduate high school-- in this time, the high school was eight years long.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Later on, the division came between junior high and [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "You have to be a very good student to pass the examination of all the general classes, what every high school has to go through, plus also Hebrew classes, where they have extra curriculum in Hebrew in language and religion and so much--",
      "word_count": 43
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "This- only I was a member of Jewish school or university, but not-- they were not political organization.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They were mostly more like a fun and game and meeting people and have good time.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "School-- high-- there was high school-- how do we call this?",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There was Jewish high school organization.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "But there was some groups of Jewish organization, like Zionists.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "You see-- no, I didn't belong to any political type of group, not to the Zionist, not to Betar, not to any of them.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I belonged to the sports organization, [? my ?] [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "It was very well organized sport organization because I was a-- a-- I would say, extraordinary sportsman in every field.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I was swimmer, and I was skier.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Skier and swimmer and hockey player and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was excellent.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And I became first Jew in Polish National Ski Association that reached the rank of the instructor, a full fledged instructor of teaching skiing.",
      "word_count": 24
    }
  ],
