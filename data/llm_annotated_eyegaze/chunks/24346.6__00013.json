  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Again, she went, what we now know was near Lodz.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "It was-- they used to gas the people in the truck, while we're still traveling, and dumping them in ditches.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We know that.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "My sister--in fact, my sister said to my brother, Abraham, don't worry.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I got two kilograms of gold in my girdle, hidden.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And I'll survive the war anywhere.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Little did they know that they'll have to undress and leave everything.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "From the experiences I had later in Buchenwald and in Dora, I know what happened to her gold.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    }
  ],
