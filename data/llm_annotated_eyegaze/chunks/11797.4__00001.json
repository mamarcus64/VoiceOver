{
  "stem": "11797.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] If they caught you sleeping, you didn't get up.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "They shot you right at the machine.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] If they caught you looking at a part slowly, they caught you-- shot.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "If you examined the part for any particular scientific reasons.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "No, they got you shot.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "If you walked slow, they shot you.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "If you walk fast, they shot you.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "There was no reason.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 4 SECONDS] There was no reason.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "There was-- and you were always-- the people who worked there felt their clothes was with oil.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "All over, the oil.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "Because the oil from the machines, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "Because there was grinders there, there were lathes there, there was polishers there.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "Different to polish these parts, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "There was dirts there-- there was-- The machines were working.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And their clothes were very shiny, because the oil completely smothered their clothes, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "People were black because the oil on their hands was-- they worked like-- like animals on that machine.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "On those machines.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Day in, day out.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Three hours-- three shifts they were there.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "But the Poles were there, too.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "The Poles.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "The Poles were like-- they were like foremans.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "They were teaching the Jews how to do it now.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "They were nice.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Some of them were nice and some were not.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "They were afraid to actually associate with us now.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Me being very gullible, and very immature, and very young.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "This happened in 1943.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] End of-- end of '43 though.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "I, um-- [PAUSES FOR 5 SECONDS] I, um-- [PAUSES FOR 3 SECONDS] The Jewish people-- the other five got together with the underground.",
      "word_count": 23
    }
  ],
