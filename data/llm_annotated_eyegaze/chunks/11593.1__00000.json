{
  "stem": "11593.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Eastern Poland in 1928, October 10.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Next city calls Zdolbunow, which-- which is a residential town about 10 miles from the largest city called Rovno.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Eastern Europe-- Eastern Poland became a country after 1920, no?",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My father was one of five brothers and two sisters.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My mother's one of six brothers and two sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My grandfather was a grain merchant, grain and cattle merchant.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And the-- and the family lived in the town for hundreds of years.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "When my dad was drafted in the army, in the Polish, on 1921, after Poland became independent of Russia.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And he served in the army in Krakow in Marshal Pilsudski's elite cavalry unit.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "After my dad finished the service, he came back to Zdolbunow.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "He was going to visit his uncle in a town called [POLISH], 20 miles from Zdolbunow.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "He met my mother on a train, and they got married a few months later.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "Then they moved back to Zdolbunow and started their new life.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "My dad was dealing in commodities, like grains and hops, and my mother operated a country store.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Hops.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Hops that you make beer from.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "You brew beer.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "H-O-P-S, hops.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My father's brothers, the four, also were in the same line of business, grain and-- and cattle merchants.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My father was the second oldest of seven children.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Two sisters-- one name was Rachel, and one name is Testle, were married, and their husbands were basically farmers.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "His sisters.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My mother's three sisters left in the turn of the century to America.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And the two remaining sisters lived in [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH] was a town surrounded by forest, and the basic industry was lumber and floor coverings and-- and plywood.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "About 4,000 Jews lived in [POLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "My aunt--",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, it was about 20,000 people.",
      "word_count": 6
    }
  ],
