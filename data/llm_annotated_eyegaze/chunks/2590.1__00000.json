{
  "stem": "2590.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "And just because she was not Jewish, he did not marry her.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And he met this girl in California when he was 40 years old.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He was a great intellectual.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Nobody is good enough for him.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And somehow, he said, gosh, it's like two heads and one mind.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And both decided to go to Israel and live in Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I am Jenny Singer.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Zenia Lidychower.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "70 Years.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "March 15, 1925.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Rowne, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Rowne is a very nice cultural city.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It had 85,000 population, half of it, maybe even more, was Jewish population.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Actually, we lived in [NON-ENGLISH], where my father had a mill.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But before my mother gave birth to me, my grandparents, the parents of my mother, insisted she should come to Rowne.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "They told they'll take care of my sister and my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And after a couple of weeks that I was born, we moved back to [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And my father, unfortunately, died when I was six or seven months old.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And my mother and my sister and myself, we moved back to Rowne.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed with our grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "We were very comfortable.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "My grandfather was a merchant with wheat export/import.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And I also had a rich uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "My mother's brother, oldest brother, was also a merchant.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And he didn't have any children.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Matter of fact, he wanted to adopt me, but my mother didn't want him.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "But he was very nice to us.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And we didn't lack anything.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "We had a nice cultural life.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "When I was seven years old, my mother went to Czechoslovakia, to Carlsbad, and she met this very nice gentlemen, Ziggi Sardovski, who was an engineer.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "And he did not know anything about Judaism.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "It was before the holidays of Pesach.",
      "word_count": 7
    }
  ],
