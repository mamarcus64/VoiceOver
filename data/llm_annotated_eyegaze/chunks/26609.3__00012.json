  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "He used to sell only-- not only sell.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "People used to go into his place and drink, sit there and drink.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "It was-- in front was that place where people used to drink alcoholic beverages or anything like it.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And at the back was his apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "He had two sons.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "One was a Hassid, the younger one.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And that younger one was, I remember as a child, I remember him.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "He was much older.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "Could be used to be like my sister's age, eldest.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "The other one was a Zionist, went to Israel.",
      "word_count": 9
    }
  ],
