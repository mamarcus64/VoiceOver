{
  "stem": "17845.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 126.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We were allowed to go outside of the camp to school, the children were allowed-- allowed to go to school.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not very much.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "They had to get special permission.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "My mother used to go out, and my father used to bring from-- he got straightaway a job.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was managing three restaurants, I mean restaurants-- I wouldn't tell them restaurants.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I would tell them more so kitchens for the inmates, us, and then one for the people who are running the-- and for the staff.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So-- and he used to calculate the food.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I don't know how he did it.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Because he never knew to boil an egg before the war.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "But he managed.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And because of that really, we never were hungry.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "Because he used to bring bread.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "He used to bring soup.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "He used to bring whatever he can from the-- the kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The Russians, I mean, there was-- was a boss there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I mean the [INAUDIBLE] there, whatever, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And my mother used to go out with bread, whatever she could to that village, where the Russian-- where actually Russians were living, and she used exchange from bread to meat.",
      "word_count": 31
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And she used to bring the meat, and she makes them kosher, un-kosher meat, she used to salt them.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "You know how kosher meat has been done.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Asino.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the Russians lived too.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But it was-- the whole, the whole village was called Asino.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But we-- we were living in the camp, which the prisoners of war, or the prisoners of-- Russian prisoners lived before we came there.",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes, yes, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had to get special permission to be able to get out of there.",
      "word_count": 15
    }
  ],
