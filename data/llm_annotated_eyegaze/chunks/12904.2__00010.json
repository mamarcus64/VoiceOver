{
  "stem": "12904.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember what.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They came out with the last train that left from Frankfurt to the border, and they came first to New York and then, for a while, St.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Louis, and then went to Chicago.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "They-- He said, my brother-in-law at the time, said that he had a friend, a good Christian friend, who warned him that apparently he had some inkling about Kristallnacht, or that something was going to happen.",
      "word_count": 36
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "He said, get out, get out, something bad is going to happen.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And so they left-- let's see, that was November-- in September or October of '38.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We came to my relatives.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "My mother's oldest brother was the editor-in-chief of the largest German newspaper in this country, the",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "He was.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Had lived there since before World War I.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Six weeks or so, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And then came to St.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Louis, because that was supposed to be our permanent residence.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Because we had the relatives who gave us the affidavit there.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Angelica-- it was called Angelica Jacket Company at the time, it was later changed to Angelica Uniform-- they had their headquarters in St.",
      "word_count": 23
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Louis.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And the people-- the immigration authorities or the Jewish community in New York did not want everybody to stay in New York.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They wanted people to move.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, at the time they did not promise that.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They had given the affidavit which meant that they were responsible for us for five years, that we would not become a burden on the government-- on the government.",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And, of course, welfare had just started.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "There was no real welfare department as we know it now.",
      "word_count": 11
    }
  ],
