{
  "stem": "5313.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "The Jews, most of them, the reason was anti-Semitism, but the Jews had the money.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "The Jews had the power.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "So it was a very well, nice time at that time where I was raised.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to cheder, you know, first, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I had a [INAUDIBLE] 'til I was about 13-year-old.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We was an religious family I came from.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You know, my both grandfather had a big beard and were religious.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And when I went to grammar school and then I went to high school and 1940s, you know, I went from Romania to Hungary, in Budapest, to my uncle, where I was-- went to the first year in college in Hungary.",
      "word_count": 41
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well most people was, if you talk about Jews, they was most of them in the business.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They owned the businesses.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They was in any kind of business you can imagine.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They owned houses.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They owned properties.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So they was very well situated far as the Jews concerned in that time.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Every year we went difference places, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My young life, you know, was very well situated there, you know, with my brother, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We went difference places, you know, every summer.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "My father was, in-- like I said, in pretty well good shape.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "He was making money.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And my mother was a housewife, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "She was, like I remember, my mother that my father, Friday night, came home with two chicken.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But when we came to the table, you know, two chicken supposed to have four legs.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "But we had only two legs at the table.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "My mother give the other two legs, you know, to the neighbors, you know, they was poorer them.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "They needed it.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We had kosher home at home, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we did.",
      "word_count": 3
    }
  ],
