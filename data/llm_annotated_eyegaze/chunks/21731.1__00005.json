{
  "stem": "21731.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So after I finished school, or when I was still at school, at-- at the-- at the college, we were interviewed by various-- various firms who wanted students or employees for their hotels, or kitchens, or whatever we learned there at this school.",
      "word_count": 43
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I got a position as a trainee-- I think you say, in-- at the Sacher Hotel.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "That was one of the-- one of the three famous hotels in Vienna.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "One was it was Sacher, one Imperial, and the third, I can't remember.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "But before I started work, my uncle, Jacob Parnus, who at this time was a professor of chemistry in Lvov, he left Strasbourg.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He was divorced from his first wife and-- and left the children with his first wife; married a second time, and was professor in Lvov.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He told my mother to let me come to visit them for two weeks before I start work, because later, nobody knows when I will have a holiday.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So let's show her a little bit of a different life.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I traveled-- just a very unsophisticated schoolgirl, to Lvov.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "By train.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "It took, I think, 24 hours.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember now.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But I traveled alone, which was quite unusual at this time.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Also, I was 18, but still-- I was still kind of school girl.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And so I arrived in Lvov on the 1st of October 19-- what was it?",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "1927.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "'27.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I forgot to say that while I was at school, I did two courses.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "One was for physiotherapy at the [NON-ENGLISH], where I also worked during the holidays to earn some pocket money-- in the kitchen.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And the second course was diet-- for-- to being a dietitian at the Professor [NON-ENGLISH] clinic, in Vienna.",
      "word_count": 18
    }
  ],
