{
  "stem": "6803.1",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "So he didn't hit me.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "He didn't hit me because I did my job.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Like this, the whole room!",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Like this, like this, like this, like this.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In a barrack, yeah, in a room.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And we couldn't sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "So apparently, we scattered around somehow.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And a lot of people died for suffocation.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "So we have enough room to sleep there, to sleep the so-called sleep on the floor.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "In the morning, we got up.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "We got a little slice--",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Died!",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people died in that room because-- from suffocation, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "It-- it's probably never told to anybody, but I was there.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I saw that.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I saw what they did.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "That's from the-- that's from the-- no, no.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "That's from whole Plaszow.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There was Hungarian and Polish all together.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And-- and so in the morning, we got up.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "We were told to stand in Appell.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And then they give us some-- a little coffee, whatever they call it.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "Black water and a little slice of bread.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "And they took us in.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "They had us march into the stone-- [? stonegrum. ?] They call it [? stonegrum. ?].",
      "word_count": 16
    }
  ],
