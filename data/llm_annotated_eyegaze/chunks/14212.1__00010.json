  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I never seen in my lifetime so much silver blocks which was there, bricks of silver, which they use there in the factories.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And with all these goods, we were evacuating.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And the evacuation was a very hard, hard work because we were bombed all the time.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Our [?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Shalom ?] was bombed, and many of times we were laying outside, there [?",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "Shalom ?] on the sides where the river used to go-- things like this-- to hide ourselves, not to be killed.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And this is the way it went down.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "Other [?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Shalom ?] supposed to go to Sebastopol on the Crimea.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And before we came to Crimea, Crimea was taken by the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "So we remained in no man's land.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "We didn't know where to go.",
      "word_count": 6
    }
  ],
