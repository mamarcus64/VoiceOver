{
  "stem": "1765.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 110.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes, please.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Do we start?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name is Esther Rudomin Hautzig.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Esther-- E-S-T-H-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Rudomin-- R-U-D-O-M-I-N.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Hautzig-- H-A-U-T-Z-I-G.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born on October 18th, 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Vilna, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The city is called Vilna by the Jews, mostly-- Vilno by the Poles, and Vilnius by the Lithuanians.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But when I was born there, it was Poland, so to the Poles it was Vilno, and to the Jews it was Vilna.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "To grow up in Vilna, for me, was like to live in perpetual heaven, until the age of nine.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I was born on a Saturday.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And I always think of what Saturday's child is supposed to do.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It's supposed to work very hard for a living.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] I was born to a family that was built in two parallel ways.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My mother was a Yiddishist.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "She was interested in cultural affairs.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "She was a-- [PAUSES FOR 3 SECONDS] a 'doer.' My father was a 'doer' in different ways.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "He was a merchant.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "He was also trained as an electrical engineer.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And my father's business was very large and very prosperous, on one of the main streets of Vilna.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "It was called, in Polish, [POLISH] [?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Domynski-- ?] the [? 'Domynski' ?] to make it more Polish-sounding than Rudomin.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "My mother's maiden name was Zunser, which is a very well-known name among Yiddish-speaking Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "Her great-great-uncle was Elyokem Zunser, who was a famous badkhn.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And a badkhn was a poet who composed songs with the words on the spot at weddings, and bar mitzvahs, and special occasions.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "So my mother was Chaja-Rivka Zunser, and she was called [?",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Raja ?] Zunser Rudomin.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And I was one of 11 cousins living in the same building.",
      "word_count": 12
    }
  ],
