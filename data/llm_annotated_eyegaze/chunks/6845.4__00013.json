{
  "stem": "6845.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Well, we looked like something to look at.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And horrible, horrible everything.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And so luckily, I had Nick's nurse to whom I went.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Everybody had somebody to home to go.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't go to our house.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I did go back two days later-- no, next day.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "The nurse took me.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And I found her-- Marishka, the maid we had before, she stayed in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And the Russian minister of agriculture moved in and insisted Marishka stays.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And the maid's room was all covered from all the way with the pictures of our pictures, the photograph.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "So those photographs, it's all from Marishka.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And she was fantastic.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And I found a friend, a partisan, who was a good friend of mind, a man.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And he bought me every day 12 french pastries.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And Marishka made one dinner.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And [INAUDIBLE] made-- I ate full two meals from everything and 24 pastries.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "And I gained, like, 40 pounds.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "So when Nick saw me at liberation, and he looked, you look so fat.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "He was right.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "I was size 14, really, really, well padded.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "But that's what I did.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "And-- and nobody was nice.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "Nobody was nice, but enough that I had the willpower to wait and see what will happen.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "And then it happened that Nick sent a letter to his nurse.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "I am being taken to a hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "I'm very ill.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "But I don't know where.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So come up real fast to Prague and go and find me.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Come and find me.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And there was no way to travel.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My luck was with me like miracle.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I bumped into a girlfriend who's brother was from our city, little village, Sobrance, who was in the diplomatic corps.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And he sent a car for his sister.",
      "word_count": 8
    }
  ],
