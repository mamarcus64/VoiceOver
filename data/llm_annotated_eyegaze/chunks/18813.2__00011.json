  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "He-- you know, he was very friendly, very-- good guy.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "What was it?",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "And he was smart enough-- 'they'-- the Gestapo.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "He was smart enough, like, I know by fact that he was drinking.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "They, they put some Gestapos what he didn't like it.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "But he knew that they were going to report him.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "So he was drinking.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And on the back of the-- they-- he report them.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "How can they watch the Jews if they, they are drinking?",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So they-- the inspection came, and they took them all away, the mean ones.",
      "word_count": 14
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And so he had to free them already to be with us.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "He, he really wanted to save us.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "Kaufman, we're at the end of this tape.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "And we'll continue in a moment.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "Thank--",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
