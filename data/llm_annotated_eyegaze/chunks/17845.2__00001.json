{
  "stem": "17845.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 120.6,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "When the Germans came into the city, I think it was about the 11th of September, [PAUSES FOR 3 SECONDS] they decided to have the headquarters, the gestapo decided to have their headquarters in this particular gentleman's house where we were staying.",
      "word_count": 42
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "You can imagine.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "We saw the Germans bathing next to the-- how do you call the-- the water?",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Oh, god, I can't say it in English.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "A well, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They were bathing there in front of it.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And we were obsessed looking at them.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And whether they knew that-- that we are hiding there or not, we don't know up till now.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But we-- we stayed there for a few-- for maybe two or three months in that place.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He used to supply us, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I really can't really remember how.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "But I think I was running out sometimes to get a bit of something, run to my grandfather.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They-- see, my grandfather and all the family-- the school yard miraculously was saved.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And lots and lots of families were living in that school, and my grandfather as well.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And we managed to get some food from them.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And we used to live on sardines and a bit of bread.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Of course we never cooked anything.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "Because there was no possibility where to cook.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother went once out, just before we left Bilgoraj.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Because my father decided that we are leaving Bilgoraj, but we haven't got any possibility to travel, because-- so he decided that we'll buy a buggy and a horse, and we leave.",
      "word_count": 32
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But that-- that's a story on its own.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "So what-- what I wanted to say is we lived there for a while.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And then my-- they start-- the Germans came in.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "No, wait a minute.",
      "word_count": 4
    }
  ],
