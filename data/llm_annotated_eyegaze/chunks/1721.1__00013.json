  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "We were loading up boxes.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "I think we were loading them on cars rather than unloading them.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "And they were just sort of like white boxes.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "We had no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Passing the boxes from one child to the next.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "From one of the warehouses going up right into the cars.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And we really didn't know what they were until one of those boxes dropped, and fell, and opened up.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And it was a human skull.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And-- and I had talked about that.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "I had never heard of anybody else remembering that until that-- an independent corroboration occurred on the East Coast.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And it must have been another child--",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "--who was in that same work party as I was on that same day.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "It was probably pretty scary.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "It was probably--",
      "word_count": 3
    }
  ],
