{
  "stem": "21731.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And I went with them.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I didn't want to stay there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "It was-- it was very lonely.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And I didn't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I didn't like to be there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "London was something different.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "When I was free, I went out.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "I saw things.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And I wanted to do something with my life.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "A friend of mine-- an acquaintance of mine-- wanted to go to Israel, and let the house, her house to somebody who took care of the house, and for a very low rent.",
      "word_count": 33
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "So I grabbed this situation.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "I gave notice to Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "Grenfell, who was very unhappy to lose me.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And I had a room for Yan, a room for George, and a lodger was there, whose rent paid nearly the rent which I paid Mrs.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "Kaufman.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "And I got in touch with Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "Sudorf, who was the dressmaker, and we started dressmaking.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "Which didn't pay.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 28,
      "text": "After a year, I gave that up, and went as a cutter to a firm, Madame Felicia, off Regent Street, a firm, which I was with later 15 years.",
      "word_count": 29
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 29,
      "text": "But I couldn't stay at Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 30,
      "text": "Kaufman longer than a year, because she came back.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 31,
      "text": "I stayed for a little while.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "And I looked for a flat where I could stay with the boys, and go to work.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 33,
      "text": "And really, I was lucky, because I found one.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 34,
      "text": "I had just 300 pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 35,
      "text": "That was what my husband got when he was demobbed.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 36,
      "text": "And he left that.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 37,
      "text": "That was all he left.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 38,
      "text": "And I had his money.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 39,
      "text": "So I gave for this flat 200 pounds.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 40,
      "text": "It was in-- well, it was not legal, but these people bought a house, or whatever, and I got a flat for a very small rent.",
      "word_count": 26
    }
  ],
