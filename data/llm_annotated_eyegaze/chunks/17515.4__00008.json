  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "1947 I immigrated here.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Oh no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Not-- not.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Because there was chaos.",
      "word_count": 4
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "There was-- at that time there was communist ruling in Poland, [INAUDIBLE], and they want to come into Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Because my brother told me, because the KBG, Secret Service come to my mom, day and night, to force mom-- mom-- mom should do anything to-- took-- to do-- to come to Poland.",
      "word_count": 33
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Because he was far away for most of it.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "So he was safer.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "--to stay home with your mother.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father died before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "My mom died after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Mostly-- you know, mostly people who were staying like in the-- in a village, much safer than most of the people-- danger-- to danger them self here, like a big city, Warsaw, Cracow, and things like that.",
      "word_count": 37
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "But when they-- when they far away, not.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "You so much were safer.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "Till now, I tell you true.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "I-- even I-- I-- even-- now, do you understand, I read news, American newspaper.",
      "word_count": 14
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "I watch-- listen to the radio.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "That was like a safe way you get it.",
      "word_count": 9
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "1947.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "I believe in a-- in the fall too, I came.",
      "word_count": 10
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "I-- I--",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "SS Marine Flasher.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "I was single.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "My mom-- my mom's sister.",
      "word_count": 5
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I believe that's like my aunt.",
      "word_count": 6
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "She was living in West Virginia.",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "Her-- her daughter helped me.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "Well, I don't-- I come a couple days-- couple days-- I-- only I-- I come here.",
      "word_count": 16
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "I didn't want to work down there.",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I'll tell you where I've been working.",
      "word_count": 8
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "Gerrish Milliken.",
      "word_count": 2
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 2,
      "text": "Familiar to you?",
      "word_count": 3
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Very rich-- rich and powerful-- richer than David Rockefeller, a cotton factory.",
      "word_count": 12
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Gerrish Milliken, on the Park Avenue, 70.",
      "word_count": 7
    }
  ],
