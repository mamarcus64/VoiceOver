  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, the importance is that people should realize what happened in somebody's life, how you can be pulled out of your life totally from one minute to the other.",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And what happens to you, and how it transforms you.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And the problem is that-- I-- I think, after living all those years-- is that it happens all the time, all over the world, just in different parts.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And that is probably part of people, the good and the bad.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "It just happens all over.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And that it will go on happening, I think.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "It's just humanity.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "It's just the way it is.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And we-- you, yourself, should try to do the best you can not to be evil.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And to live with people.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Communicate.",
      "word_count": 1
    }
  ],
