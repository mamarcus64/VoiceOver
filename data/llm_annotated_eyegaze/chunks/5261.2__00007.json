  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 132,
      "text": "And then I think as a child I-- I knew many places in [?",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 133,
      "text": "Torun ?] beside the center of city.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 134,
      "text": "We walk.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 135,
      "text": "We talk.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 136,
      "text": "He talk to me a little [? of ?] Austria.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 137,
      "text": "He wanted to know about my singing in the theater, about my family, brother-- just usually talking and talking.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 138,
      "text": "And then I remembered very nice [INAUDIBLE] in the fields with mountains.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 139,
      "text": "And I told him, you see, maybe we shall go there.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 140,
      "text": "You are sure?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 141,
      "text": "Yes, I'm sure.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 142,
      "text": "[INAUDIBLE] We can talk because it is-- he understood more danger, maybe more for you than for me.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 143,
      "text": "The Polish people are sitting home, but some soldiers they will see you.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 144,
      "text": "That will be not good.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 145,
      "text": "They will ask what happened with this young boy.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 146,
      "text": "And correct.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 147,
      "text": "Fine.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 148,
      "text": "When we came, I said, oh, it's a nice place.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 149,
      "text": "He took his-- it was, as I told you, cold.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 150,
      "text": "He had his coat.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 151,
      "text": "He took his coat.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 152,
      "text": "He hang there.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 153,
      "text": "And he took me in his arm.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 154,
      "text": "He said, you are very nice boy.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 155,
      "text": "You are pretty boy.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 156,
      "text": "Am I really?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 157,
      "text": "Nobody said me this.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 158,
      "text": "Nobody?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 159,
      "text": "He looked at me at my eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 160,
      "text": "I look at him, and he kissed me.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 161,
      "text": "Oh my god.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 162,
      "text": "He [INAUDIBLE] [? kissed ?] [? me. ?] And then he said, it was friendship kiss.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 163,
      "text": "Only friendship, nothing more.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Thanks.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I kiss him also because friendship.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we were talking.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We are singing.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And he asked me then for the [? next. ?] Because I don't [INAUDIBLE] [? details. ?] The first days, you must know, there was nothing done.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "There was very romantic.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I was very romantic as a Polish people.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And his behavior was also romantic, very dedicated.",
      "word_count": 8
    }
