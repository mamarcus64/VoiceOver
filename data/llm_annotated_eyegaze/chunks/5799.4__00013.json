{
  "stem": "5799.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "He said, in America you have to register.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "Do you have $20 to register in the Bronx Hospital?",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "I will deliver your baby.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "I said, I have to pay.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "He said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "You'll pay me when you have it.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "I said, I have to know how much.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "So I don't know, he said $50 or $60.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "I said, I will pay you.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "He said, I'm certain, but I'm going to deliver that baby.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "And my husband had a camera, a Leica.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "He sold it, and I had my baby.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "Brought her and put her in a dresser drawer.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 33,
      "text": "And you were living in a--",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "On Bryant Avenue in the Bronx, in a furnished room.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And my husband was a delivery in a grocery-- delivery boy.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't go to the HIAS because my aunt came and signed her name.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "She came to the-- to the boat and signed her name, so HIAS wouldn't help me.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They said, you have relatives.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "She wouldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "It was my father's sister.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And they wouldn't give me-- and I wouldn't take from the HIAS either.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We weren't that-- my husband used to say, don't give me any, any money.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "I'm not a beggar.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Give me a job.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "We were just not that kind of people, so we never went to any organizations either.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning I stayed with her, but that's when she told me the Jewish paper, I cannot bring in because it's not a leftist.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I have to bring in the not And then my uncle said to us that Jews like you should have been where the six million.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know that they were party members.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "That's another story.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "In America, it's very easy to be a communist.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They were leftists.",
      "word_count": 3
    }
  ],
