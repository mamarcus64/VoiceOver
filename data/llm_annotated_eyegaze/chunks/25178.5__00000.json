  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, this is all recently, right?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Recently, United States, not back to Belgium.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "We don't have a relationship at this point.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I haven't seen my brother since 1979, [PAUSES FOR 4 SECONDS] and-- [PAUSES FOR 4 SECONDS] which was a very sad occasion again in my life.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The funeral of my son, Fred.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "After-- [PAUSES FOR 4 SECONDS] after I got divorced I had custody of my son and he was doing very bad in school.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He had very bad grades.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So I decided that I was going to put him in a private school.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I enrolled him in a private school here on Lochmond-- Page Military Academy.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And within a year, he turned out to be a straight-A student, with the help of Page Military Academy.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And he went there through his junior high school years.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And after that, when he graduated, we enrolled him in a school in Lake Elsinore to finish his high school-- another military academy, Lake Elsinore Military Academy.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "After one year, they closed their doors, and he was enrolled with a partial-- partial scholarship with the Army, Navy Academy in Carlsbad, which he attended for two years and graduated with honors.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS] And decided to make a career in the Air Force.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] He enlisted in the Air Force, and finishes boot camp-- Texas, I believe.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "He was transferred to Cheyenne, [PAUSES FOR 6 SECONDS] being a paramedic.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "After some time, again, he was promoted to Corporal, and they moved him to Hawaii.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And in Hawaii he was-- two or three years, he was in Hawaii.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And he was, again, promoted to Sergeant.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 6 SECONDS] He met a girl in Hawaii and he wanted to marry her.",
      "word_count": 16
    }
  ],
