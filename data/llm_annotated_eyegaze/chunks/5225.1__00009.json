{
  "stem": "5225.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And he ask me, why you going to be sick?",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "Because I want to go to the game.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "You going to-- you're going to have a game.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "So you didn't get to go to the game?",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Stupidity.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, not a trouble maker.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I was not-- never a trouble maker.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Listen, I used to play soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "When I was 17, I used to be in the piazza, in the colosseum, and you play soccer.",
      "word_count": 18
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And they charge already $0.50 to enter.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I didn't get nothing for it.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "But I play.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "I liked to play soccer.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Like at here-- maybe more observant.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Maybe more observant.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And if you want to make a few extra pennies, you boil up a, a-- [INAUDIBLE] oil kettle, and put fire on the bottom.",
      "word_count": 24
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And you have dishes-- come on, $0.10 cents a dip.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] It was-- it was-- you know-- everything was--",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Matzohs-- you don't buy matzohs by the pound.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "You buy matzohs by-- there was a curb, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "And you must bring in your own [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "You know what [NON-ENGLISH] mean?",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "No, I don't.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] mean where you're covering-- you're covering yourself a blanket.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And on top of the blanket, what are you putting on?",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] You cover the blanket.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "A-- not a bedspread.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "You put the blanket in.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I know what you mean.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "But I forget the word too.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "OK, you put the blanket in.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "So you bring this one in.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Because if there rain, you going to [INAUDIBLE] the matzoh.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "That's-- the matzoh's no-- no-- not kosher anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Cannot be this way.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "In the bakery.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "In the bakery.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "And you stay with the-- in the griddle.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "You know, they make the holes.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "You don't have to worry about this.",
      "word_count": 7
    }
  ],
