{
  "stem": "18626.10",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.7,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was witnesses not from the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It was witnesses from all over-- from different places.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It, it was picked back-- witnesses came from England back.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was a case, understand, there that a German woman came-- a free woman.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "She was-- came from outside from Dachau, living free.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But in the wartime, she was a secretary to a big, you know, Nazi, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "She was a secretary.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And she was said-- I, I don't-- I believe it was [?",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "Frischnell, ?] if, if I don't mistake.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And when the Americans or English soldiers were shot down in Germany, they used to bring to that German [PAUSES FOR 3 SECONDS] to find out, you know, all the things and interrogate them.",
      "word_count": 34
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And she used to type on the machine.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "And she wanted to make herself like she's a still a good woman, and she's going to help in the process in the trial to get a good word against that big Nazi.",
      "word_count": 33
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So she was called on the stand.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They asked her, what are talking-- what are you saying about your boss?",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Did he ever beat, you know, American or English prisoners who were shot down by the airplanes?",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "She says, oh no.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He was just questioning them and just, you know, all questions.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He never laid a hand on a prisoner.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And then, after she was testifying, right away they called an English man.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he came out here.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He was in England maybe a year after the liberation.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "So he came with his uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And they called him to the stand.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And they said to the woman, do you recognize that man?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Did you ever see him?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "She says, no, I've never seen him.",
      "word_count": 7
    }
  ],
