{
  "stem": "5970.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And we were-- we were-- we were helping in that, just so that we were busy.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And the one man was Szwarcbart.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And the other one was Cukerman.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "They were both not from Radom.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "They were lovely, lovely people.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And one-- one evening before we went to our lodgings there-- it was one room for two families at that stage-- one of the girls forgot to switch off the iron.",
      "word_count": 31
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And when we came the next morning, the damage wasn't all that great.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "But there was damage.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "The-- the board was burnt.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "And the iron was burnt out.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And the-- the Germans, the SS, came in.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "And they took these two lovely men.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "They took them down into the courtyard.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "And they shot them in front of all of us.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "This was the first time I've seen something like that happen.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "Really, it was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "And it was an everyday occurrence.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "That-- that was it.",
      "word_count": 4
    }
  ],
