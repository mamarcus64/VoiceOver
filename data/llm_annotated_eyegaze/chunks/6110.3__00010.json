{
  "stem": "6110.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So my mother's girlfriend was scared.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Who's he?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Who's he?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "She didn't want to let him in.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "So he said, I am boyfriend of Edith.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I love her very much, and I am so happy that she's saved.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And he told her the whole story, so she opened the door and let me out.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "In the meantime, from eating good food, you know, being skinny, I got swollen.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I swell up.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I swell up.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "My hands was like that.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "You put, you put a finger, a hole-- you know, that was the reaction of the food.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You swell up.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "But he wasn't shocked, no, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He said, you're not going to stay another day here.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We are going back.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Where we are going?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Where the Americans are, to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Then we went to Regensburg, to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "There we married a year later.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "What day did you get married?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "24th of February.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "'45-- '46.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We were staying from May until, I think, February next year.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "We went to United States.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Very nice.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I was working with the American Army.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was [INAUDIBLE] office.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I was taking care of our office.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "People come.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I used to register them, used to give out cards for milk or food to help out.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "They came-- some of them, they came with, with little children, but they ran away from some place.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Some Russian Jews came over there also.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "They ran away from some place.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "So we were taking care of the people there.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "We had an office.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Post-war community Cracow, in Cracow, you mean, or Berlin?",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In Regensburg, where you were living.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Regensburg-- they were very unhappy Germans because we took away the apartments.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We threw them out on the street, and we took over, the Jewish people.",
      "word_count": 14
    }
  ],
