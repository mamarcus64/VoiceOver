{
  "stem": "15900.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The German delegation come to the Russian side.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They made up.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Who wants to go back the Russians is gonna let them.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "They all registered to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "Do you know what the Russians did?",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Everyone who registered to go back, they round them up and send them to prison.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And I in the meantime was sick.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "I got appendix--",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "They rushed me to the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And they operate on me, appendix busted.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "After I came out of the hospital, I went to Luck, a city there where I used to know people.",
      "word_count": 20
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And I worked in a-- in a store where they make ice cream.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "I eat a lot of ice cream.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "Later on I said, I come-- I come back to see my brother in Bialystok.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, they-- Russia don't have synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "But it was still standing.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "There's a famous one in Luck.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "It was standing, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I went back to Blonie.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "The synagogue was standing there too.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Anyway-- but anyway, I went back there.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And my brothers was already arrested.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "My brother who was in-- I mean and my older brother with his wife and children, his wife went through with a little girl.",
      "word_count": 24
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And I went to a-- a Communist.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "He was in Poland, a Communist.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And he was exchanged for the Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "In 1937, he was exchanged for the Russian people were [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And he was a big Communist in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "And I went to him, and I said, what you want me to do?",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I want to do something.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "He said, look.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "I give you a place where to stay to hide.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And he went to the [NON-ENGLISH] over there, the secret police.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "He tell them, you want to find him?",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "He is there.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "My friend.",
      "word_count": 2
    }
  ],
