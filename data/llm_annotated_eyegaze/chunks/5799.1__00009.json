{
  "stem": "5799.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Officially, I don't know even that you got married.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't invited.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "She says, what do you mean?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "You are not going to congratulate me?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "She sent me to the principal.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I refused.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I don't know what transpired there, but she wasn't teaching there more.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The principal, who loved me-- I was a good student-- got rid of her somehow.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I was often-- when my parents left-- I was often change-- chased by my Polish friends.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I was good in class to help them in their Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "It's like a janitor who speaks French, but doesn't know how to write well or spell.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "The same thing was with the Poles.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I knew Polish from the [?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Rutsan ?] because I had to.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "They didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "They spoke it.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "That was their language, so I used to help them.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I was sitting on one bench with the Princess [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "She was a relative of the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "My mother always pushed me in very fancy schools.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] And I helped her.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And she never defended me.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "When I went out of school, they chased me.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And I still remember the taste of horse manure where my face was pushed in.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And they called me that I'm the killer of Christ.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] And when I said that Christ was Jewish, I was beaten up more.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I learned not to complain.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "I never told my parents.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "I never snitched at my friends.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "Until they found another Jew to torment, they left me alone.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So these are incidents that I blamed my mother later on.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I used to say, you didn't you give me the religiousness and the belonging with my people.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Because you are not religious, I am not.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Tradition, I was taught.",
      "word_count": 4
    }
  ],
