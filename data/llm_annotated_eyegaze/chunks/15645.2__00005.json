  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And from Pinsk, I went to-- to Janow Podlaski.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "In Janow Podlaski, I work for a Russian-- Russian institution.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "It was called [NON-ENGLISH] means a-- a special [PAUSES FOR 4 SECONDS] company who runs-- who runs farms and, and the all produce-- distributed all produce for the-- for the-- for the company.",
      "word_count": 33
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It was state.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I don't think that a cooperative is state.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "It's run by the state, not cooperative.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And yes, I was in a-- a good position, because I have to travel a lot because we haven't got seeds.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I have to travel a lot to Ukraine direction to collect some seeds from the farmers, to buy seeds, because I haven't got seeds.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And and I was carrying a lot of money with me, and I was buying seeds and sending to-- to-- to-- to-- Janow Podlaski.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And-- and-- and where I have the possibility to go a lot, I-- I-- I visit my brother in Lvov.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "That was Andrew.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "It was Andrew.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I visit him in Lvov, and we've been a few hours or dine together.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I told him what I am doing, and-- and I then went back.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, he didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "He just left them and his place and went away, yes, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely not, no news, no.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we know about the ghetto, but we didn't know what's happened, and who is in the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "No, absolutely not.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we sent letters.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We sent letters, but I never receive a letter.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And was your wife working too?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Yes, she was working too.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Yes, she was always working, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The baby was born in in-- in '39.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "No, '39 was the war-- yes, in '40.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "1940.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
