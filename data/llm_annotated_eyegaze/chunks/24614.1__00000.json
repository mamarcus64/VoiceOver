{
  "stem": "24614.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Clara Heller Isaacman.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "C-L-A-R-A capital H-E-L-L-E-R capital I-S-A-A-C-M-A-N.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Romania.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The city of Borsa, B-O-R-S-A.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I'm not going to give you my date.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Romania-- I don't remember Romania.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I must have been a year or a year and a half before my daddy decided to-- no, I was more than a year and a half-- four years old-- before my daddy decided to leave Romania.",
      "word_count": 37
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He left Romania-- he used to tell me a story that he left Romania because of anti-Semitism.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He was Romanian born and raised there.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And he went to vote.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And he had to cross a bridge.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And every time he crossed that bridge to vote once a year, he used to be beaten up.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And the last time, he was very sick and came home, practically nearly killed because he went to vote.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And he decided that he didn't want his children to be brought up in a country like that.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We moved to Antwerp, Belgium.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My older brother, Heshie, my sister-- and my younger brother wasn't born in [PAUSES FOR 3 SECONDS] Romania.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He was born in Hungary.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Because my mother went to visit, I understand, her family.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But we had lived already in Belgium.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father's full name was Shalom, S-H-O-L-O-M, Heller, H-E-L-L-E-R.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Rose, R-O-S-A, Halpert, H-A-L-P-E-R-T.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "She was born in Hungary.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We had a helper, somebody who lived in with us, a maid.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My childhood, I remember, was very pleasant.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My parents were-- we were upper-middle class.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "My daddy was in the diamond business because everybody in Antwerp was in the diamond business.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "But he also had a soda factory, the only soda factory in Antwerp.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I remember it very well.",
      "word_count": 6
    }
  ],
