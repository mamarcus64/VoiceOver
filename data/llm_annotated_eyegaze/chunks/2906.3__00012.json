{
  "stem": "2906.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "Because there was 5,000 people in-- there wasn't to-- too big places to live.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "So one used to fight with the others.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "You know all kind of people.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And they made my husband for chief of police, because he was very-- he was very nice.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "He used to come in and make everybody to be friends, and to-- not to fight, and that.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "And then, he used to sing for the-- for this camp.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "He used to sing.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "There was a radio.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "And he used to sing.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "And he used to go to give concerts.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "In Germany, he went to [NON-ENGLISH] and give concerts.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "No, in Salzburg-- I-- I skipped this.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "We were in Salzburg.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "A cantor came that he was looking for talents.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They was making the high holidays for the American soldiers.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And they-- everybody told him that my husband is a good singer.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And he took him in.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "And he was making the high holidays there.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "But in Hallein-- we stayed in Hallein.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And we got what to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "And then I was riding--",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Well, the room was like this.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "It was like two couples.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "But when the-- when my husband-- we got a position better, we got a room for ourselves; and a little kitchen by the side.",
      "word_count": 24
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed, and we want to-- to live.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "You know--",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I write to Israel to find if my brother is alive.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "There was a-- a-- somebody gave me a phone number in Jerusalem-- or Jerusalem something.",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And I wrote there.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And I received a letter that my brother is alive, and he's in Israel with a wife and a child.",
      "word_count": 20
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And I wrote.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "In 1947 I think-- 1947.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, always, always.",
      "word_count": 3
    }
  ],
