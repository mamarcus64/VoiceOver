{
  "stem": "5388.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I sang a number of songs.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "But there were other people who were singing too.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "It was kind of a Sunday.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "People didn't go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "And it was summer.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And it was already-- the camp was going to be liquidated.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "It's going to be moved.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And there were rumors that we're going to be taken to Germany or to Tallinn.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Some people believed it.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Some didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, I was supposed to run away from that camp.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But the guy finally walked out.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I was stuck there.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But anyhow--",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there's no question about it, no question about it.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "That particular, quote-unquote, 'hootenanny' was, I would say, at least 300, 400 people minimum, if not more.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They made a stage, a platform.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "There were no speakers or loud-- you didn't have any magnifying singing.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "It's just your voice.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "You had to carry it.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "My voice was pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "So it carried it.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it certainly was.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "That was in the summer of 1944.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I remember it distinctly.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In Ereda.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, the guards around it.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "But the guards weren't German.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "The guards were-- at that time I think the guards were Estonian.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I think, pretty sure they were Estonian guards.",
      "word_count": 8
    }
  ],
