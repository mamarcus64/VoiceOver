{
  "stem": "2833.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And [PAUSES FOR 4 SECONDS] I found you know, some old friends in Prague.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I was lucky because we had left some money with our lawyer who was Czech and not Jewish when we left.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So when I went there, to him, I at least had money and could-- You couldn't buy much that was any good.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I mean, even clothing, but still better than, than what we had.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I wanted to get out of the Russian-- Prague was Russian occupied.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And it was dangerous, and they were very strange.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They-- we all had our camp here, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I had Mauthausen here on my shirt.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "But I went to a friend of my mother who had kept a watch and some rings and the things that she had on the last day when we went to, to go away.",
      "word_count": 34
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I got it, and I left and I walked.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And the first Russian soldier took it away from me.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They come and, you know, everything.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "They had watches from here to here on every arm.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And I wanted to get out.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And I went into the American sector of Czecho-- of Czechoslovakia with a girl friend of mine.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And it used to be a very beautiful spot before the war, and it was still a very nice little town.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "And they still had the Americans to occupy it, the very beautiful hotel in there.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And because I spoke English, I got a job with Red Cross.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And the director was a lovely lady.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "And I worked with her, and I met officers.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "And then the general gave a big dinner party.",
      "word_count": 9
    }
  ],
