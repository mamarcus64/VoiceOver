{
  "stem": "16106.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was talking about the German lady who was a Baltic German lady who worked for the neighbors in the neighbor factory.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And she was-- and-- and she was extremely kind.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Not only did she bring us food at night, which was absolute no-no to enter a Jewish house.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And she came in the dark, took-- took-- took her life into her hands.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Came in the dark and brought us special goodies and cakes and cookies which she had prepared.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And marinated mushrooms.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I remember so well.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They came in big jars.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And-- and not only that.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "We gave her all-- gave that lady all our jewelry.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And would you believe it?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "She kept it all to the end of the war.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She found the people-- the owners of the jewelry-- and she send it to each one.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And then she lied down and died, as if she was holding out.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I got my mom's ring, my mom's necklace [POINTING] and all what we gave her.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And she had returned everything, everything, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "In those days, we were still living in our own houses.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And the few people who were still left-- I mean my mom, my father wasn't there anymore.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Sela-- [?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Sela ?] Edelstein's husband wasn't there anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] We tried to stick together, like sleeping together in one big room or staying in one bed all together.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "We spent a lot of time in bed together.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "We all-- people just lying under the blanket feeling cozy and [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And that German lady used to sneak up and bring us-- feed us.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "It was an amazing thing to do for her.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "She came constantly.",
      "word_count": 3
    }
  ],
