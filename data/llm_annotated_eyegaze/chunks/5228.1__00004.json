{
  "stem": "5228.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Well, she got four children.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "She was not young, and it was very hard of her.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No, she got a house.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not far.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Not far from us, oh, no.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "She got a beautiful house.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "She got a nice husband.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They was happy and got nice children.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "The oldest was, I think, 13 years.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And there was three small little-- and there's nobody left from them.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And that's what-- and I used a lot of help by my grandmother, going to her and to help her in house.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Oh, that part of the-- she got her own--",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "My mother's mother.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My father's parent, I didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They named me the second.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I was already named after my grandmother.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know my father's parents, although my mother's--",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Not as close, although she was-- she got her house.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "She got everything what she needed.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "She got, in the time, two sons in United States.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "They used to send and help a lot of-- for her, although she got eight girls.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "It was not easy to get-- to marry eight girls there, although they all was married, and they all was OK.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And my grandma was OK.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My grandpa died before the war, and then she was alone, although she was OK.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I used to help her [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And the other--",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh, just to be with her.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Just to be-- to sleep overnight there by her.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Just to be.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I did-- Like I said, I was lazy.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I didn't work too much.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And I [? stayed ?] there.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "My mother worked all [? out. ?] When I needed, OK, I did work too, although not as much.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I was two times in Prague to visit.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I got an aunt there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "I was staying with her.",
      "word_count": 5
    }
  ],
