{
  "stem": "27767.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And he brought in a radio, and he put on the radio.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And then we heard they was approaching Munich.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And they-- they-- they wanted to-- they was-- they were asking the people not to fight anymore, the army not to fight and so on.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "A then we knew that's why they run away, the SS troops.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And then what's happened, we organized ourselves.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "We put outside white flags.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "And we put some of our people in the towers there.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "And then in another two days, the SS came back.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "And they came back again, so it looks like that they were fighting again.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "And it was-- they went through another two or three days.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "And then one night, it started at about-- I think it was April 26th.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 26,
      "text": "One day, April 26th, one day before the liberation.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 27,
      "text": "No, actually it was two days.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "Came in-- the camp opened the doors of the camp, and came in a woman from another camp.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "They brought them-- because what they did, before the liberation, they tried to-- because the order from Himmler was to kill everybody.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 30,
      "text": "And they just didn't have time.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 31,
      "text": "And they brought in a prisoners-- I mean, from our people, women.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "They brought them in.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And they brought them in to our camp.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And they took them-- to the back of our camp was an empty camp.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And they put them there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And we were looking-- I was at that time in the kitchen, I went out to look who's coming in.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Maybe I see somebody.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "In the first line, I see my sister-in-law, which wasn't at that time my sister-in-law.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "She was my best-- she was my younger sister's best friend.",
      "word_count": 11
    }
  ],
