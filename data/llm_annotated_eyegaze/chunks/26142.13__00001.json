  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "What do I need it, what do I need it for?",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And we needed a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "The children are scattered all over.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "She talked to me.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "She said, go and pick this up.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And go sell it.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I don't need, don't need it.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "So the, the, the task fell that I should go.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "So I traveled again.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "I was a little bit freer already, because I told her again I had this, this, this citizenship paper.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "It, it helped a little.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "I traveled again to Debrecen.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And I was to travel and pick up all the jewelry that she had there, and my father's jewelry, and bring it to Debrecen.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And we'll sell it over there.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "We'll make, we'll make money, because we, we, we need a lot of money.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "So I came to, to my aunt, Yuta, to [INAUDIBLE] And it had to be on a Wednesday.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "Wednesday night I remember, it was very cold in winter, is snow.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And, and I came in there.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "And I told her.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "And I told her what I came for.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And she said, fine.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "But why do you want to go back already tomorrow?",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "She said, why don't you stay here already for over Shabbos, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And then, then you'll go back on Sunday.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "There's another day.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "She, she was-- you know.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And stupid me, stupid me.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I knew that my father is deadly sick there.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And, and I should, I should take every opportunity to stay with him, to be close by.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And here I am.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "It's Wednesday.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I was going to go back on Thursday.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "She says, stay, stay over, over to over Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Go back Sunday.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And I agreed, agreed to stay, to stay over.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed there.",
      "word_count": 4
    }
  ],
