{
  "stem": "11499.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "28.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Warsaw, Poland, March 21, 1921, to Aaron and [?",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Rahul ?] Kamm.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They were my parents.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I grew up very close family.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Because we lived in a-- in a building together with my great-grandfather, and my grandparents, uncles, and aunts.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And the building used to belong to my great-grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Then, when I was--",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I would say--",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Oh, immediate family.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "By the end of-- by the end-- when the war started, with Germany--",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We were five children.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We were five children",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Five boys.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The names was-- a younger, next to me, was Paul.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "The third was Saul.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The fourth one was Henrich.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And the fifth was Simon.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And when I was seven years old, I had to attend public school, which I attended for-- for a few years.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Then they-- then I went to a Jewish high school, which I stayed there till I was about 17 years old.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "When the war broke out--",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I-- yeah, I was very involved in sports.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I used to love to run.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Every Saturday-- there were three bridges in Warsaw, so we used to run every Saturday about 10 kilometers over the three bridges.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I also played soccer almost every day, in school and also on a playground-- special play-- playground.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We were brought up different-- separately from the Polish people.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Because when I went to public school, there were maybe 500, 600 children.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We were only two Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Warsaw.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "There were only two Jews-- a guy by the name of [?",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Gura ?] and me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We had to fight everyday.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Because the Polish kids used to insult us everyday, call us dirty Jew, and filthy Jew, and all kind of things.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "So and I was a fighter.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I used to fight everyday.",
      "word_count": 5
    }
  ],
