{
  "stem": "11641.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 495.3,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "You know, you had to know somebody-- who is who.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So we were refugees.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "You know-- one of those things.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Everybody says the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Some houses were deteriorated from this, so we bought the remnants of the house.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We cut up the wood.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And we sold the wood to people for the wintertime.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "You know-- we persevered.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "For bread, we had enough for bread.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "In the meantime, I worked outside.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I started-- I got-- No, I was caught at the time, and sent to a labor camp in Plaszow.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Labor, not concentration camp.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "It was a labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "It was 19-- beginning of '43.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Let's say you're walking in the street.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They catch you.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "It's the law.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We need so many people.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Taken off the street.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, middle of the week.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "They took me to Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I was there for a while.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I stayed in Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I-- I gave them a message.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I sent them-- it wasn't that far from Bochnia to Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't that far.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "So whoever was there, I gave them my message.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "In the message I said, I'm all right.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "You know--young guy, 18 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "You know-- if you don't have high hopes, you're just-- you're down to earth, and you more or less absorb it, so to speak, quote unquote.",
      "word_count": 26
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And I spoke German also, so I acquainted with all the German soldiers who were issuing passes.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "So he gave me a pass and he told me I should issue passes.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And he signed it.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Passes that you could go home and come back.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "There were passes for certain [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So every Friday night, really, I tried to go home to Bochnia.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they didn't touch me, because I had a pass that I am working.",
      "word_count": 14
    }
  ],
