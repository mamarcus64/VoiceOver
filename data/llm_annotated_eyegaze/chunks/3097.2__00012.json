{
  "stem": "3097.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "So I said, what kind of work?",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "You go to work.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "I spoke Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "You say, you will work there.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "They took us.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The SS came to them, and they said like that.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "You're going to work there.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "You will put some dead people in the grave to prevent a-- a-- disease, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "We should not let the disease spread.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You won't get killed.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "You will quit your work.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And you go back.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we took us under guard there.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And they made artificial grave.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "No, they made a-- two graves.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They took a big-- four, you know, like a square-- big graves.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "When I came, already, I had relieved-- our group relieved already, a group which worked there.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I saw that they took them back to the synagogue.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And over there was the deeper graves.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And there were two SS men sitting on chairs, like a kitchen chairs.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And in front of them was a white linen, you know, like a bed linen, you see?",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And on the linen was money, gold, rings, valuables, you know, and-- and pieces selected there, you see?",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And wagons-- horse drawn wagons-- used to bring the people, dead people, from surrounding area.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And we could hear guns, you know, salvos and single guns all over around there, you see?",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "They used to bring it.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Our function was like that-- to take off the people from the wagons.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Take off the clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "Check everything if there's anything valuable, OK?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "Take off any rings, gold teeth, you know, to tear out, and throw them in.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And put them in layers.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "My function, personally, was-- I was supposed to open a quicklime.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "They came-- the quicklime came in-- in-- bags of heavy paper, brown paper, you see?",
      "word_count": 15
    }
  ],
