      "sentence_idx_in_seg": 1,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So she thought-- she took me to the-- to the store.",
