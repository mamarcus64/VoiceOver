    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "When the Russian came, and-- there were singing in-- in Russian.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And I understand Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "So till-- till the end of the war, I was-- but in [INAUDIBLE], I was the lady.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Her husband was also working with us.",
