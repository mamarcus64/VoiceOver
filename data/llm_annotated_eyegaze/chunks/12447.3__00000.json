{
  "stem": "12447.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Actually, it started in the-- in the fall of 1940.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I remember it was pretty cold already.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And we had to move out from our apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And we had to move out and move in-- into a designated area in Warsaw.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We did not have any apartment to move to.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And my father loaded up the furniture on a horse and wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "It was a huge wagon because they tried to take all the furniture what they could to empty the apartment.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And we moved into the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We moved into the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "My father had a friend.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And one-- I don't remember the street, but I remember it was a big one of these courts-- what I described prior-- building.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And it had a court.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And we unloaded the, the wagon with all the furniture.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "We spent the night in the court.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "We did not have a roof over our head.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And my father started to look for a place to live.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "He found a place the following evening.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "That was somewhere on Smozca Street.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "There was a market on Smozca Street.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "I don't remember what number Smozca.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "He found a, a place.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "And we moved all our furniture to that place.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "It was really a small, little room.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "We hardly got the stuff in.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And the ghetto was very crowded.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "It was just a lot of people walking, pushing little wagons, carrying things on their back.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "And we got to this little place.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "About a few days later, my father was called in on a job to open a-- some kind of a lock by a-- by some kind of a rich person.",
      "word_count": 30
    }
  ],
