{
  "stem": "21004.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He was my mother's middle brother, because there were an older-- the oldest was a sister.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "My mother's oldest sister was Sarah.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She had 12 children.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We had a big family.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And my other uncle was Abraham Neiss.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He lived in another city, [INAUDIBLE], the city.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And he had two-- three children.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And this is-- the third one was my uncle was the third one.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Then I had another uncle, Jakob, Jakob.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And my mother.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And then after my mother was another uncle, Majlech, Uncle Majlech Neiss.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "But my cousin, their-- one of his daughter survived, my first cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "She worked in Germany on papers which she got from somebody from a Polish bureau.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "And she got papers and she was not-- she was taken to Germany like other people, Polish people taken in to-- to work in Germany.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "She was in Germany in [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we dressed-- we dressed pretty nice.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We all dressed very nice, very nice.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "First of all, we had family in the United States, so they sent packages, all kind of clothes for the girls, for the whole family.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they sent packages for the men, suits and all kind of thing.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And later, when we grow up, we start working for ourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I used to go out and do business, you know, with Gentile people, selling, buying, and do business.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So I clothed myself.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I really clothed myself very good.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, to shul, it was always very, very proper, like the shul, always in my jacket and a tie and dress real nice.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we have a very good, very good-- we communicate with the Gentile people, with the Ukrainian very good.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They respected my mother, first of all.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My mother was a widow, so they all respected.",
      "word_count": 9
    }
  ],
