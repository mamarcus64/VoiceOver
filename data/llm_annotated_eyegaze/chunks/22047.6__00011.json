  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "And stories like that, and I learned a great deal more about what went on in other areas of, of these death camps and from the liberators themselves.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "I mentioned that the 45th Division personnel had actually preceded us to Dachau.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "And I had sat next to one of the fellows that was in the 45th Division.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "And he told me about this execution of the German guards.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "They were captured and lined up against the wall and summarily executed.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "And the leader of that company was court martialed but pardoned.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "Because the reason that they did that, they were so angry at what had gone on, so angry that these people did not deserve to live.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The battalion commander was Colonel Walter Fellons.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I was a company commander.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And then his boss was Colonel Henry Luongo, L-U-O-N-G-O.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And the division commander was Major General Harry Collins.",
      "word_count": 9
    }
  ],
