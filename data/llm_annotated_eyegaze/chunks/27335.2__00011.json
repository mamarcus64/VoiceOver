  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Hitler really had-- and all this-- all this gangsters around him.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "What-- what-- what they preach, they really believed it.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "They're going to conquer the world for the next 1,000 years.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And you could-- you could-- you could see it there.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "And my father, well, he spoke German better than-- than Hungarian-- he spoke Slovak-- and-- he-- he-- his customer-- in, when he opened up a harness shop in Leduc, then the surrounding area was very good land-- cleared land from-- from forest.",
      "word_count": 42
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And as thick as the forest was, so-- so was the wheat, grown as thick as that.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And most of them were-- they were all good Germans from Russia, and-- and from-- from-- from-- [INAUDIBLE] so was in Saskatchewan.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Not the--the funniest-- the funniest thing, even up to-- up to this day, the Germans are the [INAUDIBLE], and mind you there are well over 1 million of them here-- but we always had ethnic organizations, like-- like in the leftist-- 17, 18 such organizations.",
      "word_count": 45
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Even-- even the Germans-- but the Germans always the smallest.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But hardly-- hardly any [NON-ENGLISH] Dutch.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Most of them were the [NON-ENGLISH], who came from Hungary, Austria, or Romania, and so on.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And some Austrians.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But no high-German.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Not the elite, you mean.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no-- they were kept to themselves, and they were so rich, and so strong.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But you could hardly see them, you could hardly see-- but, uh, you were there among them.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You would rub shoulders with them.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And so the customers in my father's shop-- in that little [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "There was vulgar Germans-- rich farmers and--",
      "word_count": 7
    }
  ],
