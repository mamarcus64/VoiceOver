{
  "stem": "27767.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We were just outside in cell appell, staying hours and hours, counting.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And they took us from there to another camp, Allach.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "They took us by-- [PAUSES FOR 4 SECONDS] I think-- I was just trying to remember if they took by-- I think they took us by foot.",
      "word_count": 27
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we walked, we walked.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "That was-- Dachau was about 10 kilometers from-- from Allach from Dachau, Allach.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Allach is the town where the [INAUDIBLE] motorbike and the BMW plants are.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "At that time, they had their-- they-- they manufactured their airplane engines.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And they took us to Allach.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And there was a big concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "There was a Jewish camp.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "We were there.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And near our camp, there was another camp.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "There were Russian prisoners there, and some others too.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "They took us to that camp.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And I was still with my father.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we went out to-- we went to-- they gave us a barrack, separate beds, three beds like a bunk, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And with a blanket, and-- and-- and-- and I didn't have any more my boots.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "My boots got-- after the Warsaw march, my boots got already-- they were gone.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So in Dachau, I got the wooden sandals.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They didn't gave you shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They gave you the open wooden sandals.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And that's what I wore in the cold in the winter, in the snow, and the-- whatever, wooden sandals.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And-- and in Allach, we went out to work every day in the morning.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was cell appell in 4:00 o'clock in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Then at 7:00 o'clock or so, 8:00, they took us to work.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And we worked-- we worked on the rail yards.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "The American were bombing constantly there, during the day, and the English during the night, around the camp there.",
      "word_count": 19
    }
  ],
