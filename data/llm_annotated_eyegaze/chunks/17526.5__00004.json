  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "Incidentally, the expression [NON-ENGLISH SPEECH], which means our streets but your properties came up many times in our travels in Poland.' I'll skip all these here minute descriptions of the streets which wound in and out, which may not be of very importance.",
      "word_count": 43
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "But I'll continue here. 'We went back to [INAUDIBLE] Street, and we went where the [?",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "Nunbergs ?] had the sausage factory, and we went back to the other street.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "And all you see, dilapidated, torn down, black walls with noticeable marks where you can see where the second floors and then the third floors were.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "We are walking through the [INAUDIBLE] and-- Street-- and we walk through the gymnasium that was named after [INAUDIBLE], one of the prominent Jewish rich people, philanthropists, in our town.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And we are standing on a railroad bridge not far from the prison and not far-- and we are nearing the school where we went as kids.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We are nearing the school and we are wondering, is the school still there or not?",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But we-- we see some kids coming out, and as we see some kids, we follow their trail, and lo and behold, there is the building.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The building, we walk inside the sports place where we used to ice skate in the wintertime.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Where the entrance to the school was at the rear of the building, now the entrance is at the front of the building.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We walked around it and there are still some classes in session.",
      "word_count": 12
    }
  ],
