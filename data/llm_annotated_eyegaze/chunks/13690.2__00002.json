  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In 1942, there were liquidations of the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We did say that it's really getting to be very, very, re-settling.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I do not know if the people really comprehend-- and especially myself as a child-- definitely could not comprehend that liquidation of a ghetto means that they sending us to the gas chamber.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "When this came, most of the time, those-- those liquidation of ghettos were done in a sporadic and surprising attack, so to say.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They came-- mostly they picked a Jewish holiday.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "May it be the Jewish New Year, the most sacred day of Yom Kippur, which is the Day of Atonement, or the other tabernacle holiday, Simchat Torah, the day we're were rejoicing with the Torah-- that's the day that they pick for liquidation, where there really was a surprise that you could not expect anything because it is a holiday.",
      "word_count": 60
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Our city was destined to be liquidated on Simchat Torah.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We did not know-- of course, now we know that it was liquidated on Simchat Torah.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We run away from that city, just the day-- eight days before.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "In other words, the first-- a day before the holidays we run away from that city.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We got-- we got the information, so to say.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We got some rumors that other towns were liquidated.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "There was not telephone communications or any other means, but we just got the rumors that this town was liquidated, this town was liquidated.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So most likely that the town of Zarki probably will be liquidated within the next days or weeks, so to say.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "In turn, there were possibilities to run away by buying papers, getting permissions to run.",
      "word_count": 15
    }
  ],
