{
  "stem": "18670.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So Uncle Jack came up and said, did you give the money to Grandpa?",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And he said, no, I didn't.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "He-- and I wasn't home when this happened.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He said he's going to beat him up, gonna take him to the street and beat him up, and then he's going to send him back to Germany.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "So I came home and my brother was crying and this and that.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I had given Grandpa money.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "I've given some-- when I got my first pay, which was $8.56-- next pay was $15 already.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "I had given him money.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "He kissed me.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And when he kissed me, I said, Grandpa, how come you kiss me now?",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "You didn't kiss me when I came here.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "You didn't ask about my mother or anything else.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "I-- and now you kiss me because I give you money?",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "I said, I thought you were religious.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "So he said to me, [YIDDISH].",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "You know what I'm talking about.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In 1943.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I worked",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I worked and I became the fastest operator of basting machines in the clothing workers union, Local 25, the fastest one.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I used to baste in a day 100 and-- over 100 Army coats, the heavy overcoats.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "It was a nickel a coat.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And when I walked out, and I would go in across the street in the barber shop and have myself-- get a shave and they put the chair back and they put the hot towel on my face, I would pass out.",
      "word_count": 42
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "But I was the number one man in the union, fastest one.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "I joined the union, by the way.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And you stayed in the field and I-- and--",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I did not stay with my grandfather.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I had made some friends.",
      "word_count": 5
    }
  ],
