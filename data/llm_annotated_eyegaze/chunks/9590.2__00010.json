  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And she was engaged to a young boy from our city.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] And that young boy and she were students in the university in Warsaw.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And for the summer they came to our little town.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "They wanted to earn a little money, so I was their student.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "They prepared me-- they tutored me to prepare for the exams.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "That young woman, was-- her name was Jana, and she was married to Motke Finkiel, that grew up in our shtetl.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And his parents lived there.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "He was a law student in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And the day when the war broke out, they were married.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "They were planning on getting married September, 1939.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "That's when they were married, and the war broke out.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "They left Warsaw and came to our shtetl.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And then they realized that the German army are not going to stop in our shtetl.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "She helped me-- she and her husband-- at that time he was a fiance-- they were tutoring me to prepare for the exams.",
      "word_count": 23
    }
  ],
