{
  "stem": "23737.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "You see, there are so many, unfortunately, of these cases.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "You can hear about it now as well.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So I don't think so.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Wasn't a pleasure.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "No pleasure at all.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "There was.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "There was enough of everything.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We weren't starving, but it wasn't a pleasure.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was working with him in the shop for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And then somebody suggested to me, because I was always very good with my hands-- I mean, sewing and-- I did in school-- I went to a special school where we did dress making and things like that.",
      "word_count": 38
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And somebody said to me that, why don't you go to college and become a domestic science teacher?",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I said, I can't be a domestic science teacher because I never did any physics.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Oh, but you can be a domestic science-- a sewing teacher.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So I did that part of training.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I became a domestic science teacher, but I only did the sewing part of it.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And three years I went to college.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I got a grant so that I could keep my child.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "By then, we moved into Glasgow, with my mother, and father, and my grandmother.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And I could keep my daughter on my grant and myself.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And I qualified, and then I started teaching.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I was teaching for two years in the Govan High School in Glasgow, until I got married.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And that's the end of the story.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "It's not bad.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It's all right.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We were-- we, we met here.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And our background was completely different because I don't come from a very Orthodox family as my husband.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But I learned it.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And I became the way he wanted it.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And we have got lots of lovely friends in Glasgow.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And we are living very happily there.",
      "word_count": 7
    }
  ],
