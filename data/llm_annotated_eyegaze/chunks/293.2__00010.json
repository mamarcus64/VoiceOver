{
  "stem": "293.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "Friday-- Sunday, we went over there to the assembly place where for which we were going to the city of Sanok.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "I didn't see this Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "Br-- what is-- let me-- can you-- Give me this.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "This guy didn't show-- the [INAUDIBLE] doesn't showing up.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But about 3 o'clock afternoon, somebody is yelling, Pfefferberg, Polie Pfefferberg.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So I came over and say, you, you and your wife, you can get out.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Go back to your apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "But your parents I could not [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "That was the last I saw my parents and my sister, my brother-in-law, and my mother and father.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Mila and I will stay home till March the-- 1941, when they decide to move all the Jewish population from the city to the ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "So we took little bit of our things because the furniture was impossible to-- expensive furniture.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Expensive furniture.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "Mother pay about-- before the war in Vienna-- order about $3,000 for the furniture.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "Was, it was magnificent.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "[INTERPOSING VOICES] And we go to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "And we stay in the ghetto from March the-- from my birthday, March the 20th, till- till March the 20th, 1943.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "They went to Sanok.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They stay in Sanok.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "What I got information after, that my sister, my brother-in-law, his brother, and his wife went under false paper.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They got themselves false paper.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I advised them to go across the River San-- because Sanok is on the River San-- to cross the River San and get to-- to Lvov and to go to Russia.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But I found out later on-- and this was in 1942-- that my brother-in-law and my sister and his brother and his wife are in Czestochowa, and they are blackmailed.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "They need few thousand zloty.",
      "word_count": 5
    }
  ],
