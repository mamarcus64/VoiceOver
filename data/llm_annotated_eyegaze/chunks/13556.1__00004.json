  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And they didn't get an opportunity to get good positions.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] treat them without trust.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "They didn't trust capitalists.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "People-- they came often a background from capitalist.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "They absolutely didn't trust them.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "When the Russian came in was big supply.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We have food.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "No, people were scared.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Was a panic.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Everybody started to prepare himself food more like he need.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And the food disappeared from the store.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "Everything was, like, overnight disappeared.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And then we was already depended on Russia have to supply.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And supply came very slowly.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "Was lines-- lines for bread, lines for sugar, for this kind-- soap, some tobacco, you could buy free, without line.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "Now, the other way, some, like, jam or this kind stuff to buy, herring-- and was a lineup.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And was a very bad supply.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "A very poor supply.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Clothing was demand-- always a demand, Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "We was a very united [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Very united.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And my aunt was living-- was a big home-- big house.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And my grandfather was too big, the house.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And he rent it out always, one suite, for some Polish family was renting.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And my grandmother and father in the house, and I was living in the house with my parents and the kids-- my sisters and brothers.",
      "word_count": 25
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "It was a big, huge home.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "Got a big garden with lots of trees-- different kind fruit.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And we enjoy, happy family.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah-- Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "They have a business.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They rented.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I would say [PAUSES FOR 3 SECONDS] maybe 6,000 square feet?",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Which here is not so big, you know? 7,000 square feet?",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "No, before the war, we consider this big.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have a separate room, no.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "One room, we slept three brothers.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And the other room-- bedroom-- two sisters, and one bedroom for my parents.",
      "word_count": 13
    }
  ],
