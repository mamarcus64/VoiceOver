{
  "stem": "26111.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "So I was with Uncle Sam-- a very interesting time, but I won't go into detail about that-- rooting out-- helping to root out Nazis, and more particularly, Nazi arms caches that the-- that the Nazis had stashed away; and also investigating war, well, war industries that had collaborated very strongly with the Nazis and had used large, large quantities of slave labor-- foreign slave labor.",
      "word_count": 66
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And so I was there until VJ Day.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "VJ Day-- we-- the, the, the corps was-- the division I was in was suspended.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And their work was done.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I guess the attention then shifted to, to Japan.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Any case, I was back in England.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I managed to get into university in '46.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I took-- I managed to get a scholarship the year after that.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Until then, I was working in the university library and going through the first year, and then got my degree in economics in '49 from the University of London, having studied at the London School of Economics.",
      "word_count": 37
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "It's part of the university.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And then had a job in the north of England for a few years.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Met an American girl on holiday in Paris, where I was also on holiday.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And she came over to Manchester where I was living-- Manchester, England, and got married.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "We got married.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And she then wanted to go back.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "She had no intention of staying in England.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And when she saw what the rations-- food rations for visiting foreigners were-- one egg a week was as an example of the-- of the kind of shortages that we had.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "I mean, I had been-- I had been there the whole war.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "So I, I was used to it.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "But she was not.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And she had an apartment in New York.",
      "word_count": 8
    }
  ],
