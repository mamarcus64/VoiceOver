{
  "stem": "18520.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "The machers is, is the people that they support the shul.",
      "word_count": 11
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "They hold the shul.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "But rabbonim, normally they were poor people.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Poor, because they just sit and study.",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "They used to have separate.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "Sometime attached to the shul.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "A lot of them had attached.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "Richer, they had separate, completely away from it, away from it.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "But most was together, like separate.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 5,
      "text": "And they had-- they had in the shuls, poor shuls, they has classes in the shuls.",
      "word_count": 16
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 6,
      "text": "After the davening--",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "They used to put together the-- the bank and this together, no chairs, you know, and sit there.",
      "word_count": 18
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "He was not involved.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Not involved.",
      "word_count": 2
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "And the Bundist movement, was that--",
      "word_count": 6
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Maybe, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "But I think not.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "Maybe yes, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 4,
      "text": "He doesn't give me, a kid, all the-- all the details.",
      "word_count": 11
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 5,
      "text": "You know, what you know about it?",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's-- if Friday night, we had to be everybody together having the dinner, and candlelight.",
      "word_count": 16
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "So everybody.",
      "word_count": 2
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "Now if was time, we used to go downstairs in front of the building, and face talk a little bit, and that's it.",
      "word_count": 23
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "Next day, across the street from us was a place.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "But we didn't do the Shabbos.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "We had to ride bicycles, especially for a few [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "So they had bicycles.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "And you used to go up, and you know, like kids going around there.",
      "word_count": 14
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 7,
      "text": "We used to be this.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 8,
      "text": "In wintertime, used to skating there, skates, and now a street.",
      "word_count": 11
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 9,
      "text": "We used to go-- I had another friend that the father used to-- very nice people, they were.",
      "word_count": 18
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 10,
      "text": "He used to sell horses, buy and sell it.",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 11,
      "text": "Once a week was a big market from farmers coming, not far, in the same block but the end was a huge place.",
      "word_count": 23
    }
  ],
