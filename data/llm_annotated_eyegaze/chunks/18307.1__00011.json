  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "He says, but this is my house.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And he took me outside, and I put the bag on my back.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And he crossed my-- the road, and he said, [NON-ENGLISH], go with God.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "He crossed the road for me.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And as I left, I thought, I'll get-- I'll feel a bullet any minute in my back.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "But God stepped in again.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "These big snowflakes, as big as cotton balls, start to fall.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And it formed like a curtain.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "And as I looked back to where he stood, Ossen, I couldn't see him no more.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "That was another-- another day.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So then were able to get back to the barn safely--",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "--to the barn, right.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "with all the food.",
      "word_count": 4
    }
  ],
