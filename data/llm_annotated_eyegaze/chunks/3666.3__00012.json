  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I knew I am going into the crematorium, when at the last minute, the Blockalteste, the head of the block, who was Jewish, noticed me.",
      "word_count": 25
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And maybe she liked me.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "She coming over to me and she said, [SPEAKING GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You little one, what are you doing here?",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you go with your mother?",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "And I said to her, you know, but these are children.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And she actually took me by the hand and took me to my mother's group where we were standing, and this was one more time when I was saved.",
      "word_count": 29
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she absolutely saved my life.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "It was one of the-- there were more situations, but this was definitely one of them.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And my aunt.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Then we were put on a transport to go to Torun.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Interesting.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember how we got there.",
      "word_count": 7
    }
  ],
