{
  "stem": "18813.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I had to be certain time at home and not later than 9 o'clock, at 9:30 the latest.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And the other way-- and I wasn't punished because I wasn't the baby anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "But I-- the respect was there.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "My mother was coming to the house-- if I was sitting, I got up.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "My father, the same thing because the respect was really for the mother and father, for the parents.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I-- if he did, I really don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Because he was traveling for his business.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Like, he was going to different cities, buying the merchandise, or doing merchandise.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "Maybe he did.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "But we were never discussing that.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We were going, but not too often.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "There was one or two movies around, close, Because too far, I was so overprotected, I couldn't go.",
      "word_count": 18
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And, yeah, I was going to movies Sundays.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Friends, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "We knew war is coming.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "But we didn't expect from the German that.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Because I knew there is lots of anti-Semitism in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't know that that would be the good part, and the German after, wish they could-- I remember like now.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "When they came in, I was standing before the door.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in an apartment with, like, apartment doors.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And we were greeting them.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "We were so happy that they came, the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Because it was a big anti-Semitism in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Some-- like my father, who was a businessman and traveled a lot, so for him, it was a relief.",
      "word_count": 19
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Maybe now it would be better.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "He was still scared.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "I knew that only from discussion because of myself, I didn't feel nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "I didn't have too much contact with non-Jewish people, and so I didn't know too much.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we knew.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We knew.",
      "word_count": 2
    }
  ],
