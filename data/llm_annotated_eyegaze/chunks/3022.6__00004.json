{
  "stem": "3022.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We had the Jewish student organization that had over 100 Jewish students in the city of Frankfurt, at the University of Frankfurt.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "In 1948, I was elected president of that organization.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And I worked hard to make sure that even after I immigrated to the States, there was enough money to put all the students who had to go through the school program.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I accomplished this by running some benefit dances, by getting in touch, becoming sponsored by the Hillel organization of the University of Chicago.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And they used to send us clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Later on, I persuaded them not to send clothing but to send coffee beans we could sell on the black market and finance our expenses with that.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "In 1950, in my fourth year of my studies, I was working on my PhD, when the council called me for the third time.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And he said Norbert, if you don't leave now to the United States, I'll have to cancel your visa.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I registered for immigration in the United States in 1946.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "In end of 1948, I was called in.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I said, I wanted to finish my studies.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I prolonged for six months, another six months.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Finally, council said, you go now, or you can't go at all.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "So I said, to hell with the PhD in the German university.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And I did put my books and one set of suits in the foot locker.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And I went to Bremen, and I boarded the General WG Haan, which was a liberty ship used to transport the GIs in World War II.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And I went to United States.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "I went to New Orleans, because supposedly I had a work contract in the city of Atlanta.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And I arrived in New Orleans on June 5, which was a Sunday.",
      "word_count": 13
    }
  ],
