{
  "stem": "6257.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My name is Wlodka Robertson, and my first name is spelled W-L-O-D-K-A.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And my surname is Robertson, R-O-B-E-R-T-S-O-N.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I was born on the 12th of October, '31.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So I'm 64.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Warsaw, in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Here?",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I remember living in a quite small apartment with my parents, my twin sister, and a young Polish woman who was a kind of maid who lived in with us in this very small apartment.",
      "word_count": 35
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I remember that we-- that is, my sister and I had a room to ourselves and two beds in a small bedroom, and my parents had a sort of settee, which opened that up and the dining room.",
      "word_count": 38
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And then the kitchen was a very small kitchen, where this young woman slept on a folding bed.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "But I remember that we thought ourselves quite privileged.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "To us, it seemed quite the big apartment, because the building was, I think, mainly consisting of, sort of, single rooms, and people seemed very poor.",
      "word_count": 26
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And I remember thinking that we had quite a lot of space.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And the way I remember parties.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "My parents had parties in the-- this room, and quite a lot of people came and went.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "It seemed quite a lively place.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "That, I don't really know, they-- because they were both very active in-- politically.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And they had many friends, and they had-- perhaps they were partly meetings and partly parties.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "They seemed to have lots of people coming in.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember that my father was very well known in that little district.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And whenever we came, especially on Saturdays, he would take me and my sister for a walk, and there were all these people wanting to speak to him.",
      "word_count": 28
    }
  ],
