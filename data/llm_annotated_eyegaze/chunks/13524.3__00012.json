{
  "stem": "13524.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "We manage to get together, being in the latrine, or being into go into the block.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "It was dangerous but not that dangerous.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was-- well, every moment was dangerous.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The whole process of living in a camp was one danger.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "So what's a little bit more?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "But one day, suddenly, I have learned-- I was working in the gemeinschaft.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I have come back from work in the evening, it was dark, and found out that my mother was taken away on a transport.",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Well, I said, this is it.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They took all the old ladies-- 40, 42-- and the young girls who managed to get into that place to work.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They were taken on transport.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And I was sure Mother was taken.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Not even thinking about anything else, I ran down to where the trains were standing with the people loaded.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "The little windows-- it was a cattle trucks.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "There were little top windows, barbed wire.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And I-- my thoughts were to go and be with my mother together.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Wherever she goes, I like to go.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And on the way there, snow was on the, on the ground.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And Jan, SS man Jan-- short tubby fellow-- caught me and started to whip me with [NON-ENGLISH], with a whip.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "Wouldn't let me get to the trains close.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Shooed me away.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "By that time, the trains were already locked, ready to go.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "They had the contingent.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "He has beaten me very much.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "So I was totally destroyed.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "I said, well, they're taking them to Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "They didn't take me because I was still looking young enough to get some work out of me.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "And I went to my father's block.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "My father was equally destroyed.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "Both of us thought my mother went to Auschwitz.",
      "word_count": 9
    }
  ],
