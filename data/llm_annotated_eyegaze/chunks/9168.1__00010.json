  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And our office had the contract with the Detroit Police Department to report every single incident that happened during the night in Detroit.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "This was within a short-- let's see-- 1943 was the race riot-- 1943.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Just after that, I went to Detroit.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "So there was this heavy tension in that city-- race-- a racial tension, and I was very aware of that.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "The prosecutor's contract required us to be on call two nights a week-- each one of us reporters.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "No matter what happened in that city from a-- a fairly bad accident to the worst murder, we would get a phone call from the prosecutor's office in the middle of the night to get to the prosecutor's office, because they would not proceed without a court reporter there.",
      "word_count": 49
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I have-- I've never known of such a thorough system anywhere.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And I can remember I lived in a large, beautiful boarding house up off of Woodward Avenue, across from the art museum, in a wonderful area of the city.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I would get my calls at 2:00 or 3:00 in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And I remember one night, Saturday night, I had a call from the prosecutor's office that they had a terrible murder.",
      "word_count": 21
    }
  ],
