{
  "stem": "2996.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And the next day, you can see one of their brochures or pamphlets saying, they are the international communist plotters, anything to make the Americans feel Nazi Germany is their champion, their fighter.",
      "word_count": 33
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "That's one thing.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The other thing is to undermine belief in Roosevelt, whether you were a Republican or you were a Democrat, because Roosevelt was plotting to go to war against Germany.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And who was behind them?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Obviously the Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I mean, this was the continuous flow of propaganda, well organized, terribly well organized and very, very effective.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "You had people sitting in both houses of Congress, reprinting articles-- no, I'm saying it wrong.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There was a Nazi propagandist agent.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He was a Nazi agent and a propagandist by the name of George Sylvester Viereck.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Viereck wrote pro-German speeches and had those speeches delivered on the floor of both houses of Congress, then reprints it, reprints from the congressional records made.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And it's mailed out by the tens of thousands at congressional frank to people, wherever, to whatever mailing list they could contain.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "George Sylvester Viereck, that was his job.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I was the one that finally convinced the FBI it was time to arrest, pardon me, that dirty so-and-so.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I almost said the bad word.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "They finally arrested him, and he wound up in jail.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The main propaganda, the main objective was that.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Espionage was completely separate.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Was I involved?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I mean, some Nazis, but they were separate.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They were told never go near the German House.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Never going near the German House on 15th Street.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Did I actively do what?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, that was the only time I-- that's the only time I was there.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "But an attorney called me.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "He says, Joe, I'd like you to meet a fellow by the name of so-and-so.",
      "word_count": 15
    }
  ],
