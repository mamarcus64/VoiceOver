{
  "stem": "27770.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We used to like play ball.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We used to like, together, skating.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And he liked the outside activities.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We had beautiful gardens behind the house.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I used to help him, gardening.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And he liked all kind of hobbies.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My mother should rest in peace, a wonderful, Jewish mother, who liked always take care on her children.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "She helped my father, a lot, in the store, in jewelry store, especially time Hitler gave an order that Jews has to go to forced labor.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And she took over the store.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "From 1940 to 1944, she was managing all the years, the store.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We had very few workers.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "There was two watchmakers and two jewelers.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And she took care of it, on the family and the store, and the same time, spent-- sending packages to my father, always to this forced labor.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we have a religious background, from both sides, from my mother's side and from my father's side.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Munkatsh, itself, was a population for 30,000 people.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "From this 30,000 people, there are 15,000 Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Most of the main street, where my father had a store, and, of course, the neighborhood stores, also a little other, smaller streets, 99% of Jews had the stores.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So all the business was in Jewish hands.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It came Shabbos, there was no such a thing, one Jewish store should be open.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It happened once that a guy, who had a drug store, and who did-- who was not religious at all, and he came up with the idea to aggravate our rabbi, the Munkatsh rabbi.",
      "word_count": 34
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And he had a big, big drug store.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And he opened at Shabbos.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Came one of the Hasidic Jew, broke this window, and never again before was a store open Shabbos.",
      "word_count": 18
    }
  ],
