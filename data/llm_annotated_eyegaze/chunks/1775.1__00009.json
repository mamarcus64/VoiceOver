{
  "stem": "1775.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "They still didn't know at the time about the gas chambers and things.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "But they were telling, they picked up so many people and they pushed them in the [INAUDIBLE], you know, the railroads, and the things, and they packed them in like herrings.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "The people couldn't breathe.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "There's a lot of people died right then and there.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "But this lady and her five-year-old son, she just walked away from Treblinka and came back, died last year in the United States.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And her son is still alive.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "And there was another man that came back to us much later-- that was in 1943-- that ran away from Treblinka.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "When the Germans were here?",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Or you mean before the war?",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Before the war, my-- my uncle that used to have-- help me a lot with my brother, that he wanted, in the worstest way he wanted to leave Poland.",
      "word_count": 29
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In the worsted way.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But it just didn't work out.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So what.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I had an aunt that left Poland with her husband and her youngest son.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They went to Australia.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "So if it's not meant to live.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She arrived there.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "She died there right away.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "She had a heart attack because she left two more children in Poland, and she went.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "So it didn't help.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "If it didn't meant to be alive, you just went wherever you went.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "Was there any opportunity to flee into Russia, or was there danger there also?",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "A lot of people went to Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Not legally.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Everybody went, you know, through the river Bug.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "They had places where there was-- the river was narrow, and they could, you know, escape.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "There was a lot of people that knew the roads out there, how to take them back.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "They had to smuggle us, they say.",
      "word_count": 7
    }
  ],
