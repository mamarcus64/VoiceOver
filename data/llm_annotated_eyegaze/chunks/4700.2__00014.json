{
  "stem": "4700.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And there was a moat [SIGHS] around the fortifications.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "And there was a bridge across the moat, which was fairly exposed.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And we just decided, well, we've got to make a break for it and just run across the bridge.",
      "word_count": 19
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Well, we all managed.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "There were about 12 of us.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "We all managed to get back in.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't bring the cucumber or anything because we just left it there.",
      "word_count": 14
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Because the-- the Russians didn't realize what we were or who we were.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They just probably thought we were Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And then, in a day or two, the German-- the Russians came on the way from Berlin to liberate Prague.",
      "word_count": 20
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "They drove through and liberated the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And we all rushed out.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "It was in the evening, at night.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And when I saw the business end of a tank, which was the first time I saw it, [SIGHS] I was just hoping they knew that we weren't Germans.",
      "word_count": 29
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "But they did know.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "And they drove through.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "And lots of people just sat on the tanks and went to Prague.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "And I think I went a day later or two days later.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "My mother was working as a nurse for-- in the typhus hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "So she didn't want to go.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "She wanted to look after her patients.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "So I went on my own.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "All the time.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "All the time.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Total fear all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "You never--",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "You never knew when the day would come.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Because one day they'd take old people.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And one day they'd take young people.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And one day they took people whose name was from A to C.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "And the next-- you know, you never knew.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "There wasn't--",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "It was unpredictable.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And you were always-- it always came at night.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And you were always--",
      "word_count": 4
    }
  ],
