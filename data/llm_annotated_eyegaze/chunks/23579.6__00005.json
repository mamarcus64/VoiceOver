{
  "stem": "23579.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They wanted to arrest him, so we decided if he will arrest him, so probably this will be [INAUDIBLE] together, this was already this.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "So we-- and Asael was already in the army, and he fell already.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the war was over-- sure.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I was in Lida.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "In Lida.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "About four, five months.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And everything was OK till something was wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So, anyway, we run away from there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We run away to Lublin-- to Wilno.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we took a room by an old lady.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "For now.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know where to go, what to do, yet-- nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "But Zusia was working.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I was working like an accountant-- not accountant-- a bookkeeper.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So we made already a living, me and him.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And my father and mother was in Novogrudok, and they were sending me every day more money and more bread and more [INAUDIBLE] and everything.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Where were your mother and father living?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "In Novogrudok.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Novogrudok.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "She went away, and the Polish what she was living in our house gave to them two rooms in our house.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "So they had already a place.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And my father, he's very-- began already to do something, and he had everything like that.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "So he was sending us the food.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "In Lida?",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And we were working.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I am telling you, we were working.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Zusia was working, and I was working, and we were very happy-- quite happy.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I was very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I was very happy with Zusia.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I loved him very much.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And he was terrific-- very good to my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Run away to Wilno.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And the nights were terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "This was December, I think-- whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It was so cold-- terrible cold.",
      "word_count": 6
    }
  ],
