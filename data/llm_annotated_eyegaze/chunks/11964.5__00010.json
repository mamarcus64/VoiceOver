{
  "stem": "11964.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And notwithstanding the fact that we were on the list to go to Palestine, notwithstanding the fact that we establish communication with my cousins in Palestine, we decided, we told her, OK, what do you want to do?",
      "word_count": 38
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So she gave an ultimatum to her future husband.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I'm not going to America unless my two sisters go ahead of me.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So even though I would love for them to be our wedding, I'm going to forego their presence, because I am not going to separate from them.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They had to wait for permission for Jack to marry a displaced persons camp from General Mark Clark.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "By the way, another piece of information, because we were Polish citizens, they wanted to deport us to Poland at one point when we were in the displaced persons camp.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But we had a choice either to go to Poland or to declare ourselves stateless, revoke totally our Polish citizenship.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And we declared ourselves stateless.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So now we were stateless, and we were free to go and acquire any kind of a citizenship we wanted.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So we left my sister, younger sister and I.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My future brother-in-law got in touch with HIAS.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And HIAS promised to give us passage to New York.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We left on May 10 for Bremerhaven.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We stayed there for a week.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We sailed on a troop ship, on May 18, and arrived in New York on June 18.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And while we were on the high sea, June 11 of 1946, my sister and my brother-in-law got married in Salzburg, Austria.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "We came to New York, to his parents and his family, who awaited us.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed with them.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Then, when Jack and Wanda came, Teresa and I had to move out, because they stayed with his parents.",
      "word_count": 19
    }
  ],
