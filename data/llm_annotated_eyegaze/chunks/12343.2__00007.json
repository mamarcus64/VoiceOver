    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I didn't smoke.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I never smoke, and I needed bread.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I got nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Now you have to suffer.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Even my cousin, you know, [? never care. ?] [INAUDIBLE] don't care [? if he's a ?] cousin [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "He took it.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I said, [INAUDIBLE], why did you?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I know he did it.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "Later the next day, take out a piece of bread.",
