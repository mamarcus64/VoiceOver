    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "No more.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "Who was watching over you in these barracks?",
      "word_count": 8
    },
    {
