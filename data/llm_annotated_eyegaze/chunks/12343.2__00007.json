    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I come up, no more bread.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Because why?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He smoked.",
