{
  "stem": "162.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I-- I knew that bad things were happening because of my own situation.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I was old enough now to realize who I was and what I was.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I was always afraid to trip up and say the wrong things.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I knew bad things were happening.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I knew a lot of people were being killed.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "But I was a young child.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "I was what, 11 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was in-- I remember being in Warsaw with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "This is now in 1944, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "That's when there was the big uprising.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I was alone with my mother at that time in Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "My mother, because of her work with the Germans, came home one day.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We had-- she had a girlfriend living with us.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "We lived in an apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I remember the street name was [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I'm sure it's still there today.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Anyhow, my mother came home one day, and she said, there is going to be big fighting in the city.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And we were told that if we wanted to, it was OK.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "[BACKGROUND NOISE] We should pack our things and leave the city because it would not be safe for us to-- to stay.",
      "word_count": 22
    }
  ],
