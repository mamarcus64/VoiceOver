{
  "stem": "18670.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 440.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I said, I'm not interested to go back to Austria.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And then I said, are we joining the British Army, because still I might have been forced to join the British Army later on, because we were classified in different A, B, and C.",
      "word_count": 34
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Some were interned immediately.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Some had to limit how many miles they could travel from that camp.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And others had an unrestricted area that they could travel in.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I said, are we joining the British Army?",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "You're going to be part of the Pioneer Corps.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So I said, what's the Pioneer Corps.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Well, you blow up fortifications.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "When you fight the Germans, enhanced group.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, 50 years later, the British finally admitted that they had Germans, they called them, the Jews, that landed on the-- on Normandy.",
      "word_count": 27
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They had 140 of them that blew up fortifications.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "That was the Pioneer Corps.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But I had to also-- I didn't know at that time, but they told us that some of us would be interned.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I happened to be in the classification I wasn't interned.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "But I know of people that I met there that are interned, that I met after the war.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Some of them were shipped to the Isle of Man, which was very unique, Christians, Germans were interned there, German sympathizer Nazis, and the Jews in the same camp, German Jews and Austrian Jews.",
      "word_count": 34
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And others were shipped to Canada.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "You must know about that too.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Sent to Canada.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We were not considered.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Once the war broke out, you were not a refugee anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "You were German or an Austrian in their eyes.",
      "word_count": 9
    }
  ],
