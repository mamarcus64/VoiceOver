  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And we hope your survive there, but I want-- I want to see-- I want to see the money.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So you're on your-- your aunt will show us where the money, and she say no, no.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It's no use.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "It's no use to look over there.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I took the money out.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "My aunt doesn't even know.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "A friend of his, a watchmaker, lived next door, right door by door, was there.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And he gave him an idea.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "You know, [?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Belcher-- ?] when the money-- everybody knows that your aunt has money.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "So the money is not worth, and the money will be buried there.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "You have to keep the money with you always.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And we have to run or we have to go someplace.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "You have to keep your money with you.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "He say how? what do you mean?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Yeah, you can take the money out.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And you put it in shoe, put a double sole.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "You put a double sole, and it's closed.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And that's the way, when you have to run, you run, you have the money.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Otherwise, to go and dig, that's-- you have no time.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "So you figure maybe he is right.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "So he dig out the money.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "And he say, but you know what?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "You cannot put in all the money in your shoes.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Three on one side and three 20 gold bills on the other side, and I'll take the other six in my shoes.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "He had his own, a lot of money.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "He had a place even by a Polish woman already organized that she is going to-- she is going to keep it.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "Now I say, [?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "Belcher, ?] what are you talking about?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "You gave him the six 20 [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "He gave you the-- that's not right to me.",
      "word_count": 9
    }
  ],
