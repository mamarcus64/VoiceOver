{
  "stem": "26609.15",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And these people took these potatoes out and they ate them.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "When they gave a pig, they ate it.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "They didn't feed them.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "They didn't give them.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And they were not paid.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But what they could get themselves out in fields and cook for themselves, that they were allowed, like carrots they got out on the fields and cooked for themselves, potatoes.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "On that they lived for a few years.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So, I went with them to the church.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "There was one Ukrainian, a big man.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He was about-- he could be about 30 or 35.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He came from another farm.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They congregated together, but it was not allowed.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "The Gestapo came every day.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They didn't allowed people to get together, only to stay where they worked.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "So, every day came Gestapo there.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "But Gestapo left as they came.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "That man, he was Ukrainian.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "He said that Wanda, she has-- he said in Ukrainian [NON-ENGLISH] is Russian-- [NON-ENGLISH]-- a Jewish head or a Jewish mind.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "She looks to me like that.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "So, there was another one-- a Ukrainian-- in our group.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And he just wanted to be my boyfriend, because I appealed him because I was-- they called me [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "It means a city woman.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "I looked better one than the others, so he wanted to be my boyfriend.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I said to him, look.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "Can you hear what he says?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He was the-- that was a very funny story.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He was the worst.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He go with all other people if they said something he didn't like, he just got out a knife-- a knife.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I selected him to be my boyfriend, not another.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "People wonder why did I take the worst one?",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He was like a criminal there.",
      "word_count": 6
    }
  ],
