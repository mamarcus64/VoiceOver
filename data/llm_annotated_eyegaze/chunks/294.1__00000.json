{
  "stem": "294.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, well, the gentleman said they will show you all the phones.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "He can disconnect the ones that have-- in the other-- far away, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And these that are close, here.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "You can--",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Correction-- survivor's name is Ludmila Page.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The interviewer is Branko Lustig; the city, Beverly Hills, California; the language, English.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I-- my name is Ludmila Page; in Poland, it was Pfefferberg.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I was born in Kishinev, Romania, on July 15, 1920.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Levinson.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the life in Kishinev I don't remember at all, because my parents apparently met during the first world war.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They both were doctors, and they met.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Romania-- that part of Romania was under Russian rule, at the time, and they both worked in the same hospital.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "My father came-- my mother was a Russian from Kiev, and my father was from Poland, from the city of Lodz.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But they met in that hospital in-- I don't know if it was-- in those days, I was not-- when I was young, I was not interested to ask questions about-- [LAUGHS] --you know.",
      "word_count": 34
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Now I would like to know so many more things.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "But it's too late to ask those questions now.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And when I was a year old, my father brought my mother and myself from Romania, from Kishinev, to Lodz.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And this is where I lived all my life until the war broke, in 1939.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He was also a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother was a dermatologist; my father was a surgeon.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We-- well, we had an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "You know, very few people, in those days-- we lived in a very nice apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And I had a wonderful, wonderful childhood, in spite of-- of how many people describe their childhood in Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I had a wonderful childhood.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I graduated high school in 1937.",
      "word_count": 6
    }
  ],
