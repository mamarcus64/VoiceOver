  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Even if you live in the city in a beautiful section, all hotels.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And the [NON-ENGLISH], the-- all of, everything, and it was the toilets always outside.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "With that man, what he give us the apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "He was the foreman there.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And he give-- he gave me the job.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "For my sister.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "The oldest brother, he got separate because he was married.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And they got a little boy, three years old.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "So they got [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "Not far, across the city.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "He went-- my brother, what he died here four years ago, he was engaged from [PAUSES FOR 3 SECONDS] a city they call Zawiercie, not far from Cracow.",
      "word_count": 28
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "So he went to her.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And they got married there.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And he took my younger brother to stay over there with them.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "It was most cruel.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Because Lodz, they count in right away-- they change for Lodz called Litzmannstadt.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "It means it belongs to the German.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "It wasn't Poland anymore, Lodz.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "It was Litzmannstadt.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "It means it belongs to the German.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] It was a beautiful monument from [INAUDIBLE], and they cleaned up right away.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "In the-- in the-- in the small towns.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "The younger brother got killed.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "They took him to work, and it was 25 boys, I think.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And two boys, they ran out from the train to the forest.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And after they count, it was supposed to be 25.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "It was only 23.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And they killed the rest of them.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "And brother what he came out alive, my sister-in-law, she got from her grandparents, [PAUSES FOR 3 SECONDS] a little land like a farm.",
      "word_count": 24
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "And the Jewish people, they wasn't very good in farms.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 8,
      "text": "So she sold it to Polish people.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 9,
      "text": "And the Polish people was very poor.",
      "word_count": 7
    }
  ],
