  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I was writing the reports every day, the exercise what has to be done, you know, on a big board, writing down every day what's going to be done.",
      "word_count": 29
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Sometimes the captain and the-- the first lieutenant couldn't go out to call the captain, you know, to the report.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "I used to put the soldiers-- used to put them to their report and give them salute and [INAUDIBLE], all the soldiers clean, all the soldiers are ready to the report.",
      "word_count": 31
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So that's what-- and I became a little bit-- a little bit loved in my-- in my polk where I was.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I used to-- and then they gave me the magazine from the uniforms I should take care, and also the rifle magazine to look at over, which one is clean, which one is not clean.",
      "word_count": 35
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So once this guy, this anti-Semite came over, he had to come to my office first.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "For they wanted to go out to the city, they have to come to my office and see for to give him a-- a-- you know, a paper that they can go out to the city.",
      "word_count": 36
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And now we have to take a pause to change tapes.",
      "word_count": 11
    }
  ],
