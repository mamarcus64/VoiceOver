  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And he brought his gun, and bang, to kill him.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "And this thing was in his head, but he was not killed.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "It stuck, the bullet, here.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "But he was wise enough-- well, first of all, he was frightened.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "So he was playing dead.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 14,
      "text": "After the war, he had operated this.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 15,
      "text": "But you see, he did not know why.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Food, because people had to have food.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And they were--",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Well, people smuggled food for their families or for sale.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And then there was-- for example, they had to bribe that postern, the German, so that he brought the commanders through there without looking for food.",
      "word_count": 26
    }
  ],
