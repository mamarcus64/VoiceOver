  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 39,
      "text": "So they used to come by in the morning and sing songs for me when I was lying in bed and-- in order to be sort of friendly and nice to sort of cheer me up.",
      "word_count": 36
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 40,
      "text": "And after about two or three weeks or maybe-- yeah, something like that-- I was able to get up.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 41,
      "text": "I wasn't able to walk, [? actually, ?] and-- when I-- but I was able to get up.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 42,
      "text": "And I walked.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 43,
      "text": "Not very well, but I walked.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 44,
      "text": "And I wanted to go and see my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 45,
      "text": "And she was in the regular hospital, also run by nuns, but in the regular hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 46,
      "text": "And I went to see my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 47,
      "text": "And the worst-- first thing she said to me, your teeth have grown.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 48,
      "text": "[LAUGHS] Because, you know, nothing grows in-- in-- in those conditions, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 49,
      "text": "And I had-- the teeth-- my teeth had grown bigger, whatever, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 50,
      "text": "That's the first thing she noticed.",
      "word_count": 6
    }
  ],
