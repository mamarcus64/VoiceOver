{
  "stem": "3848.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And we went into a-- I joined an organization called Dror, a Zionist organization with 90-- we were all 90 people.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We lived in Bytom, and we were waiting for a transport to go to Palestine at the time.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We had some bad experiences down there in Bytom with the Polish government.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They once wanted to attack us-- all the Jews-- the 90 young Jews-- youngsters in this group of the Dror organization.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Polish soldiers came with the guns.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "They wanted us out, and it wasn't easy until the Bricha, it was called.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "The Israeli group called Bricha, working from Israel-- they were transporting all the Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "They wanted to get them into Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "So we had to cross borders.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS] One day they decided to take the whole group out and travel towards Vienna.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "We went to Katowice-- it was the town of Katowice, which is not far from the Czechoslovakian border.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And from Katowice, they brought not only the young people from that organization but also their parents, their relatives which lived in Bytom on the outskirts, on the out of this organization building.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And all of us were smuggled towards Czechoslovakia in the middle of the night, which was another experience.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "There was a smuggler hired-- a Czechoslovakian smuggler-- knew the road, through the woods, through the border from Poland to Czechoslovakia.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And it was raining that night.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "Everybody was full of mud.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "We had false documents given by the organization, that made special documents that we were not Jews, but we were Greeks.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "Everybody had a name-- a Greek name-- on the document, falsified stamps and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "We were hiding these documents when we were on the Polish border into special toothpaste tubes.",
      "word_count": 16
    }
  ],
