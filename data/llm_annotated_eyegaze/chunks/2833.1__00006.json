{
  "stem": "2833.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I had a visa to England.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I had my airline ticket.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "My luggage was gone.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And my mother cried so terribly that I didn't have the heart to leave her.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I stayed.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And then a cousin of mine, who lived in Czechoslovakia, in a small town where there were textile factories that he owned-- and he was planning on going to either America or Canada, and told me if I want to come and learn in the factory, he'll take me along.",
      "word_count": 50
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "So I left Prague and went with him, and stayed three months in the factory there.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And then it was too close to the Austrian border, that little town, and it got dangerous.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "So I went back to Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And he went on with his family to Canada, and had a visa for me, again, to go with them.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And again, I stayed, because I didn't want to leave my mother; which today I'm glad I didn't, because I stayed with her till-- as long as she was alive-- and made it definitely easier for her, and could help a little bit.",
      "word_count": 43
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And in Prague, I made a very, very dear friend, again, with a girl who unfortunately did not survive, but had a younger sister who had gone to England.",
      "word_count": 29
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And I never met her in Prague.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "But after the war, I met her here in California.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And it was like a continuation of friendship that I had with her older sister.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "So she is my closest friend now.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "But I spent a lot of time in her parents' house in Prague.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And we had an 8 o'clock curfew.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "We were not allowed to go out of the house from 8:00 in the evening till 8:00 in the morning.",
      "word_count": 20
    }
  ],
