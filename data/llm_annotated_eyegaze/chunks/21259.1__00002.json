{
  "stem": "21259.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "No, we got-- got a hard life.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "After my father when-- when it's finished, you know, what makes more money, he was very Orthodox, you know, when they make weddings, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They used to call him, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "He used to serve.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And he used to cut the cake, you know, and he used to serve like a-- a [NON-ENGLISH], you know, in a restaurant.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "He used to serve.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He used to make money for the wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And everybody knows they call Joseph Melamed, he come, he serves us.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And that's my father.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "No, no this I can tell you, we was very poor.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Now, my mother got two sisters in England.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "They sent us, you know, I remember Pesach, Passover, and she sent us [? sikkas, ?] sikkas.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "She used to us money from England, my mom's sister.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And this is the reason why we survived.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "That's-- That's the reason why.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My mother, Doba, Doba.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "My mother, she was such the woman, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "This is a reason why I can't understand here you have one child, you know, is so heavy [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And there my mother, you-- five children, she used to work everything at home, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And-- and she was a sick woman.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "12 o'clock at night, she got up 6 o'clock. 12 o'clock she went to night-- to bed.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She used to like-- like to [NON-ENGLISH], you know, sew dresses.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And I remember my sister, when she got married, they make cushions, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "She got goose, gooses, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I-- I killed the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "You know, and she make cushions for-- for-- for my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Always she was working, always.",
      "word_count": 5
    }
  ],
