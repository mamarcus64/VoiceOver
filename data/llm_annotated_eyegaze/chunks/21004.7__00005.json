{
  "stem": "21004.7",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And I always had a little hacksaw here with me, always carrying it, then while I was building, I got all the materials for building, because Stefan Marko, I told him to give me all the materials for building a bunker.",
      "word_count": 41
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So and I jumped out.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She said, Leon, they caught us already.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I jumped out, and I came out, and I figured all right, maybe you know.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And this guy say, Leon [NON-ENGLISH]-- Leon what are you doing here?",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And he grabbed me.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "He came around, and he grabbed me.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And I say who is this?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "This is my younger brother.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "He was very small those-- you know.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "I say what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "What are you doing?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "You're building here a bunker.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Such a bad spot.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Kids are common.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "It's so close from the village.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "They come in here for mushrooms to look, and what are you doing here?",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "I say I don't have nowhere to go for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "I figure for a while I say-- he say it's very bad for here.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "So he ran home.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "He brought milk and bread and butter and food and feed us all.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And he say but I'm very afraid.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "I say I'm sitting even on your-- on your farm, in the back of your farm, I sitting there already for a couple days.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "I'm sitting there.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "I thought I'll have my time to catch you and talk to you what I plan to do, to go in the bigger forest.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "So he say it's no good, but anyway all right.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "And I covered everything up, before I finished, with trees and with everything.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "Somehow, somehow, somehow the kids came for mushrooms, and they just find the place.",
      "word_count": 14
    }
  ],
