{
  "stem": "7832.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And we did sort of got woozy and all of that, and then she filled out all kind of papers.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And she handed to them, and-- and she yanked us off the table, like this, real fast, but they accepted her paper.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And she, like, kind of ran with us and threw us into this room.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And there were people there, sitting on the floor.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I mean, they were, like, half dead.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And she says, don't go near those people, just sit there.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And on the way-- on the way in there, before she closed the door, she says, and just remember, never remember your number that they just took out, and never remember your name, or you are dead.",
      "word_count": 37
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And she threw us in that room and she closed the door.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And she says, if I can, I will be back, and she left.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I guess they accepted her-- her-- you know, that we are-- we were put in there to go to the gas chamber.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And she filled out the papers that we are dead.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And we're gone, and our numbers are taken away, and everything was-- and they accepted it.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "When they left, she came into the room.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "She took us out of there.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And she put us in a-- she took us into a barrack in camp that we weren't there before.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "So in case there are people that remember us, they shouldn't say, you know, that we were there before.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "So she gave us a different number, a different name, and a different barrack.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So the two of us survived this experiment and went to-- with her help.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Then, I never knew who that nurse was until the day before liberation.",
      "word_count": 13
    }
  ],
