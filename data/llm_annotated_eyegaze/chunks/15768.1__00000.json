  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Duren, Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "D-U-E-R-E-N, which is in the Rhineland.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "It was September 17, 1929.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It was a small town, an industrial town.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was located between the major cities of Cologne and Aachen, very close.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Aachen is very close to the Belgian border.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And it was a quiet town.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And for culture and things of that nature, we could always go to Cologne and take part in museums and operas and concerts and things of that nature.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "But essentially, it was a quiet, small town.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We had our own home-- my father and my brother, my mother, myself.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was an attached home, which my father had built after the depression.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And we were very comfortable.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It was a nice part of town.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It was located immediately across the street from the Catholic hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And so for as a young girl, I was able to go over there and hold new babies in the hospital and do a bit of snooping around about what it was all about.",
      "word_count": 34
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And the nuns were always very, very kind and very generous and sort of encouraged me to do that.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In that particular house--",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My parents, my brother, and myself.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Anna Marx, and my father's name is Rudolf Marx, and my brother was Eric Marx.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He was three years older than I was.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father was in business with his older brother.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] They owned a factory, a textile factory, sorting factory, that employed about 100 people because Duren was very well known for their paper manufacturing and other products that are made from textiles.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And so it was an ideal location.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I could go down to visit the factory and sit in the secretary's office.",
      "word_count": 15
    }
  ],
