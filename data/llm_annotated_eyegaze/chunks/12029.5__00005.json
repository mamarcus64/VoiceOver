{
  "stem": "12029.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 528.9,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And I straight away had a family.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I had a husband, a mother, and a daughter-- step-daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "It was 11 years difference between the two of us.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And the following year, Henry was born, in 1948.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Sylvia was going to Hasmonean Grammar School.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And I was a housewife.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And Arnold didn't have permission to work.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] When Henry was two, I took him to the Home Office.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have-- they told us to leave.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Then he went with me to the Home Office.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And he said, don't throw my parents out.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I am British.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And funny enough, Arnold got permission to stay in England.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Two years.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "[INTERVIEWER LAUGHING]",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 4 SECONDS] Sylvia went to Hasmonean Grammar School.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I want her to be a chemist, a pharmacist.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "She said she must earn money.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And she left Hasmonean.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "She made full all levels.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And she went to learn shorthand typist.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] And she got a job.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And she was earning 5 pounds a week.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And my husband used to take the mickey out of me that I will never be able to earn money.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And this upset me.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And when Henry was about four and a half, and he had a business, a wholesale of fancy jewelry, I went to work there.",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And they paid me 5 pounds a week.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "Swell.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "When Sylvia was 18, [PAUSES FOR 3 SECONDS] one day in the morning, Arnold comes in that he had a letter from the register that she wants to get married.",
      "word_count": 30
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And she wants to get married to somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And Arnold went.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And he said, what is this?",
      "word_count": 6
    }
  ],
