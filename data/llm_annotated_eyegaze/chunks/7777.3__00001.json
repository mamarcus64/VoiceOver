{
  "stem": "7777.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "He come home [INAUDIBLE] at about 9 o'clock.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "He saw me.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "He said, now you can go home.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "It's quiet.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "I come home.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "Nobody home.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "The Ukrainian police is running around and grabbing the people and-- and taking what they want.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "They ask me, what are you doing here?",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "I just come from work.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "Because I'm supposed to be already dead, because they took the people.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "This day, this Saturday, they took 460 people.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They grabbed mens-- young, old-- and loaded up in the trucks.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "What happened with this nobody knows.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "One said is killed-- they killed them.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "One said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Only they-- the-- the Polish people over there, where they live, they was anti-Semite.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They come always and tell stories, oh, I was in Lublin, I-- to the ladies.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "I saw your husband.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "The [INAUDIBLE] is coming.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "He said to the Judenrate, I saw the people.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "They're working in the other side.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "This was everything lie.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "This was in Friday.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "This was-- they took these people.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "Later, we find out they dig holes in the woods and they killed them over there.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "We start to be memories already, even-- the people got killed.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "Meantime, the widows with the children-- they went to the Judenrate for help.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "The Judenrate went to the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "The [NON-ENGLISH] said, we will send the woman with the kids to-- to the-- over there, where the men are working.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "They was-- they was standing in a line to register.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "Meantime, they had to get some help.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "Meantime, they hear as they want to send them is the line ran away.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And everybody, the [NON-ENGLISH], said, everybody can take packages till 60 pound and we go.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "This was Friday.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "They was then 18 of September, 1941.",
      "word_count": 7
    }
  ],
