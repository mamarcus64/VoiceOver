{
  "stem": "13258.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My full name is Max [?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Marcus ?] Reuben Guttmann, G-U-T-T M-A-N-N.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in the city of Kattowitz at that time Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And that's spelled, at the time, K-A-T-T-O-W-I-T-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "It is now Poland, and it is spelled K-A-T-O-W-I-C-E.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is June 7, 1921.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I will be 75 years old in a few months.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The town which I was born is, first of all, the youngest, I would say, Upper Silesean towns, the oldest being about 16 kilometers away, or 10 miles away-- Beuthen, which goes back to the 13th century.",
      "word_count": 37
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Kattowitz became a city only in 1865, 1863 or 1865.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But it is an industrial center, surrounded by coal mines, steel mills, zinc mills, ore mines, and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Highly industrialized, and as of today, extremely polluted and-- and in bad shape.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It began to grow, really, only when the railroad was brought through there.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And by then, many of the managements from those coal mines and steel mills settled in that city.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And it also became a railroad center.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "My family was connected with the city from the-- about 1880s or 1885.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And my grandfather, as a young man-- my paternal grandfather, as a young man, came to the city as a apprentice into a hardware store.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "He later on built his first-- got his own store and later on built, with the help of some others, the biggest steel bar business in Upper Silesia, a distribution center where he bought  directly from the steel mills.",
      "word_count": 39
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "He also was a member of the city council in that city from 1903 till 1920.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And my father was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And my father later on worked there on and off.",
      "word_count": 10
    }
  ],
