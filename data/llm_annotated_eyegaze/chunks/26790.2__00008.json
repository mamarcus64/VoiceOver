  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I decided yet nothing till the Russian-- till the Red Army crossed the border.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Then I decided because before I didn't-- I can't say nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I haven't got anywhere to go because the Russian border is closed, you can't go to Russia.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "But when the Russian Army crossed the border, they opened the border and everybody can go.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I will.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Let me [? speak lighter. ?]",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I went-- anyway, and this story when I left work-- I must tell you this story.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "When I left work this day, the boss didn't pay me.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And a tell him goodbye and I hope I don't see you again.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I didn't see him again because he was-- for sure, he was one of the six million, for sure he was.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I look on the street where I used to work, [?",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Pialska ?] Street.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Nobody on the street.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "All the people died.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "I don't know where the people gone-- nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "When I come to the corner, [?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Pialska ?] Street and [?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Leblina ?] Street-- that's the [? my street, ?] [?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Liblina ?] Street, like here Elizabeth or something like that-- in this corner used to be a Yiddish restaurant.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And the name from the man from the restaurant, his name is [?",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "London, ?] but we used to call-- the Yiddish people used to call him God because he was a very religious man.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I look on him, he's already not daring the Yiddish clothes what I got here, the Yiddish clothes-- the special hat, the black suit, black coat.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He [INAUDIBLE] European clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I talk and I said, what are you [INAUDIBLE] to talk [INAUDIBLE] go [INAUDIBLE] and see what I-- I have do it.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I look across the road was a big Catholic church.",
