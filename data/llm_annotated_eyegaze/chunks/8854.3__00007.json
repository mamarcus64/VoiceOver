  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "[LAUGHS] They didn't have to beg them.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "They did it gladly.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "And they-- they-- they-- and they left them there.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "We went further.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "And we saw-- we saw there, [? that stays ?] my friend, there-- there-- [PAUSES FOR 3 SECONDS] And to the end walking in a field was a very big alarm, a bombardment.",
      "word_count": 33
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "Ooh, with the rain and-- and everybody was falling to the ground, and the [?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "SSes, ?] also, everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "And I knew that I'm going to be killed.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Because I couldn't walk anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "But listen to that, what God does.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I think-- I still-- how can I believe?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "But I still believe in God, what he [? then ?] [? did ?] me.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I get up.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And I looked around.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I saw everybody's on the ground.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And I saw, in-- in the right-hand side, a little house, very far away.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I start running.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I didn't stay in the ground.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My cousin [?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Suri, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Frimet-- ?] my Jewish name is [?",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Frimet-- ?] where are you running?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Where you going?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I didn't answer.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I run.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I run in, in that little house.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Big, a big house.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "It was a big house there, [? near ?] [? the ?] [? big ?] [? house. ?] But the Germans-- it was-- still was Germany-- they evacuated from there.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Because the bombardment was very great, very terrible, bad.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "So they were afraid to stay there.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So they left the house, their houses.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I run in, in that big house.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I covered myself with that dirt.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I fall asleep.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "A few hours later, I just heard that the command is walking.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And they singing, [GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Hallelujah!",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Hallelujah!",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "(SINGING) [GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And I knew that.",
      "word_count": 4
    }
  ],
