{
  "stem": "8527.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Just to avoid her screaming and yelling, I would volunteer to do the dishes.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I would do anything just to--",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Experiences at the Brooks' house when I was living there.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Remember I told you about not being able to know what it's like to be full?",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I would steal food in that house.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "There was no reason for it.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "She finally came up to me and says, what the hell are you doing?",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I mean, you can eat whatever you want.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Why are you stealing food?",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "At 16, 17 years old I used to have nightmares.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Nobody would come and wake me up.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They would use a broom handle to come near me.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I would automatically jump out of bed.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I used to also urinate in bed.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Not being aware--",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Being chased by Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Being almost killed.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Being almost killed.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Being almost done this.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "All these nightmares for many, many years.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I think I probably started having nightmares after I got married.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I stopped having nightmares, probably after I got married.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So I went to high school.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I graduated from high school.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And I wanted to go to college.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I went to Wright Junior College for a short period of time.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And then I volunteered to go into the Army, because the draft at that time and the war was going on in Korea.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I thought maybe they were going to send me to Germany, because I knew the language.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "My luck, they sent me to Korea.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "So I spent two years in Korea.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And I worked for a company called O'Connor and Goldberg when I was going to high school.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And I came out of--",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I became a supply sergeant.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what to do with myself.",
      "word_count": 8
    }
  ],
