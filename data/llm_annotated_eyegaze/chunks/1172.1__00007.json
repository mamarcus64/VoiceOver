{
  "stem": "1172.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "They had accumulated all the luggage from all the camps, from all the transports, 250 from Frankfurt and the thousand of-- from Berlin to unpack the luggage and to sort it.",
      "word_count": 31
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So many people had food in their luggage, and we tried to steal it.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "But in the evening, when you finish work, they would check you out.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And if they found food, that wasn't very healthy for you.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We were in that camp maybe three months.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "In the spring of 1943, we were loaded to-- on buses and sent-- we didn't know where.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It turned out to be Tallinn.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It was in the middle of the night, a full moon.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "We stopped at a place like in the Middle Ages, a prison with big, white, stone walls.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Had to go through the basement where the-- the stone steps were all blocked off, through hallways.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Through another hallway.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Came to a-- a little more modern building, and it was all dark.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "They would count 10 women, lock the door-- these iron doors.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And there was no light.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] A few minutes later, after they locked the doors, the lights went on, and we saw it was a cell with seven beds against the wall, one toilet, and one sink.",
      "word_count": 35
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "But we were 10 women.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "So the younger ones-- seven women were sleeping in beds, and the three younger ones, we were sleeping on the floor.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was always the youngest.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "There was one other girl that was-- she lives in Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The two of us were always the youngest.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We were only 15 then.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes, always.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] there, in the morning, they would open the doors.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They would throw in some raw fish.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "That was our breakfast.",
      "word_count": 4
    }
  ],
