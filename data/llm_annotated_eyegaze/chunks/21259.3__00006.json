{
  "stem": "21259.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "I was coming.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "He-- I never took [INAUDIBLE] I never ask for a price.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "They give me $180.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I say, oh, the America, it's good, you understand?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "There, you know, I make $80, $90 and the rent costs [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "It was good, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "After-- till December and all of a sudden, no work.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "No work.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So my cousin took me [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I went to my cousin, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "I used to make all the [INAUDIBLE], you know?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "My employment I couldn't get.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "I must have 20 weeks, they told me.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "So my cousin took me into [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And after, I see there is fights.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "My cousin with the wife, they fight.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "He pays me.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "If I'm not in money, I not do nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "You understand this?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I told him, you know, Dave, I don't like this job.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "So I find out my [INAUDIBLE] man, he knows my father, my mother, my grandfather.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He's a furman by [INAUDIBLE] shoes and bags.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Now, I called him up.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] you know, I said, [INAUDIBLE], my-- who you?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I'm your [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Oh, [INAUDIBLE] Come Monday in the morning, 801 Broadway.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And I tell you if, if I give you the job.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I tell you, I don't know you.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "How you look?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "He told me, I'm a small guy.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] You see me 10 to 8:00. 10 to 8:00 I be there in Broadway, go to work.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "I saw.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "I paid.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "I got up 6 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I see him [INAUDIBLE] eventually, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "He goes there.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And I ask him, you, you [INAUDIBLE]?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "He tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "He tell me, Samuel, you [INAUDIBLE]?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I went up.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He told me, you know, but the shoes is no work so much.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But it's Christmastime, this.",
      "word_count": 4
    }
  ],
