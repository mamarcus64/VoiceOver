{
  "stem": "17515.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 88.7,
  "sentences_input": [
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "SS bring them whiskey, cold cuts, salami, and things like that.",
      "word_count": 11
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 2,
      "text": "And they try to buy the jewelry, gold coins from-- from Polish prisoner in Auschwitz.",
      "word_count": 15
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Maybe Birkenau.",
      "word_count": 2
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "I-- but there was-- the Kanada was in Birkenau, in Auschwitz too.",
      "word_count": 12
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 2,
      "text": "That this is the reason why they call-- called it Kanada.",
      "word_count": 11
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 3,
      "text": "Because Kanada, there was everything, what you needed.",
      "word_count": 8
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 4,
      "text": "What you collected, like a--",
      "word_count": 5
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "Gold, diamond, rubies, everything, everything.",
      "word_count": 5
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 2,
      "text": "Mostly the people brought from France, from also, very rich people.",
      "word_count": 11
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 3,
      "text": "And they have to leave everything.",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 4,
      "text": "And-- and they get either way, gas chamber or going to-- to concentration camp, to Auschwitz.",
      "word_count": 16
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "I have no chance about here, about the Kanada, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "That's the Kanada.",
      "word_count": 3
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 3,
      "text": "Till now that Kanada, that's-- that's a goodie.",
      "word_count": 8
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "But I know the people who work in-- in fact, in Kanada.",
      "word_count": 12
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 2,
      "text": "People who work, in fact, in Kanada, people who give a new uniform for us, they-- they change the clothes maybe every couple weeks, fresh one.",
      "word_count": 26
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 3,
      "text": "And Given a shirt.",
      "word_count": 4
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 4,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "When I was sick after, I went to-- they're calling [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 1,
      "text": "They're peeling potatoes.",
      "word_count": 3
    }
  ],
