{
  "stem": "23131.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And we have a lot of problem for the real Communists because a lot of people were sent not Jewish to us, like to be in the-- in the government of the-- of the brigade, in the management of the brigade.",
      "word_count": 41
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And they tried to take over, and their only complaint is that we're more Zionist than Communist.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And this was against the Russian law.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "At that time, communism was-- you know, until Ber-- he came Borgachev-- what's his name?",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Gorbachev.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Gorbachev.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You-- I don't have to tell you how the communism was there.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "We tried to hide the Zionism when it's needed.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But in everybody's heart, everybody knew in his own heart that we are Zionist, and we are Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And nothing can take us away.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Now, Tovia had-- he was an outstanding speaker.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Was very emotional, but he was a very good speaker.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And when he spoke, the trees shivered.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "You had to move.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You had to bring in new rules.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You had to do this.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "You were-- rules and regulations, what you are allowed, what you are not allowed.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "That we have to move the base.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "That we have to go.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "That-- you had some-- you had to keep the-- the people's spirit, because they were-- if it came a bad few days, or a raid, or what-- people were very pessimistic.",
      "word_count": 31
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Because according his spirit.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "According his spirit.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They believed in him, I'm telling you.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They always knew, if he's on the base, they'll survive.",
      "word_count": 10
    }
  ],
