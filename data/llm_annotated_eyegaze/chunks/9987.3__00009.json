{
  "stem": "9987.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he registered me as a Pole, Jan Jerzowski.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Came to-- to-- gave me the ration cards.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I acted-- started to act like a Pole.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Every day, I went to church.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I was-- they had these hand organs.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I used to pump the hand organs.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I got acquainted with the priest.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "The priest wanted me to come for the communion, and come for-- what do they call this--",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "That you tell the priest-- anyway--",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Confession.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I didn't dare to do that.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So I told him, I was just for confession the next town.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, I already did it.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I also got acquainted with a Polish woman there, a former teacher, a young woman. that I told her a story that I am an escapee from the Gestapo.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "She did not know that I'm Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I started to organize myself as a-- as a Pole, to being known in the community-- a small little community.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "At one time, an order came out from the Gestapo.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "There were no Jews anymore-- in the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "An order came out from the Gestapo that all Poles have to have an internal passport, which was called the kennkarte, issued by the Gestapo.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Unable to get that, you have to have a birth certificate.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "How am I going to get a birth certificate?",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, that Christina and I convinced the priest that he gave me a birth certificate, that my name is Jan Jerzowski.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I was born over there, the place.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And he put down these tiny little letters on the bottom that that was issued on a verbal testimony.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He covered himself.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I had enough nerve.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I took that birth certificate, I walked into Stanislawow, to the Gestapo, and got an official kennkarte-- a legal-- a legal passport.",
      "word_count": 22
    }
  ],
