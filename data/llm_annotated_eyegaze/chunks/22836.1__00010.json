{
  "stem": "22836.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "They don't like the Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 4,
      "text": "They want to have the German.",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 5,
      "text": "And when the Germans come, they come with open hands against them to get rid of the-- of the Russia.",
      "word_count": 20
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "We don't even think about it.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "That's the-- that's the trouble, we should be thinking about it.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "To run with the Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "To run with the Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "Leave?",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 5,
      "text": "You can't leave nowhere.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 6,
      "text": "Not with the Russians.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 7,
      "text": "Where can you leave?",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 8,
      "text": "There's nowhere to go.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 9,
      "text": "How can we go from Kolki?",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 10,
      "text": "Where we going to go?",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "They can't go from Lutsk or Rivne, the bigger-- bigger people with more money, they can hire horses and go someplace or with the airplane somewhere.",
      "word_count": 26
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "But we in Kolki, we don't even-- we couldn't think about it.",
      "word_count": 12
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "We just wait, what can happen?",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "What-- what can I tell you?",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "How we feel, especially the Jewish people?",
      "word_count": 7
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "What can we tell?",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 3,
      "text": "It's nothing-- it's nothing-- it's unbelievable what happened.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Right, right.",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "But you still-- well, in one way, we was very happy.",
      "word_count": 11
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "One way, we was happy.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "At least we are alive by the Russian.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "But the other way, we don't know-- we didn't know Germans were going to come on top on the Russians.",
      "word_count": 20
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "They come in right away.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "When they start, right away the come in.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "When the Germans came in, the Russians came in Kolki?",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Came in.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE], right away, then.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Well, we manage.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "We manage with the Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "We manage.",
      "word_count": 2
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "At least they didn't kill nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Well, we closed.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "There was no more grocery.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "No more nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "Everything is closed.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 4,
      "text": "No business.",
      "word_count": 2
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 5,
      "text": "If somebody wanted to have a business, you have to pay 20 times more.",
      "word_count": 14
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't stay in the business.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 7,
      "text": "Everything is-- was liquidated when the Russians come.",
      "word_count": 8
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 8,
      "text": "But they don't kill nobody.",
      "word_count": 5
    }
  ],
