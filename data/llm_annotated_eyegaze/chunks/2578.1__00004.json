{
  "stem": "2578.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And everyone was assigned in places according to their trades, according to their education.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And everybody, the whole population of the ghetto, starting with small children, had to have a certificate that they are employed.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Because the whole ghetto was converted into a big camp, so to speak, to work for the German armed forces, for the German war effort.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "From making uniforms, from electrical work, from making part of ammunition, from making straw boots for the German soldiers later on when they-- when they fought on the Russian territory, especially in the wintertime.",
      "word_count": 34
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Every conceivable trade was in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And everybody, whatever it was produced, was produced for the German army.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Even the children.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "8, 10-year-old children had to work.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Naturally, they did work according to their capacity, according to their--",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Ability.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Sweeping, cleaning, picking up things in the factories, which were called in those days resorts.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they tried to do as much whatever they were told to do.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "All these places were in the confines of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We were not allowed to leave the ghetto under penalty of death.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It started in-- it started in April of 1940, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "This process went on until the very end, until the ghetto was liquidated four years later.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Throughout--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In August of 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "As far as-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "As far as I know, yeah, this was the last ghetto in Poland that was liquidated.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No, just opposite.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "When the war broke out, and-- people from Lodz, especially the Jewish population from Lodz, whoever had the means, started to move eastward, trying to get away, or hoping to get away, from the Russian occupation.",
      "word_count": 36
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Excuse me, German.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "They-- they were trying to get away from the-- I mean, from the German.",
      "word_count": 14
    }
  ],
