  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I went back to the little town where my father had lived, my grandparents there, and I found the house where he had lived.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And there was this old lady sitting on the porch next door and I went over and we-- she remembered my grandparents.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I spoke through this interpreter which was extremely frustrating, and we did this for about five minutes, and then in my frustration I said-- I yelled, 'Doesn't anybody speak English here?' And of course, they looked at me as if I were crazy.",
      "word_count": 45
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And then I said in German, 'Doesn't anybody speak German?' And this old lady said, 'Of course I speak German.' I'd forgotten that that was part of Austria before World War I.",
      "word_count": 32
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "So we were able to have this long conversation, and she remembered my aunts, my grandparents.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "She told me what happened, you know, when they were picked up by the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't tear myself away from this woman because while I was talking to her, and she was-- she must have been 85 at that time-- I had the feeling that my parents were still-- and my grandparents were still alive.",
      "word_count": 41
    }
  ],
