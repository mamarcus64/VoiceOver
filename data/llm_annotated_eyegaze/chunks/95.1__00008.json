{
  "stem": "95.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And she took me over her wing.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And then I started professionally.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "I also did something-- I mean, I was very gutsy.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "I would-- I would do imitations of French stars, French singing stars, when I was 10, 11, 12 years old.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "They probably were dreadful, but I would do them.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And I auditioned for-- for-- for an amateur contest that used to go on every Thursday for kids.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And when I auditioned, I did those stars-- I mean, [INAUDIBLE], all the big stars in France.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And the ladies who listened to the audition were very taken by it.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They said, now, can you do something else?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I had learned at school an aria from an opera.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And I sang that.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And that's what I did for the-- for the amateur contest.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I did not win the contest, but they liked me so much that I was a regular on a Thursday afternoon program on tele-- on radio.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I loved that.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And then with Madame Aron, I would go-- they would show a short film, then I would sing three songs, and then they would show another film.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And it was-- I loved it.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I was the envy of my peers.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I was making money when I was 12 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And remarkably, I was a good student.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Even though sometimes I missed school, because we used to go to school on Thursday, and I would miss that Thursday, I was-- I was a very good student.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I graduated from my school, when I was 12 years old, the first in the school, with the biggest and the highest point.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And they said, you must've cheated.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "I said no, I didn't.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "It just happened that learned two days before whatever-- I was a very fast study.",
      "word_count": 15
    }
  ],
