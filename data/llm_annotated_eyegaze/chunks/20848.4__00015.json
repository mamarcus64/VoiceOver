{
  "stem": "20848.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "When you come to the gas chambers, I'll get you out.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "But there were five gas chambers, and I didn't think that he will be in every gas chamber looking for me.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "So I told to myself, this is it.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "I'm going to die.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "And he must have somehow told the kapo, the Frau Schmidt, that I have been taken-- my number has been taken down to gas chambers.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And she was a very, very influential person in the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "She called me.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "She sent somebody to call me.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "And she said to me-- look, she said to me.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "We spoke-- she spoke-- I learned by the time to speak perfect Czechoslovakian.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "And-- it's very similar to Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 25,
      "text": "And she said to me, look, I will get you out.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 26,
      "text": "There will be lists.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 27,
      "text": "I'll-- I'll get your name crossed off.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 28,
      "text": "Don't you worry.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 29,
      "text": "Go back to your barrack, and I will get your name crossed off.",
      "word_count": 13
    }
  ],
