  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "So then they got us out, and we started to look where they are, and we went into another bunker.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We found some people there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It was a bakery.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And we hid under the-- under the flour.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And then about a day later, they came to see us and caught us.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And of course, they found some ammunition, a few guns, and they asked who is that?",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "I said, I am not here.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "I just came in tonight.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "I have not belong here.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And they let us out.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "We were so much gassed that we couldn't walk, my cousin especially, the older cousin, was gassed.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "I had to carry him.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And we came in to the umschlagplatz, to the market where the railroad leaves.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "A German came over, took his arms and said, you don't have to drag him.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "He is not going to go far, took him away and they shot him in front of  me.",
      "word_count": 18
    }
  ],
