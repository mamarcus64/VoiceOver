    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Leave her.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "If something happen, I will be responsible.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
