{
  "stem": "13584.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "The lady who was our caseworker was a 70-year-old woman from New York.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "She knew a little bit Yiddish and a little bit Russian.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "So she tried to communicate with me.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "She asked me my profession to find a sponsor.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And I told her, I'm a teacher of Russian and also [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "[NON-ENGLISH] means in Russian, Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "Or, they call it sometimes Yiddish, too.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "But I said, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "In Russian, there is a another word, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "[NON-ENGLISH] means old.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "Old, which means, in Russian, [NON-ENGLISH] or 'Hebrew.' So probably, she messed it up, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "I don't if she messed it up or not.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "She misunderstood me or whatever.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "She wrote out.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "And she found out that somewhere in this South-- because I asked for South.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "I didn't want to take New York when I came to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "I wanted somewhere in the South.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "She said, Atlanta needs a teacher for-- needs a teacher like you are.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I said, is it true?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yes, Atlanta.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Do you know anything about Atlanta?",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I said, well, Atlanta, I know, from I know Atlanta from, you know-- it's in the South, it was-- you know [INAUDIBLE] whatever I knew from history, but not too much.",
      "word_count": 31
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I was so happy, Atlanta.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I looked at a map.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "It was very close to the ocean.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I wanted by the ocean.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Great.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Yes, they need a teacher there.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And you, you have a job there.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "July the 16, we are landing in Atlanta.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "The Jewish family children services, two women are picking us up.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "One of them did not speak any-- could not communicate with me.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "The other one spoke German.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "Since Yiddish and German is a little bit similar, so I could understand her somehow.",
      "word_count": 15
    }
  ],
