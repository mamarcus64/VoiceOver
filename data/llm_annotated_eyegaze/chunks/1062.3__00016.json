  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Because I remember a guy next to me, he says to me, you see, I used to live there.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "He passed through his house.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "This guy passed through the house where he used to live.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And he must have been in the camps for years because the Polish Jews were taken there years before we were taken in.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "And it's the first time I saw it.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And we passed through Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And they kept on driving us.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And it was snowing.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "And I had wooden shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "You know, when you march in snow, the snow piles up on the sole.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "If it's leather, the snow--",
      "word_count": 5
    }
  ],
