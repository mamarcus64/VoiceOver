{
  "stem": "4513.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And the first thing he did, I-- nobody in my house, at least, my mother, didn't have a college experience of that sort-- they, they brought us into registration.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And, and I just took whatever they told me to take as courses, you know, we went through registration.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And when I found out that I was, I had-- I had a total of 22 hours.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The first semester I was there, I didn't even have time for lunch.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "My first-- I had three days a week, I went to school at 7 o'clock in the morning.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I went to school at 7 o'clock in the morning on Saturday for a half day.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And I thought that's what everybody did.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "This was college.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I was living out in a cold water flat out in Lafayette and taking the bus to school every day.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "Because they would not allowed to stay in the dormitory.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "It was-- it would-- black kids could not stay in the dormitory.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And Lafayette had a regulation that said-- West Lafayette had a regulation that said that no black person could-- it was in everybody's deed that no black person could even occupy the house as guest overnight in West Lafayette.",
      "word_count": 39
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "So we went back to Lafayette, which was across the Wabash River.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And I lived in-- there was a small black community, of about 300 families.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And I lived-- they used to, they rent rooms to students.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And so they rented this room to me and several other students, we were staying at this man's house.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "How many black students were there in your class?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "There was only-- Maurice and I were the only ones in that particular class, in civil engineering.",
      "word_count": 17
    }
  ],
