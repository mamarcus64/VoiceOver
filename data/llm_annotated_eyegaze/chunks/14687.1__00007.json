{
  "stem": "14687.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "So and then, after, we arrive in Pireo, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we were all together, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "We used to help even-- we used to help the old people, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "We used to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And we say, where are they taking us?",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know all these things.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "My-- my friends-- you know, I had a Greek people.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "They say, stay here, Lucia.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "Lucia, stay here!",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "And I say, I'm going with my family.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "I didn't want to leave them.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "At-- at at Pireo.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "We were going to Pireo.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "But before, we went to all the islands, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "And they-- they--",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, because, I told you, like, they were stopping all the time, you see?",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Because of the bombing, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Throwing bombs and things like this.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "From there, we arrived at Pireo.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And in the meantime, it was so hot there.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't stand the heat.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And they say, all the women, they must sit one side and all the men, the other side.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "So it was a-- a [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "The mother was dead, you see?",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And the daughter was taking the father, who was very old.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Maybe he was 60, 70.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "And he had a beard, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "Beard.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] beard, yes?",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And then, when he was walking-- he couldn't walk, because he was blind.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "The daughter took him.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "And they were hitting the daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "The German was hitting the daughter and the-- that man.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] ah, ah!",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And we were crying sitting there.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "Because he couldn't go alone.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "He was blind.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And the daughter was [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "We used to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "So another German came to ask me, well, why I'm crying.",
      "word_count": 11
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "He say, I'm not German, I'm Austrian.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "He was sorry.",
      "word_count": 3
    }
  ],
