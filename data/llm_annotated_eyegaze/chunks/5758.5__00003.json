{
  "stem": "5758.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 42,
      "text": "[PAUSES FOR 3 SECONDS] At least these bombs are not going to explode.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 43,
      "text": "And he told us we are to put the sand-- We were part of a sabotage group.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 44,
      "text": "One day, a group was caught doing that.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 45,
      "text": "Not our group.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 46,
      "text": "And they were interrogated.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 47,
      "text": "And the engineer who told us where to put-- and his other engineers who were working on the machinery-- were put right away, without any trial, a rope around their neck and hung on the-- on the moving-- from the ceiling.",
      "word_count": 41
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 48,
      "text": "They had these hooks-- and were hung in front of us.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 49,
      "text": "[PAUSES FOR 6 SECONDS] That was somewhere around January, February.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 50,
      "text": "[PAUSES FOR 4 SECONDS] End of February, we heard again artillery.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 51,
      "text": "We were told the Americans coming up from the south towards Dora.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 52,
      "text": "We were put in trains again, and we were transported to a place near Hamburg, Bergen-Belsen.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The group.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, they were always new people.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We got put in barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't choose with whom we were going, we were put in.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Guards-- who stayed there, there, and there, and we didn't have-- I didn't-- we were considering ourselves part of a group.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It was a new group that we never really saw before.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Some of them we saw, and some of them we met.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We had no relationship whatsoever between us, except that we worked together and slept together.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Bergen-Belsen.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We arrived in Bergen-Belsen.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We were put into SS barracks, because the SS were hardly there anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "That was [PAUSES FOR 3 SECONDS] end of March.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And we did not go to work anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "We didn't get-- hardly didn't get any food anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Maybe we got some hot soup.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "There was no bread available.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We dug the-- we dug the earth for roots or something.",
      "word_count": 11
    }
  ],
