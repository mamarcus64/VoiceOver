{
  "stem": "6523.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And from over there, we went back to-- and thank god we [INAUDIBLE] over there.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "We went back to-- before the-- the-- the, uh, the Russian approach that transported closer to Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "The-- [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "We went to Plaszow, back.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And in Plaszow, they make transport [PAUSES FOR 3 SECONDS] to go away to Germany already.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "This is the reason brought me to-- to-- Schindler.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I haven't been with Schindler.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "They got Jews in Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "He got them-- it's a whole story for themselves you heard already.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "Is because the-- the guy, the lagerfuhrer, the German-- you take care of my Jews and I take care of you Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "He put all of them together.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "It was a group, whatever, by 800 maybe left.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And he connect our names [INAUDIBLE] Wieliczka.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "[INAUDIBLE] was, um, PWs from Poland-- strong guys.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "He connected us with the-- with the Krakow Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "They make one transport.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "And-- and-- and this is the reason I-- I-- I was on the list from Schindler.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And we then--",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- I'm telling you.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "You have to figure out a little bit by yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "We-- we-- let's see.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I, myself as a group, just a few guys, came to the people where they've been in Wieliczka.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "We've been there maybe a week, two.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "He-- then Schindler organized Brunnlitz or [?",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Bernanzio. ?] He took the-- the-- the Jews from Wieliczka, connected us with Schindler's Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Then it was in Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And we become [? one ?] transport.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "The Wieliczka Jews, this is the reason I came over here.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "If not, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I would be-- my wife haven't been with Schindler.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I would maybe survive without Schindler.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I-- I could survive everywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGH] They had put us together.",
      "word_count": 6
    }
  ],
