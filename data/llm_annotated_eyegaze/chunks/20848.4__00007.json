{
  "stem": "20848.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "Children who are in the transport, if there are any, there is a special children's block in Birkenau.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And the children will get white bread and milk.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "And my mother said to me, Lusia, you ought to go to this barrack and stay there because you will get good food.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And I remembered what my father said, that you do exactly the opposite what the Germans said.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "So I said, Mama, I'm not going.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "And sure enough, after I was in the camp, I used to go and visit this block where the children were.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "They were there four or five weeks, a full block of children.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "One morning, I went to see them.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And in the night, they took them to gas chambers.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And they gassed them all.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "One night.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "They had tortures for-- for us, I can't even tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They make us run around naked through the whole camp, all of us.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Backwards and forwards.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I don't know why they did that.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Anyway.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "But that-- that happened in-- in-- in the-- yes.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "That was still happening in the-- in the block-- in the camp A.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And then they got us to clean up the B lager.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And the B lager was right next door to the A lager.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And the B lager was empty.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "There were people there, but they-- they probably killed them.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And it was full of fleas.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And I remember I was called to clean it, and it was terrible.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "But we cleaned it up.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And as soon as we clean up the camp, which took quite a few weeks, they shifted us to the other camp B.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "July, 1943.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was-- the 8th of May, we had arrived in Majdanek, 1943.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And July.",
      "word_count": 2
    }
  ],
