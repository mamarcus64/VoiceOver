{
  "stem": "18294.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.2,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And I had a girlfriend that she was with me in the same age.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And she started scream, Rachel, you know that I'm the same age.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I had a mistake in writing.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "What shall I do?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I went up to the-- to the lady that we was provided-- and I said to her, look.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "She's with me in the same age.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "She written.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I can do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And when we come back there was nothing, no more, only the people that were right between 18 and 30 to live.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have different clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They bring the clothes from the dead people, and tell us to change.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We did have-- in Strasdenhof to shave our hair, because we could run-- in case we run away, so they know we are there, we didn't have-- we didn't have any hair.",
      "word_count": 32
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Even after the liberation, I still come without hair back.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In Kaiserwald, it was a very short time.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Because from there, they used to send all the people to work.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- a mind center for people to go to work.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And then the German come, and they ask the people.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Give me 1,000 people, give me 2,000 people, and they took them to work.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Some of them, they had very good camp.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "They was working in the field, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "So there was-- they was there living there.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "You know, they didn't bring them back, just working on the fields.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Nearly a year.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "First thing in the morning they make appell.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They call us all up.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And one, one come, the German, one come and said, look, you have to give us all the children till 18 and from 30.",
      "word_count": 24
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "This was the appell once.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And then another one, they bring some soup.",
      "word_count": 8
    }
  ],
