  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Then we went to Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "We went to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Then we went from [NON-ENGLISH] to Austria-- Austria, I believe.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "We been in Austria.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "They give us rooms there, and food, everything.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "We was waiting to call us apply to America, to go to America.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Just they give us hotels.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "They give us hotels.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] stay in hotels.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was a lot of, a lot of Jewish refugees there.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In Germany, we was there a good year, maybe.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I come here 1949.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Then, from that time, I was in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "A good--",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In Augustine.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Well, they give us work.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "The camp, alone, give us work.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish camp, we was having work.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "We have to go to cook, and sometimes clean up.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "We didn't get pay.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "We didn't get pay because we get free-- free food there.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "There was-- from America, they supply that.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "And finally, they called me to America.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "Me and my wife, we come to America.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "We come.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 10,
      "text": "We got here, find our uncle, our tante.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "It was a ship.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Right, I remember. ship.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No, there was mixed.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Not Jewish alone.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "It was mixed.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "We have to paint the the ship.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "We're painting.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "They give us painting, because they give us food, we have to paint.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "We paint.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "I learn how to paint.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And we come in the ship to America.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "And America, then we're in America.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "We didn't see America.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "America, my goodness.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "We couldn't open our eyes, the-- the lights, and the-- and the cars.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "And we come here.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Mine uncle's son pick us up with a car.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We were thinking, what's going on here?",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "We never saw that.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And finally, we looking for jobs, like I was-- Where did you come in America?",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "To New York?",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Brooklyn.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
