{
  "stem": "9987.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "Eventually, I am 16 years old-- well, 16 and 1/2 years old-- and you've got to start making a living.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "You have to start learning something.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So my father said, well, Shlomo, there's no use playing around.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "You've got to learn something.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "All the other-- all you other-- my younger brother was still in school.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "My older brothers were already working in my father's shop.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father said to me, well, you got to learn a trade.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It will save you from two things in your life-- you will never get rich, and you will never starve.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And that, I started to learn tailoring.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "After approximately two years that I knew already, more or less.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I went to a designing school in Lviv.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I learned pattern-making, and I educated myself quite well.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "When we came back, we started to run the shop, the four brothers.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And we started to get successful.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "In other words, we had a lot of young friends.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "Before, the young people didn't want to support the older people in my father's shop.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "But when we took over, all the friends used to come to us.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And we started to be successful in the things that we are doing.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "We were making a nice living.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We had Polish clientele.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We had Jewish clientele.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "My father was a specialist in-- in these silk coats.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They used to call them [NON-ENGLISH], that-- And my mother was running the house.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "She had to have a maid to help her.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Because there was a practice in Poland, that every Sukkahs and every Pesach, they used to hire new people to work.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "People used to come in to hire themselves for the season.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "They used to call it [HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And they used to hire themselves to work for my father.",
      "word_count": 11
    }
  ],
