{
  "stem": "7904.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "The first day-- that wasn't a Thursday, we found out that a-- a group-- an artistic group from New York comes to entertain a Jewish girl.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I went there with my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "We found maybe [INAUDIBLE] maybe about a hundred more, you know, newcomers.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "There was-- there was a-- it was a different world, our pleasure.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And they-- I moved out from the place where the Jewish community center gave us.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And we moved in by-- with a couple with a child.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "They were on-- on-- they were on [INAUDIBLE] papers with the child.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And we moved in with them.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "I got a job with my brother in a factory.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "We use-- we used to put together [PAUSES FOR 3 SECONDS] box-- boxes.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "That's it, boxes.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So before the holidays, Rosh Hashanah, Yom Kippur, Rosh Hashanah, one guy walked over to the-- to the floor man.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He said, listen, I can't-- I can't come to work tomorrow.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He said, why?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I said-- he said, I have Rosh Hashanah.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I have a holiday.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "So you thought maybe one guy.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "We walked over there, 85 newcomers here started to ask around.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "The second, the 10, the 20th.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "He almost went crazy.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "He-- he had all this to fill.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And nobody came to-- to help him out.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "Yom Kippur, the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "A day after Yom Kippur, we wanted to come to work.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "There was no cards, no, what do you call it.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "No checking-- check cards.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "So without a job.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] I had a cousin-- I had a cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "She-- she died in San Diego.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "I had a cousin in Chicago, she found out about us.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "She said, what you gonna sit over there in Milwaukee?",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "Come.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "Chicago is a big city.",
      "word_count": 5
    }
  ],
