  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "First, it was when we were finished with the job, cutting the woman's hair, they told us to step out from the gas chamber, and they put in gas.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "They gassed them.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Inside the gas chamber, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "That's what we had to pass.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Have to go there, we had to pass that, that row.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Some.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I tell you, first I want to say that after we were finished with one transport, we came out from the gas chamber.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Another transport went in.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And we went in again, we did the job.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "If you're asking a question about we had a conversation, yes.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I had a conversation with a girl I will never forget her name.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "She was from a little town by the name of [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Her name was Chana Levinson.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I never know the girl, the most gorgeous girl I knew.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And so she said, listen.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "You are a young man.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Try escape from here, and let the world know what's going on here.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "That's exactly her words.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And that's how long it took cutting her hair.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "Because we couldn't stay for 10-15 minutes with one girl or with one woman.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Which that was my conversation with it.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] Otherwise, we were not allowed.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "They were not allowed to talk to us.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "We were not allowed to talk to them.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We were about 16 barbers.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Whenever-- whenever the transport came, we were assigned to that job.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "When this transport was finished, we were sent back to camp number II, where we did our usually working day by selecting clothes.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "We were outside.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "We didn't see that.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I tell you why.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The entrance see, was from this side.",
      "word_count": 7
    }
  ],
