{
  "stem": "11175.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "The whole family was very close to each other.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "The sister was in Warsaw, brother in Warsaw, and the younger sister was married.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "I had a younger sister, she got married.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And then, I-- you know, being in Polska, I went out with some girls, and I found a girl, which I married her.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Frania.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Fra-- yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But this was close to the war.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Otwock at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Then the war broke out.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I was there in Otwock.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "That start-- we run away, we knew then we can-- you know, the Jews, they cannot be in Poland because the Germans will-- they were very-- we heard from some other places, you know, and from Germany, the crystal night.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We knew everything.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Hitler's speeches we heard on the radio.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So everybody start to run, and run away, and run away, run to the east, more the east, more to Russia side.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I was among this people which there was running, and I was also there.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I came to Bialystok, and I was in [NON-ENGLISH], Litovsk.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And coming there, I found out my brother is there, and mine sister, mine older sister is there.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So I have to contact them to be together.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "We should be together.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "My brother said, look, when I found them in Bialystok, he looked at me and said, Simon, I have to do something.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I have to-- he was married with a child.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I have to bring the maman, and I have to bring my wife and the child.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I said, look, I was considered at that time more stronger than he.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "You know, I was-- I was more healthier.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And I said, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I'm going to try to go back to Poland, you see, and bring the family.",
      "word_count": 15
    }
  ],
