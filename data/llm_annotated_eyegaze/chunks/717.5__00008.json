{
  "stem": "717.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "Apparently every time I come from Australia, something happens.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "In 1992 when we came back from Australia, [PAUSES FOR 4 SECONDS] we came back in May, the end of April, the middle of the riots in 1992.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So I said, something wrong with me going to Australia.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Every time I come from Australia-- I'm in Hawaii on the stop to come here, I hear about the riots in Los Angeles.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And we came here in '65 and we sort of established ourselves.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I didn't go back to the fur trade.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I didn't want to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "It's dirty.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "It's-- I didn't want to work in it anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I had a letter of recommendation to a company to a gentleman, [?",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Sig Issacs. ?] He had a children's and ladies' manufacturing company, huge national company.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It went all over the states.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "A friend, a mutual friend, gave me his address, his telephone.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I called him up.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "As soon as I called him, he came over the next day in a huge, white Lincoln.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I mean, it took up half street.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I looked at him, oh my god.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Never seen anything like it.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I mean in Australia, you weren't used to these big cars.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I got into the car.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I begged him, could you turn that thing off?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I nearly froze to death from the air conditioning.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't used to that.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I drove a car in Melbourne, wasn't like that.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And he said to me, look, why don't you come down, see what I do, and then you decide if you want a job, a job I'll give you right away.",
      "word_count": 31
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "When I told my aunt that I know a guy here, a millionaire, he's a multi-millionaire, he wants to give me a job.",
      "word_count": 23
    }
  ],
