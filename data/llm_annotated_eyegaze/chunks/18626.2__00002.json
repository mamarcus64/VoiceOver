{
  "stem": "18626.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.1,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My mother said, go [INAUDIBLE] Abraham to the bakery by Sandler.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Maybe you can get some bread left over there.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "My brother walked into the bakery.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "It was all dark.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And when he walked in, on the ground, on the floor, was laying Mr.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Sandler and Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Sandler, and their sons.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "They're all laying in a puddle of blood.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And all the throats were sliced.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And he came back home and he says, Mama, the Sandlers are all dead.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They are laying all in blood.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And my mother says, don't talk like that.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "How do you know?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Maybe you didn't see good?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "He says, Mother, I saw it.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And my mother said, it's bitter, kinder.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Children, it's bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "We go to start hiding ourselves.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And that was the big, you know, pogram made by the Lithuanians.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Not even one German took act in the pogram.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The Germans took later their business, systematically according to the books, and according to the orders of the system how to kill all the Jews, you know, to exterminate the Jews.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "All with a system, all things.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But the Lithuanians, like butchers, they slaughter us.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And it was two groups of Lithuanians who did the job.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "One group was educated, college Lithuanians who killed Jews, slaughtered them in the houses.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And they walked away from the houses.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "The other group Lithuanians, they killed the Jews and they robbed them.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "They came with little wagons, with horses, and they start taking out furniture, the jewelry, and all valuables in the house.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So there were two groups in the pogram.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "The educated killed and walked away, with guns, with pistols.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "The other group was Lithuanians robbed and slaughtered like in butchers and-- and killed the Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we knew plenty.",
      "word_count": 4
    }
  ],
