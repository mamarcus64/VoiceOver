{
  "stem": "14724.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Ellen Kerry Davis, spelled E-L-L-E-N K-E-R-R-Y D-A-V-I-S.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Wertheim, W-E-R-T-H-E-I-M.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "67.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, I come from a-- I was born in a village, which was Hoof, H-O-O-F near Kassel, K-A-S-S-E-L in Germany.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "That depends how far you want me to go back.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well my background changed immensely.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I can go back to the time I was three, when it was a very happy time.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And then I can go to the age of four, when the happiness came to an end.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We lived with grandparents, and uncles, and my parents, of course, and yeah, one younger brother.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And it was just a very content, normal-- very normal sort of Jewish household.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We were orthodox, but we were used to that, because we knew nothing different.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "My grandmother was a joy.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She was a little ball of a woman, almost as broad as she was tall and always strikes me as white, black and white.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "She had snow white hair and always a black dress and a white pinafore.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And my grandfather was twice as tall as she was and always looked strict.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "But my memories of him were at the back of the house there was a garden with a stream in it.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And my happiest memories, if it could be happy, is that almost daily he would come down to the stream and drag me out of this because it was my favorite place.",
      "word_count": 32
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And this was just a happy family.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And then life changed dramatically.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a very gentle person, soft and gentle, as I remember her.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father was a very masculine man, whose hobbies were bodybuilding and things of that description, which were really not known then, but that was his hobby.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He was tough, even to us children.",
      "word_count": 7
    }
  ],
