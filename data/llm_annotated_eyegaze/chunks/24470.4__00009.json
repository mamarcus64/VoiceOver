{
  "stem": "24470.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Uh, I continued in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I was working as a teacher already.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I finished the seminary.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And he went back to America.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "It took 10 months to get papers for me.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So I was still working in Israel, in Herzliya.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And when he sent the papers, I left Israel and I went to New York.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "We have two daughters, married with grandchildren, thank god.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Six wonderful grandchildren, and two of our daughters-- one is an educator, one is an artist.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Both were born in Brooklyn, in Maimonides Hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And, uh, went to school in Queens.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "One is in Pittsburgh.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "One lives in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So we travel between the two.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "By the way, I, uh, got my education continuously in Queens.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I got my bachelor's degree and master's degree in special education.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Bachelor's in early childhood.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So I graduated with my daughter together.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "A little bit.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Uh, I studied English at home a little bit and after the camps a little bit.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I even taught a little bit of English in the B camp, in the displaced person camp.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And when I came here, I studied, uh, very seriously in college, though I-- and I like to read, so I read English books.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "That helped me a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was easy.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That was two weeks on a very elegant ship.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "It was not like the first time.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Happy and painful.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to leave Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to stay there.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Israel gave me a lot of love and acceptance and friends and new families.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And I felt that I not only owed them that after what happened to us, I wanted to live there.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "But I was alone.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "My whole family was destroyed and murdered.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "The extended family, my immediate family.",
      "word_count": 6
    }
  ],
