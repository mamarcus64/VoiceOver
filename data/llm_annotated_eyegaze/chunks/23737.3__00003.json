  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And the greatest happiness was when I had my son.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Although, I wasn't a baby by then.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And I never thought that I will have another child.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "But that was the, the biggest gift of God.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I think it's hard work to do these interviews for the interviewer and the interviewee.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But I feel it's a very, very important thing because it's most important that the new generation should know and should learn about it, what we have gone through.",
      "word_count": 29
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And that should never, ever happen again, what happened in the '40s.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
