{
  "stem": "747.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And among the-- in the technicians and engineers, were a few Jewish men, educated men.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They lived in a compound together there.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "But it was a very peaceful existence.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Until-- until Hitler came to power.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "In 1938, we started to feel the crunch.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Very polite-- very polite, respectful, everybody-- . you know, we kept the Shabbat.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But my mother was so careful that, it came Sunday, she would never allow us to do anything-- to hang up clothes, or wash, or to insult the neighbors.",
      "word_count": 29
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Because we lived in the same land.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And we respected when they had Christmas.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And then when we had our Hanukkah, there was-- everybody knew about it.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "We used to share with them matzo on Passover.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Give to-- we lived in a rented house-- and I remember my mother used to, in a starched napkin, fold in the matzo and take it as a sign of respect to their landlady.",
      "word_count": 34
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "It was very well received.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And we had-- we didn't have much in common, really.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "But it was peace, quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes, little by little.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Before the war?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Little by little.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Actually, it started when Hitler came to power.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "The real power.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "'37-- '36, '37.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "But it came-- we started to feel-- feel it in 1938.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The first Jewish law came out in Hungary.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "There was a restriction on-- they called it numerus clausus-- where the high universities were closed for Jewish kids.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "There was just a certain amount was allowed.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And then, little, little, little, they closed then, the high schools.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "They had a very strict selection.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And then they took every-- they-- these licenses.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "My husband had a flour mill, and they took the license away.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "So he had to-- he had to give it away, practically, because nobody paid for it.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The government.",
      "word_count": 2
    }
  ],
