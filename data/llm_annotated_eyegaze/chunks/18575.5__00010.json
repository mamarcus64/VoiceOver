{
  "stem": "18575.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "In fact, any time-- time you reported, you report haftling, which, in German, means 'prisoner'-- haftling [GERMAN]-- prisoner 127956, reporting.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That was my number.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "After we were tattooed, we were given prison uniforms, new ones-- or not new ones, but new from the camp, from Auschwitz-- stripe uniforms with a printed tag showing the number, which we had to sew on on the left breast of the jacket.",
      "word_count": 44
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And on the upper part of the pants, the 127956 was, on the pants, sewn here and sewn across the left breast with identification.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And the identification was a Star of David with a one triangle being red and another triangle yellow, the two triangles forming the Star of David.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "The other prisoners that I met later that had, for instance, green triangle down were criminals.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Black triangle up were antisocial.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Pink triangle up were homosexual.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "So they identify-- and red triangle down were political.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "They identify prisoners of the category.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "The Jews have one category, the Star of David of the two colors.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "For the feet, we had wooden shoes, originally, that we came back from Majdanek.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They were shoes that the Dutch wear.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Later, we were issued shoes from the people that they killed--",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "--that you-- not-- not didn't fit you, but you exchanged with other prisoners, that you found one that more or less fits you.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We were brought by trucks to Buna and put into a quarantine tent.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "That means, for four weeks, we were in the tent.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And the work was very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We had to drag electric-- heavy electric cables that you sometimes see, those big, giant wheels with cables on it, lay them out in ditches, in mud and things.",
      "word_count": 29
    }
  ],
