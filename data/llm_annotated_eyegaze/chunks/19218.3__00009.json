{
  "stem": "19218.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 400.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, when we came to the camps, they-- they locked him up immediately.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They had a roster.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They knew who was arriving in camps.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And they came to this man.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They came to this David.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "His name was David Stern.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "They said, David, everybody who has arrived within a week or so, they'll all be gone.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "They're going to other camps.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But we can take you out.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We are organized in here.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And he told us this afterwards.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And we can keep you in here, no problem.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "He says, I can't go without three other people.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "That was me, my brother-- I, my brother, and there was another guy who happens to be now in Israel, who lives in Israel now.",
      "word_count": 25
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "He says, they have to go with me.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "He says, David, you know the laws and the rules.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "We can vouch for you.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And I know that you say you can vouch for them, but it doesn't work that way.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "He says, we know you.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "You know him From the camps, but you don't know him, really.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "He says, they can't come in.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "There's not even a question of them coming into the camps-- to the camp.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "They're going to be sent away.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "So he says, then I go with them.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "I don't want to be separated from them.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "They saved my life up to now.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "He says, I'm going to stay with them.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "They send us from there to a camp called Langenstein.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "They called it [GERMAN], [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "That was 10 kilometers away from a city by the name of Halberstadt This was pure hell.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "Nobody ever came out of there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "They were just bringing in new prisoners.",
      "word_count": 7
    }
  ],
