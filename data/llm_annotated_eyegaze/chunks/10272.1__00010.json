  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And in head of the table was sitting the rabbi with the beard and with the payots and with the yarmulke, and with a stick in his hand.",
      "word_count": 28
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And he wouldn't tolerate if somebody would ask too much questions.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I was not-- most of the time, I would raise my hand-- I have a question.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "He would smack me over my fingers.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "No questions now.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I was the age of 5, and I was there till the age of 13.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Many years I've studied yeshiva.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I studied the Talmud, the Bible.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I studied how to pray in the synagogue from the Torah, which is not everybody knows how to do it.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And many things I studied, but now already-- nowadays, I don't remember too much.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And the Czech school was a Czech school over there.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "It was a large school in Bushtina.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I went five years.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I studied in this elementary school for five years.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "After five years, I went to junior high in another place, another town.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They called it [?",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Tiachovo. ?]",
      "word_count": 2
    }
  ],
