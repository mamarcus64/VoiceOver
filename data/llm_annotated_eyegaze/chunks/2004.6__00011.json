{
  "stem": "2004.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "We got married about-- let's see, now, we got married like this must've been-- this was New Year's Eve on December 31st, 1949.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And I think we got married-- not I think.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I better don't say I think.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "I'm going to get lynched later on by my wife.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "It was in-- it was, I think-- it was in August that same year that we got married in 1950.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So it was like nine months later that we got married.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Was it 1949, or was it 1948 that we met?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I have to-- I have to find out from Anna.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I think it was-- it was in 1949.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I know-- I know-- obviously, I know my marriage date.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But I don't remember whether it was from '48 to '49 where we got-- where we-- where we met first, or was it '49?",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Let me think for one second.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We knew each other year and a half-- a   year  and nine months.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "No, I think we knew each other nine months.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It was nine months.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it was '49-- '49 going into '50.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "At that time, I was working as a cabinet maker, working in the woodworking shop.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And my basic training, which I received in the infamous Gorlitzer [?",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Holback ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Holzbau ?] did come in a little bit handy because I had a basic knowledge of woodwork.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And when I-- I started working-- by the way, when I arrived, a week later, I already had a job.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I was working already.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And it was through this person, that relative, the distant relative, who secured the job for me.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "He knew somebody had a woodworking shop, introduced me to him.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "I took the job.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And I was working there.",
      "word_count": 5
    }
  ],
