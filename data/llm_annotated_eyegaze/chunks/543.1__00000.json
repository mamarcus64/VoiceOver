{
  "stem": "543.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I want to ask-- I want to ask [INAUDIBLE] [LAUGHS] [INTERPOSING VOICES] [INAUDIBLE] [INTERPOSING VOICES] [INAUDIBLE] At last--",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Elizabeth Feldman-de Jong.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I'm born in Holland, Amsterdam.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "There were four children, and my mother and my father had four kids.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "The oldest one was Sophia, and the second was Frederika, and I was the third, as Elizabeth.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And then I had a brother, Joseph.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was born in-- in 1916 in December.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And my both parents were deaf.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "They were born deaf, and we-- we spoke all of us on our hands.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Mostly on our hands.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, the sign language, so with our parents, we mostly-- they had a little bit of voice, but mostly they were deaf.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They both went to school in Groningen.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And my mother was in Groningen 18 years.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "That was like an institution.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They slept there.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Groningen was it was the deaf institution.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It was in Groningen.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I know the name is Guyot.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In Groningen.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was in-- in like a province for the Netherlands.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And it was a big, big deaf institution-- I talk about long time ago.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the kids went only to-- my mother was for 18 years and my father.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And the-- it was actually my mother was six or seven years old.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My mother is from a deaf family altogether.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Her parents were deaf.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Her two brothers were deaf, the whole family.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And my father, it was not.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "My father had like a meningitis and brain-- the-- the-- the-- the membrane of the brain was-- so when he was very-- he was only three or four years old when he was-- he was from a normal family, like speaking.",
      "word_count": 41
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So when my father was three or four years old, he was very sick.",
      "word_count": 14
    }
  ],
