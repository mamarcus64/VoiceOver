{
  "stem": "21319.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "This was the-- the-- the big hall behind the gas chambers.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "It was very hot there, and it-- this was winter when we came.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And we-- and I said, gee, they make it so nice and hot, and the floors were clean, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And the lights were on.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And everybody was so relaxed.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So first came a man-- two men.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And they said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Everybody gets undressed.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We got unclothed, and we go to the bath.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We had-- went to the gas chambers, but he couldn't-- they never tell this people, because they didn't-- they knew that we didn't know.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So they said, everybody get undressed.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We-- and everybody got a piece of soap.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Later I got the soap, we find that this was from children's fat.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Well, anyway, this is not what I want to tell you now.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So everybody gets undressed.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "We got unclothed, and we going to get a shower because everybody was filthy and dirty, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So everybody, you know, starts to take off the filth and the dirty clothes and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And one looked at me and the other one looked at me.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I was probably the only one who was clean because I washed myself, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they came over to me, and just to me, they said, did you hear about Auschwitz?",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I said, what Auschwitz?",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They said, this is Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "So I said, so what?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "It's beautiful here.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "I said, the lights, and it's so clean, and-- and we were such filthy camps.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "Listen.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "So they looked at-- I still didn't know nothing because I never heard of gas chambers.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And then he said to me, you never heard of gas chambers?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "He said, it's a pity.",
      "word_count": 5
    }
  ],
