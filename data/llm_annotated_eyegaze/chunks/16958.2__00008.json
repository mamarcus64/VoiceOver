{
  "stem": "16958.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 107.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "They talk to me because you have to go up, open this place.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "Because I was the-- the one that-- that I made this here.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 26,
      "text": "Anyway, all the people were in the chimney.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 27,
      "text": "And it got-- about 4, 5 o'clock, it got dark and they opened this here.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 28,
      "text": "And everybody run away.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 29,
      "text": "We did push out.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 30,
      "text": "And my mother start to walking with me.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 31,
      "text": "My brother in one place around.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 32,
      "text": "Because the police was around.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 33,
      "text": "The police were there.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 34,
      "text": "And I was with my mother, and my mother was almost carrying me.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 35,
      "text": "And the police catch the both.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 36,
      "text": "And the-- my mother knew how to talk.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 37,
      "text": "And she start talking to the police.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 38,
      "text": "And the police want I should go back in the cave to show where we were, because they knew that we left a lot of stuff there.",
      "word_count": 27
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 39,
      "text": "My mother said, look here.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 40,
      "text": "I come-- he's sick.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 41,
      "text": "He can't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 42,
      "text": "He can't look here what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 43,
      "text": "You can't take him to the cave.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 44,
      "text": "My mother talked to them.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 45,
      "text": "And they knew my father, because he used to them.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 46,
      "text": "My mother says my father-- that my husband bought for you two bicycles, that they want.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 47,
      "text": "Says, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 48,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 49,
      "text": "I-- I told them that I want this, and he promised me.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 50,
      "text": "He has them.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 51,
      "text": "He's going to bring them.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 52,
      "text": "Let me go.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 53,
      "text": "And he let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 54,
      "text": "I don't know where I-- I was supposed to be.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 55,
      "text": "I don't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 56,
      "text": "They let us go.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 57,
      "text": "That's really something.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 58,
      "text": "And my mother start pulling me all night.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 59,
      "text": "I don't remember nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 60,
      "text": "And it was in March.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 61,
      "text": "It was mud like that.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 62,
      "text": "And she carried me maybe, I would say, seven or eight kilometers.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 63,
      "text": "And she came to a place.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 64,
      "text": "Now here lives a Mr.",
      "word_count": 5
    }
  ],
