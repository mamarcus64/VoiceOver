  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "They paid her whatever-- whatever what they were owing, and they said we are spies.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "And they had us in the police station, and they-- they said we are spies.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "And-- and-- and we said, ask this lady about us.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "And she said, ring the police station.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "And-- and-- in fact, the police station was closed, I believe.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "But he was there just by-- by incident, he was there.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 11,
      "text": "And he said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 12,
      "text": "These people are OK.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 13,
      "text": "And they saved us.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I-- Olsha.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "His name was Olsha.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And she, he name was-- my mother might remember her.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Olsha.",
      "word_count": 1
    }
  ],
