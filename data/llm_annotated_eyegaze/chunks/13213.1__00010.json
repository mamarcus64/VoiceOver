  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "But not openly, like anybody to do any harm, or to persecute us, no, no.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very close, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Well, I used to play more with my older brother Yakov.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He was only two years older.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "So I used to play with him and do some work around the house.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I liked to do always something to fix around the house and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And he would be helping me to do some fixing around the house.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I always-- I liked always to do something, not to stand still, just always to build something or repair.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Fairly good, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, later on, when I went to a mechanical school-- actually, mechanics were always my favorite studies.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "But as a boy, nature.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I liked nature always, farming and studying about farm.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And since we lived in a village, we did a lot of planting in the school and during the harvest, so on-- before the harvest, studying about crops and everything else.",
      "word_count": 31
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And I liked it.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "But mainly, my-- I was good in poetry, for some reason, and singing.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes, like any other [LAUGHS] Jewish-- Eastern Jewish families, which would be chicken soup, and kugel, and gefilte fish, and all these [NON-ENGLISH] which were made in those days.",
      "word_count": 29
    }
  ],
