      "text": "In Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "That was first of-- it was the 1st of September.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I was called to the army back in 15 of August.",
