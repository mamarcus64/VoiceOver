    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "What kind of leader?",
      "word_count": 4
    },
    {
      "segment_idx": 70,
