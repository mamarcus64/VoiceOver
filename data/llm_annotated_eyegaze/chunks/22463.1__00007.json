    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In 1937-- 1937 is correct.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "As in a small way.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I was a member of-- of Jewish Zionist organization--",
      "word_count": 9
    },
    {
      "segment_idx": 68,
