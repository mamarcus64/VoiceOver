      "text": "What kind of leader?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "There was quite a few of them.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I remember Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Ton, who was a rabbi, and a very progressive one.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "He was member of parliament, in Poland parliament.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
