{
  "stem": "12674.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "But [INAUDIBLE] say there would be easily 60, 65 people getting together, people, wall-to-wall people, food, wall-to-wall food, and it was a fantastic thing.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "After the war, of the original 90, there were-- there were odd people outside, but in the country, there were six of us left-- my father, my brother, and I.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "Well, actually there was seven.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "But my-- my father's older sister, who was like a mother to me after my mother died, and her husband.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Her husband's name-- she was-- she was Berta, which everybody called [?",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Tata, ?] and his name was Albert.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he was a very, very big man.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And while we were in Theresienstadt, she was very concerned about his well-being.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "She was the-- she was-- I don't know, she was a fantastic woman.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "She took in her niece and made them-- was a mother for her.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "She was a mother to me.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "She-- she was a mother to all of us.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "She was a fantastic woman.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And during-- during Theresienstadt, she was-- she was a little woman, and he was a very big, heavy man.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And-- and she gave him her food, and she wound up with tuberculosis.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "She had a bad case of-- because she voluntarily starved herself so that he could eat.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "She was a saint.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "We don't have this in our religion, but she qualifies.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Anyway, so that's what it was.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And she was there and her husband and my father's youngest brother with his wife.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "His youngest brother's name was Samuel, and his wife was Liesl.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And that was all that was left.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my father kept us all-- well, I'll tell you that later because my father kept us all alive.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a very nice woman.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "She was a shy woman.",
      "word_count": 5
    }
  ],
