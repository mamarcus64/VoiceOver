  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "We knew that this is not a shower.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "That they send us to burn down.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "But it was not true.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "The first few people, what they called, nobody wants to go.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "So they, by force, they push a few.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "So then we go, all of us.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "It was really a shower.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And from there, it was one day more.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "We were ready, and we went by train to Brnenec.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "So that was the transportation, what we had from Plaszow to Brnenec.",
      "word_count": 12
    }
  ],
