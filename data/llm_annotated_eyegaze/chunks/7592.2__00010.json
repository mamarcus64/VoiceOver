{
  "stem": "7592.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "He shot him right on the spot-- right in front of everything.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "Where's your wife?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "So he called the wife.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "She came, saw him-- him laying down already.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "She fell on him.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "He killed her, too.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "Chilovitch's wife?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Wife, too.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Which was Chilovitch's sister.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "This is his-- yeah, the Schnitzer, I think.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Then, I remember he went inside over there and called.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I was in the front.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "He says, listen, I know you people got money.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And the money, and the visa,  and you know.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And [NON-ENGLISH]-- If the money wasn't returned, we'd be all shot like this one.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And Goeth is-- he uses the word, shit out from here.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "He went downstairs.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Well, now we lay there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They took us all down and there was on the road, laying Chilowitch dead, his wife, his nephew, Schnitzer, his wife, about eight, 10 guys, with a big sign that they tried to-- you know how this, why he shot Chilowitch?",
      "word_count": 41
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He called them in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Hey, listen, you got something to tell me, tell me.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "He wanted to get from him that he was planning to run away.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "He tried to help him because he was the guy who made money for him.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "He says, no, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Everything is fine.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "So he says, take off your boot.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "He took off his boot, and a gun fell out.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Take off.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Because he knew already because--",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Because the other guy tried to prove it to Chilowitch, you can trust him.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "So the gun fell out, and he says, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "You told me only lies.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "How you are a soldier in Polish army.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The gun is no good.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And the where is the-- you've got three bundles of diamonds.",
      "word_count": 11
    }
  ],
