{
  "stem": "22047.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We have one, two, three-- three grandchildren and two great-grandchildren.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My, my children, the oldest is Shelley, Shelley Eileen.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Her name is Bochinno now.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "She married-- or is married.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She lives in Virginia with her husband.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And, as a matter of fact, we went back to her marriage and--",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, she, she does not.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The middle--",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "The middle-- my middle daughter is Claudia, Claudia Melinda Hardwick.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She-- she's an entertainer.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And her husband's a stand-up comedian.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "She performed at Disneyland at the Golden Horseshoe and-- along with him.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And she then sang at the Disneyland Hotel with a band for a long time.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And now she's out doing, doing those gigs on her own.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And he does, too.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "He's always gone.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "He's a very-- apparently, a very popular comedian 'cause he does-- he's doing quite well.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And then my son, son, James Christopher, he is a very, very talented musician.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "As a matter of fact, he was a music minister for a very large church in Scottsdale, Arizona, and took charge of all of the music and performed at that church.",
      "word_count": 31
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "So he's-- he lives there with his, his wife, Robin, and their two children.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Julianne and Sarah.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Julianne-- let's see, Sarah is-- can't think of their middle names.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Julianne and Sarah Dunn.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I have, to a Rotary Club in Monterey, also to an organization I belong to called SIRs, Sons In Retirement.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I gave a talk to them about my Dachau experiences.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I-- at first, I was a, a bit reluctant because of the trauma associated with it.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And, as a matter of fact, York School, which is a private school here in Monterey, talked to me about giving a talk to the students.",
      "word_count": 26
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I, I wondered whether that was appropriate.",
      "word_count": 8
    }
  ],
