{
  "stem": "20142.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I attended the gymnasium from 1934 till 19-- till the outbreak of war in Poland, September 1, 1939.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Salomea Frenkiel, spelled F-R-E-N-K-I-E-L, but maiden name was Slomnicki, from the family of Slomnicki in Warsaw.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "She originally was from Warsaw, a participant in quite a few drives for the needy children and, and a real, true mother.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Interested in developing children, and the benefit of both my, myself and my my brother and myself.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Always interested in our studies and our progress in learning.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "She was very warm, an extremely loving mother with the-- knowing, with the knowledge of developing a good relation between the children-- son, the son and mother.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And always looking after people coming and having good company for us for the benefit of the developing gifts.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I also remember that from time to time, there were people from orphanages invited for Shabbats, to our house to enjoy the Shabbat meal, and staying over for going together to shul, and so on.",
      "word_count": 35
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Mother was even participating in Warsaw when there was shortages of food and things like this.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "If there was any possibility of giving and sharing with others, she always gave with the utmost.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name was Mieczyslaw, spelled M-I-E-C-Z-Y-S-L-A-W.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Mieczyslaw Frenkiel.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "His Jewish name I don't remember very well, but I think it was [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He departed-- when he graduated from the Jewish gymnasium in Lodz, he departed for studies of textile manufacturing to, to Belgium, where he finished after the war.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "The city that he departed for [NON-ENGLISH] in Belgium.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And he's living, still today, over there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He left Poland in 1938.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He was born on January 26, 1918.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "In Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He was a very good student, extremely talented when it comes to coloring and recognizing shades in coloring.",
      "word_count": 18
    }
  ],
