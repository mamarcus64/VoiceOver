  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Which means-- it stands for Zwiazek Walki Zbrojnej, Association of-- of Armed Struggle.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "This organization later on was transformed.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "In 1943 in December, this organization was transformed to so-called Home Army, or Armia Krajowa, which was, or the ZWZ already was-- already-- [PAUSES FOR 3 SECONDS] not organized, but controlled by the Polish government in exile in London.",
      "word_count": 39
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1940-- 1940. 1940, spring.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Later on, when I was still with this organization, accidentally in a streetcar, I met my leader of the Boy Scouts, which I knew him when I was in the high school in Warsaw.",
      "word_count": 34
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And after-- you know, a few words, he asked me if I were willing to help his organization, also underground organization, because I told him that I graduated high school, and I speak now in German because the language which I learned-- by six years I was learning-- and they-- [INAUDIBLE] yeah.",
      "word_count": 52
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Almost eight years German language at high school.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So he asked me if I were willing to-- to give some lectures of the German language to his group of boys.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And they were-- and I participated in this exercise.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And there was a few meetings in very remote areas of city of Warsaw, where there were some young people coming.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I was just lecturing them on the German language.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Did you take part in any other activities with the ZWZ?",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "There-- there was-- during the 1940-- during the, I think, in '42 was ghetto uprising in Warsaw.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Some of colleagues of the participants of this same organization, they ask me to help in transfer of arms to ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "To-- because at that time, I was very close to the area where-- where the ghetto was.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Zolborska Street.",
      "word_count": 2
    }
  ],
