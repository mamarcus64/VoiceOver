{
  "stem": "3638.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And the bar mitzvah was on the day when the bar mitzvah was, like middle of the week [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "But it was in the middle of the week.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "It was celebrated in the morning prayer in the synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, my-- my first brother was Isaac, the-- the-- the oldest one.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the-- the-- the younger-- the middle one was Henry, Henrick they called it.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Well, my brother Henrick, he died in concentration camp after the war.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And my brother died a few years ago here in Australia.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Straight after the war.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "As a result of the malnutrition and all the sickness.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He survived the war, but he didn't survive the Holocaust, I guess.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "My sister went to-- it's at Krakow-- there was a-- they took my sister with my parents to the now what is-- to the concentration camp.",
      "word_count": 26
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Not concentration camp, but to the gas chambers.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't know, but it could be either Treblinka or Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Karola.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Karola.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "She was married and she had a child and a husband.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Her married-- Lesman.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "L-E-S-M-A-N.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Her husband survived after the war-- till after the war-- because he wasn't-- she-- she was taken because of the child, but he stayed.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And he married again and he live in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But I believe he died.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He would be now in his 80s.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I have no contact with him anymore at this stage.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had with him contact till 1984--",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "--where I went to visit him.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "His first name was Wolf.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, you want to know what happened to them?",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They went to the gas chambers.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "That's what you want to know.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No, my parents were not in a camp.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "My care-- my parents were first in Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Then we went to Wieliczka.",
      "word_count": 5
    }
  ],
