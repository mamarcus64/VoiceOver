{
  "stem": "182.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And we got on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And we came to Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We came to Prague, and hardly were we there two days, and they-- they-- they told us that there will a big search.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And the people who are without a-- a passport or without the permission, who came from Podkarpatska Rus, they will be all taken back by the Russians.",
      "word_count": 27
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And we got scared.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And there was a chance to go further.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And we got on a bus that carried children to France.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And we arrived to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "All.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "No, just-- just my mother, my father, and me.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "My brother stayed in Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And-- and we arrived to Paris.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And there, my parents-- we had some relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And we ate there.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And there was a couple also who came to eat there.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And these people-- this was a lawyer.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And he told my mother that they are in midst of buying a home for orphans who are coming from Poland, and would she go and advise them whether the house that they saw is good or not.",
      "word_count": 38
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Then mother--",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And my mother went.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And these people liked my mother's-- my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And they hired us, that mother should supervise the kitchen.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And father should supervise the schooling of the children.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And I shall be responsible for the-- that they should be clean, and they should-- I went with them for walks, et cetera.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "20.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And this house was in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "That is about 60 kilometers from Paris.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And it's a very, very small, sleepy town.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And there was a big house with a gorgeous, gorgeous chestnut tree, and a big yard, and the garden.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And they brought about 24 children there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "The youngest--",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "This was in '40-- this was-- we-- we got there '46.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "This was '46.",
      "word_count": 3
    }
  ],
