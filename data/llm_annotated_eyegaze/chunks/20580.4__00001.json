  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "A pair of soles, you could have a bag of under a kilo tomatoes, [NON-ENGLISH], you know.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I don't know what to tell you more with that story, about Josef.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Then, they gave us-- they've been [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "At night, they call us [NON-ENGLISH] in the Russian language.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "The daughter comes, Ludia, later Andre come.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Now December, December, the holidays.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "They bring us out food.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And she says to me, I couldn't understand.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "We got so much to eggs, and you never touch eggs.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Because the chickens are laying the eggs, and I never touch eggs, because why should I.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "Then I will give you 5-6 eggs, because you never touch it, the eggs.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "She knows how much eggs, how much chicken, you know, that way.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I didn't know about it.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "But I wouldn't touch the egg.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And she give us to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "December we had a good meal.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "December and January-- January, I fixed the leather-- the leather.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And then March comes friends all from my town.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "Knocks on the door, Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "He says, he's Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "I want to have a piece of bread.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "And they give him a piece of bread.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And they ask about, us, whether that they are there.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "He goes, we are-- he was in the forest, and we don't know where he is.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "She says to him, he was in the-- we've been in the [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "He said, if you see him, you tell him that I'm looking for him.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "She says to this guys, she gives him the-- she gives him bread, she gives him this-- she gives him whatever he want.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "And they're going away, and then she comes in, and she says, come the next-- tomorrow, I'll give you again.",
      "word_count": 20
    }
  ],
