{
  "stem": "4700.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And there was a very famous teacher, Friedl Brandeis.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And she taught the children drawing.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And she had drawing classes.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And the man who was in charge of our barracks kept these drawings and hid them.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And after the war, he had two suitcases full of those drawings.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "He said that was all he managed to bring back from the camp, was two suitcases of drawings.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 12,
      "text": "And he gave them to the Prague Jewish Museum.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 13,
      "text": "And eventually, they are exhibited.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 14,
      "text": "And it's a huge draw card in Prague, in the Jewish-- they get tours to go there and view those pictures.",
      "word_count": 21
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 15,
      "text": "And the, the assistant director of the War Memorial saw them.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 16,
      "text": "And he was so impressed that he negotiated for some of the pictures to be shown in Australia.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 17,
      "text": "And we had about 40 of them.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, they were returned again.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Except one, there was-- Prime Minister Keating opened the exhibition.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And he asked, are there any pictures by anybody who lives in Australia?",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And there was one picture.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And that was in Washington.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "So Prime Minister said we should get it.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And it is in Canberra.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The-- they didn't know who it was by.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Somebody asked me, at the museum, you know everybody.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Do you know anybody called Kitty Passarova?",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes, you want her telephone number?",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "It was Kitty's picture.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "As a child, she drew that picture.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And it is exhibited in the War Memorial in Canberra.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There is a book in existence of the drawings.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I can show you.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "I've got a book of the drawings.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "You teach art to children.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I've got, I think, a couple of books.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I've got a lot of books on the art and, and the music in the-- during the Holocaust and all that.",
      "word_count": 21
    }
  ],
