  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Till one day-- this was in 19-- by the end of '44.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] '44, when we are escaped.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I was working there for nine months.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I'd been working in the shop.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "That's-- one morning, we heard that something is going to happen here in that camp.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "This is in the time when we heard the Russian army already starting to advance on Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "They took already Lublin.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "They took some-- you heard.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "People, which they were working in the offices by the-- by the SS, the German Jews, they were working in the offices from the-- the SS, they heard the radio.",
      "word_count": 30
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "They came back to the camps.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They said, oh, the Russians, they're in Lublin.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE].",
      "word_count": 1
    }
  ],
