{
  "stem": "9215.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "And in the need, we-- he made-- to-- to go in-- a little, you know, a little place, and with a spring inside.",
      "word_count": 23
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "Nobody can go in-- out we can with the spring.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "I don't know that he made it something, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And all my-- the brothers and-- went to there, in the-- and my husband-- in the hiding place-- and myself, and the baby, and my-- my mother, and my sister, we went in the-- how do you call it?",
      "word_count": 39
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "It's in the [NON-ENGLISH]-- in a-- The attic?",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "--attic, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We been there for three days.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And I made a little hole, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And I looked out and I saw everything.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "Every day they chased-- they were Jewish people-- to-- to there.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "They made it.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "This place was-- they used to call it [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "They made there bricks, a special place where they made the bricks.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "There was-- there was this place where they made the two graves.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "And there was all the Jewish people that was killed there.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "I used to saw.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 11,
      "text": "Because we marked-- I made a little hole in the roof, you know, in the attic.",
      "word_count": 16
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 12,
      "text": "And I looked out.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 13,
      "text": "I was there three days.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 14,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Over there.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I saw through the little hole.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I saw what they--",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "--every day they chased the people to the-- to shot-- to shoot them.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I told you where-- where they made the two big graves-- in this place where they made-- this is the place they used to call it, in Polish, [POLISH].",
      "word_count": 29
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "This means where they made the bricks over there.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And, yes, and three days I was hiding with my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And then my baby start crying.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "I didn't got what to give him to eat-- nothing-- three days.",
      "word_count": 12
    }
  ],
