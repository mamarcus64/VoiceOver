  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "But there aren't Jewish children going to that school.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And there are children of mixed marriages going there.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Oh, they said.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "That is a Jewish school.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Just as well.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And Germans, as I said before, they've got these special names.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Like saying this is a Jewish school sounds all right in German, but when you translate it, it's sort of a derogatory.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It means it's sort of a, a school for little Jewish pigs.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And [PAUSES FOR 4 SECONDS] my mother said to one of the police inspectors, we haven't eaten anything.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "The children are hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So he said, lady, take my sandwiches.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] But don't show it to anybody.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And that was that.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "So we had some sandwiches.",
      "word_count": 5
    }
  ],
