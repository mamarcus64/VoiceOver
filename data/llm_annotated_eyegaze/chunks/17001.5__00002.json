{
  "stem": "17001.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And when we went up that night to lay in the-- the [POLISH], the bunk bed, some of the girls said that she doesn't belong in here.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "She-- she's a child.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "She was-- and she came from the children-- so I told her to shut you mouth and so and so.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And she kept quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "There was another occasion where we were selected, my sister Clara and myself.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And my cousin [?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Alice ?] and my sister Elizabeth, they stayed behind.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So they locked us up in one of the block, one of the barrack.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And we were standing there, staying there.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I'm looking, and the-- the edge of the-- the-- the barrack was full of bread, which meant that one of the Stubenalteste who stole the bread because somebody died and this was extra portion, and they put it up there.",
      "word_count": 41
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "So I started eating.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I'm sitting on-- up on top of the-- the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And my sister Elizabeth is standing, walking back and forth, and she is crying.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And she said, you come out.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "If not, I'm going to go against the-- the fence because I don't want to live without the two of you, and so on.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "So I said, here is a bread.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And I throw out one bread, with another bread, another bread.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I said, eat it and stop complaining.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "Stop crying.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We will get out.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "We will get-- now she said, I-- I want you to come out.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "I don't want to stay this way.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "I don't want your lousy so-and-so bread.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I said to Clara.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I said, you know, she doesn't want a bread.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And she is carrying on something terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I want to make sure that you break out.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I don't want to be alone here.",
      "word_count": 7
    }
  ],
