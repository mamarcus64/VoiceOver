  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and I met his parents in Westerbork.",
      "word_count": 8
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Well, my brother, the youngest one, he was 16.",
      "word_count": 9
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "He got-- the three of us got call-up papers.",
      "word_count": 9
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "But my brother and myself got out of it for the time being because of British-- because we were born in Britain.",
      "word_count": 22
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 3,
      "text": "And the young brother just went.",
      "word_count": 6
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 4,
      "text": "He had to assemble at such-and-such a time, such-and-such a spot.",
      "word_count": 11
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 5,
      "text": "And he just went.",
      "word_count": 4
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 6,
      "text": "It will be all right.",
      "word_count": 5
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 7,
      "text": "If I don't go, they'll take the parents.",
      "word_count": 8
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 8,
      "text": "That's what everybody said.",
      "word_count": 4
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "So he felt that if he didn't-- if didn't go, then he would be putting other people in danger.",
      "word_count": 19
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Lots of people did not go.",
      "word_count": 6
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "They went into hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 2,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "See, the administration in Holland was so good, they had everything on paper.",
      "word_count": 13
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "They're good.",
      "word_count": 2
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 2,
      "text": "Not like in Denmark.",
      "word_count": 4
    }
  ],
