{
  "stem": "14928.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "When I worked in the depot already, from this ghetto out, I worked-- we were cleaning the smiths-- what are they called-- all the places, the workplaces for the people that worked over there.",
      "word_count": 34
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we also washed the clothes, the uniforms, fatigues from the people that did the locomotive, fixing locomotives, fixing the cars, train cars and stuff like that.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "So we washed these clothes for them.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And a lot of people worked over there, boys, who worked carpentry-- carpentry.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And girls, some girls worked in the office.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And some girls were cleaning their offices.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "We were not cleaning the offices.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "We worked over there.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "There were a lot of rumors.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "Every day came out another rumor.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "One time, when we worked for the smith, a Polish man came over.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And I worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And there was a boy, who was named Zimering.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "His name was Zimering, a boy also from Kowel.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I didn't know him.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we both worked there, cleaning, doing.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "He helped them work whatever.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I was cleaning.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And he said to us that tonight, they're going to take out everybody from the ghetto, the Jews, and kill them.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "If you want to come sleep over, stay overnight by me, you could do it.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "So you could stay alive.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So if he says this, we both decided we'll go there.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "So we had to cross the railroad tracks and things to come to his house.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "He was nice.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "He gave us a-- not a mattress, some straw or something on the floor.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "We slept over the night.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "But thank God, nothing happened that night.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "We came straight back to work.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Another time there were rumors, same thing, they going to do that.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "One time, they said that that's what's going to happen this night.",
      "word_count": 12
    }
  ],
