{
  "stem": "2350.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Tell me a little bit about school growing up.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We happened to have, in Zawiercie, a Jewish school for Jewish children, only Jewish children, which the teachers were also Jewish, and the principal.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And this is very unique for Poland, because normally, in every other city, people shared with the Polish people.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So all of my brothers and sisters attended the school.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I was the last one to attend already that the teachers knew the name already, I was so familiar.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So unfortunately, I only finished five grades, because the war started.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "But the school was very educational, very respectful.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish boys went to cheder and to public school.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And the girls had the option to go to Tarbut, was a Hebrew school.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "This was paid.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And the public school was free.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And then there was a [YIDDISH], if you wanted to learn Yiddish.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I went to [YIDDISH].",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "My brothers went to cheders to be educated in Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And life was free, comfortable.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "You were not as free, as Jews, as anybody can think.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "We knew that we were Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "On every walk and every street, if we met some Polacks, they were pointing at us that we are Jewish.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "If there came holidays or Sukkot, and if you make the Sukkos, all the Polacks was screaming the Jews have a holiday.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "You know, I wasn't completely comfortable with being Jewish, but that was the way of life.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "Everybody knew that.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "We had 30,000 Polacks and 3,000 Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Was a very nice community-- Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We had temples-- synagogues, I mean.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Was one big temple.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And each section of the city had a synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "We lived, as they call it, in the Polish neighborhood.",
      "word_count": 10
    }
  ],
