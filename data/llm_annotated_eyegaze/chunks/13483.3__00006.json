{
  "stem": "13483.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] I shouldn't really say this, but I said to myself, there's no damned God.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I became an atheist after that.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I just didn't want to believe there was a God.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, especially my friend, David Goldstein.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] He felt the same way as me.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] some of the British soldiers me, some of my friends in the regiment with me.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "They sat down and cried like I did when we first saw it.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "You know, they-- they weren't Jewish and when they say it, they say down and cried.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "They didn't cry, they wept.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "If they didn't wept, they sobbed.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Bulldozing the corpses into the graves.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "That's something I'll never forget.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "What could I say?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Just mass of bodies.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "You know, you're pushing dead bodies with a big blade into these mass graves.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No, most of them were naked.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Some had tatters, you know, dressed in tatters, but I suppose they died on the spot.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They used to drop dead in the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "They just didn't take any notice of them.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I didn't want to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, after one day, I said to my [INAUDIBLE], I said, I just don't want to carry on doing this.",
      "word_count": 24
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "He said, I understand.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "He said, I understand.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "We had to take relays.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "You just couldn't do the whole time.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "It's just, [INAUDIBLE] nauseating.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "It's just you became-- you became dehumanized to think that you could-- you know, that I was shoveling Jewish bodies into a grave.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "More than angry.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was angry with God.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
