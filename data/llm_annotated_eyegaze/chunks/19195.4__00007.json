{
  "stem": "19195.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "I [? say, ?] honey.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "I decided to go to Frankfurt.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "He says, then go.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "He says-- because when you make up your mind, you do it.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I says, I want to.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And that's how I went to-- [SIGHS]",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "'63.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "It was rough.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "It was really, really rough.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I-- we-- the plane was arriving in Frankfurt, and the plane start-- started to [PAUSES FOR 5 SECONDS] land.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And all of a sudden, the microphone came on.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Zelmanovic, please report to the information desk.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And going over and over.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] And got off the plane.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "Instead of going to the information desk, I went to a telephone.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] And I called for the American embassy.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "Right away, the-- he came on.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "And I says, I'm an American citizen.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "I came to testify at the Auschwitz trial.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I said, could you be of any help to me?",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I'm a-- petrified being in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "That was the first time I am back to Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And so he says, please don't move.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Just stay where you are.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And I'm calling my chauffeur.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "We'll be there with the limousine.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "We'll pick you up.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And he came with the limousine.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And instead of going to the American embassy, he took us to a man named Max Bauer who was responsible for the Auschwitz trial in Frankfurt.",
      "word_count": 26
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, he was here in the States a few weeks ago.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I would say about four days.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Same thing.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "The ones I really remember is [?",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Hoffman. ?] He was a schoolteacher when Hitler came to power.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And I forgot the name of the-- he was the photographer in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And I forgot who the other one was.",
      "word_count": 8
    }
  ],
