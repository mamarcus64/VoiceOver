  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 6,
      "text": "I-- so I from there, I went to Rome myself, and I-- I from Rome I went to Greece, to Athens, where I worked for four years for the American Joint Distribution Committee at that time.",
      "word_count": 36
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 7,
      "text": "You know, at that time Athens was the biggest warehouse after the war where they used to come from all over Europe and go to places.",
      "word_count": 26
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 8,
      "text": "And so they were distributing all this the American Joint Distribution Committee was sending there.",
      "word_count": 15
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 9,
      "text": "Were distributing the-- all [INAUDIBLE] to get dress and everything else.",
      "word_count": 11
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 10,
      "text": "And from-- from there I-- after four years, they-- they finished the work.",
      "word_count": 13
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 11,
      "text": "And I was an Italian citizen, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 12,
      "text": "And I didn't think in Greece I couldn't get work at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 13,
      "text": "I went to the American embassy, and in the same day they gave me the stamp to-- to go-- to come to the US.",
      "word_count": 24
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 14,
      "text": "In the beginning, I-- they-- the Jewish community of Cleveland OK that.",
      "word_count": 12
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 15,
      "text": "So I went to Cleveland, Ohio.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 16,
      "text": "It wasn't my place.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 17,
      "text": "[CHUCKLING] It was-- it was cold and [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 18,
      "text": "So I stayed a month.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 19,
      "text": "Then I had some friends calling back to-- to Los Angeles.",
      "word_count": 11
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 20,
      "text": "Do you know [PAUSES FOR 3 SECONDS] Nico [?",
      "word_count": 9
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 21,
      "text": "Minardos? ?]",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- anyhow, he was a nice man.",
      "word_count": 9
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "Passed away a few years ago.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "And we were-- [INAUDIBLE] helped me a lot to come to Los Angeles, because she knew a lot of influential Jewish people.",
      "word_count": 22
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "And I came in here, and I-- I went to work for a textile company called Lensol Fabrics.",
      "word_count": 18
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 4,
      "text": "So Lensol Fabrics, I went to.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 5,
      "text": "They had drapery and upholstery fabrics.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 6,
      "text": "And at that time, in Los Angeles there were thousands of apartments putting together for-- for-- to rented.",
      "word_count": 18
    }
  ],
