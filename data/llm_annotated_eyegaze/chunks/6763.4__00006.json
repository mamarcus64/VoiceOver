{
  "stem": "6763.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I think she was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Um.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I had a change of underwear.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I know I had another blouse.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "I had some socks.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Uh.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "They took burlap and tied it around our feet.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And we walked about eleven hours over the mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And I know that every time we got to a mountaintop, I said, is this it, and they said no.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And then right behind the mountain top, there was another mountain top, and there was another one.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "And we heard dogs barking, and we knew that the Germans were parole-- patrolling this whole area, that they were on our scent, so to speak.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "Because a lot of people were escaping into Switzerland from every border in Switzerland.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "Um.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "We finally made it into the southern part of Switzerland, because we came, you know, from that area, uh, on a most gorgeous Sunday morning in April that I do remember because it wasn't far from my birthday.",
      "word_count": 38
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And we arrived to a mountain patrol station in Switzerland.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "And there were about three Swiss army men working in that station.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And we went in.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "We said we escaping from Italy.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "We feel the Germans are on our trail.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "And they said-- the man in charge there said, sorry, you're going back.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "We can't take you.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So my father said, I have lived in Switzerland for many, many years.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I had a business in Switzerland.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Would you let me make a phone call to Bern, which is the capital?",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Uh.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "He said-- the man said, well, I have no proof that you're telling the truth.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And he said, well, I'm telling you.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Would you let me make a phone call and I can substantiate that?",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, no, he said.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Not making any phone calls.",
      "word_count": 5
    }
  ],
