    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 53,
      "text": "And they took all of the corpses out of the train because most of the people had died.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 54,
      "text": "[PAUSES FOR 6 SECONDS] And they put the corpses along the train track.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 55,
      "text": "And it was very sad because my brother always sought out Catholic people in the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 56,
      "text": "And there was a Catholic lady that he always talked with.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 57,
      "text": "And she was one of the corpses laying there on the ground.",
      "word_count": 12
    },
    {
