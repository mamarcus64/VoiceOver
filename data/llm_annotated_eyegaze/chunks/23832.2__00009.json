{
  "stem": "23832.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "People who ordered people like this, something like this.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "They would come to build things.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "And people would hide-- being in a chimney, they have a chance.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "Or I remember there was a big, wooden big box where they kept the x-rays, the films.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "And people would hide in that box, wherever they can, in the closet.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "But they would come with the whistle.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "All down, come down, all.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "And I had-- from my husband's work-- that paper.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "In a way, it helped me a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "If you don't have a paper, they'll take you away to the Umschlagplatz-- you know what that is.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 36,
      "text": "But I-- a friend of mine who had two papers, and she had a child with her, and she gave me one.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 37,
      "text": "So for a short time, that was like save you from going down.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Terrible, terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You would get a piece of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It was all gravel in it.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "You would be very hungry.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I remember when the Germans invaded Greece, and there they live.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Many live on fishing.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And they would send into the ghetto tiny, tiny bits of fish.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And I would grind it and have a mess, like chopped meat, let's say.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "In all--",
      "word_count": 2
    }
  ],
