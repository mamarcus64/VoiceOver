  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "There I was looking for brown or red paint, because I was full of blood.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And paint, just where we run out of this particular color.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know what to do, nobody knew the procedure.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Would Goeth send somebody to collect three people, or what's going to be?",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "If they find only two, well, you know, nobody knew.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "It was-- you know, we were working in two shifts of 12.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Evening shift finished, went away from the workshop into our barracks, past the two people whose name I didn't know, but whose blood has saved my life.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I think it's that time or later, ask for my father for prayer what to say.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "But anyway, the next morning they had gone.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I took another jacket-- because it was mostly the jacket which was bloodied-- another jacket out of my suitcase, and then went back to work.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Now, next comes when I-- we had to plan for escape.",
      "word_count": 11
    }
  ],
