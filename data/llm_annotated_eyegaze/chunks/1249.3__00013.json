  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "He was always a brilliant man.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "He was a missile designer engineer for Douglas for about 30 years, so-- and a good person.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And he taught me to be decent, and honest, and good, just like my mother told me, and my grandfather.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And something I wanted to tell.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "I-- I don't know what was it.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "So he's right now very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "And it has effect on me.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "I-- you know, two years, he's in bed.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "And it's very hard, very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "But I have two wonderful children.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "And I have the wonderful grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "And thanks God for them.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "And thank God for my husband.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 22,
      "text": "They keeping me alive.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Don't hate anybody.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Just, just don't hate anybody, because look what happened from, from the hatred.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] because somebody has a different religion, or different race, or-- you shouldn't look at that.",
      "word_count": 20
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You should look for the person, the human being, what is inside.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And if somebody a good human being, that's what you have to look.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And the life is not forever.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "We are just here as a visitors.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So it's not worth it to hate and kill, because we are not going to be all of our time here.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Might as not be, be good to each other.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Thank you so very much.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Thank you very much.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Thank you very much.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Read the--",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    }
  ],
