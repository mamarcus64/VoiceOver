  "model": "openai/gpt-oss-120b",
  "elapsed_s": 302.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] He hired him.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And he will start working from 8:00 until 4:30, 5 o'clock, 6 o'clock.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "He was working in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We can move ahead, but if you want, I can tell you what I did, also, I mean--",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I told you before that I am very handy with the hand.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And, um, I was also try to get into restaurant business.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I mean, not me, there aren't any can own, but-- and, um, I was introduced to make parties.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And, uh, I made parties.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "All carving, ice carving, centerpiece carving, all kind of stuff.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And I did it, and I was successful.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And I did it, and, um-- they open up some new restaurants, which I made it.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "I organize it.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And I was very famous down there.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "In the Soviet Union.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "This was-- this was in 1940, [PAUSES FOR 4 SECONDS] before the war-- the war started 22nd of June, 1941.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Started war between Germany and Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And this was in 1940.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I lived by this woman, Mazgirova [INAUDIBLE] Aleksandra Arkad'evna, in with my friend.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "But, um, before the war start, [PAUSES FOR 3 SECONDS] they, um, drafted us-- sorry.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They drafted us, preparation for the army.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Not to the army preparation, but army-- [PAUSES FOR 3 SECONDS] And I got registered, and that's all that it was.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "But when the war start already, in 1941, [PAUSES FOR 3 SECONDS] the-- see, I was drafted before I was already an Amer-- a Russian citizen.",
      "word_count": 26
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because I'm Soviet-- Soviet citizen.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, when you come to the Russian-- the Russian country, and, um-- and you have papers, and done the interview, you-- and you became a Russian citizen.",
      "word_count": 27
    }
  ],
