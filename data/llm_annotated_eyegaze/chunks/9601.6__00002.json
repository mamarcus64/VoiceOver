{
  "stem": "9601.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 69,
      "text": "Uster, Abraham Uster, that came from Klevan to live in the village, he did not know-- did not understand the art of survival.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 70,
      "text": "He was told to stay put, not to go out.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 71,
      "text": "He used to walk down the street.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 72,
      "text": "And strangers, and especially strange Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I had none in our society, right?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "In any society, a strange person-- an outsider moves in, everybody becomes suspicious.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Well, he went for work one day, and never came back.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Who knows what happened to him?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "No one knows.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "So but my grandma lived there too, which-- Grandma Sarah Tesler.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "When-- we'll come back to that, what happened to grandma.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Next door to my Grandma Tesler lived the Adlers, also known as Korns.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And they had, you know, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Korn-- or Adler.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Him and his-- the two of them, they had two little children, a boy-- a little boy and a girl, who's names I do not remember.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "And they had four other children.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "There was Joseph-- [YIDDISH], and [?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Reubin, ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "Hershel, ?] and Dvora.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "Out of that family-- how many is that?",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Nine?",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "Only two survived, Joe and Dvora.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "Joe used to live in Brooklyn.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "He just died last year.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 3 SECONDS] Dvora was hidden out among Czech people.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "You know, when you're liberated, you just like to see each other.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "Everybody's going his own way.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "You know, how did you survive?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "Well, blah, blah, blah. story, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "Well, you came from hell.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "So did I.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "You're story is not any different than mine.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "So you actually do not dwell to know all the little fine details.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 30,
      "text": "And besides, what's the use?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 31,
      "text": "So you left people alone.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Then-- the Korns had three aunts living there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "There was Sarah Yedlin.",
      "word_count": 4
    }
  ],
