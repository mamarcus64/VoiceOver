{
  "stem": "12564.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Like a passage-- passage place.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And I remember the first time they give us, to eat, olives.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And we start spitting out.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And we're from Poland, we're not used to olives to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] And we were looking for places.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And mine ex-friends from the Haganah, they recommended a town in Kfar Bilu, which is 20 kilometers from Tel Aviv.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "That they are already 50 families.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "There may be room for one more.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And that they're building the houses them self.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "So I join them.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "With mine girlfriend, already.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "And we came over there, and we start building the home till that in December, we had the wedding.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "We had no music, no light.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "The soldiers were playing in cans from [?",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "Bisquick, ?] it was making music.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "We pulled out [? vials ?] with kerosene lamp, for electricity.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "And the next day, we went to [? cutting ?] [? oranges. ?] No honeymoon after the wedding.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 19,
      "text": "And we had three kids in Israel, three daughters.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 20,
      "text": "I was one of the successful farmers over there.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 21,
      "text": "Actually, very successful.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 22,
      "text": "Even today, when I come for a visit, they want to give me land to build a villa, a home.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No, own farm.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Private farm.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "My brother, the Partisans did not release him.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They took him away to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I did not know, 30 years, if he is alive.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They-- he was a captain of the Russian army.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And they kept him in Kurilskiye Ostrava.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "This is the island, what Russia took away from Japan, what Japan wants it back from them, even now.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And from there, this was military secret place.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And nobody could write a letter.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "After 30 years, he wrote a letter to the Polish people we were hiding.",
      "word_count": 14
    }
  ],
