  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And when I came to back to the partisans, to my-- my general said, gosh, you live a long life.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He was right.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "My only explanation for that, and this is mine, I wore-- [INAUDIBLE] they saw me, I'm positively.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "They saw me on a horse.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My only-- my explanation I wore a German uniform from a German pilot.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I remember it was, we got it once in the fights.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And he was a-- must be a tall, a tall [? fritz. ?] You know, so, I had to cut off.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "You know, I remember cutting it off to-- to suit me.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And I had a poncho, a poncho.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "You know with those different colors.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "The kids now wearing, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "When you camouflage, you can camouflage.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "You fall on the ground you camouflage.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "With this, you don't-- you-- you don't-- when a plane comes over you, hovering over you, he doesn't see.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "You are a part of the ground.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And I wore this pilot hat.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "My explanation for all this things, how that they didn't sniper me down, or they didn't kill me, because they saw me in full view.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "They thought that maybe I was one of them.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "It's the only thing I can tell you.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "Maybe I was lucky, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "But this is my explanation for this story.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "This is another.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Up till 1944, about a year and a half.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But you can have to start from '42, to come to '44.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] They were gallant fighters.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They were fighting to hell.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I know [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They were afraid of our shit.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They were afraid of us.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "They used to-- imagine, they had the guts to call the partisans, bandits.",
