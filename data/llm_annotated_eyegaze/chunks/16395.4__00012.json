{
  "stem": "16395.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 297.0,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And he was ?] really nice.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "They brought in-- soon we came, they brought in things for the baby.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "But I was really ashamed to take, because I knew that, in Europe, if you took something, you were so poor.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "And I didn't want it they should think that I'm so poor.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "So I didn't want to take it, but they told me that it's nice.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "And they brought everything for the baby.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "And we used to go to shows, to-- to-- to see a movie.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "And they used to give us dishes.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "So they all went to the movies, and they got dishes, and they gave it to me.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "I should have a whole set.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 15,
      "text": "They really were very, very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 16,
      "text": "I cannot say no.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Then I went to work, too.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I was-- in the beginning, I was at home.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And when Shirley was six and started school, I went to work.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I worked in an optical company.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And I made very nice money, $50 a month-- a week, which it was a lot of money.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And I worked there for maybe eight months.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And then I became pregnant with the second child.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And I was pregnant [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And I-- and I had-- I was very sick, because I didn't go to the-- I knew that I'm pregnant, and I didn't go to a doctor.",
      "word_count": 27
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And finally, under two months, the tube busted, and I was poisoned all over.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And they took me to the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "I was four weeks in the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And they had to change all my blood.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "And all the newcomers came to the hospital day after day to give blood.",
      "word_count": 14
    }
  ],
