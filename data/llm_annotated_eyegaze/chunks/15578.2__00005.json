  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "This I remember correctly.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And he did gave-- he knocked him out, with blood.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "He said, you're going to pay with blood.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And in that time, the Polish paper-- the newspaper, they said that he didn't [PAUSES FOR 3 SECONDS] express himself nice on the ring.",
      "word_count": 24
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "That's all that I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "That the-- that Rotholz, the Jewish boxer, had not expressed himself.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "That's the Polish newspaper they would say I think like this.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "After all, this is sport, but he and-- the coach, the Polish coach, he took them away on the side and went back to the hotel, not to see so much.",
      "word_count": 31
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I could hear, but I didn't pay very much attention.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "That it was going on, the-- the killing, they're [SIGHS] abusing Jewish people in Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "That's all what I know.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "As a young boy, nobody ever did-- I wouldn't say nobody, but I didn't pay very much attention.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "That was always.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I remember I had an account, a bank account at it called [INAUDIBLE] Polish-- in the post office there.",
      "word_count": 19
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And near the war, I went up and wanted-- we had to stay in the line, and a lot of people there, they want to withdraw some money.",
      "word_count": 28
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And there was an organization, a Polish youth organization and it call OZON, O-Z-O-N, OZON.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "This is youth follow, like I would say, like probably like the Hitlerjugend.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And they would stay in the line and will have the Jewish people want to go near the window to draw some money, they special blocked it.",
      "word_count": 27
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "In 1939.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I did try.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "From my own account.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Not very much, but--",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I went once in the morning, right in the morning, and withdraw.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
