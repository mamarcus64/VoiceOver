    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "The people who started rescue activities in Hungary for refugee Jews were two groups of people.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "The Zionists on the one hand, who were, generally speaking, non-religious, and who started their own [NON-ENGLISH], their own committee of-- of help and rescue.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And independently of that, there was an Orthodox [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "These two groups, the Zionists on the one hand and the Orthodox on the other hand, represented a minority of the Jews in Budapest, and represented even a minority of the Jews in Hungary, although in the countryside, the Orthodox were quite numerous.",
      "word_count": 43
    }
  ],
