{
  "stem": "1550.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And the Gestapo helped them.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "The Gestapo sent, allowed, a Jewish functionary from the Jewish community council to go to Bratislava and pick me up.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Not only me [INAUDIBLE], but there were also two other people who were in the same position.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "There were-- we were three young men all about 18-19, to go back to Vienna with the permission of the Gestapo to get the American visa, so we could go to America.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "You see, it's very interesting.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "These-- you don't-- people don't know about those things, the Gestapo helping Jews, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, the Jewish functionary arrived in Bratislava.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He-- we picked up our-- we picked our bags-- we packed our bags and went back to Vienna.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "But we tried to get back to Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "At the German border, we were stopped by the German passport control.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "He looks at my passport.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And he says, look, with this passport it says here, you can only leave Germany once.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And you can never come back.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "That's what it said there.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You see what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But the functionary said, it says, here, I have the letter from the Gestapo.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He say, Gestapo, schmepapo.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I am not-- I am not interested in the Gestapo.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I am a border passport control.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Here, it says in the-- in the passport, you can't come back.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And I don't care what the Gestapo says.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "You can't come back.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I have nothing against you personally.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "He was very nice, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "He says, look.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I have nothing against you, Jewish, or non-Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "It says here you can't come back.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "So you can't-- you can't come back.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "Never mind what the Gestapo says.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The fellow from Vienna was allowed to go back to Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Because he hadn't-- he didn't have that stamp in his passport.",
      "word_count": 11
    }
  ],
