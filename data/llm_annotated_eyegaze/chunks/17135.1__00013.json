  "elapsed_s": 40.1,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 25,
      "text": "And he went to the window.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 26,
      "text": "And that really saved us from being hurt.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 27,
      "text": "I'll give you an example.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 28,
      "text": "There was a family about two blocks from us.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 29,
      "text": "They had a big store, a very big store, one of the biggest shoe stores.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 30,
      "text": "And they also lived on the second floor in the same house.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 31,
      "text": "They literally took the man and the woman and threw 'em out of the window.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 32,
      "text": "Just like that.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 33,
      "text": "As if they were garbage.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 34,
      "text": "And the man was totally paralyzed after this.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 35,
      "text": "The woman was sick and broke her leg or her arm.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 36,
      "text": "But the husband was paralyzed after this.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 37,
      "text": "That we heard after the event.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 38,
      "text": "And we-- but we were afraid that they will hurt us.",
      "word_count": 11
    }
  ],
