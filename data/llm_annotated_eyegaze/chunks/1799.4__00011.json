{
  "stem": "1799.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "That marriage lasted about 10 years.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And there were two children.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Bob-- Robert and Steve.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Robert was born in 1949.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "He spent four years in the Army, in-- or the Navy in Vietnam, between college period and is living in Los Angeles and is not married.",
      "word_count": 26
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And then Steve, his brother, was born in '51.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "He's 44 years old.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And he's married.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "He became a physician.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "He is a nuclear, doctor of nuclear medicine, works at the VA hospital in San Francisco.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "That's where they live.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "They have two children, two of our grandchildren.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And their names are Julie and Benjamin.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Julie is going to be six.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And Benjamin is three.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And Steve's wife's name is Trudy.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And my current wife is Betty.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Current-- I-- we've been married since '72, so it's 20-- 23 years, and happily married.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And Betty has two children from her previous marriage.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And they are Michael, who was born in '50-- '54, I believe, and his brother, David, who is a successful realtor and businessman, and has two children, also.",
      "word_count": 28
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And David's children-- his wife's name is Suzanne.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And his children are Garrett and Britain-- girl and a boy.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "So each of our kids that have children have one of each.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, the one thing I feel I must add, it might be controversial.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "But I'd like to add it.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And that is, in-- in this interview, I don't know how much time you have.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I am-- I am thankful, grateful, respectful of being able to get the chance to tell part of my story.",
      "word_count": 20
    }
  ],
