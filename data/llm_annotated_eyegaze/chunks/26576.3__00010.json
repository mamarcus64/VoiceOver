{
  "stem": "26576.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And my father helped me to write a letter.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And we did write a letter to Stalin, and we got an answer which reads like a fairy story.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "But it's true.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We got-- and I'm sure Stalin didn't write.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "But it was written from Stalin.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And it was signed.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they said they'll do everything possible to find her, and to free her.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And we had information later on that she was seen on the street in Siedlce where she was imprisoned later on.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "But she was shot by the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "She was shot in the street by the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Somebody said, you're a Communist.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And they shot her.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "This is not Sosnowiec.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "This is Losice.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "They were all taken to Treblinka.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I'm reading now a book that came out from Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And-- and so this is a new book that just came out.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "It's a Holocaust, the children from Holocaust survivors.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And somebody writes about Losice.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Somebody writes, the ones that either they were taken to Treblinka or they were shot on the way.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "She says that the elderly, which is very possible that my grandparents were in it, were shot on the way from Losice to Treblinka that when she was traveling the road was full of dead old people.",
      "word_count": 37
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "So this is what he found out.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "That they went to Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Where my mother lost again everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "She heard later on that her brother, the one that-- David, the one that was working for my father, that he even was in the uprising that he tried to run away or tried to fight with the Germans.",
      "word_count": 39
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "But-- but he died.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "His wife died, and his child died.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "You know, so it was terrible sad.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "It was a very sad return really for my parents.",
      "word_count": 10
    }
  ],
