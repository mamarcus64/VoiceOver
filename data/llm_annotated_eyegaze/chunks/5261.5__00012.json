  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 53,
      "text": "Very nice for young readers.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 54,
      "text": "I think maybe it will be good.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 55,
      "text": "So I wrote to him.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 56,
      "text": "I agree.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 57,
      "text": "I-- I bought used typewriter.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 58,
      "text": "And I typed him my story.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 59,
      "text": "He-- he wrote me also some question.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 60,
      "text": "We collaborated on one book as my story.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 61,
      "text": "I wanted to show all the world how I suffered for nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 62,
      "text": "For nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 63,
      "text": "Without any reason.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 64,
      "text": "And the German government, they treated me in this way.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 65,
      "text": "Therefore, I wrote to-- and I wrote this book.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 66,
      "text": "And when the project of this book was finished, the writer of this book came to Warsaw.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 67,
      "text": "With this project I read once more.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 68,
      "text": "Of course, it was difficult to read, but I read.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 69,
      "text": "I gave my signature.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 70,
      "text": "I agree with the publisher of the-- publish this book.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 71,
      "text": "Oh, he brought me-- because it was in December, he brought me some gifts for Christmas from his home, from some friends.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 72,
      "text": "Because the first book was written for that.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 73,
      "text": "He brought from his friend, and he gave me also the birthday present, gifts.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 74,
      "text": "And so later, I received letters from, not only from readers, but also from homosexual.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 75,
      "text": "And he said, yes, they knew that you are in demand.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 76,
      "text": "You must be operated.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 77,
      "text": "I had-- I suffered also skin cancer skin.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 78,
      "text": "And in this martial time, no medicine.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 79,
      "text": "I had to do only private, and it costed a lot of money.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 80,
      "text": "They paid for me.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 81,
      "text": "They collected this.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 82,
      "text": "Only-- and it was also very touched for me.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 83,
      "text": "Like for them, my story was touched.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 84,
      "text": "Because they-- they are wondering that me, as a homosexual in Polish, I-- I'm forget.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 85,
      "text": "Forgive them, and I give the hand.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 86,
      "text": "As a Catholic, I forgave.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 87,
      "text": "It is in our prayer.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 88,
      "text": "You must forgive to everybody.",
      "word_count": 5
    }
  ],
