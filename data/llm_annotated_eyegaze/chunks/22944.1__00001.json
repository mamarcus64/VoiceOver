{
  "stem": "22944.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And later, it was possibly one period, just Hungary and then Slovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "That's what I understand the historical period of that time.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Solomon Mannheimer, and his family came from Piestany in Slovakia, and, I believe, originally came from Germany.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But I think our family lived approximately 300 years already in Slovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He was in textile business.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, I think he was working for somebody else.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I can't really tell you awfully lot, but I do know that he used to travel around quite a bit, and he was away from home.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But that's what I was told, and that's what I remember.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had one brother, and I had four sisters.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my eldest sister was Barbara.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We call her Bracha.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And my brother was [?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Martzie-- ?] Moshe.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "My next sister was Edith [?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Tova, ?] [PAUSES FOR 3 SECONDS] then Naomi, and Gertie and then [?",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Chava ?] at the present and myself, Miriam Eva.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I'm the youngest.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I remember quite a bit in Bratislava.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Well, first of all, I come from very orthodox family, strictly observant Jewish family.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] the special occasions used to be on a weekend or summer holidays.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We used to go out.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Bratislava has got lovely hills and the parks, and we used to go out quite a lot as a family outing and picnics.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "It was great fun on Saturdays.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I remember going to school, of course.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "To junior school, or kindergarten, you would call it.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And family gathering, not a lot, because we had an enormous big family, but cousins and uncles and aunt coming to visit us.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "From my father's side, I remember only one uncle.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I think his name was Jeno.",
      "word_count": 6
    }
  ],
