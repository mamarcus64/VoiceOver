{
  "stem": "27129.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "With the three children she was left.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "My older brother was 13 years old and I was only 9.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "My middle brother was 11, so we were two years apart.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And my mother got sick after she worked a year or year and a half after my father died.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And then became very hard times.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "We got a little bit from an uncle, you know, a little money.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And then my older brother went to work, and then my second brother went to work.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And it got there a little bit easier.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "But still it was very, very not-- not a comfortable life economically.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "Always was not enough food in the house, clothing was-- was a luxury.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "You know, I had to wear clothes what my older brother passed to my next brother and my middle brother, then it came to me.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "It was from pants and jackets and shoes.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Even though it was not my size, but this is the way it was.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "I couldn't--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were too proud to go to agencies for help.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "You know, I come from a proud family, so my mother wouldn't-- wouldn't stand for that, to go for any help to an agency.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Bernard.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Tauba.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Spiegel.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My older brother was Aaron.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My middle brother was Henry, or Hanoch, and mine was Abram -Avram.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, before my father died was not easy, because 10 years he was sick.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He was sick on TB, was a tuberculosis patient.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So during the war-- after the First World War, you know there was a typhoid epidemic, and he was sick, you know, because of that epidemic.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "He was in the hospital, and when he recovered from the typhoid sickness, he got pneumonia.",
      "word_count": 16
    }
  ],
