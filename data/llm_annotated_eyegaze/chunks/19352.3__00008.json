{
  "stem": "19352.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 564.4,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Aquarium with-- with fish.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "To him, what I took care of it.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And the fish died.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And I receive-- oh.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "He beat me.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "You cannot imagine.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And I was the good one.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I know everything, what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- when something was wrong in the books, he said, no, it's not her fault.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "It must be your fault.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "You have wrong.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "But he beat me up.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "This was a sadist.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "This was something-- you cannot imagine what this was.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "Another human being completely.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "And we work with that thing like that.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "We cannot-- The second one was [?",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "Frau-- ?] first name was Dora Fawlowski.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "A lady.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "The second one was also a lady.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "A lady, she was-- what do you call?",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She used to take, you know, the people, take a iron brush and take the chemicals that you washed the-- the-- the-- the ammunition, you wash in a special solution.",
      "word_count": 34
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They're so terrible, bad, that when you work only with it, the fumes makes you sick, makes you have the whole hand sick with rash, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And they-- she used to wash them, take them naked, in front of everyone, wash those people.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The-- our-- our inmates, they washed it.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish people were there.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Was.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Men, men.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "They worked there at the ammunition factory, with ammunition, with everything, they worked there.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "This was the people who were in the-- in the barracks already.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "She used to come to control everything, go around.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "One was having a prayer book with him.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "He was-- during the-- our lunch hour, during he was praying.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And she took him out.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "And they shot them.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "He was praying to God against the German.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "All of us were there.",
      "word_count": 5
    }
  ],
