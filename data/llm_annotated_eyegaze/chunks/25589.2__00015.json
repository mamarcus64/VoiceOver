  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And I come to stories-- I'll tell you later-- because I was never scared for the simple reason you can't sidetrack-- step something if it's coming to you.",
      "word_count": 28
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "You can-- and we-- that's why I said-- and we have this from my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "My mother was never scared.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "Don't ever-- even when we were children, she said, don't ever be scared of anything.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "Tell the truth.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "Behave like a good kid.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "And the truth you can repeat all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 14,
      "text": "A lie you can't, a lie you can never say twice because it's always a different story.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "The story I'm telling you now, I can repeat 10 times, every time till I'm 95.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "I'm going to live till I'm 95, at least I want to.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
