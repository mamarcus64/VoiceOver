{
  "stem": "2533.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And she told me not to go home anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "You won't find anybody, and it will be very hard for you to get out.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And we'll see what we can do to get away, to migrate somebody.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And then I went back to the administration.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I said, now I've got a witness, somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And then they helped me to change over when I got married.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "The name-- I had both names on my birth certificate, because I didn't have anything with a photo.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And my working, it was like a passport, the working book, with a photo with stamps.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "So I had both my names, because they needed something to go by if I am that person.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "So that's when she went away to the United States because she had uncles there.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, I was-- oh, yes, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "She came back.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "She came back then.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And she went to Stuttgart.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And from there, she migrated to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes, because Wetzlar was not-- it wasn't finished then, but there was transports coming from Russia.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "They were a lot of-- from Russia, Jews were coming.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "It was transferred to a Jewish camp, but I stayed on there because I was sick between that, and I had to-- Andrew was a year old.",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I had to go to have a kidney removed.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And instead to stay a few weeks, it took me five months to get on my feet because I had an infection.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "They didn't have any penicillin, so the American army tried to get it from Geneva, and the clinic got some penicillin.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And then I got through and I was five months in hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And I had more German blood than my own, because I had to have a lot of transfusions.",
      "word_count": 18
    }
  ],
