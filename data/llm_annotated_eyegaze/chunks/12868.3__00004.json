{
  "stem": "12868.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "They found out he's there, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And they put a-- a bomb, something like this, you know, gas.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And they kill a lot of people.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "But they got bunkers, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Some of them in the ghetto, they tried to make some-- let's say they make double walls.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "They took some children, little children, when they're putting in double walls.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "But a child, you could not keep up not crying.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "People kill their own children before they going to kill them.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "One brother-- got him.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My brother there, what he hanged himself.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He didn't go to the action, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He didn't come with my father and brother.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "But they killed him in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He was in a bunker.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The middle one, Mottel.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see them do this.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "But the rest of them got out alive.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We know he's in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I know that he's in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "But after the liberation, he not founded.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] the last one, the little one.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But they became 13 years.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Me, I used to.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I sang-- I sang because I was hungry.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I sang.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] People listened to me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They became-- they forget about they are hungry, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They said to me, I am-- I am-- I am the doctor, what-- making everybody to be-- to stay alive.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I tell them jokes, everything I can.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I davened, we were-- I prayed for him, Yom Kippur.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Whenver-- it was Yom Kippur everyday there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "But the same day for Yom Kippur is I used to-- I used daven for them, you know, the prayers, you know, Yom Kippur, prayers.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And everybody after me, you know, we forgot about-- about the hunger.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I-- any kind of songs, I sing.",
      "word_count": 7
    }
  ],
