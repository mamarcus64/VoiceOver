{
  "stem": "8002.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they took us to a place in the camp, but in back of the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And there was a lot of children [PAUSES FOR 3 SECONDS] dead, laying.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And they told us to cut off the limbs, cut off the arms, the legs, and put-- to put the stuff in a big barrel.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "There was about four barrels, five barrels.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And we had to put it in.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And then we had to put some kind of a chemical.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We didn't know what chemical it was.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "Every time we put in the limbs, we had to put in the chemical.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "Like, I guess it shouldn't smell, or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And then I says to one of the guards, what are we doing with this?",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He says, we're sending it to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They're making soap.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Were you wearing gloves or a mask?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "No mask.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "No gloves.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "It had a terrible smell, but we had to endure it.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And the next day, there were a lot of women.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And they gave us big shears.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And each one of us had to cut the women's hair off and put it also in-- in big baskets, the hair.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "So we had to take all the women's, their hair, cut off.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And then we saw another site.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "There was a lot of dead women.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And the German says, cut the breast off.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And they put it in another barrel and put some other stuff.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "We had to put it on.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And he called us in.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And he told us to swear that, if we ever say anything or tell anybody, we're going to wind up the same like these people wind up.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "We had to have a secrecy.",
      "word_count": 6
    }
  ],
