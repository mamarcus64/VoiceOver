  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So I was sitting at the table so I didn't want to-- the blood was coming out, a little discharge, so I put a cap on.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "My boss tells me, he says, Bruno, [SPEAKING GERMAN].",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "You look like a Jew with a cap.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I said, but you only know what's underneath that cap.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So I made a-- I smiled and that-- I said, don't worry.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I can't sit like this any-- Anyway, that was the end.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "So you stop now?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "We'll stop now.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
