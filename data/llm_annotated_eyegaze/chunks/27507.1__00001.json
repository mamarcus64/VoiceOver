  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And there was practically [PAUSES FOR 4 SECONDS] all our friends and so on-- all the friends of my parents rather-- were belonged to this section of the Jewish community in Warsaw, which one would call intelligentsia, which were basically people who were mostly professionals and who basically had not very much contact or not very much connection with the orthodox or traditional Jewish community.",
      "word_count": 65
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And my parents were-- they came from two different-- two different backgrounds.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "My father's background was the Stok family, was a much more-- much more secular family in most ways.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And they were-- they originally lived in the East of Poland, not in Warsaw but in Brzesc nad Bugiem, which is now Brest-Litovsk, which is now there is a border state between Belarus and Poland.",
      "word_count": 35
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And they had-- they were industrialists.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "They had factories-- of soap factories.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "And I am not quite sure when they were started, but sometime in the 19th century there was a firm of my grandfather and his brother-- brothers-- [POLISH] Stok.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And my grandfather then moved sometime in the late 19th century to Warsaw and had four children, among them, my father.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "He died, unfortunately, quite early, and he died before I was born in 1932.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And after he died and after one of the son-- the oldest son-- who was-- who was more or less managing the factory after him-- after he became ill and then died, he died as well.",
      "word_count": 36
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He died very young because of heart attack when he was not yet 40.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And the factory was then sold already before the war in the 1930s.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And they were-- the whole Stok family were very well off, very assimilated family, educated.",
      "word_count": 15
    }
  ],
