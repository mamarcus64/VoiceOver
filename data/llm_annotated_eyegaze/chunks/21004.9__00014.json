  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Otherwise, I know nobody is there.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "I know my brother, and I know my one brother, I know my sister, and mother and one brother, I know he was in Janov Ghetto got killed, in Janov Ghetto.",
      "word_count": 31
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "My brother, the older, David, my older brother was killed.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "From my family?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Well, from my family, I got a first cousin in Seattle, Washington.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "He was on Irish papers, when she act like Gentile.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "There was one first cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And then there was another cousin survived in Russia, and came to Israel, and to the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "A second cousin survived also in Germany, in a camp.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "She was like a [NON-ENGLISH], you know, like not Jewish, also on paper.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "So about 1, 2, 3-- like 3, 3, 1, 2, 3, and I'm the fourth.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Big family, hundreds, hundreds.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "My mother's family, very big.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "My father's family, also very big.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Uncles, and aunts, and cousins, and second cousins, very rich family.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "I got a cousin, oh, yeah, one cousin also survived in Russia, in [INAUDIBLE] with her daughter she lives.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "The daughter and the mother died.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "The daughter lived in Montreal, what I got this and another survived in Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, to her first husband, now what's happened, later on when my brother-in-law came, my brother-in-law came back from Russia.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And he said to my wife, I heard that [INAUDIBLE] is alive.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Somebody told him they saw him, you know [INAUDIBLE] is alive.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "He says, well, where is he?",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "If he would be alive, he should have come.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "But Anyway in a couple of weeks later, [INAUDIBLE] comes in.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And he say, this one here and there, you survived.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "He way, what's happened to you?",
      "word_count": 6
    }
  ],
