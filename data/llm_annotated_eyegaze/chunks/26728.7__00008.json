{
  "stem": "26728.7",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I said, well, it's kind of-- so I hung it out on the fence there by the-- by the strip, and the next day I went out there and was going to have my uniform pressed.",
      "word_count": 36
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "We had some German women that we paid them with coffee or something and they would press our uniforms for us.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And, um-- I still smell-- I said, Louis, do you smell this?",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He said, no, I don't smell-- it doesn't even smell like carbon tet, because it evaporates.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And when you've been inside of a dry cleaners, you can-- there's a certain chemical odor.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Well, there was a faint odor of that.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "But anyhow, I said, the hell with it.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Get me some-- get me some 100-octane gasoline.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I said, I'm going to burn this shit.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "He says, your boots?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I said, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So I took all this, the-- the flight suit, my pinks, my belt, my socks, my underwear, everything that had been in this carbon tet, and I put it all in a pile and poured gasoline on it and threw a match on it and burned it.",
      "word_count": 47
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And, OK, that takes care of that.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I'm not going to smell that again.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But I still smelled it.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And Louis says, boy, I don't know about you.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "His name was Louis Nardini.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He lives in Pittsburgh.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I talk to him on the phone all the time.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Little Italian guy.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "He said, I don't know about you, Lieutenant.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And he said-- and he smoked cigars.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Smoke one of these stogies and whatever is wrong, that will fix you right up.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And I couldn't stand those damn cigars.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I went--",
      "word_count": 2
    }
  ],
