{
  "stem": "1363.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "We took gold or sheets to the country, what the country people didn't have, and they gave us food.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "So, we took food back to Budapest, and we fed those two, Grandma and my little niece.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And we gave-- we brought the food back, so they got a bit better and they built their strength up physically.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And the rest of the family who lived in that house in [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And that's how we survived eventually.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I met, then, after, a young man.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "He courted me.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "We got married.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] And we came to Australia in 1947.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I left Hungary in December, '47.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "Arrived in Sydney in January, '48, and was married for another two years.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So, altogether, my first marriage lasted three years, when I realized that my husband wasn't a worker.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He didn't want to build up a future.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He's just sort of a good-looking bludger.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And we separated, eventually divorced, and then for 10 years after, I didn't-- 12 years after, I didn't have any marriages.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And-- had a relationship for six years.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And then, eventually, I married the second time, who is the father of my two children.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And that marriage lasted for 10 years.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And I'm very happy, in spite of having a divorce in my hand again.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But I'm happy that I had the two children.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "In a way, that was what I lived for.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I wanted to have children, of course, under different circumstances, but c'est la vie.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not as much the experiences.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I did feel a bit of antisemitism.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And anti-- not even antisemitism as much, but anti-foreignism, reffos.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We were refugees, reffos.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "There was a stigma to us.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "There was a name given to us who survived the war, and we came and invaded Australia.",
      "word_count": 17
    }
  ],
