{
  "stem": "26022.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Lisbeth Kornreich, L-I-S-B-E-T-H K-O-R-N-R-E-I-C-H.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name is Modley.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I just retained the M as a middle initial-- M-O-D-L-E-Y.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Lisbeth Ida Modley, Ida after my late grandmother on my father's side.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I-D-A-- Lisbeth, L-I-S-B-E-T-H I-D-A and then M-O-D-L-Y",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't, except that the short version for Lisbeth from where I, where I come from is Liesl.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I spell that L-I-E-S-L.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "But you can-- some Liesls spell it without the E or any other way.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "This is the way I spell it.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born May 14, 1914.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I will be 84 in a couple of months.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Vienna, V-I-E-N-N-A, in Austria, A-U-S-T-R-I-A.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was an only child.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And I was my grandfather's first grandchild.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "When I say grandfather, that means I never knew my grandmothers.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "One died a few months before my birth, the other one a few months after my birth.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And my paternal grandfather had died before my father was an adult.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "So I had one doting grandpa.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "My mother was his favorite.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And I was, of course, spoiled.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And I enjoyed that.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] We lived in a fairly small apartment, by the standards that we later were able to reach.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And, as I said, there were no other children.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "My mother's two sisters, my aunts, were just wonderful.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "The war broke out, as you might remember, in August, 1914. 1915, my father was drafted.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And so I grew-- I remember my early childhood without men around because we didn't talk to strangers.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "There were very few men in the family.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "It was a small family.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "So it was my grandpa, my mother, and my two aunts.",
      "word_count": 11
    }
  ],
