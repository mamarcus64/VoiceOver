  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "How it will be?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "No, maybe 10 minutes, 15 minutes, you're tired and you sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And then, we get up and run again.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Was Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Stupak with you through all of this?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Was he--",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He-- that's what I-- they brought him from the other side.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He stay-- if you bring the food and he stay in one place.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Then, when we come out from the ground, he come out, too.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "He didn't move at all.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "He didn't move from the place.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He was staying in one place for that when we make the hole, he was standing.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Then, when it was the water, we make him another place--",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "--in forest, not everywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And we was asking some people to make us some medicines.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "With no medicine.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
