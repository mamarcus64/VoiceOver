{
  "stem": "9215.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "And it was black.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "Who knows how long he was lying there dead?",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And my husband cut out a piece of meat.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "He said come, we're going to cook a piece of meat.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I said, I wouldn't eat this meat!",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "It's black!",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Look!",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "He said, you will, you will, you will.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "You hungry.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And we start cooking the piece of meat.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And the water was black and with-- with the fresh water, this and that.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And we ate.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "We ate.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "You know something?",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Believe me or not, we ate the whole horse over the winter!",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "Yes, I eat.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And another thing I'll tell you, I forgot to tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We knew the-- a-- a lady, a old lady.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "She got a pig.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And she cook for the pig big potatoes.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "She cooked.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "She didn't cut or nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "She was an old lady.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "She put potatoes with the peels, and she gave the pig.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "My husband saw.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "He said, come on.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "We'll go there.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "She gave, every night, the pig potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "And we went in that-- the pig, where the pig was.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 13,
      "text": "And I had a little sack.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 14,
      "text": "And my husband hold the pig.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 15,
      "text": "And I took all the potatoes, and we run away to the woods.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 16,
      "text": "We took from the pig-- from the pig's mouth!",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 17,
      "text": "[LAUGHS] Believe me or not!",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 18,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I used to tell my friend, I used to eat from the pig's mouth.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "She said, how?",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I told her how.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "I said, my husband hold the pig, and I took the potatoes, and we run away.",
      "word_count": 16
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "We got a few days to eat potatoes, cooked potatoes, with the peels, for the pigs.",
      "word_count": 16
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We ate from the pig.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We ate a-- a dead horse, everything, OK, until 1944, two years.",
      "word_count": 12
    }
  ],
