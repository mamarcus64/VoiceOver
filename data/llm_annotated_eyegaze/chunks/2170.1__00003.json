{
  "stem": "2170.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And a German officer came out, and he, he made a speech right away about the Jews.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "If the Jews not going to resist and not going to do anything, if you're going to be quiet, if you're going to let us leave you alone, and we will not shot nobody.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "That was the first that he gave the order.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "A week later, before Yom Kippur, actually, the Polish Army attacked the Germans in the town again, a counterattack.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And we run out of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We run away because we knew that there was going to be established a front zone around there because the Polish surrounded the Germans.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So we run away in the morning, the whole family.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "There were other Jewish people in our town, which came in already from west of Poland, running towards the Russians' borders, or whatever.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And they all run with us.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And as we came in into-- we were surrounded by mountains, around small mountains.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And we laid down there to be able to save our life to run away from the town, which was only a mile away.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And that-- we stayed there a whole day.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And then we heard already shooting.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans came very close.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "As they came close, it was at night.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And we heard the shooting right on top on us.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "We were under the mountain.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And they were on top of us already, the German regular army.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And we-- right away, at that time, we saw the city burning, the whole city afire.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "It was like Rome was burning.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "The whole city was in flames.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And we glad that we run away.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "We stayed on that mountain for two days.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "At, at, at the bottom-- on the bottom.",
      "word_count": 8
    }
  ],
