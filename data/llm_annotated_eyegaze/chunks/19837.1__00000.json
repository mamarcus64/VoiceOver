{
  "stem": "19837.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 125.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Gerda Haas.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "H-A-A-S.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My first name is spelled G-E-R-D-A.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name was Gerda Buchheim.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "B-U-C-H-H-E-I-M.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is April 11, and I was born in 1914.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Berlin, Germany.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My age at this taping is 82.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Sounds terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "It was just fine.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It was like people live here as Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "There we were accepted by everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We had a kosher butcher shop, so we had to do, only, really, business-- no, I mean in the store, with Jewish people, we had kosher meat.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But we mingled with just everybody else, and in the school, there wasn't any difference.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And the public schools had religion there, so we went to the Jewish religion as ours, and Christians or-- went to theirs.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "There wasn't any problem.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "We lived in an apartment house.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "We knew everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "There were three, four, five Jewish families, maybe 50 non-Jewish ones.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "When they had Christmas, we helped them celebrate.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "They came to our Hanukkah, and it was fine.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father was a six foot tall man who worked around the clock, and all my parents wanted, both of them, that we children make something more out of-- more schooling than what they had.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father, especially, [BACKROUND NOISE] had to quit school when he was 12 years old and learned the butcher trade, because there were too many children in the family, and the house-- they didn't re-model their house like they do here and build on.",
      "word_count": 44
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The oldest, or the older people, have to go.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Meyer Buchheim, but in Berlin, he was called Max.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But his real name is Meyer.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "M-E-Y-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He was born April 7, 1884.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In a little town called Rosenthal.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was in Hessen.",
      "word_count": 4
    }
  ],
