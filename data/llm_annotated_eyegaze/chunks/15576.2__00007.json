{
  "stem": "15576.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And I didn't know what-- what's happening.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And I was afraid to leave the cows and go back.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And Gestapo even came to the words with the Ukrainians, and they passed me by.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Did you see any Jews?",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I was dressed up like a-- no.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "A peasant.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And they-- they let me go.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And then at-- at night, the shooting stopped.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And I went down.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "My mother and younger brother were always hiding in one place.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And I would hide in another place.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "So if they catch one of us, one of us will remain.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I came home and I knew where mother should be in the-- and, thank God, they didn't take her that time.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "They were in hiding [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Floor., ?] But we walked the streets.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "You saw dead bodies all-- all over.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "You saw the Ukrainians carrying stuff.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Loot.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And then I spoke-- then I spoke to some-- I don't remember.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I said, yeah, it happened to me.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And not to this one.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "No, this one didn't happen.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "I got-- I was afraid to go back to it as peasant.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And my uncle had connection.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "He got me another job as a cowherd for a little old lady, a little old lady, who was guarding that cow like she would be her-- her only possession.",
      "word_count": 30
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And I didn't like the way her son-in-law behaved.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And I was afraid that, one day, he'll just get tired of me, and-- You know, let me tell you about the first aktion, too.",
      "word_count": 25
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "They didn't take you to concentration camps for my part of Europe.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "They took you behind the cemetery.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "There's already a big grave.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "And I know, I keep mixing myself with two things I don't remember for sure.",
      "word_count": 15
    }
  ],
