{
  "stem": "20684.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "But if it's small-- rabbits, rice, and mice, rats, any of those things you can eat.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "You grab the meat and quietly.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "You don't cook anything because if you cook, you show the smoke comes up.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There's no cooking, we eat raw.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "When they bring-- bring from the village, they bring that were cooked.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "The peasant families and so on used to cook meat for us or whatever soup they would carry in parcels.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't cook.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "You cannot cook in the forest.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "You eat what you eat.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "What you catch, you eat.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I mean, you supplement yourself, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Especially in summer and spring, you get lots of things that are growing-- the flowers and grass and things like that.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Even when the bark is the only thing that you can eat if you're hungry, besides the food that you get.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "But it's not all that exciting.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I-- I-- I never got to like bark.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "I like the greenery or whatever I catch.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "It was OK.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "Butterflies, you know, flies, [INAUDIBLE] they were OK, an occasional rat or mice.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "But-- but the others, I wasn't good enough to catch rabbits.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "They were too quick for me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "The others used to set traps and used to catch rabbits and slice them up, dry them up, or take them to the village to cook.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "I don't know what they did with them.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "Anyhow, we'd get him back.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "But bark was never any good.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "I never got to like the bark.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "I used to-- I had my handkerchiefs.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "I had lots of things-- things that-- I ate threads.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "I used to get very hungry, I used to eat-- chew away at whatever I was wearing and then get something new when the-- when the occasion came.",
      "word_count": 28
    }
  ],
