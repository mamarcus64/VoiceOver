{
  "stem": "2946.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And Max told her, I have a friend in Theresienstadt who is in the Jewish government.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "His name is Dr.-- he was a lawyer; in the old country, lawyers are called doctors-- Dr.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Pauper.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Egan Pauper.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Egan Pauper.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "He said, when you get to Theresienstadt, find him, and he will help you there.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Lo and behold, in the train station, Hilda was walking with the man who didn't have a badge, and she called me over, Albert, come over here.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "This is Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Pauper.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Remember Max told us about him?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And this Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Pauper said, well, I'm in the Jewish government here, and I'll take your number.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "He wrote down my number.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And out of 1,000 people, about 500 were next day, next morning taking another train, and taken to the east.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "If you didn't know what east means, that was Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what it means.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "They told us labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Just labor.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And I was still in the old place-- in the old station-- and a man came to me and said, I am a policeman.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I was sent from Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Pauper to take you to the government office.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "So I got out with this policeman, and I was taken to a barracks with 30 people.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I-- I think this-- I was already in the barracks, and this man came to talk to me.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "He said, I have to take you to Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Pauper.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "I came to Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Pauper-- because the gendarmes and the Germans were at the-- at the gates, so we couldn't get out.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "But this man had a-- a piece of paper from the Jewish government for Dr.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "Pauper to let us out.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "He took me to Egan-- the Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "Pauper.",
      "word_count": 1
    }
  ],
