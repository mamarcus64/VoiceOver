{
  "stem": "3361.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She made that small bundle for me to help her carry because I couldn't carry.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I have a bundle.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And-- but I wanted help every time my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And it was hard life, very hard life.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "But we got-- we, we are used to it like this, and we finished.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "We thought it should be.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And when my sister got married, she moved to another city with her husband, and her mother was living with her.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "The mother was stealing grains from my-- from her son and bringing that grains to her daughter.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And I saw that, and I didn't want to make a fight between my sister and her husband/ so I went and I told my brother-in-law that-- what she is doing.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "He slapped me and threw me out from the house.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And I, I, I didn't have there go so I went to Cracow that time.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "11 Years old.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "By myself.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I went on a horse and wagon, what they brought eggs, and chickens, and gooses to Cracow to sell.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So I went on that wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We went two, two nights and one day.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We were driving to Cracow from that city.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "They were trying to make a work.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "My oldest brother and the next to oldest brother, they were also dealing with grains, buying from the [INAUDIBLE] and selling to the-- to a big company the grain.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they make the flour from the grains, you know, and everything else.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They were all doing that.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "They all help.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They put in the-- little bit help that should be able to work.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "When my sister got married, I left to-- I left with her.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I went with her to Wieliczka.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And they but help me with their mother-in-law still.",
      "word_count": 9
    }
  ],
