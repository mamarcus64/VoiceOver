    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They were killing them.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "This is the first time and the last time, never went out by themselves.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And this was only once.",
