{
  "stem": "22972.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My full name is Ellen Brandt.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "E-L-L-E-N B-R-A-N-D-T.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Ellen Ruth Friedsam.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Want me to spell the last name?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Ellen Ruth, I think is OK.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "F-R-I-E-D-S-A-M.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "May 10, 1922.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Place of birth is Mannheim, Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "74.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was born in a hospital in Mannheim, because the hospital in the town where my mother came from, Landau, where my parents resided at the time, wasn't good enough for my grandfather.",
      "word_count": 34
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So I was born in Mannheim.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was there for two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We moved to Munich when I was six months old.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My father had bought a factory, a paper factory.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And I lived in Munich until the first of January, 1933, when we moved to Berlin.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My father saw the handwriting on the wall, and we moved to Berlin.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was an upscale neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I had my own-- not nanny.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I had my own nanny.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I was an only child.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My mother was deemed too old to have another child.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I had a very comfortable life.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I-- my father was very, very strict.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I was not a spoiled single child.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I decided I wanted to be an actress when I was about five years old.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "I made all the neighborhood children act in plays with me, and wrote my first play when I was six.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And charged the parents five pfennig to attend all these little plays.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And I think there's one interesting story that I should tell.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I had a very, very proverbial rich uncle in America, my grandmother's brother.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "We were then living in a building.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "My grandparents had moved to Munich because both their daughters were married and lived in Munich.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And the proverbial rich uncle from America came with his entourage.",
      "word_count": 11
    }
  ],
