{
  "stem": "17543.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 90.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Thank.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My married name is Clare Parker, which is P-A-R-K-E-R.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And my maiden name was Klara Hochhauser, which is H-O-C double H-A-U-S-E-R.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It was Klara in Hungary.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It's K-L-A-R-A.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this 1st of January-- is 13th of January, 1932.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So I'm 64 now.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Budapest, Hungary.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I only remember when things start change from, [SOBBING] from normal [CRYING] to different way of life.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Like my father was taken to-- on and off to forced labor, which one was before I was 11.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And where we lived is outskirt of Budapest, is Pestszenterzsebet.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And that town is a suburb of Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We lived in a house, which was several flats in a courtyard.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And, and business my father had there.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "That was there was polishing metals, like skates and cutleries and things like that, came raw material, [INAUDIBLE] shining.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I think was chrome and nickel.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] eventually had to close it down, because he was going away more longer period of time.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He had to wear a yellow armband.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I would still go to school [SOBBING] in the school where I was the, the only Jewish child.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I, [SOBBING] I had to go out from the classroom when was-- everybody was Catholic.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "You know Hungary a Catholic country.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "A priest came with a long, black frock and told me I have to go out to the corridor for an hour until they learn religion.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And [PAUSES FOR 3 SECONDS] eventually I have been thrown stone at me.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They-- yeah, children.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They laughed at me when I was in school.",
      "word_count": 9
    }
  ],
