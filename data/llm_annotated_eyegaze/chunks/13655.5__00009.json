{
  "stem": "13655.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 16,
      "text": "In the morning, I'll come out, And I'm going to call the dog's name.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 17,
      "text": "Then you come out.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And there is a cemetery-- prisoners, Russian prisoners, was killed there-- about six, seven.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "The bones is all around.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "There were Jews-- the Polish people were afraid to go there.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Then you got to make a bunker and stay there.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "This is what we did.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "We took out the people from the woods, go back in the other forest, and we made--",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "The cemetery was from bones, was [INAUDIBLE] skeletons, from the people.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "We made it.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "We made it-- me and a few of them.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "We did this.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And there we were sitting.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "But we was not enough.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "We made maybe 10 more bunkers.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "If this was [? built ?] up, then we go to the other one.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And this was-- we're sitting from June 16 or July 16 till July the 30th, 1944.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Not in the same area.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "It was the wider sections-- other sections.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Around Konstantynow.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The woods-- the way-- the woods neighborhood was called [?",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Walima-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Walima. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "We got a few-- [INAUDIBLE], but he was baking bread in night time, we should pick up.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We paid him.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And potatoes, we were stealing.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Water we had to steal.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "We had to go far, far for water.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "We were about 60 people-- and 50.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And six people got killed nine days before the liberation.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "One man--",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] got killed-- the [?",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "AK ?] was in the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "The code word.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] .",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And they caught one guy there, and they took him to the other place, to show where the other one, and they killed him-- six people.",
      "word_count": 26
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And one guy, he was twice in Treblinka.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "He struggled to go out into the [NON-ENGLISH].",
      "word_count": 8
    }
  ],
