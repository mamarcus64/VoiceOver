{
  "stem": "18294.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "This was the first place, where there was buried my mother and his mother.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And the couples went with us together.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "The two couples, what-- they was interested to see everything.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And there was in the Ponary there was written there was buried here 100,000 Russian citizens.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "There was nothing about Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "The second time when I come to Vilna, there was no Russia anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "There is a big monument was written that here was buried 75,000 Vilna Jewish people.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "In the town, I found my place where-- where I was living, his not.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "His place is ruined.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "It's-- It's different.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Because it's every-- every street you're going, you-- you were brought up there all your life, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And you can't dare, you don't find nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "It's nothing there.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "It's just an emptiness there, just empty.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "It's painful, very painful to go there.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "The second time when I went to Vilna, I-- I go into my home where I was living.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And there was a Russian woman, a Russian family lived there.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And I opened the door, and I said, can I go in?",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "I was living here with my mother, and father, and brother, and sister.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And she-- she said, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Come in.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "I went in.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "Suddenly, I couldn't recognize the place.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "But it was hurting, this was very hurt.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "I left her $10, American $10.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "Oh, she didn't know what to do with us.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "You want a cup of tea?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "Because the wages was $20 a month.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "And she-- she said-- she was so-- so really friendly.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "And then I went to the place what I was learning, to my school.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "When-- when we had the business there, there is nothing there, nothing there.",
      "word_count": 13
    }
  ],
