{
  "stem": "21437.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "And then they-- next, they took Lilka into-- on the left, there, into that place, into that little-- whatever that was-- a little pantry or whatever-- like, a little room it was there.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "And they said to us-- [PAUSES FOR 3 SECONDS] --no sound.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "If we hear one sound, if we hear a cry, or a yell, or anything, she is going-- she is going to be no Lilka no more-- not a sound from you.",
      "word_count": 32
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "And then next we heard-- the-- the sounds of her being beaten.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "And they kept saying, tell us.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 39,
      "text": "We know that your father-- or we know that things are come-- your father was very wealthy-- your parents were very wealthy.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 40,
      "text": "We know that there is extras here.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 41,
      "text": "We want to know where it's coming from.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 42,
      "text": "You-- you know.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 43,
      "text": "Tell us.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 44,
      "text": "And she kept whimpering.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 45,
      "text": "She kept saying, I don't know anything.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 46,
      "text": "I'm starving.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 47,
      "text": "I'm just a child.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 48,
      "text": "I don't remember even from home.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 49,
      "text": "We don't have anything.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 50,
      "text": "Please let me be.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 51,
      "text": "I don't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 52,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 53,
      "text": "She kept repeating again and again while she was beaten.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 54,
      "text": "And we couldn't do a thing.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 55,
      "text": "After a long, long time-- [PAUSES FOR 4 SECONDS] --the door opened.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 56,
      "text": "I don't know how many hours it was.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 57,
      "text": "Maybe it wasn't hours.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 58,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 59,
      "text": "But it was hours, but I don't know how many.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 60,
      "text": "[SIGHS] They threw her on the ground, and they left without a backward glance-- without a backward glance.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 61,
      "text": "For the next two weeks-- I mean-- that they didn't kill her, that she survived, I really don't know how.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 62,
      "text": "For the next two weeks, all I remember is watching her.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 63,
      "text": "And I looked at her.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 64,
      "text": "And I watched her.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 65,
      "text": "And I looked at her.",
      "word_count": 5
    }
  ],
