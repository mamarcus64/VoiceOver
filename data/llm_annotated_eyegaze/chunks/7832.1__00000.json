{
  "stem": "7832.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Irene Zisblatt, and my maiden name is Irene Zeigelstein.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It's spelled Z-E-I-G-E-L-S-T-E-I-N.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I was born December 28, 1930, in a small town in the Carpathian Mountains called Poleno.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "It's spelled P-O-L-E-N-O.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Rochel, and my father's name was Moshe.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My mother's maiden name was Rochel Merlmestin.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "That's M-E-R-L-S-T-I-N-- L-M-E-S-T-I-N.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I had-- we were six-- one sister and four brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My-- my oldest brother-- I was the oldest in the family, and my older brother after me, his name was Mendel, and he 11 years old.",
      "word_count": 30
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He was two years younger than me.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Then I had a brother named Meyer, and he was two years younger than my oldest brother.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Then I had a brother, David.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And he was about four years younger than my second brother.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Then I had a sister, and she was about two years younger than David.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And then I had another brother-- two and a half-- and he was about a year and a half or two years younger than my sister.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And her name was Hindu.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And my youngest brother's name was Luzer.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My life was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We were bought up very orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "My grandparents were alive most of my growing up life.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We were together a lot, and they taught us a lot.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I went to public school, and I went to Jewish school, which we called the cheder.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "We had one temple in town, where all the Jews went to the same temple.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "We were orthodox.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Everybody was orthodox, so the men and women were separated during services.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] There were about, I would say, about 60 or 70 Jewish families in town.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "So we were all very close.",
      "word_count": 6
    }
  ],
