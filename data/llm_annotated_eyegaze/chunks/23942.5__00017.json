  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 30,
      "text": "But she didn't say, you can sleep in my house or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 31,
      "text": "But the father must have gone.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 32,
      "text": "The husband must have-- he must have wrote-- he must have wrote a letter to his sister in America, and the letter appeared in 1945.",
      "word_count": 25
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 33,
      "text": "The early part of '45.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 34,
      "text": "I have the-- the article.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 35,
      "text": "The whole page that it appeared.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 36,
      "text": "The paragraph appeared about me in the paper when the war was still going on in Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 37,
      "text": "And he wrote to his sister.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 38,
      "text": "In those days, people wrote already when the war was-- as soon as the war was ended in a part of Poland, somehow they managed to get it, either through the [NON-ENGLISH] or another way, and they sent it to America, and it appeared in the paper, in the forewords in the Jewish paper.",
      "word_count": 54
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 39,
      "text": "They were searching people from their own relatives, if they had relatives in New York or any place in America.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 40,
      "text": "And that article about me, the paragraph, appeared in the page where people were searching for their relatives.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
