  "sentences_input": [
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 11,
      "text": "And you start again to deal with him but as a different name already.",
      "word_count": 14
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 12,
      "text": "They didn't want-- they did have documents like pieces of paper, different names every day in case something happened and the Germans looked for someone, they look for man which is--",
      "word_count": 31
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "--the previous name, not the name-- so I had been very, very careful there.",
      "word_count": 14
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "You could buy--",
      "word_count": 3
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 1,
      "text": "You could pay up front, to pay them front, and pick up the goods next day.",
      "word_count": 16
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "That was accepted by them.",
      "word_count": 5
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 1,
      "text": "Another thing is there, which is--",
      "word_count": 6
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "The machine guns, guns, ammunition, everything.",
      "word_count": 6
    }
  ],
