  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "Later on, in 1942, in May of '42, an informer, a, a chimney sweeper who was an informer for the Germans-- because he traveled to the villages, he knew what was going on-- informed on, on my father that he was slaughtering non-kosher meat.",
      "word_count": 44
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "They caught the man who was distributing the meat in the villages.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "They brought him to our house.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "They shot him in front of the house.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "I grabbed my father through the house.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "We ran down the hill to the Vistula River.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "I knew a friend of mine had a boat parked, a little wooden boat.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "And I put my father in the boat.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And there were no oars.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "There was just a long stick that you maneuvered the boat across the river.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "And I took my father across the Vistula River.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "And I hid him in the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "And I returned back to the town to confer with my mother what we should do.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "And the decision was made that we have to get out of town.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 39,
      "text": "My mother was not in the house at that time, so she was able to stay with some friends.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 40,
      "text": "OK, we'll have to stop there--",
      "word_count": 6
    }
  ],
