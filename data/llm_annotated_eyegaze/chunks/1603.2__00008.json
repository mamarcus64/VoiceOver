  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Now, he-- his looks were 100% non-Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And he spoke fluent Serbian and Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He spoke pretty good German.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And actually, he worked for the underground.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But for the underground, he was involved with the Arrow Cross Party.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "So that he was a spy for the underground.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "So he-- the underground in Hungary was informed as what's the next move of the Nazis, the Hungarian Nazis.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And he asked me, where is your sister and mother?",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So I told him.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And he didn't say anything to me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And then we said goodbye.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "But later on I found out that next morning, he went up to this place where my sister was staying.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And what happened was [PAUSES FOR 8 SECONDS] he went up and found my sister and my mother and-- [PAUSES FOR 5 SECONDS] and brought them down from this place where-- where the nuns were because he knew that Arrow Cross people will go out and execute everybody the next day.",
      "word_count": 51
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And that's how my sister and mother survived that.",
      "word_count": 9
    }
  ],
