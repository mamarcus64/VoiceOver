  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I was worried that I might meet the snake.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] You know?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And the mice-- the little field mice.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We had some cookies, and they were stealing it from us, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "It's-- it was-- you you know, we were exposed to the elements.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "But I think that if I wouldn't have worked, I would have gotten nuts there, not to do anything.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And my poor mother was cooking.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You know, we had two beds there.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And then we had a little box that we transformed it for a cooking table, you know, a wooden box.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And then we had a-- an oil something-- gas, oil lamp.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "My mother was-- very primitive.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "We had a very, very primitive life.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And after we came back, we came in very primitive, also, transportation.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And we always-- we always had cargo ships, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We never had an elegant thing.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "But it was very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "It was a hard year in Cyprus, especially being pregnant.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And, you know, it was not easy.",
      "word_count": 7
    }
  ],
