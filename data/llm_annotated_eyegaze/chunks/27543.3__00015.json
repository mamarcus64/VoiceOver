  "sentences_input": [
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "He's a year and two months younger what he is.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "This was taken in 1955.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "In-- in the house.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "In Boston, Brookline.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "On Harvard Street, 406 Harvard--",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "406 Harvard Street.",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "This is my cousin, only live relative I got left over.",
      "word_count": 11
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "The whole family got killed.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "Her name is Susan.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "What's her Jewish name?",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "I don't even know.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I don't even know her last Jewish name.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Her name is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "It was originally [INAUDIBLE], but it come from Hungary, from [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "This was taken 10 years ago, exactly.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "That was in Israel, right on Lebanon-- oh, right on the Lebanon border, in Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "This is my son, Steven.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "This was taken on the Lebanon Jordan River, but 10 years ago too.",
      "word_count": 13
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And that's me.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "He's a doctor.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "He's 6' 3'.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    }
