{
  "stem": "1901.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 593.0,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Still there.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Very good quality after so many years.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] And-- and then we start-- and then you speak to the-- to the-- well, everything is done by the-- by the-- the [INAUDIBLE], you know, the-- the-- how do you call it?",
      "word_count": 33
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The camp, the Jewish camp who would work.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "They did all the work-- the doctors, everything was Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "Well, mainly Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And they start telling you, oh, you got six-- six weeks to live.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Then we knew.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "[GERMAN] is here.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "[GERMAN].",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "That's where we're going.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Up there.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And then the smell, already it start immediately.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "As soon as those transports arrived, they went straight on to the-- to the gas chamber.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Unbelievable.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "It-- it-- it's so fast, you don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "You don't.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "You don't.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "You can't.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "You can't even-- even comprehend it.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "It all went that fast.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "You don't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "You got no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "Suddenly, you get all your clothes gone.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "You've got your striped clothing on.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "You're nobody.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "And you're a number.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "You don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "Frightened.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And those-- there were people were gone in-- in-- in-- in a few days.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "They-- they-- they-- There's no [? description ?] for it.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And then I-- I was in Birkenau-- you've heard the name Birkenau-- only a few days, and was selected.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And-- and all those diamonds, we were together all the time, and then they were split up all over the place.",
      "word_count": 21
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And they pick me for a camp in Monowitz.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "You've heard of Monowitz?",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "It's Buna.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "IG Farben work.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And I worked at IG Farben.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "Big camp, and I was very fortunate.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "The next day, they were hanging six men.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "Immediately.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Six-- that's normal there.",
      "word_count": 4
    }
  ],
