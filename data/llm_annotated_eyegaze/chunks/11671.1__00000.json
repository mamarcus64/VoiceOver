{
  "stem": "11671.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Penina, P-E-N-I-N-A, Weisz, W-E-I-S-Z, Bowman, B-O-W-M-A-N.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "At birth, it was Pszi, P-S-Z-I, Weisz.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I also have-- I was also named in Hungarian Piroska, in Romanian Paraskiva, and then Piri for short for, for Piroska, Pszi in Yiddish, and then Penina in Hebrew, and Penny in English.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born April 19, 1927.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Today is 68.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cluj, Romania.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I had two sisters and one brother.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The oldest was Yaffa.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "She was born in 1923.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "She's, she's 70-something. 1923, she was born in '23.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "My brother, Mordechai, was born in 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I was born in 1927.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And my youngest sister, Miriam, was born in 1929.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Mother and father, and we were all born in Cluj, Romania.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We were raised very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We were extreme Orthodox.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My father was a ritual bath owner.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "They called it a mikvah.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And we, we had to be an example in the community because-- we had to observe all the laws, and we were raised very religious.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We observed all the holidays.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Passover, we had separate dishes.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And us girls were not allowed to wear short sleeves.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We used to cheat and roll them up when we were away from the house.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And we were not allowed to wear bobby socks.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "We had to wear long stockings.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "On the Sabbath, we were, we were not allowed to tear paper or use money or walk too far.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And of course, we were extreme kosher, only kosher food.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And we went to Jewish schools.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And we were not allowed to date.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "We cheated with that.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "We were not allowed to be Zionists.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Religious Jews were not allowed to be Zionists.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They were supposed to wait for the Messiah to come.",
      "word_count": 10
    }
  ],
