{
  "stem": "18258.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 154.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "I got my first fountain pen, which was standard present for the bar mitzvah boy.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "The fountain pen.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "We got the first fountain pen from our bar mitzvah.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "Of course it was liquid, with liquid ink we had to fill, and the regular writing pen, not what we have now, a ballpoint.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "That wasn't my bar mitzvah.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Pesach I didn't know until much later in life.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And just as I said, the high holidays we spent mostly with our grandmother at the grand synagogue in the center in Leopoldstadt.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "In other words, there was no Jewish life in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was much more interested and active in political life, because by the time I was 13, 14, I already had gone into the left wing, into the Social Democratic Youth Movement.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "My parents were members of the Social Democratic Party, and so the influence was given.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I was in the Social Democratic Gymnastic Club and I played-- I was active in sports, track.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I played ball with them.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Completely left-oriented and [INAUDIBLE] was 15 joined-- when I was 15 or 16, I joined the Academic Legion of the Republikanischer Schutzbund where I have the picture.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I was with them until, well, 1925 or 1926.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Active, we exercised, we marched, we got shooting instructions.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "We went out to protect [PAUSES FOR 4 SECONDS] Meetings of the socialist students, middle school, high school students.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "We wore a uniform.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I was active in [? political ?] life.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Zionist?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "When I was 11, I joined for a very few months, because it was closest to home, the Maccabi [INAUDIBLE] in our district.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But that was only for a very few months.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I left there soon and went to [NON-ENGLISH], the Social Democratic Gymnastic Club.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "That's where I spent most of my time.",
      "word_count": 8
    }
  ],
