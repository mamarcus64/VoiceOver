{
  "stem": "22889.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "Wintertime, especially, they used to keep themselves warm.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "We used to sit and drink the soda water and the hot tea.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "We used to sell, too, hot tea.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "So we had a lot of friends who used to once in a while used to bring us potatoes and the butter.",
      "word_count": 22
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "So we had a-- it wasn't so bad.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The only thing I remember was a hardship for my parents-- heat up the place.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "We had no-- we weren't allowed to purchase wood by-- from the-- from the Gentile people, or coal.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "But when I-- as long as I used to work on the railroad station, you know, I used to unload the coal.",
      "word_count": 22
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I used to always wear two pairs of pants, one inside out.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "I used to wear the knickers.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I used to always load up the pants, my pockets, the inside of the knickers, with coal.",
      "word_count": 17
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "In my jacket.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I used to bring it home.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "I could hardly walk.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "We has to bring some coal home.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "That was tough.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "No, we didn't get no mail.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "We didn't-- we didn't correspond.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Because we all were together, really, except the neighboring town where my father family was.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "So we used to hear from them.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "People used to travel once in a while.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "And that's where we used to get the news.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "--well, activities like-- for instance, sometimes on Sunday, we didn't work.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "So we used to get together.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "This was more already later on in the ghetto-- when we were in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "We used to get together, young children, like young kids.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "We were already-- we were young kids, but we were grow up already, you know, after--",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "--all of those years, you know, you become self-sufficient.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "You grow up very quick.",
      "word_count": 5
    }
  ],
