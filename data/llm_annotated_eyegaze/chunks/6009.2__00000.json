{
  "stem": "6009.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, then--",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "He said, the-- the officer, we have nothing to push to come to Dabie, because all the people in Dabie are gonna come here.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And then a couple days later, I arrived to Dabie.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I smuggled the [INAUDIBLE] through, and I went to Dabie.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I came home and I met my family.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I was home about three or four months, and then I was taken to a labor camp.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Sent away to labor camp, to Posen.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Because the other two kids were too young.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They were only 13 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And my father, I-- they told-- I don't want to-- they decided-- the-- the city, the Jewish Federation had to decide who should go and who shouldn't go.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They forced them do it.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So one from the federation by us, he said because I have to say who have to go, I'll go myself to this.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And he went.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He didn't live, though.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He was killed there in the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "So he said, listen, Leon, if-- I know you came from camp just.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "You was out a year in camp and was in the war.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "You don't supposed to go.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "But we have to put on so many people, and we have to take at least one from each family.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "If you don't want to go, your father has to go.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "So I say OK, I go.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "What was the name of the labor camp?",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "Do you remember where it was located?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Hart was the labor camp, the name of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Near Posen-- Poznan.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The condition was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We have to go up in the morning, they gave you a small piece of bread.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And you had to march 25 kilometers to the job, to the work.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And there, you have to work hard.",
      "word_count": 7
    }
  ],
