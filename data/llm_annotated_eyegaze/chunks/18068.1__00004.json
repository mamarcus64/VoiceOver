  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.7,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "When-- that's going back into history now.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, during the war.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Before the war, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "He was about two years when the war started.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Talk locally.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Too well.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Just before the war started, we had an inkling, a good idea that war's gonna breakout.",
      "word_count": 16
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And I said to my wife, I've got to do something.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I'll join the civil defense, like locally.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "If it's going to be air raids, well, I'll help.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "I went to a local town hall and enlisted.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "There was no vacancies normally, except in the casualty service.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "I said, I'll do casualty work.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "First aid.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "Started on first aid and war broke out.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "Then we were called up in the civil defense.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "How long I did it for?",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "For two years until the air raids eased up a bit, and we had to join the forces.",
      "word_count": 18
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "That's 19-- [PAUSES FOR 5 SECONDS] '42.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Would it be?",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "'41. '42, when the air raids eased up.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "First aid.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "First aid and home nursing.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "When the war started, the fur trade was finished.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Everybody fled or left the fur trade.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "It was a luxury trade, so I was in that.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And who was in charge of that civil defense?",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "Do you remember who-- who was in charge there?",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Did you wear a uniform?",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "All we wore was a-- [PAUSES FOR 3 SECONDS] well, wore a hat.",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Yes, we wore a steel helmet.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "SB, stretcher bearer.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And-- and were there a lot of casualties in that time?",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Who-- who--",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "During the war?",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "In those first two years when you were a volunteer.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "There was a lot of casualties, but actually, we weren't in the heart of the casualty area.",
      "word_count": 17
    }
  ],
