{
  "stem": "19518.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "We got a piece of German salami.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "We got a piece of margarine.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "We were put on the train 20 into a wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] There was a pail of water and a cup to drink.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "There was on the other side a pail of whatever necessity you have.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "But you know, we really used-- I mean, we were using-- the necessities weren't that big.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "We had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "So we didn't have [LAUGHS] the-- the urge.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And after two days, we arrived to Bavaria.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "Gellenau was the station.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And we were walked into a camp that-- which had only four barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "There were 500 women from Ravensbruck working already, and we were 500 from Bergen-Belsen.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "We worked-- the factory was actually in [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "It was a factory in the mountain.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "We used to take the elevators four flights down.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "Unfortunately in Bergen-Belsen typhoid was rampant, and a lot of our women had the germs in them.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 3 SECONDS] A lot of the people that came [PAUSES FOR 3 SECONDS] succumbed to typhoid.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And the German Lageralteste did not know what to do.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "That's the one that-- the-- the head of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "So he took one barrack, and he turned it into a hospital like.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "One of the women that was with us had some nurse's training years back.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "And she was the nurse on that barrack.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "And on daily basis, people were led into that barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "Because a lot of them had it, as-- including a friend of mine, who lives now in Plainfield, New Jersey.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "And she was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "And after work I used to come and bring a drop of water into her mouth, a grain of sugar to put in her mouth, sponge her around a little bit.",
      "word_count": 31
    }
  ],
