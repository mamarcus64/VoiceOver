  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "He was so attached to this camp and to his people and to the survivors, that even after the war, he still maintained his contact with survivors, whether they were in England, whether in America, or were in Israel-- so much so that when he died at the age of I think it was 80 or 90-- [PAUSES FOR 4 SECONDS] he said that-- and his last words were that if he was to-- there was to be any form of service, he would want a special prayer for the survivors of Belsen.",
      "word_count": 93
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And if I were around, would I do it?",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And the service took place at the parish church in Melbourne.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And the former assistant chaplain in general, with whom I didn't get on too well, he officiated.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And it was a very moving occasion.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And the order of service, and the little prayer I composed, I sent to Yad Vashem in Jerusalem.",
      "word_count": 18
    }
  ],
