{
  "stem": "15578.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] It was just the beating and beating, and that's all.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know where we are going, [PAUSES FOR 3 SECONDS] till we did arrive there in Blizyn.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was very bad-- very, very bad, because there were a lot of people in one car.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And the sanitary, [PAUSES FOR 3 SECONDS] unbelievable.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "You know, I personally had a need to go to the washroom and, yet, very bad.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Nothing was provided.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I think it was about five or six hours, something like this.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "It's not very far, but it took us a long time.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "The-- also the Ukrainians and Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, with my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "My older brother, Nojech.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "They were deported, and they were sent to Treblinka before.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "Some in the same and some two days before.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Like my sister Cluwa was transport-- was transported the 30th of November.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And also--",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "'43.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Oh, to Treblinka.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And so the-- and we, after-- in 1944, we were transported to Blizyn.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "When that was [PAUSES FOR 3 SECONDS] 1943, '42, yeah, 1942, I've heard say.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Everything gets mixed.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
