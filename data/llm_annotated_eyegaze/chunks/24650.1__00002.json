{
  "stem": "24650.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "We had boot factories.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "We had glass, too, glass factories.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Nothing else.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So the people had to live how they can.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So everybody did what they could.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It was a very hard life.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I can't say that we had a hard life, but I can't say that we were millionaires.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We weren't.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Because my mother's father lost everything before he died.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He had people working for him, 1,400 people.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He had-- we call it [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "That means old stuff is-- they bought-- they bought it, and then they sold it to factories, like in Bialystok, in Poland, in Lodz.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "In-- there were a couple of cities where they sold it.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But he was old and sick, and he lost everything, just the house and that.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And my father's father went terribly, in a terrible death, in 1918.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Arath Kuricki Zalman got burned in his own house.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "My grandma did go to the market with the lady.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And they came.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "No, my-- not my grandpapa, not-- not the house, nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "When he-- he had burned alive when he was asleep.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "By himself.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "He-- he smoked a pipe.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Nobody touched him.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I had a brother, Natan Kuricki, and a sister, Asya Kuricki.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My brother got killed by the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I don't know when.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "My sister and my mother runned, and they came to Siberia.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They were there up to '45.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know that they are alive up to '50-- '49.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I haven't seen my mother, my sister, up to '58, 17 1/2 years.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It's not nice, could be, to say.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I was the love of my father and mother.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Because when I was four and a half years old, my father took me to a ballet school.",
      "word_count": 18
    }
  ],
