{
  "stem": "17299.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 344.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "One of the Latvian Jews put his head over the wall to talk to somebody else, and the guards shot him.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And he was only wounded.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And [NON-ENGLISH] came out and told him he is not getting any dressing, nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And he let him lie on the ground to bleed to death.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The chief medical officer.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because a day later, 25 Jews were needed to work in the harbor.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And one Latvian Jew spoke fluently German with a German accent.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he said he was from Cassel.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So he went with us.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And I was one of the 25.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to work in the harbor, loading ships.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, there were nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto was obliterated in '43.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And we worked only a few days in the harbor.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And we got enough food to eat there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And we found out how far the Russians were advanced and that they were carrying off everything, that they were close to Riga.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "They would be in Riga soon.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And we found out quite a few things what we didn't know before.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "How far the Americans had advanced into France already and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "We worked only four or five days there.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "We were put in boxcars to Stutthof.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, concentration camp, near Gdansk.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "When we were came out of the boxcar, SS was standing there with dogs and rifles.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And we had to line up, and they marched us in the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And one SS man told us, this is, see, wire you cannot cross.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "If you cross the wire, you will be shot.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "On further is an electrified wire.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "You'll be electrocuted.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "You are in isolation here in this camp.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No, there-- there were nearly half.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Nearly all the Latvian Jews had escaped [INAUDIBLE] and one of the women with them.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
