{
  "stem": "25381.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So I met him, and we got together.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we were in Austria.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I wanted-- so we came in 1945.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We were married in '46.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And I came-- I came to Austria, and they asked us where-- it was temporarily-- where we want to go.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I wanted to go to Israel very badly, because I had, there, cousins that survived the war.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And I spoke Hebrew, and I wanted to be with them, together.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "My husband didn't want to go to Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "He was too very sick, and he wanted to go to United States.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "So I almost left him in-- in-- you know, we had a fight, and I had to give in.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "He had a cousin in United States that-- he thought that he still a single man.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "He had a daughter, that she was in her late 30's-- and he's a single man, that he's going to marry her.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And so he sent us some papers to go to America.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "He lived in New York.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we came in-- in January the 17th.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The name of the ship was We left Hamburg the 1st of January.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And 17 days we were on the-- on the ship.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "We came to the United States.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We came to Boston.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And whatever had to stay in Boston, they left.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And the rest, they-- they took us-- they came-- there's a HIAS organization.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "They took us by train from Boston to New York.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "We came to New York.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Everybody, relatives, came to pick up the Jewish people with their families, with their children.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Nobody came to us.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "He changed his mind, because I wrote him a letter that he's married and has a child.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "It was 20 months old-- she was born in Austria in 1947, on April 18.",
      "word_count": 15
    }
  ],
