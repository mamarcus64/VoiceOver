{
  "stem": "17625.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "To make the story short, at that night we worked in Crematorium 5-- there was a transport-- and they brought in in the hundreds-- in the hundreds from, from, from those trying to escape.",
      "word_count": 34
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And this was-- and this was happening exactly to the day it was [POLISH], [INAUDIBLE] 1944.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "October, '44.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This was the [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I was in 5 and I saw the fire there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I saw there's no way-- there's only dead.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I saw there was only-- there's nothing else that can help me there, so I tried to run over the road.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Because 4 and 5 was like this side of the road and the other side of the road.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "So it was one against the other.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "So I run over.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "It-- it, it, it-- [INAUDIBLE], you know what I mean?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "It [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Crematorium 5.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Crematorium 5, we had-- at that time, we were active in, in, in, in the-- in the crematorium.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "So they left-- they let us stay.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They let us-- they let us stay.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Do the work.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Somebody has to do the work so they let us.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "But later [PAUSES FOR 4 SECONDS] they took us back to the block.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] And they started [POLISH] kommando.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "You know what means [POLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Destroy the, the, the crematoriums.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Whoever was left [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "So we went to [POLISH] kommando.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And then sometime we stood on the block.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "We didn't go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden came in the Schreiber.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "He says he needs some, some people to go to work-- to work-- empty out the, the, the-- because on Crematorium 2, the commander when they would get work, they, they, they, they lived there.",
      "word_count": 35
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They didn't take him out.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They didn't bring him to the work-- to the block back.",
      "word_count": 11
    }
  ],
