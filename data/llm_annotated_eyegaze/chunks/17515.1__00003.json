  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And some kind of mushrooms, [INAUDIBLE] and pierogi with sauerkraut, or all kind of different, now delicious, delicious.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Ah, she made an excellent-- my mom even killed the pork, and she made kielbasa, kishka, home-- home-- homemade, excellent.",
      "word_count": 20
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I never forget it.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And goodies, goodies on the table.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "The children-- nothing, nothing, not even my brother, not even me.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "We only help to eating.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I believe so, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she had help.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "The truth, we used to live in a-- in a baron property, Petrosky.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] We had a beautiful life, like a castle.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Maybe 13.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "White, blue, or something like that.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Big bed.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Toys, small horses, carriage; things like that.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Also some balls.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, I was not interested in nothing, nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Clearly I start-- when-- when I was liberated from Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Then I woke up.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Deblin.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "There was Air Force training for the army.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And there was a big [NON-ENGLISH], when Marshal Pilsudski died in 1935 in May, we went to Deblin.",
      "word_count": 18
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "Then after I went to see in Deblin, a beautiful city, so it was a dream for me to immigrate from-- from Maciejowice to Warsaw, which I did.",
      "word_count": 28
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "And Polish-Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "In Maciejowice, it was a very well, the Jewish people.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "They owned beautiful stores, bakery, fish market, and it was a very, very nice town, Maciejowice.",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Mostly, mostly all over.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Outside.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "School was in Maciejowice, in-- in-- in town.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "We walk.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "It was not far away, a mile and a half.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "And special seven class, there was one school, a big building.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "They have to transfer to Deblin, big city, or you even come to Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "By myself.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Even I don't know, but possible I went by train.",
      "word_count": 11
    }
  ],
