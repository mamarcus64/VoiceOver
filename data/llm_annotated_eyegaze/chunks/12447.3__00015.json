  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I never seen her again.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "She just disappeared in the railroad station.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And here, me being like, at that time, 10 years old, I had to-- I had some money on me that my father gave me besides what my aunt supposed to buy the tickets.",
      "word_count": 34
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I got to my, my-- next to the cashier, and I bought a ticket.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And he kind of looked at me funny, a kid my age going to this-and-this town.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I had to explain it, why am I going alone.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, I got there.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And I bought a ticket.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
