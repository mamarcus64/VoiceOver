{
  "stem": "22447.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And-- while I was on the bridge-- I wasn't on the bridge, I was in the office at the time-- someone come in, a British driver.",
      "word_count": 26
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "He was all shaken up.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "He said he's had an accident on the bridge.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He's knocked a boy down.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He's badly hurt, what should he do?",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I said, just get on your lorry and go.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "There's so many thousands of troops got killed in Orleans, so what civilian boy is going to make all the difference?",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Nobody-- civilians don't come into it.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "But we had instructions not to get mixed up with civilian people.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "So we went in.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I said, look, someone has come in, there's been a nasty accident.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "Can we take a lorry and take him down to the hospital?",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "They said, no, you mustn't get mixed up with the civilians.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "Which country was this?",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In Holland.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Just past-- north of Eindhoven.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I said, we can't leave him on the road.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "In the snow.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "It was snow, it was in December.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Are we just going to leave him there like that?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "He said, look, the best thing to do, take him, put him in the lorry.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Take him up to the hospital, in Eindhoven, which was about 10 miles, but don't go in.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Take him up to the hospital and let them take over.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "They were very nice people, very hospitable.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "We used to go in there every evening.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "In the cafe, they had the cafe.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "We would just go and-- even if you didn't buy anything, they had a big fire there and it was bitterly cold, so we used to go into the fire.",
      "word_count": 30
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So how can you go in and tell these people that their only son, he was 17, he got knocked down by this lorry?",
      "word_count": 24
    }
  ],
