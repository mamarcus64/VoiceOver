  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "That was in Budapest, made by photographers who made 200 million photos a day in one of the-- one of the parks.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "That's me in 1949 in Prague, playing against-- I am under the textiles shirt.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And it is in Prague playing against one of the greatest right wingers in the world, 1949.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "That's me again, my first appearance in the newspapers in Budapest in 1949.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And when we played-- MTK played the first very, very important game against Kispest, which was the champion.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And we ran second in the competition.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "That is Eva and myself in 1993.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "On the-- on the-- I think, so the occasion is somebody's birthday.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "We went.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And this is my home where the picture was taken.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In Sydney, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And this is my immediate family-- my daughter Agnes, Mark, Richie, Stephen and Paul Brandon.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And this was taken when my grandson bar mitzvah-- the oldest son, Stephen.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And it was at the after temple Emmanuel when the reception was finished.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And all I want to say is that, when I look at these three boys, that I'm absolutely delighted that they didn't have to and won't have to go through the things what me and all my fellow Jews had to go in the past.",
      "word_count": 45
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And I hope their life will be happier than mine.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And that's it.",
      "word_count": 3
    }
  ],
