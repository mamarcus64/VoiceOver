  "elapsed_s": 92.9,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "After war-- the war, the Swiss notified me that since I had relatives in other countries, I had a year to emigrate.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And I contacted my mother's two sisters in America, my Aunt Nellie, who lived in Philadelphia, who-- and my Aunt Katie, who also lived in Philadelphia.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And they and their husbands got together and got me papers and then brought me over here in-- I came over in April of 1946.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "I got here on the 9th of April.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "I spent some time in England on the way waiting for a plane.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "My cousin, Lizel, who had gotten to Switzerland and worked in a factory, I had seen several times.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "The last time I saw her was just before I left Switzerland.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "She was very, very sick with an infection and they didn't have penicillin yet and she died from her infection shortly after I came to the States, the 9h of April.",
      "word_count": 31
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "And so we lost her also.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "In Philadelphia, I started going to high school, started 10th grade.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "I got credit for most of my work in Switzerland and then switched from a-- an academic high school to a vocational high school and learned refrigeration and air conditioning there, which I never took advantage of because the unions were very difficult and you couldn't.",
      "word_count": 46
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "I finished high school went to work for an electrician for a while, but in between right after I got there, I started working as a busboy in a restaurant and that was always my first love.",
      "word_count": 37
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "I wanted to become a cook.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "But when I worked in this restaurant, I realized how hot and miserable to work as a cook is in the kitchen and I decided that was not for me.",
      "word_count": 30
    }
  ],
