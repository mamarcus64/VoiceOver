{
  "stem": "979.1",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "When I was in-- in the [NON-ENGLISH], when I was playing, and a German soldier told the waiter, send this to the little girl an apple or something-- that I was sitting with my-- there at the table sometimes, if I'm not playing.",
      "word_count": 43
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "And-- [LAUGHS] --the Greek waiter said, there is an apple for Yvette.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "If he only he knew he was Jewish, he'd throw it in your head.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "They think like this.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know we were Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "So that proves you that there was-- Jews are not a special look that they have, that they-- they pretended we are horrible looking people-- something like that.",
      "word_count": 28
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "So there were so many beautiful Jewish girls who came to the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And so-- so that was it.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "So we now were living with-- my sister had-- had met a young man.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And he asked to marry her.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "And he was from the German school.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "He spoke German beautifully.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "So he was talking to the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "He-- he was doing his own business-- working.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "He didn't know that this is gonna happen.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "He was doing business with a German soldier while we were there.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And he was saying, you better get out of here.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "He says, you better get out of here.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "Go to the mountains.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "It's not going to be good.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "I see your families.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "Your-- your sister-- I mean, your fiance's family, they're such a good people.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "He says, and I don't want them something to happen to them.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "When they start to see us, that we were people, you know, they were feeling sorry-- some of them.",
      "word_count": 19
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So, but he went away.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "He says, my sister didn't want to go.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "He says, take your daughters away from here!",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know where to go.",
      "word_count": 6
    }
  ],
