  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And here was my grandmother and my grandfather in the same house that they had lived in for a long time.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "My father's father.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Except that now, they lived in one room.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "The rest of the house was taken over by other people.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "With as little as she had, she cooked a meal for me.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She had had a stroke two years before and recuperated.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And she said, you know, you wrote to me.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And you said, you've got to move everything.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And that's what I've been doing.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "I can move my hand.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "The only thing I can't move is my little finger.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And here was the woman was 86 years old in her long dress, always wore long dresses.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And she cooked dinner for my mother and myself and for my grandfather.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And he took us into the backyard where he had a pear tree and an apple tree.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he says, remember when you grew up, when you were little and you climbed the apple tree, and you stole some apples, and ate them, and you got sick?",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And while I was laughing, the tears were running down my checks.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So this is what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We said goodbye to my grandmother.",
      "word_count": 6
    }
  ],
