{
  "stem": "10818.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 1.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "It was called Hauptsynagoge, which means the chief synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And it had been built in-- it had been dedicated in 1912.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "For the ages, they thought.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "It was built of marble and gold, and it had an enormous chandelier.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And it had a beautiful round kodesh, and bema, and maybe 12 or more Sefer Torah, each of which had elaborate golden breast plates, and rimonim, and yad for reading.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And it was-- it just-- it was like an opera house.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "In fact, some people thought it was a bit too much.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And you know, if you went up the stairs, it was like going up to the opera house.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And up the stairs, were in the tier of what would be an opera house, a horseshoe where the women sat.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And I used to sit with my mother and grandmother.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "But when we went to school later on, to the Jewish school, they made space for us down for all the children, downstairs with the men.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And so we sat-- the children sat downstairs together.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Our rabbi was Sali Levi-- S-A-L-I L-E-V-I.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He was a magnificent man.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He was handsome with a gray beard.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "He was an artist as well as a rabbi.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "He came originally from a very small town in southern Germany, but going to a rabbinical school in Breslow, where my husband is from.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And where there was a very important rabbinical school.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "He served as a chaplain during the First World War, and was just a wonderful, dedicated man.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "He was the co-director of our school and stayed on even though he had-- had several chances to come to this country.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "He stayed with his congregation until almost the end, when he went to Berlin to immigrate and had a heart attack there.",
      "word_count": 22
    }
  ],
