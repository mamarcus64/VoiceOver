  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "Any of my family, my brothers?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "Oh, we don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And was kind of-- Ukrainers there already, occupied.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "They took over the whole complex with all the furniture and everything, because they left everything behind.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "So it was nothing I could claim in the beginning.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "So then I found out later in the day, I started walk around town.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "My brother came home for you.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "He was in the Ukraine in the Ukraine labor camps.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "And he came home.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "And I found out that he's alive.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 20,
      "text": "And he came home, and he lives with three other Jewish boys.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 21,
      "text": "So it was something.",
      "word_count": 4
    }
  ],
