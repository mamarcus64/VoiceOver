{
  "stem": "1537.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I used to go on the field to pick up-- what do you call-- the wheat.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I used to take all the wheat in through a, a small mill to make little flours to bake the matzo for the last Pesach.",
      "word_count": 26
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "But between, before, what happened about a year and a half when I came back from [INAUDIBLE], there was a family in Somotor.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "The name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Rabovsky, ?] not Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They, they liked my mother very much this family.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And they were in the business of agriculture products-- you know, cotton, wheat, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They used to buy up from the farmers.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And the wife of this [?",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Rabovsky ?] came to my mother-- let her rest in peace-- listen, I'm going to give you if you want flours.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And of course, it's black market.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "So who will do it?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "My father will not do it.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "My brother, Betzalel [?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Josef ?] will not do it.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "I decide I was always-- you know, I guess I was always born to do some kind of a business.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "I decided in the night, on the field, we used to-- the wheel barrow to bring 50 pounds of flours, bring it into the house.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "In the morning when I was going-- then I was coming home every day.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I, I didn't sleep anymore in the town, you know, Satoraljaujhely.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I came home every evening.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, I was taking the train.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And I had-- I remember till today-- I had one package, I had seven kilo, in the other package, five kilo, 12 kilo.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "This is approximately 25 pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I used to sell it on the black market for the bakeries-- for Jewish bakeries.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And that's-- I used to make more money than an average.",
      "word_count": 11
    }
  ],
