  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But I'm naming it 750, easy reckoning.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I says to [?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Els, ?] my wife, look, Schlesinger is talking to Konrad Gemmeker, the SS commander from Westerbork.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Now, as we walk towards that, we stop.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You stop.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And we stop next to Schlesinger.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And you say this time-- he, I said, he doesn't like me anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "I've been troubling him.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "You tell him we're English.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "We need not go.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And our documents are on the way.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "They can arrive any minute.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And we stopped at Schlesinger.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And she said that.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he gave us less than a second.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He said to Konrad Gemmeker, [SPEAKING GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "This has been refused in the Hague.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "They've got to go.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "We're going to Hague, the headquarter of the SS.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "We went through the gates into the train.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "This was still the passenger train.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Later on, you get the cattle trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "In the train we went.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 9 SECONDS] Our baby was ill.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "He had some [INAUDIBLE] in the head.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Don't know.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "There's still alive in Rotterdam a doctor who took blood from me and injected it into my baby's [INAUDIBLE] try to-- because children were ill.",
      "word_count": 25
    }
  ],
