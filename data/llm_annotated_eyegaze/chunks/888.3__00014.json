  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And of course, you know, Jewish people lived in Hungary, for-- I think before the Hungarians, really.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "From 1,900 years-- 1,900 years, you know, that the Jews lived in Hungary, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And at least there was-- you know, when the Hungarians established, which was 1,000 years back, there was also Jews came with them.",
      "word_count": 23
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "But of course, the anti-Semitism, you know, was there.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "You know, you felt it all the time, of course.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "You know, constantly accused, being accused of killing Christ, and so on and so forth, and being different.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Of course, you know, a lot of, a lot of people-- you know, like for instance, I was telling you, you know, like with Romanians--",
      "word_count": 25
    }
  ],
