  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And then, around 9:00, it was almost dark, he finally came back.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They came back.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So of course, I asked him, what happened?",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And so he says, well, after the work, instead of coming back to camp, they took them to the-- to Canada for showers.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And while he was getting dressed, a kapo, a German kapo, came up to him.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "He was a civilian, who he knew from before the war, from our home town.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And he says, Jacob Leipciger, [NON-ENGLISH], you know?",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "He says, you know, [NON-ENGLISH], you know what I make doing here.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I'm-- I'm a Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "So he says, I'm a kapo in the tailor shop, and I can save your life.",
      "word_count": 16
    }
  ],
