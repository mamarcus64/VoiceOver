  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And the next six weeks, I believe I cried every night, cried myself to sleep before I felt I had reached a point where I belonged and gradually eased myself into the American scene with the effort to blend or assimilate as quickly as possible.",
      "word_count": 45
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "No one knew there was German in my background.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "To everyone, I passed as French.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I spoke French in school I did not want anybody to know.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I remember a teacher actually confronting me and saying, make up your mind.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Are you Jewish?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Or are you French?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We'll stop here, change tape.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
