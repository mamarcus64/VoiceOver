    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "And he said, and I heard this, the Final Solution was applied to more than 5 million Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "Now, this is an eyewitness statement that I personally heard.",
