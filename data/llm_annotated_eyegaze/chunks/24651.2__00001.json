{
  "stem": "24651.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Actually, people didn't really know what it meant, but they were fearful that if they took out Russian papers that they would be giving up their Polish citizenship and the rights to their property and their homes and-- so at that point, people were very divided and confused and really not know what, what to do about it.",
      "word_count": 58
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And my grandparents, the Nabels, and my one aunt and uncle-- two aunts and uncles decided to, to do this, to take out the Russian citizenship.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And they were actually shipped on, on, by train to Siberia.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And the, the people who refused to do it had to return to Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So we returned.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And I guess that was a very grave mistake.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "My one aunt, one aunt and uncle who were heading toward Siberia just before the train left, they got off the train and went to Poland.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "My father told me that, [PAUSES FOR 3 SECONDS] that he had one of his brothers come and pick us up in a truck.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "So we all returned to Nowy Targ.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I think it was a long journey.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It's several hundred kilometers away.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So we, we went back to Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And at that point, there was a ghetto in Nowy Targ.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "So we had to live in a ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "My grandparents were still there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I don't really know.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I, I think-- I just know that we had to-- we all lived together in, in a very small apartment in the ghetto.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "All the, all the belongings from, from the apartment and the store, everything was confiscated.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "When we returned, my father was arrested because he was-- they thought he was a communist.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he was arrested.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And I remember my grandmother preparing food every day for him.",
      "word_count": 11
    }
  ],
