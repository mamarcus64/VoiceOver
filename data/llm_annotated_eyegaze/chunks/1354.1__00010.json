  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And I had one girlfriend-- I even talked to her the other day.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "I just found out that she-- where she is.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "We were together, and we were like sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "We cooked together.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "We cried together.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "We left together if it was time to, you know, to left.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, I had a-- a friend there-- I wouldn't call it a boyfriend.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "He didn't-- he didn't live through the-- he went to Mauthausen, and he didn't-- he didn't survive.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So we stayed there till-- till what was it when we went to Auschwitz?",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "In '42 or '43?",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And we worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And then to-- they were liquidating Plaszow.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Stop right there.",
      "word_count": 3
    }
  ],
