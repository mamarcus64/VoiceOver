{
  "stem": "11144.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And I really didn't want to, but he put enough pressure that I finally agreed.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "His family.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In 1959.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, [PAUSES FOR 3 SECONDS] for-- at the beginning, I went and I met-- I mean, somebody suggested I should go to Burrough's school.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Burroughs Corporation was training people, giving courses for machine operators.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "They were bookkeeping machine operators.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Being that my English was practically nil, I went, I took the course and I finished, you know, before everybody else.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And I got a very good job on Wall Street with some lawyer who was having a [INAUDIBLE] et cetera.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And I was working for him for about a year, a year and a half.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And at that time, we decided to have a family.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And I became pregnant, and I was having a problem with my pregnancy.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "So after working-- in the third month I had to-- I had to quit my job and I was home.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Then when my son was born, I went-- they called me back and I went back.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I worked for them part time a little bit, but I just-- it just was so hard for me to leave him.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "I had no mother.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "I had no one here except for his sister, and we really weren't that close, close.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "So I-- so I stayed home for 11 years.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother didn't come here eventually.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My mother, in the meantime, was traveling back and forth.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Was coming and visiting us first for two months, then she was leaving, then she was coming.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "My stepfather got very sick, and eventually he passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And at that time she really wanted to come here to America.",
      "word_count": 12
    }
  ],
