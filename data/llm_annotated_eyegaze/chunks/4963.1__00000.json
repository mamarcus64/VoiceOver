{
  "stem": "4963.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "All right, I am Marcia Ceitlin is-- was my maiden name, and Spies is my married name.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in Kovno, Lithuania in 1929, December 13, 1929.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My parents' names were Genia.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "My mother was Genia.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Taft was her maiden name, and Ceitlin.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And my father was Mayer Zvi Ceitlin.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "My father was born in [INAUDIBLE], and he came to Kovno.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Actually, [INAUDIBLE] is a suburb of Kovno.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "It's about five minutes from Kovno.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "Kovno used to be the capital of Lithuania then.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And he met my mother and they were married in Kovno [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "I think it was 1926 that they were married.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "My mother was a very-- both of my parents, actually, were very, very ambitious people and my mother already was in business at the age of probably 20.",
      "word_count": 28
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "She was like 25, 26 at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And my father came, and-- and they met.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "She was always in clothing and fabric business.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And when my father came, he had a-- he was an accountant, and they married, and-- and they immediately moved the business into a larger one.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And my father was really very involved in-- in larger-- he was better in wholesale and [? overall ?] and my mother was much better in retail.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So it was a real good combination.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And they just-- in no time, they just grew and their business grew and grew.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And by the time I was born, 1929, I think it was about a year later, we moved into a beautiful home.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I can describe my home.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My home was really very modern, I'm thinking.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Because I was just back in Lithuania two years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "First time I was back was six years ago, and then second time was two years ago.",
      "word_count": 17
    }
  ],
