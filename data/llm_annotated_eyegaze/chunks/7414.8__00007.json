{
  "stem": "7414.8",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "What a lawyer can do in a foreign country, in a foreign language and that?",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "So he had to learn something practical.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I had to learn.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Michael was three years old.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So I took him in the morning to a child minding center, and I run to Alliance Francaise which was situated not far from Sorbonne.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "That was for the foreign student on the level of university for the-- I went around-- I run over there.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "At 12 o'clock, I was running back picking up the child and cooking the meal, because the French are eating twice a day.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They are eating cooked meals.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "So I had to cook the meal.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And we lived by then-- I lived on the outskirts of Paris.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "My brother bought a house there.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "At 2 o'clock, I had to be in the center, not far from the opera, because I enrolled into a school of design and dressmaking.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "In meantime my brother helped us.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My husband was learning, too, because he could not work.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "What do you-- he was learning this handbags making art.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish organization-- art.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So at 2 o'clock, I was [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And at 5 o'clock-- till 5 o'clock until I took the underground now back, I had to pick up the baby at 6 o'clock and start to cook again.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And it was not an easy time, but--",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Six years.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I worked.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Because when I finished the course, I was so good at it that the head of the school, this woman.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I hardly spoke yet French.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I spoke a little bit what I learned at this, but that was that at the beginning.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I did not have, of course, a permit to work.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "But she offered me a position with Vogue patterns.",
      "word_count": 9
    }
  ],
