{
  "stem": "16887.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "She-- she-- she had no choice.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Because we didn't let her go.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Once we were in Vienna, I wasn't afraid for her.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "She was with me.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "She was glad.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- I found out from my sister that my brother was shot.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He came to my neighbors for food.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They gave him food-- with the children.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "On the way back to the ghetto, he was shot by the wall from the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "The children escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "My mother died from hunger.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And that's when she told the children, try to escape to go to my neighbors.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "That's how my sister was saved through my neighbors.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "My sister, Hana, was in the church.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "The priest that used to teach religion the school I was attending to, he kept her for quite some time.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "But my sister, when it became very dangerous for my neighbors-- because some were good.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Some were afraid that the-- they were-- they'll be shot by the neighbors because of Jewish child.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So one of my neighbors took her to a friend of hers, to Praga.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That's where I found her.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But she took her to a friend that she knew, that she didn't know nothing about her.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "She was working for Gestapo.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "She was taking in Jews, keeping him for a week or two, taking everything away, and then the Gestapo would come in and take him away and they disappeared.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "My sister would-- my older sister, Hana-- she would risk her life during the curfew hours, to come to see my younger sister.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "One day, the lady said, why should your sister risk her life?",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "She could stay with you.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And she was with her.",
      "word_count": 5
    }
  ],
