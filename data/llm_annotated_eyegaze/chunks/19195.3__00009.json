{
  "stem": "19195.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 204.4,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Was in a nightstand next to where the-- my fellow prisoners left me.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And then when they came to pick me up, I says, look, I found an Auschwitz album, which was six months before-- later and 500 miles away.",
      "word_count": 27
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Pictures of-- [PAUSES FOR 3 SECONDS] of the people that I grew up with, that we were friends or we were relatives.",
      "word_count": 22
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He says, you wouldn't be able to take it because they'll arrest you, maybe, somewheres on the border, and they'll take it away from you.",
      "word_count": 25
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "As it turn out, they did take it away from-- from me, the Russians.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "But they gave it back 'cause I carried on like a lunatic.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "There were like 200 pictures pasted in.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Right away.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I was very ignorant about it.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I kept it with me.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "When my daughter was-- our daughter was born, Esther, that album was under her mattress in the carriage.",
      "word_count": 18
    }
  ],
