{
  "stem": "1938.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 349.6,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I got married in '47, March. 30Th of March, '47.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And from this day I was behind him.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "He told me that I am not obligated.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I was just engaged, and wife leaves the husband in this condition.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "He-- he want me to be free and have a happy life, because I was happy and lucky to come out OK.",
      "word_count": 22
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "But I said, Naomi and Ruth.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "Whatever will happen to you, will happen to me.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "You are not so lucky, but you're lucky that I will take care.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "And I took care 45 years.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "After that time, he was better.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And after we got married-- that was '48, '45-- three years later, I had my son.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And this was the biggest blessing.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "In Germany, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Born in Feldafing, in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I have one son and one daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "My daughter was born in Cleveland, Ohio.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And I'll talk about them later.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "I still want to talk about my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "He was a very great guy, very nice, very good family.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And we had a good relation.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Besides, he was a good patient.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Never-- never aggravated, and never-- no nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Everything was good.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "Everything was good.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "He was very happy that he had somebody to help him, and devoted like me.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "And the children were good, and everything was good.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "But he was--",
      "word_count": 3
    }
  ],
