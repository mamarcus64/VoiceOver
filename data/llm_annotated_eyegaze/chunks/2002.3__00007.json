{
  "stem": "2002.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And we buried it in the cemetery with plastic bags that they wouldn't get spoiled.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And we figured when it cools off in a couple weeks later, we'll go get the sugar.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We went back.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Nobody could find where the place was we buried, and we never find the place.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Then we went out, and we got-- got a cow in the-- way out in the field.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And we killed a cow.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And some of the guys were butchers.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "They took the skin, and they put the skin in the ground.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "We took wood with us, and put a lot of salt in the meat.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And we covered it up in the field with a lot of salt.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So often we went, we took a piece of meat, we cooked in the middle of the night, and we ate.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I'm going from there.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Suddenly comes the military in taking me and my brother and some other people.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And I got picture of two people.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They took quite a lot of people.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And they took him to send him to Siberia to do the work.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "That's the second time I'm in Siberia.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Now I'm in a place called Beryozovka.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "One guy-- while I'm working there, one guy gets very sick.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And there's a doctor about five kilometers, six kilometers away.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And-- and I was almost the youngest guy there.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "The [INAUDIBLE] said I should go get the doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I go get the doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "The doctor was a young girl.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I get the doctor, and you don't mind me to go into that conversation, because because as the doctor came and he gets some medicine.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "But she has the medicine [? on. ?] So somebody has to go with her back to get the medicine.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "Her name was Wanda [?",
      "word_count": 5
    }
  ],
