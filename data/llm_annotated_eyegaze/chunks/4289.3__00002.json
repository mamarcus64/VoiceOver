{
  "stem": "4289.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And when they came to Israel, they wanted to identify with Israeli children.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And they went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And I believed that they did not pick up anything from my aunt.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Because still today, they are not Jehovah's Witnesses.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "Actually both of them got married to Jewish girls.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, when my aunt introduced him to me, it was like she talked for me.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "She told me, this is the man you going to marry.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Don't think that anybody will like you.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Look at yourself, how you look.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "You have three hair on your head.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "You have two sticks instead legs, two hands-- two sticks instead hands.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "She said, what do you think, you're a beauty?",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "She put me down completely.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And then she said, if you go to the United States, at least you gonna have a good life.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Probably, if he was telling the truth, he must have been at least 18 years older than I was.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And I went like a sheep to the butcher.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I did get married.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And in a few days, he left, because he had some business to attend in United States.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And when he left, I kind of woke up out of the shock.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I said, there is no way I'm gonna go to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And I was looking for a way, you know, to get out of it.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I didn't know the language.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I didn't know anybody who would cooperate with me.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "They all said, yeah, yeah, yeah, go.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "My father was-- he was thrilled that I'm gonna go to United States, everybody in the family.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "If I would say no, that they were angry with me.",
      "word_count": 11
    }
  ],
