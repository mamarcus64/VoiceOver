{
  "stem": "26914.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 107.0,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I think it's harder to raise your own children than childrens-- strange children.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "It's very hard, especially in the case of hemophilia.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "You have to be very careful.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "You have to be strict with them-- don't do this, don't do this, don't do this.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "I knew, and I felt that sometimes, they hate me.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "But I hadn't got a choice.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "One time, Leon said to me, ma, I know that you are right, but I cannot take all the time no, no, no.",
      "word_count": 23
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "I will not listen to you.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Even you are right, I will not listen.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "Mark was at that time four years old, and he want to play baseball.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "He want to do-- to go on a bicycle.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "I said, you cannot go play ball, because you have to run, and you might fell-- fell.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "You can't go on a bicycle, because you have to drive with your legs, but you have very often swollen legs.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "But I took them to play tennis, ping pong.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "I bought that table.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "We played ping pong, tennis.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "But they want something else.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "They had something in sport in themself from me.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "They want to do things.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 19,
      "text": "So I knew, and I felt that they hate me sometimes.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 20,
      "text": "It's hard to raise children, your own.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 21,
      "text": "But in a case like this, it's very, very hard.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Ulcers.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And he played the role that he is always sick, never helped me.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But he was a sick person.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Well, I adjust to everything.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Everything is easier for me.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I know that Leon has a marvelous wife.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Mark has a wife.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "So my responsibilities not so much.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I enjoy it now, life.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I enjoy life.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And I try to give something from my life.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I volunteer 12 years in a old home, Northwest Home.",
      "word_count": 10
    }
  ],
