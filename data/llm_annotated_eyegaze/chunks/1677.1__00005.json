  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So I decided that I'm not going to play this dang game.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And there was the premiere.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "If you remember, they had the anniversary, here, the 60th anniversary last year of Walt Disney's Even the movie house belongs to my parents-- but you were not allowed to go there.",
      "word_count": 32
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Not dogs, gypsies, and Jews were allowed into the picture show.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So I kept the bright idea, I take the Star of David off with my mother's manicure scissors.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And without the Star of David I must see And then I operated that Star of David off-- which had to be very firmly sewn on.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I had a catastrophe happen in my life.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "My little jacket faded and I had a great big black Star of David on my black bust, and I locked myself in the toilet to sew it on again, that my mother doesn't find me out.",
      "word_count": 37
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I told this story a couple of years ago, here in Renwick High School-- I talk to schools quite often, when they do their Holocaust studies-- and they-- I said-- I make it always very funny.",
      "word_count": 37
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I never speak about sad things.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I make it for children interesting how a child survived the Holocaust.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And they said, 'Miss Kitty, did you ever manage to see A little boy from Vietnam asked me.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I said, no, truthfully I never saw.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He said, 'I want your name and address after class, because I have a beautiful Walt Disney video, and there is the whole and I lend it to you.'",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that's--no, the first was that I was thrown out of school.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "'38.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "September 1. 1st of September, when school starts in Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "It was a decree from the-- from the Slovak government, that all solicitors had to be struck off.",
      "word_count": 18
    }
  ],
