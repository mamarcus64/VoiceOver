{
  "stem": "20142.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Henry Frankel.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Spell-- spell it?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "F-R-A-N-K-E-L.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My previous name-- I was born with F-R-E-N-K-I-E-L.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "The name was changed during naturalization when I came to the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The only name that I was working in Warsaw for the underground was Tadek, spelled T-A-D-E-K.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I only responded to this name when I was outside of the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "There no other names that I responded to or knew that I had.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The name was given to me by the organization of the Polish Socialist Party, the PPS, spelled in Polish, [POLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It's [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born June 16, 1924 in Lodz, Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Hayim Mayer, but they were calling him Max Frenkiel.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He was born in December 12, in 1888.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Always having time, interested in our school, work and participating.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Encouraging us to join Zionist organizations.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And particularly, was very fond of us when we got together on holidays and had some other people on Shabbat celebrating Shabbat in holidays in a real Jewish way.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "He had the textile manufacturing place, quite a large one that he built up himself.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And he had a-- his brother was a partner to the finished goods that the plant was in [NON-ENGLISH], near Lodz. 10 kilometers north east-- north east-- northwest of Lodz.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they distribute-- they-- a place of the business of his father, of my father, brother, and him was in Lodz.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "On Narutowicza and Piortkowska Street in Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "N-A-R-U-T-O-W-I-C-Z-A.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Narutowicza Street in Lodz, and Piortkowska Street, from the name of city of Piotrkow.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "P-I-O-R-T-K-O-W-S-K-A Street.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "There was textiles, weaving and finishing.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And a quite successful business.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I didn't really experience any hardship at home.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And my brother and my-- and me were attending private, Jewish gymnasium, predominantly of interest to father for Hebrew studies.",
      "word_count": 20
    }
  ],
