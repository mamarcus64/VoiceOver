{
  "stem": "15900.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He was in Atlantic City on vacation.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I went up.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And the people who worked with me before saw me coming up there.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He said, Sol, what are you doing?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'm the manager.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "How much you make?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I swear to God, I was ashamed to tell him.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I told him double this salary.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He said, I give you the same salary.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Listen to this.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He's gonna give me $10.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "He give me the double salary.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "How much you get vacation?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "I said, three weeks.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "You get three weeks too.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Was that part true?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, wait a minute.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And he said, I give you the vacation.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I double your bonus.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He was there, and the manager took me into the dark room to print.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He gave me a an order.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "In 10 minutes, I finished all of it.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "He called up the boss in Atlantic City.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Come back.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "You've got a man who can never get this kind of person.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "This way he can take over, and I go out to the street.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "He came back.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The place where I went out there.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I was three weeks vacation.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He came back, and he had a conference with me, the boss.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I said, I hear everybody who works for you tell you are a rotten boss.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "You are impossible to get along, and you fire a lot of people.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I said, so what are you going to do when you fire me, and you hire me, and I lost this job?",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I like the boss.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I never talked about him.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "But he gave me-- I maked a living.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I liked him.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "But you never talked about the boss.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "He said to me, so what are you going to do?",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "You want to stay with me?",
      "word_count": 6
    }
  ],
