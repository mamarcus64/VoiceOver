{
  "stem": "7684.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 26,
      "text": "There was [? no ?] camp four, what I heard later, where the clothes-- they called it also where the clothes was from people that died in the gas chamber.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 27,
      "text": "So camp three was the death camp.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 28,
      "text": "And we know-- we never looked at that.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 29,
      "text": "That was just the death.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 30,
      "text": "So we came on in camp one with all the girls together.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 31,
      "text": "And I saw some people from my hometown.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 32,
      "text": "Three boys.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 33,
      "text": "And there was two very close.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 34,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 35,
      "text": "Vaughn ?] was-- his parents were my parents' best friend.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 36,
      "text": "And the other one stayed in our house when the German took his house.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 37,
      "text": "And he stayed with us-- with my father in the hotel.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And I say hi.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "How are you?",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And they didn't even say hello.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They didn't say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And so strange.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They know me very well.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So then they went away to work and then we went to work.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "What did camp one look like?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Camp one was looked like-- I thought in that time-- like, I saw movies once from Mexico, from [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It was all wooden.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And Holland's [INAUDIBLE] stone.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And there was all wooden barracks all around, so all around.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And there we slept.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "It was bed, a bathroom.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "There was a barrack for men and there was a kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And there was a barrack for women.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And there was a place for the-- for ironing and one for the laundry.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And one was for the goldsmith that worked at a little place.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And for the carpenter also for the German.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "Carpenter.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And there was a-- and a shoemaker.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And there was something else on the-- on the back.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "Copper? ?] Oh, and somebody that painted.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "There was very famous painter-- [?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "Van Damme ?] was his name-- from Holland.",
      "word_count": 8
    }
  ],
