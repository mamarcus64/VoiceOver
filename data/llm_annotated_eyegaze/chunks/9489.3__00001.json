  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I jump in, in a coal train, from coal, in the train.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I couldn't go in a passenger train.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I need-- you know, I need a what do you call them?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "A ticket.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't get a ticket.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Searching I don't know where, until I got into a Chkalov.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "In Chkalov, they stop the train.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "They start to look in the train, the army.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "So I jumped up, and I went into them.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "I says, I want to volunteer.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "Here's mine pass.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "Here's mine-- two weeks, or three weeks, or a week, I made myself a [INAUDIBLE] on the pass.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "I want to volunteer.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "This was Russian army--",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "This is Russia.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "This is Russia, Chkalov, yeah-- a very big city.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They stop the train from the coal.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You know, and the-- right away, the army start to look, you know, who knows for what?",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "You know, they know what they're looking for-- runaways, you know, deserters.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Any why should I be a deserter or runaway?",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Right away, I come into the guys and I says-- anyways, they believe me.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And they took me into the-- to the station, train station.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And they give me away to the command from the police force.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "You know why?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "I was a civilian, know-- to the police force.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And they told them, you know, I got-- I got all the papers.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "They can't arrest me.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "I'm not a criminal.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And I tell them the truth.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And they say to me, OK, Borys Gregoravitch, we got-- we don't know what to do with you.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "But if you want to volunteer to the army, we get you to the army.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "I says, I'm hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "Anyways, they gave me food.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And after a few hours, they call me to get out.",
      "word_count": 11
    }
  ],
