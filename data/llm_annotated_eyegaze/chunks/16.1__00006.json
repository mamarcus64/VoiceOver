{
  "stem": "16.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They were hitting-- beating you with the gun butts.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Just, just making it, you know-- they didn't have to do these things on their own.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Nobody was behind them, watching them, and so on.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They just did it because they were sadistic.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "They were happy to see the Jews get out of there.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I'm just adding that as a guess.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "It was not possible--",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "--just--",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, we were writing to each other, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "My mother was very proud of me because my aunt wrote all kinds of nice things about me.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "My aunt was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't even go to a movie.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And I was working-- I loved what I learned in the printing shop.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And I was working there on my own.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I did things on my own.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Well, she had her daughter-in-law there.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "She had a little boy, three years old-- the daughter-in-law-- who loved me to pieces.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "That's one of the reasons why she was able to convince me not to leave.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And they're going to take you off the train.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I said, no, they're not.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "I'm not a Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And I pulled out my paper.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And I showed her what I printed for myself.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "And then she even got scared worse.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "They're going to catch you.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "They're going to shoot you right there.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "And so I told her, chances have to be taken.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "I want to get home.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "But still, you do things even though you are afraid.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "If you-- if the end-- the goal is you want it that bad-- and I wanted to go home.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "All I remember was a lot of shouting and yelling and screaming, and whatnot.",
      "word_count": 14
    }
  ],
