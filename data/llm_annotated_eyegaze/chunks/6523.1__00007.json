  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "A small percentage-- I find-- tried to find them a reason why we been hated because of religious-- like was a Gentile religion, a holiday, you couldn't come outside because, let's say, was the time when the holiday, the crucifixion when Jesus, the [INAUDIBLE] Jews.",
      "word_count": 45
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They crucified Jesus.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "This is the reason we, we tried to stay away, to educate ourselves, and to be always ahead like Jews-- I mentioned to you privately like they couldn't go to professional schools.",
      "word_count": 32
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Or this percentage, like 10%, 15%, what could afford it sent their children to Germany, to England, to France.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And when they come back, they come back professional-- doctors, lawyers.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "No, we belong to-- our dream was to go to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Never start-- finish with a fight.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't afford to win.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I mean class, like A class, B class.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Was many difference classes.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "If we would win, we would be beaten up.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I'm talking about youngsters, kids.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, many times, yeah, I beat up.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Well, this is-- the neighborhood was kids.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Was a time we, we was ahead.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Was time they was ahead.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Oh, the parents, they didn't-- they raised the children a way they shouldn't get in fights.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "They shouldn't get-- because caused trouble between the parents.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "You know, they are always like this.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "We tried to stay away.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Later on, in the later year, like--",
      "word_count": 7
    }
