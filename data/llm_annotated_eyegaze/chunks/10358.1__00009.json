{
  "stem": "10358.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And then towards the evening, I said, I'm going to get myself out and I don't want to live.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "As I ran out through the back of the cellar, I saw my mother running up the hill.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And she was black.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Her face was black.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I never saw her look like this.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And she said, they took all your friends, all the young people they took on trucks.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And she was screaming and crying.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And we embraced.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "And we came back to the house.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "This was the second execution, where they took all the young people, all my friends, all my young relatives they took on trucks and we didn't know where they took them.",
      "word_count": 31
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "Some say that they were gassed in the trucks and some say they were shot.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "This, I don't have no recollection of that.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "That was the second [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "And after that, [PAUSES FOR 3 SECONDS] we lived in fear.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Excuse me?",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "We went out of the house, yes, because after that, an order came out they're going to place us in a ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "We had to pack our belongings and move to a ghetto, which was a-- a neighborhood where very poor Jews lived years ago.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And there was this big, very famous synagogue, [NON-ENGLISH], it was called, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Maharsha.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "It was just called Ostrog ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Living in the ghetto?",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We were-- we-- they gave us one room and a kitchen to share with-- with other people.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It was a small room and my mother and I slept in one room.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And we were practically starving.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "There was no food.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Whoever tried to escape from the ghetto to get food, they were shot in front of that synagogue.",
      "word_count": 18
    }
  ],
