  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 111,
      "text": "[PAUSES FOR 4 SECONDS] And I remember we were very sparsely clothed, but it was still summer so we were lucky.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 112,
      "text": "[PAUSES FOR 3 SECONDS] We were in that block not too long.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 113,
      "text": "But I remember after we got there, there were French people.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 114,
      "text": "There were Hungarian.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 115,
      "text": "There were Czechs.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 116,
      "text": "[PAUSES FOR 3 SECONDS] There might have been some other kind of people, too.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 117,
      "text": "But it was a mixed bag, definitely, because I never got to know the-- the people on that side of the divide.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 118,
      "text": "There was that holy divide in the-- in the block, which was like a 2 or 3-foot brick raised area in between the block-- in the-- between our-- our block [PAUSES FOR 3 SECONDS] that ran the length of the block.",
      "word_count": 41
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 119,
      "text": "And at each end, there was a chimney going up.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 120,
      "text": "At each end of that-- of the block, there was a chimney going up.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 121,
      "text": "So on-- on one side of the divide-- I never got to the other one.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 122,
      "text": "I was on that side, and I never got to the other side.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 123,
      "text": "There were so many people in that block, and I remember there were quite a few from my hometown, like I say.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 124,
      "text": "But we were just a little minority because there was so many people in there.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 125,
      "text": "And they asked me to sing.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 126,
      "text": "[PAUSES FOR 3 SECONDS] And I figured, listen, if I wet these people every night, maybe I'd better.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 127,
      "text": "So I remember getting up to sing.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 128,
      "text": "And [PAUSES FOR 4 SECONDS] the block, I--",
      "word_count": 8
    }
  ],
