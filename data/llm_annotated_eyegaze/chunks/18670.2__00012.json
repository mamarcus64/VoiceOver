{
  "stem": "18670.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 396.0,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "My parents would buy international stamps and I would sell the stamps there, turn them into cash, and then send back a form of money, I forgot already what the deal was.",
      "word_count": 32
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "But each time we made an exchange-- between Austria and the stamps an exchange-- I had some dollars.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Well, not dollars, had some francs to spend.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "Did",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "You can't work.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "They did not let you work.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "You're talking in camp?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Before I was arrested?",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "They were from Vienna too.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "But I made friends with Belgian Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "They even took us out to see a Jewish play.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, it was the Jewish play that we went to.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And then they took us to restaurant for dinner, that we didn't get home 'til very late.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And unfortunately, I said to my brother, never leave the key?",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I left the key in the door.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And 4 o'clock in the morning, there was a knock on the door and the police was here.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "So we were arrested.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I looked and said, oh my god.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I says, the key's in the door.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I didn't say it in English.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "I said it in German.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] And I said, oh.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "This is it.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Open up the door and there's three policemen or two policemen standing.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And they said, come with us.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I said, do I need anything?",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "No, don't worry.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "You'll be back right away, which was a lie.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We were sent to prison.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We spent a week in prison.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And during that week, we were handed a questionnaire to ask us whether we're political refugees.",
      "word_count": 16
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And naturally, Jews were not recognized as political refugees.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I was in a single cell.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "My brother was in a single cell.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "And once a day they would take us out.",
      "word_count": 9
    }
  ],
