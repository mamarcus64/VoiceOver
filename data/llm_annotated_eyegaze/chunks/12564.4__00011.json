{
  "stem": "12564.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Some-- The fact that I don't know where the energy I had, but being undernourished and be able to run fast that nobody can caught on with me.",
      "word_count": 28
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "It's-- it's a power which is-- you cannot even imagine.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Or to be able to climb in trees.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "I was never a climber.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "It wasn't my profession.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "But you know it.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "You have to know it.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And you deal with it.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] And I was always a survivor.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 5 SECONDS] And even now, I love to work a lot.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And I always provided for the family.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "I didn't let my wife to work.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "Until Houston, she never worked here.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "Here she said, I'm not sitting home.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "The kids are gone.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "I have to work.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So I opened a store especially for her, for perfumes, two blocks away from here.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "It still operates, but without-- unfortunately, without her.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Thank you so much.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "You are welcome.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "My pleasure.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
