{
  "stem": "24411.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And they asked if we have-- if we have citizen papers, passports.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "We said no.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have anything.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "We left home with nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "So they took us out, and everybody was thinking they just take-- take us, not somebody else.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "But they--",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "They took me, they took my husband, and they started to take everyone from the-- from this house.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Then, we started to say something in Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Why-- why are they taking us?",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Is something wrong?",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "Then we find out they took everyone.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, the--the newcomers, when they came to Lutsk.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Not that was living there people.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "They took us to the police station.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And they started to ask questions.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And they said, where is your children?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I said, we have no children.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "They took me one place in one room, they took my husband in the other.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know what he was saying, and he didn't know what I was saying.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Well, what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "And then you know, this was first or the second-- they took us, the whole people were the newcomers.",
      "word_count": 19
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "They took us in a big place.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "A big-- it was a-- it wasn't a park, it was just a place, outside.",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In Lutsk.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Outside, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And they start to talk with microphones.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "They said, who wants-- who wants to take citizen papers so that they could stay?",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And who doesn't want it, they're going to send us this-- they're going to send us someplace.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No, they didn't say anything.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Well, afterwards, everybody said, we have-- we want to go home.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "You send us back to Poland, to the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "The Germans was there.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And they said, OK, we don't want to take-- a lot of people took citizen papers from them.",
      "word_count": 18
    }
  ],
