{
  "stem": "6320.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, there was a lot of them in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And in [INAUDIBLE], did you speak any Polish?",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "No, I never learned Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Yiddish was my first language.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "[INTERPOSING VOICES] My parents were very smart.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "In Poland, we spoke Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "We came to Israel, we started to speak Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] And still, until they passed away, they spoke only Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "[INTERPOSING VOICES] September the 14th, 1995.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "The survivor is Bernice Greenbaum, and Greenberg, her maiden name.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "Ronald Weinstein, interviewer, Los Angeles, California, USA.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "It will be in English.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Who do I look at, you?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Bernice Greenbaum, B-E-R-N-I-C-E.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Greenbaum is G-R-E-E-N-B-A-U-M.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Brandla, B-R-A-N-D-L-A.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Greenberg, G-R-E-E-N-B-E-R-G.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Weisberg.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Bernice Weisberg, B-E-R-N-I-C-E.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Weisberg is W-E-I-S-B-E-R-G.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "October 29, 1926.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "68.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I'm going to be 69.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Zwolen.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's in Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "It's Z-W-O-L-E-N.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It's not far from Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I-- Zwolen was a small city, and there were lots of Jewish people.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And I was attending school, and it was a Catholic school that we all have to.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But I still was going to another school, to Bais Yaakov.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Everything I know from Yiddish is from these few years that I attended at Bais Yaakov.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I remember that I-- when I was going to school, I was a very good student.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And my parents were very proud of me.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And that school that I attended was Catholic, so we had to stand up each time when the other children were saying the prayers.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "But we had a teacher for Jewish religion one hour a day.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "That was beside that I was going to Bais Yaakov.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And our house was very Orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "My mother was very Orthodox.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And my father wasn't that Orthodox, because he was the president of the Jewish community.",
      "word_count": 15
    }
  ],
