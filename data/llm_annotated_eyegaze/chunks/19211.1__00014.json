  "elapsed_s": 164.2,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 21,
      "text": "Now, I don't know until today if he was just a decent human being, if he had enough killing, or what, or whether he didn't see us.",
      "word_count": 27
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 22,
      "text": "I don't believe he didn't see us.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 23,
      "text": "Because we were right there under-- I saw his boots.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 24,
      "text": "So I can't explain what it was.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 25,
      "text": "I can't believe that he was decent.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 26,
      "text": "I mean, he killed my, my friends.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 27,
      "text": "But why he did it, I'll never know.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 28,
      "text": "That was just a streak of luck.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 29,
      "text": "And that's why we're here alive, I think, today.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
  ],
