{
  "stem": "18626.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "So my mother gave her a push.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And she says, in.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And she pushed her in, and my little sister got all mangled up between the women who go to work.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And the other women embraced her.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And that's how my little sister, who is in Israel, remained alive.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And that train rolled down after they dropped off all the women in Stutthof.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Some of the women went in Stutthof and they remained alive because they were transport to working camps.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But some of the women who had children who didn't want to give up the children-- if my mother would have give away my little brother, she maybe would have remained and stayed alive too, because women without children, they took a lot of them to different camps for work, labor, slave labor.",
      "word_count": 53
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But my mother's-- the German came here.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He says, gibt mir dein Kind.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "My mother said, nein.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "This is my baby.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I don't give him away.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "I go where my baby goes.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "[GERMAN].",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "Pushed her on right with all the kids and with all the women and with the old people, and with all the mothers with children.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And she went right into the crematorium.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Didn't want to give up my brother, Solomon.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My sister Miriam told--",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My sister, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She was still-- you know, hearing the stories from the other people.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "There was a lot of women in the camp who were kapos.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "That's how-- they told Miriam.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They told my sister.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "My sister still remained in Stutthof like four, five days till they took them away in different camps.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So my sister came back from work with the people.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Where is my mother?",
      "word_count": 4
    }
  ],
