{
  "stem": "27767.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "My one sister, her-- her name-- well, she was two years younger than me.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Her Hebrew name was-- Yiddish name-- Blima.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And her official name was Wilhelmina.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And I had a smaller sister.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "She was four years younger than me.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "She was born in '29.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "Her name was Khana.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And Anna in-- in Hungarian or Romanian.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And we were living-- we were living in that-- we had only, actually, two rooms beside the living room.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And it was pretty crowded.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And the bathroom was outside.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Not-- we didn't have inside.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We had running water and-- at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And I remember, we had there, if somebody needed the bathroom, they had to go out.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we had running water.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had electricity too.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "That was our own home, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And that was my father got it from his father and-- and helping.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And-- and he built it up a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And so that was our own home.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "It-- it was considered a-- a pretty big house there, you know, at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And we had a yard in the home.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had flowers.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And beautiful-- my-- my mother loved flowers.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And she worked all the time with her flowers.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We had-- [CRYING] [SOBBING] And-- [PAUSES FOR 6 SECONDS] and we did, because there were wood stoves there, so my brother, myself, we always chopped wood.",
      "word_count": 26
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had-- we have-- we had cats.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And we had a dog.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "But there you kept the dog in the-- in the yard.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And we had two, three cats all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "There it wasn't like here-- you have a Jewish area or not.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "That was-- you know, there were some Jews there, around there.",
      "word_count": 11
    }
  ],
