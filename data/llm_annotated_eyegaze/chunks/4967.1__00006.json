{
  "stem": "4967.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And it didn't take long that the German decided that it's no good to have the ghetto on the main road.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So they pushed the ghetto and made it slightly, four streets, smaller.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And in this time, while we'd been in this particular area, the Lithuanian robbed and killed people as well in the ghetto, although it was separated from the other places.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Then the Germans decided to make a judenrat.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "It means a Jewish office and to be Jewish police.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And Jewish people who should see about arranging work for the Jewish people where it has to be required for certain departments.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And they start to register the people of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "And my late father registered as an electrician, as he was a qualified electrician.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And you had to register the family, and the ages, and so on.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And from time to time, the ghetto started to become smaller.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "They used to come into the ghetto, and they used to take away women, children, or whole families for other places to be worked at, like in factories, but not in Kovno itself, outside Kovno.",
      "word_count": 35
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "And they established working camps around Kovno.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "My late uncle was also there.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "They took him with complete family.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And they worked in certain places.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "The main work, the main job in Kovno ghetto was for the people to go to work on the aircraft [INAUDIBLE], where the planes used to land.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "They used to help to service them.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "They used to bring bombs or other explosives that planes should take from place to place.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "And there, a lot of people died.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "They used to march five or six or seven kilometers every morning and back again.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "Food we used to get once a week.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "I think it was coupons.",
      "word_count": 5
    }
  ],
