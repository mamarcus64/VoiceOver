{
  "stem": "15017.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "When he saw me coming out, you know-- when I came out from the dock side at Pier 90, at Pier 90 at 50th Street, he said, my god, come on we're going to go-- you got money?",
      "word_count": 38
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Come.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We'll go to Macy's.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I'll buy you a tropical suit.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "So you spent most of your career afterwards leading bands--",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They weren't cruise ships.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They were--",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "They were passengers.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "The only ship that I was on was a passenger ship.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But in the winter-- that was on the Mauritania-- that did cruises to the Caribbean, to Havana-- uh, what's the-- Caracas, Nassau, Curacao, and all these things.",
      "word_count": 27
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I did that-- wait a minute.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I did another journey.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "After I did the Cunard, I did another journey to South America.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Coming back in 1949.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "That was my home.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You only got time off when you docked.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "They turned you around quickly.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "You're gone.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "My daughter, at the time-- when I was on the Queen Mary-- my aunt from Great Barrington came down to see me.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Because when I arrived in New York, she came from Great Barrington, Massachusetts.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And I told her this story.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "You know, she knew the story already.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And she says, bring her here.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And she'll [HEBREW] with the family.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I will bring her up.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We will bring her up with a family, her cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Because my aunt and uncle-- and they incidentally died out here in California, in the valley-- they had a chicken farm, which they used to sell the eggs, in Great Barrington, Massachusetts.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So I arranged when I got home, I said, Mama, I'm sending Jackie to America to the [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "She says, [HEBREW].",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Because they were getting old.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "You see?",
      "word_count": 2
    }
  ],
