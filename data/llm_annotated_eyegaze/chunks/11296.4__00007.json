{
  "stem": "11296.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "There was one Jewish boy.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "So before we came into this village, it was a square.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "In the square it was a cemetery.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And the cemetery consisted on the people on soldiers who got killed.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And we were standing, and looking on it, and crying.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "It said, look, 20, 18-year-old soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "You could make out the-- the-- the years.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "We couldn't make out the names.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And there was flowers there, in the square, literally around.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And we went out from the square, and we walked a little further down to a-- to a-- a farm.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "There was a house.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "In the house it was beautiful dishes and everything, but there was nothing to-- to cook in the-- in the stove.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So we went outside.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "We brought some woods.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We picked up some woods and we made a fire.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And every day, some from the girls-- every day somebody else had to cook or had to clean up the wagons, make everything nice.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So mine-- I was in-- my sister was already-- she ate already.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Whoever cooked, ate first.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So they went out, some other ones and there was cooking.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We was making bread.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We had flour and water.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So we were making like little breads, because we was afraid for the Polish people when they're hungry not to do a harm to us.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "So this girl-- this particular girl, another one, and my sister-- my sister went away from this-- from the little fire and she went up to-- to the wagons.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "She wanted to straighten up everything on the wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We said, we're not going to stay the evening here because there's not a human being there.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "It was-- in-- in-- in-- in between, we were sitting and starting to eat, we heard a boom.",
      "word_count": 18
    }
  ],
