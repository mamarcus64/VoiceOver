  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Whatever there was then, that we already-- they, they-- plague, that's right.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "That's right, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Not one, but whatever there was.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "You know, like they used to have the seven [NON-ENGLISH], you know?",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Pesach?",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "So this is-- this is what we were greeted with.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And this is what we heard from morning till night.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "So we really-- we, we, we were in no mood, really, to, to pause and think.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "So you-- whatever apparently you absorbed.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I didn't think really to tell you honestly-- I would not have thought then how much I have absorbed.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't have thought how much I have absorbed, really.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Because you couldn't look to the left.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't look to the right.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't-- they didn't want you to see where you were.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "We just were deposited there, to say it mildly, in Blechhammer.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And there was a vast camp.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "There was a vast camp.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "It was huge.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "It was huge.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "People from everywhere.",
      "word_count": 3
    }
  ],
