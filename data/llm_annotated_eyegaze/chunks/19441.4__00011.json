  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "So he said, tell me what you are from profession.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I said, I'm a kindergarten teacher.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I told you there is, is a mistake.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "You are not Jewish, and that's it.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "So then I said to myself, how about using it for the good of the people?",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "So I said, Hauptsturmfuhrer Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "Wirths-- his name I remember well-- if you want here a hospital, then we need like linen-- [PAUSES FOR 3 SECONDS] Keep going.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "--sheets.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Sheet.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We need sheets, pillows, towels, soap.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So he said, that's all right.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And also nighties.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So he-- and I told myself, they are going to kill me for it.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "He didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "He said, all the things you are getting, but the nighties they have wait one day or two.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So the girls was ecstatic.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Where do they get pillows, sheets, blankets, proper clean towels?",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "So-- And these were the girls that were being experimented on.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "They, they just started.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was the start, because they had started the barrack.",
      "word_count": 10
    }
  ],
