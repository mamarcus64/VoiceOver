  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Because it was a relatively, as a concentration camp goes-- because it was mainly inhabited by non-Jews, the regime for Jews, even in the concentration camp, was worse than for non-Jews.",
      "word_count": 31
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "There was a distinct difference drawn.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And even some of the inmates-- might as well-- they may have been caught for some other reason.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "They were criminals, or something.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "So it wasn't all we are united.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "Everybody who has got a prison uniform is the same.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And we all are brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "No, it wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And this Jewish management pushed us into the transport with these Jews, very nice people from Riga ghetto who came.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And we were sent out to [INAUDIBLE], to the same place where our original half transport went.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "Because the first 1,500 people, they were already sent back from-- as a [INAUDIBLE] transport to Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So that is when we arrived in-- it was called [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It's near Erfurt, eastern Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And it was a camp on the lower part of the side of a hill.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And that was the [? summer ?] camp.",
      "word_count": 8
    }
  ],
