  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "We were constantly walking.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "We walked to work six miles a day and six miles back.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were working digging ditches.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And when where we lived in the beer factory, we-- we walked too quite a bit of distances.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So [PAUSES FOR 3 SECONDS] here we arrived, and they're herding us into a-- a room, a big barrack with wooden steps.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "One I had, a woman by the name [?",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Ilse, ?] which one took fancy to me after-- after a while.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She liked my hair very much.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if that was a-- a joke by her or she really meant it.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "But I never got my hair cut account of [?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Ilse ?] liked my hair.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "She always said she going to make a wig out of it.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Sheitel-- she wanted a sheitel out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "So I don't know if she had meant it serious or it was just a joke by her.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "But it saved my hair if-- it's not anything [? but ?] it doesn't grow back.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And I was with one girlfriend in this time already.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "The rest of them-- no, not now, a little bit later.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "I still had all the girlfriends with us.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "And herd us in in a barrack and to take off our clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "But it was cold enough with the clothes on.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "But they took away all the clothes.",
      "word_count": 7
    }
  ],
