  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "If I-- if I at least have-- have another day, a good day.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "If I go from the-- from the-- from the gate, they can't take me back.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "There was a commander, what they called him, Moll-- and-- when they make the airplanes, and done with and their way-- [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So that was-- I get a really good now, you know, from them So I come over there.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "The fellow-- can't-- can't-- he say one-- one fellow is too much here.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Because I had that in my block with 50 now.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And the-- and the work commander was 17-- the [NON-ENGLISH] where the-- [NON-ENGLISH] is when you build, and take stones, like that.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "So I said-- I lift up my hand.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I am here.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "He said, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "You know you're not supposed to come here.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "So what are you doing here?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I said, I was in-- in hospital, like in-- in the revere.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was not such a thing a Jew could have-- won't come back home.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "If a Jew went over there, forget about, Judy.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "The Pollacks never let them out.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "This is 99% of Polish doctors-- some Jewish doctors maybe.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "They were in a Polish name.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So I say-- he said listen.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They let you out?",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Sorry, I was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In the meantime, stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "So I stayed over there, and they give me to-- to a [NON-ENGLISH], like a [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "It was [NON-ENGLISH] were, it was blacksmith.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "It was welders.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I had a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "We were-- we were 240, 250.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
