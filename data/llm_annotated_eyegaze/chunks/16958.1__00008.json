{
  "stem": "16958.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.8,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "All around was valleys and a-- and a river.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "And it was very nice morning.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "Saturday morning.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "It was first day of Sukkot.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So my mother walked with me down the hill.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I tell, Ma, I forgot the bag.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I have to give back the bag.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So she says, stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I'll go back and pack the bag, because there is something that-- if you go back, it's not-- it's not lucky.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "So I was-- she brought me the bag.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And as I walked down the hill, and I start cross over that little river, and I walk up-- up another hill to go there.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I hear a shot.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "I turn around my head, I see Germans around the city.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "See police in this.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I see people running.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We had a-- a big marketplace.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I see people running like maybe 20, 30 people running this way.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I see they can't run there.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They run back this way.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I look around.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I see what's going on.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So I didn't go to the [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I went straight to the forest.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It was a Saturday.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And I was listening to all day, pow, pow, shooting.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I was sitting in the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And in the evening, I thought I'll go back to the [GERMAN] because I didn't eat nothing all day.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "So I go.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "While I go back, I come to the road.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Police are driving in a car and start shooting.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And I hear a bullet just pow through-- near my near.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "So I-- I didn't go to the-- already to my place.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And I run to the field.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And it was-- it was-- it was not cold.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And it was like those corn stacks.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I made myself a-- like a little house.",
      "word_count": 8
    }
  ],
