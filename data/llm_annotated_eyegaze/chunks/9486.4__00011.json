  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And he couldn't take the climate there.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "To go back to Poland or to Russia, I would not go with him.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Then he thought he have an auntie here.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Then he going to try go to Canada.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Canada is the same weather.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "He came here.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And he really-- after he send me-- two months later, he send me a picture.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "That's my husband.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "He gained weight.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And he felt good here.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] He didn't have [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "He didn't have much where to be.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "Like, he told you, he's going [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "[LAUGHS] He came to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "And two weeks later, she put in the suitcase.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] And I can ever thank Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 16,
      "text": "[INAUDIBLE] and Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 17,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 18,
      "text": "She took him in.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 19,
      "text": "And he felt very good and warm there.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] Sometime a friend can be more like family.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 21,
      "text": "And I can that-- I can never tell thank you for that.",
      "word_count": 12
    }
  ],
