{
  "stem": "6110.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "How could she send her child away?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So she came to us and to my mother to ask me, I should give my papers away to her daughter to save her daughter with my life, like they say, you know.",
      "word_count": 33
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't have another way, because she was taking care of my baby.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "You know, she was helping to dress him, to feed him.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have money, didn't have another way to save it.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "So I sacrificed it.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "You take care of my baby, and for that, I let myself go to some other girl.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "So my mother found a girlfriend there.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "This girlfriend got two boys.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And she was moving to Skala.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "She didn't have papers to stay also in ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "So my mother told her to take me with her and take care of me.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "I left the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "And I went to Skala, where she was taking care of me there.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "What did she take care of me?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "She used to cook dinner, or she made breakfast.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "So she gave me some food, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "Meantime, my sister used to send me some money to help me out.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "Look, I gave her my life like this.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "I, I really gave my life for her daughter.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "So she helped me out.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And I used to, every few days, I used to dress as a peasant girl-- you know, the kerchief and, and barefoot, no shoes, shoes in the hand.",
      "word_count": 28
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I used to walk to sneak into the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to see my boy, to see him, how is he doing, how he-- you know, he was growing up without a mother.",
      "word_count": 24
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "He was two years old.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It was-- how old was I? 20 I think, or 21, something.",
      "word_count": 12
    }
  ],
