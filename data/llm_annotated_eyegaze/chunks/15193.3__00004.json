{
  "stem": "15193.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "In the meantime-- Had you known this man before or--",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Never really knew him personally, only through business.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I corresponded with him as the secretary of the [GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I never saw him, I never met him.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But he was a very fine, kind man.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I didn't ask him his religion.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I didn't dare ask him.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And he said, my daughter lives in London.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "I'm going to write to her or call her and see what she can do.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Now, I got word in order for me to enter into England, I have to make a test to be a cleaning woman.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "So they gave me a big house, a two-story house, that I had to clean from A to Z and then professional cleaners would come in and see if I did a good job.",
      "word_count": 34
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "That set-- the-- the Jewish community set that up.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They-- they-- I don't know what they got in touch with, but they set it up for me to clean that house.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So I get the permission to get a house cleaning job.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "That was a test.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "My own house, but not anybody else's.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And so I got an A for my test.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So that was good.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "She found out that Professor Norman Bentwich, who was the head of the Kitchener Camp and had a summer cottage in Sandwich, he lived in London but he had to go to supervise now and then to Sandwich.",
      "word_count": 38
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And he needed a housekeeper in his cottage in Sandwich, was not far from the Kitchener Camp so I got the job.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And I was able to go.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "By letters and telephone.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I never spoke to Professor Bentwich, but she made all the arrangements and my husband was allowed to pick me up.",
      "word_count": 21
    }
  ],
