{
  "stem": "26609.12",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "They took me in.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And there was a fat man sitting behind his desk, Chief Gestapo.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He was a very good man.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I tell you later about him.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "A very good man.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But he was only sitting, writing down name and [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Then two SS men-- these were the, was young men, tall young men-- they came in with huge big, big slices of bread and butter, so high butter on top.",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "They thought maybe I want some food, and I tell them, I'll tell them my name if they offer me some.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They ate it and came-- two men-- they came up to me and said again, what's your name?",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I said, Wanda Grabowienska.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I could hardly bring me, you know, myself to talk to them.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "One hit me so hard on my face with his big hand, hit me when I said Wanda Grabowienska because he believed it's not my real name.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Hit me so hard that he nearly got my eye out.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "It started to bleeding through the nose, and eye.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "My whole face was in blood.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And that Chief Gestapo looked at it.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "He couldn't-- you know, he was a Chief Gestapo, but SS men, they had much more power than himself, those young men.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "You couldn't tell them stop.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Do you remember his name?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He didn't say, no.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He didn't say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they thought that I would start crying, because anyone, if you hit them so hard, so, but so hard that I felt the, a pain in the back of the head and blood running.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he thought-- they thought that now I will tell them.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And again, what's your name?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Wanda Grabowienska.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So they couldn't believe that I'm Jewish.",
      "word_count": 7
    }
  ],
