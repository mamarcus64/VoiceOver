{
  "stem": "7722.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Do you know on the-- not the-- because in that time, there was the British mandate, and they didn't let us.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And they were-- and they were going anyway, without asking them.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "So many from-- many left for Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "My wife did it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And I was ready to go to Israel, and I wanted to go.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "So my wife had.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "My younger daughter was born in Eschwege in 1947.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "She was born in Eschwege.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "So my wife--",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Bina.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So my wife-- I didn't know I had cousins got in touch from the United States, got in touch with us.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And they send us up a package, and they send us papers.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We should come to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And my wife insists she wants to go to the-- to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Because her first cousin, what we took her apartment, it so happen my wife was born after 23 years.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And the cousin whose apartment we got, her mother died.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And my wife's mother, she didn't have children.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "She took her in and she brought her up.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That cousin.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Her name is-- her name was-- well what is it?",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Let me--",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So she did insist.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So we came here to the-- to the states.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I wanted to show you what kind of a person I am.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "All the DPs who came here that [INAUDIBLE] took care of them, put them in in hotels, gave them later apartments, gave them money.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "When I came here, the cousins-- I had cousins, my wife cousins.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They-- they helped us, and I told myself I will not take up any [INAUDIBLE] from the-- from the Joint.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "So I help my wife's first cousin at-- at the shop.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "He made dresses, a shop.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "He was a-- a contractor.",
      "word_count": 5
    }
  ],
