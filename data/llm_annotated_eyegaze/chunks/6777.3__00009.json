  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Well, I've-- in the same compartment, the same wagon, or carriage, or whatever you call it-- it was a cattle train.",
      "word_count": 21
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And 100 or 120 people have been crowded into it.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "You could hardly place-- hardly a place to stand.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "But some people have been determined that they won't make it and gave up all hope.",
      "word_count": 16
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "But other young people didn't think like this.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "And especially young boys came to the side of the wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "The wagon was in the shape of a rectangle-- long, long and short across.",
      "word_count": 14
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "And there wasn't-- haven't been windows.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "But there have been tiny, little holes, just the width of one board.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "And two of the strong young men, or boys, or whatever you want to call them, have managed to push out one more bit of the next board.",
      "word_count": 28
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "And whoever wanted to jump, take the risk of jumping, came, squeezed to this little opening.",
      "word_count": 16
    }
  ],
