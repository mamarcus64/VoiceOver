{
  "stem": "19242.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.7,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I come back to Appleton, Wisconsin.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They sponsored me.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish-- what do you call it?",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish-- UNRRA or--",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Joint Distribution Committee.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Who did you come to here?",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Didn't I tell you how I find a relative here?",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I come to Appleton, and I stayed about three months.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Or two months.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "The-- the-- Joint Distribution Committee says go over there.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And they-- they'll find a job for me.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Shovel coal.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] In a-- in a stock room there.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "But I didn't know it.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "You know that they-- they asked me, why were you-- you know, you come out of the job.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "You're all black.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And they all asked me, you like it?",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I say, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "How's the job?",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "The job-- you know, as a young man I used to work hard.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "Is the job hard?",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "Then the men-- the men from the store said, you know what?",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "You're going to know a little more English.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "I have a better job for you.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "This is a starting job.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "I want to see if-- how good you're going to do with that.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "And then he says we're going to move you up.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "You can be a salesman or something.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 15,
      "text": "And I says good.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 16,
      "text": "And the main thing there was, I'm not a Jewish guy.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 17,
      "text": "He's a refugee.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 18,
      "text": "He's younger than me.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 19,
      "text": "So he said to me, you know what?",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 20,
      "text": "We're going to go to Milwaukee.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 21,
      "text": "Do you want to, I mean, do you want to go with us?",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 22,
      "text": "He had a car.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 23,
      "text": "I didn't have a car.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 24,
      "text": "I didn't have a car till 1955.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 25,
      "text": "I figured I don't have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 26,
      "text": "I don't need a car.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 27,
      "text": "And he had a sweet car.",
      "word_count": 6
    }
  ],
