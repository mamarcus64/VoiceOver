    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Today, I'm 78.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Lublin [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 13,
