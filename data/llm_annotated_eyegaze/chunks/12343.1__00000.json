    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Moshe ?] Kashemacher.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "When you're born, they give you the name.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Mucemacher.",
