  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "The whole night, people-- you know, they preferred the Russians than the Germans, and so that's-- you know, especially in Chelm, it-- the First World War was also Russian people.",
      "word_count": 30
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And that was-- and they went on.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "It was-- took two-- two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "They were two weeks in Chelm.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No, not that time, not at all.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "When-- you think, when Poland was in Poland-- look, I knew I was Jewish, so I didn't have pretenses.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So the-- the Russians were two weeks, and then they start to move out when they made the-- the border.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "So the border was behind Chelm.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "The River Bug was the border.",
      "word_count": 6
    }
  ],
