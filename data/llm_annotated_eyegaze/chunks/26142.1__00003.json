{
  "stem": "26142.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And it was around in the city of Munkacs.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And this was 1933, at the depression time.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "My parents could not afford to send me to-- to high school, because you had to pay tuition and upkeep.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "My father had a sister that lived in the city-- in [?",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Noitserlich ?] the Hungarians called it.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Noitserlich. ?] The Jews called it [?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "Serlich, ?] Salich-- there was a Yeshiva organized by the Supreme [?",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "Carraba, ?] which was-- the Yeshiva's name was [HEBREW].",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So after my bar mitzvah, I was sent into that Yeshiva.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Because in the same city, my father had that sister lived there.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "So I was-- I had where to stay.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I stayed with my-- with my uncle and aunt there.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And the Yeshiva happened to be just a block away.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And so it was very convenient for me to be close there.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And I-- and I stayed there for two semesters.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "After I finished two semesters, I grew up-- within one year-- as tall as I am now.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And I came back sick from the city.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And my parents took me to-- to the doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I was very thin, and tall, and he suspected that I might get TB.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And he advised my parents not to send me to the-- back to the city.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Stay here, and-- which was in the country, like very fresh air.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So my parents hired two tutors to continue my Yeshiva education in Torun.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "One of them-- the one of them happened to be a teacher that was the same age as my older brother-- older than I was-- about 25 years older.",
      "word_count": 29
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And the rabbi's son that was a scholar and in Talmud.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And that-- I continued-- they continued to teach me.",
      "word_count": 9
    }
  ],
