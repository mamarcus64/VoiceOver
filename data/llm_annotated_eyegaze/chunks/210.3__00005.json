{
  "stem": "210.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "After I die, I don't want, want to be thrown down like that.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I just-- I don't know how.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I got down, and I just sat down at the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "There was-- let's say the barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The [INAUDIBLE] were until here.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And there was a wall, let's say, like over there.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I just-- I don't know how I got there.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I just sat at the wall.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And other girls, you know, when they walked by with a little water in their pot or whatever, they would wash my face.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "They would get me to drink some water.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And slowly-- and they would bring me some soup because I couldn't help myself anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And slowly, slowly, I got stronger.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And, and somehow, I got out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "I don't know how, but I got out of it.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Let's see, when I got better, they took us to-- a whole bunch of us.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "They picked out always the ones that were looking better and still able to work.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And they took me-- and they took us to-- again, we had to stand in line.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And we didn't know where we're going, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "And sometimes, they would, like, make-- let's say they would count, let's say, so many rows, you know-- let's say 200 or whatever.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "And I would be, let's say, the last one.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And they would ask us to go.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "They took them out and-- I don't know where they took them.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And they were the last one.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "Then the rest could go back to the barracks.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "This went down for all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "Anyway, at that time, they took us to Stutthof-- no.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "From-- to this-- to this camp where we worked.",
      "word_count": 9
    }
  ],
