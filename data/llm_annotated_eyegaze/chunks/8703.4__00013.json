{
  "stem": "8703.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And I was working for one-- at that time, I had to-- I checked on two places, because one guy who was responsible for the-- for the production escaped.",
      "word_count": 29
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "So they made me work on two places to check.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "From this place, it was one block from one hall to the other.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "I had to go to two places.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So one Pollack came to me, and he said, would you like to buy bread?",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Where is it?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "OK, come in over there into the neighboring hall.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Over there, we have bread.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Come in in five minutes.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "In five minutes, I came.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And he said, I ask him how much.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "He said 20 zloty.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I take out the 20 zloty, and I gave it to him.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Meantime, another guy behind me, which I didn't know, threw a blanket on me.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And all of a sudden, they started hitting me-- I don't know how many guys-- hitting me, and I fell down.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "They beat me up so badly.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And they took the money.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE] They took the blanket away, and they ran away.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "All right.",
      "word_count": 2
    }
  ],
