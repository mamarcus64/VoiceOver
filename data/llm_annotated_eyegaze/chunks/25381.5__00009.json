{
  "stem": "25381.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I have another concentration, another ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He says, what do you mean?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I say, if she world cook at least one day a potato soup, or a potato.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I say, just every day, just peas-- you know the green peas-- every, single day, pea soup, and pea soup, and pea soup.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Not a piece of meat, no anything.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And I'm starving until-- and I told him about the bread.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And I say, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "If you don't believe me, then you can ask Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Grushkin-- the lady that lives with her.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Call her up and ask her.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And I tell him the story, that she took me to-- to A and P, to the market.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And she takes such advantage, you [NON-ENGLISH], excuse me-- you know, you [NON-ENGLISH], and you [NON-ENGLISH], you this, and you don't know how to turn on the light, and this.",
      "word_count": 30
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "She's not even a citizen.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "She doesn't even know how to read and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "She is the American.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I'm the nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "You know, because we survivors-- we're-- Anyway, so he was so upset.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I fell, almost faint.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't breathe.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And they were crying, too.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And he said, she's such a good-for-nothing, and she tells me that you have a paradise at her house.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "You're not going to stay here for Passover.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So on Grand and Wildemer he had two daughters, at two-family flat.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "One lived downstairs and one lived upstairs.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He took us on the-- on the attic.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "OK, I had a little electric lamp, a little electric, you know, that-- a burner, with the burners.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So in the bathroom, I put it in.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "So I went, and I went to the butcher.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I bought, already, a-- a kosher chicken.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And I had, already, I bought a pat, and a bread.",
      "word_count": 11
    }
  ],
