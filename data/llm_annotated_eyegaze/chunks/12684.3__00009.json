  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And when I heard that I had scarlet fever, and I had to run, and I had to be in isolation, I knew I had to cross the street with all these cars going back and forth to Prague, that I had to see him before.",
      "word_count": 46
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "Because I knew he might die.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And I went to see him.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And he said, I have one eye, but I can see you have scarlet fever.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I told him that I would be away for six weeks, and I was afraid I wouldn't see him anymore.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And he said, no, I wouldn't.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Have a kiss goodbye, and I left.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Do you know what he was sick with?",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "It was something in his eye.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Plenty.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
