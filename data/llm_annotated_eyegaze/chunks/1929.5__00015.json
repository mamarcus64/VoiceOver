    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "We had a death certificate.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "The Germans kept very good records.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "We have a-- we had a-- actually, a-- a death certificate of his death.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Probably, a few months.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No, not to my knowledge.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I would have liked to have been with him.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Yes, now I would.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "But then, I didn't feel like I should.",
      "word_count": 8
    }
