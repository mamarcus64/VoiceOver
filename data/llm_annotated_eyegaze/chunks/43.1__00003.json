{
  "stem": "43.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto I was-- I am the only one what I was working in the ghetto-- only one.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And my-- my sisters was already-- one was 35, 40-- in the-- in the-- in the 30s and the 40s, my sister were.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So-- and-- and-- and one sister got nine children.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "One sister got seven children; and the older from me, three children, and my three children.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And it-- it was-- it was very bad.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I was working by potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I took out potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So I sometime I put in a few potatoes here.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I brought it home.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But it was very bad with food.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So I am the only one what I speak a little English and Ukrainish, of course.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Because they didn't-- they was very good in Hebrew-- all of them only in Hebrew school.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They didn't-- so later, I was only in the Hebrew school.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And I was going out from the ghetto to make a place.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I was going out from the ghetto, mostly every other night.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Sometime I took-- we took a blouse, sometime a sweater.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And we-- we were up, and I brought a bread.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And-- all of a sudden came the Judenrat-- and told me that I got a farm.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I have to go to work for the Germans, the-- in the Yiddish farms and the Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So I told them I wouldn't go without my children.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "My sisters can-- can go out to bring for their children.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "What shall I do?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But I-- so I told the Judenrat I will not go.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And if he will even kill me, I wouldn't leave my three children.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The little one was a year and a 1/2 old then.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So and I didn't come in a few days.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So you have to go out.",
      "word_count": 6
    }
  ],
