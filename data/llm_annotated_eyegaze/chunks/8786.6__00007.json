{
  "stem": "8786.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They were first cousins, and it was beautiful, so far beautiful that this lady is still our guest, when she just has the strength to come here.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Here-- years ago, every Shabbos he was here, every Yom Tov he was here.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Now, a little bit less because she's not that strong.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "This was the story of my coming out.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I brought her-- I brought him out, then I brought her out, because she was actually not my mother.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I established a rule-- I found a-- I found a loophole which says-- I found it in the application for the immigration office-- that if your stepparent becomes your stepparent before your-- before your 18th birthday, she has the same rights as a real parent.",
      "word_count": 45
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I came up to the 70 Columbus, and I showed them this paragraph-- in the small letters, small prints-- I said, have you never heard about this.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "I said, I didn't put it in.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "Look at it.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And they went up to the supervisor, after supervisor's supervisor.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And he says, this young man is right.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "So it was-- it was one of those things I'm very proud of that I did find a legal way to have her out also.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "Today, the-- the-- the doors are open for every-- they don't ask questions.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "Today you don't need-- those days when we came here, you had to have all the papers, plus a financial certificate.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "Somebody had to guarantee that you're not going to fall on the government's neck.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "They're not going to-- you're going to be on your own.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "They wouldn't have to support you.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "But those days, it was hard.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "Today those-- the gates are open.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "Every schlimazel could come in, and they do.",
      "word_count": 8
    }
  ],
