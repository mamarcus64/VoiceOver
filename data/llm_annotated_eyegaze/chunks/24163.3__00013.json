  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Even so, when, in the latter stages of the war, in particular around the time when we were ready to invade Germany, we were issued weapons, because they no longer respected the Red Cross, which we wore around our arm.",
      "word_count": 40
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And we had many casualties where they bombed ambulances, as well as killed Red Cross-- medics with the Red Cross badges.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "So we were issued weapons later on.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "But all through France, we were just active, running a field hospital, both treating our wounded, as well as some German prisoners.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We were always attached to a combat unit.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "A field hospital is the front line hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "That's the first unit-- the moment somebody gets hit or wounded, that-- the moment that happens, they put them into a field hospital.",
      "word_count": 23
    }
  ],
