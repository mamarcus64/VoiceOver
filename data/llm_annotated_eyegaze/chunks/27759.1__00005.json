  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "All the states where they had these camps.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "They were segregated.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "You get passes and go into town.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And at Camp Forrest, you had [INAUDIBLE] you-- you could go to, or Memphis.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Well, generally as a rule, we would find black communities.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And we were treated well.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of places I had read about when I was in school-- when I'd go on pass, my chief interest was to see these places and visit these places, like Meharry.",
      "word_count": 33
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "It was a black university there in Tennessee, in Nashville.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I'd go out there, meet with different persons.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And then there was a Jackson [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "I'd go there and have lunch.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And stayed at the YMCA.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, in the white community, they had their restaurants.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And in the black community, they had their restaurants.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Most of the restaurants that I frequented when I went into town were black.",
      "word_count": 14
    }
  ],
