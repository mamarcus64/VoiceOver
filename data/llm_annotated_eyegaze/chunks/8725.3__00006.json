{
  "stem": "8725.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "She didn't want to take me or my sister because we were pretty young girls.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She say, when I take you, they take you to the pleasure homes.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Because that's what they did with pretty, blond, nice, young girls.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So she left me-- us with aunt.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We cried and cried and cried.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But we were alone now.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Janina did have work.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "One day, I was going to church for religious service.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "When I was coming out, the church was surrounded.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "There were Wehrmacht Nazis-- surrounded.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "They took all the young men and women.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They let the older people and children go.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "They took us on the trucks.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And they brought us to special encampment to be sent to Germany to work in the fields.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Because they have the, the Jewish people-- they, you know, they brought them to Poland and this.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "But they needed-- in Germany-- workers to factories and fields.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "So we were in the encampment.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Somehow, I was able, through the fence, to give people passing by to notify Helena Pavlovska, my, my aunt and my-- that I am here.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And I remember Janina came, wanted visit me.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "Through the fence, she wanted to get in to me.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "She wanted to go with me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "I pleaded with her.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "I say, at least-- I said, I don't know what will be with me, where I go.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "You have to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "That night, I remember [PAUSES FOR 3 SECONDS] that some-- a few of these young Polish men, they tried to climb the fence and get out.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "They were shot.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "That was in Radom, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And next day, I was prepared to leave.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Instead that, about 10 German officers came.",
      "word_count": 7
    }
  ],
