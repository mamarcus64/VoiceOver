{
  "stem": "13213.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the boss here at the company I worked for had to mentioned to me many times if I want to go to work for same company here, he would be glad to move-- pay for my move, and at the same time, guarantee me a salary.",
      "word_count": 47
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So I came here for one year, tried it out, I liked it.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Everything worked out OK.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Everything worked out OK.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Then my other daughter, Yona, finished a bachelor's at McGill in commerce came to Toronto, too, and got a job-- a very good job with a bank.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Then my youngest one, Sheila, finished McGill as an engineer, mechanical engineer.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And she moved here.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And my wife was a teacher in Montreal, with a public Jewish school-- people's school called Judische Volkshochschule.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And she moved a year later when I was here already to Toronto.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And we bought this house.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "We got all settled.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "We're all happy.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Then, thank god, the kids, like I said-- the girls-- got all settled on their jobs.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "Anna got married to a nice young man, Jerry Silverberg.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And they have now a boy, nine months old, called Jason Saul.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "And a lovely young couple, and a beautiful grandson, I have.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And then, Yona got married to Earl Weiner, also a young man, a nice man.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And they have a son named Colby after my brother-- alav hashalom-- Yakov.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "And he's is three and a half years old.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And then Sheila got married to a nice young man, Frank Friedman.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And they have a beautiful daughter named Eliza, four years old.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "All my son-in-laws are graduated of university.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "Frank is a CA.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning, I didn't want to talk to anyone about the experience.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I just couldn't face it.",
      "word_count": 5
    }
  ],
