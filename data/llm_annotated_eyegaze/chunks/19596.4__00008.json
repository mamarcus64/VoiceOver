{
  "stem": "19596.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "A bit of singing, a bit of this, a bit of that, that's about it.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "There was not much entertainment.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "The only entertainment that the-- the SS got, you see.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "If they get a boxer like Saunders and they put another one against him and they were all sitting around.",
      "word_count": 20
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And they let them thresh it out and they were-- that's the way they were entertaining themselves.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "It was a friend of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He was in the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "He was champion of Holland, a boxer.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "That's the one who survived.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "He's in Curacao.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Boxing.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "They put even SS against him.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "He beat them up in the ring.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Not very-- they laughed.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "You're asking me about atrocities.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I saw atrocities.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I saw Orthodox Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "They put them into thick coats, into ladies' fur coats.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "They put rope around them and they put them thick Russian gloves on and Russian caps on.",
      "word_count": 17
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "And they put Dobermans on them and they torn them apart.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "In the camp.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't know when. '42, '43.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And they were laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "That was the SS entertainment.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I was doing [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "That means cleaning the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "I was doing that.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And sometime-- once I was helping in the-- in the hospitals.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "I was doing that, helping a bit and carrying a bit and doing things.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "And other work I did in the camp, I was also in the [NON-ENGLISH], I remember now.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "That means in the-- it's called-- you know, to help the waterworks.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh, dig-- dig-- dig channels and put pipes in.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We did that too.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And once I had a bit of bad luck.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I struck one of those [NON-ENGLISH] and he was completely drunk. he got hold of us, two guards.",
      "word_count": 18
    }
  ],
