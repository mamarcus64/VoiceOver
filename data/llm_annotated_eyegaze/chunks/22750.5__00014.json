  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "They would come in there, in the beginning.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "And to them we are trust because we were waiting for them.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 8,
      "text": "Now, some people who came to the Russian, only the Russian.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 9,
      "text": "Because in our area, the occupation was from the Russian people.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Well, if-- if I see them?",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Some of them.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see them.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "If I see them, they will see me.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "I was maybe, 10, 20, you know, meter or from them when they went by.",
      "word_count": 15
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "And I sit in grass.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't see me.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "If they see me, I would be underground already.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Everything is, if you are believer, I'm not so sure for nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "But if God will, if you believe in God, to survive, he made them sleepy. then I saw them.",
      "word_count": 19
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "They didn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "It's only by a miracle, if you believe in a miracle.",
      "word_count": 11
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "I am not a-- such a strong believer.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "But on this subject, only in miracles, it's happened to me.",
      "word_count": 11
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
