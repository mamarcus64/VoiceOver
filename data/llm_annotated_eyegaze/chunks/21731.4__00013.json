  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They were very pleased that the Poles were killed.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They were very anti-Polish, the Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So when on the-- I think the first of October, the-- '44?",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The truce was signed by the-- it suddenly was quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You can't-- can't imagine what it was suddenly quiet after all that bombardment.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It was the first time, I think, minesweepers were-- we called it [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "That means cows, because the sound of it was like, what is the sound of a cow?",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "But it was like that.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We called it [NON-ENGLISH], and that were mines which they fired from far away.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "That was the end of the Polish Uprising.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "That's the end of--",
      "word_count": 4
    }
  ],
