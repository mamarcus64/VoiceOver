  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "And the day before, Wallenberg came to the ghetto and had discussions with the Jewish official people.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "But they didn't speak German.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And because my German was school German and good German, I was translating between Wallenberg and the Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And as a matter of fact, there was a woman with him whose name was Asta Nielsen.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "Asta Nielsen is a very well-known-- or was a very well-known actress in Sweden, like Ingrid Bergman.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And she came, accompanied Wallenberg.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] And I translated.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "And Asta Nielsen gave me her card when we were in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "And they were there as guests.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "They didn't stay in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "But on Christmas day-- night, 24th, Wallenberg has gotten permission that he takes out 12-- no, 23 Jews from the ghetto.",
      "word_count": 21
    }
  ],
