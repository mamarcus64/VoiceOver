{
  "stem": "11067.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "She stayed in England.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "She became a Christadelphian.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "She became a nurse, and she stayed in England.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Her family was completely annihilated.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "Once we were in Kenilworth for a couple of days, the four of us were then taken by Mr.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "Laxon to homes that said they would take refugees.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So we went to the families, and I was taken by the first family we went to.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They were a young couple, about 28 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They had a little boy who was 13 months old.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I was chosen purely by my name.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They knew nothing about me.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "These people knew nothing about us.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They volunteered to take us in.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was chosen purely by my name.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Their little boy was named David.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Had it been a girl it would have been Suse.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "The other three were taken in by three other families.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "There were-- the Coventry ecclesia, or congregation, was about 100 families, I think.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Out of those 100, there were six of us that lived with Christadelphians in Coventry.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "It's a big percentage when you think about it.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "There were some others taken in in Coventry.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "The cathedral sponsored a couple of people-- the Coventry cathedral-- and a couple of other people.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I stayed with the Parrys, George and Florence Parry.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "They-- of course, immediately we wrote to my parents to let me know where I was, my address.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "This proved to be very, very important later on.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And my foster father outlined to my father what would be taught to me as part of their religion, going to Sunday school or going with them to their services.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Of course, my father demurred.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I mean, you know, what was he going to do?",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "He wasn't going to agree.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "This was not anything Jewish.",
      "word_count": 5
    }
  ],
