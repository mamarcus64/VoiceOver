{
  "stem": "11272.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And we acquired enough land to, [PAUSES FOR 3 SECONDS] to start building and developing and eventually a little house, something like 15,000 people.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And we have already about 5,000 families living there.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And we have shopping centers and office parks and rental property and single-family homes.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And we built 16 lakes on the property to create a community that everybody will enjoy-- those that can afford better, as well as those that can afford very low.",
      "word_count": 30
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And we have been very fortunate there.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "We are very happy there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "The people-- we started a soccer program, second to none.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "We were very-- my brother was very instrumental in the Atlanta Chiefs soccer team.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And we have 16 soccer fields in our property.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And I'm still active and try to play there.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "It's just a great community, wonderful people.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was very fortunate.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I met a girl on one of my trips to the bank.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was anxious to introduce me to Jewish girls.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And this guy came-- and first time when I met my wife, I wasn't interested at all.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But I guess she went on a diet.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And, and she became extremely attractive.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And then the vice president came.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "You got to meet this girl.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And I said, no, I don't have time.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I got to go out of town.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "As I was leaving, this girl comes over to me.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And she says, [PAUSES FOR 4 SECONDS] happy holidays.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I said, how do you know it's my holidays?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And she said, [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "That's a happy new year.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And I looked at her.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I said, I didn't know you were Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And next thing I knew, I went on vacation.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I said I found my girl.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And I want to marry.",
      "word_count": 5
    }
  ],
