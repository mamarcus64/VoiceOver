  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "The reason I wanted to elaborate a little bit more on-- on my mother, her affiliation, there was a very fine Jewish organization affiliated with Zionism.",
      "word_count": 26
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "It was called WIZO.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "And my mother went-- she was, of course, raised in Plovdiv, but when my father married her, they went back to his city, Gorna Dzhumaya.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "And she founded the chapter of WIZO in Gorna Dzhumaya.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "And she was not a woman libber.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "It's not like today that it's so much in vogue.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "But she was in the women's suffrage, you know, foreground.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "When it was unheard of, she went to school, she graduated high school, she-- she took her teaching credential.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "She studied.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "She organized.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "She was always super social.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "And if I have any appreciation of fine art, and music, literature, I owe it to her.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "Because as my father would be traveling for weeks at a time abroad, I would be really going with her to all these fine things with her, with her sisters.",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "So I grew up in this kind of atmosphere from day one.",
      "word_count": 12
    }
  ],
