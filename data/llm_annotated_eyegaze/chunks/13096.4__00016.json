  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "But no-- nobody tried to escape or to evade or to [? then-- ?] because we can't.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "You know, we couldn't.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "There were, you know, these-- these Germans there in the towers, five or four of them, with their guns pointed to us daily and nightly.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And they wouldn't stop that.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So we couldn't do a thing.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And then all these wires, you know, they were electric, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "If you touch them, you will die instantly, hot-- high voltage.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "[BACKGROUND NOISE] Did you ever stop believing in God--",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "That's what I say, never.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I say, God will take us out from here.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "God will-- how the-- you know, he took us, the-- the Jews, out of Egypt, how he makes so many miracles.",
      "word_count": 21
    }
  ],
