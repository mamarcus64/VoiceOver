  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 41,
      "text": "This was an emergency number, for heart attacks, and other things.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They were running over the streets with fire engines.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And they rang the bell, on the third floor.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "When they walked in, I didn't know this is oxygen.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I knew my aunt had the-- [PAUSES FOR 4 SECONDS] she was selling sodas and ice cream.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "So this was like for sodas to make.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "So I didn't get scared.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I-- I thought it a-- something for water.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "When I-- when they saw me-- who's sick?",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And I said, I am the sick one.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "You the sick one?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "You called it.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "Where did you get this number?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "I said, I had in my mind.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I have-- I was very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "So we waked-- I woke up a neighbor.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And she explained.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "If I wouldn't be a newcomer, I would be very punished at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And later, we moved in an apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I had a very nice apartment-- one bedroom.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But I had a living room, my eat-in kitchen, and a foyer-- comfortable.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We came with a little bit money.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "So matter of fact, those things what I have here in the closet, we shipped in boxes.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "We could have take everything.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I-- I don't know [INAUDIBLE].",
      "word_count": 6
    }
  ],
