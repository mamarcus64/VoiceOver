{
  "stem": "3097.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "[PAUSES FOR 3 SECONDS] My mother had a-- also a sister, was married to a man by the name of Koliszewski in Warsaw, who was in the business of lumber-- a wholesaler of lumber.",
      "word_count": 34
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "And she had also-- well, she [INAUDIBLE] my aunt had two sons.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "One was an engineer who emigrated to France, quite a few years prior to the war.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "And another son, who went there in 1936, to France to study, and he's still alive.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "He's now 81 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "I just talked to him on the phone a few days ago.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "And he still lived there.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "And I was supposed, in 1939, to go to France to study medicine.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 46,
      "text": "But the war came out, and destructed all-- destroyed my all plans.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 47,
      "text": "My father's side, he had two brothers and a sister.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 48,
      "text": "One brother, Henry, was a dentist in city of Kielce.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 49,
      "text": "The other brother, Solomon, was married to a lady by the name from home, Lola Freijzinger, who survived the war on the Aryan papers and died a few years ago in Israel.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 50,
      "text": "And her son lived also, and survived the war on Aryan papers, and died about two years ago in Israel also.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 51,
      "text": "Also, he had a-- another one, was a-- that was Solomon.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 52,
      "text": "It was also a sister, Sophie.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 53,
      "text": "The sister, Sophie, was not married.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 54,
      "text": "She'd married quite late, to a Pole-- a Christian Pole-- who was a secretary of the court in Kielce.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 55,
      "text": "And this is the man who located my sister, my aunt, and one of my cousins, in a ho-- in a home near a forest during the Holocaust.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 56,
      "text": "And in this-- this home was destroyed by the Polish partisans.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 57,
      "text": "And they killed everybody there, and they burned the house.",
      "word_count": 10
    }
  ],
