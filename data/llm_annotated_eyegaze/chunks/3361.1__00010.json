{
  "stem": "3361.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They took all of them, and they sent us to--",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Young boys, older boys, whatever they could they--",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Girls, too.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They took us and they send us to Donbas.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And there-- and that time they were working hard in the coal mine, and we didn't what nothing to eat.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "We came in in the-- in the restaurant there to eat, and there was a soup, a piece of cabbage was swimming in the soup.",
      "word_count": 25
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But they give us bread.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "If we were giving eight tons coal a day, we were getting 800 grams of bread a day.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "But beside this, we-- once a week we had-- or a piece of fish or piece of meat, once a week.",
      "word_count": 21
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And the rest of the week we had only--",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In Donbasm Voroshilovgrad.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "This is the-- this is-- Donbas was the coal mine.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "With I and digging-- knock out the coal from the walls.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Knock out, this I was doing.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They showed us what to do, and we were doing.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Anyway--",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they had to special barracks for us to, to live in it.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I had the friends that we went together.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We had friends.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "But anyway, then one time came down, the main engineer from the coal mine.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And I was working-- I was a hard-working man.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I don't fool around with the work.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "I do work.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So he saw me working and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And I-- the time should go by, I was singing Jewish songs.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "What were you singing?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "What songs would you sing?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Oh, [SPEAKING HEBREW], you know--",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "[SINGING IN HEBREW] Oh, I forget already.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[SINGING IN HEBREW]",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So he heard me singing.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And he says to me, I want to see you in my house.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I have very important.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I went to his house.",
      "word_count": 6
    }
  ],
