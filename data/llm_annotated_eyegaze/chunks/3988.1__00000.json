{
  "stem": "3988.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Steve Lewkowicz.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in Poland, a small town, Boleslawiec.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "That wasn't too far from the German border, I would say about three, four kilometers.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And the biggest city to mine was Wielun.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And the biggest one was Lodz.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born December the 2nd, 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Approximately 70, 70 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a small town, mostly farmers, and with a few Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I would say approximately maybe about 100 Jews lived in that town.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And we had our own synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We had a [POLISH], what you call.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And mostly the Jewish people were in business, you know, or were tradesmen, you know, went to villages, brought-- went to where we bought some eggs, chickens, you know, brought in town, you know.",
      "word_count": 34
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And they sold them to the people.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And that's how we made a living.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father did.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "He went to-- to village to village.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And he used to buy a couple chickens, a couple dozen eggs, a pound of butter.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And he brought them into town.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And he sold them.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was [?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Moshe, ?] Moses, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And with the money, you know, we made-- made a living.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "You know, it wasn't much, but we made a living.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Bluma.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And she was a housewife, you know, took care of her kids.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I had two little sisters, and me, and my father, and mother.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My sisters' name was Gitel and Leiba.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I started-- when I grow up, I started to go to school.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I went to Polish school in the morning, like from 8:00 till-- till maybe 12:00, 12:30.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I went to Polish school.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Then I came home.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "My mother used to make a lunch.",
      "word_count": 7
    }
  ],
