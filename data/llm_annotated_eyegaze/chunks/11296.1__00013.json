  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "As the restrictions came more and more, and you had less and less food, what other-- where was your sisters-- your two married sisters at that time?",
      "word_count": 27
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They was there.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They was in--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "My sister was in the ghetto-- both of them.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "One husband-- my youngest sister-- was a tailor.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And he was working for-- for the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "He was-- he was a very good tailor.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They converted it for all trades.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So there were shoes, this and that.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "There was-- there was tailors.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And there was jewelry men, watch makers, everything.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "They came in, you know, they wanted suits.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "So he had to supply.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "They didn't supply the material.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "You had to supply the material.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "You had to supply everything.",
      "word_count": 5
    }
  ],
