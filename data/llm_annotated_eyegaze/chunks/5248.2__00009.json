{
  "stem": "5248.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "We thought it would be more safe.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We had some friends.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "But it really was not.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Well, the things more or-- more or less repeated itself.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "We knew in Lwow there was police-- police was every-- Jewish police in ghetto was a very-- very powerful force.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Like in large ghetto, there was this famous man, Rumkowski.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "In Lwow, there was a man by name Boris Rojzen.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Boris Rojze, R-O-- R-O-J-Z-E-N.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And he was actually from Rowne.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And the Russians were after him.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "But he fled.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "He was hiding in our house.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "But then he fled.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And they never found him.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And then, again, he came to Lwow.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "He must have been close to a German side and then had some good connections.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And then we found he-- that he's a police chief in Lwow.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And he, he and his wife and, and their child, we knew them from Rowne.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "So we saw that there were other people from Rowne living in Lwow.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "So we thought that might be safer.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "But--",
      "word_count": 1
    }
  ],
