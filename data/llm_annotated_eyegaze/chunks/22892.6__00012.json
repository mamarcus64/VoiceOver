    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And Cookie was around eight.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Leah was a cousin of mine that-- she was an older cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "She's still alive.",
