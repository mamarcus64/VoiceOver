  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "They felt themselves more German than Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "Many of the German Jews were like that.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "I mean, my-- my-- from both my father and my mother's side, it goes back many generations.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "I mean, I tried to check out-- when I was in Dinslaken-- on my father's side, there's no way of going-- finding [? that ?] [? today. ?] What I could find from the grandfather and the great-grandfather all were from the same area in Germany.",
      "word_count": 46
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So they felt themselves very German and, then, Jewish-- you know, of the Jewish faith.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And so it wasn't-- it was, also, shock for them.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Many-- many German Jews left, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "But those who remained behind, by the time-- after the Kristallnacht, it became a panic to-- to leave, in a way.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And you couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't leave because nobody was accepting you.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "OK, we have to stop.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Did we do OK?",
      "word_count": 4
    }
  ],
