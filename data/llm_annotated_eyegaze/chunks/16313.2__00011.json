  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "He tell me, Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Krause, you know-- I tell him, what you know?",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "He tell me, I know something what I can tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "What he can tell me?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "You see, we're dying.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "We been-- must die.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "No, I want-- I want tell you what your future be here.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I can't tell you for myself.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "I have not the power.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Now I got the power-- actually, I was born with this power.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I can tell you you'll be free or you die here, or something.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I tell him [? sound ?] meshugenah.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So this man, we're laying around like this.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I-- I remember to this day.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "It's unbelievable.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "He take a piece of-- a piece of thread.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "He put on a-- on the thread a piece of-- a piece of wood.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "He put on the thread like this, and this wood hanging on the thread.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
