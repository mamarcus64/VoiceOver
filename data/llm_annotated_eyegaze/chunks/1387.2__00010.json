  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And the whole family-- now the family of Szarf [PAUSES FOR 3 SECONDS] was [PAUSES FOR 4 SECONDS] three brothers, one sister, a mother with three children.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] There were a few other people there, and I was one of them.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] My future wife, Dora, was in that bunker.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She was the one that was able to go out to acquire food because she was a blonde, and she was dressed like a peasant.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And the local people knew who she was.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "There was a question of hiding the footsteps in the snow.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "It was a ingenious idea of one of the Szarf brothers to use a sieve and walk backwards and with the sieve, put snow in the sieve and use it like you use for, for flour.",
      "word_count": 36
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sprinkling then.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So if you walked backwards, you couldn't-- you could not walk into the woods without showing footsteps.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So he devised this ingenious thing that to sieve the snow so that they, they-- it will cover the footsteps.",
      "word_count": 20
    }
  ],
