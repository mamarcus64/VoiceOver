{
  "stem": "17372.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 257.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "To explain what was ghetto, it was a few blocks of houses in [NON-ENGLISH] in Podgorze in Cracow surrounded by barbed wire and some brick wall.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "There was big entrance-- big way out.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "There was a tram going through the ghetto but not stopping.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "And no one was allowed to leave the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "It was police on both ends.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "And we were being pressed in-- into apartment usually one couple with a child who would be pressed five or six couple or families, some with small children.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "Terrible cramp-- shout-- children crying.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And can you imagine five woman cooking at the same stove?",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] But that was only beginning.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And it was very, very hot.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Then they start to make segregation.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "They called one day all people.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "The older one, they put to the left, the younger one to the right.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They took my-- both parents to the left.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I never seen them again.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] There was a little cafe in ghetto where I play with my brother, Henry.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And this is where I met my wife, Helene.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] We decided to get married.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "We get married on the 17th of January, '43, 1943.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And on the night of the wedding, I was taken to concentration camp for honeymoon alone.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Any documentation?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They said, only Kennkarte.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "This is people who work get a stamp.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And you are allowed to-- otherwise, if you have-- didn't have a Kennkarte, they took you out.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And you would never be seen again.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So I was-- my, my job was going on the guards to [PAUSES FOR 4 SECONDS] Luftgau Kommando.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "This is fly-- air, air, air, air Kommando.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I was going under guard there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I had to light fire in 36 iron stoves, 36 every morning.",
      "word_count": 13
    }
  ],
