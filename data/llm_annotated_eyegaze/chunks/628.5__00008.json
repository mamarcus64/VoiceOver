{
  "stem": "628.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "All the groups, the boys and-- and-- one way-- a bit like outcast.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Even my own mother.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "But-- we-- you know, we-- we came out of hell.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we came into a world-- because I was-- when I got to London and I lived with her, I didn't get along-- she lived with a man together.",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I didn't like him.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I went on the streets everyday in the American uniform.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "One day the police came up and said to my mother, he can't keep that uniform on.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "He has to take that uniform and put the civilian clothes, because he's not really a soldier.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "But I didn't care, so I kept it on.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "What I'd do the whole day, go to cinemas, learn English.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Twice a day, I went to-- I became member of the Maccabee Club.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "I looked for Jews, I had Jewish friends, Jewish-- but we didn't get along.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "They didn't accept me.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "First of all, my mother, we weren't rich.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "I didn't come from a big family.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Concentration camp, [NON-ENGLISH]-- they don't say nothing, don't say nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "So I didn't say-- But I had a bit of a complex.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "I always showed my number.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "I always-- you know, I tell you something.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "Until now, [PAUSES FOR 3 SECONDS] I didn't have a childhood.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "Our childhood was taken away from us.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "We became grown-ups.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "And we missed that childhood, and freedom.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "We were searching understanding from people, to give us understanding, to give us positions, to carry us on our feet, high up, like you carry the Torah, and say he has-- we give him everything.",
      "word_count": 35
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "No, it was not that.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "We were a bit stupid.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "We didn't have university behind us.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "Everything you see here is self-made, self-learned.",
      "word_count": 7
    }
  ],
