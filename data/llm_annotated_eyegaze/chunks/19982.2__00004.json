{
  "stem": "19982.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "But I wanted [SOBBING] that I should go home to my parents.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "And then they-- this was already end of September because it was-- the water was freezing already.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "And they put me on the boat alone.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "And that was the last boat.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "When we were going, the water was half-frozen already.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 29,
      "text": "The boat hardly could go because September there is already all-- and the boat came.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 30,
      "text": "On the boat, I had no food, no place.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 31,
      "text": "But the Russian people were very good.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 32,
      "text": "Whoever ate, somebody left me a little bit to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 33,
      "text": "[SOBBING] They were nice.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "[SOBBING] I guess they have pity me.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "My head were shaved.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "I, I didn't have shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "Because when I was left, I was left without shoes.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "Probably what they think, that they took me off.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 39,
      "text": "Because I understand they promised him to the last time the-- because the whole time the NKVD was with us.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 40,
      "text": "The NKVD promised that they're going to put me on their-- whatever they-- whatever they go with.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 41,
      "text": "And the last minute, they didn't.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 42,
      "text": "They just send me.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 3 SECONDS] so there, you know, there on the boat, the Russian people got pity on me.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And they gave me food.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was sleeping in there-- outside, though it was very cold.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So I went inside.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They let me sleep, you know, where the workers were sleeping, and came to Iakutsk-- came to Iakutsk.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And I'm coming [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "The captain from the boat calls the NKVD, what to do with me?",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "NKVD comes, takes me, puts me in the orphan for prisoners-- prisoners children.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Well, I was so frightened.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I mean, everybody had shaved hair there.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But my hair was shaved anyhow, so they didn't have to shave again.",
      "word_count": 13
    }
  ],
