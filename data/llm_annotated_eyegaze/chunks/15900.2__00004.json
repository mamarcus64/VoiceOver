{
  "stem": "15900.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "He walked over to them, just leave him alone.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "He's under my protection.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "And we decide we're not gonna stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "We decide we're not going to stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "And I went by myself to the other side, to Bialystok.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I-- I took a train from Warsaw to the border.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And-- and I went there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I just went there-- just I took-- I took my clothes, and everything.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I went there to see what's going on.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And later on I figured out here is-- everybody's free.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You don't have to worry for the bombs and and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It was Communism.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "But we don't like them, anyway.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "But anyway it was free, people working in the streets, business.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And I went back in the nighttime.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I crossed the border.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I had somebody.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "I was afraid to walk into the city.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "When I came to Warsaw, I was afraid to walk.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "People already had the-- the yellow--",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "At that time-- and--",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in 1939.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "The people already had to separate-- who are Jews have to put to the-- the yellow star and everything.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And I don't have a yellow star, and I was walking.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And the tanks was going to the other front, the French-- it was the main highway, and I was walking at nighttime.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I-- I have guts.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I walked over to a German.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "He was working with a-- it was an open car.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And I said, can I take a lift?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I was guts, to say-- but I didn't have a yellow-- he was thinking I'm a Polack.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And he took me-- and I-- and I stopped from-- from my city about two kilometers.",
      "word_count": 16
    }
  ],
