      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And there was not enough room in Hinton Hall.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Plus it was falling to bits.",
