{
  "stem": "11296.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "Whatever we had, we sold it.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "We had a lot of stuff from Germany between.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "We made a nice home there.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "We sold everything and we came to Canada.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In Canada, we started again.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So in every country we came, we had to start on the beginning.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Again, with empty pockets, with nothing, just a suitcase.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So we started and-- and-- and we came to-- to Canada, to Montreal.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "So I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "In between, I-- I lost my husband.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I knew already I had to work, you know, with the fields.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And Hanka took care of my child constantly.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "She always took care of me.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "She was my savior.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I start working, and this was until 1955.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "That's when I-- I met my-- my-- my husband.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And in 1955, I got married, and I moved away from-- from Canada again.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "I-- I made my-- my home in the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Boston, in the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We lived in Boston.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "My daughter was already a big girl.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And I bore two sons.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Their name is Elliot-- Larry and Elliot.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And you know, my husband went to work and I took care of the children.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And I did my best.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I made new friends.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And I was, you know, how often I could.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "You know, my sister constantly, she was calling me.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "She was very heartbroken, you know, why I moved away from-- why I moved away from-- from-- from Montreal.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "This, I had to settle for my life.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And this was going on till-- I lived 10 years in Boston.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And from Boston I moved to Connecticut.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "There, you know, I-- we had a-- a business, a farm with livestocks.",
      "word_count": 13
    }
  ],
