  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I don't think it was 1,000 people, all together.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "No food, again.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in a, let's say, a beer factory, OK?",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And they have the potato peel, hot.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And that was the luxury dinner for us.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They gave you hot potato peels?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Peel.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They didn't have anything else.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Whatever they could require, they gave us.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Because otherwise, we-- and we ate the snow.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Even my mother told me, don't gave me soft.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I want to bite something, so frozen snow.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So we were going and going.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Finally, the very first of March, we-- or end of February, we-- we came to a Hitlerjugend camp.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "We'll stop now.",
      "word_count": 3
    }
  ],
