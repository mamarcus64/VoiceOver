{
  "stem": "11998.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I remember the day.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Because it was Yom Kippur, and they kept us all inside the barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I was, at that time, in the [NON-ENGLISH], which is the transition camp, the temporary camp.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And it was right on the route of the trucks that went from the women's camp, past our camp, into the crematorium, to the gas chambers.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And they had women naked on-- on-- on trucks.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And they were screaming and yelling, and they knew what was happening by that time.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Once you were in Auschwitz, you knew what the purpose of Auschwitz was.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And once they took you, naked, on a truck, you knew what's going to happen.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "There was no questions in their mind as to what their-- was going to happen to them.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "They were sent directly to the gas chamber.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My father's parents were Avraham Hirsh, and Rudl.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My-- Bernbaum.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, my father's mother's maiden name was Bernbaum.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And my mother's parents was [PAUSES FOR 4 SECONDS] Elka, Hoffman-- ne Hoffman Percik, and my grandfather is Schuman Percik.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "They died before the war.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I mean, my grandmother died before the war, and my grandfather had died just before the first deportation from Sosnoviec.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "My father's parents, they were sent to Treblinka.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My cousin, who lives in Paris, she was with them when they were deported from Czestochowa.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She was in the Czestochowa camp, and she knows that they were-- she was there when they took them and the rest of the family.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Most of the family, at one point, went to Treblinka.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "My father had three brothers and four sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "The oldest was David, who was in Canada, and he, of course, survived.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "A second one was Leon.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "The third one was Kuba.",
      "word_count": 5
    }
  ],
