{
  "stem": "2938.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] So the-- the men, they put on trains, [PAUSES FOR 3 SECONDS] and also the women and the children.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And shipped them away to Treblinka-- Treblinka, Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And from there, nobody ever returned.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "After [PAUSES FOR 6 SECONDS] the ghetto was liquidated, they took about 1,500 young people, and they put them in a small ghetto.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And from there, we went to work in different factories all around the city.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Myself with my brothers, we still went back to our own factory, and our own address.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "The factory did exist, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "We'd been living in this small ghetto for quite a while, and every morning we went to work in groups-- to our place, to another place, to Huta Ludwikow, to Henrykow, to different places, [PAUSES FOR 5 SECONDS] for a long period of time, while the war was going on.",
      "word_count": 50
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "After living in the small ghetto for a period of time-- this was sometimes in end of 1943-- they decided to liquidate the small ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "One morning, we woke up, they surrounded the ghetto with police, took out all the people, and segregated again.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 14 SECONDS] Segregated again.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "The president of this small ghetto, with all his children, were taken out in the Jewish cemetery.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And they build their own grave, a round grave.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "They told them to surround the grave, and after the grave was already dug, they took machine guns and killed them-- and everybody fell into the grave.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "They had several people behind, that they covered the grave, and they left.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Next morning, the Polish people went to look to see what happened, and they saw the grave.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "The soil moved.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "The people were buried alive.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "This was the end of the Jewish community with the president of Kielce.",
      "word_count": 13
    }
  ],
