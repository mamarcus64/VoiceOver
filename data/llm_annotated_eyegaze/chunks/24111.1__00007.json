  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And my father came home.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I don't want to say an broken man, but he was changed in the few days, or perhaps, week, week and a half in-- in prison.",
      "word_count": 26
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "The-- the-- the building is called Rossauer Kaserne in the Vienna Ninth District.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "They must have interrogated him in an very brutal fashion.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "He never really spoke about that.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But physically, we saw there was a change, a-- physically as well as mentally.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We, of course, tried also to leave Austria.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Because-- because there are-- you know, we saw there was no future in us, for us.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Well, I have to go back a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "In the First World War, my father had an officer's servant, which was an Austrian soldier by the name of Bauer, B-A-U-E-R.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He came of the part of Tyrol.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And after the War in 1920 or '22, the economic situation was very, very bad in Austria, and he tried to emigrate, leave Austria for Paraguay.",
      "word_count": 26
    }
  ],
