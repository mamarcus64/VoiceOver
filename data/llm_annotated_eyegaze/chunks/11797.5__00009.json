{
  "stem": "11797.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 334.9,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "This camp was a torturous camp.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We took one stone from here and put it there.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "One stone from there, put over here.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Then they took us out now to a city where they bombed, you know, to pick up the ruins, you know, and look for any things.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And I never forget, I went to a city called Heilbronn.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "A lot of watches were there.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't even steal a watch.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Because you know why?",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We had no use for it.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And-- and they-- they was-- we used to-- we used to work in the fields, now, making foxholes.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We used to work in the mines, you know, Some kind of mines, you know, we were working.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We used to help-- help--",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "We used to help doing certain things like fixing the-- the barracks, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "What with electrical matters, fixed the lights, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They-- they had people working, keeping people-- people busy, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But every other minute, we used to appell.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Go outside in the street, you know? in the-- and the-- and the platz now.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Take off your hats now, [INAUDIBLE] off, [INAUDIBLE] on, [INAUDIBLE], off.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "It was going on for hours, hours.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And we didn't have no hair.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "So we used to do that, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And if somebody-- and a guy used to come in like, in charge of the Army SS.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "You know, the SS, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "We used to take off our hat 50 times, like a-- like a-- give him some kind of salute.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And then we used to stay there, at attention, if somebody came in.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "This was in '44.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "This camp, you know, I stayed probably-- probably a few months.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "This camp was very, very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Still there were-- there were friends there.",
      "word_count": 7
    }
  ],
