  "elapsed_s": 141.3,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "Many of times, they had asked us to go and do errand in the city with this German [GERMAN].",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And when we were walking-- we went to a bakery once, and I couldn't steal anything.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "So I said, that's a waste.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Once, they asked me to volunteer.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "I volunteered.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "They took one of the girl who died.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I had to take her to the cemetery that was across the street from the lager.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "And we had to lay the body down into one of these cement four.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "I never seen something like that.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "I don't know what they did with her.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "We left her there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "And I said never again.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "I'm not going to volunteer, because this is not for me.",
      "word_count": 11
    }
  ],
