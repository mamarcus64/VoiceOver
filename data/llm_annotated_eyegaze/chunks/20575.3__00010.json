{
  "stem": "20575.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And then we were sent-- we were put it into wagons again, cattle wagons, and didn't know where they're bringing us again.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we finally arrived in Freiberg, which is Saxony, in a factory.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We had to work in a factory.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they assembled us there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It was maybe, I don't know, 200, 300 people there.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Women, only women.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "They were not even finished with our barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They we're building barracks.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "After a couple of weeks, they took us from the factory to sleep.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "This was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "There was no heat.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "It was still wet, everything, and it was bitter, bitter cold there.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "We didn't have underwear or nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I don't even remember how we went to the bathroom, honestly, what we did.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "I think we tore out the lining of the coat to clean ourselves.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And this-- this was it, and we were in Freiberg.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Freiberg was a town, a small town, which belonged actually to the concentration camp Flossenburg.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This was the concentration camp, and this was a side camp.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "It was a small, peaceful town where people went to work and saw us marching in the morning, and nobody even threw us a piece of bread or anything.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They knew what was going on, and we were [INAUDIBLE] in a factory there.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "It was an airplane factory.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They just made wings for airplanes.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I worked on those wings.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I can remember there was a whole bunch of people holding up, and they were soldering, welding their wing down.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I don't know the name for it.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Is is, you know, I don't even think they ever got finished [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "But we were holding those things, and somebody was working on it.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And we did this like maybe 15 hours a day.",
      "word_count": 10
    }
  ],
