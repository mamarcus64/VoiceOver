{
  "stem": "13655.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Polish people, with the help from the Gestapo.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 3 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "--this was a miserable, miserable thing.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Nobody cared anymore for his life, because we knew, how much can you take it?",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "A few of them got killed coming in by the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "How did they get killed?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "The Germans--",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The Germans was seeing they're coming.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They catched a couple [INAUDIBLE]. with Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They shot them.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They knew from where they're coming.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This was they shot them just--",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Because they were Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They knew already.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "The Polish people told them the whole story.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They knew the whole story, what's going on.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "One by the name Leon Busch, a Gestapo, he was a murderer.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He was killing right and left Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And [INAUDIBLE] the other name, I forgot, [INAUDIBLE] tsuris.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, to the municipal, in our town, they sent [INAUDIBLE] from the Biala.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "When he arrived to us, right away, he gave us the first shot.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "This was before a year and a half, maybe.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He took away-- we had a car and a horse.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "They took away everything.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1940?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "In 1940, right.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Then what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "One, I had a friend, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "He was a non-Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He told me who is [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "What was the friend's name?",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Yusef-- ?]",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 7 SECONDS] [?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Yusef ?] I know.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "The second name, I don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I'll remind myself later.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "So he told me, Louis, this guy, he's an engineer.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "He was working in Biala, some little jobs, architectural, in a [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I told him, tell me where he lives.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "He told me that this is the place, there, and there, and there, and there, and that's it.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Then I took-- it was winter time, cold.",
      "word_count": 8
    }
  ],
