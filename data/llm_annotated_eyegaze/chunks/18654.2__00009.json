{
  "stem": "18654.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 53.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, with my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No, I mean with the sisters with the-- with your-- with your guardian.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes they must have obviously been in touch with me because she came-- she came to the hospital and looked after me in the hospital.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "She stayed in-- they allowed her to stay in the hospital to look after me.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I have an older cousin who also came to see me.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] He lived in-- in Blackburn, in Lancashire.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And-- and my-- I was in the hospital in Cambridge, and I remember my sister also, of course, came to see me.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Cambridge is not far from Ely.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No, not really.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But I must say the-- the headmistress of the school was very kind.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And you couldn't get things like oranges, bananas you couldn't get.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I remember they asked me what I wanted, and I asked for two things.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I asked for a banana and a bicycle.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "The banana was not available, you couldn't get bananas.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "The bicycle I was given the money for.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I had some rather wealthy very distant relatives living in Blackburn, and they sent me the 15 pound to buy a bicycle, which I never got [LAUGHS] because I wasn't allowed to do anything for more or less a year after that.",
      "word_count": 42
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Because don't forget, times have changed.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "You know, they kept you-- I couldn't walk when I got out of hospital because they kept you in bed.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "You couldn't-- you-- I could barely walk, I should say.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I was lying in bed for about four weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I couldn't stand up for four weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I think my-- I called him Uncle Walter.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The name [?",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Neumann, ?] Neuman.",
      "word_count": 3
    }
  ],
