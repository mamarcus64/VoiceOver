{
  "stem": "2980.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They were all government schools, but the Polish school, only Polish children went.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "The-- there was a Jewish school where Jewish children went.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Then there was a Ukrainian school, where the Ukrainian children went.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And I went to the Jewish school, which was called [HEBREW], which means public school number two in-- in there.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "But the basic language was Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I think it was located on the-- [PAUSES FOR 3 SECONDS] in a place called the [HEBREW].",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The-- the fire department was downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And we had the school upstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Subsequent to that, we went to a school called [HEBREW], which was a division where children third or fourth grade would go there before the war.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Religious rituals.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "When it came Shabbos, on Saturdays, my mother prepared for Shabbos like every household.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They would cook, and bake, and prepare, and give to the poor.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And-- [PAUSES FOR 3 SECONDS] and we would have candles, Shabbos candles.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "We would have [HEBREW].",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "We would have Hanukkah candles.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "We would have-- such a long time ago.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "We would have all the Jewish objects that we had-- that a Jewish home would have.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "My father went to the [HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It was a little shul that belonged to the [HEBREW] rabbi, which he had the seat in Luboml, but he had another place where the main Hasidi went with the beards.",
      "word_count": 31
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "This was for the more modern followers.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They didn't have beards anymore, but they were Hasidic.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It was connected to the main synagogue, which I have photographs.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I'll be able to point out that little [HEBREW].",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It's called the [HEBREW], the great synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "That synagogue was unique in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "It was built around 600 or 700 years ago by some Italian architect.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And it was built as a fortress.",
      "word_count": 7
    }
  ],
