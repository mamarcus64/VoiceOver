{
  "stem": "9.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Women were not allowed to go to school.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Women weren't allowed to be educated.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Women weren't allowed to read the Bible.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Only the men could do that.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "This was the man's world, man's privilege.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And-- afternoons in the holidays was the same like Shabbat, rest or study.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "The men would go and study together.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "They would gather in the room, four, five at a time, and the whole afternoon discuss various issues, whatever they decided to do.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Afterwards was a time to visit the family.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And we always visited the family Saturday and part of Sunday.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "Now, we always had two days-- no, three days.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "Saturday only off.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "On Sunday was visiting day, basically, and going places, picnics and so on.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Passover celebration really what it was was a whole month of work.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was totally anti-women.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We had to take out all of the dishes, usually paint, clean the cupboards, get rid of all the bread and bread items made from bread, take out new dishes that were stored through the year, and eat only matzah.",
      "word_count": 40
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "The day before Passover around 9 o'clock in the morning was the last time we would eat bread.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And afterwards that all was allowed was matzo.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "In the evening, we would have what we called a seder.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Seder is a meal where the story of the Jews from Egypt going through the desert is told.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Small children ask questions.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "The families vary it at times.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "But the best-- the seder that I remember the most is not in my childhood, and I have to tell you that.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "When I arrived in the United States-- and now we are 1947, we going ahead quite a bit-- I had here two uncles.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "One was very religious.",
      "word_count": 4
    }
  ],
