{
  "stem": "3605.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "They didn't even want to waste a-- a bullet on us.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "Later on, I was four weeks in Bergen-Belsen, and I went out with the last transport from Bergen-Belsen.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "There were 500 women and 500 men.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "We were moved to Southern Germany to a work place.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "In the middle of our route, the train tracks were bumped.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And for 14 days, we stood on Wurzburg, in Wurzburg, Main-- this was a city in Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And we couldn't move.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And a lot of people died from starvation.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Wurzburg-- I think it is W-U- umlaut-- R-T-Z-B-U-G.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "--dash Main.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I think it is.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how you spell it-- M-A-I-N or M-E-I-N.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The Main is the river-- a river that we were there.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And we stood there.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And we got rations for four days-- a bread, and conserves, and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "But we were there 14 days.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "A lot of people ate it up in one day, and they got sick from the food.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "They said, I'm going to be three days hungry, but one day I want to be full.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And a lot of people died from the food there.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And the other people, if they ate it so fast, they had so many more days to starve.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "I kept the food a little longer, and I didn't have so many starvation days.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "Anyhow, I came.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And there was less than 1/2 of the people that survived that transport.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "This was just my willpower, I imagine, and not to give-- give in to that overpowering hunger.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I even remember giving away a piece of bread to one of the girls.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She was so thin that I could see all her veins through the skin.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And she was one of the girls from Krakow that I knew her relatives.",
      "word_count": 14
    }
  ],
