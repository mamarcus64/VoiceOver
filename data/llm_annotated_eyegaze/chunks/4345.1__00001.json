{
  "stem": "4345.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I went to camp as a child.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I used to go to day camp and away for the-- for the summer.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I had my-- my-- Mommy would sew our clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "She would bake delicious breads and cakes.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We conducted magnificent Shabbat-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Shabbosem ?] at home-- full of Yiddish guide, full of love for God and for people, and for mankind.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I came from public school and I went to Bais Yaakov, and I spend another two, three hours there.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I-- we had friends.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "We had family.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "We had many relatives at home and abroad.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "My bubbe, my zayde, my aunts, my uncles, my cousins-- we used to go to their homes, especially on Shabbat, where my Uncle Joseph would test us in what we learned in Bais Yaakov over the week.",
      "word_count": 37
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And he would test us in Chumash and reading the Torah.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "It was a beautiful life.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "It was poor in luxuries but rich in love.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very much so.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Religion played an integral part in our life.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I think that my parents paid the rabbis to teach us-- to teach us Torah where we-- when we needed the money to buy bread.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It's as simple as that.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "It was like mandatory.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I think in every Jewish home.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But to be poor, you would think that you buy the food first.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "But not so.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "They-- they-- the knowledge and the education was very important very-- and-- and Yiddish [? guide. ?] And-- and this is the way it was.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I loved every minute of it.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I still read Yiddish, and I write Yiddish and I speak Yiddish.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And-- and I love it.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I wouldn't have it any other way.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So do my children.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Each one of them speaks Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They speak Hebrew.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "They speak Yiddish.",
      "word_count": 3
    }
  ],
