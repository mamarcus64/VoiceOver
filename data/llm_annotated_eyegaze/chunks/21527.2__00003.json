{
  "stem": "21527.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And on the 16th of August 1943, the Germans started giving orders for people to leave their homes and to be, and to be rounded up in a huge empty place just outside the ghetto.",
      "word_count": 35
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We weren't given very much time.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So everybody just took their-- just their personal belongings.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I remember my auntie put on three dresses, because she wasn't allowed to carry too much.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So she put on three dresses, one of which I've got.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And we'll see it later on.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And so we went-- pardon me.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we went to this-- my, my mother, my father, my grandmother, and I went to this huge place where the whole population of, of the ghetto was taken.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But my aunt and my uncle and my cousin went to the Jewish hospital.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Because my uncle felt that as long as there was anybody left in the ghetto, they would need a doctor.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "My aunt was a trained nurse.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And their daughter went with them.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So they went to the, to the Jewish hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And as I remember, as we were led through the streets of the ghetto to the outside, there was shooting.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "There was blood in the street.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And the, the Bialystok Ghetto Uprising had started.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "So we were taken to this huge place.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It was August.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "It was in the middle of summer.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "From what I can remember, 1943 had a very, very hot summer in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And we were sitting there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And then an order came that all the children were to be rounded up.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They, they sort of came with loudspeakers.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And they said-- and this was a trick the, the Germans used on the Jews all the time.",
      "word_count": 18
    }
  ],
