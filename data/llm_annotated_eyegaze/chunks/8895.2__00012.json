{
  "stem": "8895.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "I didn't care anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "It was ?] [? the state ?] I didn't care anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "When we came to the internment camp, which we missed years before because there was a bad illness in it.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And there was a quarantine.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And so we were pushed from one prison to the other, from one camp to the other.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And we came there two-- that was only two years.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And we came straight away to the hospital, my mom and I.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "There was a doctor, a Viennese doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And his mother was a, was a, was a top nurse.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "She didn't have [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "But she was, was really good.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And she, she was sort of the boss from the whole hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And when we lay in this room and we got our food, somebody said, they build-- we build our, our [INAUDIBLE] ourselves.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And we did the bricks ourselves with, with burnt out [? coke ?] and, and earth.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And we had to-- after the work, we had to, to, to carry two of those bricks into the camp.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "They weighed 12 kilos each.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "You could only carry them like that.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And somebody said, this is man there with the, with the nave blue thing, that is Mrs.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "Picker's son.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "That was my husband building, building then.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "Little did I know that we will end up together.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I met him there.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't love at first, but it just grew.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The marriage--",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "'47 And--",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "We returned home.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I have the whole trip on a piece of paper.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I had-- my mother, she was in this art studio, had a little block.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And this block, this, this was something was out of this world.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Do I have it here?",
      "word_count": 5
    }
  ],
