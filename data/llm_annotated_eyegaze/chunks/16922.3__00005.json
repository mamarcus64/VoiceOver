  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Maybe-- I was pregnant, and I got a baby there, in Konstanz.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Is first thing, [PAUSES FOR 3 SECONDS] Mary Ann was born.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Through Joint.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "By boat.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "[BACKROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Oh, very.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "The baby was fine.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "She was drinking milk and eating crackers.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "But I was very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] It was a boat, the [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "I remember to day.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "This I didn't forget.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I think this was for soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "It was hard.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "New York.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I was-- [PAUSES FOR 3 SECONDS] I was thinking here is-- it's not anti-Semitism, it's not this, I was thinking.",
      "word_count": 20
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "I was very disappointed.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I was very happy, but-- this no-- I was thinking there's not anti-Semitism.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "It was plenty.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "From Joint, a woman came.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And she was very nice, very helpful.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "She was American, from the Joint.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Downtown, I took-- I found an apartment for $18.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Jefferson Street in New York, downtown.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "Oh, it was horrible.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "The mouse were running like crazy in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I was not used to it.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "In Germany, I lived-- in Konstanz, I lived in like a nice-- nice apartment I have.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "And here I was thinking it's going to be beautiful.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 8,
      "text": "It's going to be-- it was very tough [PAUSES FOR 3 SECONDS] till I go out from there.",
      "word_count": 18
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 9,
      "text": "I move to-- here in Jackson Heights.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 10,
      "text": "And now you know where I was.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Not much, and I was very nervous, very-- [PAUSES FOR 4 SECONDS] maybe they asked me.",
      "word_count": 16
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 9 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "I have no contact with nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
