  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "This business is very-- you have to be a millionaire to go in that business.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Textile-- that kind, you have to be am millionaire.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "You giving on trust.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And then after the season, they don't pay you.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "They giving you back the, the merchandise.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And then it goes out of printer style.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And he explained to me what is wrong-- what I cannot have it.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "He gave me the suggestion as to go in, in grocery business.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "OK, you have to know the grocery business.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "You cannot just open a store without knowing, he said.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "He said, I have a cousin, an uncle-- his co-- uncle-- from [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "He is a-- he can find you a job.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "I will tell him.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And he will find you a job in a grocery.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Sure enough, they sent me to a, a supermarket-- a small supermarket.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "He was very busy.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And he saw on me that I'm a businessman.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "I'm not just a worker.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "He could tell.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "And he send me I should watch the, the appetizing place.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "And I should learn there a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "And then I'm going to be on the appe-- appetizing clerk.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "I don't have to learn for long.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "I catch up right away.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "And I start already there in selling whitefish, whatever they was, lox, whatever it is.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So a, a, a pound was whitefish was a dol-- $0.99 a pound.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "So a quarter of a pound is a quarter.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I don't know of a lot [? of-- ?] [? other ?] places.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "He calls me on the side.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And he says, you know you have to make up your wages on the, on the customers.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "You have to like charge them a little bit more.",
      "word_count": 10
    },
    {
