{
  "stem": "12612.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And the following Friday, we went to Le Havre in-- in France to get on the boat.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I remember telling my mother, but we're not allowed to ride on the Sabbath.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And she says, we're allowed to, because we're boarding before Sabbath, and we're getting off after.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And that's going to be your home for two weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Then we arrived here, [PAUSES FOR 3 SECONDS] 14--",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "--14 Days-- yeah. 14 days later.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We arrived in Halifax.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And from there, we took a three-day train trip-- a sleeper-- to Toronto.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Because we had someone-- someone to speak for us there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My mother's brother-in-law's sister lived in Toronto.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And she was able to, you know, vouch for us that she would make sure we wouldn't be on welfare.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And she would take care of us.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She found us a place to live, above a Russian or Polish lady.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And I remember coming up the stairs one day, and I heard my mother say to the landlady, don't worry.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "She's going to live in New York with her grandfather.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "That's all I had to hear.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I said, we just got out of the camps.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And now, she's sending me away to live with somebody else.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "I was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And she came after me, and she whispered in my ear, it's only a fake story, because they didn't want any children in this apartment, and we have nowhere to go.",
      "word_count": 31
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "We're not going anywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Not really well.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He-- he would come to visit sometimes, but I really didn't know him that well.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I made friends pretty easily.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Because you can talk a lot with your eyes, and with your hands, and smiling.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And in the beginning, when we arrived, it was summertime, so there was no school.",
      "word_count": 15
    }
  ],
