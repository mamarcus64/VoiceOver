{
  "stem": "6526.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And I used to go to the places where they used to buy, or other places, to ask him-- show him this.",
      "word_count": 22
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Do you have this material?",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "How much is it?",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "How much a yard?",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "How many yards of this?",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "All kind of information.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And I used to make commission.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "That I started-- and then we started the business into export business that we used to sell all the items that we needed.",
      "word_count": 23
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "We used to travel to Central America, to South America.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "And we became a company, Kishel Brothers Trading Company.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "And then, after a few years, we incorporated.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And we were a company since 1948.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Started in business-- until 1988.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "1949.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "My greatest fear-- that I won't be able-- that I won't live to see the end of it.",
      "word_count": 18
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Because, well, we were-- the greatest fears were at the time we were on the march.",
      "word_count": 16
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "When we were on the march, there was nothing that you could hide from.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Let's say you were in a camp.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "You could hide under a bed.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "You could hide someplace.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "On the march, you are on the outside.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "No, uh-- on the fields-- no-- nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "It was especially-- one time, we were on the march.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "There was a wagon.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "No horse-- we were the horses.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "A wagon-- and the Germans put all their equipment on the wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And we used to-- on the wagon, the-- the one at the front used to pull.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "And we in the back and the sides used to push.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "So the Germans went on-- on-- on the front and the back.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "To the guys in the front, they should not pull that fast.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And to us, they beat us up not to push that fast.",
      "word_count": 12
    }
  ],
