  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And this was [PAUSES FOR 3 SECONDS] September, October, '42.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "So they kept us there in the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "And a lot of things went-- happened there in this-- in this time.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "It was a full jail, all Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In the Jewish police, in the-- in the Jewish police.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Inside the ghetto, there was a Jewish police.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And on-- and they had-- they had like a barrack, which was a jail.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "On the next tape?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
