{
  "stem": "16.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.4,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We had-- we had some food that we were allowed to bring with us.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't give us any food.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Three days-- three days and two nights, two nights and three days, something like that.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Or maybe three nights and two days.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "It took a total of three days.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We arrived in Birkenau.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "We arrived into a camp, where we're [SIGHS] surrounded by barbed wire.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And as you got off the train-- and everybody was, schnell, schnell!",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Los, los!",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "Everything had to be done fast.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I don't care how fast you did something, it wasn't fast enough for the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And and there was a-- one person that looked like a ranked German, with high rank.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And he was telling you, you go to this side.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "You go to this side, and so on.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And later on, we found out the left side meant-- or one side meant life.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "The other side meant the death camp.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Oh, as soon as we, we got inside.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I was inside the camp already with a striped Sing-Sing type of suit as a prisoner.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "One of the barrack leaders, who was a Polish Jew, also a prisoner-- but he was already there since 1938 or so.",
      "word_count": 22
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "He said, that's your parents burning there.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And I just-- I said, you're crazy!",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "He said, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "I spit in his face.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "I literally spit in his face.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "He started beating me up.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Yes, he was.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And I even yelled at him.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I said, why are you saying that?",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "You're a Jew.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "I mean, why, why are you saying these things?",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "And the reason they left me there-- they would've beat me to death.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "All of a sudden, it, it just started pouring rain out of the clear blue.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "It just was raining.",
      "word_count": 4
    }
  ],
