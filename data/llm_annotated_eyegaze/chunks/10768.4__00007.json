{
  "stem": "10768.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I was there as a nurse and another one who was always like making dressings in an operating room.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "There were two doctors.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "There was the kitchen and a third department.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember what the third depart-- three trucks.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "When we went through Warsaw, Warsaw, at least the street where we drove through, was all in flames.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And then came a command.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "You're not stopping here.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "You are going.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "The Germans are running.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Mostly they drove at night, but it didn't take too much.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Poland still is not-- in a truck, it's not such a huge territory.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "From there they told us the next stop is going to be-- there are two towns, Torun and Bydgoszcz.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I don't remember if we were first in Torun and then in Bydgosczcz or first in Bydgosczcz and then in Torun.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "But anyhow, it's irrelevant.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "When we came to one town, they said, you are not stopping here.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "The Germans are running.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "We came to the second town, you're not stopping.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "You go, go, go.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Until we came on the German-- the old German territory, a town which was called Flatow.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "Now it belongs to Poland and it's called Zlotow.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "When we came to Flatow, the German town was dead, abandoned.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "If somebody was hiding in their houses, they didn't show their faces.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "They were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "There was no electricity.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "There was no water.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "If there was water, we were afraid that it's poisoned.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "And our hospital was only prepared for very light-- for some illnesses and for light mostly muscle or, or not, not, not injuries through the bone.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "We were not prepared for very difficult patients.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "When we came here, of course, the hospital, we couldn't go in.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "The buildings were not adequate.",
      "word_count": 5
    }
  ],
