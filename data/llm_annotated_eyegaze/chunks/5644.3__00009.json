{
  "stem": "5644.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "He said, look, David.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "I want to tell you something.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "The faces, you, me, we can't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "That's, that's, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 9,
      "text": "But I tell you something.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 10,
      "text": "Does not exist anybody in the world to know those details without being with me.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 11,
      "text": "And I, mine sight is [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 12,
      "text": "There's not a man, another one than me, to remember your movements there.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "So you are the David.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "And he said it in-- on a tape in the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He-- I-- I know after.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know before.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "But at the time, I-- no, no, I didn't.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "He took out the message, and he went to England, and to the war ministry.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And he spoke to Eden.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "He spoke with Roosevelt.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "Unfortunately, nobody could believe.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "That's what I say, always.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "If I got to speak to someone, or I'm speaking to some boys, to an organization, I am starting go to private people.",
      "word_count": 23
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "I'm starting of ladies and gentleman, you won't offend me not believing my stories.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "I don't believe, myself.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Apparently it was twice, but I don't know about  the second.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I don't know before or after.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I never asked.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, no, no, no, no.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "The coming of the-- of the empty house-- as I told you, when you're coming to the cellar of 7 9, I can take you to [INAUDIBLE], three kilometers away.",
      "word_count": 30
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, that was a, a living house.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "People lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I spent quite a time, because night times, I-- or if I went out, I went out for two or three days.",
      "word_count": 22
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "No, I spent quite a bit with Luba.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "At this stage, all over the places.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I've been in contact.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I've been busy with my work, and with my wife already.",
      "word_count": 11
    }
  ],
