{
  "stem": "4662.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And what you attribute that over-protectiveness to?",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Was it his-- was it your family's upbringing?",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Was it something that their parents had done?",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "That's the way they were brought up too.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what-- we kids in those days, we didn't know what that was, rebelling against your parents.",
      "word_count": 19
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Your parents were your gods.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "Everything they did, everything they said, was good.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "There were Jewish children too.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't know that now.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "You know how long ago that is?",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "The grammar school, the grammar school was the last school I attended.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- it was a very, very good school, well known for, for its-- the teaching high-class things, more than a public school.",
      "word_count": 24
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "They were advanced.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "It was something that your parents paid for privately.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Well, I, I was around about 16.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Then I went into another school to teach the kindergarten for two years.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was good.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I enjoyed it.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "That was in Mayvale.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "That's a suburb of London.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother-- my mother said you should do that, so I did it.",
      "word_count": 14
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I liked that too.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "And you did that for a while--",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "For a while, and then I went to the dancing school.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "After dancing school, I wanted to learn hairdressing.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "So I went in for hairdressing for a year.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And that was in Regent Street in London.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "I had a very happy youth.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I enjoyed everything I did.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "My two brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I got along better was my eldest brother than my youngest brother.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "He was born on my first birthday.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "He was my birthday present.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Well, no.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "This is all a suburb.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I went with the underground home.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "So you continued to live at home.",
      "word_count": 7
    }
  ],
