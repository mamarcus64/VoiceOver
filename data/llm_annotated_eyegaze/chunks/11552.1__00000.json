{
  "stem": "11552.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Alicia Appleman.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And my maiden name is Jurman.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Appleman, A-P-P-L-E-M-A-N.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And my maiden name, J-U-R-M-A-N.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Alicia.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "In polish, it this Alicia.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "From Alicia, you can call me Ala, A-L-A, or Alusia, A-L-U-S-I-A.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "May 9, 1930.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "65.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I will be 66 in May.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a little village called Rosulna R-O-S-L-N-A.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And it's in the Carpathian mountains in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And from the age of five, I lived in the city of Buczacz, B-U-C-Z-A-C-Z.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And it's also in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Sigmund Jurman.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And he was a former officer in World War I.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And he was born in Vienna in Austria.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "My mother's name was Frieda.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And she was born in Sweden.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They spoke three languages at home, Hebrew, German, and Polish.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I had four brothers, my oldest brother Zachary.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He was born in 1922.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "My second brother Moshe was born in 1924.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And then there was Bunio.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And he was born in 1928.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I was born in 1930.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And I had a little brother Hertzl, who was born in 1932.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Well, I tell the students when I speak in schools that we were a very active family.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "We lived in the mountains.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "My father built us a big house, put the pool around it, put a couple of drawbridges.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And I felt like a princess.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "I had three older brothers who bossed me around, as older brothers do.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "I also had a younger brother, whom I bossed around, as older sisters do.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "I remember my father telling me that he would have had as many boys as need be until he had his darling daughter Alicia.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "Well, I was a very active little girl.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We lived already in the vacationing home.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So we actually received a lot of people.",
      "word_count": 8
    }
  ],
