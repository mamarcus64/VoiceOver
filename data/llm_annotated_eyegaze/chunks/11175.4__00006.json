{
  "stem": "11175.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "This is the arbeitz places where they were there, you see?",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "When I talked about the Otwock, when I told you about Otwock, it's-- the group what was from Otwock were there.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They was the first one what they grabbed.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "They to told them to send them to Treblinka.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "They build that [INAUDIBLE] Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "So they were working in this shop.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "I knew them.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "They knew me also, from Otwock.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "One Sunday morning, I was assigned from this group, from this Taunton barrack, assigned to go over there, in-- not-- not by myself, you see?",
      "word_count": 25
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "With a few other boys, and bring over something-- either some bricks, either something.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember exactly what, we bring it over there.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I knew that they are there in this shop, so I-- you know, I hide myself.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I jumped into the shop, and I looked at them, and they looked at me.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I said, please, [NON-ENGLISH] Help me.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "If not today, it's tomorrow I'm going to be dead.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He said, what can we-- we cannot do anything.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So one guy-- he's-- that's Katz.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "His name was Katz.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He said, wait a minute.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "You-- don't-- don't move out from here.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Don't move out from here.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "He gave me a-- I don't know how you say [INAUDIBLE] to shave the wood.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "A-- a plane?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to shave the wood, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And he gave me in the hand to me, put-- put me in-- aside.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I should stay and work.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he said, don't-- don't say anything.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "He was helping me, until the-- about 4 or 5 o'clock, when the appell is there.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I have to be there on the other side.",
      "word_count": 9
    }
  ],
