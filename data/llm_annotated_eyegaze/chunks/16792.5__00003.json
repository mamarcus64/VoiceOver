{
  "stem": "16792.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I-- I personally didn't see it.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But it was-- they told me that it was plenty graves.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "You see, I was a very busy man.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I was working mostly day and night, mostly nights.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "This I can tell-- mostly nights I was working.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Days I slept a couple hours, three or four hours, five hours, you know, because and I've got vodka.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "You know, if not I couldn't sleep.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And we-- we was-- our-- our organization, the reconnaissance was-- the feeding the food was excellent.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The best food what exist, we got.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I was going normally every couple of days to [POLISH], Army and [POLISH] Division.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And down there in the [POLISH] Army Division also by Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And if I tell them I need 10 liter-- you know what liter means, right?",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Leader?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "A liter is a half a gram.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "A liter, yeah. 10 liter vodka he give me.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And the reason was also they have got-- they ask me, why you give me?",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Why-- why-- what does Alex give me?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "You see, what we did is this way.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "When we lost people, when we lose people-- you see I lost in a week one or every two weeks three people-- dead, you know, lost.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "The uniforms I bring over to this guy, I give it to him.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And he sells it someplace and this I got vodka.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I was-- Auschwitz and Treblinka, I was only when I got a vacation after-- when I was on vacation in Poland I was in Auschwitz myself.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I came home in uniform.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It's after the war, but I was in the Army till 1946.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I was close to a year longer as a-- as a-- as the war end.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "The war end May 9.",
      "word_count": 5
    }
  ],
