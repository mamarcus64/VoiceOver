{
  "stem": "24411.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And there was-- we had-- the boots was from cloth made, and a big shawl over your head.",
      "word_count": 18
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "And this was wet at night.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "We came home, everything was frozen till we warmed them up by the oven.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Summer was-- was hot.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Summer was good.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "So we didn't have to have these clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "We got, you know, like schmattas.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "You know, I have a rag.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "Who has a rag?",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "Who had-- everybody said, I give you this.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "You got this.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "Give me the piece of bread, I give you a dress.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "That was the life.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 10,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was in pain.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Pain, emotional pain.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Everybody said, this is it.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "We're not going to go out from here.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "This is it.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Everybody did.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "We talk about if someday is going to come-- one evening, it was we were in one place, in the other barracks.",
      "word_count": 22
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And it was young people.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And we start to laugh.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And we start to say-- I said the first thing, I said, look, if the day's going to come, we're going to sit by the table, and it's going to be bread on the table.",
      "word_count": 35
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "And we're going to eat, and it's going to-- and I'm going to say, I have enough.",
      "word_count": 17
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "A piece of bread is leftover, I don't think so if it's going to come this day.",
      "word_count": 17
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "But it eventually came.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "A lot of people got malaria.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    }
  ],
