{
  "stem": "23626.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "From the beginning, when we lived in the suburbs, we used to go to school, and I was driven by a-- [PAUSES FOR 4 SECONDS] you know, I was commuting, actually.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "But it was a very short time because, short afterwards, we moved to-- to Cracow, [NON-ENGLISH] where we lived.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "It was very close to the river and the famous Castle Wawel that everybody knew about.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And it was a fairly new building.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And I adjusted rather quickly.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "I made friends.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And we were very happy there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "It was a nice neighborhood.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "I was going frequently to the river with my parents, and also to Wawel, which was a famous place for people who came to visit.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "It was a historical place.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "It was a castle.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "There was a lot of history to it.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And me and my sisters would go there frequently, and I went there with my parents.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "As a matter of fact, I had one picture taken with my mother that was given to us here by our cousin on this famous castle named Wawel, which I will show you later.",
      "word_count": 34
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Well, Cracow was a historical place.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "There were a lot of lovely places to go to.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I was rather young to remember every place I went to.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "This Wawel was-- stood out in my mind because it was a place where we-- everybody would would want to go and see.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "There were other historical places that we-- I have seen and I visited.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "It-- it was a beautiful city.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Cracow was actually the capital of Poland, but in the late-- lately, Warsaw became the new capital.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But Cracow was the historical capital of Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And it was rather nice.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "I mean, it...",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "There were beautiful places to go to and to see.",
      "word_count": 10
    }
  ],
