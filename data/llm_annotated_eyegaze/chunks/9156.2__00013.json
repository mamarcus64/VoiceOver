  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They got the money-- they got three marks-- the money from the Nazi party?",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "From the party for one week.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And they were-- well, I mean, I always take it as a picture, always, like there is a big demonstration of the Nazis, in the streets of the Republic-- it's still the Republic-- with spades over their shoulders because they were not allowed to wear any other arms.",
      "word_count": 48
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And Paul and I go down to see what's going on.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And suddenly, the spades just fly on people who stand by, so that they get bloody.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "They were beating people.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They were constantly beating.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I stood next to a policeman who was not a Nazi.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And he said, God, help us when those people get into power.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And yeah?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So I think I can start with the Nazi period.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And then I'll talk about examinations.",
      "word_count": 6
    }
  ],
