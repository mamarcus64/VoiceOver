{
  "stem": "5799.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "You'll work yourself up from the boots up.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "I never took from this country anything.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "I don't want it.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "I owe it.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "You have to give back something.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "And I resent when people HIV positive are let in.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "We haven't got a cure for it.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "Why was I kept three weeks, and they gave me all kinds of powder against lice-- which I didn't have-- [LAUGHS] [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "We were kept three weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "If you had a spot on your lung, you weren't going because maybe you had TB.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "And you had already, I think-- no, the cure for TB came later, came in '49, came the Isoniazid that they found here.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "But people were kept away, and the Statue of Liberty meant something.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "You just didn't come in and take things for granted.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I was in Schlachtensee.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Only Schlachtensee in, in-- and we were useful.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I earned my ticket.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They didn't pay me money, I worked, and my husband worked.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They gave us food.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They gave us a room.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "But we come from a culture that you don't take for nothing because we weren't beggars.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean, I'll come and they'll give me?",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I'll come and I'll take?",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Of course I could register someplace, and you only think I took.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I went to a clinic, and I told them how much money my husband makes, and that's how much I paid in the Bronx.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't take anything for free.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And anybody who comes now to my house can say, yes, you live in a palace.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Nobody gave it to me.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "We earned it.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And if I wouldn't earn it, [INAUDIBLE] all of my people are a success.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Even if they live in small houses, small apartments, they raise their children.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "They educated them.",
      "word_count": 3
    }
  ],
