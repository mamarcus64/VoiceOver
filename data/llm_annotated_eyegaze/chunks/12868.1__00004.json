{
  "stem": "12868.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I'd been 16, 17 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Zionism.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You know, Zionism.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We-- we-- we dreamed to go to Israel, you know, or to have our own country like-- like all-- like all the nations in the world.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And that's what we-- that's what-- that's what we did.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "After the army, back-- I go back.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I had my job again, what I had before.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I have a normal life.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "In Lithuania.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "In Kovno.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "That's a big town.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "That's the-- that's the capital for Lithuania.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "From the shtetl in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I'd been on the leave later, we're moving to Kovno.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And in Kovno, we live together and made a family.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No, there didn't was a ghetto yet, you know, because the Russians occupied Lithuania.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And the Russians didn't make any ghettos.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We moved to Kovno because my-- my brother and my sister and me, we left the shtetl.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And we want a better life, a more educational life, a more activity life with more people.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we moved.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We-- we worked together, all of them, in the big town.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And later, we bring our parents there, and we lived together.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1932, '33, something like this.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I been in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Everybody got to go-- got to go in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They-- they make us to go in the ghetto, to leave everything to go in the ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And in the ghetto they put me, the whole ghetto was around with-- with barbed wires.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't go in or go.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And nobody can go in or go out without-- without-- And this was-- this was the ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "You got to  leave everything and to stay there in ghetto.",
      "word_count": 11
    }
  ],
