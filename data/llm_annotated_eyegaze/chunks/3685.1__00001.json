{
  "stem": "3685.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Now, my oldest sister was also going to the school in-- in a school, to the-- called Berestechko.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "It was 5 kilometers from Stremilcze.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And then my sister, when she turned 16, my father send her to Israel to study agriculture, near Jerusalem.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And then she came back in 1938.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "My young-- my second oldest sister was also going to Berestechko.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And my third older sister was going also with me in-- in school in Berestechko.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "Because in Stremilcze was only four grade-- a grade four.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "That was the requirement the Polish government requires.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "You have to finish grade four.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "After grade four, you on your own.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "So whoever wanted to go farther to school had to go someplace else, because that's-- that was it.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My sister's-- the oldest-- name was Walerka, W-A-L-E-R-K-A.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My second oldest sister was Helena, H-E-L-E-N-A.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My-- my name, I already said it.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And my youngest sister was Edzia, E-D-Z-I-A.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And my second youngest sister was Bronia, B-R-O-N-I-A.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was David, and my mother's name was Lea, L-E-A.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We had the-- like, we were very modern at home.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Our house wasn't actually kosher, but we were traditional Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We believed in that-- in Judaism, and we were pro-Zionist.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I, even as a child, was already active in Hashomer Hatzair, OK?",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And my oldest sister was-- my-- the one that went to Israel-- she was-- she belonged to a-- to a organization-- the [NON-ENGLISH].",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "That was Jabotinsky's party.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "There, then this party became later Likud.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And my second older sister, she didn't take any part, and went to school.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "That's in the-- and the rest-- the Shabbat.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "The-- every Friday we used to have-- Friday night, we used to go to shul, come home, have Shabbat dinner.",
      "word_count": 20
    }
  ],
