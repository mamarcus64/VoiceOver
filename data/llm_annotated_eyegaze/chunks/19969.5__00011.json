{
  "stem": "19969.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The atomic bomb had been dropped.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And shortly after that, Japan surrendered, which was around the 1st or 2nd of December in 1945.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "September-- right around the 1st of September in '45.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I had just been back to the States three or four days when that happened.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And the 45th Division was almost immediately-- all of the-- most of the National Guard and Reserve Division-- well, all of the National Guard and Reserve divisions were then demobilized.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They were removed from federal service.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They were shipped back to the States.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And everybody that wanted to discharge was discharged.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And the units were terminated.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "They did-- no, no longer existed.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They were-- some of them reformed after that, back in their original status.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "But I, I wanted to-- I had been in law school at the University of Arizona when I got my notice to report to the Army, which was in December of 1940.",
      "word_count": 32
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So I was anxious to get back to law school.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "I was anxious to see my two and 1/2 year old son that I had never seen.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "So I immediately applied for termination.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And it was granted.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "I then started back to law school and went summers and all and completed it at the University of Colorado.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "I got my degree in 1947, [PAUSES FOR 3 SECONDS] moved to Western Colorado.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "On the following election, I was elected district attorney over there.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In Delta, Colorado.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "That's in Western Colorado.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I have seven counties in my district.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I had a private practice of law, had a law firm.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I had formed a law firm called Sparks, Conklin, and [?",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Carol-- ?] three of us.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And we-- in the private practice, and besides, I was a district attorney.",
      "word_count": 13
    }
  ],
