{
  "stem": "10644.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 390.9,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I was little afraid, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I was all the time a Zionist.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "I was-- belonged to Zionist's organization in the university.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "I was very active summertime in the student's organization in Bialystok as a-- representing the Zionist people.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And now comes the communists.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And now the leftist students who have a, a, a-- but it was--",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Students?",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They're very, you know-- they're very with the Russians, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They are all the communists, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "So they got positions right away, et cetera.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But, in general, they didn't do me any, any harm.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I will tell you the simple thing why.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "The, the man who was the head of the remaining-- all the doctor.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall his name.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He is in Bialystok.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "He works in the-- in the administration-- health administration.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In the Jewish-- no, it was in the health administration of the city.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "There was an episode.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "When I was in high school in Miedzyrzec-- Mezritch-- there was two other Jews, one Grinburg and one Kannel.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Kannel went to study medicine, I know, somewhere in Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "He was not admitted to-- Grinburg went studying in Vilna-- I don't recall what.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "But he got involved, became a communist.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And he was distributing on the street literature.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And here, you know, Russian-- Polish police noticed him and started to chase.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And the place where he could find it was just-- I am living not far away.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He came, ran to me.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And I was-- ran to me.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And he tells me, I am running away from police.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "He is my friend.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I worked with him.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I lived with him, work with him two years, you know, in, in, in duration.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "It was-- I, [PAUSES FOR 3 SECONDS] I say, you stay in my room.",
      "word_count": 14
    }
  ],
