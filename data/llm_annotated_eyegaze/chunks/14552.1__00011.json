{
  "stem": "14552.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "And then there was the central, the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "And it, it was just a very pleasant place.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "The store-- we had a front-- we had suitcases lined up on one wall.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And the other wall were glass shelves where we had pocketbooks.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And I-- now I call it the carriage tray because you had to be very comfortable to buy there.",
      "word_count": 19
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And so we had the-- all kinds of purses and, and bags.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "And if you needed a holster for a gun, my father would make it.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And in the back, my father did the repairs.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "Or whoever ordered a suitcase, he did that.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And he loved to be there.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "He loved to work late.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "And my grandmother would come to the back door and bring him another snack, too.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "That was where he-- her way of pampering and remembering that he is her baby.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, there--",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "--was just a stove where they were warming the, the glue.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "The glue had to be kept warm.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "It smelled.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "But we, we didn't know that it was bad.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "It was good.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "For us--",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "--was good.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--leather-- the smell of leather must have been--",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Leather, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "--still love that smell of leather--",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "--yes.",
      "word_count": 1
    }
  ],
