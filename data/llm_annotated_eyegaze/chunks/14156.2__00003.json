{
  "stem": "14156.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "You know how that goes?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Like, like a, she was the, the mother-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "She, she was the, the, the, the, he was the moth-- she was the, the, the mother-in-law.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And Grandma was-- had, had reigned all over everything OK?",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "She was the-- she was just a, the daughter-in-law-- not mother-in-law, daughter-in-law.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "She was the daughter-in-law, so to speak of.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And tell us what happened to your mother?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother, in 1935, [PAUSES FOR 3 SECONDS] had an accident.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I was 11.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "In 1935, I was 11.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I was born in 1924.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I went-- I was in school.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "My grandmother wasn't home.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "My father wasn't home, out on business.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "My mother was by herself.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And we had a, a, a counter in the store.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And it was in early spring, probably about March, April.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "It was still cool like it is down there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "There was a little-- there was a stove, a coal stove, sitting in the, in the store.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And my mother was leaning over the counter, reading the paper.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Her skirt touched the oven where there was small, little plastic windows.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "One of them was somehow broke.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And the, the, the coal-- you know, the heat and the coal showed right through.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And there, she caught fire.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "I mean her, her--",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Skirt caught fire.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And as she felt that, in her, in her-- how should I say?",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She, she, she was disoriented.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And she didn't know or she forgot that she was all by herself in the home.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "She ran up upstairs, the next floor.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And she called for my father.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Or she called for somebody to help her.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "But as she was running, naturally, the flames got bigger and bigger.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Finally, she seen there was no one home.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "She ran outside.",
      "word_count": 3
    }
  ],
