{
  "stem": "1160.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I had my father's parents, and I had my mother's parents.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 4 SECONDS] one-- one grandparents, they actually lived in an area where there were-- it was a non-Jewish area.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "That was my father's parents.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather, he was a Hebrew teacher.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And my grandmother, she was-- she was a very smart, independent woman-- strong woman.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 4 SECONDS] she-- [PAUSES FOR 5 SECONDS] she-- she was doing all kind of ways to-- to-- to make their liv-- their financial [PAUSES FOR 3 SECONDS] life better, because the teaching didn't pay much.",
      "word_count": 38
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And a lot of people sent their children to the cheder, but not everybody was paying, not-- because they didn't have money to pay, not everybody had.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "So my grandmother was very creative, and she-- she was-- she was making some money also, so this way they were all right.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "What she was-- not exactly what she was selling.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "She was helping, yes, the income.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The same town, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, my grandmother was very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "When I remember her, she was already in bed.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She was a sick woman.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "She was on medication.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "She had to have medication.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And [PAUSES FOR 3 SECONDS] my mother was helping a lot to raise the youngest children, because my grandmother's illness.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the oldest child for my grandmother, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The youngest ones, yes, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Especially the youngest sister.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And, well, they all-- they were all working.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "The grandfather and my uncle and the-- my aunts, they were all-- I remember they have sewing machines in the room there.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And my grandfather was cutting, and everybody else was sewing on the machine.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And that's how they made a living.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very close, to both of them.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Both of them.",
      "word_count": 3
    }
  ],
