  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Because Lithuania, [PAUSES FOR SECONDS] I hate to say that, is one of the most anti-Semitic countries, little countries, in the world, Lithuania.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "What-- what's the reason?",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But Lithuanians it all these years hate against the Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "All the time.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "When you used to go from school home, we used to be stoned by Gentile kids.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We had to run.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "When there used to be a soccer game between Maccabi and the Lithuanian commanders, you know, teams, in soccer, and if the Jews were about to win, we had to run from the stadium very fast.",
      "word_count": 36
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Otherwise, we were beaten and stoned again.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "If a Jewish boxer knocked out a Gentile Lithuanian in the ring, the people outside the stadium-- the-- the boxing arena was in danger already.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "With clubs and stones, and the fights used to break out terrible.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And Lithuanians, [PAUSES FOR 3 SECONDS] even if they are a Catholic country, you know, the Lithuania.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And for [INAUDIBLE] the old, I-- I think, they'll all thinking that the Jews are at fault of Jesus' death.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And this is the old fanatic Lithuanians who couldn't get away from that, that we killed Jesus.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "When it was real bad, they came.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But they saw a fight where a little Gentile Lithuanian, beating up a Jewish Lithuanian, they looked a little on the side, another couple of punches wouldn't hurt.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was thinking all the time, that's how we live.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "That's, it's our country.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I was born here.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It's Lithuania.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Maybe one of these days, they are gonna get more educated, more sensible, more modern, [PAUSES FOR 3 SECONDS] and understand more, all about what life is, that we are all human beings.",
      "word_count": 33
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And have-- we are under the same God, you know.",
      "word_count": 10
    }
  ],
