{
  "stem": "1419.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "So they threw up maybe 10, 10 loaves of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So who, who grabbed the bread had a piece of bread.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Who didn't-- who didn't grab a bread or who didn't get a piece of bread didn't get any bread.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "But we traveled through Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And some, some place in Czechoslovakia, we stopped at some railroad crossings.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And people going, going through, through-- they saw us in the-- in the trucks.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "And they threw some food out at us.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They were open cattle cars.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "So a lot of people, you know, jumped from the cattle cars and tried to run away.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "They, they were-- got killed right on the spot.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Freeze in the cattle cars.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Some of them just-- as a matter of fact, I, I remember a friend of mine, he start to take  his clothes off.",
      "word_count": 23
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "He must have got-- he was getting-- was getting sick.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "He was getting a fever.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "He was taking his clothes off.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "He took his clothes off, and he, he froze to death right on the-- on the-- on the-- on the car-- on the truck.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "There were a lot of dead people arrived at, at, at Sachsenhausen.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "At Sachsenhausen, we were unloaded.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "We stayed over there-- I don't know-- a day or two.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "And they-- we were shipped to Flossenburg.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "In Flossenburg, we were then in the quarantine.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They, they, they cleaned us up again, gave us some, some, some-- what are they called?",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "The striped, striped suits.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And we were shipped to a place in either-- in Bavaria named Ganacker.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Do you remember how to spell that?",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "G-A-N-A-C-K-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "It's a small village.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Ganacker is close to-- not too far from Regensburg.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And over there, we're working on the-- on the airfield.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "We came to the place.",
      "word_count": 5
    }
  ],
