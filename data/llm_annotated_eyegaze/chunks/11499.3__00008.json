{
  "stem": "11499.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I had a friend in Los Angeles, who was an engineer on the first Apollo project.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He used to work Librascope.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And he begged me to come to Los Angeles.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "In-- what year was it, Elly?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "1957.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We came to Los Angeles in '57, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I should come to Los Angeles.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "So we-- I came to Los Angeles after leaving my uncle.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I was so mad.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I came to Los Angeles.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And I stayed with him, with my friends, for a few weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And Elly had an uncle here, her father's brother, Maury Diament.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "It was-- it was nice.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And I got a job in a suit factory, make ladies suits.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "The-- the owner was from Germany, a German Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "And he liked me, very much, right away.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And I said to him, but I cannot stay here.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "My wife is in New York.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "I don't have any money.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Don't worry, I give you money.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "I give you, just stay here.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "Don't go.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "You stay here.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "Call your wife that you stay here.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "That's what I did.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In '50, 1950 in New York.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Alice.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "In Jewish Memorial Hospital in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I forgot about her.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] So this Ernest--",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Ernest is the-- the owner of the factory I used to work.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And he liked very much.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I did a very good job with him.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Then he split with his partner.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And he opened a new business.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So he took-- took him with me, I should run his place.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "We did very well.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "We built up the-- a nice business, again.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Then he-- I ran the place very good.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I worked very hard, very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I give everything.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And he got sick with cancer, some kind of a cancer.",
      "word_count": 11
    }
  ],
