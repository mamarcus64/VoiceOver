  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And here, you know, [LAUGHS] no-- no machines, no washing, washing, she used to, you know, every month you know, she went to water.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "This is a [? vessel. ?] They call in Jewish a vessel.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It's-- and she used to, you know, like they hack the wash.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And they used to cook.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They used to cook the-- the clothes in pots, you know, they come in.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And she was always work very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And she was-- and my father died very young, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And he left all children, and they was very young, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And that's a hard life she got.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I remember my grandma-- I no remember my grandma.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "My grandfather I remember.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Now she used to sell, you know, how you-- what they make, challahs bread, haven, when it gets bigger, they put yeast, yeast.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And she used to sell this, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And a lot of woman, they bought--",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I was about 12, 11, 12 years I was old when my father died.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And when my father died, you know, I went to-- to a job, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I guess I was very religious, very Orthodox.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I used to wear, you know, a hat, payot, kippah, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I was very religious.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I went to another teacher, to Melamed, Moshe Melamed, you know, bigger.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH], you know.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I used to learn the Torah, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And still, you know, so many years, 56 I never look, and I remember, you know, [LAUGHS] everything.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Very religious.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Now, when I went away there for a job, I went away for a job, in commercial [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Commercial, [NON-ENGLISH], I used to-- we used to make the top, the top stitch by the machine, you understand?",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Of shoes.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "After by my-- after I don't make good.",
      "word_count": 8
    }
  ],
