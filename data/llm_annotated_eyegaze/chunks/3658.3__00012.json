{
  "stem": "3658.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Came to Irshava because there was a few people, a sprinkling of people arrived looking for if there's anybody alive.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "So that's when, I told you, I come back to the place.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And when I got back home, our house was completely destroyed.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "There was no house.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "It was just flat, flattened.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "What they did was they destroyed a lot of the Jewish houses and looked for gold and diamonds, if anybody put in.",
      "word_count": 22
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "But there was no house.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "It was completely destroyed.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "So I heard there's a transport in Bucharest.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "People were going to Bucharest because the, the Romanian Jews were still left there.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "And they were sort of saying that the transport should go there.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And they can be looked after more by the Joint, and to Budapest from there and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "But there was nobody in our place.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I found some cousins.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I found a cousin in Bilky.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "That's Malke's, my father's sister's son.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "The butcher.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And I also found another cousin in Irshava that I met.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "So we sort of were together.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And I traveled then to Bucharest to see if I can find somebody from my family.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I mean, I've got nothing--",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "--to do, nowhere to go.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "No papers, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I just had a little piece of paper from Wels, from there-- I haven't got it anymore.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I didn't keep it-- and no money.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "So we traveled on the top of the trains, or on the side of the train.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "You know, on the-- as you step, on a step.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "So I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Couldn't find anybody.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "There was nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they say, do you know my sister?",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Do you know my brother?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Do you know my anybody?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "If anybody had survived.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And everybody was doing the same thing.",
      "word_count": 7
    }
  ],
