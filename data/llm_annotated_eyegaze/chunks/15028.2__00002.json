{
  "stem": "15028.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We took covers.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We had some silver, [NON-ENGLISH], what we used the candles for Shabbas, dishes, and only what we were able to carry, and whatever food we had available.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Books, no, very little, very little.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My father took some [NON-ENGLISH], a couple of-- took the [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We went to next town in [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And there, matter of fact, we stayed in the same area where my-- in the same house.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I had an uncle there.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And that whole area, half of that town became the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And all the towns and villages, all the Jews were brought in there.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And we stayed together in the town, uncle and aunt with their kids.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "What I remember is, well, four to six weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And the town, we were talking for escaping, escaping.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And my brother-- older brothers than me, Mende.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "He was two years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And he was tall, strong guy.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And he and the other-- he had a partner in the lumber business.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And he and other boys in that age, four of them, somehow at night made themselves papers, somewhere in the ghetto, and escaped, and ran out of the ghetto, dressed in the-- you know, the gentiles were wearing a different costume of uniform-- white clothes, instead of regular material clothes.",
      "word_count": 50
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "They made their own clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And I never heard from them.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I never from those four guys again, till after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And I-- and so they caught them while-- in the-- in the town on the mountains.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And they brought them in to the concentration camps.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And they-- all of them disappeared.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "They're not alive.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In that town, they had transports.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "The train, they gave orders that [PAUSES FOR 6 SECONDS] one transport, they loaded up to Auschwitz.",
      "word_count": 17
    }
  ],
