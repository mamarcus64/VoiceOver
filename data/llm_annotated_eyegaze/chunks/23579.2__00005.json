{
  "stem": "23579.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And they took 50 from the best people of Novogrudok.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "They was lawyers, doctors, and they shot them blank [PAUSES FOR 4 SECONDS] in the marketplace in Novogrudok.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "Then we knew what is the war.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "What is the war, meaning from the war.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "After that-- this was in November.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "In December, they said that the ghetto has to be built.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "Everybody from their houses has to go out and we will build you a ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "You will be living in the ghetto, the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "This was December.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We slept already-- my friends was in my room still.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I slept with my papa and my mama in her bed.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And about two, three o'clock, I was dreaming.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And I wake up with crying, terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Mommy, I got shot in the head from a German.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I waked up my father and mother, and my mother said, OK.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "We show them this is a [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "You know what is it?",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "This is a dream that you have to go away.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Something will be.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Because she never dreamed, Sonia.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And this was the day where they took all of the Jewish people to the graves.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So my mother was very good to my father.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "We had a friend, [?",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Marvin ?] and he had a brother in Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "He came with the brother from Warsaw with a small girl-- six, seven years old.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And he didn't know how to take care of her.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "So my mother took her to the family.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And when they decided that we have to go away this day.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We have to go away from Novogrudok.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "So my mother said, you take the children and go away.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "You know where to go.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I will take the baby, and I will put him in a very good hand.",
      "word_count": 16
    }
  ],
