  "model": "openai/gpt-oss-120b",
  "elapsed_s": 260.8,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "So I said, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "I have relatives in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "And that's where I would like to go.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "So he said, do you know their names?",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "I have an uncle by the name Sol Wetizman.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "That's my mother's brother.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "And my mother's sister is Kaila Geller.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Geller, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they came before, after the World War I.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They went to America.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "My uncle was 14 years old, and his sister.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "My mother was supposed to go, but she had some of the [NON-ENGLISH] kids, that they're, you know, they say, where we are we going to go?",
      "word_count": 27
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And the kid stayed where the mother stayed.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "She had really papers and the war broke out.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "Somewhere it was World War II, or I, or II; I, I think.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "I'm mixed up.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "Anyway, so this is-- the-- so he gave-- he took the names, and he gave these-- the names into the the Jewish And it went to United States.",
      "word_count": 28
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "And my uncle told us-- just recently he told me that day, the phone did not stop ringing.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 11,
      "text": "Everybody-- my uncle-- my uncle was known in Brooklyn.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 12,
      "text": "Everybody-- he was the president of the society.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Stepan society.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Everybody called, if he knows if he saw on the paper that there's a survivor from his family that has survived.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "So-- it was-- it was something.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] Sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I [CRYING] didn't think I'll do that.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, [INAUDIBLE] he started to write to me letters.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I give him the address that this is where-- you know, they had [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And-- and he kept on writing, and I kept writing back.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And then he made papers for us to come.",
      "word_count": 9
    }
  ],
