{
  "stem": "7358.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We used to grind the-- the wheat from the surrounding neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Most of the villages in our area were agricultural.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And they used to come to our town for-- in the harvest time, to-- to grind the wheat.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a-- my mother was a housewife, in a sense.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "But she was also a photographer.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Before my father married my mother, she-- she was a photographer.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "She also was college educated.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And for those days, she was a progressive woman.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "My father maintained a photography for my mother, so she would not feel that she has to give up her profession.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And we used to hire people from the town that worked for us.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, we-- we lived in a [? very-- ?] we had a private home, a one-family house.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It was very close to the-- to the Tarbut, which-- to the Hebrew school, which was sort of the newer part of town.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And we had a very comfortable home with a garden, which was the style.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And basically, that's it.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We had-- we had a live-in maid in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And we had a, a woman that used to come in and do the laundry and light the stoves in the winter, you know, for heating purposes.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I-- I attended Hebrew school, and my-- so did my older sister.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And my little sister attended kindergarten.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The school was privately funded, and my father was apparently a contributor.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And he was the honorary president of the-- of the Board of Trustees, I suppose.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The school was mostly-- was only for Jewish children, because the-- the main-- the main teaching in school was-- was done in Hebrew.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And Polish was taught as a language.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And we used to talk to each other in Hebrew.",
      "word_count": 10
    }
  ],
