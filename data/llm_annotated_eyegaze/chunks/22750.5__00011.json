  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "Because took four years, the history [? if we want, ?] it took me 10 years from the history when we started until I came to the United States, a refugee.",
      "word_count": 31
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 11,
      "text": "It took 10 years.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 12,
      "text": "Because the history it was started in '39.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 13,
      "text": "And I came here '49.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 14,
      "text": "And never a normal life, and never in a-- in a house, [? in ?] [? my ?] [? home ?] [? of ?] [? my ?] living, usually. 10 years, it took.",
      "word_count": 33
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They killed them in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "This is the-- the picture, where they are, with all the people there, where they took--",
      "word_count": 16
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "That-- what year they kill them?",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "In 1942, then, yes, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The Germans.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "The Germans didn't kill.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "The main thing, the killers, was Ukrainian, most of them.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "They belonged to [? militia. ?] But the German was fighters, and they were in the army.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And they took helpers when they came.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "For this-- where you know, most in our area was Ukrainian.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "They took them-- this I heard later.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Because we had friends too.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "And-- and they told me they saw when they-- they took my mother with my-- with other Jews, on-- on trucks.",
      "word_count": 21
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And they brought them to their grave.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And that's where they kill-- they killed her.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Outside, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Did I show you the picture?",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, you see the picture.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "You have to see the picture of the grave.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And this is by a miracle.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And what-- my mind, not because I want [? the ?] [? carrot. ?] I'm older.",
      "word_count": 16
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "I know what's waiting for me tomorrow, will be the same thing as everybody.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "But my mind was not this way.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "When I make the picture, when I-- when I survived, I had a mind to do it, and I did  it.",
      "word_count": 21
    }
  ],
