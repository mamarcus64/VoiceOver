  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was to see him, though, soon, because in late June of 1939, a transport was arranged for me and the other kids, many of the other kids in that orphanage, to go up to Paris to be taken care of by way of the O.S.E-- O-S-E.",
      "word_count": 47
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "O period, S period, E period, which is an organization.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "It stands for Oeuvre de Secours aux Enfants-- Organization of Help to Children, which, actually, originally was formed in Russia.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "A Jewish organization.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And they had prepared a home for this group of kids from Berlin near Paris in June of 19-- end of June of 1939, where we came.",
      "word_count": 27
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And it was a beautiful summer, by the way, that year.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And I remember the garden.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "This was a small, almost like a residence-- there were 40 of us-- a large residence.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "There was a French gardener and a few other staff as we arrived there.",
      "word_count": 14
    }
  ],
