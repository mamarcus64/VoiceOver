{
  "stem": "3212.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "That was the song that we had to sing.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but we were-- we-- we knew we will never get out of there.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We-- then we had to work in this stone thing.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It-- in Buchenwald, Walter and me and the other kids who were there, we worked over in this-- in this stone mountain.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "During the time they told us things.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, in-- in Buchenwald, they brought-- this I know and we saw-- there was barracks.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "There was Russian soldiers they-- they captured.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And there was one barrack with a weight, and the Russian soldiers came in for a check-up, and behind the weight, the SS was standing, and everybody was shot.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "They had ditches for the blood.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And all the Russian captures, they got killed there.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "They-- they made appells for the Russians to stay outside in an appell.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The head of the SS, the woman, went through selection, selected all the Russians that had beautiful [GERMAN].",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "How do you call it?",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Tattoos.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Tattoos.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They had beautiful tattoos on their body.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they took them, they cut it out, and they made lamps, handbags, all kind of things that she liked.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And they-- they-- they-- it still exists till today.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We were there in-- in-- in-- in Buchenwald till it came-- before April.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I remember Walter's birthday.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "It was on 4th of April.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "But before that, they sent all kind of transports out of the camps.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "We were told a lot of thousands of people they took outside the camps and killed them.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Put in barracks and put bombs in it, shooting, all kind of killings.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "They want to get rid of the people.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I remember Walter's birthday was on 4th of April, that we saved up bread crumbs.",
      "word_count": 15
    }
  ],
