  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 56,
      "text": "We was doing a lot of mileage daily, and we came to Lwow.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 57,
      "text": "We came to the city Lwow.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 58,
      "text": "When we came to the city Lwow, the Russian army was already there.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 59,
      "text": "A day before, they came in.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 60,
      "text": "They took-- the reason they took Lwow, because they don't want that Hitler should take it.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 61,
      "text": "Because they've got-- they've got [PAUSES FOR 4 SECONDS] a reunion [INAUDIBLE] I think before Germany attack Poland, that Russia will take Lwow in a certain part, and the Russian army came in and took it.",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And when I came-- when I came to Lwow, I didn't speak.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I speak a little bit Russian, not too much, but you know.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I met friends of my father in Lwow, and he told me, Alex-- [?",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Issa, ?] what do want to do?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He called me [?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Issa ?] in this particular time.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I said I don't know what I will do.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I think I like to sell something.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I said I don't have nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I don't have money.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Money I will give you.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "How much you need?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I said I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "What we can do, I say, we buy cigarettes from the Polish people, and I will sell to the Russian army soldiers.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "He said good.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We make a price.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I was a kid.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] [PAUSES FOR 6 SECONDS] [DRINKS] And I was doing that, and I was working every day, running around between the Russian soldiers and selling cigarettes and taking ruble.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And one time, we had that the Russian did [PAUSES FOR 4 SECONDS] did register people to go to Russia.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't stay in Lwow, nothing to do, and they give money.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I with my friends was going to register.",
      "word_count": 9
    }
  ],
