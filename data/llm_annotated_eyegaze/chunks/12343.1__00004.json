{
  "stem": "12343.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You know the picture I show before, the people that are in Israel, my mother used to go work for them, too.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "She used to come, said, your mother will leave now-- [CRYING] She was a [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "She started to cry, too.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She said to me, if your mother would leave now, [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "They love her.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "She was-- she was never-- [CRYING] oh, let me talk something else.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh, not like here.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Those Jews were [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I can show you.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "The said with 4,000 people there, more than just Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "That was a small town [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I got [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Was after the war, the other [INAUDIBLE]-- how you call, [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "That's over 4,000 gone and dead in concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Lot of them-- lot of them-- mostly Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "Most [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I never think to pay attention.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I didn't pay attention.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] I don't care.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Here, you care how many.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "In Europe, you don't care how many people.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "You got your friend, you got a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Who care how many people?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Mostly-- mostly Gentiles used to live out-- out of the city.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "Most.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "Oh, I don't care how many.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I never pay attention to this.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they used to-- used to send it out of [NON-ENGLISH], they call the camps the summertime, together.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Used to go [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Used to go all the time in meetings together, and talk about Israel, talk everythings.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They-- [INAUDIBLE] Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Every time.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Going dance, all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Every-- every-- after work, right after work, we used to go to it.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "They called it, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I don't know what to call it in English.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "I don't care because there's no organization [? here ?] too much.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "It's not like Europe.",
      "word_count": 4
    }
  ],
