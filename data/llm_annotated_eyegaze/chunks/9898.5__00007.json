{
  "stem": "9898.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Those who didn't, were healthy, were able to, to go to Israel or any other country.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] So-- and then we left there.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And we went to Regensburg from Amberg.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And I was employed there again for the camps by the Palestine Jewish organization, I think they called them, or something like this.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I was very active through all the four years.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "I, I worked for them for the last two years, from '47 to '49.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "We were living in Regensburg.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "I had my apartment or a house.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "It was easy living.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "The Germans, [PAUSES FOR 3 SECONDS] they said no.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "They loved to say that it was a hoax, the whole-- the whole Holocaust.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "They couldn't believe me, everybody said.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "I was-- I didn't know anything about it.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "They lived next to the concentration camps.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "They saw us in Hersbruck.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "After the war, not during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes, during-- after the war, you--",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "After the war, sure.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Germany was a free Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I talked to the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But everyone said, I didn't know anything about it.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Nobody knew anything!",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] So-- but we convinced them and tried to convince them what happened there.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And in-- I got a visa from the American Joint Distribution Committee.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They gave me a visa.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I was supposed to go to Israel because I had a cousin in Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "But they said to my wife, you are not the type for Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "You better go to-- come to America.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And they gave me the visa, the first.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "There were 50 visas.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I got number one because I was very active during the whole four years.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
