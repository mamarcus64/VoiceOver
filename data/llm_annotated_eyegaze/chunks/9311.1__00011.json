  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "They gave me their bread.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "They gave me everything.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "Because they weren't hungry like me.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "And every single day, I got thinner and thinner.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "All the swelling went down.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "And I said, I'm not gonna die.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 20,
      "text": "These kept me not-- not to die, only aiming that I'll come to Canada to see my sisters.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 21,
      "text": "After the month, I came back to the kolkhoz.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 22,
      "text": "I have shoes from home.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 23,
      "text": "I couldn't wear them still.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 24,
      "text": "A dress what I couldn't wear.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 25,
      "text": "I looked just like I came from home.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 26,
      "text": "Now, I have strength again, hopefully till the war will be finished.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
