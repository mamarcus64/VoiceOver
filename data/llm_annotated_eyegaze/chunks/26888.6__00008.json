{
  "stem": "26888.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And first I came, I was in a room.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "It was a horrible room.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "There was a woman, she-- she weighed about 300 pounds, very poor.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "Her husband was 70 years old, she was 34.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "That would be in a room like this.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "And I was crying, day and night.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "Little bugs everywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "And my daughter was crying all night, because the bugs are biting her.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "And it was a horrible, horrible place.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "But then, I don't know, we couldn't stay anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "We find another room, another place.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "Again, in another room.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "That time, I think, the second time, my husband made a little bit more money-- not too much, also.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "And I lived about for seven months there.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "And she find out that I'm pregnant, and she says, no way.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "There is no place for me.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "You have to go somewhere else.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 33,
      "text": "So what we did, as it was very hard to find a house, and they wanted us a lot of key money-- $700 key money.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 34,
      "text": "We find a house.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 35,
      "text": "It was a big house, old furniture.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 36,
      "text": "You touch them, they fall apart.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 37,
      "text": "But he wanted $700 key money.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 38,
      "text": "So we went to, a [INAUDIBLE], call it, and we borrowed money.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 39,
      "text": "So somebody signed for us, a friend who came a year before us.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 40,
      "text": "And we got money, and we moved it in the house, the big house.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 41,
      "text": "It was a very dirty house, but I didn't have money to paint.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So but what I did, there was an upstairs and a downstairs, and the upstairs I rented it.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I had a bunch of boarders there, three boarders there.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And that's how I had my son.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He had a place already downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I had boarders, they paid me.",
      "word_count": 7
    }
  ],
