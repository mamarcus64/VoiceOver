{
  "stem": "7600.5",
  "chunk_idx": 18,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I'd never made $12 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I'd lived on-- oh yeah, before that, I also tried-- the Jewish agency gave a, a class for people that wanted to learn sewing and go into the garment district.",
      "word_count": 30
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I took this course.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And they supported me, like, with $7 a week.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "But after that, they wouldn't give you a job.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "You learned how to put-- use the machine and how to put things together.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "You had to go around to the various unions.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And I went around, made my way.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And I couldn't get a job.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "This-- if you had a little experience in Europe, they got a job.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Then somebody once said, oh, yeah, you want a job?",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I tell you, come to a, come to a party tonight.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And we'll get you settled.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I told this to Betty.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "She says, don't go to any parties.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "You don't know what they do there.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "So that was finished.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "So when I came back, I said, you know, I come to your party after you get me a job.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "He says, oh, if you don't come to the party, there's no job.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "So that's when I got this job out in the Catskills.",
      "word_count": 11
    }
  ],
