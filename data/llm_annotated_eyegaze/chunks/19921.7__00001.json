{
  "stem": "19921.7",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 351.3,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And there's a garden.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "People are planting there.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Probably herself too.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Or the next door neighbor.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Is she the one who told you what happened to your mother and brothers?",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She is the one which told me that they went to ghetto, and that the ghetto was liquidated in 1942.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She did not tell me exactly that-- how or when or what.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "She just told me that the ghetto was liquidated and ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "She didn't know-- she says, people were sent-- they were sent to Belzec, and they were sent to Auschwitz.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But she does not know which way she-- which way who went.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Now-- so I had a short visit.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I did not stay over in her house.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "I was looking for people which-- Jewish people which came back.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I-- somebody told me-- as a matter of fact, she told me that down the street, there's a family, two brothers which survive in Hungary.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And they came back to Bochnia.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And they are there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And then there's a-- people congregate at one of the places by Schanser.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Schanser was a manufacturer of soap.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And Schanser is the one which donated the synagogue to the city, and the synagogue was named Schanser Synagogue.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And that's the synagogue which I was bar-- bar mitzvah in.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And so I went to that build-- to that house.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And I met one of the Schanser kid only survived.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "Aaron Schanser was his name.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "Later I found out he passed away in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "But Aaron Schanser survived.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And then there were eight other people there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "I don't know everybody's name.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "But one of the girls was-- her name was Schneider.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "Schneider [?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "Ruvna. ?] And she was a colleague of mine.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "We belonged to the same Zionist organization.",
      "word_count": 7
    }
  ],
