{
  "stem": "1775.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 142.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "When we-- when spring started to come, and they said that we have to leave, we started to say when the corn is going to go-- grow higher, and we'll be able to go away, to hide in the corn.",
      "word_count": 40
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We're going to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We're not going to make any trouble for nobody.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We're going to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "But the corn has to grow a little higher.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "But they were-- I guess a lot of people in that thing knew about us, but they just didn't pay no attention.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "They didn't give us-- give us away to the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Because like nothing, they could have told on us.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "But they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And they were very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And we were there a year.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "We were there until we were liberated, because we couldn't have an occasion to go away.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "Everything was happening-- anything that's happening was happening right there.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "There's was a lot of Jewish boys killed there, in the [? same ?] Jelnica.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "One of our friends came to us, and we told him to stick with us, not to go away by himself.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "And he didn't listen.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "And he went away, and he got killed.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "The following night, he was dead.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "Because there were-- there were the [NON-ENGLISH] working at that time-- very, very high.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "And they were just looking for Jews to kill.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 25,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 26,
      "text": "And we-- we were liberated in July.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 27,
      "text": "We were there a little over a-- a little over a-- a week more than a year, we were there, in hiding.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "There was one Witkowski, one Kavenski, one Podgani, and especially Noresto Renkus.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They were marvelous.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They never asked for money.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They never asked for nothing.",
      "word_count": 5
    }
  ],
