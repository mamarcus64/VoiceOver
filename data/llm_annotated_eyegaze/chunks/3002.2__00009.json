{
  "stem": "3002.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I was walking, I remember, in a dress that I just had on me, and a pair of sandals-- that's all.",
      "word_count": 21
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "I arrived to Zdolbunow in the evening, and I hear the shootings all around.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I asked for the headquarters of this company, and in-- in-- Groebe.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "I wanted to see Groebe.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "Somebody showed me to the place.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And I-- as I said before, I was so lucky.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "I came into his office, and he was there.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "It really-- it-- it sounds like it's not real.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "When I told him I'm Jewish, I'm running, and I need help, he didn't even hesitate for a second.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "He called one of his drivers.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "The driver came with a-- not car-- a open trunk.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 13,
      "text": "And I was-- he took me to a building where those people from the company, the Germans from the company, lived.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "The-- the quarters of theirs where they were sleeping there.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And he opened one of the rooms.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "He let me into the room.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "He left.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "He put the lock outside.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "And I was there the whole night.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Alone-- while all this shooting was going on around me.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Tell me about it.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, I was crying the whole night.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Later on, I found out that the liquidation of the ghetto in Zdolbunow was going on that night.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
