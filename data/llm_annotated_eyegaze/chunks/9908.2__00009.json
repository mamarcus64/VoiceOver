{
  "stem": "9908.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And when they finished, they digged the grave for the oncoming.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And there was my little brother, too.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "People were saying that they been buried alive.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "There was a couple with four children and a wife.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "We were three children-- then my little boy-- my little brother was gone already.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And-- and then-- and only one single lady.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "In one little house they were-- in one little house-- there were three families in one little house.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So it wasn't enough for the people to get in.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They build-- you should see some-- some houses-- for the people.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "My cousin-- she was-- between them, she got a-- a flat in the new buildings.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "My father was a celebrity with the Germans, so they gave him a nice room-- one room.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And-- What street were you in?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I-- this was a-- just a-- a developing.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I really couldn't tell you about this street.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I know it was-- where it was.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And every day, we walked to the shops and sewed.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "My mother, she never knew how to keep a needle in her hands, because she was left-handed.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And everybody was a tailor in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So my mother didn't know how to sew.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So we had to go.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "In order to get your ration, you had to work.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "If you didn't work, you don't eat-- to get the ration.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So we took our mother with us, and she said-- and we've been sewing for her-- my sister and myself.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And we made her production.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And she got every day a soup in Ozorkow.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't as bad in Ozorkow as it came later.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Because we went out, and we had people which knew us-- somebody-- something-- somebody sold this and that.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "We-- we-- we lived.",
      "word_count": 4
    }
  ],
