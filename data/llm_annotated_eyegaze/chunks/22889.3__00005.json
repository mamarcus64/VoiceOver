{
  "stem": "22889.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So after I got through with that, I was sent to-- we used to travel by train, not too far from my home town, another 13 miles-- 13 kilometers-- a small, little village town they called Czarny Dunajec-- capital C-Z-A-R-N-Y dash D-U-N-A-J-E-C.",
      "word_count": 42
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I used to work in a-- we used to-- it was like a-- like a mine.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We used to mine sand.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We used to dig out sand.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "We used to sort small stone, different-- different size of the stones, then till we come to sand.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "The company name was the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "It was a German company.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I used to travel every day home, back and forth on a train.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We start early in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And we work till evening.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "We got home late night.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, Judenrat, which means-- Judenrat was a Jewish community center.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "It's not-- I mean, it was a center, that's true.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Judenrat-- you know what Judenrat is.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The Judenrat usually was--",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In the--",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "--leadership of a ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "They were leadership of the Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And one man was in charge.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "His name was [NON-ENGLISH], Leon-- [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "He was in charge to the gang labor, to send people to work.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "My father joined later on the Judenrat, also.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "My father used to work with the people.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "For instance, a-- it was a group of us, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And my father had to deliver us to the work.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "Then he went back-- keeping order.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "There was no changes until about 1941--",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "--till the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Dunajec.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Every night I come back to home, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I worked--",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I worked down there for about a-- let's see-- for about a year-- for about a year.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Then-- then I was assigned, also in Czarny Dunajec, to lumber yard.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "We used to go.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "We used to chop the timber.",
      "word_count": 6
    }
  ],
