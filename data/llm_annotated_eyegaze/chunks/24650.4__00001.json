{
  "stem": "24650.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] the main boss, [INAUDIBLE] was the main boss.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] is like a-- a general-- a general major.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And he called me to come.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And he asked me questions.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He put a piece of [NON-ENGLISH] from the machine, a piece of [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he's gone on the table.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And he hold me an hour and a half.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "How did they run away?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "How come I didn't know?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Why didn't I tell?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I said, I didn't know nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "The people that ran were amongst the 10 that you were--",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Among the 12.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "No, among the 12 who run together and four run separate.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They run-- I didn't know where they run.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I just know that my [INAUDIBLE], the lady who had a husband, he came with his cousin.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And he saw me through the through the-- toilet, excuse me.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And he said to her, take your friend.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I will hold her.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And I said, no, I didn't go.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So, then after we came home-- home, in concentration camp, [INAUDIBLE] asked me to come.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And he asked me questions.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I told him that I really didn't know where they did go.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "But I would never tell, that's for sure.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He said to me-- by the end, he said to me, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "That means my hair-- my hair must be cut.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I must have the striped dresses.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "So I said, thank you, Herr Kommandant.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Danke, Herr Kommandant.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "That means I thank him.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He said, just a moment, why?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I said, my head is here.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Hair will grow.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "He said, out of here.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So, I did go out.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Twice he helped me.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "That's true.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Twice he helped.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Once he helped me when we came.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if I told you.",
      "word_count": 7
    }
  ],
