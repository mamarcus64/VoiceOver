{
  "stem": "9.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 53,
      "text": "They were making lamp shades from human skin.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 54,
      "text": "They were making-- using blood for various experiments.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 55,
      "text": "And many horrible things were happening.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 56,
      "text": "Everything was camouflaged.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 57,
      "text": "In Auschwitz, there was-- I think it would be a mile or two miles away was a-- Birkenau, and that's where the cremetorias were.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 58,
      "text": "Every day we had absolutely nothing to do.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 59,
      "text": "The psychology was mentally-- mental degradation, mental suppression, so the people themselves die, I presume.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 60,
      "text": "Every day we would have to stand on what they called appell, which is in the army, they call it differently.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 61,
      "text": "I don't know exactly what.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 62,
      "text": "You stay attention for hours.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 63,
      "text": "If it was cold or hot, it didn't matter.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 64,
      "text": "Not allowed to go to the bathroom, but don't make it on the place where you stand, because you're shot immediately.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 65,
      "text": "We were given few minutes per day to wash, which was impossible for hundreds and thousands of people, but we had to be clean.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 66,
      "text": "We were given one what they called a meal a day.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 67,
      "text": "It was a piece of bread plus some hot cabbage soup that you could barely see a piece of cabbage floating around, and some coffee.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 68,
      "text": "And that we had to divide into whole day.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 69,
      "text": "Whenever we-- whatever we pleased, we could do that.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So the degradation, mental depression was tremendous.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Every day there was a what they called a selection, when SS men would come in and say, you go to the right and you go to the left.",
      "word_count": 29
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "The people on the right disappeared and they were getting killed in crematoria.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "The people on the left stayed.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "After-- now, I do have to tell you that in Auschwitz, there were not only Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "There were other nationalities also for various reasons.",
      "word_count": 8
    }
  ],
