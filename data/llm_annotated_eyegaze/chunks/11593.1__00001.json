{
  "stem": "11593.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My aunt was a widow.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Her husband died young, and she had two children.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And she operate a-- a restaurant and a guest house.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother on my-- and grandfather on my-- on my mother's side-- my grandfather was managing an estate for a prince who basically was farming and lumber.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my grandmother with her three sons were running a guest house and a-- what do you call?-- a tobacco store.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My other two uncles became lumber engineers-- you know, forest engineers.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And they moved on to a larger city and continued to be forest engineers.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "When I reached the age of school age, I-- I went to a school, a private school called Tarbut, which all subjects were taught in Hebrew, but we were taking Polish, Ukrainian, Russian, and other foreign language.",
      "word_count": 37
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Our town, Zdolbunow, was about a little over 12,000 people, and close to 1,200 Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We had a Polish high school, a Ukraine high school, and a Czech high school.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "The population of the town comprised of majority Ukrainians, Poles, about 10% of the Jews, and Czechs, and some Germans who were left over from the First World War.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We had a Catholic church, and a-- and a-- and also a-- a Czech church.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "We had a Greek Catholic and a Roman Catholic church.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We had a Polish high school.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "We had a Czech high school.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "We had a private school, Tarbut, and some religious schools.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "The neighbors, they were quite friendly.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "We-- all the ethnic groups had no ethnical problems.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "They were trying to build a new society because leaving the czar, they had to start over from scratch.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And the Polish government awarded some Polish officers some land.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "They became land owners and large farmers.",
      "word_count": 7
    }
  ],
