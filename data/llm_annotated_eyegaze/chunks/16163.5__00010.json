  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "No straw or, or covers or anything.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Just the wood and that's where [INAUDIBLE]-- on five at-- five people at a time on each.",
      "word_count": 17
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No mattress.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "No covers.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "No nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Just us.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "It was bitter cold.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "It was very cold, and it was in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "It's very cold there.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "I know being very cold and very hungry [BACKROUND NOISE] and very dirty [PAUSES FOR 3 SECONDS] and feeling my head.",
      "word_count": 21
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "Where's my hair?",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "My mother and I, we were together all the time.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "We huddled together.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "Maybe that kept us warm.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Being afraid, because by then we knew when we saw the smoke from the chimneys that they were extermination gas ovens.",
      "word_count": 21
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "Being afraid from one minute to the other, now they take us.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Because it was like a period of [INAUDIBLE] waiting and doing nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "Once they either took us to what they called the latrine.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "You know, to the--",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "--bathrooms.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "And that's-- one day, a girl approached me-- if I have a piece of bread to give her, she would give me a knife.",
      "word_count": 24
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And I still have the knife today.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "I gave her my bread.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "And she gave me-- I wanted a knife.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Don't ask me why.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "But I had a knife.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I was the big shot.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "I had a knife.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "Nothing to cut with, right?",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "And-- But if you were so hungry, why did you give up the bread?",
      "word_count": 14
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "I thought maybe with a knife I could save my life.",
      "word_count": 11
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, of course.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "She was right next to me.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "Everything happened together to us.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "From that minute on, everything happened together.",
      "word_count": 7
    }
  ],
