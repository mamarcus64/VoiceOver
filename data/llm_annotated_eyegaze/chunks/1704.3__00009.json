{
  "stem": "1704.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.3,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You know, there was one woman with two grown up children-- well, grown up, maybe 12, 13 years-- and her husband died.",
      "word_count": 22
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "She was whole night, she was sitting there next to her dead husband.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I had my locket in there, and I left it there.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Forgot it all.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Never saw it again.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And we had to go to the houses of the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "Well, I wasn't that active, and the people I was with, you know, we took it easy.",
      "word_count": 17
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "And by the time we came in the village, most of the houses were taken.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "And we found a house and just put a mattress on the floor.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "And some people got nice bedrooms.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "The cellars of those houses were full of food, bottled-- you know, bottled food.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 9,
      "text": "They had plenty.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "So we lived in that house until I got typhoid again, a different kind of typhoid.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Everybody got typhoid again.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "Lots of people died, couldn't-- the food, they couldn't stand the food.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Stomach wasn't used to it.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "They died.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Were you with anybody who died?",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And the Russians opened up a hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "But somehow, I didn't go to that hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "Then I got a little bit better.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And I could walk around.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "And then one morning, the Russians are coming to shave our heads, you know, because of the lice.",
      "word_count": 18
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "So the Russians came in the front door of our house, and I went out the back.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "And I walked and walked and walked all day.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "I didn't want my head shaven.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "That's something, you know, I don't want a shaven head.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "And then there was somebody who, for a bit of food, he would clean your head.",
      "word_count": 16
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "A special comb.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "I think it was my comb, but I lost it.",
      "word_count": 10
    }
  ],
