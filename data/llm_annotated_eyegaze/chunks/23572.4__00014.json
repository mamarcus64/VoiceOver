{
  "stem": "23572.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So I went to-- I went to England.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "On the way back, I got a Swiss visa, a transit visa.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "On the way back, I was supposed to-- I was supposed to go back to the Swiss consulate in London and get myself a transit visa back to Italy.",
      "word_count": 29
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "So when I arrived-- the plane arrives in-- in-- in Switzerland.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "You know, right away they-- they question me.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "Where is your-- where is your-- your Swiss transit visa?",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "I knew damn well I didn't have it.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "I said, what do you mean?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "There wasn't this visa-- No, no, no.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "I said, look, you want to check up on me, I used to work for you guys.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "I was a military police interpreter.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "They checked it out.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "They said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "They gave me a visa.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I went back to Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I came over here on the last-- I came over by boat.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was called the the steamship It was a Polish owned boat, Polish flag, which-- which went between Genoa, Italy and New York.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So I came over here by boat from Italy.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes April of-- April of 1949, I think it was.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Something like that.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "You know, I don't have the exact date.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "April '49.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I first went-- first went to Halifax.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "This boat-- this boat went from Geneva-- from-- from Genoa, Italy.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "It first landed in Halifax, Nova Scotia, Canada.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "There-- they-- they let us out, even though we had no Canadian papers.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "But, you know, we weren't going anywhere, so four of us, we rented a taxi.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "He gave us a tour of Halifax, Nova Scotia.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "We landed-- we landed a few days later in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And a friend of mine who is now my close friend, lived in New York.",
      "word_count": 15
    }
  ],
