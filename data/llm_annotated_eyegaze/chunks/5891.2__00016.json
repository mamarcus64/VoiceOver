{
  "stem": "5891.2",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So I said I don't know where to go.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And I had a terrible toothache.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And he said, well, he said, why don't you wait and I'll see what I could do?",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "So he came over with another-- I was sitting there, waiting for him to come.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "He came with another block leader, from eight, from block eight.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And they said come with us, come with us.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And they took me up in some near sick block there.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And there were in there was a Polish guy.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "He was a prisoner, but he used to be a dentist.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So they sat me down over there [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They set me on the table.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They're going to hold me down there.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "But I had a terrible toothache.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And what they did [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Well, this man pulled-- I lost my first tooth there, pulled my eye tooth, with one root.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And he took that tooth out.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And he showed it, and there was a little sack hanging on the bottom.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "He said, are you lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "He said, if that little sack would have went, there was pus in that thing.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "They would have went and would have killed me, right then and there.",
      "word_count": 13
    }
  ],
