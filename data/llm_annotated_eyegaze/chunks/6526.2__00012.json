{
  "stem": "6526.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no work.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We were trying to get-- where's some money?",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "We used buy the bread from the Polish bakers and so on.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But we were only there nine days.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "But being in the ghetto, one of the police-- of the German police and Polish police-- found out that my brother and I are alive, that we are there.",
      "word_count": 29
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Being that they knew that we always used to get things, but they know that-- they called us the night before, on December 8, in the evening, they told some where are the [POLISH]?",
      "word_count": 34
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So my brother and I went over to see them.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And my brother said, no, you know something, let's not go both together.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I'll go by myself, in case, who knows what can happen?",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "When he went there, they gave him an order for-- we need-- I will need something for his wife.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "The other one needs a pair of earrings.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And a big order of a big business.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "So my brother says, look, we just came in.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "We'll have to look around.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "We'll see what happens.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And we found out in the morning, we got up about 6:00, we hear already shooting.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And there we were with the Germans and the Polish police and the Lithuanians and Latvians and Ukrainians were getting to deport us again.",
      "word_count": 24
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So I ran away from wherever I was with a friend of mine that's in the picture-- in the picture.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And we wanted to get out of town.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "There was a policeman that used to practically live at our house and eat, stretched his gun and shooting at us.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "He didn't catch me, but he caught my friend, died right in front of me.",
      "word_count": 15
    }
  ],
