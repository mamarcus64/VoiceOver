{
  "stem": "1765.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 265.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "So four of us slept on each bed.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And if one had to turn around at night, then you had to tap the people next to you so they could turn around with you.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And there was a Russian couple and a baby.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And there was a stove and a place to eat, and a little, like a anteroom, sort of like a shed, which was a-- these were all [PAUSES FOR 4 SECONDS] mud houses, you know, made out of mud blocks.",
      "word_count": 40
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "They were-- the fancy houses in [INAUDIBLE] were made of logs.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "They were log cabins.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "But the houses we lived in were really mud huts.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "The hut-- the first hut we lived in had a wooden floor.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "The others didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "We had sort of mud on the floor, which was like white-washed.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And this is where we lived, and my father worked in a [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "You know what a [NON-ENGLISH] is, a communal farm.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "And he worked in their office because he was very good with figures.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "He was an electrical engineer, but he was an excellent sort of bookkeeper.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "And my mother was put to work in the bakery.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "She always drew the-- the hardest work.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "But she could eat in the bakery.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "So we were able to use her ration of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "And I started school.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "I got to go to school there.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We had to go to the-- what was virtually the police station, and we were assigned to families who would have to take us in.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They weren't thrilled to have us, believe me.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But all these people came from different-- from that gypsum mine and some-- it's not hundreds.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "You know, it was maybe 150, 120 people came.",
      "word_count": 9
    }
  ],
