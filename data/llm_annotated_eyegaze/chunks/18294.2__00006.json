{
  "stem": "18294.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 22.3,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "They took away my mother and my mother-in-law, and threw them on the left, and for me, they threw me on the right.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "So I had a watch on my hand.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And I said to the German, from-- from far away to my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "I said mom, I'm going to give German the watch, and I'm coming to you.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "I'm not going without you.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "And she started-- at first the German didn't took me, pushed me back.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "And she started to scream from far away.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "Don't you dare come to us.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "We're all going to shoot.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "Because we are old people.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "And you young, and it will be a normal world.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "You meet your husband, and you will be alive.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "Don't you dare come to me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The German didn't let me.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I would go.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I wouldn't listen to her.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Who-- who leaves their mother?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They didn't-- they just-- they take me there.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I went to the-- to the right.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And then we-- we were concentrated to the camps.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "So your father and your brother--",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "My father-- my father and my brother went for the mens.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They were separate.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "We-- they didn't permit a mens together.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "By the liquidation from ghetto, they make already, two separate places, one for the womans, one for the mens.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So I-- when I went out from the ghetto, this was it.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I never saw my brother and my father.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "My brother went with my father.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Now my father was very young looking, and they put him on the right, with my brother together, to live-- to live.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Just it was bad luck that he was very sick.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And he went in, there was actually in the concentration camp for children, and he was 13 years old.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "So they took him.",
      "word_count": 4
    }
  ],
