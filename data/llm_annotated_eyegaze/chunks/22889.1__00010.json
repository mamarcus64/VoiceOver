{
  "stem": "22889.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And he wouldn't travel, so I had to go down there-- had a bar mitzvah in his hometown.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I was bar mitzvahed, I was dressed up like a regular Hasid, the [NON-ENGLISH] and a girdle.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And I had to-- everything was in Yiddish.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Everything's in Hebrew.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I didn't conduct the whole services, only when they call you for the Torah.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Of course, I knew that very well, because I had a good training.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "At home we spoke Polish, German, and Yiddish-- mostly, we Polish and German.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "At school, Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "In the cheder, again, we learned Polish, and German, and Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "For instance, when we study [NON-ENGLISH], so we have to translate every syllable, every word, every pentola, you have to translate, which mean.",
      "word_count": 23
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my mother older sister name was Regina.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "She had two daughters-- she was married, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Her husband, he was dealing with the-- money.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He used to trade money, dollars for Polish money, and so for on.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "He used to deal-- they say in Polish [POLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "They had two daughters.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "The older daughter's name was Anda.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "She was a professor at the university, in the Jagiellonian University in Krakow.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "Her sister, the younger sister, her name was Frydka.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And she was a dress maker-- very, very famous dress maker.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My mother's other sister was Mala.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And her husband's name was Gustav.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Their two children-- Anna, she was the same age as my sister.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And then their son-- the younger son-- Leon.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "He was three years younger than, again, than his sister.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "She was a housewife.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Her husband has a grocery store in our house, in the front.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "It was a small store, sell groceries and things like that.",
      "word_count": 11
    }
  ],
