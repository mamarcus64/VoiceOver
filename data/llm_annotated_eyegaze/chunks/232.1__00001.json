{
  "stem": "232.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I was beaten up in school by the youngsters, and I was afraid to go to school.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "So my father decided my mother was born in Oswiecim.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "This became Auschwitz, later infamous place, to go to Oswiecim to visit her grandmother.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "A lot of family lived in Oswiecim, so our family went to Oswiecim.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We stayed there about a year, and we picked up a little bit of the Polish language.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "I started school in a village, and it was pretty nice.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "We had a lot of family there-- cousins and uncles.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And we stayed there till 1934, and my dad decided that it calmed down in Berlin.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "We should come back.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "We did not believe that really it will grow to something big, this Hitler.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "So we came back to Berlin, and my parents put me in a Jewish boys' school.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "It was called Kaiserstrasse.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And we lived pretty much in the center of Berlin, in a Jewish neighborhood.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And I went there to school.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "It was a boys' school, and we were about 800 boys in this school.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Later, my brother went to the same school.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And we still continued fairly quietly.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We were taught not to make any noise in the street, not to be seen, not to be recognized as Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "What do you mean recognize?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We were children.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We were playing.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We were shouting.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We were doing things, and our parents always said, psht.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Don't do it.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Don't be remarked by the goyim.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "You know, they will beat you up.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And it was really like this.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "When we went to school, we went three, four children.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "From my home to the school was about a 40 minutes walk.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "We walked to school.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "We left the house at 7:00.",
      "word_count": 6
    }
  ],
