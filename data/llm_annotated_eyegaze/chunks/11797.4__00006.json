{
  "stem": "11797.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 35,
      "text": "Unfortunately, he reported us to the guy, to the kommandeur, that what we did is a crime.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 36,
      "text": "We hit-- we hit him.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "The guy in charge from the Radom camp was a mean SS.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "I don't know his rank.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "Lieutenant or a captain.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "He had just come back from the Russian front.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "We used to call him-- he had his behind shot off.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 42,
      "text": "Half  a behind shot off in the front line.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 43,
      "text": "We used to call him, in Jewish, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 44,
      "text": "[PAUSES FOR 3 SECONDS] But he was a mean man.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 45,
      "text": "He was a man without heart.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "It means, half-ass.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGH] Right?",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He was known for that.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And we came in back from work.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And we heard near the gate from the-- and I didn't work no more at the Iron Brigade.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I was afraid to tell them I'm the Iron Brigade, too.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So I did some extra work, like cleaning the streets and taking rocks, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Working unloading a truck, the coal, or something.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "You know, manual, different works, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Whatever they had people working there, I helped, too.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It was with 20.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I was the 21.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And at that work I was like a helper.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't-- I was trying to hide myself they shouldn't find out I'm the sixth guy.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And they kill.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Because all my friends-- these five people that got killed, that was all my good friends from cheder.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was so pitiful.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So I came back from the work.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I heard there was screaming, hollering.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Brothers Steinberg! 26203.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Brothers Steinberg!",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Number.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Die Bruder Steinberg-- [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "They took us out.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My brother was a very tiny boy.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I was taller.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was always taller than my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And they took us into the kommandantur.",
      "word_count": 7
    }
  ],
