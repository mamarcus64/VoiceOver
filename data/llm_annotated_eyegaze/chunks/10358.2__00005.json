{
  "stem": "10358.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And they gave us some bread and some mil.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And then we went back into the woods.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "Until one day, we were surrounded by, by the Nazis.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "They found out there were Jews hiding there.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And we heard shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] And I was separated from my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "Everybody dispersed.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "We went into different directions.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "And I was running.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "And then I turned around.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "And I heard shots.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "And I turned around.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "And there was six Nazis with machine guns aiming at me.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "I had my Polish documents with me in my little pocket book.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "I took out the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "And I raised my hands, both arms, as if to say, I'm not Jewish.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "Don't kill me.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "I'm just here in the woods looking for blueberries or whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "And they continued shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "And then they shot me in my right foot.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "I saw immediately lots of blood.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "The bullet went through the back, came-- and I saw the bullet coming out the front of the foot.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 33,
      "text": "[CRYING] And then I ran into the forest among the trees.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 34,
      "text": "And they lost me.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 35,
      "text": "And I went into this Ukrainian house.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 36,
      "text": "And she put me-- she couldn't take me into the house.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 37,
      "text": "She was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 38,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 39,
      "text": "She told me to go into the woods.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 40,
      "text": "She couldn't take me to the house.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 41,
      "text": "She saw my foot.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 42,
      "text": "She came out with bandages.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 43,
      "text": "She put some white, clean rags.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 44,
      "text": "And she left food for me.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 45,
      "text": "And she went back home.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 46,
      "text": "She was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 47,
      "text": "And I was laying there all night.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 48,
      "text": "I was unconscious.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 49,
      "text": "I developed high fever.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 50,
      "text": "I couldn't eat anything.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 51,
      "text": "And I just felt, crawling on my foot, big worms.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 52,
      "text": "[PAUSES FOR 3 SECONDS] They were sucking the blood from my wounded food.",
      "word_count": 13
    }
  ],
