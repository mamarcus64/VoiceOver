{
  "stem": "162.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I think I'm very lucky that I became that strong person.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Because the experiences made me an adult very quickly.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And it made-- it gave me strength to go through a lot of other things.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And maybe that's why I fell in love with my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I couldn't communicate with-- with the giddy guys that were my age.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "They didn't have the substance for me.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And I think that is the only good thing, I think, that came out of it for me.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "That it gave me a lot of strength to-- to be the person that I hope I am.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, I had a difficult time with my father.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Because of his-- I don't know if it had to do with his scars of the war or whatever.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My father had a very strange personality.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Even though I loved him very much, it was-- it was hard.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "He was very strict, and he still had the very old world attitudes.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And here we are in Minneapolis.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "You know, it's now-- [LAUGHS] I'm 15 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Or no, 16.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Excuse me, I'm 16.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "So by that time I was 17 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I would always have to be home at a certain time.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "If I wasn't home, he would stand at the top of the stairs and really be furious with me.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And my father had a very, very bad way.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "Although at the time, I couldn't correct it.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "He would never be violent or hit me or anything.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "He would become silent.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "He would become angry.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And when my mother sided with me or he was angry at both of us, it could be sometimes days before he spoke to us.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "So there was this constant silence in the apartment.",
      "word_count": 9
    }
  ],
