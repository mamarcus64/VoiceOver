  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So we came home earlier once from-- my niece-- I took in the morning from my nieces' undershirts to wash them and mine and daughter had-- she just had her own one.",
      "word_count": 32
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "But by the time I finished three of them and came out, and that gate was closed.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And the man was then already there.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "He was Jewish, the man, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I saw already that I am in trouble, but I thought, I'm going to explain him what it is, thing.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "So he said, what are you doing here?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I said, we don't have any water, and I-- they told me I could come-- I just-- well, I had been told that I could come here and wash.",
      "word_count": 29
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "He starts hitting me over the face.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "On one side and the other side.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I was kind of like got dizzy a few times, and then he let me go.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "This the end of tape number 4.",
      "word_count": 7
    }
  ],
