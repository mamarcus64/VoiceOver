{
  "stem": "3097.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "We went to Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "From Czechoslovakia, we went to Austria.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "From Austria, we went to Leipzig, to-- to Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "It was the eastern part of Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We got caught by the Russian police or whoever.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They did arrest us, put us in the basement.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I spoke Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I talked to them.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I tell them a lot of stories.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They gave [? out ?] to eat, and they said, [RUSSIAN], go.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And they let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "They let us go, and we came to Munich, Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I came to Munich, Germany, and I stayed with the-- because the-- with those friends.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And there was a concert once or-- or-- a some kind of a-- I don't know what it was-- some people was talking about the Holocaust, about the-- the concentration camps in a big place.",
      "word_count": 35
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And I had some documents with my [INAUDIBLE], with my-- from school, papers from school, and pictures of my family, and some money here.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And after the concert, I see nothing is there.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Somebody stole it.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "I was heartbroken.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "I was so angry because only Jewish people were there.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "There were nobody else.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "That somebody stole it-- that I was ready to go back to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And I was thinking.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I asked Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Lipfeld, ?] go and make contact for me with those-- those people from the mafia there in Munich, those pickpockets.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And let-- what do they do?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Let them take the money that I have, but let them give me back the documents and so forth.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was left without documents, without anything.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "But I decided to stay.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "So I went to [?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Unrah. ?] The [?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Unrah ?] had a special settlement place in Deutsches Museum in a big place.",
      "word_count": 14
    }
  ],
