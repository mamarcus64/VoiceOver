{
  "stem": "26447.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Who-- I am afraid, and they got afraid.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I tell him, where is the-- where I can find a boat to come over the river Styr?",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He tell me, it's right-- very close.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Go and you will find a boat.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "When I come to the river and I begin to see the boats, all of them, it's closed-- locked with locks.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I try.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I see it's become the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "If the light will happen here, I will know-- in danger that somebody will kill me.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I begin to try to break off a boat.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "For a while, I broke off one boat.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And what to do?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I have only the pitch fork in my hand.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And the water in the river Styr is going very fast.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "To swim-- I'm not a swimmer, but I can swim across the river.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I came again to the house.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "It was very close.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And I was asking, maybe can you give me what you have-- Oar.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oar.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "He said, open my barn, it's a door.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And you will find near to the door it's stay.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You manage-- how I can look?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I am afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I don't know what is waiting for me on the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I would put my hand-- I don't go in the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "I put my hand, I cannot find nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "As I take something-- a clothes-- some-- I don't know what it was.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And I was thinking, I have the pitch fork.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "I will put them-- which will be easier to go with the boat through the river.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "I done this.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Done.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "I come over the river Styr.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And it become the day, become the sun.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Little night begin to run its left.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "Maybe at 3 kilometers.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Now, I feel that I will come in time.",
      "word_count": 9
    }
  ],
