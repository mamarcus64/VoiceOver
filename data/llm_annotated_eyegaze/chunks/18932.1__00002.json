{
  "stem": "18932.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 56.9,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I used to let them ride on my bicycle, because this was kind of luxury before the war.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was a large industrial city.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Like New York is in the United States, that was Lodz was in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I went to public school on [NON-ENGLISH] 18.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And then the war broke out.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I believe I was in the sixth grade, I-- because I think I skipped.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I-- I don't remember really.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Arithmetic, Polish, spelling, geography.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Was-- was kind of long time ago.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Not in Poland, no, afterwards.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother took a rebbetzin for me to give me some instructions how to read, but I wasn't too good in it.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I used to memorize one story.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Because the rebbetzin used to tell-- give me a-- to read a-- a love story she had in the back of her book, and I learned one by heart.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And every time she asked me, and I wanted to read this one, till she got wise to me.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "She says, read something else, and I couldn't.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I used to go with my mom in a spa before the war.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We went to [?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Sczcawnica, ?] which was a-- a resort in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In the-- in the mountains.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, no, it was in the mountains.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was beautiful there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I was a little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I remember they used to have, like, a goat, and they used to milk the goat and I would drink the goat milk.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "It was really nice.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this was-- I was a very poor eater and, like, always so green.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So my mom decided that she send me away with my aunt, which was my Aunt [?",
      "word_count": 17
    }
  ],
