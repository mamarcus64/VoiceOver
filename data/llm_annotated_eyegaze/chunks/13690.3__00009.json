{
  "stem": "13690.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "Until this day, you will never hear me sneezing, because I always-- when I was in hiding, I had to take a little pillow and killed the sneeze and choked my sneezing, not to be heard downstairs or outside at the sidewalk.",
      "word_count": 42
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So when he came back-- during the second time when he went, he did not-- knowing that he's being followed, he did not come back to our hiding place, and he went to the village where the other part of our relatives stayed there.",
      "word_count": 44
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "After a while, rumors were spreading unbelievable about the Placzek family.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So when one day, Eli came back to-- to the bunker, we decided that we have to go out.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "In the beginning, Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Placzek and Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Placzek was absolutely against that we should leave.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And the reason was quite simple.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "They were reasoning with us.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "They said, 'Look, if you're going to be caught, the children will-- they will definitely say where they were hiding.' And she was really afraid that we will denounce her.",
      "word_count": 30
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Not because we wanted to denounce-- because we were just children.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So one night, we decided to move, and this was in the summer months.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The night is short.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "The days are long.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We could not start to move out of the hiding until it's really-- Nighttime.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "--Late.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Beside, it is a curfew.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And the people were sitting in the backyards.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "We had to wait almost until midnight.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "At midnight, we starting to move out.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We happened to be-- as small as this little town was, we were in the western part of the city.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We had to go east.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "West was the border.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "We were hot on the border.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "It's a border.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "It's police.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "So we decided to go.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "The men--",
      "word_count": 2
    }
  ],
