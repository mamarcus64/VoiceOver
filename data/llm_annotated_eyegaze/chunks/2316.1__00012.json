  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 33,
      "text": "There were always guests for Shabbos.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 34,
      "text": "They were travelers, merchants on the road passing by and they couldn't make it home in time.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 35,
      "text": "Everybody had to bring somebody home from shul to the table.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 36,
      "text": "So we always met a lot of different-- mostly men, of course, from different towns and villages and cities.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 37,
      "text": "And [PAUSES FOR 3 SECONDS] we were always-- thought about tzedekah and charity and it was very important in our lives.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 38,
      "text": "We always had the [NON-ENGLISH] and otherwise.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 39,
      "text": "And my parents-- even though I had a lot of family who immigrated to the States, my-- like my mother's sisters and brother and so forth, they used to send us some packages once in a while, five zlotys or-- we really didn't need it that bad.",
      "word_count": 47
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 40,
      "text": "But we accepted it and we gave it to our poorer relatives when it came.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 41,
      "text": "So we didn't discourage them from sending those things.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 42,
      "text": "But we would give it-- my father would always give it to our poorer families, and-- and my, you know, his sisters or brother or nephews and nieces who needed it more than we did.",
      "word_count": 35
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    }
  ],
