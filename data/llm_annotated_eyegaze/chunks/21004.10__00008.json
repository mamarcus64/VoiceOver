{
  "stem": "21004.10",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Three times painting, three times fire.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I worked there for a while 'til we find a place and we bought a restaurant.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We bought a restaurant in Paterson.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "It was not a big restaurant.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Leon's.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Started on my name.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Leon's Restaurant.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I had it for four years.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "After that, I sold it and I went to-- to Plainfield, New Jersey, where I bought a big restaurant.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "New Yorkers bought my restaurant and I had nice profit and the restaurant, so I bought a big restaurant [INAUDIBLE], 200 seats.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "It was also-- in five years, there was six heads in five years.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "Big menus, but not much on the menu, and no prices.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "So they couldn't stay.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "I bought it for a very reasonable price.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And we built it up.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "We built it up.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "We stayed 11 years, 'til came another-- another thing.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "We had riots.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "When the riots came to Plainfield, New Jersey, they killed a policeman.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "There were helicrafters.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "It was unbelievable what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "My restaurant was worth $120,000.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "And later, business fall down.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "People were afraid-- I have international, mostly Jewish-style restaurant.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "From a lot of cities they used to come to me to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, I had to liquidate first the restaurants and sell it for $7,000 on auction.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I had to sell it on auction.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I have a 10 years lease, so I stayed another year.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And after 11 years, I have to let the people go slowly.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I let them go slowly, but later on I see I can't do it, pay the bills and people don't come and the rent was big and all the expenses.",
      "word_count": 30
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So I sold it.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I called in an auctioneer.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Sold all the equipment, beautiful equipment, refrigerator, freezers, and all, for $7,000.",
      "word_count": 12
    }
  ],
