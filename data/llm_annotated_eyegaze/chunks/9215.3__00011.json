{
  "stem": "9215.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 13,
      "text": "We were sleeping on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 14,
      "text": "Who-- who is the family that was living there?",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I don't know, a Polish family.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I told them to go.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I said, it's my house.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "But then, the Russian, a few Russian, big ones, generals or something, came.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "It was a beautiful house.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And they came and said, how do you-- how do I know it's your house?",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "I said, it's my grandfather's house.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "He said, bring me two witnesses if it's-- if it's your grandfather's house.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "I'll bring you.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "There was a few Ukrainian old people.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "They knew me.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "They knew me.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 12,
      "text": "I went to them.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 13,
      "text": "And I took two witnesses.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 14,
      "text": "And they went with me.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 15,
      "text": "I told them, they want to check.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 16,
      "text": "They want to throw me out.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 17,
      "text": "They went.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 18,
      "text": "They know me.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 19,
      "text": "They knew my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 20,
      "text": "And they signed that I'm a-- a granddaughter.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 21,
      "text": "When-- if I'm a granddaughter, I-- they have no right to-- to throw me out.",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 22,
      "text": "And I've been there until the war finished.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 23,
      "text": "Your-- well, wait a minute.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 24,
      "text": "Now, this.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 25,
      "text": "They saw me.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 26,
      "text": "I was standing in there.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 27,
      "text": "At one time, a Russian soldier went.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 28,
      "text": "He see me standing and looking.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 29,
      "text": "You know, I was looking.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He said, what do you seen?",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "You-- for Russian, he said, you very young.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "You-- you can't-- is-- the war is not finish.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "Our-- our girls is in the war.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "The Russian girls said the same thing.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "Like they-- from-- like in Israel, they go in-- in the army.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And they want me sent to the army.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "There was-- we were two girls and two-- four of us where.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And they want to take it away.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "We find somebody, a Russian man.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "He was Jewish.",
      "word_count": 3
    }
  ],
