{
  "stem": "740.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "By the 19th of April, 1943, they formed a transport.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We all got into a cattle wagon this time, and via Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "This cattle cars usually holds about 40 to 60 horses, or approximately 120 people.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We were 167 people in there, from babies, to old, to young, to women, to men.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Closed.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Two buckets in each corner to go to your duties.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Between the 18th of April and 23rd of April when we arrived in Auschwitz in the morning, the door never opened.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "We had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We had no water.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "We had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And at one time they hoisted me up to the opening and said Louis, we try again.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I said, let's see.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And the moment I put my head out, there were shots ringing.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "The gendarmes were right next door.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "So no escape this time.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "We arrive at six o'clock in the morning on a ramp in Auschwitz, Auschwitz I, which is the main camp.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] And the doors clink open and suddenly you hear hollering, yelling, Germans, dogs.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "The only time I saw dogs, Shepherds.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "Inmate clothing people, military, SS people.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No idea.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "No idea.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "This is foggy.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And there's a huge, big chief SS man.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I can see the insignia of it's a doctor.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And then we have to parade by him.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "He does his famous left and right, and left and right.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And I'm looking at what he's doing and I'm seeing the babies, the old people going to one corner.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I'm seeing the strong ones going over there.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "I said, oh, oh, oh.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I got wise.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "I went to the strong ones.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "There was a tall man.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "I hid behind him.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "So nobody saw me.",
      "word_count": 4
    }
  ],
