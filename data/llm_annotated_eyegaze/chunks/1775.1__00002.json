{
  "stem": "1775.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 152.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I used to run in and look at it, but I never had an opportunity to work.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I was too young.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "No, we couldn't work there.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My brother was involved with Betar organizations.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was a very young fella which had his mind set on being-- being a Jabotinsky man.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And that's what he is until today.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I had quite a few gentile girl friends.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I think our town was, it was nice.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "The people were nice.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "There wasn't that many gentiles.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I'm ashamed I don't have the picture from my school class which I have back in Illinois.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "But there was-- we were a nice group of children.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Not in Meserich.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Not in Meserich.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "There was no-- to my knowledge, there was no anti-Semitism in Meserich.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I was too young to understand it, but the thing is the people that I came in contact with, they were all nice.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They were all nice.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, people were always talking about what's going on in Germany.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "In 19-- just before Passover of 1939, they thought there was going to be a war.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[DOORBELL] And then it changed.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "[BACKGROUND CHATTER] Then it changed.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He's going to be worried about me, whether to answer the door.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "[CLANKING] Before the war, I was only a young girl, and I didn't do nothing special.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I just went to school, stayed with my friends, visited.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "They come to visit us.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I was with my family.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "We were a very close-- close family.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "My aunts, my mother's sisters, and my mother had an only brother.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "He was a wonderful, wonderful man.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "I think our town thought a lot about my uncle-- a lot.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He was a nice man.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "Everybody was nice.",
      "word_count": 3
    }
  ],
