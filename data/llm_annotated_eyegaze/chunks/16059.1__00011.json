    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "He said, where's such and such a place.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And my mother would answer in French and say, [SPEAKING FRENCH] Now, well, she heard this soldier walking away and he says, ugh, she speaks French.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "What's French?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They speak French-- because it was in German that they had asked.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And there were various incidents at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And it was getting so bad that my dad said to my mother, we've got to do something.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And my mother Erna had heard of a convent on the outskirts of Brussels, a convent that housed Jewish children, that protected them.",
      "word_count": 23
    }
