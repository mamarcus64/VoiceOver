{
  "stem": "353.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "The name of the village was Niepolomice.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "It was only 25 miles away from Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And I was staying in Krakow with my brother, and they were living in Niepolomice.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And we used to go to them to visit for Saturday-- Friday night to Saturday.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And then ghetto come up.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "So we-- I mean, my brother and me moved into the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And my parents--",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "In Niepolomice.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "In ghetto, like, you know you had to work.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You had to go to work someplace.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I became an auto mechanic.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Took a job by SS.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "One Jew between 20 Polacks.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "I was wearing armband on-- on a hand with the David star, and walking to work, and [INAUDIBLE], and living to work as long as they let you go alone.",
      "word_count": 30
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "Later on, and months later, you couldn't go by yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "You had to find a group.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "The SS people came, pick you-- picked a group up from ghetto, and brought to work, and brought them back to ghetto from work.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My father [INAUDIBLE] in, like I told you, in Niepolomice for, I-- I would say, a year, till they start moving the other people who are back in small towns.",
      "word_count": 30
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They start to move them out, push them out from the-- from the town-- from the small town.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "So, we decided me-- my brother and me decided to bring them to ghetto of Krakow without the papers.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And we smuggle-- smuggled the whole family in-- my mother, my father, my sister, and my youngest brother.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "My grandmother passed away a-- I think a year before, and take him to the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "The ghetto was an enclosed area?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was enclosed area with barbed wire.",
      "word_count": 8
    }
  ],
