{
  "stem": "19352.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "This was a SS one.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "He was holding his hand like that.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I says, what's that?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "He-- he put me [INAUDIBLE] SS.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I said, what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "He said, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I said, what are you doing?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "He said, I am taking those bad people who didn't behave like they should-- inmates.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And I took him to the school, where I used to go to the school.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And we make [INAUDIBLE] to shut up.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "This is what he told you?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "This is what he told me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "But-- what can you tell him?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I-- I make-- I-- I thought that I don't understand what he's meaning, but shut up.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We know that they have-- they killed those people in the school, young people, people from the streets, not only Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "He used to take somebody from the streets, because they are-- [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They were all zealot of undergrounds.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "They were those-- the right wings.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And they were the left wings.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They were [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They were different groups, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "But they were there.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It's true.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They were there.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So and-- and I worked-- oh, well, I start working about-- at the time.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I didn't tell you before.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was a foreman who-- a lady was working there, a older lady.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And he hold the head like that.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I grab him by his elbow and not let him to hit her.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He turn his head to me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And with his hand, he grabbed me.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I had metals in my eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "She was working there, and she make a mistakes in a way.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He-- he tried to beat her up, like everybody else.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I grab him and not let him to beat her up.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I was in the-- the control booths.",
      "word_count": 7
    }
  ],
