{
  "stem": "151.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And a few weeks later, I-- in the meantime I was in touch with my aunt here in California.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I had my father's sister here who came long before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I was in touch with her and she insisted that we come to Los Angeles.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And so, again, the Joint helped us to come out here by train.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And I arrived on April 15, 1949.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "It was 115 degrees.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "It was a very hot day.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And I looked at the palm trees and I said to my husband, I will never leave this town again.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And I love Los Angeles.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I opened my own business very early.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want to work for anybody.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My husband was a schoolteacher in Europe, but he learned a trade here.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we were in business for 37 years.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I had my own factory.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I became a well-known name in the industry.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I lived a very glamorous life as a fashion designer until one day I had a phone call from the Simon Wiesenthal Center asking me would I come to tell my story.",
      "word_count": 33
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I laughed at Rabbi Cooper and I said, come on.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "After all these years why should I now start talking about those terrible days, those terrible weeks and years?",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And he proceeded to tell me that that night a Jewish cemetery was desecrated in the valley and-- and a temple was spray-painted with swastikas.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And when I heard the word swastika I went crazy and I hung up on him.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I said I have to think about it.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And that night I was back in camp all night in my nightmare.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Next morning, I woke up and I called him back and I said I'm ready to talk.",
      "word_count": 17
    }
  ],
