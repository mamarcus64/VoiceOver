{
  "stem": "21482.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "I mean, there was just-- I can't imagine, like, they took my soul out.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "That's how I felt.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "Auschwitz was such a hell.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "I mean, there was never enough food, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "And we slept in the barracks where we had nothing, just on a wooden, on the wooden bunk beds or on the stone floors.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 36,
      "text": "And I will go-- every morning they would take me and some others girls, and we would walk to the kitchen.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 37,
      "text": "I had, like, a pole on my-- a wooden pole with the barrels on each side.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 38,
      "text": "Of course, I could hardly carry it.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So by the time I came back from the kitchen, like half of it would spill.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And then we got to the barrack, people had to share utensils.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have enough utensils.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We were-- I mean, every day, we were getting sicker and sicker.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But one day while we were standing, waiting again to be counted, Mengele came by and took me and another girl.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I had no idea what we were going to go, what was going to happen to us.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And they took us, they walked us to another camp.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "The soldiers walked us to, to a little clinic.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And the nurse told us to lay down on white beds.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And they took blood from us.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Took blood from me, blood from my friend.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Said they have to make plasma to send to the throne to save a German soldier.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "She was so nice to us, that nurse.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And she gave each one of us a slice of bread with a slice of liverwurst.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And I remember I ate half of it right away and brought the other half to my mother.",
      "word_count": 18
    }
  ],
