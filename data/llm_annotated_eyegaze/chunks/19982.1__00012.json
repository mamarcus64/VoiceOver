  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I want to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I told them my parents are there.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "I'm lost here.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I'm alone.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "So they asked me, Jude?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "So he gave me such a kick that I fell.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I-- on my knees, I still begged him, please, please let me go.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So they took me and, like, they pushed me out.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And I knew that I cannot go back.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "This was end of May.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "In June, one night, they came, the-- this time they were called [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And they came to the house.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And they said, we are giving you one hour.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And we are-- and you have to pack.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And one of them was nice.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "He says, but take warm clothes, whatever you can.",
      "word_count": 9
    }
  ],
