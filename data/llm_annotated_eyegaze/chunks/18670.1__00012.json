{
  "stem": "18670.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.8,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "The people were trying to get papers to leave Austria, go to different countries.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "Like the American embassy, a lot of people were lined up at the embassy.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 14,
      "text": "And they would pick out people, usually the elderly.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 15,
      "text": "And I haven't seen it, but I was told that people who survived, they took them to the park.",
      "word_count": 19
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 16,
      "text": "And the Nazis would line up facing each other, a row of Nazis about 100 feet long.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 17,
      "text": "And then you had to run between them, called [GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 18,
      "text": "Each one had a club.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 19,
      "text": "They would hit you with it.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 20,
      "text": "If you were younger you can run faster.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 21,
      "text": "You only got hit by every third or fourth.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 22,
      "text": "If you were older, you never made it to the end.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 23,
      "text": "And I saw the trucks that they loaded up with the people that they picked in the streets.",
      "word_count": 18
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "That happened to my father, the time with the coal.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't there.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They came into my parents' home, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "This is the same time.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I-- when I came home to Mitterdorf, I had to-- my brother and I and my parents had to report to the police twice a week.",
      "word_count": 26
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, we just had to report.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "It's a very silly thing, because basically what are we going to do, dissolve the government, be revolutionaries against the Nazis?",
      "word_count": 21
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And as a matter of fact, when we escaped, when he left, my father reported that we had gone to Vienna, that we were in Vienna now.",
      "word_count": 27
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "We didn't tell them that we were escaping to Belgium.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not in Vienna, no.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
