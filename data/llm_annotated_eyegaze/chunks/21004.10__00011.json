{
  "stem": "21004.10",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 17,
      "text": "And that's the way she died there, from typhus.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 18,
      "text": "They used to taking out dead people every day, 10, 20, 30 dead people.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 19,
      "text": "That's the way they brought in also a lot of food.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 20,
      "text": "They took the dead people out on the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 21,
      "text": "Over there was already speculators where they were bringing in all kind of stuff.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 22,
      "text": "And they-- they changed with all kinds of materials.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 23,
      "text": "And they brought in-- on the same wagons they brought in food.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 24,
      "text": "That's the way we managed-- with that food, we managed to have-- serve people.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I said there is no god, there's no this.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "But later on, it changed.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "I belonged to an Orthodox synagogue in Paterson, New Jersey.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "We were in Paterson, New Jersey 11 years.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And then when we came to Miami, I just went into a-- into a conservative synagogue, usually for my wife.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "She never learned too much Hebrew, no cheder, whatever, so she liked to go to-- to shul and sit together.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "In the Orthodox synagogue she was sitting separate and we were sitting separate.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "So I changed it.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "She was very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "She was singing.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "She know all the Hebrew songs, [HEBREW].",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "Was a happy person, very happy, nice, good mother, good wife, good grandmother, great-grandmother.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "I remember her.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 5 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, message?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They should stay Jewish, number one, not to marry, but some of them did marry-- some of them did marry not Jewish.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And keep going, you know, in the tradition.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Keep the Jewish tradition.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "That's very important.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Tradition for the Jews is very important.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And keep raising the kids the same way, in the Jewish tradition.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "My son here, he does it.",
      "word_count": 6
    }
  ],
