  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And then we're going to be-- then we're going to see what we have to do it.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And I picked up myself, another few people, and we start to go back.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "This was in wintertime, we start to go back to Poland, to the occupied territories from the Germans.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "We were in the occupied territory at that time with the Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "From the Russian side we went to the German, and when we came there, and-- [PAUSES FOR 3 SECONDS] it was impossible to go back again.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "So I remained stuck there in Poland and the-- with the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I went-- yeah, I went back to Otwock.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And then I found out that my brother, where my brother is there.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I couldn't do anything to take my mother and my sister-in-law and the baby-- and go back to the other side, to the Russian side.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "It was impossible already.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "All the borders were-- [PAUSES FOR 3 SECONDS] guard very, very good.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I remain in that-- in Otwock.",
      "word_count": 7
    }
  ],
