{
  "stem": "25651.14",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And the driver says, plny.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It's full.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "We haven't got room, even for a child.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So this polkovnik takes out a gun.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And he says to the bus, is there anyone in the bus here who can drive a bus?",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And then two or three hands go up, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "From inside the bus.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And he says to the driver, he says, look.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "You take this boy to Czechoslovakia, now.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "If you don't, I'm going to shoot you.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And one of them is going to drive the bus.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So I'll make room.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I don't think he meant it.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "It was a joke.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "But it was quite serious.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And the fellow said, well, all right.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "He can sit on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "So that night I was going back to Czechoslovakia.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Well, up till now, I had-- I was sort of fighting, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was going to get back.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And my brothers were-- my two brothers were young men.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "So get home, ask where they are.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Join up with my brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "By this time, it was the beginning of July.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Or-- or end of June, 1945, height of summer.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And we traveled through Vienna.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And I saw the bombed-- you know, the big wheel that they had on the [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Went over the only bridge that was-- that was still standing over the Danube.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And we get to a place called Znojmo.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And I took a train.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And in-- it was lovely, getting into Czechoslovakia , and speaking to people in Czech again.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "All you had to do is show your number.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "You didn't have to pay for a ticket.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I was in Valasske Mezirici the evening-- the next evening.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I arrived and walked to the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "They put me up for the night.",
      "word_count": 7
    }
  ],
