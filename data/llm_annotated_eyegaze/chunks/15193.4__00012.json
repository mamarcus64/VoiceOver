{
  "stem": "15193.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "We all had a beautiful dinner when we came home.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "No [INAUDIBLE], no meat, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 25,
      "text": "And it was very nice, and the people were very, very nice.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And one more thing I will say.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "They had a daughter, who had a cafe, and she catered--",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and she-- Sonia went to school in Wales.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Sonia spoke perfect Welsh.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "She must have been six, and she started to speak a beautiful Welsh.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "She could speak Welsh.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And then the daughter of-- of the people who owned the hotel had a cafe, and she catered to the-- she catered to the Army, the American Army who were there.",
      "word_count": 31
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And every Sunday, she would give a-- a party for them-- for the American soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They were not far from Oswestry.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They would come to Llanfyllin, and she would have sandwiches and fruit.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And we would volunteer to help to make the sandwiches and that was strictly volunteer.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Then, I volunteered to be a Red Cross nurse.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And once a week, I went to Oswestry by train and worked in a hospital as a volunteer.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And-- and then I came home.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And there were lots of people I could help.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "For instance, when they came in the recovery room, that was all on a voluntary basis.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "They wanted me-- the doctors, particularly, wanted me to be there when they were operating, but my train didn't come in early enough so that I could only be there after the operation.",
      "word_count": 33
    }
  ],
