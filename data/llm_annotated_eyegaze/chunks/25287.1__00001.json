  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "However, my two older sisters now live here in Pasadena.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "The oldest one is at a retirement home.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And my other sister, I close, but I cannot talk to them about  the Holocaust and what happened.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My-- [PAUSES FOR 3 SECONDS] my mother, father, parents, have a [NON-ENGLISH]-- a tavern, I think called in English.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And my father, when married, came to same house.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Both my father, here called real estate-- selling the barnyard and the houses.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It's a different way, most of the time.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Tokaj is famous for the wine, and a lot of grape mountain in this one.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "This was a very familiar tavern, not like here, the bars.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "People have regular way to came.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And after work, or after supper at home, they came over and play card-- you know, not-- not like in Las Vegas card.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And the little children, even, watched that.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And my mother-- they respected her.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "If anybody would come who was drunk, she don't serve.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Or we have some help her.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And how much I heard, the house my grandfather-- who I never know, this side, my mother's side grandfather-- built it, 1856.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Where all the five children were born, and even my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I only have grandfather, and his second wife, very close.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Like he had many-- before the war I'm talking about-- he had many grandchildren.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But for Seder, he always wanted me.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Even when I was in a bigger city, after when I got the diploma and needed for [INAUDIBLE], came home for Passover, my mother said, Zayde said he would like to you go for Seder.",
      "word_count": 35
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And only alone.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And I never had met the first wife.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "The second wife, Bobbi, was-- one hand, you know, couldn't move.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Very close, we was.",
      "word_count": 4
    }
  ],
