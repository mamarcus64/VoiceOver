{
  "stem": "1391.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Even the [NON-ENGLISH], they're jealous of me, darling.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "She have two kids-- one the grocers from Toronto.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The biggest furrier what they used to be.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Now that they're now, millionaires.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Now is the only thing I should wake up every morning.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "That now they find it out anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They find out.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And some they say, take it easy.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I'm still doing work because, I tell you the truth, I feel better when I work when I don't do nothing.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Because at night time, this night she say, [NON-ENGLISH], Why you scream so high?",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I see the Gestapo one time grab me by the hair, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I didn't--",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Now you're talking.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how to answer to you.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I remember how did my sisters get.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "One sister was raped.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "What you talking about?",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "A beautiful sister.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Five beautiful sisters, model sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Around [INAUDIBLE] children.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "You see, when you didn't have children, you have a chance to survive.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Now, when you have children-- there was some mommies, some son of a guns take you away.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "They come in, they lay-- they give away the children to you, and she go the other way.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "But not every mama can do this.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "If my child go, I go.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Look, the bottom line is this.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Germany is still Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And the damage was done.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "You don't can't blow it away.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "I hope I didn't disturb you with my talk.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, because in my store I never want a politic.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "When it's come in some day Germans, some they must think I'm German because I speak very good German.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I told you one time Yom Kippur I say I closed.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I lost a friend.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "He is in the oil business, [NON-ENGLISH], a Gentile.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "I lost it.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "That's [INAUDIBLE].",
      "word_count": 2
    }
  ],
