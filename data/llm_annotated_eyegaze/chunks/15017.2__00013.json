  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I went into work there on a Thursday.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "On the Friday, the boss was in to show me the things-- a delta-winged bomber from the Royal Air Force in England was coming on a, on a-- what's the name-- a visit to America and fell on his house and, and destroyed it entirely.",
      "word_count": 45
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I put my jacket on.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "You saved our lives.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Don't do this.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Because we're usually home doing our laundry on this Friday.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "But because you're here, it saved our lives.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
