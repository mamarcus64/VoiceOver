{
  "stem": "58.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He was in-- in the camps for years.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "He says, [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They are French people.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And most of the people working in the kitchen were all French.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, when we came to this camp, they gave me some fresh clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And I-- something was like paper cracking in my pocket.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "The pocket has a-- always a piece of material on the end.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And some people went, probably, to Auschwitz, to the gas chamber, they'd sew in the pants-- maybe somebody sewed in some money.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So I took out about 10,000 francs.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what kind of francs they were.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "So I went to the kitchen and I said to the kitchen people, you're a Frenchman.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Someday you'll go home.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "You'll have money.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "He says, but this money is not our money.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "This is Vichy money.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "You know, it was the government in Vichy.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "So I said, what do you care?",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "The only thing you have to give me is some more soup.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "It's not going to hurt you.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "I'll give you the money.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "So I gave him the money and he supplied some food for about a month.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "He gave me some more food.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "I figured every little bit helps.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "Next day they took us to work.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "They took us down to this salt mine.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "The stench, you know, of the mine, and that.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "And we had new bosses, new Germans there.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "And what are we going to do here?",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "He says we have to take down machinery.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They were coming, machinery from Europe, from all over the-- into Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They stole all the machinery.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But the salt mines didn't have big enough elevators to bring it down, so we had to put them on, straight up, the machinery.",
      "word_count": 24
    }
  ],
