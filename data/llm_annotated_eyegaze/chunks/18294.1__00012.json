{
  "stem": "18294.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Like my husband had a girlfriend.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I had a boyfriend.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Nobody turn up in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "Only me and my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "Everybody was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "So I was going-- I had-- I was very close.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "We was in the same company with my husband.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "So I was going to him.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And he used to come to me.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And I'm going so long till I fall in love with him.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "And this was the company.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And his brother, his sister-in-law was there, and the family.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Most of them, they keep the company most of them with your family.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "You didn't look for new friends because when I went in the ghetto, I was 22 years old.",
      "word_count": 18
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "I had all my friends for years and years before.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "So you didn't look for new friends in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Not all of them.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Only my husband from the friends.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "None of the others.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "We hear news when are still-- before the German arrive in Vilna because in 1939, they run away to Vilna.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "So then they came and told us, that the Germans going to kill the Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "We didn't-- we didn't believe it.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Like my-- my father said, what?",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "The German, if you work for them, they wouldn't do to you nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Did you get mail?",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Letters?",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Letters, no.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Newspaper-- there was a Yiddish paper.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And I think in Vilna get.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "There was because there was a lot of young, very clever-- he was writing hisself, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "But he had even books there, from there.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Like the song what we were singing in Vilna was Hirsh Glik, his name.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "He wrote this song.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "And this song is now in the whole world in all kind of languages.",
      "word_count": 14
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I can.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "[CLEARS THROAT] Pardon me.",
      "word_count": 4
    }
  ],
