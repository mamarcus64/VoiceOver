{
  "stem": "12029.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And the baby was a few months old.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And I said, Sylvia, she will fall down.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "Why don't you-- she said, she doesn't move.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "And I was really upset.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And then, two days later, I rang up there.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And her husband answered the telephone.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I said, what you are doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "He said, I'll tell you what it is.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "The baby, [PAUSES FOR 3 SECONDS] we took her to the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And we found out that she got a lump on her brain.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And they are going to make a lumbar puncture.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And then they took the baby to the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And they operated.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And they took out a cyst as big as a grapefruit pressing on the brain.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Then my husband said to her, you better leave this baby, because you will only have trouble.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "She started screaming, shouting, this is my baby!",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "But it was first-- it still was on fostering.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 5 SECONDS] Then my mother died.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "My mother died.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "She still had the baby.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And then they came from the council.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "And they said, [PAUSES FOR 4 SECONDS] listen, this baby is not suitable for adoption.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "And they took her away.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "And every week, they used to go to look after the baby.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "One day she rings me up.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "And she says, they want me to take her back.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "In the meantime, she got a very good job.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "And she worked.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 4 SECONDS] Then she came over here without her husband.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "And I turned around like a witch.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "And I said, Sylvia, perhaps one day you will have your own baby.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "And she got pregnant.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "And she had a little boy.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 10 SECONDS] That was after my mother died.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "It was everything OK.",
      "word_count": 4
    }
  ],
