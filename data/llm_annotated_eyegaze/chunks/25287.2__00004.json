  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Some people getting them-- you know, a small town, they were to go out then why we not getting married, or what?",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Because Ilona is waiting.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "While it's-- if she's coming back, have [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "But even when we get married and then to Budapest, my fiance's mother was welcome.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Morton and the children.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "When we came back the concentration camp, we went to her house.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "We don't want to separate them.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "In Budapest, doesn't have such a big apartment houses like in Tokaj.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And in Tokaj everybody had a house not apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And she gived her apartment to us.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And she went to stay with her daughter-in-law, the other one.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And then we three of us.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Because when I came home, I don't have the-- you know.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And a cousin of my husband fixed it, so we stayed in Budapest.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Naturally, for his wife, I designed some dress and sewed the dress.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "You know, we don't have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "We couldn't believe it, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't believe it. '39-- then going to have so terrible things.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Some people like from Poland and all over the Hungary they came to find a place in Hungary.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And they told the terrible story, but we couldn't believe it.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "People.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "You know, we never saw them.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I cannot really remember.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I cannot really remember.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "How I said, like for instance, in [NON-ENGLISH]-- you know, I just told my student the other day, when they said, [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I said, I lived in-- and my girlfriend wasn't Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And it was a natural things.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And then the day before Christmas, we went to help decorate the Christmas tree.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Not the Thanksgiving time, but the day before.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It never occurred to me why I don't have it.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Never.",
      "word_count": 1
    }
  ],
