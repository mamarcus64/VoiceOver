{
  "stem": "20084.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He was-- he was selling billiard pool tables, billiard balls, and cues, and whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He traveled to the countryside carrying his wares on his back and doing a lot of walking, a lot of thumb-- thumb-pointing.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And-- but he always managed to come home for-- when we were children for-- for the Sabbath.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- my mother had-- let me see how many sisters she had.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "She has Ida was the youngest.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Then Haila was the second, then Beyla.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Then Gusta was mother, Gusta.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And then she had a brother, Joel.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So she had four sisters and-- and one brother.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And I don't recall my grandfather because he died before I was born.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And my mother was a dressmaker by profession.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "She was-- people used to bring their fabrics, and she used to cut it and make dresses up for them.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, life was-- it wasn't easy.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was tough.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And we were poor, but [LAUGHS] we didn't know about it because all our friends, all our neighbors were poor too.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So we all were struggling.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "This was accepted.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We accepted this because we didn't know any better.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Well, life was-- I attended the public school, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And-- and I enjoyed playing soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And then we had hike and see-- hide and seek, children's games, all kinds of children's game.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "We were happy, very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "We used to go to the park play.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "We used to play a game called palestra.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "This is similar to baseball, but you played with a broomstick and a little piece of about 7, 8 inches thick.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "You put it on an angle, and you hit it.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And then you mark off the yardage-- I mean, the meters, how many meters you supposed to.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And this was a game.",
      "word_count": 5
    }
  ],
