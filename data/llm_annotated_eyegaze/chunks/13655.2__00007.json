  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "They couldn't go no place, and they didn't know where to go.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "They didn't have help.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "They dressed up themselves in Yom Kippur, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "But Friday came a message.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "The Germans were not going to send them out anymore to the Russians.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "But this was not [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 11,
      "text": "They're supposed to go to Russia, but they went to Sobibor.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 12,
      "text": "They're not going to do anything more.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 13,
      "text": "They could come back.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 14,
      "text": "And they started coming back.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 15,
      "text": "We had so much tsuris to coming back-- terrible.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Everyone was attacking the Jews to come back.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Everyone-- a Polish, and the Russian prisoners.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Everyone was attacking.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Not beating.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "They used to take away the [INAUDIBLE] from them, and a sofa.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "It was very hard to come back.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "OK, change it.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Tell me, how is my expression?",
      "word_count": 6
    }
  ],
