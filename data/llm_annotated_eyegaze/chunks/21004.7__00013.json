{
  "stem": "21004.7",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 43,
      "text": "I recognize the scream, a voice.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 44,
      "text": "I say, you know, [?",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 45,
      "text": "Belcher, ?] let's drop everything and run.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 46,
      "text": "And we ran.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 47,
      "text": "I see something.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 48,
      "text": "Oh, a wild animal caught or whatever, some-- I didn't-- came right away to my mind that will, and she let the wood burn-- burned and then not to change.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 49,
      "text": "And I came, and I saw the scream and throwing yourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 50,
      "text": "He say hang me, kill me, do anything.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 51,
      "text": "I don't want to live no more.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 52,
      "text": "And then I start don't scream, don't cry.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 53,
      "text": "Everybody start blowing.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 54,
      "text": "I have no medication.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 55,
      "text": "I don't have nothing, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 56,
      "text": "Put a little cold water.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 57,
      "text": "It didn't help.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 58,
      "text": "She was screaming.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 59,
      "text": "Won't you put something.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 60,
      "text": "She was blowing and blowing.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 61,
      "text": "It went out like this.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Later I say, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I'm not going to stay here.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I'm going to run to the village, to Stefan Marko, and let him go and bring me medication from the city, from the drugstore, and then I'll come back.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But when I went at night, when I went there, I couldn't come back the same day.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "In the day I couldn't walk.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "She had to go to the city with a horse and wagon and go to the drugstore and bring me all the medications for burns.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And then at night, I'm going to walk and come back.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Now, she brought everything, whatever I needed for the medication, even extra I told.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And when I come back-- when I come back in the morning, my Ruthie is walking around.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "I say what's happened?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "So she picked up her dress, and she showed me-- all healed.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Everything healed, the whole thing, all the blisters from here, all the way up.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "All the blisters.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "So I say how did that happen?",
      "word_count": 7
    }
  ],
