{
  "stem": "10394.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "The collars was for Madritsch-- on-- the chef from the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And I make the collars.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "One looks at the one that says, oh, beautiful, so nice.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't believe that they-- I sit in the first [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And I got a machine.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I got everything.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "And the supervisors-- this was Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "And then they give me, you know, pyjamas to do for Madritsch.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "I was the first over there-- the first.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "They need something, they came to me, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "And for a while, we was-- we lived in-- in ghetto, and we go to outside.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "This was not too far from ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 14,
      "text": "From ghetto to Madritsch was in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 15,
      "text": "And we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 16,
      "text": "But now a few months--",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "This was the year-- 1939 or '40-- '40.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And then from Madritsch, then he got six shirts to make for [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "If these-- if some stitch is not right, he can kill you.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "He looks like this on-- you know?",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH]-- the [NON-ENGLISH] was the ship-- the chef from the whole concentration camp Krakow-Plaszow.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And we went-- before we went to work in Krakow-Plaszow.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We didn't go when they liquidated this ghetto, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "So we went to Krakow-Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "19-- 1940-- '41?",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Exactly, I don't remember the date.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "When we came--",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There was--",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "--no!",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And then everybody has to go in concentration camp-- no more ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "In ghetto when we was-- when it was-- there's a liquidate the ghetto, got to over there.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "It was unbelievable what they doing with the Jewish people.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "They kill.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "What I saw-- I was scared to look.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I saw this.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "They take a baby, a small baby from third floor.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "This is not the third floor of like here.",
      "word_count": 9
    }
  ],
