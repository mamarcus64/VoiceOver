{
  "stem": "597.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "He knew all the-- he went to a private teacher to teach him all, you know, arithmetic, and our world things.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And the other things it was in Hebrew-- everything in Hebrew, not in-- so he-- he was-- he was very educated-- writing and writing, and then-- very educated, my son-- my father.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And I loved him very much.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "[CRYING] My mother was the same way.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "She comes from a very religious home.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "My grandfather, had-- he was in business in-- in lumber business-- lumber business.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "My grandmother had a-- a market in a village.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "In fact, this village-- I was saved.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "This village saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "They had like a-- they had-- my grandmother had a store, a general merchandise store.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And my grandfather was working in the lumber-- in the lumber yard.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "They had 12 children.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "Not all of them survived, either.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "It was in the old days in Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "It was very hard to-- to raise children.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "They-- they got sick, you know, the-- the children sickness.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "And they died.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And survived about five or six children-- five children survived, too.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "So my mother was one of them.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "And she married my father after the World War I.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "And then, the-- she left Russia over there-- Russia-- the village.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "And then other side was Poland, because we was living on the border, two kilometers from-- from the Russian-Polish border.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So she never could go back.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "She left her sisters there, with nieces, with nephews, with cousins in Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "All of them perished.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Nobody is alive.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And she was-- and she married my-- my father.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And she lived in Poland up till the World War II.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "That's-- that's then I want to tell you about my mother's family and my father's family.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We came from very orthodox people.",
      "word_count": 6
    }
  ],
