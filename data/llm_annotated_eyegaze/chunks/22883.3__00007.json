{
  "stem": "22883.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "So we boarded the train, but the last-- last-- last carriage.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And this way, we came to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "We came to Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And of course, when we came to Warsaw, right away, we went to my previous apartment where I lived on Padewska.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And when I came there, the-- the-- the landlady opened the door.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And she gave me-- because Lilian was not there.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She was on the street.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "On the street.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So she gave bad news.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "She told me that she cannot let me in.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Apparently, in this apartment, my sister was living now.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She took my apartment, and she was living there.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But this landlady told me that she cannot let me in because the police is looking after me.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And-- and also, she took me there are some rumors that I met some [PAUSES FOR 4 SECONDS] Soviet Union agent, a spy, and so on-- you know, such wild rumors.",
      "word_count": 31
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "But she-- she's afraid to let me in.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "OK, so I said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So I took Lilian, and we went on the main station in Warsaw, railroad station.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And we spent the whole night over there in the main railroad station.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Next day, we decided to go the other day.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And this way was-- I knew already.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I had the [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "There was another recruiting office in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And they were recruiting people to Kapfenberg in Austria.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "The Kapfenberg is a-- a famous [SIGHS] steel works in Austria in Steiermark, province of Steiermark.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "It was 300 kilometers beyond Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And they were looking for people.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And because I had some kind of-- of a mechanical background, so I thought maybe they will accept me, and they will take me.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Take me.",
      "word_count": 2
    }
  ],
