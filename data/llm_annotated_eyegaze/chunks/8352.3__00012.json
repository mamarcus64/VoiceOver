  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "So I went and I gave him the cigarette for my father.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He said the cigarette will do me better than the bread.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And it wasn't getting any better.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "After a week or so, I come home and I run in to visit him and the whole building was empty.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "All the sick people were gone.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They took all the sick people away again, and they got rid of them.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They burned them.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "They gassed them.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "They killed them out.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So here I was left all alone A soul with these strange people in a strange world.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] I didn't know anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And I was alone left, and just pushed through the days and see what will happen.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And that was going on for quite a few other months.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We were there about, I would say, about 10 months in that camp.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I kept on going to that factory, and we kept on working.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And, and for some reason, it was OK.",
      "word_count": 8
    }
  ],
