{
  "stem": "23131.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "--16, close to 17.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "17.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I did-- listen.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, I was nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "What could you do?",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "We weren't-- where we slept, we didn't eat, like I said before.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't stay in one place, because-- or we were threatened.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Or we heard news that the Germans are not far from us, and they will be close to us.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And they were looking for us.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "So at night, the night was the day and the day was the night.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The-- in the beginning, not too much.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "But later, when we settled down on the-- on the raid basis, I was like any other soldier-- all-- not like a commander's wife.",
      "word_count": 24
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "In the beginning, I wasn't the commander's wife.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I was a commander's niece.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "But then in '43-- in '43, January 5th, my stepmother got very sick.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "She got the flu.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And they took her to a farmer's place to recover a little bit, because she ran a very high temperature.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Her sister and her son took her there.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And it was a terrible raid on this house and two houses.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "They probably find out, the Germans, that they-- or the-- or the Poles or the Belarus, send out somebody to let them know, like they usually do.",
      "word_count": 27
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "That's how my father got killed in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And they-- and they sent probably somebody in, or they knew something.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And they made a big raid on the house.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And they were all killed alive.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "And this was January 1943-- January 5, 1943.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the-- we were stay-- we were on the base.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We were in the woods, and they were in a house.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "So right away, we knew of what happened.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "We heard-- we heard even the shooting.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't too far.",
      "word_count": 4
    }
  ],
