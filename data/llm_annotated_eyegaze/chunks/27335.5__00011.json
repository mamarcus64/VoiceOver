  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "And then he just slowed down.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And I took another step forward.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "And all the [INAUDIBLE] who came [INAUDIBLE] just came.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "And right there she was.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "[CRYING] In a glass.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "In a glass with a brick wall built up.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "That was the wall of the chapel of the prison.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 26,
      "text": "That's where they carried out the-- the executions.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 27,
      "text": "And that was the-- we stood at that wall, that she was her back against it, she's in front of-- front of it, and [INAUDIBLE] behind her they have a huge picture of her.",
      "word_count": 34
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 28,
      "text": "When I saw that, I just passed out.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 29,
      "text": "Here she is.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 30,
      "text": "That's-- that's why they maneuvered me to the-- wanted to see her.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 31,
      "text": "And that's how it happened.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Coming to 23.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And not accidentally, November the 7, 1944.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "November the 7th.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Not accident.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "You know the day.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "He-- he come to it.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And they knew, because she was betrayed by the Jew who lives in [?",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Taranto ?].",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] I was just coming to the [INAUDIBLE] so on.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Because he was-- he was planted in my-- a month later he was planted in my cell to get information from.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "That you wanted to this on a-- on a story?",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS] Well-- [PAUSES FOR 5 SECONDS] It was in November.",
      "word_count": 13
