{
  "stem": "22086.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't high enough to stand up.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But you can sit.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And no facilities.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Once a day, we had a pail that she used to take out from us.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Once a day, she used to give us a loaf of bread and a jug of soup.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And we used to share it.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "For 18 months.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I said we were six at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "A couple months later, that we-- she used to have contact with the world.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "She was outside.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And she used to bring us down a newspaper once in awhile.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no light.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But during the day, you can see a little bit.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The floor.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Floor.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "There was incidents when her brothers went for some kind of reason under where we were, under the floor.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But being that we don't go out, and we covered ourselves in one area with the ground, that they never realized.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And as I said, two months later, two more people from our town knocked on her door at the middle of the night.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And when she saw them, she knew them.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "She says, what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "What are-- she says, [?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Bella, ?] somehow we feel that you know about the Lippers.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And you tell us where they are.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Maybe we can go with them.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Maybe we can hide with them.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And she was that kind of a person that she couldn't say no.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And she told them to stay and called us and led them down to us.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So that made us eight.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We stayed underground for 18 months.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "You had to be careful.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You heard when somebody was around.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So we knew that when somebody was around.",
      "word_count": 8
    }
  ],
