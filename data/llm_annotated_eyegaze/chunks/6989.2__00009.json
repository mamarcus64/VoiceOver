{
  "stem": "6989.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I guess they was scattered, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I know that they did go to church.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what they were.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Whether they were Catholic or Protestant, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But they did go to church.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Not there.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "When I went to church was towards the end of the war, practically.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I believe it was-- it couldn't have been more than two, three weeks, I would say.",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "To the mother?",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "She told them the truth.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "She knew that they knew that I was not really her daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "It's only for the outside world sort of that I was her daughter, illegitimate daughter, while she was away.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I had absolutely no papers.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I called her Lena.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't-- I couldn't that word, so I would just either touch her when I needed her or Lena.",
      "word_count": 19
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Not-- because I remembered my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "So somehow, I guess, I couldn't say the word.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I don't think that she told me anything.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I don't think that she-- I think that I found out later that, you know, what happened.",
      "word_count": 17
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "She didn't say to me that, you know, they were destroyed or--",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No one.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No one.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I think he survived.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In which are we talking?",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "In the first one.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "The first village.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I think I mentioned three or something weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And then we went to this [NON-ENGLISH] that I tried to explain to you that was a farm also.",
      "word_count": 19
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Bigger than this farm but isolated.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "With-- for miles you didn't have other farms.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "That's the reason that it was called a [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And there we stayed quite a number of months.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Good question.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember the names.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "It was far from them.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    }
  ],
