{
  "stem": "23599.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No, we were very friendly with our neighbors, our Gentile neighbors.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But we knew that they were [INAUDIBLE], that there was a difference.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have Christmas, and we didn't-- and-- and they didn't have-- they didn't have Yom Kippur, and things like that.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So there--",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In Prague?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I-- maybe I-- maybe I was in for a week, and after I had a cousin in Czechoslovakia, in [NON-ENGLISH], so I visited there for a week, and then I came home.",
      "word_count": 32
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't remember now exactly by the-- by the year or so, but my father passed away very early, and I had to take over the-- the-- the store and the bookkeeping, and everything.",
      "word_count": 35
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "When I was-- I was declared full of age with 18 years.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "He had-- he was on a trip-- on a business trip-- and he-- and that's what we assume-- that he ate there something that didn't agree with him-- and they had to-- [NON-ENGLISH], something with the stomach, an upset stomach, and so-- and he got sick and he passed away, just like that.",
      "word_count": 53
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "What shall I tell you?",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "It was very hard, but-- but I had to take over.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I still remember-- I'll never forget-- like I was doing my homework.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I was still in school.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And I was doing my homework.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And my mother came up and called me, and had tears in her eyes, and said, excuse us, if she's sorry that she has to call me but she can't help herself, and I have to come down and, you know, and work.",
      "word_count": 43
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "So I-- I had to take over.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 6 SECONDS] And from then, I-- I did both.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My mother was very good.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "She always wish-- she never would-- keeping me back from activities.",
      "word_count": 11
    }
  ],
