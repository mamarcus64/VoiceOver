{
  "stem": "11144.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Where is Legnica?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Legnica is on the Western part of Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It's near Broslev, Bratslav, whatever have you heard.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It was the-- Legnica had a big Russian army there for many, many years.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Rokossovsky was stationed with his big army in Legnica.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No, that was Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No, but after the war.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I mean, the Russian army was all over the place, was in Poland, was in, you know, in all the eastern countries.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But it was called the Common Polish Communist Government.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So after they found their apartment, and whatever, they came back and took me and my sister.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "In the meantime, I was going to school in Lodz for just maybe a couple of months or half a year.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I went to the sixth grade.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Who'd they leave you with?",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother took an apartment, a small apartment-- a room, really, in somebody's house.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And we were a little bit with my aunt and my cousin-- my cousins.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And then we took the apartment-- my mother took the apartment, so we stayed there.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And they went east.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Well, listen.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "At that time, I was, what, 14 years old?",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, I was a grown-- a grown person.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I was very mature, you know, at that time already after going through-- as a matter of fact, one-- during one of the times when my mother went to-- went west to look for an apartment, I just went, got on the train.",
      "word_count": 43
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I was hanging on the train, really, because at that time, that was right after the war, and the schedules of the trains were terrible.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And it was a mess, a mess.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't get into the train.",
      "word_count": 6
    }
  ],
