{
  "stem": "20405.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, not too long, maybe a week, because I was married at the time and I had a little girl in Athens.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That's why when I went to Salonika-- was the second time, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "The second time I stood maybe a week, two weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I was working at American Joint Distribution Committee at the time with Dario.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "What I was doing?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I was working in a warehouse of the Jewish-- of the American Joint, going to the port with the trucks, getting all the clothes and many other things they were sending us from-- from over here and then take them to the warehouse, and then the warehouse, putting everything together, soap, medicine, clothes shoes, and so on.",
      "word_count": 57
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And there was some other guy who was taking care of the families.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "What do you need, this?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "What do you need?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "You were given a receipt, go ahead and get it from the warehouse.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "This what I was doing over there.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "How did you meet your wife?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I met my wife in a photograph studio.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Was a little room of photograph studio, because when we went in Athens, I rent that studio on top of the building.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "We were working over there with this Isaac Venezia I told you, which [PAUSES FOR 3 SECONDS] he lived from the crematoria when it was burning and he went to the Kanada-Kommando.",
      "word_count": 32
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "That guy was a technician to make briefcases, suitcases of leather.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "So we want to make a living over there, so I rent that place and we're making this kind of business, until they get us.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "But this place was rented still in my name.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "We would go-- we went back with Dario over there.",
      "word_count": 10
    }
  ],
