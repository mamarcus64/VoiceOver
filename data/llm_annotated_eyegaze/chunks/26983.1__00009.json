  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Only-- friends, of course, all my--",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "My friends from the school, their fathers were in Nisko.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And I remember the very first day when we came to school, our teacher gave us a talk and said, now, poor children, you are a half-- you have no father.",
      "word_count": 31
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "And all of us were very sad.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "And I had to play that even my father is there.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Because, yeah, I had to pretend.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And at that time, it wasn't so dangerous.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "And somehow nothing happened.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "A rest, yeah.",
      "word_count": 3
    }
  ],
