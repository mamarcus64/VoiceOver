{
  "stem": "3771.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And my mother was always to make sure that-- [PAUSES FOR 3 SECONDS] that there's somebody there, and they liked the food and things like that.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Shabbat was something very beautiful.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And of course, the-- the Shabbat meal was-- it wasn't only the food.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It was a table where Torah and world affairs and love and laughter and singing together.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It was not that you ate, and you got up from the table.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "It was something we never know it-- the table, the Shabbat table, lingered on unknown hours.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And everybody had to sit and share or contributed to part of the Shabbat table, something like this.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "This is indescribable.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "It's very beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, we speak, of course-- we speak most often Yiddish by the table.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And of course, we speak some other languages, because my-- they speak the language, Polish language.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Or my mother speak very good German.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "A part of her family come from Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "It was a mixture of exchanging it [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And it was a lot of laughter and-- and-- and happiness.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "There was-- it was all interwoven one with each other.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "It was-- was a part of us.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well, first, our city was not a big city.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Of course, I went to school at the high school in my city.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And then of course, I was sent to another school.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I went to Lodz-- was the biggest city.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We had some relatives there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "When I went to the bigger, larger Yeshiva there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I would say maybe 16, 17, something like this.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I liked it very much.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Of course, we become a very close knit family.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we're always afraid-- in other words, to make it-- put it bluntly-- that my mother would never let you grow up.",
      "word_count": 22
    }
  ],
