{
  "stem": "15900.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I got a job with the tea factory and they would bring in the trains with the tea and I used to unload them, 100 pounds [INAUDIBLE].",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "There was a wall there and a police around the wall-- nobody should steal anything.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Because it was very valuable, the tea.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Tea.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And-- and-- and I said to the chief of the police, what do-- what do you think?",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I take 100 pound bag and I throw across the-- the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And you stay there.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "When I get up, I pick it up and we go home and the invalids who had come back from the war with legs, with everything, they were in the black market.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They were waiting in the house to buy it.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, soon I got finished work, I go over there--",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The guards who the police was there waiting for me so nobody should take it.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "When I finished work, I took the bagged tea on my shoulder, and he was walking with me with a bayonet like he arrest me and nobody should touch me.",
      "word_count": 30
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Instead of going to the police station, he went to my house and there, the-- the people were waiting.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "My brother didn't know about it.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "He came to visit me and looked in the window and see police in my house.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "He give it to me, don't tell them I'm your brother, and I don't want no-- they know me.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "He was so afraid for the [? shadow. ?] And-- and I-- if not from me, I supply them-- my nieces got the-- sick, the typhoid, they almost died, food.",
      "word_count": 30
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And I did everything for them.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "When I got there, I-- I supply with meat, with everything to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "If not, they would die.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "After the war--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But he was working.",
      "word_count": 4
    }
  ],
