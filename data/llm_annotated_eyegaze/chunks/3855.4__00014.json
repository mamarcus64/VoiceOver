  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "We used the old Edison wax roll to dictate letters.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "It was a large company.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "It went to the steno pool.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "Then we got the copies, we corrected them, and sent them back.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So it was a different style of doing business in those days.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But I was happy there, I must say, professionally.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But when my wife, her sister didn't-- talking about missing her parents, and her sister, and brother-in-law, who had come in the meantime from France and Portugal.",
      "word_count": 27
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I succumbed and got myself another job.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "We'll continue on.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Certainly.",
      "word_count": 1
    }
  ],
