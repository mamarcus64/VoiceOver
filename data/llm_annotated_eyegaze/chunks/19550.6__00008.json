  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "The sheer force of being driven [PAUSES FOR 3 SECONDS] and being shoved brought you there.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I have a feeling that the fact that I had-- I think it was Sosnowiec, but I'm not sure where the, the train had stopped and I had, had torn off my shirt.",
      "word_count": 37
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was not only foul in those cars, but there was no air.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And it was hot, even hotter than under this lamp.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 4 SECONDS] I guess a, a, a strong, young body-- I was pretty muscly-- is what Mengele saw, so he sent me to the life side.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I knew after I got in to the camp where everybody knew.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I don't even think that I-- that we realized, really, that this was what later we knew was selection.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I mean, this man stood there with white gloves, and he just went like this.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And you didn't even have a chance to look at him, because you were being shoved and pushed.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And the din and the noise and, and, and the barking of the dogs and, and the thing being hauled away.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And the train was being shoved back and forth and was screeching.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It-- you know, you-- you had no awareness of, of your surroundings.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "You had no cognition.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "You, you knew that you were moving, but you didn't know where or, or how or, or who pushed you or who shoved you.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I saw her being driven [PAUSES FOR 4 SECONDS] with other women.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And you know, that, too, it was like automatically, they formed into a line of five in a row.",
      "word_count": 19
    }
  ],
