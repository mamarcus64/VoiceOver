{
  "stem": "6503.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "It was a freight, half freight and half passenger, very little passenger, and that's where we came.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Barry.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "B-A-R-R-Y.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Barry Seeman.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But he was fine, he grew up, everything was OK.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he's a wonderful son.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "We have a lot of pleasure from him.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "'49, in New York.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I think it was February.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We had a difficult time coming.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We had-- the sea was very rough.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We came to the United States.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We went over Bermuda.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We had to throw the anchors out and stay in Bermuda, because they couldn't continue.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "It was a rough time to go over the sea.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "We came to-- [PAUSES FOR 3 SECONDS] I think it was in February we came to the United States, with a little baby.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] I couldn't go to work.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "My baby was very small.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "My husband worked with my brother-in-law.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "We all lived together in one apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Then later on, after three months, we went and we rented out own apartment on the Lower East Side.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Very difficult to live there.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We lived by other people.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have our own apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "The people were very nice to us.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "We lived with them for quite a time.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Then, a friend for me, that I met there, came in and told me that he had a friend who got an apartment in Brooklyn, but they couldn't make it because it was on the third floor.",
      "word_count": 37
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I said, I'll take anything, so long as I can get mine apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And we got-- went to Brooklyn, and we rented that apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And that was in Bensonhurst, on 65th Street.",
      "word_count": 8
    }
  ],
