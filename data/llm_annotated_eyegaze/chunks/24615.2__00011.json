    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 28,
      "text": "We came back, you know to-- so we asked a German if we could go and buy some bread.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 29,
      "text": "One-- so he said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 30,
      "text": "One guy went, and while he brought the bread, another German came, a Gestapo.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 31,
      "text": "So they had to put the bread under the snow, you know, to-- to hide it.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 32,
      "text": "And one boy, while we were taken-- I remember his name was Bill-- he almost-- he went in, and I caught him.",
      "word_count": 22
    }
