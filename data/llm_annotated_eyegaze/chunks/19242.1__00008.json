{
  "stem": "19242.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't run after the ball.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHING] But I still played though.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "I had fun, and I played.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "My bar mitzvah, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I think I'm born in 15 day at Thomas.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "But now, I forget that what-- what Haftarah is.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "I should have called the rabbi and asked him what Haftarah was.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "To the bimah.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the Haftarah.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Well, there they don't do it like here.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "They do it like-- oop.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "They do-- they do the Haftarah.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They, I mean, you're 13 here, they don't let you to the bimah.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "There's special people for that.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "It's not like over here.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "When you're 13 years, you can pray.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "You can go on the bimah.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "Over there, you're a good bar mitzvah, you say Haftarah.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "In shul, you have to bring all kind of-- in shul, make a party.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And then in the afternoon, another party at home.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "You know, the neighbors.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "This was strictly for the temple, when I was there.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "See I remember little thing-- the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Don't remember.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "I talked to my brother, and we sat down both and don't--",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, a little stuff, not too much really, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "People were-- most of the people that come to a bar mitzvah, they-- they cooked and that.",
      "word_count": 17
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And everybody bring things.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And-- But I remember the bar mitzvah lasted from-- from noon all the way till the evening.",
      "word_count": 17
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "So I remember that's about-- what I know?",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember all of that.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "Your friends-- were your friends were all Jewish--",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "All Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Only they didn't-- in school we didn't wear no-- no kippahs.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Just--",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "But they were all Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "All Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have any Gentile friend.",
      "word_count": 6
    }
  ],
