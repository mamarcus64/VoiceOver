{
  "stem": "17330.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 45.5,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So I said to Bill, when we come back, I'll have that egg and then we have a party.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So I put that in my father's room.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And she had to go somewhere, to Amsterdam or something.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And I said to him, today is egg day.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And then he said listen, Selien, I'm thinking about it, but I can't do that to my sister-in-law.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And I said, look, Bill, when she came back, she had a party.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Now it's my party.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He said no.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And I was nervous wreck in those days, and I said, no?",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I don't want it.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I said, you don't want it?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Then nobody has it.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I went to the toilet, took the egg, and smashed it in the toilet.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I had to clean the whole bathroom, because it went to pieces, of course.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "But I couldn't care less.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I didn't have the egg, so she didn't have the egg.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Maybe not fair, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
