{
  "stem": "20580.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 28,
      "text": "And into the coat I had-- like, well, you know, any kind of junk, little rags, should be lower.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 29,
      "text": "And I had all covered up.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 30,
      "text": "And the foot, over here, I had the shoe.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 31,
      "text": "And he had the boots.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 32,
      "text": "We are complete.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Then he kept us two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He says, the, the Germans looking for who killed pigs.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "You have to go away.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Where are you going to go?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "He went-- he went away.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And we followed to that gate with these guys, they were-- run away.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he says, go.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And I went to this guy, which I told you, the next door, just three blocks.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I came and knocking the door.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And the letter said, [?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Hamka. ?] He says to me-- he says, I'm looking for this guy-- this and this guy, that [?",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Garber, ?] for months and months.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And these people I had into my house.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "They was here, and I give them bread-- [?",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Adems, ?] I told you.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And they told me they have a guy-- they have me.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "They know me.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "They're going to bring me.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "He says-- and the Einsatz, they're very smart.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "He says, look at this, what Jews are-- he's so tricky.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "When I says, I need you.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "And he says, he isn't.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 16,
      "text": "And I told him, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He says, how would I prove it?",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "He says, these guys-- and she wants to keep it to make the leather.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "She want to keep us because the other one, she let him go.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And right away, they kill them, the third day, the other one.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And she says to me-- I says to her this way, I remember a guy-- but the name, I don't remember the name.",
      "word_count": 23
    }
  ],
