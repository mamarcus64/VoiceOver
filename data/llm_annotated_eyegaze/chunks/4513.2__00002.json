{
  "stem": "4513.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "And they talked about things, which I had never talked about before.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "It was just a different world.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they would talk about food that they ate that I was totally unfamiliar with.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They talked about games that they played, which I had no idea what they were.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They talked about things like them going to school and wanting to go to college, and all the things that they wanted to do.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And that was all foreign to me.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "The whole thing was foreign to me.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "The college piece wasn't, because my mother had talked about that.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "But it was a different context that I was hearing for the first time.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And when I came back, I really didn't-- wasn't interested in being with the-- with the guys anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Between Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "Parker and those folk, I sort of drifted away from them.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And became more and more involved.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And he just took me under his wing and told me, you're going to be somebody.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And I'm going to see that you'll be somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And he met my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And he talked to her.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And my father never wanted me to go to college anyway.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "He never wanted me to go to school.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "He wanted me to go out and fish.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "But-- and he was really opposed to it.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "Because everyone who went to college, he said, look, I'm not going to give you one dime to go to college.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Well, my father didn't have one dime to give me.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "So that was not really of great importance.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "But the fact that he said that you'll never take a dime of my money to go off and do that crazy thing.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "And so that's fine.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "It was only because he-- he wasn't a bad person.",
      "word_count": 10
    }
  ],
