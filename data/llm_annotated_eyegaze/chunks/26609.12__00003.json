  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have a, a scrap of linen to put on top, to, to, you know, to cover it.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Next day, I have, had very bad scars there, and a doctor, he has seen it, a German doctor.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "What was his name?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I had to go to a German doctor, they-- because I told him about-- and I had no, no witnesses.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But I described the prison so well and so exactly that they believe me.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They don't believe easily.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "You have to have witnesses.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I didn't have.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I told him, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Do you know if anyone survived [NON-ENGLISH]?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I have seen-- that we all stood in [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "As we stood around near each other, huddled together, a tiny little window from the second floor, it was on second floor, down to the back yard, we have seen them killing people.",
      "word_count": 33
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "They killed Poles, too.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "If they had a long nose, or they had dark hair, they didn't believe.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "One screamed-- she was in our, in our room-- and said, I give you the address.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "My parents live there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Go-- they got her on the street.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Go over there Lwow they live, my parents there.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't bother.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I'm not, I'm not Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I'm a Catholic, Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "They didn't believe her.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "They killed her.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We have seen it.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "They killed her.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Once they had something on-- on, they thought on me, it's enough to be killed.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "Then one day, they took me in there, and I thought, all right if they kill me, but I don't want to look like this one, you know, with strips of-- If they'd beat me like that, I don't know.",
      "word_count": 40
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Maybe with razors, how they cut her.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Only not said.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "Tortures.",
      "word_count": 1
    }
  ],
