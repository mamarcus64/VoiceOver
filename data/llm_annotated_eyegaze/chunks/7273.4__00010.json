{
  "stem": "7273.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "You know, when I looked out of the window, like you see here sometimes, when they make the signs with the airplanes [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "So I saw it and saw the bombardment.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "The first they make the line where to go, where to bombard, and then the things fall down.",
      "word_count": 18
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "It was the front line.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I don't think so long I was in at the station, they didn't bombard the station.",
      "word_count": 16
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "I always was worried about it, because there was a lot of bombarding going on.",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "Mostly 12:00 when we wanted to serve the dinner, we had it on the plates.",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] And we had to go in the cellar.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "And I don't know whether they were Russian or English planes, practically daily towards the end.",
      "word_count": 16
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And they always wondered I didn't want to go to the cellar.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "You know, I-- you get so cold blooded I would say.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't worried, no.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Because I don't know.",
      "word_count": 4
    }
  ],
