    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And they said that he's the most vicious one.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And his father was there also.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
