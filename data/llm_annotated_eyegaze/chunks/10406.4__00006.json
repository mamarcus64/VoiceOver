{
  "stem": "10406.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "I was there before, before the war because my, my uncles had stores there and businesses.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And my grandfather had like four, four brothers there and two sisters, big family.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But, but I lost my orientation, and I wanted to get to a particular uncle.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "His name was Falek.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So I asked this woman if he-- if she can show me where Falek Ginzburg lives.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And she said, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I explained to her.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She happened to be his daughter-in-law.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "But his son married her after I knew-- you know, I wasn't there since then.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "So she went and got her brother, and the brother-- she said, we have to do it fast, because the curfew starts 6:00.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "So he took me-- he took me there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And there were a lot of people in that house.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "My uncle had a big house.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "It had two main floors and then like a little attic that was also fixed up like a, like, you know, a living.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "Was this right in the town of Lubon?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "That was in the town, the center of the town.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So being that it was a bigger house, and this was part of a ghetto, they made a lot of people move in there.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So it was crowded.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And they got a bed for me, like in the living room, set up a bed.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And, and they gave me a jacket to wear and some shoes.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And the next day, my brother showed up.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And he told me that he was captured, and he was taken to the synagogue.",
      "word_count": 15
    }
  ],
