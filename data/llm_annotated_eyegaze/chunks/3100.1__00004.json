{
  "stem": "3100.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And sometimes, I as a young-- [PAUSES FOR 3 SECONDS] a young man of 18 years old, were glad to go out and work for them to maybe I could be able to organize something to bring home and to my family.",
      "word_count": 42
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Sometimes I was successful in organizing an extra piece of bread or a few potatoes.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And sometimes it didn't work.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I came home and-- well, we managed.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "This last lasted until I was awaken from sleep once in the fall or in the spring of 1940.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I was taken away on an Army truck with a few-- with a bunch of others, Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And they took us away about 100, 150 miles or kilometers away from Krasnik And to a place called-- [PAUSES FOR 3 SECONDS] oh, I forgot the name what it was called.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Would you remember the name?",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was near Savin, not far from Chelm-- Ruda Opalin.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I was going to say Ruda--",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Ruda.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Ruda Opalin.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I was there and interrogated into this camp for a whole summer and including the winter until about January 1941, where took sick.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they liquidated the camp around December.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Because our work in this camp was to regulate a river and to build--",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Dam.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we kept on doing.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They didn't give us too much food there, but it was still better then I found out later on when I was taken to concentration camps.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But it was very unhealthy.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "The sanitary--",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Conditions were there awful.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We have-- we had-- we were full of lice.",
      "word_count": 9
    }
  ],
