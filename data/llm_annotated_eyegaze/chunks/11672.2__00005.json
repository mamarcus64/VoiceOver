{
  "stem": "11672.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "The German solders very friendly, the soldiers said, you not can go over.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Yesterday, closed the border.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "You have to go to town called Swierce.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] This is [PAUSES FOR 4 SECONDS] about 30 kilometer from Dorohusk.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "This is a village.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "And when I and my friends walk, it's so dark.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "And a Polish farmer said, boys, don't walk.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "But here, you have-- I don't know what in English what's called this.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "You have when you walk you can go in on the dirt.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "You sink in, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And the two farmers take the 11 boys to the house overnight.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "You don't have Jewish farmers.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "This is-- you see, in this place it's a very poor place for the Polish people.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "The farmers live very poor.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And the farmers cooked potatoes for everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah. 5:00 in the morning, I am with my friend.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "We walked to the Swierce, to the-- there's the headquarters for the German.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "You have to take a paper that can go over the river to Russian.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And there you have a little boat.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And the German soldiers or the Russian take you over.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "If you have in the German headquarters, a [NON-ENGLISH], in German called this, you can go over.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I come there.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "Said, you not can go over.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "You have to go to the headquarters.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Now, what to do?",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Because you have to tell him your lived before in Ukraine, in Polish Ukraine on the other side of the river, you can go.",
      "word_count": 24
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I don't have papers.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I have papers from Lublin.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I belong to the German.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And so I go to tell him-- everybody thought I lost everything-- the bombs.",
      "word_count": 14
    }
  ],
