{
  "stem": "16163.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Well, in the morning was appell, which took for hours, standing in the cold, freezing till the SS can count it and count it and count it again.",
      "word_count": 28
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Just let us stand out there.",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "And the rest of the time you were in the barrack, wondering what the next hour brings.",
      "word_count": 17
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "You were looking ahead to get our soup once a day.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "All, all, all that-- what we got.",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "You used to have-- me, personally, I never talked about it.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "I didn't even write about it when I wrote it.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "We had a terrible experience.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 3,
      "text": "We had a soup next to us in big bucket.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 4,
      "text": "I don't even know how we ate it.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "And really now, I don't remember all that.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "I just know one thing.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 7,
      "text": "It must have been the third or fourth day in Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 8,
      "text": "There was a finger in there with a, with a ring.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 9,
      "text": "I have never, ever talked about it to anybody.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "A human finger with a ring in it.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "I guess we ate the soup.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "But I remember that that was-- we were-- the five girls from [INAUDIBLE] that we sleeping on the bunk together, we were like in, in shock for days.",
      "word_count": 28
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "I mean, you know, this is things which you really bury so deep down you don't even want to talk about it, but it happened.",
      "word_count": 25
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "That happened.",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know any names from anybody.",
      "word_count": 7
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "That didn't existed if you knew names.",
      "word_count": 7
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know any names.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "We had a Ukrainian kapo, which was very bad.",
      "word_count": 9
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "And we had [PAUSES FOR 3 SECONDS] a Jewish kapo, I believe there.",
      "word_count": 13
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "We didn't really know what they-- I know one was Ukrainian, because she had a different-- they were in uniform, right?",
      "word_count": 21
    }
  ],
