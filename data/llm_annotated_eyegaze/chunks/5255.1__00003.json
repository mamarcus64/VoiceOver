{
  "stem": "5255.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "It was a larger living room and that's-- like a private shul.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I think he was a member of a Orthodox political party, which is called Agudath Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And it's a very well-known organization.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "It's still in existence today.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I was not.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I didn't belong to--",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I'd say about 14.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "While I was going to school I worked part-time in a-- a printing and rubber stamp company that was right-- our neighbors had the-- and I was working there.",
      "word_count": 29
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I was delivering things.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I was doing-- go kind of chores.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And they used to give me $5 a week for part-time work.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And I-- it was handy money, and naturally I gave it to my mother because I didn't need any money.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My father-- I'll tell you-- most of the time he wasn't home.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "He was in the fields.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "His work required him to be outside the home.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "He was buying fruits of the trees by ranchers.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And when the fruit ripens-- and he had people watching the ranches-- when the fruit ripens he organize it to bring it to Warsaw and sell it to wholesalers.",
      "word_count": 29
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Friday was a busy day home.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My mother used to bake challahs, make gefilte fish.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Everything was made from scratch.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was like a holiday.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, very, very important.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Everything was made home.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "The cakes, the fish, the challah, the chicken-- whatever she made was home-cooked.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'll tell you what.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "The situation in Poland was so that almost every Jewish young man, being aware of situation that we lived at the time, was-- our dream was to go either to Palestine, at the time, or to the United States.",
      "word_count": 39
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Almost everyone had some member of his family in America.",
      "word_count": 10
    }
  ],
