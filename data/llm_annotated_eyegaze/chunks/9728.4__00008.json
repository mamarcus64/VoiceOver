{
  "stem": "9728.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Rumkowski, when he came to the Birkenau he was treated the same way.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And then-- they-- they treated him the same way.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And he got beaten up by the guys who-- when we came, when we got--",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Just a-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "But I know it's a fact.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I know it's a fact, because some people that I met after the war, they saw it.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "When we came to Birkenau, we were told to undress in the nude.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And there were several kapos.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Now, a kapo is a guy who was in charge, who was actually a mean guy.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "They took the meanest guy and made kapo.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "Kapo was in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And he told you what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And if you didn't do it, you got beaten up.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And those kapos, when we got undressed, they shaved us-- all the hair, under the arms, pubic-- all over there.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And Rumkowski got the same treatment.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "He got shaven and cut.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "And they beat him up.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And we were in transitional after we-- after we were shaven and they gave us the clothing.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "They gave us-- it was striped clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "They gave me a pair of shoes, pair of pants, and a jacket-- a striped jacket, a striped pants, and a striped hat from the same thing that I have today.",
      "word_count": 31
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No underwear.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "No socks.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "No nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We were in transitional when we got out.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And-- yeah-- And we were so-called deloused.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "The funny part about it is that they told the people that came to Auschwitz, and they send them into the gas chambers, they told them that this is a delousing, too.",
      "word_count": 32
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "That you are going to be cleaned and you know-- and-- and sanitized.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And they put on the gas.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "However, we in Birkenau did not experience this.",
      "word_count": 8
    }
  ],
