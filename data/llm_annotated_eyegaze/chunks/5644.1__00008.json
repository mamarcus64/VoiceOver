{
  "stem": "5644.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Now, I been told by father that he spoke to a big ranking officer which was in charge with the, the buyer, the military buyer of the-- of our goods for the army.",
      "word_count": 33
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And he told him that he better see me out of Warsaw, the oldest, which is left with-- in the family, David, which was 19-year-old.",
      "word_count": 25
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Better if he will leave Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "If I will, David.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And go towards, towards Lublin.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Because we're going to have a stand there against the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "We're going to re-army, re-organize, And we're going to have a stand near Lublin.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "So better if a young person will walk to-- will go towards Lublin.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And that was a lot of young people you could see at the-- on the road, very, very-- quite a lot when I went out about five, six days after, after the, the war start when the Germans.",
      "word_count": 38
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "That was already-- the Germans have been, I think, already in Warsaw, or next to Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "And they start to march out from the-- from Warsaw towards Lublin.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Marched out-- went out with groups of people which were going out of Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "They'd been leaving Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "But on the way, we tried to get into, to places like over the road.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "We went actually towards Kowel.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And on the road, I met few people which I knew, Christian, Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And then I met up with one boy which was from a village.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "And we been marching together, together.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "And few little things happened on, on the way because--",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Not as a Jew, but normally the attacking of the, of the planes, the roads, the German planes.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Then we caught two spies.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Two spies.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Dressed in, in clerical, clerical [INAUDIBLE].",
      "word_count": 6
    }
  ],
