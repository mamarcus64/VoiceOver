  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Emory Angles.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Budapest on the 21st of October, 1924.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Lajos Engel, E-N-G-E-L.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It was spelled differently.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was Gisella Engel.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- we lived in Ujpest, which is a suburb of Budapest, about 6 kilometers from Budapest.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It's a township which had about 100,000 inhabitants.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We lived in number one Kiraly street.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Kiraly means in Hungarian King.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So I lived in number one King Street.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "It was a flat house, as we called them at the time.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And we had a flat on the first floor.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "It was a typical dwelling for middle class citizens of-- of the time.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "My early childhood was completely absorbed in the times, which-- which meant that we lived on the strong discipline in our school.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "We have obeyed our teachers, our professors to the letter.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And we worked really hard.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "The school I started in had over 150 people starting-- pupils starting.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And by the time we finished, we had, I think, 28 or so matriculating, which meant that you had to be really talented, or work as hard as I did.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I said, or work as hard as I did.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So I gave you the answer.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No, it was a public school.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was a state school.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have private schools of the types we have here today.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And not speaking of the fact that we could not afford the expenses attached to it.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It was a public school.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "It was a-- a state supported funded school.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And as it turned out to be, as I compared my early education with what I've seen all over the world, it was an excellent school.",
      "word_count": 26
    }
  ],
