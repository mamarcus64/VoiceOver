  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Couple other guys.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And we do everything.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Cleaning people, change the bandage or-- or something like this.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Put the bed or something-- that was my job.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Good job.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I don't know how you call it.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Cut and see what is, why?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And so on and so on.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You know, that's like animal.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Here, in the United States, we take [? surge ?] for a small mouse or small animal.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "There, was the people.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "You know, for me, it was very hard.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Because before the war, in Warsaw, one near our house, the car kicked somebody, and it was blood.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I go all over the other [? blocks. ?] And I not like see the blood.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "In concentration camp, was only blood.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "You know how I feel.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And it was way-- be there or be dead.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So it was very hard for me.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "That's a reason I not go to medical school after the concentration camp.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I finish polytechnic institute.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I not going to medical way.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "What kept you alive in the camp?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Listen, first I was young and I was thinking all the time what must be done.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "What God [PAUSES FOR 3 SECONDS] has for me-- that happened.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And besides this, I like survive, because I was thinking we have something-- was family together.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You know, also probably only what I feel-- my feeling I must survive.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I have a photo.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My next neighbor was doctor-- right now, he's doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It was 10 years younger, like me.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And leaving in New York.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I have the name and address.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And many was-- not many-- only, you don't know who was Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "It was not with the stripe.",
      "word_count": 6
    }
  ],
