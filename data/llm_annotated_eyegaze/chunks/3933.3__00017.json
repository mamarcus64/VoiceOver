      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "I left my son there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "And I'll never forget-- I go to pick up the few shmattes I've got.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "And she gave me-- somebody gave me-- I don't remember.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "Oh, I know-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "Anna. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "Anna. ?] She gave me a little jar with a little potato soup, for [?",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "Erik. ?] He left-- I left him with the old lady over there.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "And I took this little jar.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "And I go with this little jar [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "And I have a little shmatte, a few shmattes here.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "I go to the tramway.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 33,
      "text": "And suddenly-- oy, god, I'll never forget it.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 34,
      "text": "Suddenly a Ukrainian came over to me, with a Ukrainian uniform, a Ukrainian uniform-- to me-- come.",
