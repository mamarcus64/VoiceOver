  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I am afraid-- I am afraid Gestapo's in this house.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "You see, downstairs there's the Gestapo car.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I say, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I know the Gestapo is in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Take me to the door.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Because I didn't know her apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "She took-- oh, yes, good.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Leave right away because I'm scared.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "She took me to the door, and I went downstairs.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "Gestapo car was there standing.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "The Gestapo was up in my room.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And I, again, disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "I didn't have where to go too much.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "They had a daughter.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "One night I was with the daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 13,
      "text": "And most of the nights I was sleeping in attics-- in, in Warsaw in attics.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 14,
      "text": "Because my sister's boss couldn't take me in-- her, her woman couldn't take me in because one Jew is enough.",
      "word_count": 20
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 15,
      "text": "Two Jews is a already, naturally.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 16,
      "text": "Till this Anna [NON-ENGLISH] got in touch with my sister, and she gave me a place in Grodzisk, [BACKROUND NOISE] which is 15 or 17 miles west of Warsaw.",
      "word_count": 29
    }
  ],
