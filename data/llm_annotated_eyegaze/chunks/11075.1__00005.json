{
  "stem": "11075.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "When we came over there, we went straight to the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And over there in the ghetto, we were two years, till 1942.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Just-- just a few things.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Just a few things, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Just a few things that we-- we could get in the hands.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Small suitcases.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "My father, my mother, and my two-- my-- my-- one-- the little sister.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Because my-- the other sister was in Stanislawow-- still in Stanislawow.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "From Wolbrom, we-- my father tried to get, you know-- you know, the-- my-- my-- the other sister who was married, you know, to bring her so she would be able to be with us.",
      "word_count": 35
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My brother was in Rzeszow, also in Poland, because he was married.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "You know, and he was in-- in a-- in a ghetto in Rzeszow with his wife.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "In Wolbrom, a couple of streets-- three, four streets, and that's-- that's it, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And we had a small-- we had-- we had one room.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "You can imagine, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Before, we had five rooms, now we had-- and over there in Wolbrom.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But we were happy.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "At least we are together.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Whatever will be, we'll be together.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Not by a wall, but, you know, but they were-- they were watching, you know-- the SS was watching.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We could get it, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Not clothing, you know, because we took some from home, you know, in the suitcase.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But my father's sister was living a long time in Wolbrom, so she helped us.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "She helped us with food, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She came every day, every second day.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] next block.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And she brought us.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "We didn't eat so much.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Not too good, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't take every day a shower.",
      "word_count": 7
    }
  ],
