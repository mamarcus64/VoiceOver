  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And my parents came over after my daughter was nine months old.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "They came over in 1943 on a convoy with 21 ships, 12 of which were sunk.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And Churchill was making a speech at that time, saying, as I'm speaking, a convoy is being attacked in the Atlantic.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And I just knew that was the convoy my parents were on, because they had sent a letter, we're leaving soon.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And I knew that that meant that they were leaving.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "So that was very exciting, when they finally came and were alive and called from New York and came to Chicago and I had a nine-month-old baby girl.",
      "word_count": 28
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "My daughter's name is Diana.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I went to the Art Institute of Chicago.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I was married and I went to school.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And I never graduated, unfortunately, because we moved.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "At that time, it was difficult to get apartments and all that, so we moved to a suburb.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I went there for two years on and off, and then subsequently took lots of courses in art and art history.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
