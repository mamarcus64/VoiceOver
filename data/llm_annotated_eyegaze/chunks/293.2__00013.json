{
  "stem": "293.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "She looks like a French girl, like an Italian girl, like a Romanian girl.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And she has a birth certificate that she was born in Romania, because she was born Romania.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "When she was not even--",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I tell you-- I'll tell you what it is.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "In 19-- my uncle was a big shot in Jewish [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "He was arrested with the president of the [INAUDIBLE], because they were bribing a German official to allow the Jews to stay in Cracow not to get to ghetto.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "It's a Jewish federation.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You know, Jewish council.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So they arrested three people.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "One of them was the president, who-- the president was a teacher before the war.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "He was my teacher.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "When I became a teacher, I was teaching at the same high school what he was teaching.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We were colleagues.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "This reason, I was selected by him to be-- give me the documentation that I work in the Jewish council.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "My uncle was a, a, a, a treasurer.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And they tried to bribe a higher official to allow the Jews to stay as long as possible in their homes.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And they were sending them every day to work, the forced labor.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Because every day they assigned lots of people to work.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Now when-- for example, when I was supposed to go this day to work, I took 10 zloty or 20 zloty, I give a guy, and he took my cart.",
      "word_count": 30
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "He went for me there.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So I didn't have to go.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "You could buy your time.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And this way I have a chance to go and make some-- somebody has a diamond ring.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "A jeweler.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He was locked out.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "He give me the diamond ring.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I went out, outside.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I sell it.",
      "word_count": 3
    }
  ],
