{
  "stem": "2460.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "But we were stealing it.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "After four or five days, I got sick.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I didn't know what.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "I got very, very sick with lot of fever.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And while I was walking-- waling on the street, my two friends helping me walking, an American army six-wheeler stopped with two black soldiers.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "They grabbed me, and they took me on the truck, and they took me to an army hospital.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And I-- then I found out that I had typhus of my stomach.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "I was very, very sick for a long time.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "An army-- a Hungarian-- not a Hungarian.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "An American Jewish doctor treated me.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "But he knew very little Hungarian.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "He didn't spoke no German.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "Just because his parents probably was Hungarian.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "And I was told by my friends that he healed me with hypnosis.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "I don't remember too much because he told me that there is no medicine for me anymore.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "After three weeks, either the typhus is cured, or it leaves the body, the-- the temperature, or the patient dies.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "I just remember that he was young.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "I wish I would know his name.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "I never knew his name, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "He was sitting many, many hours-- seemed to me hours, but maybe it was just a few minutes-- on my bedside.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "And he told me that I remember that you want to be strong.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "You want to come home.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "Things like this.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "But mostly I was in trance.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "I don't remember many things.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "I was very, very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "And about seven days later, I felt better.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "In the morning, I woke up.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "And I didn't have so much temperature.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "And the first time, after four weeks, I was able to walk into the restroom by myself.",
      "word_count": 17
    }
  ],
