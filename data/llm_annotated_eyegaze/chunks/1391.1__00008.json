{
  "stem": "1391.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 526.1,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Another go, month go by, another man stabbed to death.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "The youngster brother was in our Hebrew school, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "The way when he come home, they catch him off a wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And the mama didn't see him anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And he is still alive, the same one.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, making short this-- one time, they saying they're supposed to deliver 300 people [INAUDIBLE] And right away, with Jewish couples, you know, they [? pull it. ?] And then [? the religious, ?] they, they grab your brother.",
      "word_count": 39
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Your brother, they looked off the list.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "It's already the Gestapo come out from the house.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "Hey, [SPEAKING GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "They [? caught ?] him, him.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "It was 300.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And this come in a wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "They took it away.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "Till now, nobody know it, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "The first one, no.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "The next week, they're saying they needed another 100.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Then they catch my little brother, the youngest, the youngest brother.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And Mama say, let's go run away.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "It was too late.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Right away was [INAUDIBLE] on the streets.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "We have to be delivered to the big ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "This was Lodz.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I was locked up.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "You know what mean locked up?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You didn't can go out in the street.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Here, was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "The only thing was you can do is go up and kill yourself.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Then, the father stay like you, like-- and he say, [SPEAKING NON-ENGLISH] Now, I tell you in English how it was said.",
      "word_count": 22
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "I double cross you.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "He start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "Too late.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "Daddy, is too late.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "They took out-- little by little, they took out the young people.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "But the old people, OK, we have to go to Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "Oh, yeah, was-- between time was factories, little factories.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "And the same, they closed up.",
      "word_count": 6
    }
  ],
