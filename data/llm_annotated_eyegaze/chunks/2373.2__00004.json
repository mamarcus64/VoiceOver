{
  "stem": "2373.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That was already run by the-- by the-- by the English.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "That was a proper hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, to help people, yes, to restore them back to health, and send them home.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That was a normal hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, for-- I-- I met there my-- I met there a doctor.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We fell in love.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And we married there.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I became pregnant.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And we returned to Prague, in April, the 6th of April.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And the 7 of April, my daughter was born.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Of course, from all the traveling, and all the excitement, she was born on seven months.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "She was very premature.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And-- but the next day, when we arrived home, she was born.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "My husband had there some people he knew.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And we had a room there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So-- and I went straight to the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And when I came out from the hospital, my-- I had a daughter.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Her name is Vera.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't let her home with me, because she was very delicate, very small.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So she was kept there in the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have any milk.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "So they arranged for a special young mother, who was feeding her.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And I was just visiting every day to see her.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And in the meantime, we organized.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "We had a place.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And then after two months, she came home.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And-- you know.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "She was a healthy young girl.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "But when she was born, she was a kilo 20.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Because both parents came from the concentration camp, that she got special care.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Well he-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And he worked there in the-- in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "How long were we in Prague?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was '46 April, when we arrived, until '49.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But in the meantime, I divorced.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And in '49, we went to Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
