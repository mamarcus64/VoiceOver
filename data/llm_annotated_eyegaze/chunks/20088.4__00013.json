{
  "stem": "20088.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It all sounds reasonable.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "But it wasn't reasonable.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "It was all-- you didn't really get medicine.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And you didn't really get care.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But it was all there.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And so my mother said, all right, we'll go one day to this surgery.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And when we were waiting, there was a nurse walking.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And I saw my mother looking.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I saw this nurse looking.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And, suddenly, they fell into each other's arms.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And it was a cousin of my mother who had been deported from Prague and sent to Auschwitz.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And her husband was a skin specialist.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "And when-- you know, when he filled in probably that he was a skin specialist, the German picked him out.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "And he became-- he had to work for the Germans for-- because there were a lot of skin illnesses.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "He had to work for the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "And he was in touch with Mini.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "Mini was the name of that [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Sameck, I don't know his first name.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And-- and he was-- he knew as well Mengele.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "So-- well, with this Mini is a very, very interesting story, which I will tell you a little bit more in details later.",
      "word_count": 23
    }
  ],
