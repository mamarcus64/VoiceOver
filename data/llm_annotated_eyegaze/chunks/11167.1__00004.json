  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We used to invite people, you know, to see.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] Which holidays, you--",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Rosh Hashanah, and Yom Kippur, that was a very sad-- not like here.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It's a very sad holiday-- very sad.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] [CRYING] [PAUSES FOR 7 SECONDS] Absolutely everybody is killed-- everybody.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "The two brothers was straight-- straight away.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "One brother, my sister, and I, and then my niece, survived in a-- in a field where you bury potatoes.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They survived-- I don't want to-- it's very difficult to say.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] She's now arrived in Israel-- my niece.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS] They survived.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They had a lot of jewelry and gold, you know, gold in money, not gold like-- you know, in rubles.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And she-- they had a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "They gave up everything to be saved.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "After the war, when--",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In a-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they used to-- the-- these one what they took from him-- all the jewelry and everything-- he used-- they used to-- you know, their life, of course, it wasn't safe to go in to spare-- to save Jewish people.",
      "word_count": 40
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And so they used to bring in the night a little bit of soup, a little bit of water, a little bit something to keep them, you know?",
      "word_count": 28
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "In a hole, until, you know-- we didn't have Frigidaires, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "In these days, there wasn't Frigidaires.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "It was made holes, and it was very cold, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "In-- in winter it was warm.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We used to keep all the potatoes and greens and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "It was warm.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And in summer, it was cold.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "In these days there wasn't Frigidaires.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "You had to adjust yourself to something else, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "He-- he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And they all three survived.",
      "word_count": 5
    }
  ],
