  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "--we used to take a room somewhere in a private home and sort of just have-- go out, perhaps, for lunch or for dinner and prepare our meals otherwise.",
      "word_count": 29
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "So-- But it was good.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "We used to walk a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "My mother was a great walker.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "I was too.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "I always loved walking.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "I met my husband in a bushwalking club.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "And she'd go to Theresienstadt too, to stay with her sisters over the holidays.",
      "word_count": 14
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And we'd go somewhere else.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "About 60K north of Prague, about two hours' train journey.",
      "word_count": 10
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    }
  ],
