{
  "stem": "523.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Hello.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Freda Rosenblatt.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In 19-- February 1, 1932 in Bessarabia, at that time was part of Romania-- province of Romania.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "That's right-- on the map, I did-- Bessarabia.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Now it's Moldova.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "As a child, my father was very well off.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They have a factory from sunflower oil, sunflower seeds.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was a very educated lady.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "She came by herself from Ukraine during the revolution.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I was grow up with maids and nannies.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And that's what I remember until 1940.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Chuna.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Sara.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a older brother.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "His name was Hersch, but was nicknamed him [INAUDIBLE] as a child.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, about four, five years, approximately.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes, as a child-- I mean, going to school, playing with children, normal-- normal life.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Romanian school-- at that time was Romania.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "In school was Romanian.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But we spoke home Yiddish and Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Because Bessarabia once belonged to Russia until the First World War.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So the majority of the-- of the people spoke Yiddish and Russian, and some Romanian.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So we-- because my mother was from Russia, we spoke Russian.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We also have a maid home who spoke Russian and Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So this was my main-- main languages what we spoke home.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Do you remember the factory that your father ran?",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "As a child, I used to go to visit.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "The-- the maid used to take me there.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was a beautiful home and had a beautiful life.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Beautiful, big garden with fruit, with trees-- it's like a little paradise right behind our home.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Before the war was about 5,000, 6,000 Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know the rest, but Jews have approximately 5,000, 6,000 Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, I wouldn't say.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "It was a modern Zionist town.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Actually, the war in our place started in '41.",
      "word_count": 9
    }
  ],
