{
  "stem": "21319.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And next morning, about 8 o'clock in the morning, I don't know, the-- the SS commandant came in.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And he says, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "You all have to go to unclothing, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "So I gave-- mine baby was sitting there waiting on the benches with other people, mine-- my pat, whatever I had, a little pat, a glass of something.",
      "word_count": 28
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And she should have in the pack.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And I said, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "I am going to be soon back, because I thought we just going to-- to the unclothing.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know we'll come back and then we'll be separated.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And she started to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And she says, Mommy, Mommy, please don't leave me.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "I said, I'm not going to leave you.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Everybody's here.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "We were only like 10 or 12 people, that's all.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "So we were coming back, I said.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "We're just going to-- to get some fresh clothes or something.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "I don't know what he told me, that-- the guy there, the man.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I never saw my child again.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And they took us in-- in the camp in Birkenau in Auschwitz.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And they shaved our heads.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "Shaved us all over, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And then they put a number.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "I was the 75th-- who came in the camp, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "75,603.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "That's the people who came alive.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Later on, they were killed anyway.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But I mean, that was my number.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I asked one of the guards, after they did all this thing, I said, can I see my baby now?",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So he says, look at the sky.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So I look, and I saw the big flames.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And-- and-- and I said-- I said, what do you mean, your child?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I said-- you see these big flames, he said?",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And the big fire coming out?",
      "word_count": 6
    }
  ],
