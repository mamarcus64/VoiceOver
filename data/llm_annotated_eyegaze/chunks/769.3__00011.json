  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And I'm going to go to [?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Shlomo ?] to give him what my father sent.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "He said, wait.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "He called my brother and gave him $100.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "Now, taking the dollars, I bought a [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "And gave it to [INAUDIBLE] back.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "When my brother got to him the dollar, he opened it up and counted to him the dollar.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "Me, he gave it, I put it in the pocket.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "He said, he will be a businessman, and you not.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "You see it.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "He's a businessman.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "When I give to him the dollar, never mind [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "He counted the hundred dollars.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "This is a businessman.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And when I give to him the dollar, you put it right away in the bag-- in the pocket.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You never will be a good businessman.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was right.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I was a tailor, a short time.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't like it, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I realized, being a tailor, I'll never go too far.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So I worked for a short time.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And after, I started to make it a clothing store that didn't working.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I bought a cigar store, like a variety store.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We were both working very hard at the variety store.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] We didn't make it so much money.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "We make it money, not because we earned it.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "We make it money, because we didn't spend it.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Never got time, haven't got the place.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "We haven't got no way to spend.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "When I buy the store, the variety store, I got a car.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And the moment I buy the variety store, the car was in the garage.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "I never use it.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I haven't got time to use it.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "What I buy-- a-- a salesman's coming in.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "They bring it in everything.",
      "word_count": 5
    }
  ],
