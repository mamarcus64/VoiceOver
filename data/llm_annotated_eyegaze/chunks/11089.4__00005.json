{
  "stem": "11089.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I kept on marching, because I came from a village-- I told you-- and whenever I saw some greens on the field, I headed off for that, even they shoot me.",
      "word_count": 31
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I took some greens, a potato, a carrot.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I will show you some.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "But I'm not ashamed to show you my leg right here, this scratch.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "God knows why it is, but I will tell you why it is.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "While we were marching, there was a man, 45 years old-- because I was born [INAUDIBLE] in Khust in his place.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He had to send two sons-- one my age, and one older.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And their tate, their father, started to weaken.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "He couldn't keep up the march.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And the two sons knew what's going to happen.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They would shoot those that can't keep up the march.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I again, being from a village, I went to the side.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We were walking a highway.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I looked down in the field, and I saw carrots-- and those greens, green carrots, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I knew it's carrots.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I went and I tripped up myself.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I rolled down from the highway into the field.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And with two of my hands, I pulled out whatever I could.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They started to shoot-- anybody who left the line-- and one bullet hit me.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "But thanks God, only my skin.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It didn't go into my knee.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I ran back.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I took a carrot, a big one, on my jacket like this.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I cleaned it.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "I say, [?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Duvid Bachi. ?] [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Duvid Bachi ?] means, in Hungarian, Uncle David.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Bachi ?] is [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Duvid. ?] I said, eat!",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "I stick it to his mouth.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "He start [MAKES CHEWING NOISES] to chew it.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "He said, [PANTS] Eisler!",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "You saved me.",
      "word_count": 3
    }
  ],
