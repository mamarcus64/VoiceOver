{
  "stem": "11964.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "Her name was [NON-ENGLISH], and she and Teresa became very close friends, not knowing that one or the other were Jewish.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "They just became very good friends.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And when we were in Warsaw after liberation, my younger sister went to join, to register herself as a surviving orphan, Jewish orphan.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And whom does she meet there but her friend from convent, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And they couldn't believe it.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "They just fell into each other's arms, and they said, no wonder we were friends in the convent.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "Her father survived, and her brother.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And her father just adopted us, and he says, I am going to help you girls as much as I can.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And when we told him that we felt so uncomfortable being here, he says, don't worry.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "There is a movement by Palestine, by Jews in Palestine.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And they call it Aliyah Bet.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "They send us those young Palestinian boys, Jewish boys, and we have a way of taking people out of Poland who don't want to remain in Poland.",
      "word_count": 27
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "We take them through the Russian zone.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "We take them to Czechoslovakia through the Russian zone of Austria, to the American zone of Austria, put them in camps, and then we wait for the illegal entry to Israel with those boats, like the boat and those other boats.",
      "word_count": 41
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "And lo and behold, he comes to us one day.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "And he says, this is the day.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "Tomorrow morning you are going to go to the railroad station.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "A young boy-- not a young man-- a young boy will approach you.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "And here is the money he gave us, 500 zloty, which was a large sum at that time.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "You give him the money.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "You don't tell anybody what you're doing.",
      "word_count": 7
    }
  ],
