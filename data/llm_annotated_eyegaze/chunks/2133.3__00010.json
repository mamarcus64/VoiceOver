{
  "stem": "2133.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Oh the camp?",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we have displaced people.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "About thousands of us from every nationality-- Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Matter of fact, on a picture, the little picture there, there is one lady who I met there who used to be one of the biggest banker in Berlin.",
      "word_count": 29
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Panis was the name.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Her son was-- their friend was the Rothschilds.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And she was in this displaced person camp, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Her husband was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And I'm there in the picture with her.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "She sent her son before, way before.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "When the bad time came in Germany, she sent them to England, was raised by the Rothschild family in England.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And she was looking forward to go back to England.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "There was a lot of interesting people in the camp after the war.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "How long did you stay?",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed there from '45 to 1946.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "The 31st of August, I came to the United States, went through [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "He's something that all the displaced person was able to come into the country without waiting for a quota.",
      "word_count": 19
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They had the priority.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Because you had families here?",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Is that why?",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because I had family here.",
      "word_count": 6
    }
  ],
