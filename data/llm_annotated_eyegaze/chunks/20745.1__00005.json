{
  "stem": "20745.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I slept in an attic with my friend [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And they start to gather-- gather the people to send out the people to the Ghetto Miedzyrzec.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And-- and they-- and a-- and a Gentile told them that we are upstairs in the attic sleeping.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And they got us too.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "They took us out.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "But and one man watched us-- me and my friend.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "But we weren't with the other people yet, but they were gonna take us.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So I bribe-- I bribed him.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to bribe him.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I gave him my-- I had gold earrings, and I had some money.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And I gave him-- I said, let me run away.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "Let me go-- me and my friend.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "He-- he took everything, and then he pulled a gun, and he said, you're not going anyplace.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "Then he-- I-- somehow, he left, and another one came.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "I had no money.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "I had nothing left.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "But I said, [POLISH], please let me go.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "Let us go.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "They said, you go-- go, then we start.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "So my friend said, where are you going?",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "He's going to kill you.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "Why are you running?",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "I said, let's go.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "Let's take a chance.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "So we ran.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 19,
      "text": "He didn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 20,
      "text": "He let us-- he let us go.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 21,
      "text": "So we ran in-- on-- went through the fields, and we went into a barn because we didn't want to walk during the day, and we stayed there.",
      "word_count": 28
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 22,
      "text": "We say other people passing with a horse and buggy.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 23,
      "text": "You know, the people who they-- and they took them to Miedzyrzec.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And when it got dark, I tried-- we tried to get home to my-- to Wohyn.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I came home, and-- and my brother was looking for me.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They-- they passed our town.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "They didn't see me.",
      "word_count": 4
    }
  ],
