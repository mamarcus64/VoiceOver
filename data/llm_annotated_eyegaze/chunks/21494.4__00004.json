{
  "stem": "21494.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember the name of the-- of the-- was a small-- a small, not a forest, how you say, a [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "A park.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "A park.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We went and we found all kind of [SPEAKING GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Some bones also buried there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I they told me, but I couldn't go there.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I-- as a pauper, after the war-- after the war, I took such revenge of this what killed my father, the ones that took away everything.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "How?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They-- I came to my place and there was the Czech was still there.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I came to the-- to the mayor, you know, and I recognized all the-- the equipment and everything.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I said, oy, this is mine.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He said, oh, no this is not yours.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Go right away from here.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And you know, I-- I took very bad steps.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "He could kill me with Sanja, and we ran away.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I came to the neighbor, a Czech, first, which they neighbored our--",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Farms, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I called-- told her and I-- I cried very much, and she gave me bread and-- and this--",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Bacon-- and bacon.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And at night, she was very rich, a nice house-- came the- the-- not [INAUDIBLE], the-- the like-- the-- the-- from the-- from the Army, like in come from the Army.",
      "word_count": 31
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And they made there their-- their headquarter there.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And the soldiers were in the-- in the forest.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "There was a big forest where our village was.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And she told the whole story.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They went to him.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They arrested him.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "They arrested him, and they brought him in the shtetl and I was there, yes.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And-- and-- and he says come in to Lutsk, you must be a witness and I was a witness.",
      "word_count": 19
    }
  ],
