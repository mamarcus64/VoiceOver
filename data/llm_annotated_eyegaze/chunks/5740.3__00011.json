  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 3,
      "text": "It meant a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 4,
      "text": "But yet, on the other side, I met here a girl that was with me for three years and three months in the same room.",
      "word_count": 25
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 5,
      "text": "And we were in Mount Buffalo, in the same, in the same, on the same holiday place for two weeks.",
      "word_count": 20
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 6,
      "text": "We spoke to each other.",
      "word_count": 5
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 7,
      "text": "We, we watched each other play games.",
      "word_count": 7
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 8,
      "text": "And we didn't know who we are.",
      "word_count": 7
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "The last day, somebody ask her, where did you-- where have you been during the war?",
      "word_count": 16
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "And she said, I've been in the concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "Which camp?",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 3,
      "text": "Ober Altstadt.",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 4,
      "text": "I said, I've been in Ober Altstadt.",
      "word_count": 7
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 5,
      "text": "And that was [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 6,
      "text": "She didn't recognize me.",
      "word_count": 4
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 7,
      "text": "And I didn't recognize her.",
      "word_count": 5
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 8,
      "text": "And yet, she had been in--",
      "word_count": 6
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Been in the same camp.",
      "word_count": 5
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "And we were quite good friends in the same [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "The same room.",
      "word_count": 3
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "All the time.",
      "word_count": 3
    }
  ],
