  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And he was-- he injured a few people, and he killed one or two.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "Finally, a Jewish butcher got hold of him and handed him over to the police.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "There was a big trial.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "It dragged on for about a year, maybe longer.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "And he was acquitted.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "This is-- was the Polish justice.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "A Jew did not stand much a chance in law.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "It's not like here.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "People today can't imagine these things, but Jews didn't have many rights in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "Especially after the-- 1935, the leader of the Polish government, Pilsudski his name was-- and he died.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "So then it changed.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "Things completely changed after his death.",
      "word_count": 6
    }
  ],
