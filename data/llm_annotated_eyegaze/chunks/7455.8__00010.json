{
  "stem": "7455.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And then my brother and I, we said, you know, I remember my mother had cousins in Brooklyn.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Axael, it was A-X-A-E-L, Axael.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE] was their name.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Maybe we'll call.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We'll find them.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We didn't speak English, but the names we could read because it's English.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It's like-- so Axael, there were maybe 50 Axaels, and we kept calling.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We were-- had free use of the telephone, they let us use.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And my mother's name was Charlotte.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Are you my relative?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Until we found somebody, a cousin, Axael, who said, oh my God.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Charlotte [YIDDISH], was the Yiddish, my mother's name.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "[YIDDISH] [GERMAN]?",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Children of-- children.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "They're coming to see us at the hotel.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And it came, my cousin and his wife.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And he said he'll describe himself.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He wears like a pink shirt, a sport shirt.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And my brother and I, we waited and we saw.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And they came.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We recognized them.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Embraced us.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And we-- we were gregarious.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We wanted to tell them everything what was done to us.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And they-- they thought, perhaps, that we talk too much.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "But we had to.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "They invited us to their home.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And all the other relatives, younger people who didn't-- my cousin knew my mother in her youth, and so, but they did not know.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "Introduced us.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "The [YIDDISH].",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And whatever I had of clothes, they felt maybe I'm contaminated.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Tore off me, even thought I was not contaminated.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And they took me, bought me clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "Whoever didn't have relatives stayed on at the hotel until they find them something.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And my cousin took us.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And my cousin said, like that.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "You are a girl.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "You need a home.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "Your brother can get a furnished room, we'll get him.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "He'll find a job.",
      "word_count": 4
    }
  ],
