{
  "stem": "10272.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "We went to the same class-- school buddies.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And they come to say goodbye to me to the train station.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And I said, goodbye.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "I'm going.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "I just took a, a small bundle of things from the-- when we saw the movie was over, they showed us-- showed me off to the train.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "I, I boarded the train.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "I bought a ticket-- Bustino to Brunn.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "It took me a whole day go get there, because the train didn't run properly.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "It was all kind of-- had to stop over and wait for another train.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "So it took me almost-- more than a day to get to Brunn.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "I came to Brunn.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "I had never been in a big city.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "I didn't know where, where he is.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "I don't know his address.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "I was lost in this city.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So finally, I went-- I found a Jewish community.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I saw written, 'Jewish Community.' And I was asking-- yeah, I, I remembered the name of the place were [?",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Fred's ?] supposed to work.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They called it 'Stiassni.' Stiassni was the biggest textile factory in Czechoslovakia, the biggest.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So finally I got to the Stiassni office.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I was asking for a job.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I said-- I, I had the school clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "They don't accept no more us in school.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And I am from Bustino, from the-- Carpathia.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And I would like to work something.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I showed them some sketches.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I brought with me also sketch-- what I am sketching.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I can do something which in textiles they use for, for sketching.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "He said, OK, we will-- we will give you a job.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He give me a job.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And when I went to the-- to the cafeteria to have lunch, I, I met my friend [?",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Freddie ?] over there.",
      "word_count": 4
    }
  ],
