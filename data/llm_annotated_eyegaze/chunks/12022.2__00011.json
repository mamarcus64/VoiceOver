  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 52,
      "text": "They grabbed me [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 53,
      "text": "And then one-- a couple Germans said-- I answer them in Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 54,
      "text": "I took out mine passport and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 55,
      "text": "And they was looking at passport.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 56,
      "text": "And they couldn't see anything.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 57,
      "text": "And then, just saw that I'm a Lithuanian citizen.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 58,
      "text": "And they said from the beginning, they [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 59,
      "text": "They check me and took me and took me.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 60,
      "text": "I thought, they're going to kill me down there.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 61,
      "text": "Finally, I had, I had luck.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 62,
      "text": "They let me go.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 63,
      "text": "They let me go.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 64,
      "text": "Then I was going farther.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 65,
      "text": "And I come to the town, Orany.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 66,
      "text": "And I was so-- was, the heat was so hot weather.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 67,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 68,
      "text": "And I ?] was so dry.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 69,
      "text": "And I was afraid to go in, ask for a drink of water.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "That was in June.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "In June-- by the end of June.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't tell you the day, because I get mixed up already.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I don't know which day it was.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And then I came to Orany.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I was-- wanted a drink.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And I know the Lithuanians not so friendly.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And I saw a well with a pole, with a pail.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I start to pull out some water from the well.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And the pail was burned.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Before I pull out, the water run out.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Then a lady came out and said to me, you want to drink water?",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She said, come over.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And finally, I told-- she told, talked to me in Lithuanian.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Then I told her maybe she know how to speak Polish or Russian.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She said, I can speak anything, [INAUDIBLE] Jewish, Jewish, too.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She recognized me right away.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I'm Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Well, she took me in.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "She give me food and, and shelter.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And they was talking against the Germans.",
      "word_count": 7
    }
  ],
