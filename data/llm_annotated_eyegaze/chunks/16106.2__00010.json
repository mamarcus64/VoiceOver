{
  "stem": "16106.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "And he has a daughter who's an architect and a son-in-law who's an architect and has two grandchildren, lives in Minsk, and it's very tough now.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "If I can, I send always money with somebody who goes back and forth.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "He was-- he really was a genius.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "I have the picture here.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "And he used to draw fabulous.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "Maths was his forte, and-- and languages.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "He-- until today, he can recite Schiller and Goethe without-- and very clever man, very smart man.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "And he was deported.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "And then I went to school, and half of the class wasn't there.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "And we had no tests.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "This time, I wasn't happy.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 29,
      "text": "Half of the class were-- it was empty.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 30,
      "text": "No test, no people, nothing-- that's when it really started to get tough.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 31,
      "text": "And then the bombings started.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 32,
      "text": "And when it was quiet, the Germans were in town.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Germans?",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Wehrmacht-- grey uniforms.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, you had the-- the usual things with everybody went through.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Jews were not allowed to have radios.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Jews were not-- our bicycles they had to take away.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And we had-- no more jobs for us.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And we couldn't work.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't-- then after-- it then escalated.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Then Jews couldn't go-- had the curfew.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "They could be in the street only certain hours.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And then they escalated even more.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "We had to wear the green-- the yellow-- yellow star, which is--",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yellow-- yellow-- yellow Magen David with Jew written in it.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I had a very elegant one.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "My [NON-ENGLISH] made me one of silk.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "It had to be in the front and had to be in the back.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Sewn on.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And we are not-- we're not meant to walk on the sidewalk, only in the middle of the street with the horses, which was good company.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    }
  ],
