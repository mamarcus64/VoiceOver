{
  "stem": "1419.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It was, was without explanation to my mother, I guess, you know, why he left.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But we have to-- we lived with it.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Because a lot of people came back from, from, from, from Lemberg and from Russia, which they, they got killed anyway.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "But my mother was left with, with three kids, myself and a brother and a sister.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And, and, and, and I guess, you know, my father, he was afraid to come back.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They thought maybe the, the war will-- the war will, will end.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And, and will, will, you know, they, they were telling people that the, the Germans killing off the Jewish men, or the taking away the Jewish men.",
      "word_count": 27
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "It was the reason they run away.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "In a way I felt abandoned.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I wished that my father would be with us.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Would be easier on my mother and myself.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Right, right.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Well, a lot-- a lot of them ran away.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And, and, and some of them survived in Russia, about the same age as my father.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They run away.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Their family never survived their wives, in some cases, never survived.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "But I know some people from Nowy Targ which ran away to Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "They survived in Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Good friends of mine, their parents, their fathers, I mean, not their parents, their fathers.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "So that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother had a hard time to, to keep everybody, you know, alive and fed and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We had-- like I tell you, we had the store with, with textiles and, and, and grocery [INAUDIBLE] textiles.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And my mother used to sell out, in the beginning, some textiles.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we had some money.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And we managed.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We had some-- like I tell you, we lived between Polish people.",
      "word_count": 12
    }
  ],
