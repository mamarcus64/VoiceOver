  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Before-- before-- before we light the-- we-- before there's the-- the [?",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Habdallah ?] we have [INAUDIBLE] which means, [INAUDIBLE] before the Sabbath ends.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And the piece of herring was very appropriate almost every Shabbos until-- until the horrible thing happened.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "This was like a-- it was like a must in a Jewish home.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I should get a herring, a piece a [INAUDIBLE], piece of cake, sour milk.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And it was just beautiful.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And then the love, you know-- the sisters, the brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Very well.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Very well.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We-- we-- I don't ever remember fighting with my siblings.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I don't, because my sister was old.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Malka was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "She was like the little [INAUDIBLE], like the little house model, sort of, in the house.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "She would clean.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "She would do-- so we listened to her, because she kept this apartment spotless.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And we had wooden floors, you know, and no carpets.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "So you had to lay down and scrub the floors on-- on your knees.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And it was beautiful, you know, so-- Then she brought her friends in, which were beautiful people-- she-- the cream of the crop.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "She was a magnificent looking girl, my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "She was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "We had gorgeous six children.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I helped with housecleaning, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I-- I remember my sister going to school there too.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "My sister graduated [INAUDIBLE], which is equivalent to high school here.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "She was lucky she-- she-- she graduated.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She was-- [PAUSES FOR 3 SECONDS] It was like, when you graduate high school, the [INAUDIBLE] is like high school-- it's equivalent to college here in-- in education.",
      "word_count": 28
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "The education was very intense.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "You can imagine that I am in the United States of America.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "I came in 1947.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "That makes a 48 years.",
      "word_count": 5
    }
  ],
