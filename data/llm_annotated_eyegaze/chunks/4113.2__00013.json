  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My father comes back, and he tells us the story.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The Gestapo from the town next to us, Jaslo, where there was the-- the headquarters of the Gestapo of that whole region, was in Jaslo, a town, 24 kilometers away from us.",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And Schmatzler's group, in our town, was under them.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So what happened, my father came down, and he said, the order is that all Jews have to deliver all their woolens, all their furs, to one place within 24 hours.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Whoever is going to be caught who had not delivered that is going to be shot on the spot.",
      "word_count": 19
    }
  ],
