  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "For years, I carried her on my shoulders And she-- and then, then gradually, she recovered and we looked after her.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And one day, unfortunately, when she was about 10 or 11, a local constable comes in.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And he says that for the-- for the registration purposes, are the family members in this house so and so, and so and so, and so and so?",
      "word_count": 28
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Then he says, is Rosette Goldstein here?",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Daughter of Jacques, deceased.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And she hears that from him, and she got-- went into a state of shock, because until then she thought that my parents were her parents.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And she had never forgiven my parents for not telling her the truth about her own parents.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And then she couldn't forgive the fact that as a child, that my parents were alive and hers weren't.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "She couldn't understand that.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And that became an absolutely-- war between her and my, my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "It's only-- it also wrecked her own life.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "She was never able to put her life together.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "It's only a year and a half ago, or a couple of years, that my mother was-- was going downhill in the senior home in Belgium that they finally reconciled.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And after all these years.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "That's, that's Rosette.",
      "word_count": 3
    }
  ],
