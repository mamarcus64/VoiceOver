{
  "stem": "3380.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "No other people made $60 at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I mean, very seldom.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "People used to work for $20 and $30 dollars a week.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And we were so happy.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "We had a healthy child.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And my wife, we were the happiest people in the world.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In Chicago.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In Chicago.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Jack was born in Mount Sinai Hospital in Chicago.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I used to live at Springfield Avenue, 5036 Springfield.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And then she-- she gave birth to two more kids.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Thanks God, I mean.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "But all my years with her, I was living in fear that something shouldn't pop out.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't expect that she's going to die.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "She's-- you know, that she's going to die on complete different things, that she's going to have a brain hemorrhage.",
      "word_count": 20
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] You know, she-- this-- well, this-- this came out of nowhere.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "She was pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You didn't expect this to happen.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You're in a new land, a lot of hope.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "People what know me, they know the story.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "People what didn't know, didn't care.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "No, I mean, you could not constantly-- and I did not want to discuss this thing with my wife.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Because she was depending on my health.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't want to talk about it.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] She did more talking to the kids than I did.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "You know, I didn't want to say, I married a sick girl.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "Or you know, if that wouldn't be for me, maybe, we-- no.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "We-- we never talked about it.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my kids were aware about the Holocaust, as little as the war.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, when Debbie, the youngest, who is 35, she once had watched television.",
      "word_count": 17
    }
  ],
