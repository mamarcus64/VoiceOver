{
  "stem": "7600.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "I was so curious.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "But I was told that they lived in the same house, even though separate.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Because, as I said, women didn't live alone in those days.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "And she had no-- she had only a child that was my age, a son.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "She had no children to go to, so she had no-- nobody to live with.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "So he gave her another-- a room, and a-- you know.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "She had her own room-- sitting bedroom in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "And they didn't eat together, didn't go out together.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "They were just living like strangers in the same house.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "Even though she tried very hard to probably come back to-- I don't know whether she had a boyfriend.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "I know at that point she had a boyfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "She used to get dressed and get-- go out.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "But I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "I never saw him or heard of him, or anything like that.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "But when I came to the-- the apartment, there was the housekeeper.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "Her name was Mitzi.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "And my cousin's name was Kurt-- K-U-R-T.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "He was exactly my age.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "He was just a couple of months difference.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "So, I thought he was very handsome and nice.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "And I have a picture of him.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "And they gave me a little nook in the-- in a large living room.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "There was a couch, and I was to sleep there, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "And I was part of the household.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "And Mitzi took care of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "She did the cooking, the shopping, the cleaning, everything.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "She even cleaned the-- the two rooms that he had as a dentist.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 38,
      "text": "But then Selma, was my aunt's name-- his ex-wife's name, Selma-- S-E-L-M-A-- Selma.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 39,
      "text": "Selma it was called in German.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And she was-- I thought she was very strange.",
      "word_count": 9
    }
  ],
