{
  "stem": "6076.6",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In the morning, she, she took her two children and came out from her hiding place, which I wrote a poem.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I gave you to read that poem about my two nieces in their hiding nest.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And she gave her over to the police.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Let them do whatever they want.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Well, she wasn't the only one.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They were already about around, around about 10, 15 Jewish people, who tried to do the same trick like they did.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But it wasn't successful.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "They find them.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And because of hunger, they have to give themselves up.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "How long can they sit in a bunker with no, no water and no-- not a little crumb of food?",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "So they send them Skarzysko.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "In Skarzyko, next day, Simchat Torah, she came with her children.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "My parents didn't ask her about her husband.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "She made it with her hand, not questions.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "She didn't want to tell her story.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "She came in with her two children to my parents' home.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "On Simchat Torah day, on a Sunday, arouse 11 o'clock.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] They took the Jews away.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "We're going to stop there.",
      "word_count": 5
    }
  ],
