{
  "stem": "26609.19",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "I thought I come for my child and I will get her.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, no, not with those people.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He says, you don't know those.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We have the battle here with those people.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They are killing there.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "It's a Jewish place after the war, mostly survivors are from Partisans.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "We had one man killed here-- and drinking.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "They bring in alcohol.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "You don't know with whom you are dealing.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And I said, no, of course I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "All right, don't go back there.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "We have a room here in the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Stay here.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "We will do something about it.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "It came out that 10 men from [NON-ENGLISH SPEECH] who years ago-- before in Munchen helped me to get back to my name-- remember, I said that when the Hungarian Jews [NON-ENGLISH SPEECH].",
      "word_count": 33
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "That man who knew me from there was here.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They set up a tribunal, a [NON-ENGLISH SPEECH]--",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, court-- to try him.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They didn't want to go to the Germans to know about it.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They were around Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They wouldn't go to a German court, but Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And there were a few lawyers.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And there was that.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And he laughed at that story when I told him, [?",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Smolenski ?] from Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He was there.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And he knew me already from Munchen.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And they said, now we'll deal with him.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "To get a woman comes in-- he wants straight away to marry her because he want her child.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And he's so stupid that he believes it's his child.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "Although she had a different name-- he don't remember the name of his child.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "Set up a court-- they took him.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I haven't seen it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "But there, I've seen it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "They took in the child, my daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "It's the first time I have seen her.",
      "word_count": 8
    }
  ],
