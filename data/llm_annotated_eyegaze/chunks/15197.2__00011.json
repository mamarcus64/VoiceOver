{
  "stem": "15197.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 1.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "When they ask me, for instance, to get out of the ghetto, at this time I had to smuggle out a map of Treblinka, which they already knew how and where it is created and formed.",
      "word_count": 36
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I had the first account.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Very, very difficult but also lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "At this particular time when I got the assignment is for the first time I got to know mine future husband.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "He was working on the Polish side in a Jewish labor battalion and he was also able sometimes somebody has to get out of the ghetto to bribe the group leader, Ukrainian.",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And the underground told me that I have to get in contact with him where he lives and he will include me in the labor group-- of course, bribing the group leader, the Ukrainian-- and to get out this way.",
      "word_count": 40
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And this is how I got to know him the first time.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Later on I met him more often on the inside.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "At that time I had the map of the Treblinka in my shoes.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And having in my shoes, I stood with all the other people in the group.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And I was one woman among men, only men, and they singled me out and they asked me to go to the checking point.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "What I have?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They understood that I have some smuggle or something, some clothing, some special thing.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I went into the shack where the German was checking me, and it was a German there.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "At the place to go out of the ghetto was Polish police and Jewish police and German.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And he asked me to take off the clothes and everything.",
      "word_count": 11
    }
  ],
