  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He was killed, no, see, the manager still was-- of the still farm-- he was called [NON-ENGLISH] I wrote a book, and in the book is everything what I was-- I could put everything in the book.",
      "word_count": 37
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I put-- I was-- worth four times as much [INAUDIBLE] in book.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "No, I was ready to read for myself-- to write, for myself, a book.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And all of a sudden, I became sick, I became a stroke.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Then I'm not able to read in the book, to write in the book.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I saw the ghetto, two miles.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "The man put me in, like I'm a-- [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "A [NON-ENGLISH] mean a gardener.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And I had two team people-- the nicest people, whom I want.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I took in-- the nicest people-- and between the two team people was the rabbi, a rabbi [NON-ENGLISH] in our city.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "The name of the rabbi was [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He was with me in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "In the ghetto, he was all time, and they kill him.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "We was working to the last day, till one man came from [NON-ENGLISH] from [NON-ENGLISH], and he told-- this man was the name Schneider.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "He was used to help for the-- for the-- for the everything, for the [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "They used to give him this gold, and everything-- you know, he used to say everything.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "It's a [INAUDIBLE] from Hitler, till October the 10, must be kill out all Jewish people in Ukraine.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "When [INAUDIBLE] told me this, in the morning, we went to work, and we came in field, and we was digging potatoes.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "Then I say to the people what was working, stop the work.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "So you know-- they saw something going on.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "My son came-- he was six years old-- he came for himself in ghetto.",
      "word_count": 14
    }
  ],
