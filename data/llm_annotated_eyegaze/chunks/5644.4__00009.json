{
  "stem": "5644.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "She lived safely with her until after the war.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "They had been killed.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Most probably-- um, no.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Her father was killed at the Miller Street when was the cleaning.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "Her mother was killed by the Poles, which she was there with them.",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "Because they did want to find out from [INAUDIBLE] where we live.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "And where her child lives.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And she didn't want to do give away the, the--",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "We know the name of the Pole.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "We advised it after the War to the Polish government, to a Jewish fellow, which was a cousin of my wife.",
      "word_count": 21
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "Advised them.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "And he was a, a, a, a judge in the new government.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "And he said to us when we went to him with the name, everything is excellent.",
      "word_count": 16
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 6,
      "text": "He said, we didn't came here to fight now.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 7,
      "text": "We came here to build a socialist--",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "System.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Naomi was living with us after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "I smuggled her up to Germany because I was working in the Bricha.",
      "word_count": 13
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "After the war, we have to smuggle her to Germany from Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't a free way to--",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Smuggle her out to--",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "We smuggled the border by the help of the-- of the Haganah, of the--",
      "word_count": 14
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "They were working-- not Haganah, but the other I said to you.",
      "word_count": 12
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Bricha.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "It was working everywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "I'd been working on the border of Czechoslovakia and Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "We got her back from the nanny in a very hard way.",
      "word_count": 12
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "That was very hard to get her back.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "But we got her back.",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "She was paid for it.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "'42, '43, '44.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "About three years.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "She was very--",
      "word_count": 3
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "--very upset with everything that was happening.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "Very upset.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "She thought that this is her mother and she wants back to Nanna.",
      "word_count": 13
    }
  ],
