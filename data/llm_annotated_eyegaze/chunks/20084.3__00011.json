  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "Then was a sergeant came to our tent.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And he says, you're going to report to Lieutenant this and this on the double.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "We didn't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "Maybe they checking on us that we took off for a couple, couple days or what.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "We came into that captain or lieutenant.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "Oh, he was Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "Kimmerling from Lviv.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "And he said, fellows.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "First, he said shalom.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "So we knew we home.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "He said shalom to us.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "So he said, I went through your records.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "He says, and you are not ready to join the army.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "He says, you have to go to convalescent.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "You're not ready to join the army.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 42,
      "text": "And so we said OK.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 43,
      "text": "So he said, I will take you to a friend of mine, assign you to a ward to be in a hospital convalescent.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 44,
      "text": "And the following day, I will come and pick you up.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So first day, he picked up my brother, Sam.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And then the following day, he came and picked me up and assign us to a hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Here, we'll pause to change the tapes.",
      "word_count": 7
    }
  ],
