{
  "stem": "10644.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I can-- we-- I can talk?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, his name was Krepsbach.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Krepsbach.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Nickname when he was in a camp-- not a Jewish camp.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He was camp-- in a camp Mauthausen, where Poles, Czechs, Russians were there, even the Italians, and sometimes few French people were in these camps.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And that was, you know, with-- with-- in Mauthausen.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And he was a doctor there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And he became famous among the-- the-- he came already with the reputation with the SS people.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "He came, and the SS people, oh, Krepsbach [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "We called him [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "He-- Krepsbach were around 45, 48.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, he would come.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He came, basically, to inspect me twice.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Next day-- yes, this is next day.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was informed Wiesner is her.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Wiesner is the right hand of this Dr.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Krepsbach.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He is not a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But he's-- in administrative capacity-- came.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I was-- went out, and I see he going to the second floor-- I after him.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And he knew exactly where she's located.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And he-- I am behind him.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Spies-- informers were plenty.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Maybe Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I suspected it must be one Jew could say to-- from the-- from the-- from the guard-- guard, oh, this woman is now on the second floor.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And guards were-- were in there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Oh, it is bed-- bed on the left side.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "One in this revere.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "In my revere there was only one room.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And he comes.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And now this.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Get up.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Get up.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And she understood very well.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "She got up.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She has a small bundle of things.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She took the bundles with her.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And he took her on the truck and brought to Kaiserwald.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I have my informers what is going on in Kaiserwald.",
      "word_count": 10
    }
  ],
