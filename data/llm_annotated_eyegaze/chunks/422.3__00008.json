{
  "stem": "422.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And the epidemics in the ghetto-- typhoid epidemic, tuberculosis, all the kind-- all the kind of terrible sicknesses.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And they blamed us.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "They took us to [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "[GERMAN] meant disinfection, that we're dirty Jews-- we keep ourselves dirty, in those conditions that people that they were chased out from villages, from other towns.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Everyone to Warsaw, to make one big, you know, evacuation point from us to be easier for them to get all the Jews from Poland.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "So they chased them all first into the Warsaw ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And from-- and the ghetto was not prepared to have so many people, so the-- the sickness was terrible.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Terrible sicknesses broke out.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "Hunger and sicknesses and the winter frost, suffering from-- from the cold.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And they still blamed us that we created this condition-- we made the war.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "We created the war.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "If would be access to medical care, my youngest brother would survive.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "He was not-- in the beginning, he had only a sickness of enlarged glands, which, with good food and vitamins, and some maybe antibiotics, the sicknesses is being taken care of.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And he died from this.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Temperature got higher and higher, till he got meningitis.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "It went to his-- to-- to his brain.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And we had to watch him two weeks, the way he was dying in the house, and we couldn't help him.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We couldn't help him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I, who almost brought him up, because my mother couldn't take so much care no more, so I helped a lot.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "After school I didn't play with children, I was a little mother-- wheeling the carriage, diapering the baby, feeding him.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I had to watch him die for two weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "I almost died with him, and my mother, too.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a different story.",
      "word_count": 4
    }
  ],
