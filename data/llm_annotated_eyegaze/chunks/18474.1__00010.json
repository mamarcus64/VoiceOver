{
  "stem": "18474.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "Sure enough, there I heard later, we heard they took all these boys and girls to the town of [INAUDIBLE]-- it was a little Jewish town-- and they killed them all out.",
      "word_count": 32
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 22,
      "text": "When I came back to the ghetto, the ghetto still existed, I went away to a Czech in a-- in a-- in a village called Podize, Podize.",
      "word_count": 27
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In English.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "P-O-D-I-- Podi-- I-Z-E or some-- Podize.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "There was-- there was a Jew-- a Czech settlement there.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "The Czechs were very good people.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They helped whenever they can.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "So I run away to the-- not run away.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "I went to-- from the ghetto, got out of the ghetto and I run away to him to work for him on a-- he had a big farm.",
      "word_count": 28
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "He had different farm hands.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "He knew I-- who I was, I was-- I was Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And he had a son in our town, too.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "That son was a good friend of-- with my father all these years.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "Anyway, he let me work.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "Then it started to get a little bit too hot.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "He said to me, I'll tell you what, I have a son in a different village about 30 kilometers away named [INAUDIBLE], also a Czech settlement.",
      "word_count": 26
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "He says, you go work for my son.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So sure enough, he drove me to there and I started to work for his son.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was a little town, [INAUDIBLE], [INAUDIBLE], they used to call it, a little Jewish town like ours.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "One day I was plowing and--",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "[CLEARS THROAT] --this was already late-- almost the fall.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They-- they had potatoes in that field and I was plowing.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And sometimes some potatoes are left in the field.",
      "word_count": 9
    }
  ],
