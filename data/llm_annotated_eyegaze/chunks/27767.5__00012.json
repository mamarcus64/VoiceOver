  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 33,
      "text": "Let him stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 34,
      "text": "I'll be able to help him.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 35,
      "text": "I'm still helping him.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 36,
      "text": "And he-- and he was working outside.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 37,
      "text": "He had to go outside everyday working.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 38,
      "text": "He said, look, I can't.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 39,
      "text": "He's sick.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 40,
      "text": "He can't go out working.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And if he's not going out, they will take him right away to the crematorium.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "So I said, how can you be that that selfish, not to let him go to Dachau?",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So I said to him, you know-- I mean-- it wasn't up to me, actually.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "But maybe-- he said, no, no, he has to go.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And so he sent him there to Dachau.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And that was really unbelievable in the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "After three days, we had-- we had a man with a wagon, one guy from Auschwitz, a wagon, horse wagon.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "He took every second day, the deads, from our camp to Dachau, to the crematorium.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "He took 30, 40 deads, 50 deads, whatever it was, every--",
      "word_count": 11
    }
  ],
