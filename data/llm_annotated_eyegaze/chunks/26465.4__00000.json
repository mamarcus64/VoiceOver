{
  "stem": "26465.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It was in February, towards the end of February in 1943.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Beg your pardon?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was in Augsburg at Hans Dieter's camp.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And there was a bombardment.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We run to the shelter.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "The shelter was outside of our fence.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And we were always driven there, taken there, by the guards.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Because they-- I believe the factory wanted their people to be safe.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And the bomb had struck near the-- at the other end of the bunker.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And there was panic, and panic ensued.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Everybody was running everywhere, to all sides.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Even the guards they didn't watch-- watch us anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So I started running.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I was running, running into the fields.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "There were fields nearby because we were living-- the factory was at the outskirts of the-- of the town.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I hid, finally under the bushes and like a scared rabbit, thinking, what next?",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And somebody-- on the other side of the bushes, somebody crawled in as well.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And I thought it was some animal or something.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And then-- and then it was a-- a friend from-- from the camp who decided to call my name.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "She recognized me.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And we were thinking both aloud, what are we going to do?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "So we decided to run off.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And we didn't know which way or where because a map was not in our-- our fortune.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "So we just went into the fields.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And we were-- we've noticed there-- there was a highway.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And we went on that highway.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And we were going-- marching all through the night.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And looking sometimes to the-- to the-- back towards the town, which was burning.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "You could see the flames here and there.",
      "word_count": 8
    }
  ],
