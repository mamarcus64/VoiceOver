{
  "stem": "748.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In the lining, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "In the-- [MOVES HAND ON ARM].",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In the sleeves.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And I don't know from where the transport came there, but there must be a very rich people-- diamonds, American gold, money.",
      "word_count": 22
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I opened it once, a [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Then, there started to-- like beads fell out.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I says, what-- I says, Yoli, what we will do with this?",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "If they catch us, they kill us all.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "She says, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "There is French men working, private.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And they will-- they will sell us food for this.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And this while like this.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "We went into a city and where the French men was working.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And they ask us, have you some gold?",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Some diamond jewelry?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "And Yoli says, yes, I have some.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "What would you like for this?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "She says bread, bread, or something to eat.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "We are three sisters here, and we would like survive.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "And it changed, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "Then, we went to work there, night shift.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "The-- the French men, were they just-- did they-- were they free individuals?",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "Or were they also prisoners?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "They wasn't free, but not prisoners.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they became food from the house-- from the home.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Their families sent.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Or maybe Red Cross sent them.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "But they sent them very nice food-- salami, and meat roasted, and bread, white bread.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "This what keep us a little bit, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And we-- they took us for a couple weeks, because we wasn't long there.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "[CHUCKLES] They went straight to the crematorium.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Straight.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we was sitting-- they was told something, then we repair.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They give us a little bit thread and needle.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And not-- not long, we was.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I think about three weeks, or four weeks, that this was all.",
      "word_count": 12
    }
  ],
