{
  "stem": "21817.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 46,
      "text": "They didn't care if somebody wants to go to over on the other side to the Soviet Union.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 47,
      "text": "And they, they took us over there.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 48,
      "text": "There was a woman.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 49,
      "text": "She spoke to us.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 50,
      "text": "I think she was some kind of military order integration.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 51,
      "text": "No, she was in-- the woman talked to my father.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 52,
      "text": "But he couldn't understand, so I answered for him.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 53,
      "text": "And she was surprised that I understand what she's saying.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 54,
      "text": "And they told her, go straight ahead.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 55,
      "text": "And you get to the city and you go to City Hall.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 56,
      "text": "And we arrived at Bialystok, in the city-- in the of Bialystok.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 57,
      "text": "And that started off almost like a chapter in our life.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 58,
      "text": "We never saw my mother again, or my sisters, or anybody else, or uncles or anybody else.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Bialystok.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Beginning, they didn't do it.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "But when we are over there, they didn't have any yellow stars yet.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was not-- we didn't know about it.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The local population used to point out, this is a Juden.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He lives over here.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "But they did not bother us the first few weeks in 1939.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "School was finished.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I never went to school back or my sisters went to school or [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "That was-- it was closed, period.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was taken over by the government.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Either they had-- they had some kind of people over there, but no kids went to school.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "All kids.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Now, the other schools, I don't know what happens because I never went over there.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But our school where I used to go was closed and nobody would dare even to go over there because we always saw German, German soldiers.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes I'll hear them.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes they just, they just walk away.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They don't pay any attention.",
      "word_count": 5
    }
  ],
