    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was very nice city.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It was a big-- not a very big one, smaller from-- from Rowne.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Only it was a manufacture for wood.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "It's lots of people.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "What I remember, I just remember my family.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "We were-- I had a father and a mother.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "My father was-- his name was Yacov.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "My mother's name was Hannah.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I had a grandmother, Laiya.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And my grandfather was Shai.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And we were five children when we left the city.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Then my mother thought we were going to return back.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "My grandparents didn't want to leave the house.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And we thought we were going to leave just for one week, and we will come back.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "Then she left my oldest brother-- his name was [?",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "Label-- ?] to look after the parents.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "We were walking to Kiev.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "When we came there, we couldn't return back.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "The German was already in our city.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "And my brother went-- thanks to that, what my brother went catching fish.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "He returned back.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "They told him, don't come.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "They took your grandparents.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "And that's was a place which would football-- what they used to play football.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "They used to take-- they took all the people what left.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "And they-- the [? bank ?] was making the [? board, ?] the holes.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "And a woman was alive, buried them alive.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "And then they killed the man.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "My brother saw that from a tree.",
      "word_count": 7
    },
    {
