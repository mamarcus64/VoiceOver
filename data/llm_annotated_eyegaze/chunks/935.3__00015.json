  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And these two girls had made arrangements with a big organization to leave the next morning to be brought with one guy over the border to Belgium, and somebody else then from Belgium to Switzerland.",
      "word_count": 35
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And they told me exactly how, where, what.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They had heard about it from friends of theirs who had left that way, and it was very safe and very good.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Cost 2,000 guilders, which was a fortune then.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And you were told to bring, of course, all your jewelry, because you needed something to barter with to change.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And money you could possibly bring.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Only a little suitcase.",
      "word_count": 4
    }
  ],
