{
  "stem": "3848.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And he said there was, yes, there's one guy comes by, his name is Gedale Tennenbojm.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He said, [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Gedale ?] Tennenbojm?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "That's my sister's son, where is he?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, Tashkent is one of the biggest cities in Asia, in Uzbekistan.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He says, I don't know, but I know that he works someplace.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He went to the Bureau, to the address named Bureau they called it in Tashkent.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He asked for my name, I was registered, and sure enough, he found my name where I worked.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And he showed up in this factory in the daytime.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I wasn't there in the daytime.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I worked nights.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "In the daytime, I used to go around looking for relatives, looking to search for some-- some.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Well, lucky enough, this day I came back to the place that I used to sleep.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And the caretaker said to me that two of your brothers are looking for you.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They were in Russian uniforms, soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I said, I had no brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "I was the oldest one.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "So I-- I wouldn't have brothers that would be in the Russian army.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And they said-- she says to me, that they are going to where you work.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "Well, I rushed to the place.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And from afar I saw two soldiers sitting.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't recognize them.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And one of them was my uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "Naturally he was pale and full of wounds.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "He didn't eat for three days traveling.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And right away, I took him into the restaurant over there.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "I had some coupons left, because you had to show them, and the both of them, he was a-- the other one was a friend of his who was also going to the Polish army.",
      "word_count": 35
    }
  ],
