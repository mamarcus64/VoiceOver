{
  "stem": "7938.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "But from a visual point of view, the film will show really the atrocities which would happen-- which happened at that time.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Do you have an idea, more or less, how many thousands that they took from Krakow to Plaszow on that first liquidation date?",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Any figures or anything, more or less?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "They-- I-- I have to say something before.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "After the first Belzec liquidation-- after the first Belzec liquidation, first transport to Belzec, the ghetto was made smaller because they sent out so many people.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So they cut the ghetto in half.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And we have to move, I with my sister, from the [?",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Rinkafka ?] Street, we had to move into-- into a different place.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "So we moved in one apartment, which had two rooms and a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And we were a part of the kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "We brought our furniture from there, our two cabinets, and we put them around, and we were in the kitchen.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And my wife and-- with her mother and her brother were in the last room, which was the room was also divided in half.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And another couple was in another half.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And the same was in the middle room.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No, everybody-- everybody had food for himself.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We got some food.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We received some food, and-- and-- in-- as long as we were in ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "In camp, of course, in camp Plaszow, we had-- we had-- we had rations.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "There was no other waves.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "There was only one wave.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "This is all what came in the first day.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "The rest, everything was sent out of Krakow, or-- or they were killed or they were sent out.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't know which camp.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "They never said which camps.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Maybe later people will know, but we didn't know anything.",
      "word_count": 10
    }
  ],
