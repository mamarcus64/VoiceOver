{
  "stem": "27443.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 59,
      "text": "And I joined the group, and I played with my husband on the stage.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 60,
      "text": "We went from one displaced person camp to the other, entertaining displaced person people like us, we entertained them.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 61,
      "text": "And my husband from the beginning, he even entertained the American troops.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 62,
      "text": "Because he was liberated by the Americans.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 63,
      "text": "He was liberated from Auschwitz to Mauthausen.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 64,
      "text": "And he was liberated.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 65,
      "text": "Because he went to a krankenhaus.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 66,
      "text": "He had typhoid right after he was liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 67,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 68,
      "text": "He was liberated from a krankenhaus in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Krankenhaus is a hospital in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And then he arrived to Italy.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I met him in the dramatic group.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And we kept together with the dramatic group.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And Sol and I would formed a kibbutz aliyah.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And from the beginning, they gave us rations of food.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And I, being that I was brought up in a kosher home, I longed to have a kosher kibbutz.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And I went to Rome, with Sol.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We went to the UNRRA.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And we worked on it they should give us dry products, and we will be in charge.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And I will cook.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "We were 120 youngsters, boys and girls, and formed a beautiful kibbutz aliyah.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And we made a kosher kibbutz.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Came Friday, I had to pluck the chickens, came a shohet from Rome.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And I used to pluck the chicken and make kosher, and used to cook for Shabbat, and I churned and bake and cook.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And we had a kosher kibbutz.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And Friday night my husband was in charge for all the Shabbats.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "I wasn't even married then.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "But I lit candles every Friday night in memory of my parents.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Because a lot of kids asked me, you have no right to light candles, because you are not married.",
      "word_count": 19
    }
  ],
