{
  "stem": "11552.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And the mother says, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "We are going to Daddy.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And the little girl jumped up.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And she was saying, we are going to Daddy.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "We are going to Daddy.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "The following morning, when they pushed us out, the mother was holding the baby.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And she was walking in the front, and I was holding the little girl's hand.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "In the other hand, she was holding her doll.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Somebody was shot in back of us, and we were pushed forward.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "The little girl dropped the doll.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "And one of the SS men-- we were walking on the-- one of the SS men came up, picked up the doll, handed it to the little girl.",
      "word_count": 28
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "She smiled at him.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "And then he took out his gun and shot her face away.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "And I picked the little--",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "--in front of me.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And I picked the little girl, and I carried her in my arms.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't just leave her there.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And I carried her to the grave.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Her mother never knew what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "She was in front of us.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Because you know, when you walk, a lot of people pushing you.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And then I brought her to the grave with me.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I want you to know something very important-- extremely important.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Because we are--",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Ah, OK.",
      "word_count": 2
    }
  ],
