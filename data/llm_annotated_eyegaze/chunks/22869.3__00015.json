  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "I would say that, in general, we probably had it a little bit better than the-- than the-- than the rest of the guys who had to go out in the fields and who were deprived of all kinds of food and so forth.",
      "word_count": 44
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "Because it helped us a lot that-- that I remember how many months we were there under this dry, what they call-- teaching in the building.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "It gave us a lot of protection from weather and from rain and from so forth.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "And you had quasi-decent kind of food, if you can say so, in a concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "But it gave us a new hope that maybe someday, who knows, you might see the daylights again out of this place.",
      "word_count": 22
    }
  ],
