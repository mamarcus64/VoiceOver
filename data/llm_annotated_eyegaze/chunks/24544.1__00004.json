  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Without any conscience, they stealing together because they can't carry that in a basket or in their pocket. six, seven people and wagon with horse ridden wagon.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But nobody knows anything.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And they making their new houses' steps from it.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I am wondering, and that's the reason I would like to go again, because my grandparents from my mother's side, they were well doing people, and they have two beautiful, tall, real marble tombs.",
      "word_count": 34
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "My great grandfather tombs was already stolen when I was there four years ago.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "But I am wondering maybe I am afraid to know it was taken.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It is certain kind, hard cement, mixed something.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They were poor people, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They didn't-- maybe this time they didn't come any marble from Italy.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So-- And all Jewish, everything gone.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "So when I am going to visit my great-grandparents in my village, I mean, the next village, I'm just standing with one stone, because nobody, my brother and me, that's it.",
      "word_count": 31
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Finished.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I'm just standing with one tombs and say the prayer because nobody visiting them anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "It's a very sad.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS] So.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "My mother's family was a very-- they were like called village, noble family, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It's a good character, well-doing people.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And my grandfather was gabbai, which means president in the shul.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And my uncle was a very special man.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "His schooling, or my mother's schooling, you know, she went in 1914, walking every single day five kilometer in the city and five kilometer to coming home because she went high school.",
      "word_count": 32
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And that was--",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Every single day, 10 months a year.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't a Jewish school.",
      "word_count": 5
    }
