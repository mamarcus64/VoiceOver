{
  "stem": "25912.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BEEP]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Barbara Marlow.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "M-A-R-L-O-W.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born Barbara Berta Hagina Bregman.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "B-R-E-G-M-A-N.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born on Sunday, September 21st, 1930.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I am now age 66.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Warsaw, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was the younger of two children.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My brother, George, was eight years older than myself.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And when I was born, everybody was delighted to have a little girl in the family again, as my grandparents had one daughter who died at the age of a year of meningitis.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Afterwards, they had two sons.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And they were very happy to have a little girl in the family.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "My father, Leon, was working in the petroleum industry.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "He had his own company, which was trading with various companies, including one in England.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "He had graduated in law, but he never practiced as a lawyer.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "We had a comfortable, middle class life.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "We lived in the center of Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 5 SECONDS] My-- we were a close family.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "I really didn't know my maternal grandfather, who died when my mother was very young.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Her mother was very elderly, as she had a family of five children, of whom my mother was the youngest.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And her eldest sister already had children of my mother's age by the time she arrived.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "For this reason, I was much closer to my father's family.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "My grandparents lived not far from us, also in the center of Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "My grandfather was a neurologist at the Jewish hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "He was head of department, and one of the very known-- well-known Polish neurologist who published a lot in the international medical press, in France, in Germany, as well as in Poland.",
      "word_count": 32
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] I also knew my great-grandfather, Sebastian Bregman, who died in 1939.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "He was very involved in social work.",
      "word_count": 7
    }
  ],
