  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 15,
      "text": "And this was the contract, that I have to stay with him, to go with him, to be like a wife to him.",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And it let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He didn't touch me.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He didn't He said, when?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I say, OK, so come.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "So it took about two, three months.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And I saw that all the people, they're coming, they're coming young, beautiful girls.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "Always they were coming to him with everything.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "With everything.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "There is-- I have friends there in the partisan.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And they was telling me, Sonia, you know, he was with her, there and there.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "They were telling me.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "Now I had a friend, [NON-ENGLISH], [NON-ENGLISH], my friends from school.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "She was telling me, are you [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "You know what you're doing?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "I said, what I'm doing?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "[NON-ENGLISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "I said-- Meaning what?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "That he went with this-and-this in a hooter on a farm.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I said, he was home.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He came about 11 o'clock.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So till 11 o'clock, he did whatever he needed.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And I begin to be very jealous.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Listen to me.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I didn't fall in love with him.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I was very jealous, because everybody likes him.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And I couldn't fall in love with him.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "I was afraid of him.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "But my parents had everything.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "They had the bread and butter and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I had everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They were calling for work.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Tuvia was calling all the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "You know what's [NON-ENGLISH]?",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "All the girls.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Go to work.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Go do something.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And I never went to work, because I didn't feel that I am a [NON-ENGLISH], that I am a [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], this was his silly language, OK?",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "This was his language.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Loose.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Loose.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
