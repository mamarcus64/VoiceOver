{
  "stem": "17372.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 334.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In Fremantle-- we stopped Fremantle.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But I came to Melbourne with the boat.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And from that time, I didn't-- I-- my brother-in-law bought a house in Glen Huntly Road in Caulfield, quite a big house.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "We moved together.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "At that time, we weren't allowed to bring any money.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I had couple thousand of dollars when I came to Australia.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So I got idea.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I had a half of bread-- rye bread.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I cut off a slice and dig out the middle.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I put the money in, put the slice back with toothpicks.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And I smuggled that money here.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "It was very handy.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "We gave deposit on this house.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And we paid it off.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] It was quite a big house, big garden, back garden, front garden.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "We weren't used to such a big gardens.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I didn't have a car, of course, then.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And never forget this-- the first year in Australia, I play some Australian party.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "I play double bass and accordion.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "I didn't have a car.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "One Australian offer himself to give me a lift.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "It took me half an hour to put the big bass into car, you know, across.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "It was-- it was a long instrument-- put the accordion.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "He was a bit drunk.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "He's driving about [PAUSES FOR 3 SECONDS] half a kilometer.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "He said, get out.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "I haven't got petrol.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "He throw me out of middle of nowhere.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I couldn't hardly speak English.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "Now, with the accordion and bass, look for telephone book-- booth.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "If I got telephone booth, I have to have small change for telephone.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "If I have small change for telephone, I have to speak English.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "If I speak English, have to say to contacts you where, where I am at night.",
      "word_count": 16
    }
  ],
