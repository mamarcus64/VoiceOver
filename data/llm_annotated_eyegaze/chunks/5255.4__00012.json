  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And I went to the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And the doctor pronounced me fit-- nothing wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "It was a very lucky occasion for me to know.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And then I went to the Jewish organization that organized transportation to Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And their objective was to get all the Jewish boys, and girls, and families that came through Czechoslovakia from Poland and Russia to Germany.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So from Germany, they should go register-- either go to Israel-- Palestine at that time-- or America or wherever.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "At least they'll be out of Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So the Joint and the highest whoever was there worked with all the Jewish survivors to get out of Poland as fast as they can.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Because it was a bad place to be after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It's worse.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was more dangerous to be in Poland than in Germany.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "In Germany, they organized displaced person camps.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "In Poland, they tried to kill you.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Jewish people in Poland were in danger.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "So many Jewish people in Poland joined the police and various communist organizations in order to be safe-- very dangerous life.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was a different time.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Right now I am telling you that the way we completed the exit out of Poland, back to Germany, through Czechoslovakia.",
      "word_count": 21
    }
  ],
