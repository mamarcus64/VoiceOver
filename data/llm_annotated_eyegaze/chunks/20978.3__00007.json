{
  "stem": "20978.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And there was a doctor, a Russian officer, a Jew that spoke Yiddish.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "So he came in, you know, to look at her.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And he gave me a handful of cotton, and put it on the wound, you know, to slow down the bleeding.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "He wouldn't do any more.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "We stayed-- that that night we stayed in that house.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "The Russians came.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "I had to hide my sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "Because anything that moved, they raped.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "They tried to attack my mother in bed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "I had to show her to them, that she's shot.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "She's bleeding.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "And finally--",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Russian soldiers, animals.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Finally, daylight came.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I went outside.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I said to my sisters, we've got to get out of here.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We cannot stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "First of all, we were afraid the people may come back, you know, the people that owned the place.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I found a stray horse, and I caught him.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I hitched him into-- into a wagon I found in a farm.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And I filled it up with hay and lay my mother in it.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And we traveled like that for [SOBBING] three days, [PAUSES FOR 4 SECONDS] three days and nights, through hell, through mud.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 7 SECONDS] She was hoping that by Friday she can light candles for the first time.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 8 SECONDS] In the midst of traveling, we met up with more Russians.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "I had a better horse than they had.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "They took it from me, and they gave me their sick horse.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "I had to dress up my two sisters like old ladies, so they don't bother-- they don't bother them.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 12 SECONDS] We couldn't get no medication, or anybody to help us.",
      "word_count": 14
    }
  ],
