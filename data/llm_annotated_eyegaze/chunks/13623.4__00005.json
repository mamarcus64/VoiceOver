  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] They had out houses, where-- the prisoners had out houses.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "There was no facilities in our-- in our barracks.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And they would use that.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "The kapo that was our kapo at that time was a-- a German who was-- who-- he was in for-- for-- he was a criminal.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We could see on his-- on his collar.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He-- he was already in the camps at that point, at least, he told us, about six or seven years at that point already.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he was a very strict man.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But he was, compared to other kapos, treating other prisoners, he-- he didn't treat us too bad.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We worked like this for some time.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "When we used to get fed in the morning, we used to get a-- a third of the loaf of bread.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "As I say, the bread was always the size of a brick.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "The team used to get-- the team that worked on the same-- carrying the same box was-- got to be close, like partners.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Most of us that got the bread in the morning, if you ate it up right away, you didn't have anything else for the rest of the day.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So we would split-- the team, we would split one of-- one of our pieces of bread in the morning.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And we would keep one of our pieces of bread for later on when we got hungry during the day.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 5 SECONDS] There were people that were heavy smokers.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And they were looking for cigarettes.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And some other [? were ?] tobacco or people rolled their own, I don't know how they got it, but some people gave their bread away so they could have-- so they can buy a cigarette or two.",
      "word_count": 38
    }
  ],
