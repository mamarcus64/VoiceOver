{
  "stem": "17001.6",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "So I put the bread between my leg, and through my pocket I was holding the bread.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "So I went over to the [GERMAN], yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Before I couldn't think of the name of it.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I told her in German-- I learned that my German-- that I have to go to the bathroom.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "So she gave me a push, so I went.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "When I went into the barrack, I told my sister, hold the bread.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Maybe I could get another one.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "So she put it under her dress, and she was sitting on top of the bed.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So I couldn't get another bread because by that time, we pushed the truck out from the mud and went away.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "There was one occasion when they-- meantime, they selected my sister Elizabeth and my cousin, they were working inside in the-- in the lager.",
      "word_count": 24
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And they were doing small little spinning and small-- like a battery thickness.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And they were putting on little wires like-- like a thread.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They were doing that.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Because they selected all the girls who had fine fingers.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "The only thing is they had two groups over there.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "One was working daytime.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "One was working nighttime.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And my sister Elizabeth and my cousin was selected to work at nighttime.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
