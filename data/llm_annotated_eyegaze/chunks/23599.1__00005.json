  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "There was still a German-- in-- in German I could have the degree.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We were in grade 12.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It would have been-- what age would I have been?",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I just can't give you any number.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "There was no German school anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It was only in Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know Polish enough to have the exams.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "That's why in there-- so that's why I got-- I had to go to-- to Prague and get exam.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And it helped me after because I had-- because I had [PAUSES FOR 4 SECONDS] the degree for the [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "You know what that is, [NON-ENGLISH]?",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "The compensation.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They were paying compensation to people who-- who lost their jobs, or you didn't-- [PAUSES FOR 3 SECONDS] they couldn't work or they don't have enough experiences so.",
      "word_count": 28
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "So that helped me.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "But that was after-- yeah--",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was away with some my relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I always went to my relatives.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "My mother had a big family, and there was some children my age, so I went with them.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was there-- I was-- of course, we were very close family.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And they used to always to come, the ones that who were out of town, they would come to us, and I knew them close, so-- [PAUSES FOR 4 SECONDS] it was-- it was nice.",
      "word_count": 35
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I went there for summer holidays, and they had girls in my age, so I had a good time, because I'm, myself, was alone, so.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "There was a difference between the Jews and the Gentiles.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Just like here, too, for the ones that are observing.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they are not observing.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "There was a difference.",
      "word_count": 4
    }
  ],
