{
  "stem": "443.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "He just arrived with another train, and we were supposed to leave with the same train.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "When he heard my voice, he kept on screaming my name.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And we kept on coming closer to each other, till we found each other.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "So instead to go away, I came back.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And he stayed with me in the camps, in-- in-- in-- in Bergen-Belsen.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "While he was in the camp, we decided to go back home, to go back to Romania.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "Through him, I found out that my older two brothers survived.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "They were in the Russian-- by the Russian prisoners.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "So after the war, the Russians let them go home.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "So I heard that two of my older brothers survived.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "When we were in Romania, we were in a city, I discovered that my oldest sister survived with her family.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "And we stayed in that city a few days.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "Then, I went back to my city where I was born.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "When I arrived to that city, I discovered I have three more sisters survived.",
      "word_count": 14
    }
  ],
