  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Well like I say, there was no use of going any further to school, so my father opened up a children's wares shop for me, which I carry on not too long, because the war broke out.",
      "word_count": 37
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And when it close to the war, when it broke out, you had to put on a [NON-ENGLISH] in the front of the door.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And it was Helena's Shop.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I had to change on [?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Haja's ?] Shop, to show that it is a Jewish store.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "For like approximately a year and a half.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We-- we had other place to live, too.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But this was the place the [INAUDIBLE] address.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "A year and a half before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "That means it would be like '37.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, as I say, we felt in the air the business become bad.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Because we felt in the air the old kind of meeting went on.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "The anti-Semitic meeting.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And you wasn't safe to walk in the street at night when it dark.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "My parents didn't allow us to go now, because you got beaten up.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And on account of beaten up, I'll tell you then a story what I witnessed.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And then I told my father that I'm leaving Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "That I didn't do anything wrong, [SOBS] that I should stay just because I was born Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I was walking on the street, and the Germans were already in Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And two young boys, maybe 19, 20 grabbed an Hassidic Jew to the hallway.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And I went to look.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And I start yelling at them in Yiddish.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I didn't imagine that they're going to do.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "So they shaved a half a face with the beard from that Hassidic Jew.",
      "word_count": 14
    }
  ],
