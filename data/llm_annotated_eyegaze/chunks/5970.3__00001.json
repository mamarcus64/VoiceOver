{
  "stem": "5970.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "Then there was another one who was in charge of the-- of the women SS.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "Her name was Weber.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And she was-- excuse me-- she was also in charge of me.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "She told me what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And there were another couple.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "She was an-- an older woman.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "She wasn't-- the others were all young.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "There were five of them living there in this house.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "And my job was to clean the whole house and do whatever they needed to be done.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "Now, I've never done this sort of work in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "I didn't know where to start, and I didn't know where to-- to end.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "And-- and they probably were never used to having servants in the house, either, because they demanded the most impossible jobs.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "For example, they had there, like, shaggy carpets there.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "They-- they were made out of natural wool, I think sheepskins or something like that.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "And they insisted they must be washed every day.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "I mean, every person who knows would know that this is-- this is nonsense.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "But they insisted it's got to be washed every day.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "And in every room there was a-- a-- a carpet.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "And then there was always an enormous dish of dirty dishes that I had to wash in the morning.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "And the first few mornings, I just thought, this is-- they're going to shoot me, because I'll never be able to do all this work.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "And water was not available from the tap.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "You had to take it from a well, which was in a-- in a-- in a-- in the courtyard there, and that was outside of the camp.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "It wasn't in the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "It was in a-- in the village, in Plaszow, where they requisitions the houses, and-- and they lived there.",
      "word_count": 19
    }
  ],
