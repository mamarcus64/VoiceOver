{
  "stem": "13213.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And then I had a brother Chaim.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "He was born in 1926.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Yakov was born in 1928.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And then myself-- I was born in 1930.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, there were no others.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was the youngest, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, after the extermination, my brother Yakov escaped, like I said before, from the-- practically near the killing.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He escaped into the village.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And he survived then.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Then my other two brothers, Chaim and Shabtai, were in a labor camp in a town of Kostopol, which was about 30 kilometers west from Stepan.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "These were all young Jewish men from the age of 16 and up were kept there in labor camps.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "During the night, when the extermination started in Kostopol of the labor camp, they all broke the barriers of the gates and some of the walls. 80% or 90% of them were all killed.",
      "word_count": 34
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "But my brother Shabtai and Chaim escaped into the village.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Into the village of Male Werbcze, where we came from, because they knew there the people would help us out.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So actually, all five of us survived for that time.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We were all into hiding with our neighbors and friends in the village of Male Werbcze and the area.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And nobody touched us.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "The people were really, I would say, good people.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The only surviving brother I have now is Yitshak, who lives in Israel with his family.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My brothers were killed.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "One, Shabtai, was killed in 19-- the end of 1942, beg-- I think it was February-- sorry-- 1943.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He was caught by some of the Ukrainian bandits and taken to the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And he was killed.",
      "word_count": 4
    }
  ],
