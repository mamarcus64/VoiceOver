{
  "stem": "19231.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 383.3,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "About five years probably.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Five years, till the war ended. 1945 when the war ended, we still-- we still worked.",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "A year later, I was still there, almost a year.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Till they came out with this that we can go home to Poland if we want to.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Not at all there, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "There were, but nobody observed anything.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "We had no holidays, no nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I-- I didn't even think about it.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Only thing I was thinking, you know, will I ever meet somebody that will be alive that I can tell them the stories that I went through with my father, with my mother?",
      "word_count": 33
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "You know, how it's sorry they should feel for me what I went through.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "That's what-- you know, and how are hungry we-- we were.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "That-- that was the only-- or, if we-- if sometime we will have enough to eat or if we will have enough bread.",
      "word_count": 23
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "Our mind was occupied only with this.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "We hear that.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "We hear that.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "It was a happy occasion.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Everybody was dancing and music.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "We had Russian band, I guess.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And it was a very happy occasion that the war ended.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I tell you how I start-- how I was.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "A short time before the war ended, I found a family that left with us on the same bus from Szczekocin.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "I found this family.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "They were not too far from Tashkent.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "They were in a smaller town.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And they were much-- there was a whole family.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "There children were mine age.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Their two daughters were mine age.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "They had a son also.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "And I went to them.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "And they took me, very nicely, in.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "And they felt so sorry for me.",
      "word_count": 7
    }
  ],
