{
  "stem": "25381.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "You know what that mean?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "That you-- that you take the corn and like it was in-- you know, in September already--",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The harvest.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So with this, I cut off all the way.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They were standing and looking how I'm doing so-- all the way.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I cut off this.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "This was hanging, the whole piece.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "So you see?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "See the marks over here.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I was working.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So then he says, I'm sorry.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I have to take you to the city because today they're killing, or tomorrow morning, they're killing already all the Jew.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It's going to be the slaughter from the ghettos.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "That's already the Germans made the-- the note.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Now, how long were you or your sisters in the ghetto?",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "How many months?",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Do you remember?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We were in the ghetto almost a year.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We were a year in the homes, and a year they took us in the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Of '42.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Of '42.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So while-- well, I have no choice.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So I was on the wagon and they were like a lot of, you know, people. were-- they were-- some of them were a shoemaker in the country, in the village.",
      "word_count": 31
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Some of them was a-- a tailor.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Some of them were a farmer.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "A lot of few Jewish were out of the ghetto and working there.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So he says to me, the farmer-- he was a very nice fellow-- he says to me, you know what, [NON-ENGLISH]?",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He spoke Ukrainish to me.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "He says, I'm in the front.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I'm holding the horses.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And you are in the back of the wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They're going to kill you.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Run away.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Jump off from the wagon and run in the forest, because they're going to-- they're going to kill you anyways.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Maybe you'll survive.",
      "word_count": 3
    }
  ],
