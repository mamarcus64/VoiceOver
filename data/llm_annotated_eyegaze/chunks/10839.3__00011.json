  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And he was-- when I was in the army with him, again, when I was in the magazine, I gave him a lot of clothing.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "He was like a sergeant already in the army.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I, I was-- I have to go back to the army.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "I told you already this story.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "Because I forgot to say that I was in a school, not a student.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "Only, I was a tailor there.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And when he came to me, I gave him the best already.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And he was sleeping with me.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "He was like my best friend.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "He was my best friend in the, in the, in the room what-- he was became a sergeant.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "And I, I was a tailor.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
