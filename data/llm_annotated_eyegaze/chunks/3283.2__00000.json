{
  "stem": "3283.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "So as I said, I moved to Brooklyn, Eastern Parkway, near the Botanical Gardens.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And then one day, I decided I'll go to the Democratic Club, 'cause in New York, in Manhattan, I was a member of the Democratic Club on Second Avenue and 8th Street.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So one evening, I took a walk.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I found the Democratic Club.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And McCooey was the-- the leader at that time, John McCooey.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And then I walk into the room.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And lo and behold, I see this Rebecca.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Of course, I didn't know her name then, but she looks familiar to me.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I said-- I walked over to her and I said, I saw you on the train.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "You were handing out sandwiches.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And she didn't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "We got to talking, and we found that we were both lawyers.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "She had been admitted to the bar, too.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And talking, and we had about the same cases.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "We handled criminal cases.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And so I walked her home.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "She lived on Union Street, a big stoop.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And I walked her home.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And her brother, her older brother, was a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "He lived there with his wife and the children.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And so then I made a date.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "I said, I'll call you and we'll go out sometime, which I did.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "We went to the movies from time to time.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And to make a long story short, one year later we got married.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We were going to elope.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But her brother found out, the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He said, you're going to elope?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "You may as well get married.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I'll arrange for the wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "So he went to the temple and he got the rabbi.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And on August 31st, 1932-- [PAUSES FOR 4 SECONDS] sorry.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Correction. 1933.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "August 31st 1933, we got married.",
      "word_count": 6
    }
  ],
