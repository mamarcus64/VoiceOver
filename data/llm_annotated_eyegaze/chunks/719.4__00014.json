{
  "stem": "719.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And right away, we became-- well, not right away, we had to make citizenship.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "But it was a beautiful start to go to Australia.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "1950, because most of my family was already in Israel, which was another story.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "When the state of Israel was declared, my aunt and uncle, they were Zionists for years, they were dreaming to die in Israel.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Unfortunately, after two or three years, they went back to Europe.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And then they ended up here, which I followed them.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "That's how I ended up coming to America, again.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So after 15 years-- so we moved in 1950-- OK, two young people who are starting new life.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Two years later, my older daughter was born, Dinah.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And then it wasn't that easy because of economy and all kinds of problems.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And my Dinah wasn't that healthy in the beginning.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have such a great pregnancy, so I wasn't rushing into having another child.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But then years go by, and you forget.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "You forget the scare, you forget the pain.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And so I tried to get pregnant again, which took eight years.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So Silvia is eight years younger than Dinah.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Both were born in Melbourne.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And while I was pregnant with her, my aunt and uncle moved from Israel back to Belgium, from Belgium to America.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Oh, actually, no, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She moved.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "She didn't go back to Belgium.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "She had a sister, which I never met.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I have cousins in Chicago, first cousins, American-born, because she had a sister.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "My father had sisters in Chicago, so they brought them, they brought my aunt and uncle.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "But Chicago was too hard for them to live.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "If they would stay in Chicago, we would have never leave Australia.",
      "word_count": 12
    }
  ],
