{
  "stem": "20616.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And then I went through a procession of studios that came and went.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "There was a baby boom that started with lots of babies, lots of competition, lots of fly by night studios.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And then I figured I knew enough about it to go out on my own.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "I was on my own for a while with very moderate success because I-- I couldn't do enough-- I couldn't make a good living on it.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So I figured I'd join an established studio.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And then I was with one studio for many, many years and then another studio for over 35 years and-- until my retirement.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I did fairly well.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I made a living, good living.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "What year did you married your wife?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We married in 1950.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 3 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "--we met accidentally on-- well, a friend of mine belonged to a youth group of a temple.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I was never much of a joiner of anything.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you know, we're going away for a weekend and would you like to come along?",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I said, oh, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I'm not into temples and-- oh, there's some nice, good-looking girls there.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "So my ears perked up a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I said, what are you going to do there?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we're going to have fun.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It's-- just going to go away.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It's a summer-- it's a winter resort in Allenville and we're meeting at the Hotel Dixie and we're gonna take a train or bus up there.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So I said, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He said, do me a favor, come along.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "You'll-- I'm sure you'll like it.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "He twisted my arm.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "OK, I'll go.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And we met at the Hotel Dixie.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "It was the meeting place.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "There's also a bus terminal.",
      "word_count": 5
    }
  ],
