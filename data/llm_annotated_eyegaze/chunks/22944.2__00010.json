{
  "stem": "22944.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "And there, these youngsters used to come, and used to train, or play organized games.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "And one incident, I went to play on the swing.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "And I saw this group of kids there.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "And I was dark, and black eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "I saw those kids, and I thought, I'm going to play with them.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "I was quite-- a very daring incident.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 36,
      "text": "I never told any member of my family about it.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 37,
      "text": "My God, my mother would have walloped me if she would have known what I'm doing.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 38,
      "text": "And I went to those kids.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 39,
      "text": "And I asked them-- they spoke.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 40,
      "text": "I spoke German as well.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 41,
      "text": "We spoke German at home.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 42,
      "text": "And we just start talking.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 43,
      "text": "And they ask me my name.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 44,
      "text": "And I said, my name is Eva Mannheimer.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 45,
      "text": "And it's a very Germanic name.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 46,
      "text": "And they sort of played with me.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 47,
      "text": "And they thought-- they just were puzzled that I got dark hair and black eyes.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So they said, how did you got black eyes?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I said, because I forgot to wash them.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So I going to go home, and I going to wash them.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And it struck me very strongly-- is that I went home, and I probably didn't tell exactly the incident to my mother.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But I asked my mother, can I have some soap?",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I started to put soap into my eyes. 'Cause I wanted to be like everybody else.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And my eyes become so inflamed.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I said, I must wash my eyes-- that I want to have blue eyes-- or something-- so very urgent.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And my mother said, no.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "You're never going to have blue eyes, because you've got the most beautiful black eyes.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "She was wonderful.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "She tried to sort of make me feel important, you know, as any mother can.",
      "word_count": 15
    }
  ],
