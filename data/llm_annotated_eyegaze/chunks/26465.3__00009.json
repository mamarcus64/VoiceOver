  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "While we, the Polish girls, were treated like terribly-- like we were treated in other camps.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And there were fights and insults flying across that table.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And we had a lot of strange happenings there that only probably my book will tell.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I was in Hans Deuter till 1944.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And 1944, in February, there was a huge bombardment of Augsburg.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We were taken-- each time there was a bombardment, we were taken to the bunkers, or shelters.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And during this bombardment, the shelter on one side was-- uh--",
      "word_count": 11
    }
  ],
