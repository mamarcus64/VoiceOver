{
  "stem": "740.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they pummel me up good.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And then they take me to the streetcar.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I'm just a little hootenanny.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I'm about five foot two.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I may weigh about 130, max.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And they put me in the corner of the streetcars and have two Mauser guns in my ribs.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Like I'm going to go someplace.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "The people in the streetcars were laughing.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] They take me to Gestapo headquarter on Avenue Louise.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And there I met Lieutenant Frank.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And all he does, first of all-- he picks me up by my jacket and lifts me up on a wall.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I turned pale.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I could feel it.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I peed in my pants.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "It was soaking.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And he says, [TSKS] you Jews are something, aren't you?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Goes to his desk.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Lets me down again.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Goes to his desk.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "Picks up my papers.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "He says, Louis Posener, Berlin, [INAUDIBLE] the whole shaboom.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "He's got it all in front of him.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "What am I going to tell him?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "He says, but you know something?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "You look pretty strong.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "We're going to put you in a labor camp.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "The Belgian authorities will register you someplace.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "It'll be good for you.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "You can work for the German government.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea what he's talking about.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I'd been put in a basement of the-- the Gestapo.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I stayed there two weeks, while other people come in.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Finally, the day comes-- this is like, the 24th. 24Th of June, 1942.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Early in the morning, we all assemble at the train station.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Other people come from other places.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "We're about 45 men out of Belgium.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Most of them-- matter of fact, all of them-- came from Antwerp.",
      "word_count": 12
    }
  ],
