{
  "stem": "8895.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "There was also a family with a mixed marriage.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "The-- the girl was five days older than I am, and we grew up together.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And when Hitler came, the mother took-- the husband was Jewish, a very distinguished gentleman.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "When Hitler came, the girl left the school.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "She had different friends, and it-- we were-- it was finished-- finished.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And the woman left her husband and went with a very prominent Nazi.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "I read about them in a book later on.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "She went-- that was her boyfriend.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "A horrible man, a horrible man!",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The father-- the girl-- the daughter stayed with her father.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I tried to find them through the Red Cross, and, as they said, if it's not a familial relation, I couldn't.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I know now-- the only thing, she can be alive.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "She is my age.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The father is-- was also much, much older.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And we grew up together.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "When she had a bath downstairs, I went to her.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] she'd be-- you know, we slept together and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Edith Herman.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Herman.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I went to different school.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "First I went to public school for-- till I was 10.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to a private school.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I went to a private school, then-- I don't-- I-- I went to two private school.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "One, maybe I didn't go to attend.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Maybe I-- I went from-- from 8 till 10 to one private school, and then from 10 to 12 to another private school.",
      "word_count": 23
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And this second private school was very good.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "It was a Catholic school.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "They were very much against Hitler.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And I remember when the children started to wear these little pins with the swastika, the headmistress went in-- in the yard and took it off and threw it away.",
      "word_count": 30
    }
  ],
