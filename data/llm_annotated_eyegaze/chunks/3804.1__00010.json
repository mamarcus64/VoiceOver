{
  "stem": "3804.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "So don't-- don't make it so-- don't try to show that you are my relative.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "First, you have to be a mensch, a human being, and right.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "You don't have to show me that you're a relative.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "These relatives haven't been, you know, in a way very near to us.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And-- and I told you, they want to use me.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "They want to use my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "It didn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And after two weeks, we left and we went, you know, down from the hill into the valley to live there.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So it didn't help.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Haifa.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Brick company.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And my mother went to work in the small, how say, sell all the kind of-- I don't how you say [NON-ENGLISH]/ It is a place that you can buy bread, butter, this, all these things.",
      "word_count": 36
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "A small-- a small, how do you call it, place that you can buy almost the small things when you need for home.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a market.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning, you know, you have a lot of fantasy when you studied the Bible.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "It was the Messiah and the big things when you come to Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "When I saw the ship coming near to the port, I said to my father, let's go back.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He said, why?",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see cars.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I didn't-- I see a donkey here, Arabs, all these kind of people.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'm not accustomed to it.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I would like to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And my father said, don't worry.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "You never know.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "He liked the Bible.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "You will see big things.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And how do you say, why do I see big things?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "I already see what I see and don't like it.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "Difficult, you know, for people, for children just asked to leave.",
      "word_count": 11
    }
  ],
