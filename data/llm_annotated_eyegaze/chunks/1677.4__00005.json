{
  "stem": "1677.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.8,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And the money-- the currency lost value.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And we had nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We had a war orphan pension after our father.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "An uncle, my mother's cousin, Josef Haas, who was in Dachau.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And he bitterly cried when he saw us without hair.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He didn't look much better.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "His wife died in his arms.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "He found her in Ramsberg.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And he died, only a few years ago, when he was 80.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I correspond-- he had Roman Catholic family, a son and a daughter, all very Catholic.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "He married a Catholic girl in second marriage, who died of leukemia.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "He-- and he brought up the children by himself.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And that is my only connection with Slovakia, that twice a year, I write her a rude letter about the Slovaks.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And she tells me how she saw and how she cried.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And I have nothing to say to her.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And my sister and I decided that this is no future for us.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And there was a possibility to come to Australia as a war orphan scheme.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In 1946, 19-- 1947.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "To [INAUDIBLE], to a next town, and I did my, my living with distinction.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They gave me [NON-ENGLISH SPEECH], the toughest translation you can have.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They made it so hard for me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And then the examining professor-- we do it all orally in Czechoslovakia-- and then, then for examining, professor said, how many Jews do you think have been deported?",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I said, six million from what I read in the papers.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He said, well, when I hear you translating here, I think seven million came out the other end of the chimney.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I-- we were so unwelcome, so unwelcome, so hated.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "People would meet me in Puchov in the street.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I say, good day.",
      "word_count": 5
    }
  ],
