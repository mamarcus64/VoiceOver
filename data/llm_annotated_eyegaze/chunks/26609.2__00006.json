{
  "stem": "26609.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And there at the back, because it was on a hill, you have to go down.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I don't know, the called it [? fosa ?], like a valley.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And through there, she ran quickly to the school and told the teacher what happened.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And the teacher said, expect me, and a few days later we will come up.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "One or two teachers, we will teach you, to finish even high school.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "We'll bring books.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "We'll teach you.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "So they did.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "My grandfather never found out, because he was only interested in-- in Hasidic life.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "He went out from the front, and sit all day or half a day in the synagogues, or whatever or with his sons, shochtin.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And they were around, near the synagogue, which was on the other side.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "He wasn't concerned.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "He didn't suspect anything.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Day by day, they came, the teachers.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "My mother told me the story.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "The teachers and taught her, with books, even-- blackboards, they brought.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And she wrote everything.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "She went up to [INAUDIBLE], because she wanted it so much.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "I still have seen later, after years, years after the war-- I was, I said, in the United States where I found out about my sister.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "There was living a-- a niece of sister-- of my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "She showed me the letters of my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "My mother was in contact with her, used to write her letters in Polish.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I came in.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "I met them there.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "She said, that's your mother's letters here, I still-- I keep them here.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "Beautiful.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "I don't speak such a Polish as my mother did.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I haven't got even a photo of my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I haven't got photos, not of my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, she wouldn't give it to me.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "No, she kept it.",
      "word_count": 4
    }
  ],
