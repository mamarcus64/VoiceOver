{
  "stem": "10644.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.0,
  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "We went-- but you see, the religious Jews would come right away and will take and give him a decent burial.",
      "word_count": 21
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "So we went, you know, to-- to the Rabbi of Vilna.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "And the Rabbi was Chaim Eizer Rodianski.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I had met him in his-- in his-- where he lived, where he was teaching.",
      "word_count": 15
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "I presume so.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "That is on the-- on [?",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "Villenska ?] Street, yeah, called [?",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "Villenska ?] Street.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "The main rabbi, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "He was the main rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "We came and asked him, Rabbi, help us, Jewish students to get-- to get a cadaver.",
      "word_count": 16
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "He said, please, no, you must understand-- he was very human-- you must understand me.",
      "word_count": 15
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Said, I would like to help you as much as possible.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "But this is a Jewish law that if a Jew died, within 24 hours, he has to be interred, [PAUSES FOR 3 SECONDS] and I cannot help you.",
      "word_count": 28
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "We came in-- oh, three-- three, from the 20-something Jew-- Jews, we-- I was the leading.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Kapinski ?] was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "And-- and-- I forgot-- from a very famous Jewish-- Jewish-- from a Jewish family very famous in Vilna, she was the third one.",
      "word_count": 23
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "I-- maybe I recall her name.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "You know, it is-- it is just-- [INTERPOSING VOICES]",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "And then, after we finished our conversation, we said, rabbi, thank you very much.",
      "word_count": 14
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "He turned to us [INAUDIBLE] stretched the hand, shake-- shook hands with me, shook hands with doctor-- doctor-- with-- at that time, [?",
      "word_count": 23
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Tom ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Kapinski, ?] and they-- and the other--",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "She stretches her hand, and he makes 180 degree turn at the side.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And [?",
      "word_count": 2
    }
  ],
