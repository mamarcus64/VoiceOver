  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And there, we joined another Jewish school.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish area-- we didn't live in such a Jewish area, but there was sort of a small street.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "The Jewish area was called the Vatican, strange enough.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "There was a Jewish district where the Synagogue, the yeshiva was, and the butcher and slaughterhouses.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And that was-- Nitra was a very active Jewish community.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "It had a reputation for a very good yeshiva.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I think so.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "My mother had there three sisters [PAUSES FOR 3 SECONDS] and a brother.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I think her other brother may have been living in another town, [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And another sister of my mother was in England.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "She was assistant in hospital here, and she came earlier out.",
      "word_count": 11
    }
  ],
