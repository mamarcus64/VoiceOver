{
  "stem": "9471.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And how long he was living, I don't have any idea.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I don't have any idea about that.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I don't have any idea.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And I-- I remember when, from Kruscica, when they took us to Zagreb, we were all praying, maybe they are taking us-- because they were-- we were told that the men sat in Jasenovac.",
      "word_count": 34
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Then we were told.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And we said, oh, thank god, we're going to go to Jasenovac.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "So we're going to be reunited.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "They didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "They took us in [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And like I said, I escaped.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I mean, they took me from the train, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And after baby died, I told you what happened, that I went from one, slept, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And how did I escape from Yugoslavia?",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "A friend of mine, she had some connection.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And he says they can give us papers, false paper.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "But we have to pay them.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So I had a beautiful bracelet, and I gave it to him.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And we get our paper and-- for both of us, because she didn't have any money.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "He was-- her father was a rabbi in Koprivnica.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "So we were like sister.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have-- you know, we were so close then.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And we came together to Crikvenica.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "It was on Adriatic Sea.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We were there, I don't know, a couple of months, till I told you what happened to me.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Who did?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "She's still living.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She's in Koprivnica now, and I'm all the time in touch with her.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Her name is Erna, Erna-- oh, what was-- Wolfenson, Erna Wolfenson.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Now, her name is Relege, because she remarried.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She married.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "She was a young girl then, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because that was-- nobody wanted to tell, you know?",
      "word_count": 9
    }
  ],
