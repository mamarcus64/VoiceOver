  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] So a good accent sometimes helps.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Not a proud time in my life.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "But then again, if it wasn't, there wouldn't be a life.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "We wouldn't be taping today.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I-- it left me with a-- [PAUSES FOR 3 SECONDS] well, whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I'm trying to bring this up.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I'm trying to be not only candid, but honest.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And that's not an easy thing to bring things like that up, because they are-- leave deep scars with you, and maybe deeper.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I mean, what the heck.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "This is, compared to all the other things, it wasn't such a terrible thing.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But to me, it was a traumatic thing.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And so anyway, I-- [PAUSES FOR 5 SECONDS] I don't know where I am now.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I'm sort of in this some period of time that I think I am now leaving Auschwitz, I presume.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "It's time to leave Auschwitz, as they say.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So this is the last tape?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I thought you had four tapes.",
      "word_count": 6
    }
  ],
