  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "He was-- at that time, we thought in Radzyn that he's the only rabbi in the whole world, because when his birthday was, there must have come thousands and thousands from England, France, and the United-- from all over the world.",
      "word_count": 41
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And they would set up tents because there was no hotels.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And even, as I remember, the president of Poland, Pilsudksi, came to-- to visit him.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "He was very, very famous.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "One coincident, I'm gonna say what happened in my house.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "We were sleeping.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "My bother came home about around maybe, I don't know, 10, 11 o'clock at night, because in there when it gets dark, you got to bed, because there was no electricity and so forth, whatever.",
      "word_count": 35
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And as my brother come home, I got up and I had to go outside to-- how do you say it?",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "To go to the bathroom.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Pee.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "To OK.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And as I got up, I fell down.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "When I fell down, so my brother started to scream that I passed out.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "So other-- the other families started to get up-- brothers and sister.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They all fell down.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So my brother right away knew it whats was goin' on.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "So he pulled us outside, and we ran into the Polish family, which is within 50 feet, 100 feet, and they all came out and they took us in, because we were already almost dying from the gas.",
      "word_count": 38
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "They were cooking with coal, and I guess they closed up.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And the gas, there was no exhaust, [INAUDIBLE] exhaust.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And we-- a miracle that he came home and he woke me up, that we are alive.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "OK.",
      "word_count": 1
    }
  ],
