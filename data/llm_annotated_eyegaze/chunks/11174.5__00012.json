{
  "stem": "11174.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And then I am from a rabbinical house and there were some [INAUDIBLE] from the [NON-ENGLISH] that heard I'm getting married.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They came to [? run. ?] It was a very-- it was touching too, but there was a-- a lot of people unexpected came.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Slowly.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Once I got a letter.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Still being in Shanghai, I got a letter from a couple of people who survived.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And one of them just called me on the telephone-- writing me that-- that they know that my-- my-- my parents got killed, my father and mother got killed.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "So I was in the house crying for a few weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And, you know, you talk to people.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "You see lists in the papers.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "My father-- I still don't know where and how he got killed.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Only me.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Uncles, aunts, you know, no.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "My grandfather had six children-- four sons and two daughters also.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "One daughter had about 11 children in [?",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Vokvill ?] where the ghetto was-- all killed out in one day.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "No one or two, but before that.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And one after the other taken like-- like-- like chickens.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "The older one, when he was about to [INAUDIBLE] started to [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I know you're going to kill me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "Don't forget you're going to have [INAUDIBLE], and they shot him-- everybody.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Everybody [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I came to New York right after-- I was eight days in-- in Philadelphia and then I came to New York.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I did so many things.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I can't begin to tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I was in the beginning selling vacuum cleaners door to door, I think.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Then I was-- oh, I was a-- I was a Hebrew teacher in Rockaway Beach.",
      "word_count": 15
    }
  ],
