{
  "stem": "5799.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And then I saw people meeting as with flowers.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I said, isn't it wonderful?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I got well as soon as the Statue of Liberty was there, and I felt the ground.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I came up.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Wonderful.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "They didn't need us.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They met Smetona, the president from, from Lithuania, the killer.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "The Lithuanians.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "Nobody met us, not nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "There wasn't a reporter, nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And I said, nobody knows about-- there was so many millions killed-- nobody knows about us?",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "What's going on?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And then I started-- it started out, why did you go like sheep?",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "I said, what kind of a sheep?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "What do you mean, we went to death?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "My husband wasn't locked up.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "What, are you any better?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "Why didn't you protest?",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "Jews were being killed.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "Why did you allow it?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "I mean, the questions-- from Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "And one of my aunts said to me-- may she rest in peace-- why did you come here for, from Russia?",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "Why didn't you build socialism there?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "I said, because I wanted to come someplace where it's free.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "And why don't you take your bank book and go and build socialism in Moscow now.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "Why do you sit here and tell me to stay there?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "That I heard too.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "But nobody gave us a penny, thank God.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Nobody can say that they helped us, thank God.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Whatever we have is ours.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She was in a dresser drawer.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have a crib.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was told that I cannot have any children.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So after I came from the hospital and I could not have any children, they said some kind of a story that I had to have tubes blown, this blown.",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I don't know what was blown, I became pregnant with my Anita without any blowing.",
      "word_count": 15
    }
  ],
