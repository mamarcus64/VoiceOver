{
  "stem": "24130.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "So she first sent an affidavit for my sister, my older sister.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "She was at that time 15 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And in no time then, she got a number and she-- the quota.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And she was a minor, so my father took her to Prague.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And the-- and from Prague, she-- she came to America.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And she was always very homesick.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "She used to write letters and-- And then my father tried-- got the papers to go to America and we were waiting for the quota, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "And he wrote-- I have the letter, because my sister kept the letter-- that he had-- she had the letter that my father begged her to go to Washington.",
      "word_count": 29
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "He should get the number, the quota, because he had-- he had a ticket for a boat.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "He had all the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 20,
      "text": "All he had to have is a number.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 21,
      "text": "They should make an exception because things are getting bad there.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 22,
      "text": "Well of course, they didn't make an exception.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 23,
      "text": "So my sister came here.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 24,
      "text": "And he-- we-- we wound up and my father didn't need a quota by the Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 25,
      "text": "He went into there he-- he was able to go.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 26,
      "text": "So-- so we came to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
