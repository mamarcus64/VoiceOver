{
  "stem": "27150.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Because you see that means, look if they had bought a tube of toothpaste or something, it was worth a fortune.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they gave us the old currency.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And we collected a few bob.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I was back-- in Bialystok, and Romek was not yet.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And you see then it came a requisition of the hotel by the Russian army.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And we went to our friends, sort of relatives of Lola.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And they said they can do nothing with accommodation.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "But if we go 15 kilometers from there, there is a small industrial township.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And they have a little house up there, and we went out to the little house.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Suprasl, S-U-P-R-A-S-L-I-E.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And you see that [NON-ENGLISH] had two wives.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My sister-in-law's brother went to [NON-ENGLISH] because she had a job in Warsaw with an agency of a cart factory.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And they got immediately a job there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And we got a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And we cooked a good dinner with a lot of fat, et cetera.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And we just had a fellow handyman who fixed us a stove with plenty of firewood.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "This is-- this was a little township.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "In Bialystok the place was in [NON-ENGLISH] Street but--",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Two days, three days, four days, I don't remember.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I was a king and I had two wives who cooks, and one they come back.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They went to the market and they didn't take Polish zloty.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Goodness sake, I had all the Polish zloty, which I collected in the North, you see.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I go to the station, to the bus station.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "There's no petrol.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "The bus is not going.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "So I set out by foot, 15 kilometers, took me maybe 3-4 hour walk.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "On the way, you see I went into a chemist's shop, who was our customer.",
      "word_count": 15
    }
  ],
