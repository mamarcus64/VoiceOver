{
  "stem": "6944.3",
  "chunk_idx": 17,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 61,
      "text": "And they were all ex-- they were all Rhodesians.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 62,
      "text": "Not ex.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 63,
      "text": "Rhodesians on holiday.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 64,
      "text": "And she entertained the lot.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 65,
      "text": "And there were young Spanish people.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 66,
      "text": "They started speaking Spanish with me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 67,
      "text": "It was a wonderful reception.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 68,
      "text": "What a lovely thing I had here.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 69,
      "text": "And eventually, the-- the-- the luncheon was over.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 70,
      "text": "And it wasn't a luncheon.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 71,
      "text": "It was a morning.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 72,
      "text": "And they went.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 73,
      "text": "And she gave her time to me, and then her husband arrived for lunch.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 74,
      "text": "And we're sitting there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 75,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 76,
      "text": "On-- in the letter, my husband said to me, when you come, do not divulge that we don't know each other.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 77,
      "text": "We don't know what can happen to us when we are married.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 78,
      "text": "We hope for the best, but say that we met once or twice.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 79,
      "text": "Because Jack had actually been-- during the time that I was there-- before Puterflam got-- met my father, Jack had actually been look-- been with-- with-- with the Puterflam family for a few weeks while he was in France.",
      "word_count": 39
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 80,
      "text": "But he had gone back and had come to Rhodesia at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 81,
      "text": "So it was like 18 months before this happened with me.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 82,
      "text": "And so the letter said not to divulge that we didn't know each other.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 83,
      "text": "That we had met.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 84,
      "text": "We had seen each other.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 85,
      "text": "So that stuck, actually, in my mind.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 86,
      "text": "I mustn't say that we didn't know each other.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 87,
      "text": "And then-- and then--",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Now, then Mrs.-- now, then, Mrs.-- Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Barnett said something.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You know who she's going to marry?",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "She's going to marry Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Pelham.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "He said, oh, who is this Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "Pelham?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, she says, you met him at cards.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You met him-- you know, the shorty like that.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I said, short like that?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I gave away the-- The secret.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The what?",
      "word_count": 2
    }
  ],
