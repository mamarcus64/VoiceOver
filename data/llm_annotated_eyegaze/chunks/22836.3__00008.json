  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was trying, to truth tell you, I putted in a penny, like a penny, copper.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "They was holding up a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Make it a little infected.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Keep it--",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "A little.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And they keep me another three months.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And then she sent me to [NON-ENGLISH] home.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "And finally, the war was finished.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And that was the end.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "That was the end.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "Then we went, like I told you, with the--",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Organized, like, what they call us?",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "That was-- that was not Haganah.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "It was-- they was-- was working, very hard working with that, very good working with that, too.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "A lot of people was gone.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Like Greeks-- Greeks, they sent us like Greeks.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "The Greeks was that time something the other side, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "The Greeks clothes with the berets, and Greeks.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "When the Russian come talk to us, we couldn't talk to them back Russian.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "We talk to them like we pray Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "They come to me, and they talk, I say [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "And they saying-- they saying-- I hear what they are saying because we know it.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "They saying, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I saw dummies.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Such dummies like the Greeks, he says, I never saw in my life.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "See, they talked to us.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And we asked them-- we answered them like they told us to do that, not to-- not to say a word Russian, because they can hold us up right away.",
      "word_count": 30
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And they say, we saw dummies, such dummies like the Greeks, you don't see it.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "I was praying to them.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "They talking to me, and I pray to them.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Like [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And they looking at me.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And they hollering me.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And I pray again to them.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Then they say, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "It was fun.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "They left us alone.",
      "word_count": 4
    }
  ],
