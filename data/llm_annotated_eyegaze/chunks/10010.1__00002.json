{
  "stem": "10010.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Still they-- they-- in order to probably to put themselves in the life of Poland and make a-- a living, they had to know Polish.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "They had to perfect this Polish more.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And-- and they wanted their children to advance and study, and therefore, they spoke to us Polish.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Amongst themselves, from time to time, they spoke Yiddish.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We had-- my mother comes from a family of eight-- four brothers and four sisters.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "One of the brothers, when he was very young, he ran away from the-- from Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He was a communist.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "He wanted, you know, a-- a better life for people.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And he had to run away.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And he landed in Argentina.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "As a matter of fact, I have a cousin, his son, who lives now in Israel, in Kibbutz Hakuk.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "His name is Simcha Wigotsky.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "My mother from home, her name was Wigotsky.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "Now, all the other brothers and sisters lived in Warsaw, and I met them.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And I still remember them.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "They were-- the names of her sister was Ida, then Esther-- [NON-ENGLISH], they called her-- then my mother was-- and-- I missed-- ah, and Manya, who was during the war, also with us.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Now if she has-- the brothers were-- the three brothers in Warsaw was Moshe, Meyer, and the last one I hardly even-- Smulik, I think.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Also, we had, from my mother's side, my grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "My grandmother's name was Freidle.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "She comes from [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And her maiden name was [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And she had a sister in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "Her name was Golda Amsterdamer-- married with children.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "During a certain time when probably my mother was about 18, she lived with this aunt, because it was very hard for my grandmother and grandfather to, you know, to raise eight children.",
      "word_count": 33
    }
  ],
