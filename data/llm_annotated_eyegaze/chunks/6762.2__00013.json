{
  "stem": "6762.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "You can go from one city to the other and be a new person there with a new pass-- a new paper and everything else.",
      "word_count": 25
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I was in the city.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And one-- another time it happens at-- I was in the movies.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "It was late in the evening.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "Later in the evening, we saw the picture-- in the open movie now.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "Not really had drive-in.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Over there is walk-in movies.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "You walk in.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "It's outside.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "You watch the movie.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "I was sitting with a guy right next to me.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "And he says-- we start talking.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "I'm from Europe, buh-buh-buh.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 13,
      "text": "Come over to my house.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 14,
      "text": "And we'll have some tea, have some-- And I, like was a schmendrick, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 15,
      "text": "I went with him.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 16,
      "text": "And, you know, the women have no right to coming in the room when you have a guest.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 17,
      "text": "And the man has a guest, the woman has no right.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 18,
      "text": "If she come in, she has to cover her face and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 19,
      "text": "You come in and give us the room.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 20,
      "text": "And he's starting to come up on me, and I just dumped everything, and I run like hell.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 21,
      "text": "I didn't know where I run, even.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 22,
      "text": "In the small streets, like you see in the Arab cities, a small street.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 23,
      "text": "And I just run away.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "What can I tell you?",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So many stories.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I don't know, really.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "You know, go with a mother-- next to your mother, and sitting next to her, and not even know she's dead.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know she was dead.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "We came there to the, by the hospital there.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And the guy came out-- the doctor-- and looked, says-- said, you guys, what's the matter with you?",
      "word_count": 18
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "She's dead, right here, over an hour, maybe two hours.",
      "word_count": 10
    }
  ],
