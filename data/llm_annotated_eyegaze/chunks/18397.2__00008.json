{
  "stem": "18397.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 142.1,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Where they-- they got a couple temples in one place, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "What they call it?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, he took us over there.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And he says, to me he says, you have got your friends.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "You go to them, and take their money or something.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So I was staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "There came out a boy, a young boy.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And do you know-- what was his name, the guy who was learning with me in the [NON-ENGLISH]?",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Grossman or-- anyway, nobody knew.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And this boy, he says, I know it where it is.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "He took me over there.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I see a beautiful house, and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I knock on the door.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "Where is my friend, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "He's not here.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Where is he?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "He's in the army.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "But they send him in another place, you know, down.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And me they send up.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And the-- the people there-- I would-- like-- look like, you know, I didn't wash myself for who knows how long?",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "Anyway, they gave me a place to sleep over.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "And-- the next day, they wanted to get rid of me.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "Because the guy, he wasn't there.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "And who wants to have a guy like-- so then they knew a friend, another friend of mine from Vilna.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "So they sent over the maid.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "She went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And she brought a guy, the other guy.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "He recognized me right away.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "So he took me over there.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "He didn't-- he-- I don't know what he did.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "He didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "Anyway, he didn't invite me.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "I say, I want to go to Vilna.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "And they had the-- the street-- they burn lights.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "You know, they were working, like in a regular place.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "But he didn't have no money to give me.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 31,
      "text": "I-- I didn't have a penny.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 32,
      "text": "So we went out.",
      "word_count": 4
    }
  ],
