{
  "stem": "12666.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Children were afraid to get into an ambulance, because we ran out of transportation, and we thought, well, we will transport them-- because Hitler kidnapped children who had blue eyes and were blond.",
      "word_count": 33
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And the mothers and the families were looking for those children, from Yugoslavia, from Romania, from other parts.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And we wanted to transport them in those ambulances, and they refused.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They start crying, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then we found out that the Germans had a special gas chamber installed in those ambulances and killing children.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So no wonder they were afraid to get in the ambulance.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So one trial that was stopped in the middle was the trial against Krupp, Krupp von Bohlen, who was a-- a big industrialist in Germany, and he was using slave labor.",
      "word_count": 31
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And the SS was kidnapping young people in occupied territories and selling them to the industrialists as slaves to work in their factories.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And there were two girls that were from the Ukraine.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And these two girls were kidnapped when they were 14.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And they didn't even finish school, and so they spoke only the Ukrainian dialect.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I was pulled from my work, because I know the Ukrainian dialect, to interpret during the court proceedings.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And you have the photograph.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And it was awful under what conditions they were.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They were living in a barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "The only food that they had was soup made out of potato peels.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And they had to work in those steel factories where it's awfully hot.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And one girl was pregnant, and she passed out because of that heat.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "She was not given any medical assistance.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "She gave birth right there and died.",
      "word_count": 7
    }
  ],
