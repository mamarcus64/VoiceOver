  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I thought, maybe this will help me.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "He-- now, I read that they wanted to convert for Jesus Christ, people.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Then he-- Do you remember the name of this gentleman that took you in?",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Ah, the name?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "One moment-- Homa-- Homa-- Homak-- Homa-- but the second name, I don't remember.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I stood there-- I didn't stay.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I was one night.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "One moment.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I was one night.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And then came a boy, older to him, and he gave him a glass milk with bread.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And he told, we should go in the shire to-- to sleep.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Then we already-- no, there was still my mother and brother, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And he was--",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "--and he was-- he was our [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I-- I woke up in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I don't have his gun.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I don't have the--",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "--no.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "This, don't-- don't write this.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Don't write this.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I lost this.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And when I lost the gold, then start-- you know, when I had the gold, it was terrible.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Every time something happened to me, and they're looking for me to kill me.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "When I think, my God, what I'll I do?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "I lost the gold and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And if I would sell somebody a piece of gold, they would kill me, because I have gold.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And then I-- I-- he came in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "I was still there.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "He called us in.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And he say, look.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "Three, I cannot hold.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "I can only take you in the meantime.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And I can.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "And my mother and brother went.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "My mother I found-- we-- we met like couple time-- but after-- after the-- when the-- the-- after the liberation.",
      "word_count": 20
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "The Russian.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In a-- in a village.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Dolhoszyje.",
      "word_count": 1
    }
  ],
