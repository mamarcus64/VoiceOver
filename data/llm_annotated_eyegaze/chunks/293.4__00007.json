{
  "stem": "293.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "So I stay on the platform, put her in the corner, put a blanket over her, and myself with the bayonet in my hand.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We arrive in Budapest overnight.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And then friend was waiting.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed there till about September.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Then we decided, we found out that the Russian demand that everybody's going back to their country.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have anything to go to the country for.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I said, let's go back and see what we can do, maybe in Czechoslovakia.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We came to Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We stay a month in Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Then we went to [INAUDIBLE], Carlsbad and we stay in there because it was a beautiful resort, and was beautiful fall, you know?",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Then we found out that the Russian give another order that everybody has to register themselves and go back to their country.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So we went to register as a Czechoslovakian.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So they ask me where what I was born.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So I was skiing in the border of Hungary and Czechoslovakia in Eastern part of Carpathian-- Uzok a small town on the-- on the-- on the border in the mountains, that I was skiing there.",
      "word_count": 35
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Then the guy is asking me where you was born.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I said in Uzok.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You sure you're born in Uzok?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "You know, I don't speak Czech.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I speak Polish, trying right to convey to him as much I could in Czechoslovakian, you see?",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I said-- you sure?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I said, what do you mean sure?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "When I tell you I'm born in Uzok, I'm born in Uzok.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "How you got in the Uzok?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "You familiar with that?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "What do you mean I am familiar?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I was skiing there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "Sure I'm familiar.",
      "word_count": 3
    }
  ],
