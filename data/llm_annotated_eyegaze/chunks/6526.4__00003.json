{
  "stem": "6526.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Before I'm going to tell you the story, is when I was in Majdanek I was talking with my brother, when there comes a transport, we should push ourselves to go on a transport.",
      "word_count": 34
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "To say-- the slogan was, the bowl of water and soup and the piece of bread I'll get someplace else also.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So we pushed ourself to a transport.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He got on a transport first and went to a town called Skarzysko.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They were working for military supplies and different [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't make that transport.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I was-- then it came next time, I pushed myself and I came into Birkenau, to Auschwitz.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "That was Auschwitz to Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "When I came there, we got a tattoo, 129354.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This is with a triangle.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The triangle means that I'm Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And at that time, we found out that they are different.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "There's some red, red, and the other, they had green triangles.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They were homosexuals.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Red ones were political prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "There were different-- transfer different people.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We had a transfer-- this kind of--",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Everybody that came to Birkenau, everybody that came to Auschwitz got numbered, tattooed.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We were together but only the sign, because you had a number here.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You also had a number on the jacket.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And on the pants.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "The number.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And that green or red insignia was shown so the kapo or the German SS men should know that this man is because he's a homosexual, or this man is because he is against the, the political views of the German Reich as well.",
      "word_count": 44
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My brother went to a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I went to Auschwitz-Birkenau.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "When I was in Birkenau for a few months, we were working, and there were a few-- a few camps.",
      "word_count": 20
    }
  ],
