    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I remember distinctly.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I am survivor.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I am alive.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "It's after the war.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "But I have no one.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "All of them died.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I knew that I expected to die too.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And that was a terrifying moment.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And that was the first time I cried from pain that they are not with me.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "This was when the Russian Army came to the camp?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "When-- when we left the-- the-- the labor camp and we found ourselves free in the basement, that's when I started crying.",
      "word_count": 22
    }
  ],
