  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "So all we could do was stand up.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "And [SIGHS] it took quite a few days.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "And we had very little, very little food, just what they gave us on the way-- little pieces of bread and some [SIGHS] rainwater that dripped through the tar roof of those cars.",
      "word_count": 33
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "And once they let us out to go to the toilets, which was somewhere in the wilderness.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "So we ate some grass that was, was there.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "[SIGHS] And then we went on and came to that little town.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "Were taken to a building, which they had taken over and where they housed us.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "And from there, we went to the factory every day, 12, 14 hours.",
      "word_count": 13
    }
  ],
