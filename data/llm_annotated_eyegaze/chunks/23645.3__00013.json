  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "But somebody did, somebody must have covered me up with straw.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "Somebody must have given me some water.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "Because I made it.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And when I went back to work the first day, lo and behold, again I was weak, and I stumbled.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And I got picked out.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] And before I knew it, I was on the truck.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And you know something?",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I worried very much before, and I wanted to live.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But when I got on that truck, I came to terms with it, and I really didn't care.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And I looked forward to it.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We're going to go to break now.",
      "word_count": 7
    }
  ],
