{
  "stem": "3453.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And my mother with me standing down there-- and they called out because they're-- they're-- they were very well prepared and very, very organized, the Nazis, but this is was concerned.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Right up there they called out the [NON-ENGLISH SPEECH], because alphabetically, B must come to the-- to the gate.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They all stood up.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My mother, there was a daughter, a son I remember, the whole family.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I ask him-- my mother and me ask him-- Leah was the daughter's name.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Leah, what is this?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "She said this is my wedding gown.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "This is my fiance.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I said, where are you going?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "She said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "They picked themselves up and they went, and that's the last I seen of them.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I have lost my father down there.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My father had a terrible temper.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He spoke perfect German.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Maybe he went right away to the gate-- gate and he start maybe a fight or asking some questions.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "He was killed, right maybe there on the spot, because I haven't seen him.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Then another family went up from a smaller, another town.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I used to go on vacation down there, come to there.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Dabrowica. ?] Right away, they got up.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "There was the mother, the daughter, and oh, did she stand out.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "She was a beautiful girl.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Sarah was her name.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "My age, maybe a year younger.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Beautiful blue eyes, dark hair.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "She looked like Elizabeth Taylor.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "I always compare her.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I said, where is your father? 'Cause I knew he used to come.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "She said, my father escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She said, my father escaped at night.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We don't know if he's alive or dead.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I met him in the woods afterwards, and he died fighting the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "That's not a consolation.",
      "word_count": 4
    }
  ],
