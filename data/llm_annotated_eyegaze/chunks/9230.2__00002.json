{
  "stem": "9230.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And everything has to be-- somebody has to-- to make-- to keep-- to take care-- care on it.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So they picked me because I got beautiful hands.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "Now they're old.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "They aren't beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "They picked me.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "So-- and she wasn't but only a month.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And she fell in love with me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "She likes me very much.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "And when they opened in the ghetto, they opened hotels for the people what there was working very hard.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "There-- they send them for two weeks, and they got everything over there.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "And she was the manager there.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "And she got the house near the-- the hotel.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "So she took me out from the factory, and she gave me a job, a waitress to work and-- and I got food.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "And I bring home food for my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "Because there--",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was three hotels.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes, three hotels.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "The people what they were working in the factory.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They was working very hard, so they got vacation for two weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And she was the manager there.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "A beautiful lady, she could be alive.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I beg her to come with me.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Anyways, Rumkowski came time to time.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He came to look around.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And the old girls, the girls what they got a high school education, they didn't took girls plain.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "No, all of them, they got-- they finished high school.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Beautiful girls with education, everything, they took them to work.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And I got [INAUDIBLE] because she likes me, and she took me in.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And I was staying with her when I was working there.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "But when Rumkowski has to come, a lot of girls has to run out into-- I was under the floor-- under the bed by her.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "He shouldn't find-- he shouldn't find us because he can take any girl that he want.",
      "word_count": 16
    }
  ],
