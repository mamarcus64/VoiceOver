{
  "stem": "18960.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Mark Weidman.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "M-A-R-K W-E-I-D-M-A-N.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I have a nickname that was called back home.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And that nickname was Musio, M-U-S-I-O.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "May 29, 1923.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "73 years old.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Rolow, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "R-O-L-O-W, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had-- my childhood was very happy.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They were very happy years.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I lived in Schodnica.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It was a small town, rather-- rather a larger village, district of Drohobycz.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "There was a petroleum industry there, and my family was involved in that-- in the-- in the oil fields.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My father was a manager of an oil field.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I had-- we had a private house [PAUSES FOR 3 SECONDS] where my grandparents lived with us.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Also I had a sister, four years my junior.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And my-- my younger years were full of dreams, full of hope.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And I went to school, to public school, in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "In the afternoon, I had to go to an orthodox cheder school to learn Hebrew.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "I-- I finished six grades of elementary school of that public school.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Those years were real-- really my happiest years of my life.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "I looked up to the future with-- with hope and was sure that everything would go my way because financially we were very well off.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And so till the age of about [PAUSES FOR 3 SECONDS] 14, I spent in Schodnica.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Had a lot of friends.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "We were going on vacations, usually to my grandparents' house which was a different village and different area in Poland, [POLISH], where my-- my mother was born, and my grandparents, my maternal grandparents, lived there.",
      "word_count": 35
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Because in Schodnica, we had our paternal grandparents with us.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father, as my grandfather, they were very early risers.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And I remember my grandfather, he used to rise-- he was a very pious person.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He used to rise in the wee hours.",
      "word_count": 8
    }
  ],
