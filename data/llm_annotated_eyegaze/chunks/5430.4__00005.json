{
  "stem": "5430.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And the Polish army, the Anders army that they formed, decided to go to Iran, and they went through-- as a matter of fact, they jumped off-- a lot of our people jumped off in Iran and went to Israel.",
      "word_count": 40
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Bagan ?] was one of the people that was with us.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "He was in Middle Asia.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He was in Siberia and then in Middle Asia.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "He was one-- he joined the Anders army, and when they-- I understand when they got to Iran, the whole bunch of them just separated and went to Palestine.",
      "word_count": 29
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He wasn't in our camp, but I know that he was in that--",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He was just in that same area.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It was one of the-- one of the people in our type of situation.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And of course, I was too young to go to an army, but although, they caught me in Kirghizia-- in Belovodsk.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They took me to a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They called it the Trudovoi Front, the labor front-- to work for the-- for whatever it is.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I never got to work for them, because when we got to camp, they gave out the rations, the booklets for bread.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I collected the whole week's worth or two weeks worth, and I just put in my work sack and left.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "From that point on, I was illegal.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And the many times they would come and look for me in Belovodsk.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And one time, I came very close.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "They came looking for-- I was literally a deserter from the labor front.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And my mother dressed me up as a girl, and they came in, they're looking for men and young men.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "My mother says only my little daughter is here.",
      "word_count": 9
    }
  ],
