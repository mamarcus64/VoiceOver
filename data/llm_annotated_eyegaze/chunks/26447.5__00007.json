    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 40,
      "text": "We decided we need to go out.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 41,
      "text": "And I came from Canada-- we didn't got money enough to buy the tickets we need to buy to pay for every-- every-- in the fam-- for every person in the family-- 1,000 rubles.",
