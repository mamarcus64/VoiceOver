  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "It was only that if you had to report to-- to the office in-- one of the German camp leaders where we were in the divisions, we had to say I'm Harry Guterman, Hersz Guterman, 95 [GERMAN], years, you know.",
      "word_count": 40
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And it was part of your identification but not-- nothing more.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz, we-- they put us in-- into the [PAUSES FOR 4 SECONDS] Gypsy camp.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "A day before, they killed all the Gypsies out of that camp.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They took them all into the gas chamber.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "It was called the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "We got in.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "There was blood even on some of the walls in there, on the-- because some-- some of them we couldn't-- they couldn't clean up or whatever it was.",
      "word_count": 28
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "They just-- that was it.",
      "word_count": 5
    }
  ],
