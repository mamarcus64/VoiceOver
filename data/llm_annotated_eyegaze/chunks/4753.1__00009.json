  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And my parents never knew what happened to her, and she never returned.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So after that, very soon came out the new law in Hungary that every Jew has to wear a yellow star and yellow arm band.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if that was in end of March.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I don't know exactly when.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And after [PAUSES FOR 3 SECONDS] about, I don't know, 10 days after we were wearing the  yellow star, we had to go to the ghetto.",
      "word_count": 30
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Between that time, it's not clear anymore for me.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "So we did go to the ghetto, the ghetto in-- in my city that was one single house owned by a Jew.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And that was called ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And another house owned by a Jew, 10 blocks, or 5 blocks, or any blocks away, was the other part of the ghetto.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So the ghetto wasn't in one place.",
      "word_count": 7
    }
  ],
