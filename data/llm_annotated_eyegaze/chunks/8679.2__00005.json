{
  "stem": "8679.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Because-- my mother [? in which ?] was German.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Because I had worked shortly after I had graduated in a lawyer's office, I knew shorthand, which was then used, and of course I had perfect spelling and typing.",
      "word_count": 29
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Typing.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And that's why I had an office-- an office job.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I worked in the-- the Jewish administration.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I could-- I was in constant touch with Rumkowski.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I sat next to his office.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He had his own private secretary.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I wasn't a private secretary.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I was just one of the girls.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I could see the Gestapo coming in and out, [PAUSES FOR 3 SECONDS] and I just lived in constant fear.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Because I heard too much for my own good.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "But I had a job.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My mother worked in the factory where they made toys from scraps of wood that they produced in the factory where they made furniture.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They made toys for the children in Germany, but ours starved to death.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "That's fine.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "--please say so.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "If you want to answer in any way you like it, please do so.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Your looks, as I saw in the pictures, are a woman of a blonde hair, blue eyes, which was appealing to the German people.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I was Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "There was no appeal.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Did they abuse you physically in any way?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "You know, Victoria, when they came to Vienna it started out as this.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "They declared that we are sub-humans.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Not humans, sub-humans, that we are the scum of the earth.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "They were not interested in us as women.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Maybe it happened in some places, incidence, no.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Nobody looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Absolutely not in any way than the bark out orders.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I stayed in that ghetto for four years.",
      "word_count": 8
    }
  ],
