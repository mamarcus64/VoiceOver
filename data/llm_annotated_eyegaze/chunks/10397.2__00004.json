{
  "stem": "10397.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Or they were throwing themselves in the ditch and standing on the edge of the edge of the ditch and shooting them in the back.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Nobody knew because there was-- we will survive.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "As a matter of fact, it happens when-- when they came and invaded Russia in 1941-- in-- in 22nd of June, 1941.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So yeah--",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I went to my home, to-- to Brody.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My parents lived in Brody.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I was near Warsaw-- close to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But it was  a suburban train to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And like I said, I walked 24 days with other-- the other two boys.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The Russians were there already.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "The Russians invaded Poland-- when-- or-- yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "A year before Germany invaded Poland, in 1939-- it was 1938, Ribbentrop, the minister-- the German minister of internal affairs and Stalin.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Ribbentrop went to Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they made a-- a pact.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We will divide Poland, the Curzon line.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "What is west of Curzon line will be German.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "What is east of Curzon line-- I'm talking about dividing Poland-- it will be Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So when the Russians-- when the Germans invaded Poland, the Russians invaded Poland from the east.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So when we came-- when I came home after walking 24 days, in Brody was the Russians were already there.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they were asking for a watches.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They broke-- they were-- they were going to [INAUDIBLE] to the-- they went to the drugstore and drank up all the cologne, because that's alcohol.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And they had 10, 15 watches taking home-- to take home watches.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Everybody has to-- you have a watch?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I'll pay you any money.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And he says, you see?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I've got 15.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I got 12.",
      "word_count": 3
    }
  ],
