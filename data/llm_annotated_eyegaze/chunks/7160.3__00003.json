{
  "stem": "7160.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "Everything to keep secret from everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "What do you do.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "Even my closest friend not supposed to know.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "Everything's supposed to be alone.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "Because we swear, you know, on the Torah.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "We don't going to say nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "So then he get me my job.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "Because I spoke Polish and Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "He said, you're going to go to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "There's quite a few Jews that want to come to Palestine.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "You're going to help them to cross the borders.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "You're very sharp in that, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "And you help them to cross the borders to bring them to the American side.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "And from there we can take them over.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "Because where the Russians on watch it's very hard to get out.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "Matter of fact, Russia used to-- was in Hungary at the time, part of Vienna, and the whole Poland was occupied from the Russian, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And people want to get out, they cannot get out.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "I went with another guy.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "They gave us each one a gun.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "We went there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "They give us money too, in case we have to buy off those guards crossing the border.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "So we went to where-- we had a place where we're going to be meet them, the people.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "We already give the place, the address and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "Somebody else was working from the other side.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "Used to work in groups.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 48,
      "text": "One part here, this was my job, and somebody else should take over, because one person cannot take all the way down from the-- from Poland take all the way down to Palestine.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 49,
      "text": "Each one used to have his own place.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 50,
      "text": "So when we got-- we got a group for there, about 25 people, all ages.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 51,
      "text": "Little kids, older people, middle class, women, all kinds.",
      "word_count": 9
    }
  ],
