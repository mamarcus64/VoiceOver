{
  "stem": "13693.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "It's was hard to go to a place-- to a new place without the language.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "It's was hard to go to a place where the-- where all the gates were closed.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "It's-- it was impossible.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "They did not want him.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "They did not want us in here.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "The-- the all-- the all-- the-- the all gates to the world was closed.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Definitely, they would go, especially the younger-- the younger generation.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "My brother was in-- in technical-- technical school.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I was in the gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "But I was in the middle.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "But the thing is, all-- all bridges were still burned in order to go.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was-- it was a traditional house.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Shabbos, you had to be a-- a Shabbos was a celebration.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Shabbos was something in here, what-- what you released yourself from the-- from the pressure of the days, of-- of the week.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "As Bialik said.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Oh, sure, it was something in here.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You had to find a release, like-- like the Kabbalah says.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "You have to-- you-- in order to-- to get to release yourself from the pressure, you had to-- you had to celebrate.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You have to go away and to learn-- and-- and to forget.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Let me now bring a little bit the story why.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Poland was-- under Pilsudski, what was the president, was kind of liberal.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Liberal in this respect, that they did not-- they try-- Pilsudski did not try to persecute the Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Starting with his death--",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "'36, we have-- [LAUGHS] we have Rydz-Smigly.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Rydz-Smigly was a anti-Semite.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He was under the influence of the-- of the German.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "The German took over with the propaganda.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "This what you call cruel propaganda-- Heilsgeschichte.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Cruel propaganda simple was in here that we are dispensable.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We are, because of us, the world cannot develop.",
      "word_count": 9
    }
  ],
