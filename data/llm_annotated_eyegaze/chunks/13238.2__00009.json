  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "He was smart.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And he got involved with this owner, what was the name, Abraham Bankier, and Itzhak Stern.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Itzhak Stern is portrayed, as you know, by the-- the actor who was playing his role.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "What is his-- yeah-- And from that day on, he was taking care more and more and more into the factory.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "One day-- one day, he got introduced to another three, four people, and they were bringing money in order to get into this factory.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "Many of them with money got into this factory.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And, by the way, the role of Itzhak Stern is played by Ben Kingsley in the movie.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "What I heard, they were trying to bribe Schindler that time in order to work for him.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "How much is true, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But that's what I heard through those years.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But most of the time, Schindler got a few hundred people from the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And when they liquidated the ghetto, they were coming from Plaszow, from the camp.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "So he was trying to get-- to be very friendly with Amon Goeth, who was the commandant of Plaszow, in order to get the labor.",
      "word_count": 25
    }
  ],
