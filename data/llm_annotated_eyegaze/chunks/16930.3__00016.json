  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I was in the air force for-- [INAUDIBLE] it must've been for about '48, '49.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] '50, maybe a year, year and a half altogether.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Then at that point, people want to get out, get discharged, move ahead with their lives, learn a trade or something.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I also saw people-- a lot of people leaving, because after '49, the war was won.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "The war, the '48 war was won in '49.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Leaving-- some left the country.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Some Israelis left to go back to home, get the jobs and get married, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So people were leaving, both from the [NON-ENGLISH], volunteers from other countries, Britain, France.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "They had families wherever they came from.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They went home.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "They did their job and they went home.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "We're just going to switch tapes.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
