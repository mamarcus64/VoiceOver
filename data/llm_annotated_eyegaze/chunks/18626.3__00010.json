  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But the first months, like a couple of loaves of bread.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And in the ghetto was then a kitchen, a soup kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "You could go there and get a bucket.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "You know, you have to bring your own dish to get soup, with a lot-- a lot more water than soup, with green leaves.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And sometimes you used to find in the soup a piece of beef, but not from a cow.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "It was from horse meat.",
      "word_count": 5
    }
  ],
