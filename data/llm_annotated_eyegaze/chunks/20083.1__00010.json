  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I do not know whether he-- they knew that he was a Jew.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I only knew he still worked until 1938 for the newspaper.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "What happened after that when he moved to Switzerland, I do not know.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Well, they tried to save themselves already long before.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They tried, I think they started in 1936 or 1937.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They tried to emigrate either to the United States or to England.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But the-- the immigration visas, as far as the United States was concerned, was totally oversubscribed by about I think eight or 10 years by the time that my mother tried to emigrate.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And I remember us lining up outside the US Embassy in Berlin.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And it took us probably five or six hours to finally get to the officer in charge of emigration, or immigration.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And he said, if we could put down our names but we would have to wait about eight years until it was our number to emigrate.",
      "word_count": 26
    }
  ],
