{
  "stem": "18778.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She is a very versatile person, having been a television producer and director at channel 29, an art director at a newspaper in Missoula, Montana, and finally, a teacher at Quakertown Friends School.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And she has a, a son, Asha, my oldest grandson, who is my sunshine.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I have a son, Joel.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Joel lives in Virginia with his wife, Susan.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "By the way, Joanie is married to Robert Michener, a, a TV person, completely well-rounded TV person, an engineer.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And my son is married to Susan [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "They both work for Marriott Corporation.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "My son is a director of projects for human resources, and my daughter-in-law is in charge of menus.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "They work at the international headquarters in Bethesda, Maryland, for Marriott.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "They have two children.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "The oldest one will be six soon.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "His name is Benjamin Hans.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And the little girl is going to be three in a couple of weeks, and her name is Lexis Halsey Loeb.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "That's my family.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my adult life here, I went to art school after high school.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I went to Philadelphia College of Art for a short time.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I worked at Temple University Library for a while, then I got into the art field, which was my goal.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Eventually, after about five years of marriage, I had children.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We moved into a house, and I stayed home and raised my children.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I was very active in PTA.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I was very active on the Jewish scene, here in Philadelphia.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I was the president of my sisterhood.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "We belong to congregation [INAUDIBLE], which was a German-Jewish congregation.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "My husband was one of the founders.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I also-- at the same time, we belong to [INAUDIBLE], which was where I was confirmed, where I was married.",
      "word_count": 20
    }
  ],
