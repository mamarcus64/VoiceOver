  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "We have every day.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "We was every day worried.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Well, we have the news there.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "The radio, we had a radio, at least on the radio.",
      "word_count": 11
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Not everybody got a radio, but somebody got a radio, and one told the other one what's going on.",
      "word_count": 19
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Well, at the same time, we heard that.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "We-- it was-- it was normal.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "We heard that.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "We know that.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "We have in Lutsk, in Rivne, my father's-- my [NON-ENGLISH], what do you call my father's mother.",
      "word_count": 17
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And there was a few cousins there.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't see each other.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "We couldn't get in touch.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Oh yes, the Kristal night.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Sure, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Everybody feel threatened.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Everybody, They couldn't eat.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "They couldn't drink.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "Everybody was-- it's unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "Nobody believed that it can happen, that.",
      "word_count": 7
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 5,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 6,
      "text": "They were changing-- they were changing the clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 7,
      "text": "It was not like police doing.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 8,
      "text": "No, in the beginning, it was not like police, in breaking the stores and everything that were there.",
      "word_count": 18
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 9,
      "text": "Put in-- take live people, and put them in, and burn down everything right away.",
      "word_count": 15
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 10,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 11,
      "text": "That's the problem started.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 12,
      "text": "Everybody saw it.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Sure, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "No, we're not afraid for-- the Poles was waiting for that, but they wouldn't do it because the Poles alone was afraid for German.",
      "word_count": 24
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "They says there was something-- they were saying there were something in Polish government was a German.",
      "word_count": 17
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "They-- they don't know it.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "They were saying, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "I remember, I remember that time.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "Well, we know-- we know it's a problem.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "We know the problem.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 7,
      "text": "And a lot of-- a lot was saying already, I wish Hitler comes first here.",
      "word_count": 15
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Not Poles, the Ukrainians were saying.",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, they were saying.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "They want him, because they don't like the Russian.",
      "word_count": 9
    }
  ],
