{
  "stem": "25027.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "It was large enough to put a bed in.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Mother and us two boys slept in the other room.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Across the hall in one room was mother's sister, her husband, and three children.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And the front room was rented out to a carpenter who used to produce, [PAUSES FOR 3 SECONDS] make all kinds of wooden furniture, and also made the Jewish lions-- I just remembered that-- for the synagogue.",
      "word_count": 37
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "You know those that adorned the Torah part-- on top of the Torah.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "He was a very skilled carpenter, an artist, I would call him.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And that helped us survive, that rental also helps--",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Survive, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My maternal grandparents.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather's name was Elay Hacker, H-A-C-K-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And his wife's name was Lifsha.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Lifsha.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how to spell it.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "My mother sister's name was Pepi.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I would say P-E-P-I.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And she married a man by the name of Steinkohl-- you know, stone and coal.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "S-T-E-I-N-K-O-H-L.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Pinchas.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes, their son, Mendel, was born in 1922.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 7 SECONDS] His sister, [NON-ENGLISH SPEECH], Rachel, was born in 1921.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And he had [PAUSES FOR 3 SECONDS] another sister, [NON-ENGLISH SPEECH], Rose.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And she was born, I believe, in 1927 or '28.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Lived together in that house.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Not in the house.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, they apparently rented a gardens in, in the near vicinity with a little shack like.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And that's where the children used to be entertained, and played with, and whatever was necessary for a set amount of hours.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't-- [PAUSES FOR 3 SECONDS] it was like a seven or eight-hour thing.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Every day, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Five days a week.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Not until 1938.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "They first installed one bulb in one room.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "The water, we had to carry for about a kilometer away.",
      "word_count": 11
    }
  ],
