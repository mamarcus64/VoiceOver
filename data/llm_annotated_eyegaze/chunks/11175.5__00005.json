{
  "stem": "11175.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Am I going to lay down on the floor in the-- [NON-ENGLISH SPEECH].",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I stood up with another 19, 20 people.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We stood up, and we started to walk from the barrack to the gate, from that place where they-- as we're coming over to the gate, the [GERMAN SPEECH] with the unterhosen.",
      "word_count": 32
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "They took us-- we should let-- let down the-- the pants, for the-- and start-- we couldn't walk.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We hopped.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "With our hands up and hopped, as if we are hopping.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I said to the guys with-- we were 20-- 20 people, five-- five times to four.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And from this side, a few Ukrainian, this side, and front, an SS man, and the back, an SS man.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[STAMMERS] That's the way, how they [INAUDIBLE] to the grave.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And taking us to the grave.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And that's how we're walking.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I said to the guys, what we're going to do?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We're going to go over there to be shot?",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I said it quiet, in that quiet way.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I tried to let down my hand, one hand.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I said, I'm-- I'm coming, and I want to grab the pants, I-- Get back up.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "A knock with the rifle.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "I thought I'm-- I'm dying, right away, on that place.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And I-- you know?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "I-- I-- I lost my conscious.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "I lost-- I didn't know what is going on.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I-- I picked up my hands, and I hopped again.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And I see them coming over close to that-- to that grave.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "I digged out that grave on my-- I said to myself, Simon, what are you going to-- what are you going to do?",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "You're going to put in your head, they should shot you there?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Run!",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "Then you wouldn't feel when you get killed.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "That's all right.",
      "word_count": 3
    }
  ],
