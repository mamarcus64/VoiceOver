{
  "stem": "25773.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But unfortunately, my elder-- my stepbrother, who we adored and loved, went to university to study medicine because his father was a [? doctor, ?] otherwise wouldn't he be able to, to attend the faculty.",
      "word_count": 35
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And they had-- the Jewish boys had to stand on the lectures.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They were not allowed to sit.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And there was a rampant antisemitism in Poland already.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Lectures, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They were not allowed to sit down because they were Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And then, of course, he didn't finish this because of the war.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And yes.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My sister-- when I mention my little brother, [?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Mikash ?], who also went to the same, it was called [NON-ENGLISH] Gymnasium.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It was excellent gymnasium.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And he was still a young boy.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we enjoyed him at home, because lovely.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "My sister was already-- she went to a very good school called [NON-ENGLISH], which was one of the prominent, very Jewish school.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And she lived with my grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And we saw her occasionally.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "She used to come, and oh, we went to this little villa, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And she visited us.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We had a very good relationship in that-- with my stepmother.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She was a very nice, very nice lady.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Unfortunately-- very nice.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Died so terribly, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Probably, I don't know even how.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And she was, she was a very good woman.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And it was, it was a nice harmony at home.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It was a good Jewish home, a Jewish home.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Holidays--",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Every, every Jewish holiday, because my father was an orthodox.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But he was not a strictly ortho-- very ortho.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He was orthodox, but not extreme, what we call today.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "He was quite tolerant with us children.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But holidays were beautifully at home.",
      "word_count": 6
    }
  ],
