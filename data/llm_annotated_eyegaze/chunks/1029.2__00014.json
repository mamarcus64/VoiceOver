  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "But funny thing is, you know, in Belsen, you know, we kids, we used to play around.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And to us, we were so cool towards death and corpses.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "To us, it didn't even matter.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "We used to play close to huge indentation where they sent the corpses.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And we thought they were pigs because they-- some of them were still moving.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "And then we got closer, we realized that those corpses were moving.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "[SIGHS]",
      "word_count": 1
    }
  ],
