{
  "stem": "471.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And this was around-- just before-- it's a couple days before the war broke out, but just before September 1st.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "But you know, you have to know mentality of the Polish, certain Polish people.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Where we live, we live in a section which is right across the street from Wawel, on the Vistula River, beautiful location, beautiful.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "As a matter of fact, when last time I was there, I took the picture from the hotel.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I can spot my home--",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "--right across the street.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Wawel was the big castle.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "That's right, well known.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Right across the street we lived.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And I will say, our neighborhood over there, it was, well, maybe 10% Jewish.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "We were born and raised-- we were born and raised like all those well-known soccer players.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I-- I don't have to name them.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "If you want it, I can name the names.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "They were like our neighbors.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "You know, we grow up together.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Our-- our-- [PAUSES FOR 3 SECONDS] No, no.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "Our-- those [NON-ENGLISH SPEECH], how you say that, that [NON-ENGLISH SPEECH]-- janitor from the building, his son was a well-known soccer player.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE], you know what I mean, like [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And the mother, there was no father.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "I remember like today, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "[INAUDIBLE], she was the janitor.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "She scream one day, she comes up.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "And this was that day, few days after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "We knew the war broked out.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "Because we saw-- we hear the plane coming.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "Markheim, Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "Markheim, we don't have to worry about, anymore, about the war.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "The English army took over the possession of our bridge, all the bridges, what they crossed the river.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 24,
      "text": "Now, everybody was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 25,
      "text": "Everybody was satisfied.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 26,
      "text": "But a couple-- an hour later, we find out something, that this were not English Army.",
      "word_count": 16
    }
  ],
