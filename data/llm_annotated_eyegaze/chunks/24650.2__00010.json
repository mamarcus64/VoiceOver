{
  "stem": "24650.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "They send him to Estonia.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "This is in the Baltic, too.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "It's the first-- the third Baltic state.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "To Estonia, to a-- a small town called Klooga.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "There were 6,000 people.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "And four hours before the Russians came in to free the-- the concentration camp, my father and the rest-- just 103 people, run away, because they didn't have time to run after them-- were burned in the street by the concentration camp.",
      "word_count": 42
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The pictures is in every Jewish museum.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "How is it, when they-- when they run away, the Germans?",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "My cousin's husband did go to the post in a coat, and he asked for the International Red Cross.",
      "word_count": 19
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And they make the pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "In between the people, there is my father.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "So he was killed as part of a mass group?",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Burned, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I find out a little bit later than my girlfriends, because I was-- I-- it's too-- [LAUGHS] We didn't talk yet about the concentration camp.",
      "word_count": 25
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "This was after the concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "They're making the final aktion.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "They took us to where there was nuns, a place where the nuns had the biggest place in Vilna, in-- in the backyard.",
      "word_count": 23
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "We sat there, 24,000 people, 400 children.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And they took us for selection.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "The young people, left-- right, and the older people, left.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "So I didn't want to go.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't take it anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "So the Kittel, the general, said to me, you are young.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "You go to work.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "And he sent me left-- right.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I was finished with my nerves.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "But he sent me.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And I did go.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "What could I do?",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "I have see a terrible-- two terrible tragedies when they-- they tooked us.",
      "word_count": 13
    }
  ],
