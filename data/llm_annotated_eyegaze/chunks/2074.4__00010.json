{
  "stem": "2074.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "You go to the family in America.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "If you-- any time-- from America, you can go to Israel any time.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "So that convinced him.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "We went on a truck to go to American consul.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "He was booed by the [INAUDIBLE] group.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "He was active, like [INAUDIBLE] group.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "He was active in that organization.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "He was mad at me because he didn't want to go to America.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "He was booed by his-- by his marching group in Germany, demanding to give us our homeland.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "He was active in that way.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "What I think of the US-- number one, I came in Christmas Eve.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I saw all of these decorations.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I thought, what in the world was that?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "So when I arrived at a train, the family arranged to come pick us up in Duluth to the train station.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "There is a man with a car with a uniform with a fancy hat.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I nearly had a heart attack.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I thought, well, the Nazis followed me.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "What in the world is he?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "It happened to be my cousin's son, a cadet from West Point, came home on leave.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "So he came with the car to pick us up.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "But then there was other-- two more cars with relatives.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "They came to pick us up.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And a cousin of mine in Duluth kept us for a couple of weeks at her house, until they found a house.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And they paid for one month's rent.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And when that month ran out, we went to an uncle's basement.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "So we were in the basement without water, without warm water, without a refrigerator.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And we struggled a little bit in America.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "We-- we didn't have it like some other people who come nowadays, that they give them housing, they give them everything.",
      "word_count": 21
    }
  ],
