{
  "stem": "3331.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but what the Germans did, they took all Jews from small towns, from small ghettos and they concentrate them in a large town where it was a railroad station to have it-- to be-- at-- they should be able to take them away when there was an akcja.",
      "word_count": 49
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So this town was Rzeszow, the larger town in our section.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Rzeszow is R-Z-E-S-Z-O-W.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And from Rzeszow, when they had their thousands and thousands of Jews, they sent-- made transports to Belzec, where they were gassed.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Belzec is B-E-L-Z-E-C.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Belzec.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "We were nine children, and I was the youngest from the nine.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My oldest brother, his name was Abgrum.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He came to America before I was even born.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And he became Albert.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And he was the first one who changed the name from Saleschutz to Salsitz.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "For this reason, my name is Salsitz.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Abgrum came to America.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He married, got children.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And he died natural death about 15 years ago here in the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "The second was a sister.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "She was the oldest sister.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "Her name was Gela.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Actually, her name was Bluma Gela, but she was called Gela.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "She married in 1921, and her name-- she married a man.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "His name was Ruben Weinstein.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "They had one daughter, Shaindle who was two years younger than I.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "They also were killed in Belzec.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "The, the transport to Belzec from Rzeszow with all my family was in July the 7th, 1942.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And a few days later, I don't know exactly the day when they were gassed, but usually it took two or three days till they were gassed.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "After Gela came a brother.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "His name was Leibush.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And Leibush was-- he survived the war with me in the woods.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "He was with me all the time in the ghettos, in camps.",
      "word_count": 12
    }
  ],
