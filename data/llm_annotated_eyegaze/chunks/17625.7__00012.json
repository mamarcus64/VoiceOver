  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "My brother-in-law didn't come back.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't-- he couldn't survive.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Some of them was-- was-- were-- were terrible camps, concentration camps.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And some of them was-- was just-- I mean, farmers working in factories, working.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And where-- where they had-- where the SS didn't have the direct hand on it, or the political, the-- the gestapo.",
      "word_count": 21
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "When?",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "After the war, I came home.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "It was before Rosh Hashanah.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "And what-- what did I say?",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Rosh Hashanah?",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Actually, no.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Rosh Hashanah was-- was this-- the beginning of the war.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "It was the beginning of the war.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "To [?",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "Janow ?] I came in January the 19th, I told you.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "January the 21, two days, took me, to come back.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "I thought the beginning of the war was Rosh Hashanah, when I came back home from-- from the army.",
      "word_count": 19
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "I came back for Rosh Hashanah.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "And my parents were in Cracow at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "But after the war, I was already, second day in [?",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "Janow. ?] I told you the story.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
