{
  "stem": "12674.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I mean, nobody that is not involved in this can fathom, no matter how much empathy you have, what it would be like to be subjected to conditions like that.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Because this is really unimaginable until you're stuck with it.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "We were there.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And so we cried a lot, and we talked to one another and we developed friendships and we sort of held one another up.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "We were all little girls.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "We were all afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "We were all away from mommy and daddy.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And nobody really gave a damn if we lived or died.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "They fed us asparagus and jam.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "When they cooked meat, they cooked it with marmalade.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And it was-- it was not--",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I don't know, some women.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Some sort of [NON-ENGLISH] type women, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "This came from later.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I never saw it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I had never lived this way.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You did what you were told.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "You went out in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "You did it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "You came home.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "You laid down.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "You cried a little bit.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "You ate a little bit.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "You fell asleep.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "You cried a little bit.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "You got up.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "You went to-- you went to work.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "You dug your thing, and you cried a little bit.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I-- I don't want to think about it.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Let's-- let's leave that.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was too early.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I wasn't-- I didn't have any-- any-- any defenses yet.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It is-- it's-- it's open.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It's-- it's not-- I don't-- enough.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, we came back to Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "They had my name.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "So I was assigned to this paper factory, Bunzl and Biach.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "It had been a Jewish firm-- B-U-N-Z-L and B-I-A-C-H.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "It had been a Jewish firm.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "They were taking old paper and making new paper out of it.",
      "word_count": 12
    }
  ],
