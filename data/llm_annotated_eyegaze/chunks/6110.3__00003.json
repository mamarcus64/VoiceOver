{
  "stem": "6110.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we start to cry, start to hug each other, and where are we?",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "What's going to be?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "What's going to be?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But all right, they took us to some shower that time.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They gave us a shower.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And we thought that we are going already to the oven, not to a shower.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "We knew-- you remember from the picture the women were going in a room, and they thought that's a gas chamber.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "We were-- and then, all of a sudden, water came down.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "It was a shower.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "They gave us a shower.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Then they shaved off our heads.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They shaved off my head, and I was happy.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I was so happy they shaved off my head because the lice were killing me.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they shaved it off.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They, they put some, some-- you know, that, that-- I don't know the name of it.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Naphtha, they call it in Europe.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Disinfect us, yeah, disinfect.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And they shaved us all around.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Men, can you imagine?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Can you imagine a woman, and a man takes care of such a thing?",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "That, that was degrading.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "We felt all degrading.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "We were low, low, low.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And then we went to the barracks, and they started to push us to work.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "We worked a few weeks there.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They took us to a magazine to take some clothes.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I took some rags, clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I took some rags, and I took some shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't have shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I had the, the Dutch, Dutch wooden shoes, you know, what they wearing in Holland.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And that was winter already.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "That was winter-- was snow on the ground and high snow, very high snow.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And when I went to work, running because they was yelling, oh, oh, oh, fast, fast, fast.",
      "word_count": 17
    }
  ],
