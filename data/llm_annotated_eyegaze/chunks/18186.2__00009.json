{
  "stem": "18186.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 373.8,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I believe, if not for-- if the Ukrainians wouldn't team up with the Germans, more people would survive.",
      "word_count": 19
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "That-- yeah, the Ukrainians.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah one is Mikhal, and he's in Israel, and has a beautiful family.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And the other one is Lazer.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Lazer-- that's-- or Lazer, whatever.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "He's-- I never saw him.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "But he was, I think, Lazer I believe is in Canada somewhere.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "But that's what Mikhal told me.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "But Perl is in-- is in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Perl, my friend-- the girl.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Perl, like Perl.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "You know, we call Perl.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "She lives-- she was-- she's married, has two children.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Her husband died by now.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And Mikhal is there.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "Mikhal was my best friend, his family, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "At that time it was-- it was Pieczenik.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Pieczenik is like-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I can write it down, if you want it from me.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "We have everything in writing.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "We didn't spell in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "You want me to-- do you want see--",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Pieczenik?",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Oh, it doesn't matter.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Now his name is, I think his name is altogether different.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "It's not Pieczenik.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he picked his Israeli name.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I forgot at this minute.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I never saw him again.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "From Stepan?",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "See with Pieczenik, we knew better than the other family.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "We all knew his parents too.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "Everybody knew each other, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Oh yeah, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "That's for sure.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "Then rumors-- what when we finally-- when we started to hide-- and the-- we were hiding in this forest.",
      "word_count": 19
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "And people-- people that lived close to the forest, they-- we used to go to ask for food.",
      "word_count": 18
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "And every day we would move to a different place.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "And this lady happened to be-- that she couldn't be with us children.",
      "word_count": 13
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "Because she was--",
      "word_count": 3
    }
  ],
