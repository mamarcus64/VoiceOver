{
  "stem": "8854.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "It was a lot-- and then everybody start [? marschieren. ?] And the SS, at every second foot was an SS, or a woman or a man.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And in-- in about half a mile, there was the Gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And the Gestapo and the SS, it was about a hundred of them with sticks in their hands.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And everybody has to [? marschier ?] in the front of them.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And they picked.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And when they saw my mother with Chanale by the hand, they said, [GERMAN].",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "You go to the left!",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "My sister with the baby in the hand, you go to the left!",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Hollering.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "When I came without babies and alone, they looked at me.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And they said, [GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "You go to the right.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "I was started screaming.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "I want to go with my mother!",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I like my mother!",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I want to go with my mother and sister, what.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "And they started beating me with a stick over my back and my head.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "You go to the right.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "They needed me for work.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So I went to the right.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother walked with the sister with the kids, and a lot of thousands of people.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My mother looked in the back, if-- if I come.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I hinted with my hand, bye.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Bye, ma.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "[SPEAKING YIDDISH].",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And that was the end, that I saw my mother, my sisters.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "After that, they put, again, us in five in the row, after the selection.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And the SS women went with us to the barracks where they had the showers.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Passing to the-- go into the showers there, through the barrack.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "We saw the crematorium.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We saw the flames.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And I start screaming.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I see the skelett of my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "Look at the flame.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "That is the skelett of my sister.",
      "word_count": 7
    }
  ],
