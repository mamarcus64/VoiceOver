  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "So they were jealous.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "If I was taken a sharpening stone to sharpen tools, they took it away.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "Even they find out there that I'm Jewish too.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And they made all kind of remarks, you know, about the newcomers who came to America, you know, that they've taken away all the jobs from the Americans.",
      "word_count": 28
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "They made bad remarks.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "And I saw it's not a place for me.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So one day, I saw a ad in the newspaper, said they're looking for a woodturner in Seaford, Long Island.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So I came to Long Island.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And he was a gentleman, very nice person.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "He tried me out.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "He advertised he's a gentleman, but in the American paper, he couldn't get a woodturner.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "He advertised and advertised.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Because woodturners was a trade almost in Jewish hands.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "OK, we're gonna have to stop a minute.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, OK.",
      "word_count": 2
    }
  ],
