{
  "stem": "1387.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "It was called numerus nullus.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And my father was a ardent Zionist.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And he felt that I should not bother studying in Poland, but I should prepare myself to eventually go to Palestine.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "He also wanted me to learn a trade, but he felt that I have a little bit of talent in drawings.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "So he borrowed $50.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And I worked for a teacher in [?",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "Zasow ?] by the name of Ephraim Nachimowicz who got $50 for his [PAUSES FOR 5 SECONDS] work.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And I worked for a year without pay.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was an apprentice.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "What else would you like to know?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I was orthodox, not--",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Not Hasidic.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I was orthodox.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I mentioned to you that I-- my father wanted me to go to Palestine.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So shortly after his death, I went to Kibbutz [INAUDIBLE] in Kosow.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I spent over a year to get a preparatory, [PAUSES FOR 3 SECONDS] an, an obligatory training for eventually getting a certificate to go to Palestine.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I did all kinds of work, from picking fruits in the summertime to making [NON-ENGLISH SPEECH], rugs.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And whenever they needed me to-- for any kind of work-- that's was the idea-- I was trained to go to Palestine to live on a kibbutz.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And this was a prerequisite of getting a certificate to go to Palestine.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I was never chosen and never got a certificate, because there were other people that were ahead of me.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And the British government at the time gave very few certificates.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "They-- the British had the mandate over Palestine at the time.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They had their own numerus clausus.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Well, only a few people were permitted to go to Palestine.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I was not the lucky one.",
      "word_count": 6
    }
  ],
