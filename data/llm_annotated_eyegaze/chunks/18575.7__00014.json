  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Next is a little boy named Adam, who is the son of the lady holding him, my aunt, and my uncle, my father's brother, Sojnek.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Next is a couple, my aunt, my father's sister, Adela, and her husband, who immigrated to United States long before the war, and passed away.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "The top row, starting from left to right, is Rena, my father's sister.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Next to her is her sister, my aunt, Tofila, with her son, also called Adam.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Next, the couple to the right are my grandfather-- his name was Godel Borensztejn-- and his wife, my grandmother, Pesa.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The picture it was a composite taken by my cousin, who passed away in United States, from individual photographs.",
      "word_count": 19
    }
  ],
