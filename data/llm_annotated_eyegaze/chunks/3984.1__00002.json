{
  "stem": "3984.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "This I remember-- the first picture.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "What-- what happened at home, I don't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "But I remember that my mother and father like a lot of watch-- watches-- on the-- on the-- on the wall.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "And we have a very old, very nice watch.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "And every time it was-- the watch was moving-- you know-- not moving every time-- every 1/2 hour and every hour it was-- tells the time-- you know-- 1:00, 2:00, 3:00.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And I remember this, even in the night.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "And this give me-- until now I love watches.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "And I have a lot of watches.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "And my husband like too.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "And it is-- it give me a very good feeling that I-- I hear watches.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "Until now, I have in the kitchen a very special watch.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "A clock-- but my mother-- [PAUSES FOR 3 SECONDS] --was sleeping.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "When she was going to sleep, he was-- take the watch with her in the kitchen.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I loved this very much.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] And I love my mother very much.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING] I think of her very, very much-- my husband, the children-- [CRYING] And everybody love her.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "She was a very special woman.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "[CRYING] She died almost 95 years-- 95.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "She was by us 20 years.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "My husband take care of-- very nice.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And my children take-- love her very much.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] She passed in-- in '87.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "I was in Israel before she was very sick.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "I spend with her more [NON-ENGLISH] I came to her, and he was very sick.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And I wash her.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "I make her the bed.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I feed her.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "I give her every-- and I-- I take only two-- two days off.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "I went to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] But I love her very much.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "He was a very special, very good woman.",
      "word_count": 8
    }
  ],
