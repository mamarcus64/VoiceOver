{
  "stem": "3848.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And that's where I spend the rest of the time until the war ended in 19-- I was still there until 1946.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Can you tell us why you were there until 1946?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We were a group of people sent to work over there.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Any kind of work, fixing houses, delivering stuff to the-- I-- I had a pass to go into the camp, not camp, but the prison.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The minimum of that prison was 25 years for political prisoners, Russian political prisoners.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I used to transfer materials from the prison into the part where we used to live.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We were sort of free.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But you couldn't go any place.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It was a small town, very small town that they used to work for that particular prison.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Everything in that town was to support the prisoners.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "So they had some civilian people working there.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "But being there were no men, so they took us as the refugees, in Russia, the Polish people, and they send us there.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "It was a terrible place.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "The climate was very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "Out of the 200 people they brought over there, only 20 remained.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "I was one of the 20.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "I myself was-- I-- I was sick with malaria in this particular place where every year in May, I was in the hospital for one month with chronic malaria that I picked up over there.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "The rest of the people from the 200, they sent them back.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Some got very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And they send them back into deep Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "What happened to them, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "Just about 20 people remained in this place until the end of the war.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was a hospital--",
      "word_count": 5
    }
  ],
