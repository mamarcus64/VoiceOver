  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And we knew that there was an attic in the building that we had prepared.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "My parents actually were instrumental in it.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Such an ironical twist of events.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So my sisters and I ran immediately-- went immediately into the attic.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they would already a number of people there.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And we were the last to come in.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And then we-- they closed up the attic with some bricks.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And we knew we were separated from our parents, and we didn't know what happened to them.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we were in that attic several days.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we heard the dogs going up and down.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And we heard the shouts and the footsteps of the Gestapo people, the SS men.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And here we are in the attic, that was about two feet high.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Everybody lying, couldn't sit up.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And all we had there-- we were totally unprepared-- was one bucket for, for emergency.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And there was a big, tall bottle of cherries.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "The ones that you made [? vishnak ?] from.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And I remember, I put myself in charge of the cherries.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I would dish out one cherry per meal, per person, to sustain us.",
      "word_count": 14
    }
  ],
