  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 54,
      "text": "And she was killed that Sunday afternoon.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 55,
      "text": "[PAUSES FOR 3 SECONDS] My grandfather almost went to that ravine, but some Pollock said to him, they don't want Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 56,
      "text": "They recognized him because he had a beard and this.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 57,
      "text": "He immediately ran into a stable and hid himself.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 58,
      "text": "It was a miracle.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 59,
      "text": "It was a miracle of God.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 60,
      "text": "And Sunday night, the-- Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 61,
      "text": "Marczeniek came and told us what had happened to his wife, because we were very sad.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 62,
      "text": "I recall going with my dad, picking up her body out of the ravine.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 63,
      "text": "There was hundreds of Polish killed and shot dead.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 64,
      "text": "And we buried her on Monday ourselves.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, it had nothing to do with it, no.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "That was not why she was-- they just-- the Ukrainians were always-- like the Bosnians, and the Muslims.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And that's the reason they just picked to wipe out the Poles at the end.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They figured this is their last hurrah that they could do.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And by Thursday, we were-- we were liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "We saw the Russian army come in.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Sad, happy, and sad, because [PAUSES FOR 3 SECONDS] we had an idea that there's nobody left.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I mean, just a few of us, you could be happy for yourself.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But still, it-- you lost [PAUSES FOR 3 SECONDS] generations of Jews, family, friends.",
      "word_count": 14
    }
  ],
