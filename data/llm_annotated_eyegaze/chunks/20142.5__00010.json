  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And let's attack the Germans and release the people.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And there were six out of the group of the 360.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "We disperse 300 people, at least.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "It was not a simple thing, because there was the first encounter of underground with Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was quite well organized, because youngsters were-- we did not have any special weapons.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And the weapons that we had could not be totally used for the purpose [BACKROUND NOISE] of freeing so many people.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But we-- they were using stones and youngsters primarily to hit the helmets of the escorting Germans.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "There were about 18 or 20 Germans with the guns in their hands.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "But with heavy tunic and helmets and escorting them from the [INAUDIBLE] Street to the Umschlagplatz",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I was with the group of [INAUDIBLE] waiting for to attack the people.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "They-- we-- we knew that they started to move the people from the little place on the-- in front of the Jewish community to Zamenhof Street to they assembly this group very early in the morning.",
      "word_count": 36
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And around 9 o'clock, they started to move the people around.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "When the Germans were hit with-- on the helmet with a stone, they dropped the guns.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And many of our boys were just waiting for the moment.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And they picked up the guns and pointed at the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Of course, they started to scream, don't shoot!",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Don't shoot!",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I didn't do nothing wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And we took off the tunic-- their coats-- their tunic, their ammunition, their shoes, and let them-- left them running in their underwear.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And whoever-- whichever was of them hit and hit badly was by the approaching Ukrainian unit attached to the SS for the purposes of the [? traditional ?] Warsaw ghetto.",
      "word_count": 30
    }
  ],
