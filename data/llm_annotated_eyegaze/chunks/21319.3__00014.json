{
  "stem": "21319.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Look how clean and beautiful it is, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And they told us to jump out from that-- and we jumped out from the train.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And here was the man who were-- the selection, the Sonderkommando.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "The one who takes all-- all the packages, you know, and the people and this.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "Had very sad faces, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And I didn't know why, what it is.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "And I came over to someone, and I said, why are you people so sad?",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "It's so nice and clean here.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "We were in such a terrible, filthy place.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "So one said to me, did you ever hear of Auschwitz?",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "So he didn't say nothing more.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "He didn't want to tell me about the gas chambers, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "I was so impressed, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "And then they took the children on-- on trucks, and the grownups, they walked.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "So I said to one man, would you mind if I go with mine child?",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 22,
      "text": "Please.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 23,
      "text": "She's a small child, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 24,
      "text": "So he gave me that look, because he didn't want to tell me, but the children go straight to the gas chambers, you see.",
      "word_count": 24
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 25,
      "text": "So somehow, somebody above there was watching.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 26,
      "text": "I don't know who.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 27,
      "text": "My father or somebody.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 28,
      "text": "And he took me, let me go on the-- I was the only grownup among the children on the truck, and the-- we came to-- they drove to a building which-- a big hall where 2,000, 3,000 people can go in very easily.",
      "word_count": 43
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 29,
      "text": "I didn't know it was the back of the gas chambers, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 30,
      "text": "And it was so clean, and the lights, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 31,
      "text": "And we came in.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 32,
      "text": "We're all so filthy and dirty from-- we were 10 days in filthy and in dirt, you know?",
      "word_count": 18
    }
  ],
