  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And this child was there the whole day, under that quilt, with the bed all made up, without-- I don't know how she-- how she was getting air.",
      "word_count": 28
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "But I meant in the actual woods, in the huts and the underground thing--",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, maybe-- you know, they probably were stealing them from the-- you know, from the peasants.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Because I mean, nothing was really locked.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "I mean, and these peasants lived on pieces-- big pieces of, you know, properties.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And everything was done with a shovel and very primitive-- you know, with the saw, and the shovel, and whatever.",
      "word_count": 20
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "They were no combines.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "There were no tractors.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "There were nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember one was, you know-- one was this [NON-ENGLISH] that we were hidden.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "One was [NON-ENGLISH], where we moved after already, after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember the others, no.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Boy, I didn't think that that's--",
      "word_count": 6
    }
  ],
