{
  "stem": "11175.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "We found a place and we-- in [NON-ENGLISH] 31, I still remember the number from that [NON-ENGLISH] 31 when we came in.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "Because apartments was empty.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "There was taken out people who that took them out from before that was empty.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "But we went into an apartment, it was there.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "They lived there in their apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And we went in the morning to say-- you go out, some of the people-- we asked people, which there were in the ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "You have to combine yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "You have to combine yourself with groups, and go out to work.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So, we-- we went into a group, you know, this is the [NON-ENGLISH] group.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So they took us to an older apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They take out the furnitures and the stuffs and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "A lot boarded up in the trucks, when they-- the German trucks.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they took it away.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Where they took it, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I don't want to know at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Was [NON-ENGLISH], was a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Was one from the group, he was the leader of us, and he took us there.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We connect ourselves with that group, just to connect ourselves.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Because you had to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "You-- you-- either you have to lay down, hidden the whole day, either you have to go out.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And by going out, you see, you could have the possibility to buy something, to bring in something to the ghetto, and you know to-- to keep up yourself.",
      "word_count": 29
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "By buying from one to the other-- that's all right.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "By buying and going-- and we were standing and selling these-- these flowers, these potatoes, this bread-- it was bakery.",
      "word_count": 20
    }
  ],
