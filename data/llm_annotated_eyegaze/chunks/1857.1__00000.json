{
  "stem": "1857.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "How they say?",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The wives usually say my husband thinks he died and he's in heaven when-- when they retire in Florida.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "It was-- it's a good life here after all those many, many years of hard work.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "When I started working I was working seven days a week.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Because we came penniless.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Lewis Fagen.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My middle name is L-- Ludwig, which was my name in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My previous name was Ludwig Faigenbaum.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They called me Ludek.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "November 28, 1920.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "74.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Krakow, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Jacob.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was Natalie.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I had a sister, Janine, who perished during the war, practically at the end of the war.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father, as a young boy, at the age 16, was apprenticed to a goldsmith, where he learned the trade.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Then the First World War came, and he served in the Austrian Army.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And right after the war, he was still working as a goldsmith until the age of 23.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "At the age of 23, his brother, who was working for a firm dealing in bicycles, told him that this is a great business in Poland at the time.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And my father quit goldsmithing and went into bicycle business.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He opened a store with bicycles, music instruments, [PAUSES FOR 4 SECONDS] phonographs, records, sporting goods.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Eventually it developed into three stores in Krakow until the 1930s, when the depression hit Europe.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And he got into financial difficulties, and eventually, at the end of the '30s, he had to give it up.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And he became a distributor of the biggest Polish factory of bicycles, distributor for all-- all of Poland of Kaminski bicycles.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And he also participated in manufacturing the bicycle parts.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, [PAUSES FOR 4 SECONDS] at the time, my family was quite well to do.",
      "word_count": 15
    }
  ],
