{
  "stem": "3361.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I was in that time 30-- no, '39 is it-- I was 15 years old, something, about 16--",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, I went to-- I went to go to-- I went on the train to go to Russian border.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Then the Germans came on the train to take us off from the train where I was going to leave--",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I told him.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I said, I cannot live here anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I cannot look at that, because I'm going to bust.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So he says, OK, leave.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And I-- he was crying that I left, because he was to me like a partner, not like a boss.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, I-- the Germans came on the train, so I jumped from the train.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I didn't want them to catch me while the train was going.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "On the train?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "About two, two days, because I jumped on the train and from the train.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Otherwise it wouldn't take me so long.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "But I was jumping on the train back.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I had whatever I could carry with me.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Some clothes, that's all what I had.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was already end of the year, by November.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "About starting winter already.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Cold.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And then November/December.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] Somebody there?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And I went--",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "On the train, jumping off--",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Jumping off the train, on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Finally, I arrived in Lviv.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "In Lviv, they, they, they took--",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Lviv, Lemberg, Lviv.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "This is in-- the Russians took a part from Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Used to be Poland, but that time Russia already there.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "So they took me to a coal mine in Donbas.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The Russians, and they sent me to Donbas to work in a coal mine.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "OK, in beginning they were treating us nice.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Then they were working the coal mine, we--",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "With other people who were from-- like me.",
      "word_count": 8
    }
  ],
