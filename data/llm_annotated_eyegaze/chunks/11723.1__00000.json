{
  "stem": "11723.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[AUDIO TEST TONE]",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Agnes Margaret Vertes.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was born Agnes Margaret Katz in Budapest, Hungary, September 4, 1940.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I come from a religious Jewish family, Orthodox.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "On one side of my family, [PAUSES FOR 3 SECONDS] on my mother's side of the family, they were not Hasidim, but very religious.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And my grandfather had a beard.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my grandmother wore a sheitel.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And generally, that section of my family was very, very observant.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "My father's family, the Katzes, were also observant Jews, but they were more modern.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They wore modern dress.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And they wore-- they were educated.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Not to say that the Gluck family, my mother's family, were not educated, but they were educated in Hebrew, mostly in yeshivas.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And my father's family were doctors and lawyers, et cetera.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "More modern, taking advantage of the [PAUSES FOR 3 SECONDS] equality that was the-- [PAUSES FOR 5 SECONDS] that-- that was available to the Jews in the 1900s in Hungary.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My mother was born Irene Gluck, 'Glook' in Hungarian.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And my father was born Armin Katz.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was born March 4, 1914, in Nyirbator.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "You don't want me to spell that, do you?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It's spelled N-Y-I-R-B-A-- with an accent on it-- --T-O-R.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And that's in the plains of Hungary.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It's a community of, I don't know, maybe 10,000 people.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And it had a-- a fairly sizable Jewish community, compared to the-- as compared to the entire community.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "My father was born in Maramarossziget.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And-- but he was brought up in Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "My grandparents, Katz, were first cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Leopold Katz and Cecilia Katz were first cousins.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And the story goes that my grandfather was marriageable age.",
      "word_count": 10
    }
  ],
