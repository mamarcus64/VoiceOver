{
  "stem": "2539.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "They lived a few houses away from us.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He was a Russian, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "He was Russian-- a Russian from the Czar-- still-- a old Czarist fellow.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But he-- so I slept there one night.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And he went and told my father's other friend who was a tax-- from the taxation office across the road.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "He went and told Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Schmigero.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And they hid me there for-- I don't know how long-- a few weeks.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "From end of August-- from the 20th of August, 1942.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I left Lutsk for Rovno on a-- this Mr.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Schmigero, who hid me, with his second wife, gave me the identity card of his daughter who was my school friend.",
      "word_count": 21
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "She went--",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In Lutsk-- in Lutsk, in '43.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In '43.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He gave me ID of Halinka, his daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And-- but first of all, he took me to go another family, because he couldn't hide me any longer.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "His brother-in-law, who lived in the same house, in a different apartment in the same house, spotted me.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And he was married to a gendarme-- a German woman.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And he came.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And-- oh, I went for a-- for a-- for a plate of soup from this-- from the-- I was lying on top of the house on the straw.",
      "word_count": 28
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "What do you call it?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Cellar?",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Not cellar-- cellar's the under-- and attic-- Hay-- oh, the attic.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, it wasn't an attic.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "It was straw.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "A hay-- like the haystack.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Haystack-- on top of the house.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, at night--",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Oh, on the roof?",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "No, not on the roof.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Under the roof--",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Under the roof-- oh.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "--between the roof and the roofs of the--",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "The eaves?",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Under the eaves?",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "The Polish-- in Polish, it's called [POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how it's called.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The eaves-- under the eaves.",
      "word_count": 5
    }
  ],
