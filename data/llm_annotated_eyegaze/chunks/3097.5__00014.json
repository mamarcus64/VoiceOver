  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] He said, what would the child do without the mother?",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "The man says, so this is why I had to kill the baby, too.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And the atrocity was very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And they killed about 42-- 46 people.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "My aunt was there, but at that time, she was not in the building.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "She was by her sister.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And they took the people, and they-- the-- the wounded-- there were a lot of wounded people-- they took them to Lodz, to a special hospital because they were even afraid to take them locally to the hospital in my city there, in Kielce.",
      "word_count": 44
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Because they didn't believe.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "They took people from their train, Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And when the train was going, they threw them out of the trains.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "It happened not only in Kielce.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "It happened in Poland, in all Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I didn't.",
      "word_count": 2
    }
  ],
