{
  "stem": "24554.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "So I started in some private, uh, firms to work-- help.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And I started work at home.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "You know, my father had a business.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Actually, not my father.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "It was my oldest brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "They have a business.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "They sell corks.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "You know what cork is?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "In the bottle, what you put.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So I work partly at home, partly help in different firms.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They take somebody else.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't more of [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They don't guarantee you after the-- not the war, the army that they'll take you back.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was nice.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And [CLEARS THROAT] it was a-- in the beginning, it was very hard, very difficult.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "My father, he wasn't-- he was a very good employee, my father, like I am.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But he wasn't a businessman, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I am a very good worker.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I am not a businessman.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "It is my oldest brother-- the two oldest-- that was a good businessman.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The [INAUDIBLE] the brother in Israel they weren't the same-- not businessman.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They were worker.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So it was in the family, so [INAUDIBLE] [LAUGH] mixed up.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So and I was working up to '39.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Can I f-- Yes, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Up to '39.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My mother, she died-- some trouble with her heart-- in 1938.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So I stayed at home with my father and for me older brother.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He was married, had a little daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So we stay in the house-- yes.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "My father, I, and [INAUDIBLE] up to 1939.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "In 1939, I was in Prague for something for the business-- I don't remember.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And it was-- come Hitler in-- in Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Actually, in Prague.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It was in March 1939.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I was in the [NON-ENGLISH] Square and have seen the German come in.",
      "word_count": 13
    }
  ],
