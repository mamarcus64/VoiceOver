{
  "stem": "19352.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I saw my grandmother was shot in front of us.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "She was a nurse in a-- and a wife, what they call children-- a wife.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "A midwife for the poor, for the poor.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "As she was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She was 86 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "How you can forget those things?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "How you can forget those things.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And my uncle who lives in-- together with us has two daughters.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He had three daughters.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Two daughters, age nine and seven, were taken away from him.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "My aunt was taken to the-- another ammunition factory.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "The-- he was-- they want him to-- he was a young man.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "They want him to go with them, to work for them.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He said no, I'm not going.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I'm going with my children.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And he died in Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Now, this-- from our city-- from other city, they-- they were-- all of them went to Treblinka.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "The city where my husband lived, Wadowice, where the Pope was born together, in the same city, where my husband was born.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They were good friends.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So there it went.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So it was closer to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They all perished at Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In our city, in Kielce, Radom, and the city closer to the west-- to the east went to Treblinka.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And others, it was-- thousand of others, camps.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Smaller and bigger at ours camp.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, the-- the ghetto was open still open?",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was working by Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Cahan.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "One day I was walking home.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "The-- the Germans-- [PAUSES FOR 4 SECONDS] [SIGHS] --caught me.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And they ask me to go in to clean the offices there.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And when I clean up one floor, they brought dirty water and they pour on the floor.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I was asking him what he is doing.",
      "word_count": 9
    }
  ],
