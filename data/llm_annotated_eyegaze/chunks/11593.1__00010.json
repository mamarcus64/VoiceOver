  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And something was wrong with the commissar, with-- the next day, they took him out.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They hung him in front of everybody as an example to obey, you know, the authorities.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, they did not disobey.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The guy was caught in the middle.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "One guy says, you work for me.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The other guys says, you work for me.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So when he went to work for the other guy, the commissar hung him.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And I have a picture of that you can see in there.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "It describes the details.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That went on--",
      "word_count": 3
    }
  ],
