{
  "stem": "11797.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 35,
      "text": "We were showing our bodies, that we have no sores, no.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 36,
      "text": "We're like, naked now.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "But no sores, no-- no any kind of diseases, no.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "And he picked out this one, they go over here.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "This one, go over here.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "This one, go over here.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "Go on the-- on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 42,
      "text": "Go on the-- on the wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 43,
      "text": "Go over here now.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 44,
      "text": "And that's how-- I lift up my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 45,
      "text": "We lift up.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 46,
      "text": "And he went, fortunately, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 47,
      "text": "Next.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 48,
      "text": "And all this line we were-- we were my brothers-- brother, my-- my-- my cousin, now, that particular-- 10 line. 10 people in a line.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 49,
      "text": "We all were saved.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 50,
      "text": "And afterward, they took out maybe, on that trip-- I don't know exactly how many they took out now.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 51,
      "text": "Quite a bit.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 52,
      "text": "And all the people, there was a few women there they picked up in the road, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 53,
      "text": "There was a few woman.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 54,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 55,
      "text": "Every-- ?] [? kill-- ?] they find a baby.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 56,
      "text": "A few babies they found, that are hid-- women hid in their-- you know, between their bosoms, baby, tiny baby.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 57,
      "text": "Bring them all up and out.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 58,
      "text": "And they are all marched away inside.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 59,
      "text": "Which we never saw again.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "We remained there a whole day.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "If I'm not mistaken, I think another day.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We were there but one day or two days.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I can't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "But I know every minute I know when we going to get out of here?",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "When we going to get out of here, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Just outdoors, you were staying?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We were outside the gate from Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And they were writing our numbers down.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "My number is 262-- 26203.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "The number-- the number they write down, the number, my brother's number.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They were writing our numbers down.",
      "word_count": 6
    }
  ],
