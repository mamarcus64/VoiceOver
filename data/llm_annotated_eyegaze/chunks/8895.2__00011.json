{
  "stem": "8895.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And on the boards were little like, like, barrels-- little, little pieces of barrels with maybe a pint of water.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And soap was as much as a little piece of chocolate.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Our clothes was taken to the, to the, to the stove, to the stove.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was very, very hot so the lice would die.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have the lice in this, in this camp.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But in, in, in the prisons, we looked for lice from morning till night.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "People had lice, lice in their eyelashes-- they pulled them out-- and, and pubic hair-- they pulled it out.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It was terrible-- clothes lice and, and, and body lice.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "The only person who hadn't lice was my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "She never had lice.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "She had such slippery hair, they couldn't get onto her.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And then they, then they shaved your head when you had lice.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "It's the best thing to do.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Strangely enough, not so much.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I had-- on the way to Russia, to first prison, this was [INAUDIBLE], the first prison was [INAUDIBLE], I had-- I think I had dysentery.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I had blood in the stool.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And, and, the, the-- if my mother wouldn't have been there, I wouldn't have made it.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "You didn't have any toilet.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "There was only a little, little round thing going out of the train-- no, no windows, nothing.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "We came into this train.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "There was still-- was still not clean from the animals who had been there before.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And men died like flies.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "Women are much, much stronger.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "You wouldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And my-- she pushed my insides back, you know, with her hands.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And I don't know how she managed with us.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "We had nothing and all the rubbish.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "I don't know how she managed.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "Without her, I wouldn't have been there.",
      "word_count": 7
    }
  ],
