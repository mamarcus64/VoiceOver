{
  "stem": "19352.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And we were very lucky to have them in Czestochowa.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So we receive our money.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we receive also clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And-- and they helped us to find people were-- they're missing or something.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And we finded out from people-- where Mother used to feed them-- that they were in-- in [?",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Terezina, ?] in Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Who was there?",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "My brother was there.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I went-- everything was for free at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I went to bring my brother back home.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "My mother was crying because the father, and my brother, the [INAUDIBLE] son, the only son.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And his name was after her father, who was a rabbi.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I found my-- my-- my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Then I went-- I-- they told me to take with me some cigarettes.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "The cigarettes were very-- well, very expensive there in-- in Czechoslovakia at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So we came in to-- to-- oh, on the border.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Oh my god, I forgot the name.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So they show me where to go to.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I ask him-- I wanted to go to Prague.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "From Prague, I would know where to go further-- to Prague.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't know where the-- where I am, in the south, in the back, or the thing.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And they gave me a place in the train with some inmates from Czechoslovakia, from-- from Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And they have a special wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Attached to these wagons, the-- what do you call those wagons, these wagons for transportation, materials or something like that?",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And this was a wagon specially for them, a sleeping wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And they have cocoa.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They have white bread.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And what else they have?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "What I'll-- I couldn't understand.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "The first time I had white bread, and I had [PAUSES FOR 3 SECONDS] a cocoa.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Cocoa, I have.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    }
  ],
