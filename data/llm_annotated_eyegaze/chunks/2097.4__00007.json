{
  "stem": "2097.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Winter arrived only six months after.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "When they arrived, already the children grew out the clothing.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And we had nothing, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "But we had the covering, the blankets which are-- the down covering, we still use today, the pillows.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "The dishes, for a while, we were using.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "For the children, we had to buy clothing.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And one of my husband's cousins greeted us at the airport and rented, for us, a place on Crown Heights, on Union and Bedford Corner.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "The house was a little bit run down, but it was very good.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Because for $85 a month, the rent wasn't too bad.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "I made a week, 60 gross.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "So we got about 45.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "I had to work two weeks for the rent.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I didn't speak any English.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I was working.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And at first I was working in a factory, putting pockets on a-- since I learned how to sew, I mentioned, as a child-- putting pockets inside on pocketbooks.",
      "word_count": 29
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "It was a pocketbook factory.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Later on, I went to work-- since I know how to knit, I know how to fix a knitting around on a sweater.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I went to work in a factory too, mending the sweaters.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "In the meantime at night, I went to school to learn English.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And I took a high school equivalency in 1971.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "The children, as I said, all the time, went to school at the first day.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Actually, we arrived Thursday, and Monday, the children, they went to school.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "We went to school also, to learn English, night-- at night.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And-- and the following year in 1967, in January, I started to work already, in an office, Hertz Rental Truck in Manhattan, 660 Madison Avenue.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I was opening the mail for two months.",
      "word_count": 8
    }
  ],
