  "elapsed_s": 422.8,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And, um, one time-- she-- she was a very, very nice woman, very intelligent.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And then she write me one time for dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And, um-- she asked me, what is my life?",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I told her what it was.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And then she said, if you want to live here, I could give you a home.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You can live here.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And I told her that I have a friend.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "He is-- Leon Klappholtz, a friend of mine.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "He is also in the-- in the coal mine.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And he is wounded, leg.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "If you want to help, I say, if you give me a [NON-ENGLISH], [NON-ENGLISH] means a piece of paper that at least I can go.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Because I don't want to-- I don't want to lay down under the things.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I want to go normal.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "She give me, and she stamp it.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And I was going by the train to-- to my friend.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Who He was still in the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And I talked to him.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I find a woman, a very nice woman.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "She was an older person.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And, um, I think I can take you out from here.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, I said, how you feel?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And he said it's OK, now they got several operations.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "He's got-- he's got to [INAUDIBLE] several operations, but he fix it already.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "I said, in four weeks, he can go out.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "I told him, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "I will try to-- I will-- [DRINKS] I will try to, uh-- to come back in a-- a week, or two, or three.",
      "word_count": 23
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I will see when I can come with a [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "I need a paper that I'm sent from this [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And, uh, I got back.",
      "word_count": 5
    }
  ],
