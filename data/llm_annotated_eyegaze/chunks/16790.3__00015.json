  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "So I felt that it was a worthwhile job.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "I also felt that I owed this country a tremendous amount that I can-- a debt.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "I could never repay them.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And that's one of the reasons why I stayed in, in, in the-- well, the regular-- why I joined the regular army and stayed in the reserve program.",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "And I would be on active duty for 110, 120, sometimes 130 days.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "I enjoyed it.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "Plus I really felt I was doing something worthwhile.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "And in Germany, I did a lot of things for the US government that I thought were absolutely necessary to bring this country back into the, into the fold.",
      "word_count": 29
    }
  ],
