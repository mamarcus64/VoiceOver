{
  "stem": "21817.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And we start-- they started to expand the railroad station.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "But we had no equipment, machinery, or something else.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Everything had to be done by hand.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "They had railroad truck and there were small, small cars on top.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And we used to by hand, pick up the sand, and throw it in.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And that's the way we worked 12, 14, 16 hours a day.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "But the worst thing was until now, until that point, we had to pull those human beings, soldiers-- put in-- we had blood on our hands.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Threw them in-- [CRYING] --in those ditches, or, or those big holes.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Mostly they tried to use those holes which were bombs for exploded.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "When a bomb exploded, there's a hole maybe 50, 75, to 100-feet deep.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "Used to throw it in.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Just, just, just like dirt, nothing else.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They were Russian soldiers.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The dead soldiers were Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The Germans, dead soldiers or anything else, we never saw because they picked them up themselves.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "[CLEARS THROAT]",
      "word_count": 2
    }
  ],
