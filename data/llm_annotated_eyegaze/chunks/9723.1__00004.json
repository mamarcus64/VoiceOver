{
  "stem": "9723.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My father, for example, finished medical school in Czechoslovakia in Prague, because Jews were not allowed, uh, to attend medical school in Poland.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Once he had his medical degree, he could, uh, practice in Poland, passed the uh, license examination.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "But he ad to go abroad to get his degree.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "But personally, I don't remember, uh, any incidents of anti-Semitism before the war.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I do remember a number during and after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "But before the war, I'm sure that it happened.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "But I-- I can't think of anything specific.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not specifically, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But it was a common topic on-- of conversation.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Apparently, shortly before the war, perhaps a year before the war, the, uh, laws against the Jews were becoming more common Uh-- they were trying to restrict production of kosher meat, I remember, and things like that.",
      "word_count": 37
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Perhaps what was happening in Germany at that time had some influence over what the, uh, Poles were thinking.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember any specific-- any specific restrictions or personal, uh, incidents.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I, I-- I had a number, perhaps an equal number, of non-Jewish friends and Jewish friends.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Uh-- most of the neighboring kids in the immediate neighborhood, I guess, were Jewish.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "But not-- not all of them, because I do remember non-- non-Jewish friends.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "In fact, I would say that my best friend at that time in first and second grade was-- was a Catholic boy.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Uh-- the schools were, uh, non-- non-sectarian, non-religious.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "But at the beginning of the day, uh, everybody said a prayer.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And, uh, I was instructed specifically that when we were saying a prayer not to cross myself.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I'm just supposed to stand and not say anything.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "They told me to do that.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Not in school, no.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I had Hebrew lessons privately.",
      "word_count": 5
    }
  ],
