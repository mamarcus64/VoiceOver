  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] I don't know what you did with the money, because there was nothing to buy except potato salad and what.",
      "word_count": 21
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "That was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "You get up.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "It was still dark, 4:30 in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] in they came, you know, to wake you up with the guns.",
      "word_count": 13
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Roll call.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "You get up, and you go to work.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "She was in charge, Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Felix.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "She was in charge for-- because she spoke about-- she was a professor of English.",
      "word_count": 15
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "She was a-- English.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "She was brought from England to Bielsk to teach in the university.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "That's how she wound up, you know, in--",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Not now.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Not now.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "When we-- when we continue.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
