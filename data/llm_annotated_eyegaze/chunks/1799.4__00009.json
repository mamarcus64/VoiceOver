{
  "stem": "1799.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "She was able to escape the-- I don't know how-- the pursuit of the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "She was never caught.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Lee Reinis, R-E-I-N-I-S, originally [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I changed my name from-- when I came from France to this country, the day after I got here, by going to the social security service and give them a different name.",
      "word_count": 33
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Because my name was Gerhardt Rosenzweig, it could not be pronounced in French.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I had problem spelling the name to them and they spelling it.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I made the decision at the time to change the name, which I'm-- I've been sorry for for the last 30 some years.",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I have to excuse myself, but I have to go to the bathroom.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "OK, I came to United States in February of '47.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And that is to join an aunt in San Francisco, and husband, whom I had met as a child in Germany.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I had not seen her since 1937 or '38.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And I lived in her house, although I got a job and eventually moved out.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Moved-- they lived in Sausalito, which is a community north of San Francisco, first community north of San Francisco.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And it was quite a marvel for me to see that community as I arrived from-- from Europe, because it is so idyllic.",
      "word_count": 23
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And my first impression has never left me of that particular place.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And I set up a-- I went to school.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And I took a job.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I-- what else did I do?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I got married too soon.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I met my wife and had children.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "What was- what was her name?",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Paulette.",
      "word_count": 4
    }
  ],
