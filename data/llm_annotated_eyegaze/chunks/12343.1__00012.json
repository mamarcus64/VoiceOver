{
  "stem": "12343.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 32,
      "text": "We make this-- here-- here was a table.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 33,
      "text": "Here was a bed.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 34,
      "text": "And you opened all under-- under the table.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 35,
      "text": "Then ran under the bed.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 36,
      "text": "Then make hole [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 37,
      "text": "Catch the Jew, the boys.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 38,
      "text": "They ran around to the barn.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 39,
      "text": "Cover this.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 40,
      "text": "And cover this, nobody will notice.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 41,
      "text": "After all this, come to learn, too, they said they have to make a [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 42,
      "text": "Long time, and they knock the door, and took us all away.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 43,
      "text": "Oh, yeah, there's not the girls.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 44,
      "text": "They did-- the Judenrat, [? you see, ?] the-- the-- the community.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 45,
      "text": "Because they have to get the Germans, how many people for a transport.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 46,
      "text": "[INAUDIBLE] Gestapo, to Treblinka and other places.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 47,
      "text": "They pick people that they like.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 48,
      "text": "You know, they cannot afford to pay me.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 49,
      "text": "They figured they got more money, maybe they can buy you off, not to go.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 50,
      "text": "They put my mother on the list.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 51,
      "text": "I look my mother on the list.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 52,
      "text": "I said to my partner, to my uncle, I cannot see my [INAUDIBLE] sister.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] you sister.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "He said, then he went to-- to leader for the community.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "He said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "He said, why you took my sister?",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Then he said to him, you kick him.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "He said, you can kick him out.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "Even though he works for the Gestapo, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "He said, I'm going to Gestapo.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "He went to the Gestapo.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "He said, why you send-- that is, he works for me.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] They let us stay.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 11,
      "text": "They let us stay.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 12,
      "text": "And they can do nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 13,
      "text": "He kicked him.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 14,
      "text": "Because-- he kicked him because he wanted to do it.",
      "word_count": 10
    }
  ],
