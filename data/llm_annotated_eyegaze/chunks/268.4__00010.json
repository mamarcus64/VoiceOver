{
  "stem": "268.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "I want to go with you and I didn't want to go.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 5 SECONDS] And besides, I'm not even 18.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "I said Mom, I'm not 18.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "She says, you are.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "You are 18.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "This was-- and it took less argument than what I'm telling you now.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "My story is perhaps longer than the whole argument took.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "The argument probably took seconds.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "I said no, I don't want to go.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "She said yes, you go and she sort of pushed me.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "When she pushed me out, I sort of half stand up and she pushed me.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "I fell down and I got up.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "And-- and before I know it, somebody else kicked me.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "And the SS man-- he grabbed by my neck and threw me over to the next bunch.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "And I-- and I kept looking back.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "I said, Mom.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 38,
      "text": "And I didn't see her anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And I'm among a group of men and they ask us, you're going to march over to the other side of the field in five and five, you know.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I kept looking, where is-- where is Mom?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And this group was taken away, too.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Then, they ask us again to sit down.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I hear people marching.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Outside of the field was a small road, not wide enough for-- for-- for-- for even a horse and buggy.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "But just a foot-- a path, a path.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And they're marching along the path and I see women and children marching.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And all of a sudden, I say, well, then maybe Momma is among that group.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I-- you know, I looked in that group and I see women and children and they're-- and they-- they struggling and marching and carrying babies.",
      "word_count": 26
    }
  ],
