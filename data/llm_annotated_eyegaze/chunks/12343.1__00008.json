  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 22,
      "text": "Then I went to other place work.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 23,
      "text": "[INAUDIBLE] what used to belong to the community-- leaders from the-- from the Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Judenrat.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And I asked him, why you take [INAUDIBLE]?",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] the paper from the German Gestapo, and then after take me to work.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "No, you don't do it.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "He did it for his friends and family.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Not the family.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "He's [INAUDIBLE] other state, other city.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Then I said, what to do?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "I said.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "I got no other choice.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "I quit.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "Because I don't like, like this.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "I went back to my uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "My uncle is the best tailor.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "He used to work for the Gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "Every things.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "The best suits.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "And they said-- used to send it back to Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I work for him long time.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] all the time to make a transport out.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH SPEECH] ?] Over there was the main-- main-- the main stop to send [INAUDIBLE] Auschwitz, Treblinka, other-- other places.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And then I said, long time I [INAUDIBLE] on the list.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "There were [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Let me go back.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "It used to catch [INAUDIBLE] to work.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Long time.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I know they knocking the door, in the night, [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "I went to my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Because I told you, lived in our city-- in our place, [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "Went the middle-- in going-- [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "In the morning, on the hill-- on the [INAUDIBLE] cover.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "And I said, you sit up.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "She sit up [INAUDIBLE] covered.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "[INAUDIBLE] family.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "That's how I hide myself like this.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "That's not-- not-- was not close.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Jews was together, one place.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They don't go out because [INAUDIBLE] close.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "They took away all the big-- big houses, the newer houses, for the army.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Just there were side streets just for the Jews.",
      "word_count": 9
    }
  ],
