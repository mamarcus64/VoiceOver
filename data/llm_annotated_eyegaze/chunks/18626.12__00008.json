{
  "stem": "18626.12",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 101.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And he says, Morris, [?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Moshe, ?] drink a cola too.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "Tasted very good.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "But after I came in the Bronx, for two weeks, I couldn't sleep from the Coca-Cola.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "It kept me awake.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know that they had caffeine.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I started work for my uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He had a shop on the Bowery.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And he cried very much that he lost my father, his brother, and he lost his father, my grandfather, and he lost his sister, my aunt, in Lithuania.",
      "word_count": 28
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And he says, at least, he says, some of my family survived.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "I'll try to help you what I can.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I'm not a rich man, you see.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And he gave me a job in his shop.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "I was making $30 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And he says, $8.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "I rented a room on Morris Avenue in the Bronx.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "You'll-- you'll pay the landlady $8 a week.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "You'll give my wife-- that was his second wife-- you'll give her $8 a week for making your breakfast.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And when you come from work, you'll have dinner with us.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "So it's $16.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "And you [? live-- ?] every day, it'll cost you $0.50 on the Bowery.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "You'll buy corned beef and a drink.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "It'll cost you $0.50.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "So you'll still save up, he says, maybe $8, $7 for the bank every week.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "And you can go in in a movie, and you can go sometime and take a haircut.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "And he took out $5 from his pocket.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 24,
      "text": "And he says, Morris, a man in the United States doesn't walk around without money.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "I came to the United States, I didn't have $0.05.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I wrote a letter and I wanted to send it over.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have money for a stamp.",
      "word_count": 7
    }
  ],
