{
  "stem": "7273.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, as I said, it-- the Germans sort of were all around the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Wanted us all out.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And we always prepared, sort of, it was a little trap door, where we went down, like in a little cellar.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "There we were sitting.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I'll never forget it.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "On one side, my late brother, on the other side, me, and mom in the middle.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And we were really shivering.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It was February in Europe.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And all of a sudden, we heard the noise and the stamping, and the Poles said, here they are sitting, the Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "So we had to come out.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And we were gathered in the center of town.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "And it went very, very quickly.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "We were divided.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "My mom was sent to one side, me to another side, and my brother to another side.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And what also partly saved my life, my mom went into her pocket and had some money and divided it between my brother and me.",
      "word_count": 25
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "And this amount, later on, partly saved my life.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My mom saw to it that he'd come back.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "She got him back, and she let him learn a profession, a trade.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Electrician at that time.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It was in the ghetto, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My mother, unfortunately, went to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "My brother went into a-- it was a concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In Silesia.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "When I was in the camp, a girl my age was sent back.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And she told me she was sent back from Auschwitz because she was strong enough to work.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they wanted her first to work and then to die.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And so she said she met my mother there.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "That is-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Well, we-- we knew-- of course.",
      "word_count": 6
    }
  ],
