  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But I'm sure that you have your own way, the way you want things done.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Now, you only have to tell me once, and I'll do it your way.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "He starts to laugh, and he said, well, OK.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So he says, are you Jewish?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I said to myself, oh, my god, how am I going to answer that question?",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I'm  in Australia, and this guy is asking me if I am Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And I look at him, and he has a very friendly smile on his face.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "He said,  are you Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And I said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "I said, oh, I said, yeah, I used to work in Israel years ago.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I said, I did a lot of kosher cooking.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "Said, OK, he said, you're hired.",
      "word_count": 6
    }
  ],
