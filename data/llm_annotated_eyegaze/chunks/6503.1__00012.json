  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So my husband, who was always very interested when the English came-- we were happy to see it-- were outside, too.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So he met the people and he said, why don't you come inside and have a cup of tea?",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So they came inside, and that's how we met them.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They sat inside there.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We talked about-- the woman was pregnant.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And we said, why should you stay outside?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You might as well sit with us.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And the man came back and back and back.",
      "word_count": 9
    }
  ],
