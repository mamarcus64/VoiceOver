  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I had fallen behind because the Russian school was not as good as my school had been in, in Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So to catch up, I remember for about six months, I studied privately with a couple of teachers.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And at the end of the school year-- this was now around May or June of 1942-- I went to some teachers' homes and took some what you might call final exams.",
      "word_count": 32
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And turned out, I caught up.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And these people had records, which of course doesn't exist anymore, that I had completed something, I would say, on the order of about grades seven, eight, nine-- something like that, you know.",
      "word_count": 33
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I remember I took Latin, and math, and Polish literature.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "When you carried books, you hid them because occasionally, there would be Germans in the ghetto, not very much.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And you were not allowed to walk with school books, because you're not supposed to be in school or study.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Yes.",
      "word_count": 1
    }
  ],
