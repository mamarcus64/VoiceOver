{
  "stem": "9215.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And she stop doing the dressmaking.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "She, right away, she got children, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "She was a housewife.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "That's her.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We were six of us.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Mine oldest brother-- you want to know the name?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother was Suchar.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was only 12 year old when my father died.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We were six.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And the youngest was a year old when my father died.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "He was 12.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "He used to go in cheder.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "You know how this mean?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "But when my father die, my mother took him out.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "First of all, she couldn't pay.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "In the second, she gave him to no man.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother got a girlfriend.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And in our city was, what you say?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "In Polish, they used to call it [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They used to make vodka.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And my mother's girlfriend, her husband was the manager.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "They was two Jewish people, but he was the manager.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And she, my mother went to him, and she told him, said, I want you to take my boy to work.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He said, what-- I can't.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "He's 12 year old.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Even in Europe, they're not supposed to take before 16.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "He's 12 year old.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "But my mother said, but I have not-- I-- I-- I need something, to him, to make some.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I have nothing to how to live with my six children?",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He took him.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Because he was the manager, he could do everything what he want.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He took him, and he gave him only to pour on the vodka in the bottles.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "That's all what he can do.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But he gave him the full amount, what he gave the all workers.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "The full amount was 12 zloty.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Not dollar.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Zloty.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Polish zlotys a week, 12.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "In 16 pounds of flour, to bake bread, in a liter.",
      "word_count": 11
    }
  ],
