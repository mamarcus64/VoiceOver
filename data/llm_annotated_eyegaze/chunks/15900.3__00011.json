  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And they had signatures here from the studio, the photographer where I worked.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "He signed that he has the job for me.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Every factory that we went there, how many people you're gonna supply, how many people you're going to get.",
      "word_count": 19
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "We're going to give them a home, but you give them a job.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "All over Germany.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I playing for every camp.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Ukraine, Polacks, every camp we played.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Against, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "We played with the Polacks, we got orders, if you lose the game, you're not going to get the-- the food [? for ?] [? you ?] [? get ?] [? it. ?] We-- we just like a war when we played with them.",
      "word_count": 44
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "But we won, one to nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Look, it's anything-- when I-- when I came to America, I worked very hard, day and night.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "I didn't speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Munich.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I came--",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Just-- just for-- in Poland, I didn't get money, either.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "We played for glory.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "For the city.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "We-- we-- here in America it's money.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, but sometimes people pay you or sometimes you had a job.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Here when I came to New York, the Vienna [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "You know [INAUDIBLE]?",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE], that was a Jewish group.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "They-- they-- they were the best soccer from Austria, in Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And I know them, some people there.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And I went up to them, I want to play in the team.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "In New York.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "And they say, we're going to pay you for a game.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I said, no way.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "I want a job.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "I want a security and home.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "I have my father and mother.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "Here when I get injured, who's gonna pay for me?",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "No, we're going to pay you for-- I said, forget about it.",
      "word_count": 12
    }
