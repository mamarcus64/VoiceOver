{
  "stem": "22511.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And I used to go sometime to the synagogue, because my mother was very good in-- in finding places where she-- to read the-- the-- the-- I forgot the name.",
      "word_count": 30
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The seder-- to read the seder, you have to know where you-- where you are.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Everybody used to ask my mother, what page we are?",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My mother tell everybody where she is.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Because now I appreciate it, going to the synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I can remember exactly that-- that sometime, I really don't know where we are.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Because it written numbers in the synagogue-- what page you daven in.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Only it's never the same page.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And she always knew, because she was very good in Hebrew.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Everything she knew.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "She was intelligent lady.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And she liked kosher.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Jewish was, for her, so important.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "If I-- I never care what knife.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And always they used to catch me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I had to take a knife, because I mix it.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "It was not kosher, not fleishig.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "I had to put it outside and dig it in the earth for 24 hours, because I did the wrong thing.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "Those things I do remember.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "I-- there is a lot thing.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "The-- the last holiday was 1939, was a-- a holiday.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And we had the first bomb, with war start.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "And we were very lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "We had the Russian coming into us.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "And only the holidays couldn't be on anymore holidays, because there was war.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "We had to be in the cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "It was very, very tragic.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "Only at the end we were happy.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "We had two years the Russian-- not the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "So we were really lucky people.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "And then the luck finished.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "And we had the German comes.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "My father was a-- a businessman.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He used to have leather goods.",
      "word_count": 6
    }
  ],
