{
  "stem": "14463.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Joseph Weinreich.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The spelling is W-E-I-N-R-E-I-C-H.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "24th of the second, '27.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, 24th of February, 1927.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "69.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The name of the city is Chrzanow, C-H-R-Z-A-N-O-W.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And the country is Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Chrzanow was located in the south of Poland, and about an hour and a half, two hours, from the Czech border.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And the nearest city, which was about 3/4 of an hour away-- significant city-- was Krakow.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My father's name was Chaim Weinreich.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But he was not born in Chrzanow.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He was born in Bochnia.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And my mother's name was--",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Bochnia, B-O-C-H-N-I-A.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Friedl.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And her maiden name was Schreiber.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "S-C-H-R-E-I-B-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I had a brother whose name was Moshe, and he was seven years older than I.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "This was the nearest family.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "First, do you want the grandfathers first?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I had two sets of grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "One set of grandparents was the Weinreich, which lived in Bochnia, which I hardly knew because there were about 120, 130 kilometers away.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And in those days 130 kilometers was a long way.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And the Schreibers, which was on my mother's side, and my grandfather's name was Simcha.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And my grandmother's name was Malka.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in the same block of flats-- which belonged to my grandfather-- opposite each other.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "So I knew this family-- the Schreiber family, I knew extremely well.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Simcha Schreiber had five sons and two daughters.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Now the eldest daughter was Friedl, that was my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And then you had Abys, Bernard, Yitzrik, Lizer, Mendel, and my mother's name, I said, Friedl.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And my auntie's name was Minda-- Mindel-- and Mina.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And they were all married.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And they all had two children, practically, each.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Every one of them had two children each.",
      "word_count": 8
    }
  ],
