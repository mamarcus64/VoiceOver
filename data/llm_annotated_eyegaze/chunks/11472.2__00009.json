{
  "stem": "11472.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 138.1,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "And they started to dig an exit there.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "And they dug through.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "They dug one and it-- it collapsed and the dirt came down on them.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "They dug out another exit.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They dug out 100 feet high.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And my uncle Nisel brought a tin oven and tin.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And my uncle Shulim, he was the engineer of all these excavations.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I have to tell you that you cannot believe yourself what these boys did.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "My uncle Nisel used to come at night to help him dig.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "My uncle Nisel was a very able man.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He was an Uhlan in the cavalry, the Polish cavalry.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And only the best and the brightest they took for that.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Very handsome man.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So was my father.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They were such good-looking men.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Anyway, my uncle Nisel used to come with my father, and they used to help at night, Shulim and the other men dig that exit.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And they dug through.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "They took from tin, they made a funnel.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And at night, they would let that-- they would let the-- we would cook at night, so the smoke would go out.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "They made a very big cover with a chain.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And they put a lot of dirt on it because it was in the middle of the field.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "This grotto was very huge.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "In case in the spring, when the farmers will start to dig the field, you know, that they shouldn't find it.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "So they made it very heavy.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "And we were secure.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] One winter, there was a big estate there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "A German, the overseer from the estate, passed through near the grotto, and he saw a potato outside.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And he told the Gestapo that there are people living in the grotto.",
      "word_count": 13
    }
  ],
