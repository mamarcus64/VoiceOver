  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.7,
  "sentences_input": [
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "And we were-- many people, they throw stones to the German.",
      "word_count": 11
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 2,
      "text": "But I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 3,
      "text": "I didn't throw them, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 4,
      "text": "Do you have a hatred toward the Germans now?",
      "word_count": 9
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "No, because you know, there it was the war, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 1,
      "text": "Many Germans are nice-- the one-- the-- the ones that are not SS, you see?",
      "word_count": 15
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 1,
      "text": "Here there is two, three people here they live.",
      "word_count": 9
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 2,
      "text": "They are German.",
      "word_count": 3
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 3,
      "text": "They are very nice, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "I don't say nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "But I don't-- [LAUGHS]",
      "word_count": 4
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it doesn't matter.",
      "word_count": 4
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "I feel that the Germans, you know, destroy ours family, and you know, all these people kill.",
      "word_count": 17
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "But you can't do nothing when the war, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and--",
      "word_count": 2
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "The three.",
      "word_count": 2
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 1,
      "text": "We came back, three-- Djoya, myself, and Mauricio, who died also.",
      "word_count": 11
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "Because he was there, he died young.",
      "word_count": 7
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "No, in Rome.",
      "word_count": 3
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 1,
      "text": "He died in Rome.",
      "word_count": 4
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "After.",
      "word_count": 1
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, he got married, then he got two children.",
      "word_count": 9
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 0,
      "text": "We were liberated there at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 0,
      "text": "And we stayed three two, three weeks, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 0,
      "text": "After.",
      "word_count": 1
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 1,
      "text": "And then they start-- they start coming to take us home.",
      "word_count": 11
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 0,
      "text": "Say, where do you want to go?",
      "word_count": 7
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 1,
      "text": "To Italy.",
      "word_count": 2
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 2,
      "text": "But Italy--",
      "word_count": 2
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 0,
      "text": "We were happy to go home, to Italy.",
      "word_count": 8
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 0,
      "text": "To Rome, you see, because I had my sister there.",
      "word_count": 10
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 1,
      "text": "You see.",
      "word_count": 2
    },
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 0,
      "text": "No people to go nowhere.",
      "word_count": 5
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 0,
      "text": "So we arrived in Milan for 10 days, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 193,
      "sentence_idx_in_seg": 0,
      "text": "Like that I said, from Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 0,
      "text": "We took the trains.",
      "word_count": 4
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 1,
      "text": "We were--",
      "word_count": 2
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 0,
      "text": "From Theresienstadt--",
      "word_count": 2
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 0,
      "text": "We-- we-- we left.",
      "word_count": 4
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE] And we were going-- ah, you left the telephone.",
      "word_count": 11
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 2,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 0,
      "text": "They took-- they put them on the train, the people.",
      "word_count": 10
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 0,
      "text": "[SPANISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 1,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 0,
      "text": "Stop, eh?",
      "word_count": 2
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 1,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 200,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 201,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 1,
      "text": "Everything they give us.",
      "word_count": 4
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 0,
      "text": "The fleas, yeah.",
      "word_count": 3
    }
