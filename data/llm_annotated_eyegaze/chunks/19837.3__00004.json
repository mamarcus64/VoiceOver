{
  "stem": "19837.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 386.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We didn't leave the district anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Husband and wife stayed together.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And my husband always found work in the district.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But he came rushing home that-- one day and he stopped at the place we ate.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't eat all the food there, but fruit or vegetables.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But there was a stand, I think it was called mangoes, fruit like little apricots, and we ate them.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And he-- another guy said to him, come on, come on.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "It got real gray, like nighttime almost, not quite.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And he said, come on, come on, they're coming.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And he said, I want to take that home to my family.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And he brought it and it actually saved his life.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "You know, the other guys were running, and they were killed.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And he stopped.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "It was just luck, he didn't know.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And then the families kind of stayed together and didn't want to be separated.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Chinese people.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I lived in a Chinese house.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My in-laws, where they lived, there were more Jewish people-- not in the same house, but like I said, a lane.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "The lane was like the street here with little houses together, not-- not separate houses.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We heard the cuss words-- cuss words-- and we learned to understand them.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But we took a few Japanese lessons when the Japanese first came.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They were the customers in the restaurants and bars.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And my husband went out selling all kinds of stuff, material and shoes, whatever he could lay his hands on.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "He went from house to house.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And he wanted to know the figures, you know, the dollars.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Shanghai dollars.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And we had a few Japanese lessons.",
      "word_count": 7
    }
  ],
