{
  "stem": "26609.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "She was the oldest sister and was about the [INAUDIBLE] after her.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I said when I was six, she grabbed me and took me with her by hand and took me with her-- six or even less.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "But she belonged to an older group, to those called-- here, they call them [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And she spoke Hebrew.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "She learned it in the Tarbut.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And I remember exactly doctor's daughter and two sons.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "They were at university both.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "They left university.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "Oh, it was-- they took pride in-- to leave schools and go to Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And a whole group-- my sister was in it.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "There were older ones and she was-- there were some younger ones-- a group enrolling to go to Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "Illegal-- that was illegal then.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "It was so many years back before independence of Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "And I don't remember the year when it was exactly.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "I was young, and I wasn't so concerned.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "I remember only she took me by my hand when I was little.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "And she said, I'm going away.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "I couldn't even understand exactly what she wanted at six.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "I'm going to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "Don't tell mother.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "She wouldn't let her go.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "Parents didn't let go.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "Don't tell.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "Till I'll be on my way there, don't tell.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "When you go home-- it was in the afternoon.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "And she didn't go home.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "She slept at her friend's place.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "They wouldn't let her go.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And said, don't tell anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "You can tell them tomorrow when I'll be far away that I went to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I went home, and I cried.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I cried and cried.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "My mother said, why do you-- what happened to you?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Anything-- anyone hurt you?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "What-- why do you cry?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Because-- because-- because Sala-- we called her not Sara, but Sala.",
      "word_count": 11
    }
  ],
