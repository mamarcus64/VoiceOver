  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 49,
      "text": "And every time my machine broke down, and, of course, I did let it run broken down as long as I could get away with it.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 50,
      "text": "But after awhile, I couldn't so I had to call somebody to fix it.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 51,
      "text": "And he would come.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 52,
      "text": "And he would face my machine.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 53,
      "text": "We were not allowed to talk to each other.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 54,
      "text": "And he would talk to the machine.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 55,
      "text": "And he would tell the machine like in French, you know, [SPEAKING FRENCH], 60 kilometers from Paris or something.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 56,
      "text": "And then slowly each girl from around the machines would come to me after we left, and we would share the news.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 57,
      "text": "So we had a little bit to understand.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 58,
      "text": "Anyway, April 14th was probably one of the most beautiful days of my life, even though I was only incarcerated for 10 and 1/2 months, somehow you get so used to it--",
      "word_count": 32
    }
  ],
