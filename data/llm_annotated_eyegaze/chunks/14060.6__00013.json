  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Yes, I know the, the times because all the stations had clocks.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have watches at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And I remember the name of the station being written out in German Gothic letters, Auschwitz.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "We were delighted because we thought we were in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Little did we know what Auschwitz today means.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I'm just telling You how blind the people were purely by being misled or disinformed, not being told the truth.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And this has been a great argument amongst many learned and informed people, if you like to call it an accusation against the leaders of at the time.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "I will come in to tell you-- because I think we are coming to the end of this tape-- how the arrival actually took place.",
      "word_count": 25
    }
  ],
