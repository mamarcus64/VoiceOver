    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "There was not that many Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "There were a lot of Russian refugees.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "No, I mean, I'm not correct.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "There were not many, not a lot of Polish Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "There were a lot of Russian Jews that run away, because this was already the war.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And a lot of Russian Jews that the children went to the war, and the elderly couples or little children where so that run away from Germans were also living in that Merke.",
      "word_count": 33
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And we were very sort-- look, it was for us a very-- the atmosphere for us was very good.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "Because there were Russian Jews, as I said.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "There was that atmosphere of helping each other.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "The conditions were terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Right, OK.",
      "word_count": 2
    }
  ],
