{
  "stem": "25589.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We play soccer, and [INAUDIBLE] dad, but I didn't have nothing to do.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I usually have something to do after school.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I go on my bike and deliver some parcels for him.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And he gives me a nickel.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "A nickel in those days was good.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "It's better than getting $1 today.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "Because with a nickel, you can do a lot of things in those days.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So the afternoon, I have nothing to do.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I go take my ball.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There's-- the taxis are standing near the station.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And the guys always played, played with me because, I don't know, that was a usual thing.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And there's a ball, gets kicked up on top of the roof.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "How am I going to get this thing off, I says?",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They weren't going to go up there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "This little guy gets himself up on the roof.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Said, oh, guys, I got the ball.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And I looked down there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Who's standing down there?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "My dad.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I said, oh my god.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And he's yelling at the top of his voice.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "He says, you better get down here.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "I'll break your neck.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "Be careful!",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "You know, he's standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He said, you come down.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I said, yeah, yeah, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "If you go away, I'll get down there.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "No sooner her left, I get down there.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how I'm going to get into the store because he's standing there waiting for me like, like, you know, he's going to kick me, you know.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "But I know he wasn't going to kick me.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And I figured I better--",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, home was above.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I have to get through the store [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He says get in.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I said, yeah, sure.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I'll wait till you get a customer.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Then I'll go in.",
      "word_count": 4
    }
  ],
