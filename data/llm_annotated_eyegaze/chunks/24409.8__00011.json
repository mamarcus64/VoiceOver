  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And we had the Jewish community of Budapest, called to meet in a banquet, and I was feted there.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And the waiters called me your excellency, and the Jews called me Herr Consul.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "It was very funny.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "At the same time, I informed-- at the same time, I informed our people of the same method.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "You can do the same thing in Paris and in Warsaw and everywhere.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Make yourself consul, not of Liberia, of some other country.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Sure they did.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
