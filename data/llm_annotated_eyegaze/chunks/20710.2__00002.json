  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "So anyhow, the parents-- my parents, at that time, felt that, you know, whatever can be done for the time being, that we should remain in this village and not go to the ghetto, because the next step in ghetto was to, to surround and take away to the, to the gas chambers.",
      "word_count": 53
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 6 SECONDS] [CRYING]",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So anyhow, so we went there.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So my parents-- I don't know how, I guess that they had, still, a house in [INAUDIBLE] or something.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They went to, to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And they just-- there was nothing left, belongings to take, because the Ukrainians took everything away.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "But we were-- we still had certain, few things.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And we, we gave it to, to another neighbor that we trusted that he would keep this, in case we need something.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We had a-- my mother had jewelry and things [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And she told us, in case something happens to them, that she left there things that we can, you know, do something, to be able to, to survive for a little while.",
      "word_count": 32
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "So anyhow, they went to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And then we went to this hiding place.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And they were few more than we were.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "About eight people there.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And it was a very, very tiny little place.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And we were just sitting like, you know, like this here.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "There was no air.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And this sister-in-law of this man who, who gave us this, this, you know, the house, and so she used to cook food.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And she used to bring down every evening, and it was a small hole that-- to, to push in this, this food.",
      "word_count": 22
    }
  ],
