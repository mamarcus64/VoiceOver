{
  "stem": "1765.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "Whatever manual labor we could do on our day off, on Sunday, we did, and we did it in sort of little brigades.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 50,
      "text": "It was hard work.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 51,
      "text": "You never really had time to quote, unquote 'socialize.' But if you were with friends, and you did the same work together, and you struggled through the snow together, and you-- you were in school, and you had a school newspaper, which was just a piece of paper on-- on-- on the wall, and everybody contributed a little something.",
      "word_count": 59
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 52,
      "text": "And that was our school paper.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 53,
      "text": "You don't need a lot of-- oh, I don't know, telephones and faxes and whatever to have a social life.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 54,
      "text": "You meet people in school, and it's your-- -- your social life, and then you have work at home.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Very early. 6:00, maybe, 6:30 was late.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I had to leave for school by 7:00, 7:15 to be there for 8:00.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I mean, in the winter, in storms, you had to have at least an hour to get to school.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was always dark, except in-- you know, in October, there was already snow on the ground.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My birthday is October 18.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So I can tell by my birthday, there was snow, a lot of snow.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And it didn't really melt until April.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we had-- no, we had-- people had watches.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Those who didn't sell them on the [NON-ENGLISH] had watches.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We always had a watch.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have a watch, but my mother had a watch from Vilna.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I still have it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We never sold it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I have this watch.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It doesn't work, but we have it.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I never thought about keeping time because time wasn't that important.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "You went to school, the school was over, you went home.",
      "word_count": 11
    }
  ],
