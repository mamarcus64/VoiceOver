{
  "stem": "7506.7",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I'd gone back into the beauty business, because I thought that would help, if I disassociated myself business-wise from the family.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES] And obviously, they had made their minds up to get-- to separate us.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I had a phone call from my neighbor at work, and she said, Maurice, you better come home to your apartment because there's a big removal truck outside, and your father-in-law and your wife are emptying your apartment.",
      "word_count": 38
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES]",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I asked my boss at the time, can I go?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "When I got home, to where I'd lived with my wife and my daughter, [PAUSES] the whole apartment had been emptied, and the only thing that remained was one bed and my suitcase with some clothes.",
      "word_count": 36
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "That's the only thing that remained.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "That had had such an effect upon me, even today.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "When I think, these are my people.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "My people have done that to me, not Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES] My people, who know about my past.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES] It's been a very bad thing for me.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I think I got hold of my uncle who was there.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He said come to us, come home straight away.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I was there, and I think it must've been maybe a few months.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I could--",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was-- let me think.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES] 30, 32.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "About 32.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "1979.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I came to the United States in 1979.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "On a visit.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "On a visit to the west coast, to the western part of America.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I'd been to the eastern part of America when I was doing my work on ships.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I'd known all that part.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But my mother had a cousin living here.",
      "word_count": 8
    }
  ],
