{
  "stem": "23131.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "There were doctors.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "There was a hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "There were shoemakers.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "There were-- [PAUSES FOR 3 SECONDS] every little thing what a normal life needs, there were there.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And the-- more the sen-- the seniority was more occupied with that.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Whatever Tuvia-- [PAUSES FOR 3 SECONDS] Some were volunteers that they know how to do this, a watchmaker or this, or even for the rifles, for the guns.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You needed-- you had to clean, you had something that breaks, something-- everything was organized.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "People from before the war knew some work, and that's where they volunteered.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I had-- I was-- at that time, I was already with Tuvia.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "So a lot of-- from other-- from other brigades came always visiting.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We had a kindergarten.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We had shows.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "We had-- we had-- we had to receive them.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We had to, you know, to host them.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I was staying on guard, too.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And when I'd see my husband in the mornings, he said, Mr.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "So-and-So, Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Commander, let me tell you that the night was quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Nobody showed up.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "Nobody-- no shooting, no this, no that.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I wasn't [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I never played the role of a Miss Commander-- Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "Commander.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Whoever came from outside, I tried always to host them, to give them, to help them.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "But you know, you can not be [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "They'll find anyway something to say on you.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And once you're in commend, there is always something to say because you cannot satisfy the world.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Very well.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We had children that they wanted-- that-- the parents didn't want to send them.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But they were-- they wanted-- the Russian people wanted to have them in Russia, and to go on, you know, with their lives, because they were very talented in singing and dancing.",
      "word_count": 32
    }
  ],
