{
  "stem": "19231.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 442.2,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And that's-- they tell me that's the reason we went there.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "For safety.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I was just turning 15.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I didn't Germans, because I was already-- they came to our town, I guess, first.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And a couple days later, they came to Szczekocin.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But we ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Like, Friday the war broke out.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And Sunday morning, everybody was in a panic like and said, the Germans are coming.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And the airplanes were flying over our heads.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And we ran out from my sister's house.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And there was, by the house, there was a big bus standing.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "And we tried to push in in the bus that we should be able to go away for the day and come back in the evening.",
      "word_count": 26
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "But we never came back in the evening.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "Because the Germans was-- were under us.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And we were on this bus, were traveling from town to town from all small towns, larger towns, for a couple weeks I remember.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "There were a lot of Jewish people from this small town.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "My sister was, my brother-in-law, and they had two children, my parents and I.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And there were more people from the small town.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother wasn't there.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "She remained there.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Because she was with her-- she was with her daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "She lived there with her daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "She-- and I didn't see what happened with them.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "We just were all with my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "We went into this bus.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We went, because we thought we're coming back in the evening.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So nothing, just the way we were dressed.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And we had nothing with us, absolutely nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No pictures, no money, no clothing.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "No, not even a little jacket, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So who was driving this bus?",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "There There-- he was the owner of the bus.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That was his business.",
      "word_count": 4
    }
  ],
