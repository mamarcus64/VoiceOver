{
  "stem": "9471.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Take me to Jasenovac, where my husband and all the men were.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "He says, OK, I'm going to take you.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "I come next day, and I'm going to take you.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I was so excited.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "Next day he came.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I says, I'm ready.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "He says, Zora, I cannot take you.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "He is not living anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "Your-- your father, everybody was killed already.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "I remember I fainted.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "I couldn't believe it, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "He did it in such a way, you know, without feelings.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "Oh, they are dead already.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "They were-- they were killed.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "Then I thought, oh, I better be afraid of-- of you.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "And I-- I escaped from the hospital to my girlfriend.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "And then, uh, I met friend of mine who was with me in concentration camp, who was taken from the train, too, because she had dysentery.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "And she was taken, she heard about me, that I am out, too.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "So we met.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "And we took a room together.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "We were there for, oh, about couple of months.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "We were afraid to go out, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "But the friends brought us food there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "And one day even I went to Novigrad, where my mother and sister in camp.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 32,
      "text": "I went to visit them.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 33,
      "text": "I took some food and took them.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 34,
      "text": "And when I came there-- that's the last time I saw my mother-- and my sister there with the gates, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 35,
      "text": "And my mother said, go.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 36,
      "text": "Don't you ever come.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 37,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 38,
      "text": "Because they are asking for you.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 39,
      "text": "They want you back in camp.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 40,
      "text": "Disappear.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So I did.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I disappeared.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I was by my girlfriend, and I had some, uh-- some jewelry, what my girlfriend saved for me.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And they sold it to have passport for, um, Adriatic Sea, where the Italian were, occupied by Italian.",
      "word_count": 18
    }
  ],
