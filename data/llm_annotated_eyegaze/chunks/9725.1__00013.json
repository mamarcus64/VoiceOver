  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I remember, for instance, in school-- and that was in the convent school-- we-- twice a year, you-- you wrote an essay, which you didn't sign with your name, but with-- whatever, you know, a number, or what have you.",
      "word_count": 40
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And if you won, your essay was published in, sort of, a national scholastic, you would call it, magazine.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And lo and behold, I won.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I remember-- and of course there was a great doing about it.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And I remember, the next time around, my father took me for a walk.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And he said, there's something I want to talk to you about.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "He said, the thing-- the contest is coming up.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And you'd better not try too hard.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "It wouldn't do for a Jewish girl to win twice.",
      "word_count": 10
    }
  ],
