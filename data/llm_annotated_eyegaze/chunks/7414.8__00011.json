{
  "stem": "7414.8",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We had the factory.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So my husband started first, and he said this.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But somehow the handbag were not good here, and we found someone that was this-- he went, like everybody else at this time, was going to petty market.",
      "word_count": 28
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And he met there a man.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And they started to talk.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And he told the man, you know, my wife is a dressmaker.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So he told him, really.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I need some blouses.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "If she can make me some blouses, you can't find any decent blouse here in Sydney.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So I was-- we went to a shop.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We bought a piece of material in the retail of course.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And I was standing on this in the kitchen-- on the kitchen table I cut with the scissors the dozen blouses he wanted.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I sew it.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I brought with me a small home machine, you know-- and I made those blouses.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I embroidered those buttonholes by hand.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "He got those dozen blouses.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "He sold in no time.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Then two days later, he comes.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Perhaps she can make me two dozen blouses?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I made him two dozen blouses.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "So then when he came back, he wanted more.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "So I told my husband, why he has to sell my blouses?",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "You take the blouse and go and sell it.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And he went.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "He went to Paddington.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "He went to one shop.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "The first shop he went in.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "The woman there was a Jewish shop.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "The people were from here from before the war.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "They were big wholesalers, which he didn't know because that was a small shop.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "When she saw the blouse, he rings me back after half an hour and he tells me, you know I got an order for 1,000 blouses.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "From one place.",
      "word_count": 3
    }
  ],
