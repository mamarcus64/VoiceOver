{
  "stem": "365.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "There was bunk beds in that barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "There were one prisoner per each-- like bunk beds which were two, one on top of the other-- double bunk beds-- and one for each bunk bed.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Now, the bunk bed had to made to perfection.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "There were bags of straw in the bunk beds. like for a mattress, which you had to try to spread it when you got up.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And you had only five minutes to do that.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Then stretch the blanket over it.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And you had a bench or a stool in front of every bunk bed.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "So you'd take the-- you would take out two boards from the bunk bed.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "Underneath the straw back were boards to support the back of the mattress thing.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And wedge in the blanket from one end of the bunk bed and the other.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Stretch it tight, and then go over with the stool on top of the bunk bed to make it as flat as the bunk bed, almost like it was ironed out to perfection.",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "If you didn't make the bunk bed right, you received 25 lashes.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "And the whole room, the whole barracks, would have to do exercise.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And our exercise-- running around the barracks up and down, up and down-- that was the punishment for it.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "And it had to be spotlessly cleaned up, no straw found or anything, because the inspection was-- when it was roll call in the morning, right after was the inspection of the barracks, how they are.",
      "word_count": 36
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "That was the life-- the daily life.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "Any beatings and things were daily.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "Two guys were caught once stealing potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "They were buried alive up to their necks, just a head sticking out of the ground, and two bowls of soup put in front of their eyes.",
      "word_count": 27
    }
  ],
