{
  "stem": "3331.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And they took me out, and I, uh-- and they said to me, start to dig.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I start to dig.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I said, what  am I digging for?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Dig-- don't ask questions.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was already till my knees, till my-- till here!",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It was deep enough.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I said, tell me, who is was going to be shot here?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And why I'm there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They said, you.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I said, why?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Don't ask questions.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "In the last minute, what do you do?",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And you know what some people say-- what is the taste of death?",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "How if-- I knew the taste of death, because I dug and I knew that I would be shot in five minutes or two minutes.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "So I didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "To take a shovel of sand and to throw it in his face and run away-- one was staying to one side, the other was staying in the other side, so he would shoot me.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "They was standing with rifles.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "So then something came in my mind, and I said that Fardonye had a secretary-- a girl-- a, a Polish girl from my town, and I knew her.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "They said, go and bring Krisha Kotelecka.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "This was her name.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I have something to say.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He said, we cannot go.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We have to shoot you.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I said, you will shoot me anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They went, and they brought Krisha Kotelecka.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "When she came, she started to cross herself.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "So I said, I need a favor.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "You go to Fardonye and tell him I have something to tell him.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "She said, I cannot go-- he will shoot me!",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I said, go.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "She went, and she told him that I am in the hole and I want to speak to him.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "This Fardonye was very shrewd.",
      "word_count": 5
    }
  ],
