{
  "stem": "766.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Because they don't want two.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "They didn't have to ask.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They could separate.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "But anyhow, I was the youngest from them.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "How could they recognize with that hair old, young?",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they took me out from the whole trouble.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "This why I don't have the number.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "But it didn't go so fast.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "So many transports came from all sides, every day.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And they gave me a pair of shoes which didn't fit me.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "But at least shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And they gave me a dress, no underwear or nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And they told me that I'm going someplace.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And they took a soldier with a rifle, everything, by train.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And we traveled to Guben-- Guben.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Alone.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "With soldier.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And I-- he had the papers that I am the doctor assigned to do-- to this Arbeitslager.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, no, a civilian.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Because I was supposed to be a-- a-- a humanitarian help to give them.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "After a few days, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "A couple hours.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "He didn't touch me.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "He didn't beat me.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "He didn't talk to me.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "So now we came over there.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And there was a-- a woman, the officer in the supervising of this Arbeitslager.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't an extermination camp, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "They worked in a factory and they needed a doctor, that-- so that they should be able to work and produce for the-- for the war machine.",
      "word_count": 27
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "These girl, only Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And these girl were 99% Hungarian.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And I was the only Pole.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And I was the only one-- later, I found out-- with shaven head.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So when she looked at me-- when I came, he gave her the papers.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "So she asked me in German, understand, what is my crime?",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "She thought, I think so, the head.",
      "word_count": 7
    }
  ],
