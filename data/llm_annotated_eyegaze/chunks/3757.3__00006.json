{
  "stem": "3757.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I think my mother, my poor mother, is-- maybe she can go to church, maybe not.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But she will not know what happened to me.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I am the beloved daughter, and this hurts me very much.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I cried and left the church.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So one day-- the-- this was any-- a funny story also.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "The-- in the sanatorium, the-- the bathroom and the showers were up on the attic.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't know that it is a separate room for nurses and a separate for the cleaning personnel.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "So I went up to take a bath, because I felt all-- all-- all the time I felt that I am covered with bacterias.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "So I went up.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And unfortunately, I went into the room that only the nurses should go.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So I was sitting in the bathtub, and somebody banged at the door.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "It were a man.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "Who is that?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Why-- why did you close the door?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "You don't know that you're not supposed to lock the door?",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I said no.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Open up right away!",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I jump out from the bathtub and opened up.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I was naked.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Came in a big woman and looked at me.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Who are you?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I said, I am Irene from the D Pavilion.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She said, yeah, you are lucky that you are not a man.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Now I would know who you are.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So he-- I said, I don't know what you mean, but you have very good imaginations.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And you don't know that you're not supposed to use this-- this bathroom?",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "But certainly, I will-- will left it cleaner than I found it.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And she left.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "So in the meantime, I got another job with the-- with this little pavilion.",
      "word_count": 14
    }
  ],
