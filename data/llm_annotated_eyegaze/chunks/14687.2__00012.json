  "sentences_input": [
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "We left them there like this and people dying.",
      "word_count": 9
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And if you see them walking, it was sticks the legs and diarrhea.",
      "word_count": 13
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "All the time, diarrheas, diarrheas.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 5,
      "text": "And the sores, the mouth, they used to grow sore from the water.",
      "word_count": 13
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 6,
      "text": "You see, that water was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 7,
      "text": "You couldn't drink that water.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "No, never.",
      "word_count": 2
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "I didn't drink.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "Just I should take snow.",
      "word_count": 5
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "In my mouth, you see.",
      "word_count": 5
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "And then, from there when we went--",
      "word_count": 7
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, with the other prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 2,
      "text": "They were French also.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "They-- they know everything.",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "They knew and we--",
      "word_count": 4
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "I'd say always.",
      "word_count": 3
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 2,
      "text": "They used say, no, where is God?",
      "word_count": 7
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 3,
      "text": "Where is God?",
      "word_count": 3
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 4,
      "text": "I used to say, there is God.",
      "word_count": 7
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 5,
      "text": "You'll see.",
      "word_count": 2
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 6,
      "text": "He's going to help us.",
      "word_count": 5
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 7,
      "text": "Many of them who I used to talk to, [INAUDIBLE] they died there also.",
      "word_count": 14
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 8,
      "text": "Shame.",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 9,
      "text": "You know, these [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "The sister-in-law, she said, [NON-ENGLISH], we coming out from here?",
      "word_count": 10
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "I say, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "She died also.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "She was a very--",
      "word_count": 4
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Something like I'm going to survive, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "Because I was young.",
      "word_count": 4
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 2,
      "text": "I was running, and helping, you know, all these things.",
      "word_count": 10
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 3,
      "text": "I thought I'm going to be all right.",
      "word_count": 8
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 4,
      "text": "So when we came out from Auschwitz--",
      "word_count": 7
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "In August 16.",
      "word_count": 3
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "So August, September, October, November, December.",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Something like this.",
      "word_count": 3
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "In that-- the block went in-- 20.",
      "word_count": 7
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "Block 20, I think we were.",
      "word_count": 6
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "You know, one day my friend--",
      "word_count": 6
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Leah [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "She died in-- in Milano.",
      "word_count": 5
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "Leah Levy was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "And it was her sister, Rochelle.",
      "word_count": 6
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "You see, she was hungry one day.",
      "word_count": 7
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "It was-- this in Auschwitz?",
      "word_count": 5
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 2,
      "text": "Or, it was in the factory, I think you-- Oh, it was in the factory when we went out from-- I tell you after.",
      "word_count": 24
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 2,
      "text": "No, they.",
