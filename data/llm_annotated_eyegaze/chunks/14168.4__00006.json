{
  "stem": "14168.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "You had to-- you could either buy, or you could rent, but you had to buy some useless furniture for a tremendously high price, circumventing the regulations.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "We-- and no hotels would take you over three days.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "You had to move out after three days.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "We found a little boarding house where we could have-- we had breakfast and dinner.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And it was overlooking MacArthur Park on West Sixth Street.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "The Leighton Hotel, at the time.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "We were very happy to be there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "We stayed there for three months.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "We picnicked on Westlake Park on Sunday.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "We figured we were-- we were really leading the life of Riley.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "I found a job.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "My-- I found a job after about a week.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "I went from bank to bank, trying to find a job in the international banking department.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "Because international trade was something that I thought I knew something about.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And after about a week, I was offered a little job by Union Bank, which is still in business.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "At that time, it was at Eighth and Hill Streets.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "Ursula went to take care of a boy for-- with a family, a Jewish family in Boyle Heights.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "My mother-in-law worked as practical nurse for an old gentleman who was a cripple.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "And she was a frail little woman-- how she handled that physically, I don't know, but she had tremendous willpower.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "My father-in-law became a shipping clerk in one of the manufacturing companies of ceramics-- which was the article at that time in California, ceramic products for families.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "And so I worked-- I stayed with the bank for two years, then was hired by a steel company, one of the leading steel companies, here, owned by Jews on the West Coast.",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "Became first assistant to the import-export manager, then export manager.",
      "word_count": 10
    }
  ],
