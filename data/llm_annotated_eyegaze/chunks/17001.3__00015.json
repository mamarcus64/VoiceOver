  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I'm a-- So this Lola who greeted us that you're going to go through the chimney-- seems to me, even though she was Polish, that she did understand Hungarian, because she picked up my sister.",
      "word_count": 35
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "At that time, they were selecting them and they had no clothes on them.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They were naked.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "So she pushed her through the back door of the barrack and she threw a dress after her.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Meantime, I have to tell you, my dear Ellen, that we did not recognize each other after we got the clothes when they took away our own clothing.",
      "word_count": 28
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
