  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And he had a barge, and he took us over the river, and we came to the Russian-occupied Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And then we went-- went right away-- we had some relatives near Bialystok.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We went to Bialystok.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And my brother and sister stayed there with relatives, and I went after my-- to see what my sister's doing in Novogrudok.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I slept the night, and I said, I'm not staying.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I want to go to my sister's.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And I walked back to the railroad station and went to Novogrudok, and there I met my sister.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And they were overjoyed to hear that we came here.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And my brother-in-law and my brother decided to go back to-- to the German-occupied Poland and get the rest of the family so we would be all together.",
      "word_count": 28
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So they went there to the border.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And this time, the borders were very strictly-- very guarded on both sides.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "There was no way you could cross the border.",
      "word_count": 9
    }
  ],
