  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we said to them, we are Jewish people, and that's a camp.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And he said, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I'm Jewish, too.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I shouldn't say it, but if you-- they-- don't register, because they may take you to Russia.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And in Russia, they don't like Jews, either.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And he just disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So we were sitting, and waiting, and contemplating.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Should we or shouldn't we?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Should we or shouldn't we?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "So we were there, I don't know, about four weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And-- finally, we had to register.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "But no, they took us back to Cracow.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "We'll break for the end of the tape there.",
      "word_count": 9
    }
  ],
