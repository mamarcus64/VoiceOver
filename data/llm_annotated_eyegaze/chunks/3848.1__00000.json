{
  "stem": "3848.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "He called her a dork.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Catch.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[THROWING KEYS] I have no pockets.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I'll lose them.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Don't have pockets.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Do I look at you?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Hello.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My name is Gerry, or Gerald, Grossman.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I live in the United States of America now.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I'm going to give you a little story about my life, [PAUSES FOR 3 SECONDS] in the time of war.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I was born in the city of Rowne under the name Gedalia Tennenbojm.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It was Poland in the district of Volhynia.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My father was David Tennenbojm He was a tailor all his life.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "My mother, Tsipa Tennenbojm Her maiden name was Gresores.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And she was a housewife.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We were five children.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I was the oldest one.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "My brother, next brother, was born in 1928 in the city of Rowne.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "His name was Isar Tennenbojm The next brother was Pesach, or [?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Pesar ?] Tennenbojm, who was born in 1930.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I had a little sister, Feiga was born in 1932.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And then, the youngest brother was born in 1935.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "His name was Motel Tennenbojm.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] We had a pretty nice, not a rich life, but it was interesting.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "The city was a-- a population of about 57,000 people.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] About 30,000 were Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Most of the Jews lived in the city.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And the city had a lot of organizations, Zionist organizations, that we belonged to.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I belonged to an organization named [NON-ENGLISH] when I was young.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "Mizrahi-- and we had [NON-ENGLISH], [NON-ENGLISH], [NON-ENGLISH], and a lot of other organizations-- all just sort of preparation to go eventually to Israel.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] And that's what the life was all about.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "It was very interesting.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] It was a happy life in the city.",
      "word_count": 12
    }
  ],
