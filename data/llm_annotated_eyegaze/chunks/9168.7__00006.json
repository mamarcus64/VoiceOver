  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And it was on a Friday night, the night that the cadets have off to go into Colorado Springs, a free night, or they could attend any one of 15 seminars they had presented that-- to present that evening.",
      "word_count": 39
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And mine was-- and get credit for it-- and mine was number eight on the list, with my title, 'Reporting the Nazi Doctors Case of the Nuremberg War Crimes Trials.' Of 900 cadets third-class, who are the sophomores, 368 selected my talk.",
      "word_count": 42
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And they had to move me from a classroom that was smaller into the one that would accommodate 400 people.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And they showed the slides from their projector box onto a ceiling-to-floor stage screen.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And there were cadets there who came up to me afterwards and said they never knew anything about the Holocaust, and they were interested.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And then I had another call to go down and present to the cadets again a year ago November 19th, but I had already made a commitment and was in Phoenix giving a presentation down there.",
      "word_count": 36
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, I think that we have learned that number one, that we have to educate about it.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We have to educate students.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I now believe-- I present to a lot of seventh and eighth grade students, who are the best.",
      "word_count": 19
    }
  ],
