{
  "stem": "20580.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "And the-- and they make-- the, the Germans with the Ukrainish, they kill all of them.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "But some-- three people, people run away.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "They told us the story.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "We know everything is dead there.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "But three, four people run away.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "We come in there.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "We says, OK, we could stay another week or two.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "But it's danger.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 24,
      "text": "At night, we have to go away.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "It was November, 1942.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "November 1942, we go here, we go there.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "We get a family, which the children is in Israel, [NON-ENGLISH] [?",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 28,
      "text": "Adem ?] with [NON-ENGLISH] [?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 29,
      "text": "Adem. ?] We find them there, in the forest.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 30,
      "text": "He says, come on to me.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 31,
      "text": "Sit there while you're in the hall.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 32,
      "text": "We have this.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 33,
      "text": "We have this.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 34,
      "text": "We have-- took bullets.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 35,
      "text": "And then, sit over here.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 36,
      "text": "They give me a potato.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 37,
      "text": "They give me-- I'm not so hungry because we had this one over here.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 38,
      "text": "We went together two days.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 39,
      "text": "I says, I cannot do it.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 40,
      "text": "We have to go look for some difference-- people.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 41,
      "text": "There were six, seven people in all.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 42,
      "text": "Then he says to me, you know, I have a friend which I, I give you.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 43,
      "text": "But like he says, he's looking for a tanner.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 44,
      "text": "They find me.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 45,
      "text": "I says, give me the name of him.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 46,
      "text": "Let me show.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 47,
      "text": "I'll show you.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 48,
      "text": "Stay where you are.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 49,
      "text": "I slept over a night-- the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 50,
      "text": "And-- I'll show you.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 51,
      "text": "And this guy looking for me, he has leather.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 52,
      "text": "He started, and, you know, he's looking for me.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 53,
      "text": "And he heard about me.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 54,
      "text": "He didn't tell me.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 55,
      "text": "And suddenly, he find another place.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 56,
      "text": "And he went to another place.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 57,
      "text": "And the other place, right, they kept him two days.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 58,
      "text": "And right away, they reported it to the police.",
      "word_count": 9
    }
  ],
