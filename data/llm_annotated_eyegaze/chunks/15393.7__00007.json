{
  "stem": "15393.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "You are here only thanks this little girl here, she says, pointing at me.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And don't you ever forget it.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And you are not going to go now and save your own skin.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "You are going to do something for these two ladies now.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "Otherwise, you will not go, I promise you.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And he had to, and he did.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And then, thanks to him, we were taken to the Greek Catholic convent.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Actually, the metropolitan, the head of the Greek Catholic church, took us in-- all of us, at first.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And then he separated us here and there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And my mother and me, we were in a convent and an orphanage at the same time, a Ukrainian one.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "And for me, it wasn't such a terrible thing, because I spoke Russian.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "And for me to learn Ukrainian was not difficult, and I did very quickly.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "But for my mother, it was very difficult.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "She could never, never, never learn that language.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "And so they decided that she was going to be a deaf and numb person.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "In other words, doesn't speak at all.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "Doesn't hear, doesn't speak.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "Fine.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "Well, easier said than done.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "It was very difficult for her to play such a role.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "I mean, constantly to not to react, you know, to whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "And what she did-- and she was as such.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "And I was in the orphanage, and she was in the actual convent, in the quarters of the Reverend mother, Mother Superior.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "She kept her in her quarters.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "She provided for her the necessary papers and genuine papers-- birth certificates and such like and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "I had nothing-- absolutely nothing, no papers whatsoever.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "Again.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "But-- well, if anybody had asked, it would have been very bad.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "But thank God, nobody did.",
      "word_count": 5
    }
  ],
