{
  "stem": "6878.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So we went-- we didn't go straight from there home, but we went down the bridge near Kovna, also the river by the name [INAUDIBLE], and we went and we stopped.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We may catch fish there.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But it was a bad day for fish catching, and the planes were still intensive, more flying around, and we picked up and we come back.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "When we came back to my flat, my wife, Ida, was standing there and crying-- I married in 1940-- was standing outside the flat and crying with the words, [NON-ENGLISH SPEECH], where did you got lost?",
      "word_count": 36
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And, well, we explained to her that fishing was bad.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We try this way, that way.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, a day later, my motorbike was confiscated.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The fighting intensified.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "The Germans started to bomb Kovna, so we started to run towards Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "A lot of people, also, started to run towards Russia.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And my friend was visiting [INAUDIBLE] Kovna, that [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I mentioned him before.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So he came to me crying that he wants to go home, no transport.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I said, come, I'll give you a bicycle from the shop.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I still had the keys from the shop.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I'll give you a bicycle from the shop, and go.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "But unfortunately, he did not arrive.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They killed him and took him away, and took away the bicycle from him.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Motel, I'm going to take you back a little bit.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Tell me about your wife Ida, how you met her, when you got married.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "With Ida, we were in [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We grew up together in [INAUDIBLE] [INAUDIBLE] as kids, you know.",
      "word_count": 11
    }
  ],
