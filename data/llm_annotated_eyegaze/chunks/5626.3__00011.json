{
  "stem": "5626.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And another person carried a back holder on his back-- it was made out of wood-- shaped like an L, a long piece on the back.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And the flat part, another one put up the stone.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they had to go and build stairs from the quarry all the way up to the camp.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I think it's 163 steps, if I remember correctly.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Because we saw this place in 1970, when we went back to the Mauthausen camp site, visited.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Our son, which was-- at that time he was already 16, 17 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "He wanted to see what we wet through and where.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And we saw these steps.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And we even walked up the steps.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "There is a-- a-- not statue.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "There is a sign.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It's marked that these steps, I think 163 steps, were built by the people who were incarcerated or what, here in the camp.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And in the same camp, at night, since I was working early morning till noontime, I didn't see this at that time.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "But buddies who were there told me this later on.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "There was the so-called death march in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "The camp was built on the top.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And the quarry was down there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And they had to walk, every night.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "They had counting in the morning, early morning hours, and counting at night.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "After the night counting, they have to go out and walk, right at the edge, one by one, keeping one-meter distance from person to person.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And the German SS soldier was standing over there with a bloodhound dog, a huge German shepherd.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And he told the-- the dog-- the soldier told the dog, go ahead.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And the dog pushed the men down.",
      "word_count": 7
    }
  ],
