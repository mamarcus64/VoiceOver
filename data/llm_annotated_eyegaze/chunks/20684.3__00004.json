{
  "stem": "20684.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "I finished up with a fur coat, a girl's fur coat, I think.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "I'm not sure what it was.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "But I had a fur coat at one stage, one of the winters in Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "We went to school, we learned Hebrew, we learned Yiddish, and we-- we writed and writed.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "And finally, my uncle from Paris, my mother's brother, found out that we're in-- in the displacement camp, we're spending nine months to one year.",
      "word_count": 25
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "All of-- last of '46, beginning of '47.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "He got us out, also some money-- he got us set up with the money, got us out, took us to Paris.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "With me all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He took us to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We went by train from Stuttgart to Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We were met there by my family-- my uncle; his wife; my cousin same age as me, girl; and another little girl who was only about three or four years old, could barely walk.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "We were taken in, given a good wash, and we had the whole family getting together.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "There was another uncle who survived.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "In France, most of my family survived.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "In Poland, only my mother and I from Poland-- other than Uncle [INAUDIBLE] in Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But in France, most of my-- my father's brother survived, his wife perished, his three daughters survived, my mother's brother survived who was also a doctor, studied together with my father.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "My father helped him out through their studies.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "He apparently wasn't quite as bright.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "Everyone seems to tell me that my father was very bright so he make sure that I wouldn't study medicine so I wouldn't compete with him.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "I choose-- I choose engineering instead when I came here.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So that's the brother my father helped.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "That's all relevant to the next part.",
      "word_count": 7
    }
  ],
