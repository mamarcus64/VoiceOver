{
  "stem": "15900.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.3,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "He wants me to stay in Blonie to-- to work for the Communists and become the police chief and everything.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I went back to Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And the guy--",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I met people and they told me-- I went to the post office.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They told me a Galek was there.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "A Galek was there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I think my brother who survived, he was there.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "But anyway, I had one thing--",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "People lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "But somebody else already occupied it.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I-- I it-- my-- my-- my cousin had it, who survived, some pictures that have it, a little snapshot.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I had the snapshot, too.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I don't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And-- and-- and my niece here made-- made-- made the copies.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "My-- my-- my cousin, yes, has the picture.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And-- but anyway, I settled in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "In Krakow, they didn't know I was a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I speak Polish and Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And the-- and I lived in a section, [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "If you know Krakow, the-- the Polish kings are buried there.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, they're preserved like Lenin was preserved.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "They preserved the Polish kings.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And anyway, the-- the Polacks come over to me, you know the Jews came back from Russia?",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They must have a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Now let's go rob them and kill them.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Oh my God.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "I said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Why-- why you want to rob them?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "How you know they got money?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "Anyway, and I was shaking.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "They don't know I was a Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "I was shaking.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "Later on, I don't know [INAUDIBLE] in Moscow are the Russian army who surrendered the building and have an investigation what they did.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "And this happened at a police made the-- made the-- tried to organize the killing.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "The police.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "Tried to organize the killing of?",
      "word_count": 6
    }
  ],
