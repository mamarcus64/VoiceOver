  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And, of course, we went back also-- she went back to Majdanik, went back to Auschwitz.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "On the way we visited Belzec.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And we came in and we found, in Belzec, about six or nine places where the crematoriums were there.",
      "word_count": 19
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "And I felt that this is the place.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "This is the cemetery where my parents and sisters and brother were exhumed there.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And, of course, with the proper prayers, and we said Kaddish there.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "What else can I tell you?",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Life has been good to us.",
      "word_count": 6
    }
  ],
