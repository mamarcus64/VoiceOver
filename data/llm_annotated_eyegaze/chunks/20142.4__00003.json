{
  "stem": "20142.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "There were a number of people, youngsters, who are in about my age, or a little older, that came to work on a-- working for somebody else or were caught by the gestapo and forced to come every day to work.",
      "word_count": 41
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They were all Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They were all Jews, and there were 28 of them if I'm not mistaken.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And they were brought to Majdanek and were put in a working column the following day, were building dirt field, that means the first field.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And the second field were already built.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The field was a separate compound, separate [PAUSES FOR 4 SECONDS] piece of land, on which another camp, a camp in a camp.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And in this camp, there were 22 barracks, plus the administration barracks and the other facilities, including a kitchen, and the bathrooms, and things like this.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "In each share of these barracks were between 300 and 400 people, to 500.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It became really congested.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And there were daily selections going on.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Required a great number of Russian prisoner of war, which were dying left and right because of malnutrition and impossible conditions of-- They kept to themselves and did not associate with anybody else.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And during the late months of 1942, [PAUSES FOR 5 SECONDS] he sent us to work into the Lublin, to the city of Lublin, which was about 10 kilometers from Majdanek.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Just carrying building materials from place to place and putting it in place.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Most of the walls for the barracks building material, building material for barracks on the dirt field.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "When we ran out of the material, then sent us to work in a munition factory in Lublin.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And in the--",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Until they sent us to Lublin.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "This was May, June, July, August, September, and October.",
      "word_count": 9
    }
  ],
