{
  "stem": "18581.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 383.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And they used to bring it to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And then we used to read the requests in writing of people who wanted.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And we used to decide two kilograms of potatoes, one kilogram of bread, two kilograms of bread, some soup cards, and so on.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And this is what we did.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "The-- this committee was of course a place where some of the FPO operatives, like Sonja Madeisker and Rosa [INAUDIBLE] and [INAUDIBLE]-- the first two are Communists and the one was from the Labor Zionists.",
      "word_count": 35
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "They worked.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "There was also [INAUDIBLE], who was a Buddhist.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He was also a member of the committee.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I knew about them, but I was very careful to keep my nose clean and not to say anything about it.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The FPO was Fareynikte Partizaner Organizatsye, which means in English United Partisan Organization.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And of course, it was a open secret in Vilna and they knew about it.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Nobody suggested to me to join, maybe because I-- I voiced opinions against the United Organization with the Communists.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I did not believe that joining with the Communists, although it was meant because people had the idea that Communists must have some very good contacts in town, outside the ghetto and-- But I knew the Lithuanians from childhood very well.",
      "word_count": 41
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I knew the Lithuanian Communist Party is composed of 50% Nazi agents.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I was right.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And of course, the man who was former mayor of Vilna, Vitus, who was a Lithuanian Communist, and others, they were immediately captured.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They were compromised.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And in the end, they gave the name of Wittenberg as an example.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And then the whole tragedy of Wittenberg started.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And the foundations of PLO were shaken.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I lived on Spitalna, I believe number 9.",
      "word_count": 8
    }
  ],
