{
  "stem": "3475.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Joseph Aleksander, J-O-S-E-P-H A-L-E-K-S-A-N-D-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is August the 3rd, 1923.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Warsaw, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "At that time, my name was Joseph with an F at the end.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I also had a middle name Leib, L-E-I-B.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my nickname was Lolek.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "My friends used to call me Lolek-- and my relatives, and so forth.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "But after the war, I dropped the word 'Lolek,' you know.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't too crazy about it.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, what I remember from my childhood is that it-- you know, times were not that great most of the time.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was during the Depression.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And things were very hard for most everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I remember wishing for many things that, that I couldn't have, even as a child, for a nice rocking horse and, and nice toys that I didn't have, and then later and I-- later on for nice clothing, which I couldn't have.",
      "word_count": 43
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Most of the time I wore hand-me-downs from my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My brother-- my brother's name was Joel, J-O-E-L.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Joel is one year and two months older than I am.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We were pretty close, not, not really that close.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My, my brother had his own friends.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I had my own friends, I guess, because of the age difference, slight as it was.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had a [PAUSES FOR 3 SECONDS] not a very large apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We lived on the second floor.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And it was one very large room, basically, and a kitchen and a bathroom.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the room was kind of divided by-- with moving walls, so-- into separate quarters for my parents and for us.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Abram or Abraham.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Pola-- in Jewish, was [?",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Pesa. ?] And--",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I spoke mostly Polish at home.",
      "word_count": 6
    }
  ],
