  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Michael Kraus-- M-I-C-H-A-E-L K-R-A-U-S.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Michl Kraus, M-I-CH-L K-R-A-U-S.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My friends and my parents always called me Misa.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was-- in Czech, it was M-I-S with a little accent circumflex inverted and an A.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born on June 28, 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "66.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Trutnov, T-R-U-T-N-O-V, which was in Bohemia, which is now the Czech Republic.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We belonged to the middle class of a small town that was nestled in a little valley overlooked by a beautiful castle.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The town had about 15,000 inhabitants that was famous for its textiles that was exported all over the world.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And many of the Jewish inhabitants were involved in textiles, either as owners or directors of mills.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "My father was a physician that had a large family practice that consisted of all walks of life.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "There were the wealthy people down to peasants that lived in the outlying villages.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So we were relatively well-off, lived in a villa in a large garden.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I only found out after the war that that villa didn't really belong to my father but to his brother.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "My childhood was obviously without any worries until the 1938 fall when Czechoslovakia lost its border regions to Hitler, the Sudentenland.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We-- I did not have any brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "I was the only child and was probably somewhat spoiled and had everything that I wanted.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "I went to school, to elementary school, which was almost on the same street from where we lived.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And to the best of my knowledge, I was the only Jewish child in that particular school.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Most of the other Jewish children went to another elementary school, which was closer to the center of town.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was certainly-- I wouldn't call it at the beginning discrimination.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But I was different.",
      "word_count": 4
    }
  ],
