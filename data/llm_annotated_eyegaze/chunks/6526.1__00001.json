{
  "stem": "6526.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Here, I spell Rzansky Z-O-N-Z-I-N-S-K-I.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do remember my grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father's father was [INAUDIBLE] Kisielnicki.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my father's mother was Es-- Es-- Esther.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And my mother's father was [?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Fischel. ?] And my mother's mother was Rivka.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My father was a businessman.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We had a grocery, wholesale grocery and retail grocery.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "That was in the late-- I remember-- in the late '20s, also in the early '30s.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Later on, we had made the gasoline station.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And we also with a partnership in trucks that the people in the town needed to have transportation, they needed support.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "My father was a partner, like a silent partner.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We didn't-- we did not rent trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We did not sell.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We were a partner to the-- to their trucking.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "There were a group of people that used to carry merchandise to and from Warsaw, and they needed to-- the money or they needed things, and my father was like a silent partner.",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Then investing in it.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And-- and as a matter of fact, that my uncle, my father's brother, was a partner in that endeavor.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "This is how we had the trucks also.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, is the-- Yes.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We had a restaurant.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We had a restaurant that was open 24 hours a day with the exception of Rosh Hashanah, Yom Kippur, and New Year-- Christmas and New Year's.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Well, the Rosh Hashanah, Yom Kippur was closed altogether.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise Friday night, because it was a religious town, was open the entrance from the back, from the side street, because it was Friday and we did not want to antagonize people-- the neighbors or other people because the entrance of the business was done on the side of us.",
      "word_count": 51
    }
  ],
