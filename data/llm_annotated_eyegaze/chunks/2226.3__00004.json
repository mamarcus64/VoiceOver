{
  "stem": "2226.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I had four bottles.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I tell you, I could have take out a whole car.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I could have take out, at least 30, 40 salamies from the slaughterhouse.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I used to go to the slaughterhouse-- anything what I wanted, I could have taken one.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "You know what I done?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "See, this is a bottle-- oxygen.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Here, in Canada, the bottles are round.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "If you stay with a torch, they can [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "In Europe, the bottles are like this.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "They've got the-- a little thing out here, like it's swaying.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I took that off, took that out, and took it at the-- on the lathe.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "You know a lathe?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "You know about a lathe?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "You were-- you-- you make the steel smaller or bigger.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I took it out, and make it exactly a little-- a little smaller.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "So we cut it on the lathe.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I see.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "But this, this fits exactly here.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "So when I want to take it out from the slaughterhouse, I just took that out and filled it up inside.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We-- [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, what-- what do you call a group?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Everybody [INAUDIBLE] get a-- we get a-- had only one-- one thing, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You know what [NON-ENGLISH] is?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Don't forget, and don't forgive.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You haven't got nothing to lose.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "It's like I thought the head was a Jewish fellow.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He was from Suwalki.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "His name was Kaminski, the head over kapo.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So I thought he's against us.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Well then, what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He was with us.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Oh, but he didn't want to show up.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So what's happened?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH SPEECH] Took him out for-- for a walk.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He took a walk around the crematorium.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "He took out a gun and killed him.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "Really?",
      "word_count": 1
    }
  ],
