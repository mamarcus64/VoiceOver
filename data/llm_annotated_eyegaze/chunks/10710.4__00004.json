{
  "stem": "10710.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 77,
      "text": "In the winter, it was in January-- we came there in like November.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 78,
      "text": "It was January, February, it was already by the end of the war.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Beg your pardon?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "1945.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "There was a camp [NON-ENGLISH SPEECH].",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they liquidated the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "They put about 100 Jews in a wagon, and no camp wanted to take them in.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "They went to Auschwitz, and they went to this camp.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Nobody wanted to take them in.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And they were riding for two weeks in the cold weather.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Half-frozen people.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Nobody-- no camp wanted to take them came in.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Somebody called Schindler from [NON-ENGLISH SPEECH], which was the next town.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And they told them, there is a wagon here with Jews where they hear some noises from them.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "Nobody wants to take them.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "He says, send them into Brunnlitz.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "We had a place where the trains would come in.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I wasn't there when they opened the door, but a friend of mine was there.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "It was a horrible thing.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "People were half-frozen.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Naked, frozen people with all kinds of shapes.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "You couldn't take them out because their skin was frozen to the floor from the wagon.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "You have to put hot water to get them out.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "A friend of mine who lives here, his name is Mr.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "Heller, he was a strong guy, and he went to help the people out.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "I saw the people when they brought them to the rooms there.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "They there-- [NON-ENGLISH SPEECH] skeletons and they were half alive.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "They were just frozen.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Your limbs, you know, you couldn't do nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And some of them survived.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "Some of them.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "And then Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "Schindler, Schindler's wife, she used to bring them all kind of food to nourish them.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "But this was a horrible scene.",
      "word_count": 6
    }
  ],
