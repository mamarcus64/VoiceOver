{
  "stem": "12491.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And we were walking on highways towards east.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "We stopped at the first place, about 35 kilometers east of Crakow.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "The name Bochnia, B-O-C-H-N-I-A, where my father had an acquaintance.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "We rode there.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "We knocked on his doors.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And he allowed us to sleep over, on the floor, in-- in his hallway.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "At about 4- 5 o'clock in the morning, he knocked on the door.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And he said, you better get out and-- and go further east.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "Because the Germans also coming from the south.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "By that time, Germans have occupied Czechoslovakia, which is south of Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And therefore, they were coming from the west, as well as from the south.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "We had to quickly get organized.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "So we started going a little bit more northeast rather than east, to try to get away from both of them, the ones coming from the West, as well as the ones coming from the south.",
      "word_count": 36
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "Being on the road at that time, with thousands and thousands of other people, it was very difficult to get any food.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "It was very difficult to get, even, water.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "When you let the bucket of a well down into the well, you brought up a bucket of mud.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "There was no water in the wells.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "We actually-- people actually have drunk the well dry.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "So we decided that we gonna-- not gonna stay on the road.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "There were three of us, my two brothers and I.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "And they will be going through the villages, rather than through the highway.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "And we found it much easier.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "Because there was water in the wells.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 26,
      "text": "And there was also many different things right in the field, which you could pull and eat.",
      "word_count": 17
    }
  ],
