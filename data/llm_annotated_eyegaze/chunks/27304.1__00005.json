{
  "stem": "27304.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Because all the youth was leaving, the young people.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "And everybody was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "Maybe it was something in school, maybe this, maybe that.",
      "word_count": 10
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 3,
      "text": "Everybody ran away, the young ones.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Well-- [PAUSES FOR 3 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "--like from 10 to 20.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "So did you talk about that with your family that you were going to run away?",
      "word_count": 16
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "We didn't talk about it.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "We just picked ourselves up and run.",
      "word_count": 7
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "I went with my older brother Nachman and my younger brother Lev.",
      "word_count": 12
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "We're going to Russia, yeah, with all the rest of them.",
      "word_count": 11
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Just one, the father lived.",
      "word_count": 5
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "My mother died when the Soviets were there in 1940.",
      "word_count": 10
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "She died.",
      "word_count": 2
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "She was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "See, my brother Avrum was already in the Russian army.",
      "word_count": 10
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "They took him because his year, he was born in 1919.",
      "word_count": 11
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "And his year, they took.",
      "word_count": 5
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 3,
      "text": "They mobilized.",
      "word_count": 2
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 4,
      "text": "That's why he was in the Russian army.",
      "word_count": 8
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "Later, he was in jail.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "But at the beginning, he was in the army.",
      "word_count": 9
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "And my oldest brother was some big shot on the railroad.",
      "word_count": 11
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "He ran away separate.",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "And then me and my brother older than me and the one younger than me, we ran away together.",
      "word_count": 19
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "My father, my sister, my youngest brother.",
      "word_count": 7
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Chaya and Shalom and my father.",
      "word_count": 6
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "They were killed with the Nazis.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "What I took with me was my dress and my shoes.",
      "word_count": 11
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "I mean, what you had on was all that--",
      "word_count": 9
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "What I had on.",
      "word_count": 4
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 2,
      "text": "What I had on.",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "We went-- first, we went on horse and wagon, a little walking.",
      "word_count": 12
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "That's how all the people went, the refugees.",
      "word_count": 8
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "It was a lot of people together, even Ukrainian people.",
      "word_count": 10
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "But then the Ukrainians run back because they were afraid of the Germans.",
      "word_count": 13
    }
  ],
