{
  "stem": "523.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And she was so cruel to me.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "If I cooked a little bit of food, we're cooking on the same stove, wooden stove with charcoal with ashes, she would put in ashes and charcoal in the food.",
      "word_count": 30
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So and I was cooking for this gentleman.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he thought that I did it on purpose.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And he used to beat me up brutally.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I was afraid again to say what, that, what happens.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And he used to throw me out in the backyard in the night.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I was sleeping on the grass and crying myself, miserable, alone.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have water to bathe or to shower or to keep myself clean.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "So I needed a comb.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I find a fork.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And the fork became my comb until I scratched my scalp.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And it became infected.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "But I had nobody to talk to.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "I went to visit my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "And this was the last time I saw him.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "This was in '44.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "And somehow, I had a feeling that I will never see him again.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "And I had a chance to go back with a, with a military because the military man was from Ediniti.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "And he took me back to Ediniti.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "And I said goodbye to my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "And he said, Freda, don't cry.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "I will come.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "And I will take you.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "It won't take long.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 25,
      "text": "But he couldn't come to take me because it's Russia.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "It's not like here.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "You want, you move here.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 28,
      "text": "You went there.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 29,
      "text": "He couldn't even come to visit me because at that time, in order to come from one town to another, you need a paper that you're allowed to travel.",
      "word_count": 29
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 30,
      "text": "As long-- nobody gave him-- there was no reason to let him go.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I couldn't go there.",
      "word_count": 5
    }
  ],
