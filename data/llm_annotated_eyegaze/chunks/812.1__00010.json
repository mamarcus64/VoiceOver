{
  "stem": "812.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 144,
      "text": "And my mother was able to smuggle [PAUSES FOR 4 SECONDS] some potatoes and a little can to our bunk one day.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 145,
      "text": "And [PAUSES FOR 3 SECONDS] with the little strips of-- from our slats, she was able to make a little fire, and somehow she was able to collect a little water.",
      "word_count": 31
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 146,
      "text": "And she was able to get salt, and she was able to [PAUSES FOR 3 SECONDS] make a little soup for us.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 147,
      "text": "This was done in very private on our bed, on our bunk, and I was on the bunk with her hiding the set-up.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 148,
      "text": "It took an hour or two before things start to boil, before the soup started to cook, when the Germans came into the barrack for their routine inspection.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 149,
      "text": "[PAUSES FOR 3 SECONDS] In order to hide the set-up, the soup spilled, and it had been boiling already for a short time.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 150,
      "text": "It spilled on my leg.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 151,
      "text": "We learned self-discipline the hard way.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 152,
      "text": "And I knew that if I were to cry out, it would cost us our lives.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 153,
      "text": "I was 10 years old at the time, and I, with the soup on my leg, kept very quiet and had a severe, severe burn-- my upper leg, my lower leg.",
      "word_count": 31
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 154,
      "text": "[PAUSES FOR 5 SECONDS] This was towards the end of our stay in Bergen-Belsen.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 155,
      "text": "This was in-- already in end of March of 1945.",
      "word_count": 10
    }
  ],
