  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And all the people around me, all my friends, were around the Appelplatz, you know, you know, standing around.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And they were just beating and beating and beating me-- and I don't know how long it took-- with, with, with sticks and, and, and steel bars.",
      "word_count": 27
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Then they say they're going to hang me.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "You're going to be hanged.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So at the last minute, I look at the people, and I said, my god.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My mind went through, I survived so long.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And this is the last minute.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "What did I do?",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And I said-- I said to the people, Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[POLISH], just like that.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "The minute they heard that, they said, you-- what did you talk to the-- there were some Russian people with us too.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "He said in German, [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "You know, they were afraid that I spoke to the Russians something against them.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "So they, they, they pulled me, and they're going to hang me.",
      "word_count": 12
    }
  ],
