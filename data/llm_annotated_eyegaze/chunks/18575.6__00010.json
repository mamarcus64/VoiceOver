{
  "stem": "18575.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 509.3,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "That was a, a sister of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I've seen it so many times.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "I've been so close to it.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I was weak.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "In fact, when we were liberated, the American put us into German military barracks and gave us Red Cross packages which had everything in it, chocolate, powder milk, sardines.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And we ate everything.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And people died.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "The stomach burst.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "I had a horrendous diarrhea.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "Everybody had it.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And we learn in concentration camp to stop a diarrhea because you had diarrhea constantly.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "You ate such junk.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "You ate stuff off the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "You ate bark, anything.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "You take charcoal.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "You burn wood and you eat charcoal, and it stops diarrhea.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "That people start dying.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "They stopped-- they brought a medical team, the US Army, and they took us off the food and put us on, on broth, and rice, and very mild food.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "But I recuperated very fast.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And where did you go after you recuperated?",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We were out.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "In fact, the first thing we did-- friend of mine and I, we're-- three of us there were.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Two friends and I, all from Warsaw, all went through the same camps.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They live in Germany, at least.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "One of them is leaving.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Stefan Szczupak.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I don't want to start spelling it.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Would you want me to spell it?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "Yes, if you wouldn't mind.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Stefan, S-T-E-F-A-N.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Szczupak is S-Z-C-Z-U-P-A-K.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "That's pike in English.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Szczupak is a fish, pike.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "He lives now in Hamburg, Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "He married a German girl.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And another Warsaw guy, Sevek, S-E-V-E-K.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I don't know his-- no.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "His last name is Dytman.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "D-Y-T-M-A-N.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Dytman.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We walked out and somehow got to the railroad station, which was full of luggage, German luggage.",
      "word_count": 17
    }
  ],
