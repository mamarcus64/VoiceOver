{
  "stem": "23498.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was a sin when it was-- oh, wait, it was the holy week.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Easter.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "It was '43. '43.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Easter.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It couldn't be Christmas.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was Easter.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And they invited people.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The daughter, she insisted that they make a big party.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And I said, what about me?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "You have to be hidden.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So cruel.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And she was cruel all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they were-- of course, they were all drunk like pigs.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I was three days and three nights under the bed.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] like that.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "They are drinking and singing and really rude and so on.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And a little baby is with them, little, maybe two years old, girl or boy, I don't remember.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And she's throwing a ball under the bed.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And I thought she will come here, and she will tell her parents.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "So I throw the ball back, and she's throwing it again, because she-- it was a big fun for her.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And then she's screaming, Mom!",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Mom!",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Look!",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Look!",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "You know, but luckily, the mother was drunk, and she didn't notice.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "So that was one thing.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Another thing was this Slawinski-- the older son had a girlfriend, and she was coming every night to sleep.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "That was, mind you, everything it was in one room.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So they were-- there was the broken bed for me.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "When my mother came, we were both sleeping on the broken bed.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And two beds for the younger brother and the older who had a girlfriend whose husband was in Germany.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "So in the meantime, she had a boyfriend.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "But she was-- she didn't talk to me.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "She was indifferent.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But the younger brother wouldn't touch me because he hated the Jews, so I was lucky in that respect.",
      "word_count": 19
    }
  ],
