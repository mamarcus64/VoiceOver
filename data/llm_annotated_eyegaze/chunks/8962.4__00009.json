{
  "stem": "8962.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And in the next mail, we had a check from him for $450. $150 each.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And he said, that should help you in your beginning.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And we wrote him back and we said, please, leave immediately.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "It wasn't time.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Hitler had marched into Holland.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Well, the three of us were in Baltimore.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And this Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "Kern, Robert Kern, a friend of my dad's, got him a job.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And got me a job as a second floor maid, and my mother, in the same house, a cook.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So we each made $6 or $8 a week.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "It was wonderful.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "We were in America.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "We were in a beautiful house with very wealthy people.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "They gave us our affidavit.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And life was great.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "Except my mother and I lived in one end of the city and my father lived in the other, in a furnished room.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "And he said, this has got to stop.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "Because we lived apart for 3 1/2 years, and I want to live with my wife, at least.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So one day the woman of the house said, you don't cook like we cook here in America.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I would like for you to leave and get another job.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But I don't want you to cook for us anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Your daughter can stay as a second floor maid.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And so my mother and father rented a big old house, and they made a boarding house out of it.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And it had, I think, 11 rooms, 12 rooms, and an apartment upstairs.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So they rented the apartment upstairs to a couple who had come with us on the boat.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And the other rooms were then rented to shipyard workers.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And my mother cooked for the shipyard workers and made sandwiches for them to take along.",
      "word_count": 16
    }
  ],
