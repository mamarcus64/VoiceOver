{
  "stem": "3212.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And [PAUSES FOR 3 SECONDS] What I forgot to mention-- our rooms was not only from Austria.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "We had kids from all over the world.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "We had children from Holland, Yugoslavia, Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "It was from-- community-- children from all over the world.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "It had nothing-- all Jewish people, but had nothing to do with Austria.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "From Europe.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we were all together.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We helped each other.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We tried to help and do whatever one can for the other one.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "But Walter and me, I think we were the only Austrians in this room.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I fixed the shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Then the first transport, everything was OK.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "On the second transport, I repaired the shoes for a guy.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I always had to warm the iron to soften the wax to fix the shoes.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't-- the hot wax to heat this metal finished.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I tried to use liquid.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And I tried to use the liquid to put in a little can.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And this whole thing started a fire.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And I started burning by myself.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "I burned by myself.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And the whole room-- the beds with the mattress-- everything starts burning.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And I start screaming and running around like a fire.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "My whole body was burned.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "Luckily, one of the children took a mattress and put it on me.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "He pushed me down and put the mattress on me.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "So it stopped the fire.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "But I was burned.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "And I had third degree--",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Fire damage.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And they bandaged me.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I had to work with crutches.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't walk like that.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if it was a hospital or not.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I know only that I got bandages-- if they did it in my block.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But I couldn't walk.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they gave me crutches.",
      "word_count": 5
    }
  ],
