{
  "stem": "1316.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "She used to live in Warsaw-- she had  a husband, two children, a boy and a girl.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "The husband, as soon as the war broke out, left and disappeared.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "She didn't hear from him.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "We don't know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "She was left with their  two children.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "She went back to a village, near Lublin, where she grew up.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "My grandmother lived there, and my uncle lived there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "There were village Jews-- Jews that lived in villages.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "They were merchants.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "They were-- they had food-- like with food.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "And they were also shoemakers, tailors, and so.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "And they lived among the Poles quite peacefully.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "She went there.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "But when they came to arrest all the Jews in that village, she ran out through the window with her two children.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "And a Pole ran after her, he caught her.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "And her little son-- he was about 9 or 10 years-- ran over to him, he bit him in the hand.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "So he left her for a moment.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "She ran away with her two children.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "And she came back to Otwock to stay in the ghetto with our family.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "What happened, they knew that they going to take them away.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "On August the 18th, the police-- the German regional head of the police came, Brandt.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "And they knew that they-- photographed them.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "I found a few photographs.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "They said they sending them for work, for labor.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So they photographed them.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I found, in the Jewish community, I found a whole box of photographs.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So I took out her mother's photograph-- somebody else's, their photograph.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So they knew they were taking them away.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So the night before, on the 18th of August, 1942, my auntie took her two children.",
      "word_count": 16
    }
  ],
