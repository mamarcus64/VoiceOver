{
  "stem": "12051.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "That's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It's January 15, 1926. in Berlin, Germany, B-E-R-L-I-N.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "70.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] That's a painful thing to say.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My childhood was a beautiful one.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was an only granddaughter to a large family.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Most of them lived in Poland, except for three uncles that lived in Germany, including my parents.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Unfortunately, everything was very short-lived.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Because when Hitler came to power, I was so excited about it that I came home, as a child of six, and I said, Heil Hitler.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And my poor mother didn't know how to explain that to me that this was not meant for me.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Shortly thereafter, a year later, in 1934, we were told being that my parents were of Polish origin, that we have to leave Germany.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Otherwise, we will be shipped out.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I have-- had an older brother, eight years older than myself.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And being that none in the family spoke Polish, we moved to Poland, [BACKROUND NOISE] but to a city that spoke only German.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "The city was called Bielsko, Bielitz.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My parents were Orthodox Jews that lived a very comfortable life.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We had a beautiful apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "My father was in a company in, in Germany that was dealing with the-- he was partner there-- with linen and tablecloth.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And the life was a very comfortable and beautiful one.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It was a big Jewish community.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We lived not too far from the Jewish center, where my father belonged to an Orthodox shul.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "My brother started school there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "He went to the [GERMAN]-- no, on to the-- I started at school on-- in Auguststrasse, which was also a very short time because we had to leave.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And it was very unfortunate because we lived a nice, quiet, comfortable life.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And we had relatives there.",
      "word_count": 5
    }
  ],
