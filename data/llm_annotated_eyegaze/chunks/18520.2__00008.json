{
  "stem": "18520.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 19.0,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, oh, he came back later, later, later, when I was there already, when they closed the ghetto, when they closed the ghetto already.",
      "word_count": 26
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what-- which transport this was, after me.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "But they finished the ghetto and--",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "Mr.-- did-- could you bribe Rumkowski if--",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I was--",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not just me, even other people.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "This Rumkowski had just met the, the, the, the [NON-ENGLISH], they used to call them, the top of it, you know, the top.",
      "word_count": 23
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Some people, maybe.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "You don't know about that.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Were, were there-- were you in a [NON-ENGLISH] or an [NON-ENGLISH] in the ghetto when they took people out?",
      "word_count": 19
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "They, they they came, the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They, they, they closed off the building.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember if another building.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "But they closed everything.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And everybody raus, raus, raus, raus.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "And then they went in to check.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "And they said take a pot.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 8,
      "text": "Take a fork and a spoon.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 9,
      "text": "You're going to work.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 10,
      "text": "And that's all what they said.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "We all went.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "My mother put the keys here--",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--from the house.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "What she hided, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "He died in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And a brother.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "And two brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "The rest of it.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "There was no funeral.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "A lot of people what they did to get their portion bread every week, and many times you didn't get it either.",
      "word_count": 22
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Because I came to the store.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "You stood from 2 o'clock at night by the window outside, cold or warm, whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And then they say, ha, no more.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "You always hope that you make it.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "So, so what-- I have so many-- so many things in my head comes back.",
      "word_count": 15
    }
  ],
