  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "My life has changed completely, besides the emotional.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Actually, you know, in the actual way.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I am living in a country that I love now, and where I have all the rights and privileges.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "I lived in a country where I was second-class citizen, and that's how I would have lived.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Also tremendously.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I have never felt Jewish until I was told that I'm something that should be exterminated.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And then I went through our history, and I tried to find out why?",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "What happening?",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And I still don't understand the hatred that people in Montana have towards Jews, because they don't see any Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "How do they know?",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And whether it's religious, or whether it's-- well, whatever it is, it's the hatred that scares me, you know, nowadays.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "It's the hatred that is shown that scares us.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And of course it affected me.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
