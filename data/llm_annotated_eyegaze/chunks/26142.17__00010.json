  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And they said, he all of a sudden, he died of poison, this Dr.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Schwartz.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And in the revier, everybody said that he was poisoned.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He was poisoned because they didn't want him to live to see, to tell what was going on in this-- in this operating room, this so-called operating room.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 4 SECONDS] a few weeks, a few weeks-- it didn't take a few weeks after I was in, we could hear, already, the cannons fire at night.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We could hear the front is near.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And we got-- we got, one day, the order to-- to evacuate.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And of course, because I was-- I was bandaged, I had only one shoe.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "That shoe, the doctor couldn't take it off.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "He had to cut the shoe off and throw the shoe away.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And-- and that's how-- that's how we were carried onto open wagons, in-- in-- to the-- to the train station and loaded up.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "OK.",
      "word_count": 1
    }
  ],
