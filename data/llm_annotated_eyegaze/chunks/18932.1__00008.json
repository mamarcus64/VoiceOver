{
  "stem": "18932.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "She-- at least we knew where she was buried.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Me?",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I went to school, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "I went to school for a short while.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And then they just closed all the schools, and everybody had to go to work.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "So they send me to a place.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "They were making carpets.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "It was a [NON-ENGLISH] resort.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "It consisted-- we had like a frame with some kind of a cotton going through.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "And we used to get pieces of material and make long, like, long pieces of material, and then we used to weave it in and make designs.",
      "word_count": 27
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "They really came out quite nice.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "The only thing, sometimes we got stuff from people that were evacuated, and we saw there, like, three shirts one into the other.",
      "word_count": 23
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "Because a lot of people, when they were shipped out of the ghetto, would wear a couple of things, you know, one on top of the other.",
      "word_count": 27
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Right, some of the clothing was bloodstained.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "The time in the ghetto was the worst part of-- of our lives, because we lived in constant fear.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "We never knew when there's going to be an appell and when they're going to take people off the streets.",
      "word_count": 20
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You were never sure where you're going to be when they're going to catch you.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And that's what happened to my father.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "He was once walking in the streets, and they caught him on a truck, and they-- with a lot of other people, and he had no chance.",
      "word_count": 27
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And they just evacuated them and shipped them.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "We never heard of them again.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, we don't.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He was gone, and this was the last I ever heard of him.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "It was me and my mother that was left.",
      "word_count": 9
    }
  ],
