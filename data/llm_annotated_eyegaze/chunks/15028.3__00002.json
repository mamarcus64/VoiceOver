{
  "stem": "15028.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I shall get into the shower, and grabbed it away, and just threw it.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "He didn't know--",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Just whatever was yours, they took.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Everything took away, only thing-- nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They just gave me the striped uniform, and the-- oh, the cap, and that's it.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And shoes, what I had.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They left me the shoes what I came in.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Nothing to select by age.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Had nothing to do with age.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "The way he saw-- they didn't take any young people under 15 or 14.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "If slipped through if the kid was husky and tall, and if he told he's 16 or 18, they let him go ahead.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But if a kid was 16 and he looked 12, he went to the gas chamber.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The older people went to the gas chambers and the crematorium.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A couple of days, a couple, two, or three days.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "After the two or three days, they, like I mentioned before, they counted certain amount of people.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they put me in-- put us in a train wagons.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And we went for a couple of days overnight.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And we arrived in a place called Dyhernfurth, in a camp.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "That was a labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] With electric fences, on top, they had machine guns around the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And they had factories not far away from the camps.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we arrived there in afternoon.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And next day, we went to work.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Put us in a barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "The barracks contained of double beds.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "We got a blanket, and two beds [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "We were in a barrack, I don't know how many people.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "I would say 150, 200, I don't know, a lot of people.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And kept spotless, clean.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We-- we had to.",
      "word_count": 4
    }
  ],
