{
  "stem": "24411.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 34,
      "text": "We went home.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 35,
      "text": "And I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 36,
      "text": "And he went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 37,
      "text": "Then they called us up.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 38,
      "text": "He's very, very, sick.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 39,
      "text": "And I didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 40,
      "text": "And I didn't know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "So I called the union and the-- my boss called the union.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "The union told him.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And they met.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And we went to see him.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And it took two-- two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "Then we took him home.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "He was OK.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "Did you have any other children here?",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Then we start both to work, and we saved up some money.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And-- and the-- we bought a four-family house in Bensonhurst.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And Irving was already 10 and a 1/2-- 11 1/2 years old.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And he start to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "He said, ma, I'm all alone.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "He said, everybody has family-- grandpas, aunts.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And I said to my husband, I said, what we gonna do?",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Who could afford it?",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Now we bought this house too.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "It's very bad.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And I got pregnant.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And I was working till the seventh month.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And I got Karl.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Karl was born 19-- 1957, in Borough Park, in Maimonides Hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "It was a very big thrill.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Karl's-- Karl lives-- now he's in Florida with his brother-- with the whole family.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "He works very hard, and he lives in Long Island.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "He has two beautiful children.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "Jonathan is fourteen.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "Danielle is-- he's a genius, a walking encyclopedia.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "And he is 100 from all the subjects.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "And Danielle is just 10.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "She's very beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "She's very good.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "And Irving has two children.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "One lives in Houston, Texas with her--",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Jennifer, and his name is Brent.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And they bought a house.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "He-- he works in the computer chips-- for the making the computer chips.",
      "word_count": 13
    }
  ],
