  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Then I went to my-- my girlfriend, my girlfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I stayed with-- with her parents.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Their name is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Then they used to took for me [INAUDIBLE], to work-- to work.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "The-- [INAUDIBLE] feed us, everything.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I used to stay with them.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Nothing to do.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "After all, [? this is not ?] nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "The Germans, they go like this, slowly, slowly, until they liquidated the whole thing.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Liquidation from everywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Then last time, they said, the city got to be a Judenrein.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "No Jews no more.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Then what I to do?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I hiding with my [INAUDIBLE], my brother and [INAUDIBLE] in their basement.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Midnight, used to go around the Jewish [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "They holler.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Every-- every-- go out.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Don't stay there.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "When they find over there, if you're hiding, [INAUDIBLE] nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "The Jews, everybody's going to be Judenrein.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "No more Jews in this city.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And if they see you, they're gonna kill you anyway.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Why you do it?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Get out ?] better.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I said, to my friend, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Going out.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Going out.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] got to transport.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Going ?] [? from ?] transport, going [INAUDIBLE] transport, [NON-ENGLISH]",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In Yiddish, we said [YIDDISH], Polish, [POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Decided, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "What can you do?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My uncle-- my uncle was-- and he worked for them.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "They paid him back.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "They didn't pay him back to take him to gas chamber.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They don't take him to gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Before, I'm going to tell you later about this.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "They took us on a way of there from-- from our city to [?",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Miedzyrzecz ?] was about 25 kilometer.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "How did you get there?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The [?",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Germans. ?] The Germans let us [? go. ?] The Germans watch us.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "The Germans that was going with us, the Gestapo.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We don't go by ourselves.",
      "word_count": 5
    }
