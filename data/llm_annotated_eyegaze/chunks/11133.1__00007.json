{
  "stem": "11133.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So they were able to, through knowing somebody, to get a blue card for me, which was a permit-- a work permit, really, to go out of the ghetto.",
      "word_count": 29
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "For a while there, I worked in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I worked at a paper cooperative.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They only employed children, really-- licking envelopes, making envelopes.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I also worked at a brush co-operative making brushes, sticking, you know, the bristles into a brush and pulling it with a wire.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "But that was not very long that I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My parents were able to get-- to fake my age, make it two years older, to allow me to go out of the ghetto with them.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And got the blue card for me, and then I joined them going to Madritsch out of the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I was-- then started working on a sewing machine.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Sewed uniforms, exactly sewed uniforms.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "You know what piece work is?",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "That's what I did.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "You know, everybody gets either a piece of a sleeve or a piece of a pocket, and-- and you work on it.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Well, let me see.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I must have been nine-- nine or 10, and they made me two years older.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So it would have been, you know, according to the records, 12.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Between nine and 10.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Must have been 1940 or '41, someplace in between there.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Probably right about there, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I'm not exact on the figures, because I don't really remember the exact times that the ghetto got smaller and smaller, except that I think in 1943, it closed completely, and we were transported to-- that was the last selection.",
      "word_count": 40
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We were transported to Plaszow, which became a labor camp.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "At first, it was a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Then it became a concentration camp.",
      "word_count": 6
    }
  ],
