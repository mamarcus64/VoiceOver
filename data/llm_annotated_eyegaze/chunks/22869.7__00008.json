{
  "stem": "22869.7",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Before I got this job, I used to get 15 Swiss francs a month from some organization, Jewish organization.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "This, you know-- we had food.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't have any money.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So here I find this job.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And I'm getting all of a sudden $150 American a month.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "So I'm being envied by all the DP guys who are also in Switzerland.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And that's where we started building a new life.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, since I became sick, of course, I gave up the idea and the thought of going to Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And my sister, my two brothers, Joe and Mayer, they came to America while I was in the sanatorium.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And my sister didn't want to go by herself to Israel, even though there was somebody who wanted to marry her and go to Israel to live there.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "But she refused.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Because she wanted to be with her brothers.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So they all ended up here in Detroit.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "First, in New York, really.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And eventually, my sister saw that here in America-- she was very, very religious.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I mean, to a very, very high extent-- that she saw that, at that time-- life was a little different than today.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "She will never find a partner whom she would marry that would be religious enough for her to make a life here.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So she got in correspondence to some people.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And she met a guy whom she met first in Germany, whom she refused to marry.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And she married him and lives in Tel Aviv now in Bnei Brak.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Let me ask you this.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Wasn't Mayer, your brother-- wasn't he married before the war?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he was married before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "His wife never came back.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And his child never came back.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Of course, she came to Auschwitz with a child.",
      "word_count": 9
    }
  ],
