  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "And I used to go on holidays with my mother, always, till I was about 13 or 14.",
      "word_count": 18
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Then they used to send me with the school.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "And they went on a-- you know, to Czechoslovakia or somewhere like this on holidays.",
      "word_count": 15
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "And then-- then when my father died, I, again, was always with my mother on every holiday.",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "But that's wasn't very long anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "My brother got married in 1934.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "So he left home.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And-- but he lived with his wife in our city.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "And he was very, very fond of me.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "And he used to come-- I remember when there was dance music on the radio, he used to come and to try to dance with me.",
      "word_count": 26
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "I had quite a happy childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "First of all, because I could afford-- my parents could afford medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And then I was given as much attention as possible.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "And, you know, I was only kept very strict.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "And that's why I promised myself that I'd give as much freedom as possible to my children.",
      "word_count": 17
    }
  ],
