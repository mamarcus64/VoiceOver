{
  "stem": "2118.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 50,
      "text": "If a gear was broken-- and he did a lot of that-- a gear was broken in-- in a printing press, and the machinery was from Germany, or from the United States, or from England, and they had to wait maybe two or three weeks until a gear had to be shipped in, he would take that gear home into his shop and add a toot to it, or two or three if necessary.",
      "word_count": 74
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 51,
      "text": "Always he would drill the holes, put in like a bolt, file it nice, then solder it with brass, and make the machine work again, instead of waiting two or three weeks.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 52,
      "text": "It wasn't like here you could go out and get a replacement right away or get it by mail overnight.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 53,
      "text": "It didn't work like that.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 54,
      "text": "Not even the mail worked like that.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 55,
      "text": "There was no mail overnight.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 56,
      "text": "And besides that, there was income from the house.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 57,
      "text": "My oldest brother was a furniture maker.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 58,
      "text": "He was, before the war, oh, maybe-- as long as I can remember, he worked for himself.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I was the baby, and to me, he was already like a grown man.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He was-- how many years older than me?",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Maybe-- we were separated between about a year and a 1/2 each child, or 2 years.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So he had to be at least 10 years or a little more older than me.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My older-- my oldest brother, Leibel.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And he was a furniture maker.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And he had a-- he had his own shop.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He employed about three, maybe four people sometimes, if necessary.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And it was all done by hand.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And it was very expensive furniture.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I'll give an example.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "To make a dining set would take them at least two weeks or more.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "So certain parts he had done by machine.",
      "word_count": 8
    }
  ],
