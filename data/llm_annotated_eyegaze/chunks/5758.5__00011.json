  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "For one hour, we spoke.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And we made a date.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And I said to my friend Leo, Leo, this girl, I'm going to marry her.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "He said, you must be mad.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "You never met her.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Maybe she looks like a dog.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Why-- how can you say that?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "This is the girl for me.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "We met, and we fell in love with each other.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "We met in October, got engaged in November, and got married on the 31st of December, the last day of the year.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Why the last day?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Because the American government gave us-- as if we were married for the whole year-- we got a present of somewhere around $400.",
      "word_count": 23
    }
  ],
