{
  "stem": "3341.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And this fellow who was a captain in the Slovakian Army, he was a very important personality.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And his wife-- he was-- he was a teacher officially, by profession.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "He was a headmaster of a big school, which was two or three streets away from our business.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "We knew him.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "But we didn't know then his wife.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "We found out only before she came.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "We found out that the wife of this headmaster of the high school will be our second trustee.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "This was very important, because we always tried to save ourselves-- not only personally, but the business-- as long as we can.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "And through these connections to the governmental circles, we were able to manipulate this to a certain degree.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "And really, this woman was named as a trustee.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "And our girl, who was put there by us, she didn't want to.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "She was a very religious person.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "Mimi was her name, and she became, later on, my brother's-- my brother's wife.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "So she was my sister-in-law, still alive in Slovakia now.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "My brother died.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "When she found out since that she will have another trustee as a partner in the big business, she was terribly afraid.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "She didn't want to have it.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "She wouldn't have, because she was afraid this woman will keep an eye on her, which really happened.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "So she wasn't very keen, and we had to-- my father and my brother persuaded her.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "Look, you-- you are doing it out of humanitarian feelings, and as a very believing Christian they-- they had such feelings.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "Money was not important.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "With money, she would have never taken that position.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "So my father and my brother persuaded her, yes, just take it, you will see how it will go.",
      "word_count": 19
    }
  ],
