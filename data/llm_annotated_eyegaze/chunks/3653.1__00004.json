{
  "stem": "3653.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And they got a store every farmer used to-- to bring the product there, you know, like, potatoes, feed, this and this.",
      "word_count": 22
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I have-- and later, they came with trucks.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And they took away, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "So I was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "There [INAUDIBLE] sold out.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "There was no more store.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "It was no private there.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Everything went to the government.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Until the war broke out. '41.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "'41 On Sunday-- the first day is Sunday.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "There was [? mobilization ?] in the Russian army.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, they took us-- they took us into the army.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- I never had a rifle in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And they gave me a rifle, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And we were fighting the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a public, in the-- in the-- in the city.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "This you have to go to the police.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They took you away, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "They told me I have to go to register with the army.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "They took me away and put a Russian [INAUDIBLE] with a rifle, with grenades, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they had the Russian uniforms, the blouse, you know, with the boots you know.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We were, but later we disappeared.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Everybody has his own job, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "But I never saw them again, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They took me to the army.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "There was a-- to the army, and then with the army, and then on the front, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It was 50 miles from my town.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "It was right on the border with the Germans, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "They were fighting with the Germans not-- not to long, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I know from my [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "But later we-- and a matter of fact, we [INAUDIBLE] we didn't recognize each other.",
      "word_count": 15
    }
  ],
