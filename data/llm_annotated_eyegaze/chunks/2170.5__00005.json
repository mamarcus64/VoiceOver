{
  "stem": "2170.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And by the way, you don't have no money, you have-- you don't have nowhere to be.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "I-- I give you a [? talone ?], a big paper, that you can come to the Hotel International-- international-- or eat there, or sleep there, or if you want to say with your friends, you can stay with them and take the food home and eat with them.",
      "word_count": 49
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And this is that big-- you rip off a little, they call it [? talone ?], a little-- like a--",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Ticket, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And you'll be in contact with me as soon as you go to the Polish embassy.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And then we will send you to the headquarters of the Russian KGB USSR, and the head of the KGB was Beria.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "You know the name of Beria.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But don't come before-- before you have the Polish passport.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "But you have to go and see, go every day and check if the embassy's open.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And I went to the Polish embassy every day, and I came to the Polish embassy.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I saw many generals, Polish, which were Jewish, but dressed in Russian or Polish uniforms.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "The Polish embassy itself was not open yet, they told me to come back two weeks later.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And this, I came back two weeks later, and there was the embassy was open.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "The head of the Polish embassy was Ambassador Ciechanowski.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "He was Jewish, from Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And assistant ambassador, politically actually, was [?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "Yurena ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Gafon ?], a woman, also Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And the first I came in I have to see Mrs.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Yurena ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Gafon ?] to be interrogated.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Why I want a Polish passport, and why do I want to go to the United States?",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "So I came in the room.",
      "word_count": 6
    }
  ],
