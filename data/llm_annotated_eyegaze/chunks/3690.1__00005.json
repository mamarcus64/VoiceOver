{
  "stem": "3690.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So you don't have to go there.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "They wouldn't let you in.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "So in-- after it got demolished completely almost, they couldn't do any more labor there or work there.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So they set us up in a transport again, and they took us to a place in an island that's called [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It was owned by a Jewish-- a very well-to-do Jewish millionaire.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "It was a steel factory.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And they converted the steel factory into ammunition factory.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "It was taken away from this Jewish man?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was taken away from the Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The man was probably imprisoned or whatever.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We don't even know what happened to him.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "He was a multi multimillionaire, a manufacturer of steel.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And they-- the government confiscated everything, this house, his property, his factory.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And, and they, and they converted the factory, as that steel, they were pouring steel.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So they converted it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And they brought a specialist to make ammunition and all kind of different bombs for the, for the war.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And they took us there, and we were about 500 or 600 Jewish boys and girls.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And we worked there day and night.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And at night, we got a little plate of soup with a slice of bread.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And we slept in barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "We weren't allowed to leave the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "They had in behind the factory huge wooden barracks made out of wooden crates, like crates.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And we had to sleep in those barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And they didn't give us any beds or anything, not even bunkers.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "We had to sleep on the concrete, on the plain floor concrete floors.",
      "word_count": 13
    }
  ],
