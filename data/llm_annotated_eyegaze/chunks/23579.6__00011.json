{
  "stem": "23579.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "In '57.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "July 7, '57.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Here?",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "He bought a gas station.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "He was always in cars.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "He bought a gas station.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And he was very, very, hard-working, and he made a living from the gas station.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "We built trucking.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "We had 10 trucks-- big ones.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And, from the trucking, he built a fleet of taxis.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And I had everything-- the best of everything.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "My parents?",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "They were in Paris.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And they wanted to go to Israel, to see me, so they came to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And the war began there-- yeah?",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "In '48 began the war of independence.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "So my mother couldn't take this, too.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I said, why should you stay here?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Go away to the United States-- you have there a family.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And they had a family.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "They had two sisters and two brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "So she went away here.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Later, I came from Israel here.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And she said, you know, mein kind?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "I was already here enough.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "I want to go to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "So my husband went to Israel and bought them an apartment, in Ramat Gan.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "And he bought them all the things what with the apartment is going-- deluxe things and everything.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "And put them to the apartment, and they lived.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "My mother lived a year longer than my father.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "My daddy was probably 98, and my mother was 99.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "But my father was-- to the last day, he was with his head all right.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "My mother-- two years she didn't know what is with her.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "We kept for her a woman-- two woman.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "But nobody could stay already with her.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "So I was with my father three months, who never told me not to stay.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "I went home with my father was OK.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- no, my father died from a heart attack.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Yeah?",
      "word_count": 1
    }
  ],
