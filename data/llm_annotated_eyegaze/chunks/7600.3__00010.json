{
  "stem": "7600.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And I think that was worse to her than anything else.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "But she had her boyfriend.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "She had a man friend.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "I know she had a-- she used to get dressed and go out.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "And I don't know what she did.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "She never told me, nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "I tried to find out from Kurt.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "I tried to find out from Mitzi.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "Mitzi knew, but Mitzi wouldn't tell me.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "She was very loyal to the family.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "She said, that's not your business.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "This is a private affair, and you are not supposed to know.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "She wouldn't tell me.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "And I never found out.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "And I was dying to know what the hell happened.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "I mean, in those days, people didn't get divorced.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We lived-- from this one, this was a nice apartment, and we went to a cheaper apartment.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We went down, down, down, down.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And school was horrible for me.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't wait to get out.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Except that I didn't have many friends, so I was very lonely.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So I went back to what I knew best.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I read from morning to night.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I read.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I lived in the library, and I just read.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And to me, life was not there.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "It was in the books someplace else.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "There was a swimming pool that you could go to in Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "It's the Amalienbad, I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And they had artificial waves.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Every half hour, they would put artificial waves, and it was very fun.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "What else did I do?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah, I think my cousin gave me his old bicycle, and I rode a little bit of a bicycle.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But that's all I did.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Mainly, I read.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I did nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Did you see a rise of anti-Semitism during this time?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "It didn't have to rise.",
      "word_count": 5
    }
  ],
