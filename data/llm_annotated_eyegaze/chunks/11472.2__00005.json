{
  "stem": "11472.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 43,
      "text": "Every week, they come where they grab for slave labor camp or they come to grab you.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 44,
      "text": "But an aktion-- and then the Germans in our vicinity didn't even bother anymore to take them away, because to Belzec.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 45,
      "text": "I'm sorry, I'll have to tell you-- they took them to Borszczow, all the people from the first aktion.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 46,
      "text": "They took them to Borszczow, and they put them into cattle trains.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 47,
      "text": "And they took them to Belzec.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "No, this was the aktia, that I told you about, the big aktion that they had in our town, where they took my grandparents away.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "But I failed to tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This was the first day of [NON-ENGLISH], 1942.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They took him to Belzec and there they gassed him with Zyclon gas.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Belzec was the first concentration camp that they were experimenting with Zyclon gas.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, the kids-- people started to come back to our town.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Because if you were a young boy or a young girl, your parents are gone.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Or if you're an older person, you have nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And you see the aktions going on.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Maybe a peasant, maybe somebody in the villages, maybe somebody will give you a chance to hide, to give you a piece of bread, to save you.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "All you wanted was to lay someplace quiet and a little barn in a hole.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "You didn't want anything.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "You didn't bother anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "All you wanted to be is left alone and to live.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "You didn't want anything else.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "They started to come back to our town.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "They started to make aktions in our town.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "The Ukrainian police used to go around and look and search.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "One day my grandmother was downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "She didn't have a chance to come up to the bunker.",
      "word_count": 11
    }
  ],
