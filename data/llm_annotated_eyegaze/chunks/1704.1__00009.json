{
  "stem": "1704.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 343.2,
  "sentences_input": [
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 6,
      "text": "And the next morning after, went in the cattle trucks.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Yes, one day, two days, or sometimes a few hours.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "My parents apparently were in there only couple of hours.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "No, I was picked-- picked up from home by the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean?",
      "word_count": 4
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Well, they just came in the house.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "And we just had to go.",
      "word_count": 6
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "I said, yeah, but I'm British.",
      "word_count": 6
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "You know, I don't have to go.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 4,
      "text": "They were Germans.",
      "word_count": 3
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 5,
      "text": "And they said, oh, you know, work that out later.",
      "word_count": 10
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 6,
      "text": "You have to come now.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "So I went to Bergen-Belsen.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "No, first to Westerbork.",
      "word_count": 4
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "But if we can just talk about-- you were taken to the place where everybody was collected together.",
      "word_count": 18
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "No, we were taken to Westerbork straight away.",
      "word_count": 8
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "They were gone already.",
      "word_count": 4
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I was the last one in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "My family was taken.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "My parents were just-- there was a ring at the door.",
      "word_count": 11
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And there were the, the Dutch police picked them up.",
      "word_count": 10
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "They just had to go.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 4,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "And at-- we had very good friends.",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "She was our housemate.",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "And her husband tried everything the next day to try and do something for them.",
      "word_count": 15
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "But it was too late.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "They had gone already.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "And these friends were non-Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "They were non-Jewish, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "What do you-- to whom?",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "But my fiance was picked up, like, a few days before them, before my parents.",
      "word_count": 15
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "And he was taking to Briesen first.",
      "word_count": 7
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 4,
      "text": "And they met up in the camp in Westerbork .",
      "word_count": 10
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 5,
      "text": "And they went in the same train.",
      "word_count": 7
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 6,
      "text": "He traveled with them until a certain town in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 7,
      "text": "And then the elderly had to get out.",
      "word_count": 8
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 8,
      "text": "So my parents went out, and he stayed in.",
      "word_count": 9
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 9,
      "text": "And that was it.",
      "word_count": 4
    }
  ],
