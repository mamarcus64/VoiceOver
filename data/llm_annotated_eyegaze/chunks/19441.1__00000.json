{
  "stem": "19441.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Magda Blau, born Hellinger.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Spell the whole name-- M-A-G-D-A, B-L-A-U, H-E-double L-I-N-G-E-R.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The 19th of August, thousand-nine-hundred-sixteen.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I-- 19th of August, I, I became a 80-year-old woman.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Czechoslovakia in the town of Michalovce, which is spelled M-I-C-H-A-L-O-V-C-E, Michalovce.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Czechoslovakia to spell?",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "C-E-C-H-O-V-A-L-I-A.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Before the war, that means our younger years.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They've been very nice years, because we had a very nice neighborhood.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of Jewish girls and boys lived next to each other so we had a lot of company.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Even so, that we mixed with non-Jewish girls-- so much so that where I live in the fence, the father of the non-Jewish girl who lived next by made a door in the fence saw that his daughter or I could run in and out.",
      "word_count": 45
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "You don't have to cross the street.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And because we been such a bunch of girls, we always had activities.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "On one place, we played theater.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "On one place, we've been singing and dancing.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And on one place, we did different.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We've been always occupied.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And certain days, the boys joined with us, too.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "So that was a, a very full life.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And I had a very special girlfriend whose name was Martha-- in Hebrew, Jaffa, J-A-double F-A.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "We been about the same age.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "She was two months older.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "But she became a orphan because her father fell in the war.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "The mother didn't want to survive without the father, so she died by starvation.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "The same thing, the grandmother couldn't take that-- she died.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And so she became a orphan with the old grandfather.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So our family looked after her.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And so we brought up like two sister, so much so just show you a sample.",
      "word_count": 16
    }
  ],
