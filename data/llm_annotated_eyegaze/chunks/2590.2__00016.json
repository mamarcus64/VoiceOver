{
  "stem": "2590.2",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And from Boston, the same night, 3:00 or 4:00 o'clock in the morning, we came to Manhattan-- to Broadway-- some place-- to a very cool hotel.",
      "word_count": 26
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I remember that my son, he wasn't even 2-years-old, you now?",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "On the boat he lost so much weight.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't eat anything.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And the captain always used to praise me, because everybody was seasick.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "My husband worked in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "He used to bring oranges, but I was too sick to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And on top of me there was another woman, a Polish woman.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Women with children had cabins, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And we had those bunk beds.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "On top there was this Polish woman.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "She constantly regurgitated.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And she also had a little baby.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And she didn't fed the-- she didn't feed the baby.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And I wanted to take her baby too to the dining room.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And that French captain said at the time, the only brave woman that brings the child to the dining room.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "But anyway, he didn't eat anything.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And when we came off the boat, he was a bundle of bones.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And we came to that hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And there was this black woman came.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And she brought us some food.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And my son was very afraid.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And he asked me why she has a rubber face you know?",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "She thought, was she masked?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "Why is she wearing a mask?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And the joint distribution gave us an apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And they would support us until my husband would get a job.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But my husband said he doesn't want any charity.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "They should give him any job-- any job.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "So my husband started.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "He was a bookkeeper in Europe.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "He was a controller.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "He started to peel potatoes in yeshiva, you know, and to clean floors, and wash floors.",
      "word_count": 16
    }
  ],
