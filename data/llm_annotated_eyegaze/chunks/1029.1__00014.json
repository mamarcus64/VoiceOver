  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Well, because, you know, when they press you into this cattle car, all of you, with the sick and with the well, with the healthy, with the old, with the young, with the no place to sit, I mean, you become-- you started becoming animals because you couldn't give your seat to anybody.",
      "word_count": 53
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "There was no seats.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't make anybody comfortable who was uncomfortable beside you.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "People who had to go to the washroom, they just had to go to the washroom.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "They did it in the cattle car.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And naturally, everything started smelling, because they couldn't remove their clothes, so the clothes got stained and the-- and the human excrement.",
      "word_count": 22
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "You know, this-- then, it started, this whole, this horrible, this foreboding, the, the game, the dance, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "The dance started.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "You know, this, the macabre, you know, it just started.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And that's how it was.",
      "word_count": 5
    }
  ],
