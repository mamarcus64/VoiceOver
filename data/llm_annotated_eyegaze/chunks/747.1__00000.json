{
  "stem": "747.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I'm Judith Rubenstein, family name Schwarcz.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I am 24-- I am 74 now.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In 1920, September the 19th.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Hungary.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Called a-- small town called Mezocsat, where my father's family comes from.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My father got a post-- position as a teacher in a bigger city, and we moved when I was six years old.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I lived in that town, called-- named Szerencs.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And we lived there until deportation came.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "His name was Elias Schwarcz.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He was-- when we arrived to Auschwitz, he was 54.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "1944.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "He was a teacher of religion.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And we had no parochial school in our town, so every religion had a right to send their representative into the public schools and high schools, to teach their own children their own faith.",
      "word_count": 34
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So my father represented the Jewish community.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And he was giving two, three times a week-- had a class in various level of the children.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He also was-- and the one who kept the records of the Jewish community-- comings, goings, birth, death.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And he was well-known and well-liked in the community.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We were four children.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He was a very gentle man.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was a great-- had a great mind.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He was a great scholar.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He was-- every minute of what he could spare, he was studying.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And anything we wanted to know, he had an answer.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Was a very gentle man.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "He was-- he was never interested in politic.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "He was-- he was a good man.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "A good, peace-loving person.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he was orthodox, but in a modern way.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My life was not restricted absolutely.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I went to school-- in public school, with my friends.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Most of them were Gentile girls.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And we got along beautifully.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I went to the theaters, and movies, books.",
      "word_count": 8
    }
  ],
