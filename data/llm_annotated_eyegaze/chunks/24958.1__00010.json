  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Just hiding, just being quiet and not be seen too much.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And I had some-- I had-- a little bit of money, of course.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "We had to pay for the-- the farmer for our staying there.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And then somebody, some of the Polacks, they found out that my husband is a violinist and my brother-in-law is an accordionist.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "So they-- they went to some when the-- when there was the-- when they take out the-- I don't know how you call it when-- when you take the fruit from the-- at the end of the season.",
      "word_count": 38
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "There were always games and entertainment.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "So they took my husband and my brother-in-law to play for them.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And they gave them potatoes and flour.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "They gave them something, so somehow we-- somehow we survived.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "When I think back to this over 50 years, I can't believe-- believer-- I don't believe it myself.",
      "word_count": 18
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "We'll stop here and continue on the next tape.",
      "word_count": 9
    }
  ],
