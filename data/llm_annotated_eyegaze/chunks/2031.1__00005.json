{
  "stem": "2031.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And my brother and my sister-in-law says, and we said to each other, give a sip, but remember, if you will give a big sip, we will not be for nine people, we will not have for tomorrow.",
      "word_count": 38
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "So everybody from this cup gave a little sip.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And this was once a day, it was.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "This was our meal.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "We didn't know when is night and when is day, but through the floor.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "It was a wooden floor.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "Through the floor, we saw when this is day, when the sun came in.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "My brother's children heard all the [?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "Cesky ?] children running around.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "They went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The coffee was smelling in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "In the evenings, the suppers were smelling.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My brother's children always says, why?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Why we have to lay?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Why we have to suffer?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Why are we not allowed to be in the free because we're Jews?",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So after everything, my sister-in-law became sick.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So sick that her head was like in a tub of water.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And in a short time, she died.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And this little bunker that we got, we couldn't stretch out the legs.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Everybody was sitting, laying this way.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "In this little bunker, we made a hole, and we buried my sister-in-law.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "After we buried my sister-in-law, my brother's oldest daughter, Miriam, got sick.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And she got sick-- to talk just about bread, coffee, milk, potato, this was-- and she wasn't allowed to talk because we're afraid somebody will hear the voices.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So we tried our best, and she choked, and she died.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "We buried Miriam.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "The latest was Sonia.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "My brother's fourth child, the baby was Sonia.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And Sonia was five years old.",
      "word_count": 6
    }
  ],
