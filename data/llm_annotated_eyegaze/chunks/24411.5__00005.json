{
  "stem": "24411.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And we arrived over here in Ellis Island.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And from there, they took us to the HIAS.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "Who was there at Ellis Island?",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Who brought us to the-- from the organization came-- came-- from the Bund came.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And they took us to the HIAS.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Then we called up my husband's family",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Gold.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And they took us there.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And they came.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And there was three days before Passover.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And they took us to the first seder night.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "And they were afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "You-- if you have family, they have to take you in.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "So they took in their daughter to live with them.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "And we were there the first seder night, and we slept over.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "And then we went back to the HIAS.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "We got right away here.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "My aunt, she has two daughters.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "She brought us a lot of clothes, and she brought, for the baby.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "We bought him shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "He had no-- they-- the-- one German woman give him, made him a pair of socks.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "With this, we came to this country.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Myself?",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I was wear-- I-- I had-- I didn't have-- I didn't have no underwear, no bras-- you know, bras.",
      "word_count": 21
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "But I had a-- a dress and some shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Then my aunt gave me some shoes that was too small.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And I was wearing-- I couldn't wear them.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "Then we find a friend of ours-- he had a jewelry packet in Canal Street through a friend from Europe.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "And he came to HIAS.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "He took out $50.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "He give to my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "He took off his coat.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "He give it to him to wear.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "And since then, you know, everybody start to look for work.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "And I find-- I find an apartment by a woman, a very religious woman.",
      "word_count": 14
    }
  ],
