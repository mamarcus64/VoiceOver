{
  "stem": "1917.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[TEST PATTERN TONE]",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Eva Mozes Kor.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "E-V-A M-O-Z-E-S K-O-R.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Eva Mozes, E-V-A M-O-Z-E-S.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "January 31, 1934.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "According to that, I am 61 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Portz.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It's a village-- P-O-R-T-Z-- in Romania.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My immediate family members-- my father, Alexander Mozes.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother, Jaffa, J-A-F-F-A Mozes.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Her maiden name was Herch, H-E-R-C-H, I think.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And Edit Mozes-- E-D-I-T.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Elis, or Elis in Hungarian-- E-L-I-Z.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And my twin sister Miriam-- M-I-R-I-A-M.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, two grandparents.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And I do not remember their first names, because they used to call them Zidy and Bobby.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "These were my mother's parents, and their name was Hersch.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Edit, Elise, and Miriam were all my sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It is a village.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "It was a very small village-- about a hundred families, one dusty road leading from one end to the other.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And this was basically a farming village-- very, very primitive-- no running water, no electricity, no paved roads.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "These were all farmers.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And my father was a farmer as well, and a landowner.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "We owned quite a lot of land surrounding the village.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And our home was a big farm house with big, white columns with an open corridor.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "It had a lot of other buildings, farm buildings.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "One was for the horses-- a barn for the horses and for the cows and for the hay and for the wheat to be stored, the corn to be stored.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And we had chickens and then geese and ducks and sheep, and a winery.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "It was a very, very big active, and wealthy farm.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Extremely religious-- very observant.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "On Saturday, we could not carry a handkerchief unless we tied it to our hand.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My mother was all wearing some kind of a scarf or turban, or she was wearing a wig.",
      "word_count": 18
    }
  ],
