  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "And as I got to a particular part where a big warehouse was, in front of the warehouse a sort of a Davy Jones or [?",
      "word_count": 26
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "Grace Brothers ?].",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "There was a woman standing with a basket of flowers.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "And she was selling them.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "But she was selling them without a permit.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And that was obvious because she was constantly looking.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Is a policeman coming?",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Is a-- is a Nazi coming, or someone?",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And I noticed that about 15 to 20 meters away there is uniform coming.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "So I quickly went to the women.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I said, disappear because there's somebody in uniform.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Well, then she picked up the basket and shot through.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "But the officer noticed it that I went to her.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And he got me by the arm.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And he said he's going to take me into the police station.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And would you believe that was in winter?",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I had high boots on and some sort of a winter coat.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And I wet myself.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And it was running down my legs into the boot in fright.",
      "word_count": 12
    }
  ],
