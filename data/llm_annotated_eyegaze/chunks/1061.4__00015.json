  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And by then it was summer, summer 1945.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "And subsequently, my two sisters found work in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And I went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "And I was tested and admitted to the second year of high school, and I wasn't even-- before the war I didn't even finish-- I did elementary school.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "But I had all this-- I knew chemistry, and I-- I mean, really.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "And after all the horrible experiences that I was able to even pass a test.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "But we stayed in Lodz.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "And my sister Krys met her present husband, Miles Lerman.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "They got married in December of the same year in Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "And very soon--",
      "word_count": 3
    }
  ],
