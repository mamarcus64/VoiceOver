{
  "stem": "23131.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "They found different things to tell and to go to the Russian-- there was a-- my husband wasn't the commander of the partisans.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "He was a commander of his brigade, but he has the head bosses over him that he had to listen to and obey.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Sent from-- from Russia that they had their main headquarters.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And the planes from Russia used to come there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "That was the Russians.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "The Russian Army.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Platon.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He was the whole boss of ours.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And our Jews weren't lazy to go and complain, and say that he's not a communist, that he's not having the communist party the right way At that time, in order-- you had to be a-- you know, to-- they should like you.",
      "word_count": 43
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "They should-- they should be good friends with you.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And they tried from all sides.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "There were plenty of complaints from the inside people to the main management.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Tuvia stayed.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We-- we went out, 1,250 people.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "He wasn't [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't behave with the family camp without fighters.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "They took-- the Russians tried to, not once, to take away from us, to divide us, to take away some fighters from us.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "But he built it again.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "He did it again.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And nobody was willing-- very little were willing to leave the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "They wanted to stay with him.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "One camp.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And workshops, one camp, a bakery, a salami factory, a soap factory, a-- no.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] They used to-- no, like a bath, but they took--",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "A steam bath.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They used to take turns, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "There was plenty of flies, plenty of in-- of insects.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It's woods.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And each one had his own turn, and when the time came, he had to go and take care in it.",
      "word_count": 21
    }
  ],
