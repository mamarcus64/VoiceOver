{
  "stem": "3361.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So he said, if you want to go-- he knew that I want to learn the business.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And, and this gave me a more chance.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "This was before Passover, Easter.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Were you-- did you observe the Jewish holidays when you were in American?",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Before Passover, and the salesman comes in.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And he wants  an order.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't know what to order.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I said, do you know about?",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You give me 20% more than you send the last year-- the same order, what what you sent last year, if on everything, give me 20% more.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Because I had more business than the boss had by himself, because they-- I was so nice to them.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And the customers, they like me.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They told other people.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And they only came to me to buy of me more stuff.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Listen to this.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "He said, look-- my cousin, to me-- I will give you the money.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Put it in the bank for you-- under your name.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But don't go yet in the business, because you're too young to go in that business.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "You have to learn more.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I said to him, look, if you said you a Carmel and if you said your word that you're going to give me, I'm 100% sure you're going to give me.",
      "word_count": 31
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I don't want the money unless you're going to allow me to look for a business.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Then I take the money.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "But before you not allowing me, I don't want the money.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "You keep the money, I said to him.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "I trust you more than you think.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And he said, he talking like this.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "I will give you the money and look for a business.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "But make sure that you know what to do.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I said, I will know what to do.",
      "word_count": 8
    }
  ],
