{
  "stem": "8725.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "You know, I did not know that I am heroine.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I thought that everybody has the-- I mean, I wanted to help.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I was not worried I'm heroine or no.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They told me here that I am heroine.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "But I don't-- I just wanted to-- I survived.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And it's my responsibility to tell this story.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And I did not know that I can speak like that.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I traveled all around United States, in Canada, Poland, Germany, whoever invites me-- speak to Rotary Clubs, Kiwanis Clubs, churches, temples.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "Now I even-- two months ago, I, I will show you downstairs-- Irene's Museum, my, my-- I get many, many honors from the Jewish community.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Two months ago, I brought that-- the Monsignor from the Catholic Church here into Jewish temple in, in Irvine.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "He brought it a blessing for me from Pope.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I received blessing from Pope because I saved many human lives.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Father Carp here from the John, John Paul II church here.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "The Catholic-- the whole community, not only agree-- the whole community, some of the, the Catholics never been in a temple.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was unbelievable to see that Monsignor in the red outfit kissing the rabbi and the rabbi kissing the Monsignor, and the people, each other, Jews and Christian, hugging and kissing.",
      "word_count": 31
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "It was like one big family.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Rabbi, Rabbi King in Irvine, Temple Shir Ha-Ma'alot-- I cannot pronounce.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My daughter lives in Portland, Oregon.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I-- many times when I speak that direction, you know, I see her.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "She's very proud.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "My two grandsons are so proud of me.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I mean, you know, my daughter has the most wonderful-- now I go for Thanksgiving.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "She sended me tickets to go.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She already made that appointment for me to speak in a church.",
      "word_count": 12
    }
  ],
