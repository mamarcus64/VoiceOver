{
  "stem": "20684.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I poured and I poured and I poured and I poured and poured until the glass got over.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And then I licked all that underneath them and then I-- that's my-- my first full glass of milk I had at the age of 15.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So life's been good ever since.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Well, you have your ups and down, but compared to the past, it's a good country here.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I like it.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I've had a good run here, I can't complain.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I went to Melbourne High, then I went to RMIT in those days, now it's called something else, University of Technology.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Sounds better that way.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Studied engineering, went into business at the age of 20 because I decided to make money and I thought studying wasn't for me.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I didn't want to become an engineer after two years.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I passed, no problem.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "I won the 19-- in 1953, I won the Victorian Junior School Boys-- Victorian Junior Chess Championships.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I was top boy from Melbourne High.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "That was my first trophy.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I formed a club in 1956, a secular chess club, which became one of the leading clubs in Australia for many, many years.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "I was its founder and president at the ripe age of 20.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And from then on, I got married.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "My first marriage didn't work too well.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "We had a son.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I won the custody of my son.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "I decided being a winner is better than being a loser, so I contested the custody and my wife got too smart and lost the custody because she didn't think she could lose.",
      "word_count": 33
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "In those days, mothers were given custody usually, but this time I got lucky.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "[INAUDIBLE] some-- some-- some back some [INAUDIBLE].",
      "word_count": 7
    }
  ],
