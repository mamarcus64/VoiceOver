{
  "stem": "25178.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So they took my mattress away, and he put a piece of wood on the bed-- and that's what they let me sleep on.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I slept on that for almost two years.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I had to do all of the chores in the house.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I had to-- they had two floors-- three, three floors.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And upstairs were all the bedrooms, and they had the, the pots that you urinated in during the night.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I had to empty those every morning, clean them out, bring them back.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I had to make the beds, peel potatoes, chop wood for the stove, polish shoes every Saturday-- 25 pair of shoes.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "If there was any dirt on the shoes, he would grab the shoe and hit me in my face.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 10 SECONDS] And he could be so-- so lovely, sometimes, too, all of a sudden.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "I remember at one time that he would to call me and he said-- because I had a good voice as a child.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I had a soprano voice, and I was part of the chorus to sing in church.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And I was singing soprano.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And he would sit in his chair at home, and he would call me and he said, I want you to sing for me.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "My brother always said, when he heard that story, you know, like King Saul calling for David.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I would sing mostly religious songs.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And at one time, his wife came in, and she was mad.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I don't know what happened, but she grabbed a milk can, and she hit me over the head with it while I was singing, yelling, don't you have anything better to do?",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She didn't know that he was sitting, listening to me there.",
      "word_count": 11
    }
  ],
