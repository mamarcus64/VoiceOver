{
  "stem": "18520.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "And you have four guys already, two with a machine gun, looking, quiet. 10 minutes later, I see a few tanks coming.",
      "word_count": 22
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "Then they're marching the tanks-- and a lot of tanks.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And they stopped.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "The whole convoy, you know, stopped.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "And soldiers coming out and start smoking, talking.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "And we're laying there.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "We're afraid.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "Maybe they're going",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Till he-- he said later on to stand up and with the hand up.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know who was there.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "But when we bend up a little more, you know, he was-- they were shooting in the-- in the air.",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "It scare us.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "So he saw that this is-- this is not Germans with the [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Because he passed already-- they passed already--",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "A guy in the back throw a hat to a few guys, you know, the [INAUDIBLE] who had the hat.",
      "word_count": 20
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "You know, he throw away the hat.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "So they saw that this is not Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Americans, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Gave-- everybody gave somebody-- [? black guys ?] were good chauffeurs.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] they were driving the trucks, blacks.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I had one guy that he was Jewish, one guy--",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "--in the hospital.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "He brought another transportation-- another transport with people.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Later I--",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "We saw already.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "This was Bad Tolz.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Bad Tolz.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if I'm-- I'm doing right with the name of it, but this was Bad Tolz.",
      "word_count": 18
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I think.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] This was Bad Tolz and I knew we were free.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "They said, too.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I-- I think you start living.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "You come back--",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "You-- you were-- you were crazy, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "You-- you-- you didn't think much because nothing was there.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "But your movements and things-- the smile of your face was not a smile but was a cry, but a happy cry.",
      "word_count": 22
    }
  ],
