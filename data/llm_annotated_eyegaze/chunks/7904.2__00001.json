{
  "stem": "7904.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I went there, from one train to a other, one train to another.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I got home.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "That was 7 o'clock in the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I knew my city very well, so I knew already that everybody was wearing a-- a [NON-ENGLISH], from the people what I met in Lemberg.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't have any, any documentation, nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "But I got home.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I opened the door.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They opened the door for me.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was shocked.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I remember, I must be at that time about 16 and 1/2 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I saw the life in Lemberg by the Russian.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "There was already a free-- free-- free for all, a free life.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "You could do anything if we want to.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "We could go in the movies.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "We can-- could go in the-- in the theater.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "We could do black marketing, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Otherwise, we had to do-- we had to make our living.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So I had a very good impression about-- about the Russian.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "So I told my parents, listen, I have an idea.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Let's all go back-- back.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The border was open for two weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "The border was still open.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Let's go back to-- let's go to Lemberg.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "They didn't want to listen to me.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "But the two brothers-- but the two brothers, my older two brothers-- they packed a few things.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And the sister, my sister, [PAUSES FOR 5 SECONDS] went with them to the border, to the Russian-- Russian-- Russian-- German-Polish border.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "She came back.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She came back-- they went.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "They went to Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "She came back but because she had a boyfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] And-- and that's-- she came back.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "My parents said, where are we going to go.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "We have a-- the whole family was there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "We had everything.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "We had everything.",
      "word_count": 3
    }
  ],
