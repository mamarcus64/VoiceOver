{
  "stem": "893.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "The women were left with children, and they were afraid to venture into the streets.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "They were afraid the-- from the-- of, of the German-- of the Russian soldiers.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "And even though it was a Slavic city, they were still afraid.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "[PAUSES FOR 3 SECONDS] But later on, the Czechoslovakian army [PAUSES FOR 3 SECONDS] occupied the barracks.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "And-- but still, the Russians-- if a Russian soldier saw a civilian, they tried to stop them, rob them of their watches or whatever they-- valuables they had.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "First, we went to our apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "We found that the door was broken in.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "The furniture was there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "The walls were bare.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 40,
      "text": "We had a lot of expensive paintings.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 41,
      "text": "One of the paintings still-- we still recovered.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 42,
      "text": "And my-- the twin paint was-- my brother has, and I have the other twin paint.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 43,
      "text": "It was painted by a valuable-- supposedly a valuable painting.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 44,
      "text": "After we saw our apartment, it was bare.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 45,
      "text": "We didn't find any clothing, and linen was all taken away.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 46,
      "text": "We went downstairs.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 47,
      "text": "We happened to find a fellow who was wearing my brother's good winter coat.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 48,
      "text": "We tried to ask [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 49,
      "text": "He denied.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 50,
      "text": "He said that's his own.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 51,
      "text": "And we were told to-- then we proceeded to the apartment of our-- of the nanny that brought us up, who was at that time married.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 52,
      "text": "We knocked on her door.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 53,
      "text": "She-- she was overjoyed to see us back.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 54,
      "text": "She didn't have-- she never had any children.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 55,
      "text": "She raised us.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 56,
      "text": "And she let us use-- we took a bath there.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 57,
      "text": "She washed our clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 58,
      "text": "She put us up.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 59,
      "text": "She fed us.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 60,
      "text": "After-- after that, we stayed couple of days in her house.",
      "word_count": 11
    }
  ],
