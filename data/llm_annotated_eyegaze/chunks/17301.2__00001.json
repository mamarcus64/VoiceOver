{
  "stem": "17301.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 578.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "They took us into another lager.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "It was A lager.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "When we walked into this place, it was already full.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "There was three layers of bunk beds in this place.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And there was only one small place available, which was on a very bottom.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "And there was no flooring.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "It was just the earth.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And they says, this is where you're going to be sitting, and this is where you're going to be living.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "This is where you're going to be sleeping and living.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "So that was our first day in Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "Later on that day, they didn't pay any attention to us.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "We were just sitting.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "We weren't talking.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "We were afraid to say anything at all.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Because we didn't know what to expect.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "There was one woman that's called a kapo, who is in charge of the-- that camp that building.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I happened to talk to her.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I said to her, gee, I says, you know when we came through, I saw some buildings that had large smokestacks.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I said, is this a factory?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Are we going to be working in a factory, or is this maybe a bakery or something?",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "She says, yes, it is a bakery.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And I want to tell you what kind.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I said, oh really?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And I was very naive.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I said, what kind of bakery is it?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "She says, who did you come with here?",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I says, I came with my father and my aunt and my grandmother.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And she says, well, how old was your father?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And I told her how old.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "He was about 50.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "She says, and how about your grandmother?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "I said my grandmother was 83.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "She says, well, do you see that big smokestack?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "She says, that's where they are going out from.",
      "word_count": 9
    }
  ],
