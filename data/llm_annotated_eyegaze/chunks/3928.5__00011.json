{
  "stem": "3928.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "That's my children.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And they're all doing pretty good, you know, really.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "My oldest son is an attorney.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And he's a judge in a Juvenile Court of Pittsburgh.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He's a kind of an appointed judge, you know, as juvenile courts are.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "My oldest son has a motion picture lab and a camera store.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "My daughter is a violinist.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "He was with-- a violinist with the Delaware Symphony.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "She was a concert [INAUDIBLE] of a symphony.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Now she's with the Pennsylvania Ballet, and she works on a Broadway shows, with-- in the orchestra, with the Broadway shows.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "That's why I got my free tickets.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] Then my other son, Edward David, he is a director of out-patient services of a rehab hospital.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And my youngest daughter is in Daytona Beach College.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "She is a counselor in a Daytona Beach College.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "So they're all doing better than the father.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I have two-- four-- now, wait a minute.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "One, two, three, four.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "It's correct now.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Let me correct it.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I got two grandchildren-- I mean, two boys, I beg your pardon-- two boys, Ian Leslie McClelland and Charles Edward McClelland.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I had two little girls.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "One is Kira Elizabeth Banos.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "That's from my oldest son-- no, from my second son.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And I have Laura Banos from my oldest son.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I have four grandchildren.",
      "word_count": 4
    }
  ],
