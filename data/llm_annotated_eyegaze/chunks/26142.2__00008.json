  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "When I was about 16, I wanted to-- to go to the-- there was a-- a Hashara.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "You know what a Hashara means?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Preparation places, where they-- they would teach people traits.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "The-- the revisionist organization to which I belonged had organized a marine school, to teach Jewish people how to work on-- on ships.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- I was 16-years-old at that time, and I wanted to leave.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "But I was the baby of the family.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "My older two brothers were married, and they had their own children.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "They lived out-- out-- out in their own houses.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And my parents just wouldn't-- wouldn't let me go.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And this was one of my disappointments.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And throughout the war-- throughout the war time, my-- and my older brother, also that wasn't married at that time yet, Tsvi, he also wanted to go.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And-- and-- and again, my parents were very much against it.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And during the war time, and I-- all those bitter and terrible nights and days that I had to endure, I-- I always accused myself.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "I was mad at myself.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "This-- all this here is-- I deserve it because I shouldn't-- I shouldn't have listened.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "I should have left.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
