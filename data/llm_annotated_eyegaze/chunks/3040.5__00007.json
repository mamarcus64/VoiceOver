{
  "stem": "3040.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "First of all, I didn't make enough money to pay the rent and to sustain us.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So I got another job.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And in 1960-- and I worked in the shop for 10 years.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I made a decent living.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "In 1960, we decided to go into business, and I bought, with the help of some loans from relatives, I bought a dry-cleaning store.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I was in this business until 1980, when I retired.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Presently, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I have two grandchildren.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It's Mary Ruth and Jonathan Evan.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Is Stewart.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "That was 1984.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I remarried, yeah, 1985.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Is Helena.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It's pronounced-- I pronounce it Helena, the way they call her.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Because here, you would say Helene.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name is [?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Roitman. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "She was in-- in Russia during the war.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She also-- you would say she was a survivor because she ran away from the Germans, and she spent three years in-- under very hard conditions in Russia.",
      "word_count": 28
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes, not only presently, since 1965.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "People who come-- originate from Krakow have created a society.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It's called the New Cracow Friendship Society.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I became active in this society.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Momentarily, I was elected to the board of directors.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And then I served as president of the society for six years, from 1983 to 1989.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "But all through that time, since almost 1967, two years after the establishment of the organization, I became the editor of the-- of our newsletter that we publish.",
      "word_count": 28
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "At the beginning, it was a monthly.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Now it's every two months.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I have here a copy of this.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The organization, well, as the name would imply, it was created for a purpose that we should get together in-- as a substitute for families that we have lost.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Be together in friendship, organize functions that suit our purpose.",
      "word_count": 10
    }
  ],
