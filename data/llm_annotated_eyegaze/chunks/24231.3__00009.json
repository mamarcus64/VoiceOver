{
  "stem": "24231.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And this fellow I mentioned before, who was the guy who chased us from the-- from the street, somehow found-- word got to him, and he hung himself in the house.",
      "word_count": 31
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And and the-- then the widow two days later came to my father and asked him if he would be so kind and forgave him and take him to the cemetery.",
      "word_count": 31
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "So my father, you know, acquiesced to it and-- and took his body to cemetery.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "There was nobody in our home.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] So we were able to just-- first, we had a little-- little-- a little room.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Apparently, some Germans must have been living there.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And they also cleared out.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And there was nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "There was nothing in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "It was just the empty house.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "All the furniture was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So what happened is we slowly-- my father slowly started to get things together.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And finally we-- and we found out that my uncle who had his business, about a mile-- several miles away from us didn't return.",
      "word_count": 24
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Nobody from his brothers and sisters came back.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was dead.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So we moved later on into my uncle's house, because it was a larger, larger home.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "The one of my uncle who was in charge of the agriculture, he returned also home.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But he didn't live in Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He lived in Turnov, which is on the northern side of Bohemia.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And how long did you remain in Prague?",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And when did you determine to leave Prague?",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "When I came-- when I came to Prague, this was in May.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And since I was able to go to school and-- and, you know, attend some classes in in the ghetto, I was taught by people, I-- I went back to my gymnasium.",
      "word_count": 32
    }
  ],
