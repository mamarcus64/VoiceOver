{
  "stem": "17135.6",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And that Chair is a-- a professor, a world-renowned scholar, Saul Friedlander.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "And they are always oversubscribed.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "I think the Chair exists only for 12 or 13 years.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "They had an average of 250 to 300 students enrolled in those courses.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "You know, there is a chance that some of those students will be the future leadership of the United States in the 21st century.",
      "word_count": 24
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "It's very important that people know about the Holocaust.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "Most people that take that course are somewhat stimulated to read more.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "And we already have sent-- we have a-- a program where we give a-- a stipend.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "Holocaust-- not to [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "It's not a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "We give $10,000 to a person that is willing to go for a PhD.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "We already have created six PhD in Holocaust studies over the years.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "And some of them are in-- in-- in Jerusalem.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Some of them are in small colleges.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And they teach teachers now, or students, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Which is important.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "You know, it's like almost the-- exponential.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "It multiplies.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "We'll go on on the next tape.",
      "word_count": 7
    }
  ],
