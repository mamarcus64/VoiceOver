  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "And-- but I hope you get them by Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "But I have to run now.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "It's almost noon.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "So I'll see you next time.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So we knew 12 o'clock Saturday.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And we knew where.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We were told before where, to pick them up at the railroad station or at the street corner, whatever.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And then we took them over.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And the same way our group notified the next guy that two package [LAUGHS] are on the way, or whatever-- no high secret writing or nothing like that.",
      "word_count": 28
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "It was rather primitive, honestly.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "But it worked, most of the time.",
      "word_count": 7
    }
  ],
