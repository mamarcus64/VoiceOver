{
  "stem": "11472.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So the grown-ups started to buy papers to go to Germany.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I think my uncle went to, to, to Cracow.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they said they were going to buy from the Red Cross.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They bought some papers.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We got on the train.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] In Bytom, we got on the train, and we're going, a big group of people.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "My aunts and uncles left, like, a week before us.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And they, they, they-- and my Uncle Schloime returned already to tell us that he went to save the borders.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And he came to get us.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And we're, we're, we're on a train.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And nobody's bothering us, and we feel that the papers must be good because nobody is bothering us.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We come to Czechoslovakia, to Moravska Ostrava.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "They stop us, and they tell us the papers are no good.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We should go back.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] It was a big group of people.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "We're not the only ones.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "My Uncle [NON-ENGLISH] came back already from the Siberia with my Aunt Chana.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "They're on the transport with us together.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "He pulls a string.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "He stops the train.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "We get out of the train.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "And we tell the Czechoslovakian police, you can kill us right here.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "We're not moving.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "We're not going back to the Polish border, across the Polish border, because the [NON-ENGLISH] are waiting there.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And they used to rob the Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Because when the Czechs used to push them back, they used to rob them.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And they're going to kill us because they were killing people, too.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "Anyway, the Red Cross intervenes.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "They took us into a very big place.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "Again, we're surrounded, but this time by Czech police.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "Again, we're, like, in a ghetto, but we're in a house.",
      "word_count": 11
    }
  ],
