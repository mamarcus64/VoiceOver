  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And [PAUSES FOR 3 SECONDS] so I, I, I-- just traveling on-- just sitting in a train, I enjoyed it.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Probably being by myself or not too many people around me and then seeing the scenery which changes, watching the people and the scenery and thinking on who these people could be and what are they doing.",
      "word_count": 37
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And it was very entertaining for me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And then-- so-- Then sometimes we would go to Czechoslovakia, which is also surrounding country of Hungary, and see things and experience things.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "To see things.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "To see things.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We had a very close family in a sense.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "My grandfather had a huge, enormous huge home in [INAUDIBLE] in Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And then every weekend the whole family would meet there, once a week almost.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And he had enormous, big balcony he had.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And then the whole family would sit there, and we would have breakfast there, and we would talk with each other.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And it was really beautiful, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "That-- it was peaceful and beautiful.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In Hungary, I went to an elementary school.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "It's a different system like, like in America.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "In Hungary, you go four years to an elementary school.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And after, you switch to a school what here you would call maybe a high school kind of thing.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But it's different because over there, eight years-- now, after the four years you are finished, you go eight years into the same school.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And then you graduate there, and then you go to college if you want to and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "So I went to the [INAUDIBLE] Jewish School in Hungary.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Did I have friends in school?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I had some friends, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And some of them died.",
      "word_count": 9
    }
  ],
