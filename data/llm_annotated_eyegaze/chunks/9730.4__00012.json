  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Because the whole idea was for me to find a place to live, find a job, and establish something that would allow us to get married.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "So I did find a job.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I was actually separated from the service in December, because between the time I arrived in-- in October, I went to Fort Dix, which was a separation center.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But I-- I had to stay there for a number of weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And by the time I was, in fact, discharged, it was December.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I-- I was a second lieutenant at that time.",
      "word_count": 9
    }
  ],
