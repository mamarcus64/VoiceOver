  "sentences_input": [
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Then she say, he want the baby.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "They want the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "Then she changed her mind and we have the baby.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "Thanks God that.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "He's a very good, nice man, Mike.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "Anything, anything is right away with me.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "Anything-- anything right away.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "One is Eileen.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "She's in-- she's in Brooklyn, lives there.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "Very nice girl.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And I got the elder son, Asar.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "He's in-- he's in temple, makes a living.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "And I got Mike.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "He went for a lawyer, chief lawyer.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "Now he's going for a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "You can't tell him what to do.",
      "word_count": 7
    }
  ],
