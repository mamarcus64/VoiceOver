{
  "stem": "21013.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And the way I met him was the man I worked for-- of course, I asked him, would you give me affidavits for my parents?",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "That was my constant question.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I asked everybody I met.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "He says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "He says, I'm dead broke.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I can hardly pay my bills.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "He says, but I know a bachelor who is a very nice person, and maybe he'll do it for you.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "So he set up a lunch date for me with Charlie.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And he was 34 years old at the time and I was 18.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And we had lunch and I told him my problem, that I needed someone to guarantee for my parents.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And he said he'll be glad to do it, so we went to the HIAS, and-- the Hebrew aid society, to make out the papers for my parents.",
      "word_count": 28
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, they found out that he didn't make enough money and didn't have enough money, because all he owned was $800 and a car that he was making payments on.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So they said, you can't guarantee for two people, except if you were married.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So I said to him, would you marry me?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He said, I won't hold you to it, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We'll just get married and I'll pay for that and then when my parents come over, we get divorced.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So-- this was the first day I met him.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I said, you know, it'll only be pro forma.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "It's just a legal thing.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And there was a movie after that, long time afterwards, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "That's really my story.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And he said, all my life I've been wanting to marry a girl like you.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He said, of course we'll do it.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So-- and subsequently we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very good marriage.",
      "word_count": 7
    }
  ],
