{
  "stem": "22582.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "And I-- I remember my mother's father.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "He was alive.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "And he was married second time.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "And he had-- he lived in different town.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "And he was married to another-- to-- to-- his wife was also a widow.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "And she had children from the first husband.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "But we didn't see each other that often.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "Because at that time, even that she-- he was living about, I would say, 80 kilometer, which would be 50 miles.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "But that was a big distance in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "You had to take a train and ride quite a-- a few hours.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "But once I spent a holidays-- during the summer, I went for-- for to visit him.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 25,
      "text": "And that was about two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 26,
      "text": "And then my first-- the grandmother, my mother's mother, the-- the first wife of my grandfather, was dead when I was born.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "My father was born in Tarnow.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother was born in Jaslo which was a town I don't know exactly how far.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I would say about 40 kilometers or something from Tarnow.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But also-- but she, then her father moved to Nowy Sacz That's what she lived.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "She was born in Jaslo.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "But she actually lived in Nowy Sacz I understand, which was about 80 kilometer from Tarnow.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
