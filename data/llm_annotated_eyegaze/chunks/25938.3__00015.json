  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "When did you get word about your family members, about your mother and what happened to her?",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- when I-- when I came to Birkenau, the same day when I came, the same-- the same moment when I-- when I reached out to place the platform, I knew.",
      "word_count": 32
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother said to me-- to me, [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And she went.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "And my sister went.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "And I knew they-- they went to the crematories.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "Same-- the same night.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "But-- and then I heard that-- that someone told me that even your Bashe that is in the camp, I saw her.",
      "word_count": 22
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "One-- one-- a person whom I knew.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 8,
      "text": "And I was happy and-- and then-- to hear that.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 9,
      "text": "But later, my brother came, says to me, no.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 10,
      "text": "She's not anymore.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "His-- his wife was working in a-- was in-- was-- knew her.",
      "word_count": 12
    }
  ],
