{
  "stem": "9558.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Tonia.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Tonia Schon.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Schon.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And her parents, Mr. and Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Schon.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Her parents, Abraham and Malka Schon.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We were in hiding in the middle of nowhere.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And one evening, that guy-- my sister's neighbor-- he said I can't bring you any more bread, because there is talk in the village that he is bringing food, and-- and Jews are hiding someplace.",
      "word_count": 35
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And they're going to go to the police and to the Germans and tell them about it.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So he said you have to leave here, because they're going to come after you.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And I am sorry, he said.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I can't bring you any more food.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So I ask him a favor, if he could do me a favor and go to the Bochnia ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I told him where my brother's working.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "If you could get in touch with him.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I said, if you can get in touch with him, could you please go to any Jew, and bring me a letter written in Yiddish.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "That-- what we should do, if we could come to the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know what went on, if people are in the ghetto, or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "So the next evening, he came and he says, this is the last time I could bring you bread.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And he brought me a letter from a Jew from Bochnia ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And he said that everything is almost normal.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "That we come-- that we should come to the ghetto if we have no other choice, that we should come to the ghetto.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "So that the evening, we walked.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "It was I think 15 or 16 kilometers.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "But that time, my mother wasn't a young woman.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "But somehow we managed.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "How long did it take you?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "A whole night.",
      "word_count": 3
    }
  ],
