  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And I was very surprised to see Treblinka in the forest where very few-- they tell me that very few Germans knew where Treblinka was, because whoever went there could never come back from there.",
      "word_count": 35
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And the only-- the only thing, there are stones from all the Jewish communities from the world for the Jews that perished there.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "It was quite a trip for me.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And these young Jewish people-- they were so caring and loving that I can't [? calm ?] [? down. ?] [CRYING]",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Well I share all my experiences.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- I think something came out of my-- my soul.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I hope that history doesn't repeat itself.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And always to be strong.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And nowadays, you know, there is the state of Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We'll be able-- you know, any Jew that wants to go and be there, to be safe and sound.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, I-- I think we covered, pretty good, you know, the story.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I'm happy to tell.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
