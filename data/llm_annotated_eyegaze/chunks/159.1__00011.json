{
  "stem": "159.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "So my friend said, you're crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "You have no-- you don't have anybody.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Where are you going?",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And I said, we'll manage.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "So we started two cars in the morning, and it took us five and a half days to come to Los Angeles.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "And my friend got lost on the road because his motor burned down.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "So we waited for him a whole day.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "We didn't see him, so we decided to continue on our own.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "And we came here, and we looked up his friend.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "And we told him what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "We rented a furnished room on Pico.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Near Sears, it used to be.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And we lived there for quite a while because we wanted to rent a place.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And wherever we went, they saw a little boy, they closed the door in front of us.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "So they didn't want to rent that time with children.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So finally, we found a place after that.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And then my friend came, and it was very bad.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "My husband was going every morning, got up early to look for work.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't work that time because he was a little boy.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "He was three years old when we came here from Detroit.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And he was knocking door to door until he found a job.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And then you-- what happened?",
      "word_count": 5
    }
  ],
