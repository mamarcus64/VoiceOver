{
  "stem": "5516.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They want to release her since she's got two of them, but she have to leave the kid.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Somebody told me who survived in Israel, she was with my sister.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "So my sister said, you killed already two kids of mine.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I don't want the third one.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So they took her, and I think they transport her.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know this till four or five weeks ago.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "They brought her to Auschwitz, and they gassed her.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Because I got the information from the Red Cross Geneva.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "They find out they did it.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In the barracks?",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Not too long.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Maybe two, three months.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Close to a year, no more.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Michla",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In the barracks, I was maybe-- [PAUSES FOR 4 SECONDS] maybe 3/4 year, no more.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "This was maybe in summertime.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I think in [PAUSES FOR 3 SECONDS] in '44, I think.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "First they brought us in the ghetto Shavl, and we were staying there for, I think, a day.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And after the day, they took us from the ghetto to trains.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And we was going, I don't know, for a long time.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We was in Konigsberg, a German city, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We was going by train.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Was, I don't know, 40 people in a train.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "The train was not for people, you know, the train for-- for cattle, maybe.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Some of them didn't survive even in train.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And they brought us to Stutthof.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No, my brother was-- when the-- in Shavl, on the airport.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "After this, they made him, Panevezys, a place like this.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They took from this camp, I don't know a couple hundred people or a hundred people.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "My brother was with them.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He was there, and we were separated.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, they took him, too, see?",
      "word_count": 6
    }
  ],
