{
  "stem": "25651.15",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She didn't recognize me.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So I said, I'm Misa Honigwachs, Leo's brother.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And she's a Christian woman.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "She says, Jesus Maria, [PAUSES FOR 3 SECONDS] and she says, where is Leo?",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "So I said to her, I was going to ask you whether Leo is in Prague?",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Because Leo would have been in touch with her because they were good friends.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So she says, I got to get you cleaned up.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "She started shutting up shop.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She took me, and she explained, I'm taking you to my husband's apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I've left my husband.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And now I've got a boyfriend who is a pilot in the Royal Air Force, and he's stationed here in Prague.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But I'm not living with my husband, but the only place that I know where you can get a bath and where you can stay the night is my flat where I lived with my husband.",
      "word_count": 36
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And these were really lovely people-- not only she, but these two forgot their marital problem and for him, there was no question, you know?",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He started running the hot water.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And that-- and so that's how you got to England?",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well then, we started-- I had a bath and supper.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And over supper in the kitchen-- I didn't tell them this whole story because it's takes, takes ten reels or whatever.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I said, I've got to get to England.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I don't know where my father is, but once I get to England, I'll find him.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I only have this Swiss address.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So the husband says to his wife, what about your boyfriend, the pilot?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Why doesn't he take him on his flight, you know, just take him without papers to England?",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So she said, I don't think he'll do it.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But she said she'd talk to him.",
      "word_count": 7
    }
  ],
