{
  "stem": "5188.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Well, my father got a job right away.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It was the depression.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was 1938.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "We got here February '38.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "He got a job as a dishwasher down near the fish market in some restaurant.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And he worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And I still don't know how we made ends meet, but I guess Aunt Erna's contribution made it, because we paid $42 a month in rent.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And my father earned $12 a week.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "So you figure that one out.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "My mother did home work.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "She started doing home work.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And that was making little bows for the Greek Orthodox Church.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "People used to pin those little pink or blue bows on, with little medallions-- little religious medallions and crosses-- at christenings and wedding.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "They used to put them on their lapel.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And we made those bows.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And both my sister and I helped my mother after school.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "So, that way, I suppose we made ends meet-- between the home work and the boarder that we had in the house, my aunt.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "But let me get back to going to school.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "The first day in school, my aunt-- was Aunt Rose, my mother's aunt.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "There was Aunt Rose and Uncle Ike and my aunt Erna, which was my mother's sister.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "But Aunt Erna worked all day.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "She had this job as a housekeeper, as a maid.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, we went to school.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Aunt Erna made sure that she rented this apartment in the same block as the elementary school, PS 5 in Astoria.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "That's where I went to school.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they put me in a classroom.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know what people were saying because I couldn't understand a word of English.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And I sat in that classroom.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And I sat and I sat.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they were talking and they were doing work.",
      "word_count": 9
    }
  ],
