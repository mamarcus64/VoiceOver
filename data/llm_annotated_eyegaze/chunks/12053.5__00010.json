{
  "stem": "12053.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "You see, I haven't got a PR.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "What you call in England, I haven't got anybody who gives me the publicity to go out and talk.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "Lots of us go out and talk.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "Lots of us.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "In Sheffield, in Scotland, I've got, though, it seems she leads a wonderful group of Kinder and other survivors.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "She has mixed hers.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And a lot of us go out and speak to schools, but it's mostly Jewish schools.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "But in Germany, I speak to the German schools.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "I do groups there-- Christian churches, Jewish groups, mixed-- there are a lot of Counsel of Christian Jews there.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "I find their interest more than the Jewish interest, and that really amazes me.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I would very much like to get an invitation from, say, [INAUDIBLE] College.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I've never had one.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Emmanuel College-- never had one.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I had to ask the JFS if I can give a talk there.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I had to ask the-- what is the-- the orthodox grammar school?",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Hasmonean?",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Hasmonean.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I asked them, yes, and I gave a talk there.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But the feedback is not as great as I get.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I suppose Germany's got more interest.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It's-- they've got more reason to want to know.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And we're sheltering our children also.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "They-- you know how Jewish people like to shelter their children.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "But in America, I mean, there's a big network of speakers.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "But I've never been asked, officially, here in England, from any education department.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Which is a pity in a way because now-- and with the pictures I've got.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I take my picture along with me, and they're huge.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "They are by a meter by a meter.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "The archive-- if you wanted to photograph one or two, they are terrific.",
      "word_count": 13
    }
  ],
