{
  "stem": "26359.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "As a matter of fact, she took even a small cabinet in grandma's, like a china cabinet.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I was happy for her to take it because if she wouldn't take it, somebody else will come and take it.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And we went to the village back.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I was in her house quite a few weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "Then when she said to me, Dona-- not Maria.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "She called me Dona at that time, Dina.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "She called me Dina.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "The next Sunday we'll take you to church in Horitz.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "It's a village.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I spoke already with the priest there and will arrange a baptism for you.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I asked her, what would you think if my parents would be alive?",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "What would they say?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "She said, the only thing what your mother would like for you is she would like you to live, to survive, whatever you are.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And that's what [INAUDIBLE] say on a Sunday morning.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I heard the--the church bells ringing as they took me in a horse and wagon and we went the whole ways to the church.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I came, we came, I came to the church.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And it was a lot of people were very, very crowded there.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And it's like a-- they prepared already.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They had prepared already a big dish, a barrel, like a barrel full of water.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So they asked me just to take off, I mean, I should keep my underwear just to take off the coat and things like that.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I was standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they-- they did a baptism, cut four pieces of my hair in four pieces, gave me something to eat, and said prayers, and things like that.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they pronounced me my new name, Maria Filiniuk.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Now, where did the Filiniuk come from?",
      "word_count": 7
    }
  ],
