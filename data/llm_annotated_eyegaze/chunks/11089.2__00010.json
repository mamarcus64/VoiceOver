{
  "stem": "11089.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We were looking one of another.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Nobody should see us, that we are Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "We arrived to Chust.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They went to their homes.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I went to my house.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I came to-- to my house.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "It's Friday night.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "It's quiet.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "It's late at night.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I knocked at the door.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "My mother was up.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Naturally, the first thing I say, [NON-ENGLISH], where is my father?",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She says, [YIDDISH].",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He's sleeping.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Don't wake him up.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It's not nice.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I said, no, I want to give him a kiss.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] I didn't see him a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "No, don't bother.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Tomorrow morning, you will go to shul.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He will wake you up.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "But I said, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "I want to give a kiss.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I went to kiss my brothers and sisters, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And then she broke out with tears.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "[SPEAKING YIDDISH].",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "Your father is not here.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "I said, what do you mean?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "She says, he's arrested in the village.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "In Sojmy he went for business.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "Sunday morning, they will take him to Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "So the bus will arrive 9:00 to Chust.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "And from Chust, 5:00 the afternoon, he will have a train to go to Budapest, a whole night train to go to the most secure prison in Hungary, in Budapest.",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "This was called [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Those who are from Hungary will know what I mean.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "My wife, Hungarian, she knows what it is.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, 9:00, we waited for my father.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "The little kids didn't go.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My mother came with me to the train.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "My father came, tied down to a tall, tall Hungarian officer-- police.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And the police told my father, Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "Eisner, I can let you go.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "But if you listen to me, you'd better go to the jail.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "It's much more secure.",
      "word_count": 4
    }
  ],
