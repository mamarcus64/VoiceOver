{
  "stem": "4967.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "We used to pinch.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Or we used to get from the Italian to trade in this or make another swap.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Then we used to get Russian tobacco, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What can you do with tobacco if they haven't got a pipe and they haven't got paper?",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "What can you do with this?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You can't even plant it.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It doesn't grow.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I find a plan.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I used to pinch from the office, typing paper.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Not the thick ones, the copy ones.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "The thin ones.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And I used to sell it for food in the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "A guy used to give away his last piece of bread to-- to-- to make a-- to make a-- a cigarette.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And although it was hard for me, and every day, the-- the Allied planes used to fly over-- there used to be alarms, sirens, [NON-ENGLISH].",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "But they bombed us once, on the factory, on top.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Some bombs exploded.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Some bombs just slide down.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "When the bombs fall down, and it doesn't-- you know, the center pin of the bomb doesn't explode.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "It just slided down.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And when the planes went away, used to come the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "They used to dismantle the detonator.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "They used to take out whatever it is.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And they used to send it to the-- to the German airfields to bomb the-- the other side.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "The last day was very sad.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We were supposed to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We come back from work, and they said it's quarantined.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "No work anymore.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] What happened?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] quarantine.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "The next day, we are assembled on the big platz.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And they didn't count us.",
      "word_count": 9
    }
  ],
