  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And these funds will avert a takeover by the radical right and the radical left.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "That was her prediction.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I often think of this.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "You know, when we give foreign aid now, I always think, you know, what a good investment it really is.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And if Germany could have been saved from Hitler, if they had gotten some more loan money.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Because the economy was on the rocks.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And during the-- there were two elections in 1932 prior to Hitler's being appointed chancellor.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And I think you could hear many versions of this.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But that is the way I remember it.",
      "word_count": 8
    }
  ],
