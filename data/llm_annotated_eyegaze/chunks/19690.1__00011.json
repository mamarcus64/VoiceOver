  "elapsed_s": 151.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And in the meanwhile, also, my father had a sister and a brother at that time already in Israel-- Palestine.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And the possibility of going there was also being explored.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "But my parents wanted the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "They did not-- my father didn't think he would tolerate the climate in Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And we followed this through.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And finally, my uncle and aunt found a distant, distant third cousin in Kentucky who was willing to give papers.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And she started the ball rolling on getting us papers.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And in 1938-- no, 1938, they-- the papers came, late in the year.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
