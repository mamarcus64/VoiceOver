  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "Four and a half months later, we've been in America.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "What's your son's name?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "That's Mosche.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "That's all I have.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And I have a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "That's all I have.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Three and a half years later already, in America, my daughter was born.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "So we had two beautiful children, and my husband had a good job because he had an uncle.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "It was so amazing how people could help themselves.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "My husband said that once he met with a cousin, a first cousin, and he was jumping on the train to go somewhere.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "He said to this cousin, give me the address of my uncle in America.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "My husband's mother had the oldest brother in America.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And he gave my husband the address verbally and when we came to Bamberg, my husband wrote a letter to uncle.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "It was the correct address.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "We got right away letters from Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "And communication wasn't good yet.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And the uncle said, I want to come to see you.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "So he said, Uncle, don't come.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "You come when we will settle.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "In Germany, in Bamberg, every Shabbos, every Friday night, we went American chaplains.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "They took the movie house, and we had services.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "As we've been there, every Jew, every day, every soldier adopted some Jewish family.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "Said, give me the address, give me the name, I'll write home.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "They got to send parcels.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So I was-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know ?] I was lucky with my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We adopt, I have the pictures, you'll see it.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We adopted, no, as we've been in shul, he said that he couldn't speak German really.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "You know Fisher toys?",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Willie ?] Fisher.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Willie ?] said to-- to me, give me-- I want to come-- are you married?",
      "word_count": 15
    }
