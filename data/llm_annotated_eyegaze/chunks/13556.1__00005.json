  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "A garden, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Big garden.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we used to have cucumber, tomatoes, and different kind of salad.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And the most we have trees-- apple, pears.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And we used to make our own wine, for Pesach.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "From the apple, plums, we used to make our own wine.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I was in the organization, Betar.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Mhm, Betar.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Since I was young.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "This is Jabotinsky.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "This is extreme to the right.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we have a-- a club, [? our own. ?] And a ping-pong table.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And we have meetings.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Once in a while, we used to go out in a [NON-ENGLISH]-- no, like [NON-ENGLISH] you call this-- like [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "We used to go out in forest.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And we used to have meetings.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And the whole meeting was based in patriotism and to stretch the hand to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I-- I can't remember, exactly, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Like, I am thinking roughly-- I think it was around-- maybe 250 kids?",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Ages from seven, eight, and 21, 22.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We met once in a week, a Saturday evening.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "After [YIDDISH].",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "[BACKROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "We used to enjoy.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "We used to-- ping-pong and the older kids used to dance and meetings.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And we used to enjoy over there, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I tell you, I don't remember exactly the street.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I remember, like, maybe like seven, eight blocks away from me, where I live, was like a-- like a house.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And big room.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "One huge, big room.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And this was the location.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "We have only one location.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "We used to have one location.",
