{
  "stem": "4146.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "In the other way, you couldn't survive.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "You don't have nothing to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Not, not special, no-- not special.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "We had-- one fellow, we had it, that's the-- was a soldier, and he was very religious.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "He didn't shoot.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I, I will stand up for him.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Because I don't let him do what they want to do to them.",
      "word_count": 13
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I was fighting with them.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "With the Polish kids.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "They draft me in Wolbrom.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Still, because I'm born in Wolbrom.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "They sent me to the arms camp.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "It was in [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "The German, German border's around there.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "We-- there was Friday morning in September, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "There were--",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "They take you.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "They send you papers.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "You have to come to this and this city, and you're drafted to the army.",
      "word_count": 15
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "So it's not everybody from Wolbrom went in one, one place.",
      "word_count": 11
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "They split.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "So it was very hard to do this.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "But for me, it was more easy because I belonged to Jabotinsky, and they teach me the rules and everything for the soldiers So I have it.",
      "word_count": 27
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "They don't know what I know, and I was on top.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "I was till 1939.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- we don't fight too much because they, they, they will have ammunition and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "That's-- we don't-- couldn't-- we couldn't fight them.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Just a, a, a gun.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there, a few days.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And then they took us in prison.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "This is the army prison, army prison.",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Prisoner of war.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Not too good.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Well, the first [INAUDIBLE], they don't you food.",
      "word_count": 8
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "You was hungry all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "A few months.",
      "word_count": 3
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Well, you get used-- and when you're not eating, you're on a diet.",
      "word_count": 13
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
