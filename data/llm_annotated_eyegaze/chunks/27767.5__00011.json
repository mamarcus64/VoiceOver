{
  "stem": "27767.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And I was trying-- it was winter cold.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I was trying to put that-- under-- under my-- my clothes, I was trying to put that blanket.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "If they would have find me, I would have been in big trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I lost a lot of weight.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "So I-- my father-- once I was-- you asked me if I was sick, I was sick once in-- in Allach.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "I got a terrible toothache, just-- just terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And I went to the-- we had a little, they called it, [GERMAN].",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "It was like a clinic hospital type, a barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And there, they worked three doctors-- two doctors from Oradea, from my wife's town.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And we know them.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "I know them.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And I went to him.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "And I said to him, look, I'm terrible [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "He said to me, you are-- my face was like this, like a stone.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "And he-- and he-- and he said to me, I have to open it.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "We don't have medicines.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "We don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "We don't-- we don't have-- I have a little alcohol here.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "I have nothing else.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "I'm going to open it for you from outside.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "And you can see it here still.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "He opened, and he drained the whole thing from there.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "And he said, I'm going to try to do it-- he was joking me, you should be able to get married.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "And-- and he made an opening without anaesthesia, without nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "It was terrible pain.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "And-- and he took out that.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 28,
      "text": "And-- and I got better.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 29,
      "text": "And that was a time when I was actually sick.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 30,
      "text": "But my father got sick.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 31,
      "text": "He-- and-- and-- and this doctor told me, look, I must send your father back to Dachau.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 32,
      "text": "I said to him, no, I don't want him to send.",
      "word_count": 11
    }
  ],
