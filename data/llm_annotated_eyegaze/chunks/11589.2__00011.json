{
  "stem": "11589.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And we started over there, you know, to get organized a little bit.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "They put us in another camp, but that was another camp.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, a camp, a temporary living, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They gave us food and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You know, all the facilities they had.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And until we getting established, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So, finally, with the time, you know, I had cousins over there, here and there, so we moved out and we rent a place, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They helped us out.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And I start working for a company, one of the biggest company in Israel, [INAUDIBLE], which is doing a lot of buildings, constructions, and all kind of stuff, you know.",
      "word_count": 30
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I was the man that was supplying them parts for the machines and all that stuff, because I knew English and knew a little bit about these things.",
      "word_count": 28
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "So they made me over there.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "They gave me a good job, and I start working over there, yes.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I did not have to serve, but they took me as a miluim.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "That means not the regular army--",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Reserve army.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They took me.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't have to go-- every year, I had to go for a week or two.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "When the war broke out, you know, over there, they took me to the army, with the, you know, Holy War.",
      "word_count": 21
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I showed you that thing.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "That was, I think, '48, '49, I think. 1949.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And I was taken to the army They took me to Jerusalem.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I was there with the army.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And then they took me to the Golan Heights.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Remember the night we went through over there.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "They were shooting at us, you know, from the mountains, and making fun.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "Because they were sitting up there high, you know, and we were down there.",
      "word_count": 14
    }
  ],
