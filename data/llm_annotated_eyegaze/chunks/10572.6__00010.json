  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I think it meant-- I think it meant a little bit-- you know, Stefan Zweig, one of the great German writers who went to South America and was very successful and committed suicide after the fall of France, I think that there were many people who saw the-- the destruction of civilization as we knew it, you know, who-- like I always felt that if it wouldn't have been for Winston Churchill, who was so stubborn and held out, you and I wouldn't be sitting here today because the Nazis would have won the war and would have come and so on.",
      "word_count": 102
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I think after she realized that we didn't need her unbelievable courage and strength anymore, she caved in.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And she was home alone.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And she was lonesome.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And she was in a country whose language she didn't understand.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And when she went to the AMP or Jewel, there was not little butcher in a small town who knew her.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And she had to punch buttons.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And this was a complete strange surrounding that she couldn't handle anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And when this letter came, which meant that this beloved brother of my father with his family was gone, she couldn't handle it.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother was not.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was one day asked by the-- by a man that came to our house, gestapo, and said to her, aren't you Aryan?",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And my mother looked at him and said, with great shame, I admit that I am.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    }
  ],
