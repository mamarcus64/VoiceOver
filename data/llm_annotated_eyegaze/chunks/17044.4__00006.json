{
  "stem": "17044.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "We negotiated for six loaves bread, a jacket, and a pair of boots.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "I took the other guy's place, and I sold myself to go away in the labor camp.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "So I went to the labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 36,
      "text": "I was there in the labor camp about two or three weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 37,
      "text": "Worked-- were digging turf and other items.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 38,
      "text": "And a lady appeared, what I knew her from another ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 39,
      "text": "She was a heroic lady.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 40,
      "text": "She was a mass grave-- she came out from the mass grave with the whole town-- Odessa, near Odessa.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 41,
      "text": "They execute the town, and she was buried under the people.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 42,
      "text": "Nighttime, they didn't have chance to cover the people, so she went out.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 43,
      "text": "And then she became a real heroic lady.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 44,
      "text": "She was going save people from camps, take them out--",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- I don't remember, again.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And anyway, so, she came into this camp, what I worked, in the town of Tul'chin, labor camp.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She came in, and she saw me.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So I ask her what she's doing there.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "She said she can-- she got paid to pick somebody up from this camp to take out.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I said, 'Why don't you take me?' She said, 'Yeah.' So I sold the bread, what I had-- something to somebody.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I sold my jacket, and I got some money.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I paid her.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And she told me, the way-- because we were working, and not in camp-- outside.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We're digging turf.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She said, nighttime, when you go back from work, this and this place, and this-- this forest, you jump out.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And you will hear a signal.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "You'll jump out.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And so I did.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And we worked 70-- [PAUSES FOR 3 SECONDS] kilometer, all night.",
      "word_count": 11
    }
  ],
