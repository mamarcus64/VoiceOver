{
  "stem": "8842.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And that smell that we smelled-- that was that they threw-- they poured over these bodies something of burning, and they burned all these bodies.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And when we left the day-- the same day we smelled-- that was the smell.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And all the other people were burned.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Now, my father, and together with these couple of people, were taken-- this is when somebody saw them going, a friend of my family or whoever.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I doubt-- I cannot remember who it was.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And this is when they brought him into that jail in Kovno.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Now they're in Kovno, and my father is now with us, and trying to recuperate from his pneumonia that he had.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was still summer, and this is-- this is all I'm telling you is days--",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It's weeks-- not even a couple of weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And then we had an order from the Germans that everybody should start packing.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "All the Jews have to pack because they're going to give us a certain area in Kovno where they're going to open up-- open up a ghetto.",
      "word_count": 27
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The army.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The army, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Radio.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And plaques on the-- on poles in the street that was written to us.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And newspapers.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "That the Jews-- all the Jews, wherever they live, have to take their belongings and move on to a place called Slabodka.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Spelling-- S-L-A-B-O-T-K-A.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Kovno had a river, and separated in two parts.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We lived on one side of [INAUDIBLE] Slabodka was on the other side of the river.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it's kind of a neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Yes, exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And it was a little, I would call, lower class of an area.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a lot.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "There was a very famous Slabodka yeshiva, they called it-- most famous in the whole world.",
      "word_count": 16
    }
  ],
