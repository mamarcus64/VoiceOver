{
  "stem": "1929.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And the Jewish Refugee Committee took very good care of us.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "At first, we stayed in hostels with other youngsters that were liberated.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And eventually, because I was younger, they sent me to school.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "They sent me to a boarding school called, Bunce Court.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "It was a very fine English school-- well, it was really a German school that was transplanted from Germany to England.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "But I had to totally learn everything, because I never-- well--",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Never really went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Never went to school before, and-- but I'm talking about table manners, or eating.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I-- to me-- I-- they made me sit next to the principal at meal time, because, to me, green vegetables were just grass.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And I had a terrible time adjusting, terrible time adjusting to social thing-- I didn't know, really, much any manners, or any civilized conduct.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I was still in a survival mode.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "But I did-- I did begin to learn to speak English and write English.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I went to school.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And I was doing pretty good, but it was very, very difficult to really get back, because I had missed a fundamental education.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "So then, here, I was 14 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "I was already much more advanced.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, I was going to that boarding school.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "It was called Bunce Court.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "It was in the county of Kent.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My brother was in London.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "My brother was in London.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "He had found a job.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "He was working in a-- in a furniture making factory.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I had an uncle-- my-- my brother-- my father's youngest brother-- I think it was the youngest.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Maybe he was the middle one.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "He came to America before World War I, so-- or-- yeah, I think so.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "No, after World War I.",
      "word_count": 5
    }
  ],
