{
  "stem": "6523.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "He knows he's not going to-- because they took him to bury, to clean up after the dead.",
      "word_count": 18
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "He gave me a razor blade.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "It was a big thing-- like a Gillette.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "He gave me a piece of soap.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "It was a big thing.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "He was from Rokitna.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "He was not-- he married a girl from Radom.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I met him.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "He said, well, we will go.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "They'd been left, the [NON-ENGLISH], the people that cleaned up.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "They saw the whole business of the 22,000 Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "He saw this thing.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "He said, I am not going to be alive.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH] some people tried to get us through-- many different ways.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "Ridiculous.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "You've got to really be able to put yourself in a place where you take out the trash, to hide under the-- somehow.",
      "word_count": 23
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "Most were caught.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "I remember, they made the [NON-ENGLISH] The commander people had been with us maybe, I don't know, a couple weeks.",
      "word_count": 20
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "And they disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "You know, they got an A-- [NON-ENGLISH SPEECH].",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 13,
      "text": "Jews that did the work to finish.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "After this--",
      "word_count": 2
    }
  ],
