  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He's helping me with taking care on the cows and on the pigs.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "So he didn't tell nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But I think that guy later must have told his father.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "That's why they burned down the barn while we were there.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "If he wouldn't leave, we wouldn't be alive.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "We would be burned in the barn.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We didn't even know when the holidays or anything.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what day-- I mean, we knew it was Monday.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But that's about it.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't know the dates or anything.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Whatever he used to give us.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And my mother or my father used to go back to at night to people and bring some piece of bread, crumbs, raw potatoes.",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I used to have in my stomach live worms.",
      "word_count": 9
    }
  ],
