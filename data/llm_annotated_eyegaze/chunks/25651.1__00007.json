  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "The first three years, he went to a German gymnasium.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "And the last four years, he went to the Czech gymnasium.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "Now he spoke perfect Czech because of his change at the age, about 12 or 13.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "Mortre, ?] Mordecai, or Max, Maximilian, he went to German elementary school and swapped over to German gymnasium.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "He left on Youth [?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "Alliah ?] in 1937, so he spoke perfect Czech because he had six years of gymnasium.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "He didn't actually finish [NON-ENGLISH] because my father took the view that he had to begin liquidating opposition in Novy Jicin and [?",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "Mortre ?] was the least problematical.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "Milos ?] and-- well, I haven't come to the next two but there was a next brother, next to me, and myself.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "We were still small children, so we couldn't be sent away.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "Max was the first, really sort of grownup boy-- not grown up but well adolescent-- he was tall and-- and self-assured.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 33,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 34,
      "text": "Shragga ?] was involved in studies at a-- at a textile school.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 35,
      "text": "Henry was-- Henry was in the business.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 36,
      "text": "And Henry was actually the sort of man that was handy to have when we would move.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 37,
      "text": "And in fact, Henry was the moving force to-- to help out when we actually fled in 1938.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 38,
      "text": "And Leo was at university, so the next brother it was Emmanuel, or [?",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 39,
      "text": "Manachaimendal ?] in Hebrew.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 40,
      "text": "We used to call him Milos.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 41,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 42,
      "text": "Milos ?] means lover in Czech.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 43,
      "text": "He-- he-- well, he had a lovely nature, a very loving sort of person, boy.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 44,
      "text": "He wasn't too loving with me when we were small because he-- I mean, he had a problem that I supplanted him because I became a baby.",
      "word_count": 27
    }
  ],
