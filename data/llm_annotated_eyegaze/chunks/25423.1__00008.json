  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "My father tried very hard to arrange for me a Hebrew religious education.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "But I did not respond to it, and finally my father-- being a very intelligent man-- realized that by forcing me, he only increased the resentment.",
      "word_count": 26
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "The result was that I had no religious education.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "I was free.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "No question about it.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was trained by a very pleasant young teacher.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And I could sing my [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "It's somewhere at the end of February-- I couldn't tell you it.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember any longer, but I used-- I read the [INAUDIBLE], and I also read from the Torah, which I still am able, occasionally, to do.",
      "word_count": 27
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And then I-- there was a reception in my house, and I delivered a discourse on [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Namely, there are, as you know, there are [INAUDIBLE] and [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Oh, by all means.",
      "word_count": 4
    }
  ],
