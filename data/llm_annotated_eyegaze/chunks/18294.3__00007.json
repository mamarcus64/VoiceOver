{
  "stem": "18294.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 47.3,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "So what they done, they bring some horses with-- what they call-- [NON-ENGLISH], no wagon, a wagon-- what-- a carriage.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "They bring the horse with the carriage, and all the sick ones, they put on the carriage and bring them to the little town there near the field.",
      "word_count": 28
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And my cousin was lying with maybe a lot of girls very sick with typhus.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "They have typhus.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And she was very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And I find her.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And I took her out from there.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And I washed her.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "Because anyway, the girls that were already like me, healthy, when I was-- I met with another three girls from near Vilna, they didn't want to let her in.",
      "word_count": 29
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "They said, look, she have typhus or something that we haven't got, we catch.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "This was a catching, terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "So I wash her somewhere else, and I bring her in.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And she was going with me.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "She was liberated.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "We come together.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The name of the town was Lauenburg that we're liberated.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And-- the first-- it was Lauenburg, it was near-- this was where the [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It was a little town.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And when we liberated, then we went to the houses from the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Then we had a problem.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Then arrived the Russians.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The German was ones only-- left the houses, and they run away.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "There was empty houses.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We could go in, and take whatever we wanted.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We took clean clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "We washed ourselves.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "There was food still left in there.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "There used to be-- under the houses, there used to be such a-- a hiding-- no hiding place.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They put all the food.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "There was no fridges.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "There was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "So they keep every food there.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "So we find it, and we eat it.",
      "word_count": 8
    }
  ],
