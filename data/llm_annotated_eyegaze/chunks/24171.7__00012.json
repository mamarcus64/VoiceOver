{
  "stem": "24171.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We went to the consulate, to the American.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And-- and he said to-- to us, do you know what?",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "In America is a law that-- we told him that we are married, but we haven't got the marriage license.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "That's what our papers state there.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "He said, there, you could marry-- get married twice with the same wife, even if they are divorced.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And you could get married there.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "So we-- and they give us there the secretary.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "She said there-- and there was another couple-- she said, you come tomorrow morning, or-- or whenever, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And you're going to get a divorce.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "We're going to wait for that couple, the-- the witness.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "And they're going to be for us.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "It cost us a few cartons of cigarettes, you know, because that's-- there was no money to pay.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "We didn't have.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And so, that's what we did.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "We were laughing because, in the morning, we got a divorce.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "And then we went for lunch.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "And then the men started laughing.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "They said, well, we are free now.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "We won't re-marry you.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "We're not-- we won't marry you.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "Well, they was kind of-- Eventually-- eventually, though, you came to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And then we got married.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And then, we came to the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "It was Thanksgiving, something.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Oh, we had-- oh, we had--",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "'47.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "'47.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We were in a hurricane.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Our ship was almost cut in two.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Everything was broken.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I had another problem there.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I was pregnant, and I had a miscarriage right at-- I-- on-- on-- on the-- the third day, when we went on the boat.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And there was no doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "It was a military boat, the was the name of that thing.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The men were sleeping separate.",
      "word_count": 5
    }
  ],
