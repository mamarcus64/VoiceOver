{
  "stem": "10699.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I have a friend, she was in the same convoy as us from Saint-Etienne.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "A lawyer, I don't want to mention her name.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I met her after the war in Strasbourg.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "When she arrived at the camp, the most hopeless woman, an educated woman, a barrister, the most hopeless woman you can meet when it comes to ordinary things, we helped her out, you know, with what we could.",
      "word_count": 38
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She hid in the so-called toilets there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "She couldn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They'd kill-- they killed her off otherwise.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And I saw her after the war in Strasbourg.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "They said she's here with her husband.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I said, never.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I met her in Strasbourg over a meal.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I said, Margaret, if you are here today, thousands of others should be here.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She says, how come.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I'm pleased to see you, but how come?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "She said, I'll tell you the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I was under review on the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "She was selected for the gas chambers because she was already sent before.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And whoever was in charge of the review exchanged her for another person.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "The other person probably was also on the list, but that's how she's here today.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] And she was not a youngster.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "She was-- another youngster.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Another youngster was over 30.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And she had a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And she-- her husband lived another good few years.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And her daughter is married with children, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "She has a good old age.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "That's one of the cases that that's how she came out.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "But she is a lovely person.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "She-- that's how she made it otherwise.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And there was another case that I never thought she would come out, because she was already, when she was in the-- in the-- in the barracks, my mother couldn't keep-- she was always crying.",
      "word_count": 35
    }
  ],
