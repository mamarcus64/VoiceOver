  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So he learned a lot from his experience.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "When you say that the priest instilled a sense of anti-Semitism in the people, do you know in-- in what capacity that-- that was done?",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I used to go to church continuously, because I was under the 'supervision,' quote unquote, of the Roman Catholic Church till the age of 21.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I had lived right across from the church.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And I was to go to church in the morning and at night.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And I so much wanted to show everybody that I'm still a Roman Catholic.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And this was the only religion I knew, basically.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I heard, for example, the priest during Christmastime-- that's-- that's the most horrifying thing for me, was when the priest, during-- during the time of Christmas, would just basically say that Jews have-- oh.",
      "word_count": 38
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
  ],
