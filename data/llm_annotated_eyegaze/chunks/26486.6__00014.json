{
  "stem": "26486.6",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "I said I'm going to sell everything, and I'm going to America.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So I sold everything.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I had everything new.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Everything new, because the Gestapo had taken everything.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So I had everything new in my beautiful apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I just sold everything.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Lillian helped me.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "She helped to sell things.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And I came here to find my poor daughter living down at that horrible Bromley-Heath thing there.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "That's where she was living.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I got her out of there as quick as I could.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I was lucky to find a job right-- almost right away.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "I found a job as hostess in a French restaurant.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "It was better than nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And I was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And they were my first friends here in Boston.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes, right here in Jamaica Plain.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I have three beautiful great-grandchildren.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I have my great-- my grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I have Marc, I have Patricia, and I have Carole.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I have three great-grand.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "I have Jennifer O'Halloran, I have Danielle O'Halloran, and now I have Curt Lieber.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
