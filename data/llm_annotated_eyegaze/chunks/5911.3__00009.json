{
  "stem": "5911.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "A lot of women-- I don't remember how many.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "My mother says there was about 1,200 who were picked to work.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I was in Stutthof in July.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "In-- we got there in July.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We must have been July, August, September.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Because when we got to the first small labor camp, that we lived in tents and straw on the floor-- it was still all right.",
      "word_count": 25
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Later, it froze everything.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So it was still not too bad, because you slept on straw.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "It was dry.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "So we must have been in Stutthof three months-- July, August, September-- maybe the beginning of October.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And the name of the first labor camp which you arrived?",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The-- I have to-- I have it-- yes.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was Trunz.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "There were three-- Trunz, Merzen, and Leibisch.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "We were transported from one after you finished.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And let me tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "I was a terrific worker.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "We all had-- we didn't have numbers here.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "But naturally, on our clothes was sown on a number, on your chest.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "And I was a terrific worker.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I used to dig the ditches, because also my mother was in the infirmary.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "Maybe I had an extra ration.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "Maybe I had an extra-- she used to take off her jacket and give it to me when it was cold.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "But this was the beginning.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "And I got extra rations of soup.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "The-- we used to get maybe stale bread, but I remember the soup.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "And I used to share it.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "Naturally, I lost my friend, Chaya.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "And I met a lot of people who were in Stutthof and who-- who came with us to the labor camps.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "And I made a lot of friends, because I was an only child.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 19,
      "text": "And I used to share.",
      "word_count": 5
    }
  ],
