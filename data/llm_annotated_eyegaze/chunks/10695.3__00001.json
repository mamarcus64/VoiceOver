  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] When I used to go for food, we had plenty food.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "They give us plenty food.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And when the time, when the German came and killed all the family, they came to me too.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Because that's, you know, there was a way go.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "We run away.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "We run about 20 miles away.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "They didn't caught us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] And we stayed there till it became dark.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "And we run to a-- in a Polish place where they-- people used to keep the corn and the wheat.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "We sleeped over there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "Well, the Polack knows we came-- we live there.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "He came fast to run.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Germans surrendered.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "He didn't came when they were close.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "I don't know he find out, but they were a couple miles away.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "And we run away.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "We run away, and they shoot at us.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "We run about four miles away.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "They shoot on us bullets, so fast.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "They shoot on us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "They didn't caught us, didn't caught us.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "Nobody was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "We run away to the same place where we used to stay.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "We find a little girl who was frozen.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "She frozen up.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "She run away from the-- from the bunker, with her father, and the mother lived there.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "She run to us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 39,
      "text": "But we didn't was there.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 40,
      "text": "And she frozen up.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 41,
      "text": "We took her, and we buried her with the father.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 42,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We lived.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I lived to the time a Russian man came over.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He said to me, who knows the road how to go to-- to Russian army?",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] I said, I know.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "You know why I know?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    }
  ],
