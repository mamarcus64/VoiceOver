  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "And of course the ground was wet, and these poor people were frenzied in their attempt to crawl out.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "And some of them dug their way out, and they just pinned them to the ground with bayonets through the neck, or through the heart.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 28,
      "text": "So-- and what purpose they thought they were serving, God only knows.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 29,
      "text": "But this is all over the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 30,
      "text": "So they killed a lot of people.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 31,
      "text": "Out of 8,000 people, I think they killed all except three.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Let me get up and cough--",
      "word_count": 6
    }
  ],
