  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "And I thought I had somebody to go back to.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother, we communicated through the electric barbed wire, because pieces of paper sometimes people threw.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I had one aunt, my mother's brother's wife-- youngest brother who died this year-- who was together with my mother.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So she survived the selection in Birkenau and was sent on to some other camp.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "To the best of my knowledge, to Stutthof.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But I tried to find even in Yad Vashem details about Stutthof, and there-- I couldn't find anything.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And I'm pretty well-informed how to look for it.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Apparently very few people survived from there, accordingly.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "But I heard people were put out on a ship and sunk in the ice and water.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Those who survived, had terrible stories about Stutthof.",
      "word_count": 8
    }
  ],
