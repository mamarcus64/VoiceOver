{
  "stem": "3933.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "They were giving-- chocolate stuff to Zbyshek.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "Once, I went to a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "I didn't have my period.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "I went to a doctor in the village, which was three miles, three kilometer, and he told me I'm pregnant.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And I said, sir, I couldn't be.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "And I started to cry-- no, please, don't say that.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "He said, ma'am, you are pregnant, and I don't remember how far.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And I told him the story.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "And I says, well that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "This German Franz, also blond and blue eyed from Munich.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Would you believe it?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I met him in Munich in 1975?",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Would you believe that?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And then I said-- then it was a woman, Barbara was her name.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Also, we became friends.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Of course, everything as a Catholic.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Everything as a Catholic.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And Barbara said, Maria, you are going to have to get rid of it.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I go to this doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I'll take you.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I'll go with you, but you have to have-- I don't know, cigarettes, and wine.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "They gave me, from the canteen, lots of these things, and I can give it to this man because the monies-- there was no even think about it.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I went there, and then I said, how am I going to go there?",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "How  I was going to take me back?",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to need transportation.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And I told this secret to this Franz Knoler.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I started to cry, and he was very fond of me.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And he liked this little boy.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was engaged to a girl-- he showed me the pictures in Munich.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And he was such a decent young man.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And he was also against the Nazis, anti-Nazi.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But he wouldn't--and I said, Franz, I'm-- and I started  to cry.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And he said, what happened?",
      "word_count": 5
    }
  ],
