{
  "stem": "422.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "You have to wear what you was given.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I said, I cannot put on.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It's too small.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Another-- another bang in my head.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "That's where they put people.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "The women were sometimes even worse than the men.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I witnessed-- during the time I was in Majdanek, I witnessed a couple of hangings from girls that were trying to escape, young girls.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "We had to stay-- oh, we were thousands of women.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We had to stay, and make a big circle, and watch.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "If I turned my, I couldn't see it, I was hit.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "I had to see it.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "They wanted me to watch, closely to see what's going to happen when I'm going to do the same thing, when I escape.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "After being a couple months there-- to be a couple months in Majdanek, to be even one week in Majdankek-- it was terrible.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "It's a terrible-- was a terrible death camp.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "The food was so bad that everybody developed dysentery-- the sickness.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "I had some kind of look that one SS woman was to me-- I don't know.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "She took a liking to me.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "In the field when they took us work, she said that she saw that I couldn't work.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "I was too week.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "She made me to lay in the grass the whole day.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And I said, I'm afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "I don't want to lay, because every hour-- another-- an SS man came riding by on a motorcycle, checking if you are not faking, if we really work.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "The work was to pick, in springtime, the young vegetables out of the ground.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "So of course, if we could, we ate it.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "And this, it gave us some vitamins, this.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So I said to that SS woman, I don't want to lay.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I'm strong enough I can work.",
      "word_count": 6
    }
  ],
