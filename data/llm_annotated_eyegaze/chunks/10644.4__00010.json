  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "They were Russian Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "But there are other-- other doctors, not many-- four or five in this whole hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "They were all Russians.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I decided-- I-- they-- they brought me without my wife.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "My wife left-- left in-- in-- in Stutthof.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Now my-- my-- I got-- I was decided I stay here until I have information about my family.",
      "word_count": 18
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I cannot go to Bialystok, because the Poles take out Jews out of the-- of the trains, and they killed them.",
      "word_count": 21
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Safer here.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I'm-- have Russians here.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Poles came, but the Russians-- I'm with-- with the Russians.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH], you know, [NON-ENGLISH], I have friends-- friends are Russians officers.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "I treated them for gonorrhea.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "I got sulfa drugs.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Oh, from the-- from the hospital-- from the hospital and from the-- from the doctor's office-- office.",
      "word_count": 17
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Ending?",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Ending.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "That is, how to say, the story-- not the final story.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "It is, you know, right, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "I-- I-- I found my wife dead in Eckernforde.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "It is a city, a port, in Western Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    }
  ],
