  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And-- and he was just starving, like all of us.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Apparently, he couldn't take it.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And so he went to my mother and-- and grabbed her by the foot and looked at her and he said, please, give me something to eat because I can't take it anymore.",
      "word_count": 33
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So she turned to him and she said, I have no-- nothing to give you.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And he said, please.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I want to die.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] [SOBBING] And I can never forget the look on my mother's face.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "[SOBBING] And she looked at him [SOBBING] [PAUSES FOR 4 SECONDS] and [PAUSES FOR 6 SECONDS] it was-- it was horrible.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Excuse me, please.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And somebody kicked him from the back.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And he said, please let me die.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[SOBBING] Give me some bread.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] Excuse me.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Excuse me, please.",
      "word_count": 3
    }
