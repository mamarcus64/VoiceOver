  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "I came into the barracks was a prisoner, a woman, a doctor.",
      "word_count": 12
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "This is unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "And she said to me, she bandaged everything.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 7,
      "text": "And she put iodine.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 8,
      "text": "And she said, you're going to stay here for three days, not to go to work till that set.",
      "word_count": 19
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 9,
      "text": "And I walked out from her.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 10,
      "text": "It's not a joke.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 11,
      "text": "I took off the bandage.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 12,
      "text": "And I put dirt in.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 13,
      "text": "I want to get poison.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 14,
      "text": "And three days later when I come back, everything healed.",
      "word_count": 10
    }
  ],
