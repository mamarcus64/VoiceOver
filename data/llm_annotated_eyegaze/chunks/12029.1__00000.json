{
  "stem": "12029.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Rena Zabielak.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Rena Zabielak, Z-A-B-I-E-L-A-K.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Litwak.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "L-I-T-W-A-K.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The 23rd of March, 1924.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "7-- nearly 72.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Warsaw, [PAUSES FOR 4 SECONDS] in, in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Warsaw, [PAUSES FOR 4 SECONDS] on the 23rd of March, 1924.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was Mindla, Mindla Litwak [NON-ENGLISH] Poncz, P-O-N-C-Z.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] I was the first child to my dear parents.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 3 SECONDS] when I was three, [PAUSES FOR 3 SECONDS] we had an addition of the family, my only brother, Abraham, Adek.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] We were looked after by my mother on the beginning.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And then we had a governess, which used to look after us.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "The governess spoke French.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And she taught us speak-- she spoke to us in French.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "When I was six, I was sent to a private school in Warsaw, which was called [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "It was quite a way from home.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "But my [PAUSES FOR 3 SECONDS] mother used to take us to school or our governess-- to take me to school.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Because my brother started a few years later.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father had import and export of fruit on [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was a place where all the fruit trade was in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my family were-- my grandfather used to be an antique dealer.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But the grandfather from my father's side was a teacher a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "He used to teach children in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And he had-- it was called [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My, my maternal grandparents live not far from us in Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But my paternal grandparents lived over the river.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Vistula went through Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they used to live in Praga.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And how far away was that?",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "It wasn't very far.",
      "word_count": 4
    }
  ],
