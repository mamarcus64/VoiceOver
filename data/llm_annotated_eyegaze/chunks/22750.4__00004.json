{
  "stem": "22750.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "I didn't hear she went out to here, maybe in the area, if somebody shoot somebody.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And he came back and she-- talked to her.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "Don't believe it.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "I know George-- my name is now George, at that time was a different name-- and he wouldn't do this.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And I didn't hear nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And she [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And the last night I came.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And I took my wife with my child-- I'll make it shorter.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And I went to them.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And I went to the store.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "When I came back and he told me he already was killed to take me in.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "He said, oh, we already exchanged.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "When you left, they mind not to take anyone.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "To here, to here.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "Decent people.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "Don't think everybody was killers.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "There was decent people, too.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "And anyway, I went to the store and I brought them in the store, bring it out already for the kid something warm.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "And the force start to be stronger and cold.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "And decent people with good feeling, one human to another human.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And they came out.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "And we start to discuss something to do.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "And we find out, in my mind I had a plan, heard from somebody.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "They dig in the barn, where the cows.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "A hole under the cows, and put a wood on the top.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "And put in there in the cow's back into the kitchen where the cow is eating.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "Take it off the bottom, and that's where they are.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "And when I came in, I thought, I'm a man in this house.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "I wasn't so happy.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 42,
      "text": "And so satisfied where I came to the hole, because in the hole under the cows was warm.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Shareck.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I will try.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Vladek, W-L-A-D-E-K, Vladek.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And Shareck, C-H-A-R-E-K.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "That's a different subject.",
      "word_count": 4
    }
  ],
