{
  "stem": "7600.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And then, this one person who-- my great aunt, who was living with her accountant husband, they raided her apartment.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They came to her and they said, get out of the apartment for two days.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And they took everything that they wanted to take.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And then-- and then, I think he was beaten up or somebody-- we always heard how-- you didn't need the newspaper.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Word of mouth, this one was beaten up, this one was gone to a concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "You heard nothing but bad news all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My mother had to do something, so she got herself a job as a cook in somebody else's [INAUDIBLE] because at that time, Mitzi had to go, too.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It was not allowed for people to have anybody-- [PAUSES FOR 6 SECONDS] to have a non-Jewish [PAUSES FOR 3 SECONDS] employee.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So Mitzi had to go.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And some of these people that still had money still needed a cook, so my mother got herself a job as a cook.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And she-- she says, that way, we get food.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "We get this.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She was pretty feisty.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She sort of picked herself up.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Her mother was gone.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She was the head of the household.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She sort of picked herself up, and I was really amazed to see how she got herself together and took care of-- of her kids, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And-- so we were waiting for the affidavit.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We were waiting for the affidavit.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So finally-- oh, in the meantime though, something happened to me.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My scalp itched, and when I scratched it, it was bloody.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And I was losing my hair in bunches.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So there were still some Jewish doctors.",
      "word_count": 7
    }
  ],
