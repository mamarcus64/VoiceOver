  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "We were married on February 15, 1959.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Cold winter day.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We came here.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Our honeymoon was setting up our kitchen on-- I think it was Wildemere in Detroit.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I have three boys.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "The oldest is 36, Yitzchak Segal.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Y-I-T-Z-C-H-A-K.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And he's married to Linda.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And they have five children.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He's got five children.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And he's a computer analyst.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Remy. ?] He's 14.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] 13.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Doby ?] is 11.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Yehuda is 10.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Chiffa ?] is eight.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "Now, [?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Chiffa ?] is unusual, because she was born-- the Segal families have had no girls in their family for at least 100 years.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And finally, she was born.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I have one son that's in-- does animation voices in Los Angeles, [?",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Andy ?] Segal.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And then I have a son in-- in Manhattan.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "He is an actuary.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He's the youngest one.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He's 30.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And the one in California is 35.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Since I've been in the States, besides teaching Israeli folk dancing, I was a medical receptionist.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "At the Jewish Center in Oak Park, Michigan.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And also in my basement.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I like to knit, crochet.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I love to bake and cook.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And that's it.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Travel.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We love travel.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Both my husband and I love it.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My-- I'm the oldest, but the older brother, Rabbi van Leeuwen lives in Kiryat Arba, which is near Hebron in Israel.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And he has seven children, and two daughters in law, and two grandchildren.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And then, I-- my baby brother, the one that was born six weeks after-- six weeks after-- before my father died, he lives right outside of Tel Aviv with his wife and three kids.",
      "word_count": 34
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "When we can.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We try to rack up free mileage when we go.",
      "word_count": 10
    }
  ],
