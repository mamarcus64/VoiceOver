{
  "stem": "25834.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And this young fellow-- German fellow-- German fellow, before the 1930s-- something like this-- during night, kill mother, and was sent there to this camp, for example.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "That's kind of people was there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Or politician, like General Canaris.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "If you remember, there was one of brilliant head in German Army, in the [GERMAN] [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Because it was against Hitler, he was sent there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And a couple of days before American was there, was killed.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Pure luck.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My sister-- we arrived to the Flossenburg, and the girls were sent to block number 17 or 18.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And my-- my sister was very sick.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And some-- no, excuse me-- was sick, not very sick.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And some unit, and but medical unit from the camp give some medicine, this [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And one guy named Yanitski from Poznan, young fellow treat [INAUDIBLE] my sister something.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And from this moment, my sister, my mother said, listen, we have family there-- is father and son.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And give us our name.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And after day-- or the same day-- this fellow look for us, and give our suggestion what we supposed to do.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Very important thing in my life.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "This fellow stop and said, we was not searched yet.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Meaning, we own everything in our pockets.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And I own a gold watch-- very valuable and very famous, because after I finish high school, I receive from my father.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And this fellow said, stop, look for us, and said, don't give these people-- don't take everything with you to pass along.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Give me-- later, then I give you back.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And we know this guy, because he has some message from my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "We risk.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And what we can, we give him back.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Meaning, give him and feeling maybe the fellow will give us back.",
      "word_count": 12
    }
  ],
