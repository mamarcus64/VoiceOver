{
  "stem": "11089.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Again, two angels from the heaven-- two [NON-ENGLISH] Jews-- I never saw them in my life before-- they were the first two people I saw at the gate.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Here is my bag.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Take it.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I can't smell it.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "I can't look at it.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "But please, save me.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "I'm dying.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "They knew right away what happened, that I ate too much.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Those two Jews, may they be [NON-ENGLISH], they took me, they put me down to sleep beside them on the floor.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they gave me roasted bread, a little bit of tea.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And they brought me back to life.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "The next day, I went, I found Meyerowicz.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I took him to the washrooms.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I cleaned him, and I brought him home to Chust.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "That means, what I believe-- some people do not agree.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My belief is, if people would have tried harder to apply some ways of struggling to stay alive, my opinion is that, at least, close to a million would have been survived.",
      "word_count": 32
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "What I mean is the following.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "For example, in the camp, the sick people's camp-- I begged my friend, the same age, let's go out to fresh air.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I will help you.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "He said no.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "We are warm here, under the blanket, and the lice ate them up-- the lice.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "There were camps that was made [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH] is to get rid of lice.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "It was hard to go there, because it was very hot inside.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "It was steam.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "You had-- you had to undress, pull your clothes into a little package.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "You sort them to an oven.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "They came out the other side.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "But the lice were burned.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "So you take back your clothes and put it on.",
      "word_count": 10
    }
  ],
