{
  "stem": "25912.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I mean there was my grandmother, there were two of my mother's sisters and their families.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "There was my grandmother's bother and his wife.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I think at that time this wasn't something which frightened you.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "It was an everyday thing.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "You knew you could die whether you were Jewish or you were Polish.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "It just-- it was a fact of life.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "You were alive or you could be deported to Germany for labor.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "You could be killed.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "There was no stability, security.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "You just took each day as it came.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "You just had to adapt.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Occasionally we had something Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Biedrzycka via Switzerland.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My father had a friend in Switzerland who used to transmit information because you could write to neutral country from England.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "That wasn't through the Red Cross.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "That was direct mail.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And then there were the Red Cross cards.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Or they were limited to I think twenty words or something like that.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "There were also Red Cross parcels which used to come to Mrs.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH] for us.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Sardines.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Sardines, chocolate, I can't remember anything else.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But you know they were far in between.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I can't even remember that there was close particular excitement.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "It was much more exciting having news of my father.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "My friends who were not aware that I was Jewish and I was hiding, they took it for granted that my father was in the Polish army therefore I was in hiding.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Because several of them were in the same situation.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "My patrol leader her mother was in Auschwitz because she was assistant to one of the leaders of the resistance and was arrested with him.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "She's survived and today is a lady in her 90s living in London.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Helena Czarnocka.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So you know there were all these things which happened.",
      "word_count": 10
    }
  ],
