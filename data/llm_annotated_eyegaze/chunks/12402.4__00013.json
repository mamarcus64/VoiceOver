{
  "stem": "12402.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My brothers knew already that we're coming, and they took a small plane-- they came by plane.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They were very wealthy, my brothers in Montreal.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They had a big factory.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "The both of them came to greet us.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "It was-- the joy was out of this world.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "You know to-- we were the first ones to arrive in Montreal.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "There was no OTPs, nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Nobody was there yet because there was no passage.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So from Halifax, they usually-- there was a lot of people came with us on the ship.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But they had to go by train.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But my brothers took me on a small plane, which took maybe four hours to-- to fly.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But for the train, it would take 24 hours.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It's a long trip to Montreal.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So we got into Montreal.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So right away, he set us up with the-- they rented for us a room, you know, a boarding room, you know, room and board, you know, for the two of us.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And they wanted me to work for them in the factory, my brothers.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "So-- but I didn't want to work in factories.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I said, I want to learn the language, English, and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "So I got a job in a dry goods store, and I worked there for $20 a week.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And there, she happened to work-- she was-- my wife was working in the office.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "She was young at the time.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And there was-- I-- every day I greeted, spoke to her, said one day, well, I'll take you out.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "One Saturday-- Saturday night, I didn't work Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "So I took her out once, and then on Monday, she comes back with the stories that my father has a little business.",
      "word_count": 23
    }
  ],
