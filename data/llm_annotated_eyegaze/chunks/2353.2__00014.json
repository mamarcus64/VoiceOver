  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I mean, my-- my-- my father spoke English anyway from his doing business in England so much.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And my mother happened to be a very bright person.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And she spoke English very well, wrote English very well.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And they made it their business to-- to speak English only, as we did, too.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "When-- when-- when we came over, I mean, English wasn't such a-- German wasn't such a well-liked language in this country.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So we made it our business to speak English only if we could.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And we all learned.",
      "word_count": 4
    }
  ],
