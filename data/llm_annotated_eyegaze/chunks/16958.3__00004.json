{
  "stem": "16958.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And I brought it inside.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "We took wood in a corner, completely in a corner, and I build a stand.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "Like-- like a vanity.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "Exactly a vanity.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "I build the stand.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "Took that stone.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "It had to be rough.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "Chip to make it rough.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "And with a piece of tin, had to be round, around.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "And in one place, we just let it-- I think to get-- the flour should come out.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "And we put up the stone.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "We made the stand.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "We started-- we put a little bit grain.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "Hey, flour is come out.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "Flour.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "And we made this here.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "We made this flour.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "Now, we had to-- we set up a-- I'm a little bit going too fast.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "We set up to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "Now we have to set up a place where to cook.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "Because we remember in the other cave that the-- the-- the smoke shouldn't kill us.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So went away.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "This a big route.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We went away and we find a place-- come a place.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And there's a lake.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And near this lake is a stone, a bit like a table.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And by the lake, we see like-- like a-- a few stones to go down.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I says, who made this here?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Somebody like made for us this here.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "We said, this is going to be a good place to cook.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And my mother, she always-- she always had a head.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She knew what she needed to go there.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She brought with her a copper pot about-- kept a pail of water like.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Copper.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Used to make jam with this.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And at-- from an iron ornamental, a three leg-- a three leg-- how you call it?",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It stand like-- it was about five inches high with three little legs.",
      "word_count": 13
    }
  ],
