{
  "stem": "16958.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And they were supposed to let them go next day, like next night.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And at night-- in the same day, a woman came in, a neighbor from my aunt, my mother's sister [POLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And he came in.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And she begged the chief of the police they should let her go.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "She's such a good woman.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Let her go.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So the chief of the police called this Doctor [POLISH] and says, listen.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I can't et her go.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I-- I can't let her go.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I'm not going to jeopardize myself.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "The gestapo gave me to kill them.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I let her go, they know that I let her go, and something.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And he says, if you-- I'll kill them all.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Just like that.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But could-- Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "[POLISH] told after the story, what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So what happened.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They-- they took my sister with her child.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They took my mother's sister with the-- with her son.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And-- and my cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And they brought them at night.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "There was a Jewish cemetery in Bilcze Zlote.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "They put them down.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "They cover them up.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And they were shot in the air a few times.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And they went over and they killed my-- my mother's sister with her-- with her son, a little boy.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "I think eight or 10 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "And my sister and the child and [INAUDIBLE], they-- they let it go because they want the gold and the money.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "This what happen with them.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "Now, with me.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "I was lying there.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "I don't remember how I came out from this hole.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "But what-- when my mother-- my brother came back to the cave, they find me there.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "And I was-- I couldn't talk.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "I couldn't-- I don't remember nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "Just one more thing and one more thing.",
      "word_count": 8
    }
  ],
