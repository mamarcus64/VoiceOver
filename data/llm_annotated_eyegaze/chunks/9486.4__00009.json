{
  "stem": "9486.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "You get married, and you're going to find out how poor is not good.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And I said, all my life I was not rich.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And I don't know what rich is.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "I wanted love.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "And I wanted a good husband.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "And I feel like I'm going to have a good husband.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And the [INAUDIBLE] made a very big wedding.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "I think it was about 400 people.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "We were married.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "And a year later, I had my daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yocheved, after his mother.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "His mother was called Yocheved.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And in-- in Canada, they called her Eva.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And when she came here, they ask your name.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "They said, Yocheved?",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "It was not easy for them to tell them what name you have it.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "As they told her, they can give you choice to pick a name, or Evelyn or Eva.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And she came and asked me, mom, what name should you want it I should take?",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And she said, Evelyn?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "I'm not going to remember Evelyn.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Eva, I'm going to remember.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And that's what they called her, Eva.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "But her middle name is Yocheved.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "So how old was Yocheved when you left Israel?",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Seven years old.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Well, when my daughter was born, she was a lucky child.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Everything what-- I just dreamed what I needed.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "My husband brought it for her.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "It was a bad time.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "You didn't-- everything was on ticket.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Bread was on ticket.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Even a piece of furnitures, we couldn't get it.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "And when she was born, my husband went and bought a beautiful white bed and a beautiful room, even a cover for these-- for the flies, you know.",
      "word_count": 28
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "Things you couldn't even dream I would have, I had for my daughter.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "She was a very good child.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "And after that, we moved.",
      "word_count": 5
    }
  ],
