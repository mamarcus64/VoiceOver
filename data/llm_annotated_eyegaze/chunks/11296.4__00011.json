{
  "stem": "11296.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "So it was, you know, groups still, you know, Polish people who was against the Jews and they-- they start shooting.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And they start-- you know, they killed our friends.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "A few of them killed.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "A few of them got-- you know, jumped down from the second floor.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "They-- you know, and this-- it was start thinking what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "How to--",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we-- we start thinking of what to do.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We stayed for a few months there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Until 1946, before Easter, before Pesach, we picked ourselves up again.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We put up whatever we had, nothing too much, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And we went back to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Somebody tooked us to the border.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We paid them, and tooked us to Berlin.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "In Berlin, we stayed for a while until they assigned us.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "We wanted to go some place.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So they said, where we want to go?",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Germany?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "Where we gonna go?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So they assigned us to another place.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We went to Hanover, we went to Frankfurt [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "From Frankfurt [INAUDIBLE], we went to a small place called Traunstein.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Who went?",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Me and Hanka.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, this was-- what was-- and my brother-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They was already married, and my brother-in-law.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Let me just think.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "We have already brought here-- well, yeah, my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I'm thinking about my nephew, who was not born yet.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, we went to Traunstein and he start working in his-- in his trade.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He have a little [INAUDIBLE] this place.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And between, Hanka bore a child.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Our first, you know, my first [PAUSES FOR 4 SECONDS] nephew was born.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And you know, we settled down in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "This was in '46.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "From '46, I stayed till 1950.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Between Hanka-- Hanka moved away.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She went in '49 to Israel.",
      "word_count": 6
    }
  ],
