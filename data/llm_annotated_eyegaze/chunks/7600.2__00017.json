  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "And I used to go to Mitzi.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "Mitzi was the one that was with them from before Kurt was born-- that's how long-- maybe 20, 25 years.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "And she had brought him up.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "And he was her confidant.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "If he needed something, he went to Mitzi.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "He didn't go to his mother.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "They didn't get along at all.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 33,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 34,
      "text": "I never found out.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 35,
      "text": "I tried to find out.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 36,
      "text": "I tried to ask.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 37,
      "text": "He wouldn't talk about it.",
      "word_count": 5
    }
  ],
