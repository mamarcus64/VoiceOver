{
  "stem": "25114.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "Every evening, the guards changed.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "By the time they went in, and the other ones came back, there was a little distraction.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "And, you know, they didn't just come and take over.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "But they went in this little room.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "It was a-- it was a-- it went away.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And when they came in, the other one went out.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "Five minute elapsed.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "This five minutes, it had to-- had to be done.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "And somebody came from the-- from the-- they knew it were-- there was is group trying to escape.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "As I said, you've got five minutes.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "Open the door and go.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 26,
      "text": "So we opened the door.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 27,
      "text": "I went through the gate.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 28,
      "text": "My husband has already escaped through the wires.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 29,
      "text": "He was already there.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 30,
      "text": "The wires went first, because that could take longer.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 31,
      "text": "And we went to the-- through the gates-- the women and the children, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 32,
      "text": "And the more able ones went through the wires.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 33,
      "text": "About a 1/4 kilometer or something, 200 meters, was a little forest.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 34,
      "text": "We will all meet there.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 35,
      "text": "We all-- we were all there, and came there.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 36,
      "text": "We all meet there.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 37,
      "text": "Everything went smoothly.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 38,
      "text": "And when it happened, this little-- and then we started on our way to the-- Mr.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 39,
      "text": "Kozlovski, to the-- to the hamlet, which connected us with the partisan.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So we came.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We arrived safely-- very, very tiring, and very frightened.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We sort of-- every-- every sound, we thought they are-- they are after us-- every-- you know?",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It was a very still, quiet night.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And there was nobody in the roads.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And bit by bit, we arrived.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We were very tired, and very hungry, and very cold.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And we get-- and we got some food.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And we got some very nice reception.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "He said, you all right?",
      "word_count": 5
    }
  ],
