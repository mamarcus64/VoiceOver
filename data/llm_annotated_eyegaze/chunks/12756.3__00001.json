    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And we got a little, a few pieces of potatoes, and we start eating.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "In the morning, we don't saw a shepherd drive the-- the cattle to the-- to the-- the grass.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
