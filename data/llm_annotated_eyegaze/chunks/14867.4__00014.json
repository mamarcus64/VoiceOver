  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And I don't know where they got money.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "But they did have some money.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And they were contributing.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "But of course, the substantial amounts of money was coming from America.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Many of them were thieves and liars and corrupt because they were stealing for food.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I mean, they were beaten up.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they came, and they had zero values.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They didn't know what is right, what is wrong, what is honest, what is dishonest.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And we had a mess.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "We had 20 kids, 19 kids.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And each kid was different.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And each kid had different problems.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "The problems were unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "And some of them were 13.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "Some of them were 18.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "I had a beautiful girl who was a diplomat's daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "A beautiful blond, gorgeous face-- that she was running away.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "And the Germans, as she was running, killed her.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 14,
      "text": "And she had an amputated leg up to the knee.",
      "word_count": 10
    }
  ],
