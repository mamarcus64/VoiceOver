  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Why-- one, one episode, I, I-- which is very, for me, important, the [NON-ENGLISH] in the-- in the-- in the ghetto, in [NON-ENGLISH].",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "The [NON-ENGLISH], who was a gardener in my-- in, in one of, of my farms.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And he, he keep us on his loft for a night.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And he was the burgermeister of the town because he was a German-- that the German are coming, so they find the German.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "So they make him the burgermeister.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And this is-- this is [? without-- ?] yes.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And, and we went-- we have one night when the German was dancing and, and, and drinking in his place.",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "And, and we were-- we went out there.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I and--",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "--my wife.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Still living in the ghetto, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Because you, you, you expect every night it's happen.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Maybe not this night, next night.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And a few nights, we, we, we been, after the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And when it's happened, this was it.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "And then-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "He was a communist, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he was a very big-- he was General [NON-ENGLISH] Begma, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And we went to his headquarters because he, he has a duty to give some work to everybody who comes.",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "He runs the office and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "So I was sent-- from, from there, I was sent to, to, to [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "It's from Kiev-- is it 20 or 25 kilometers?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH]-- the supplies were in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "Built a [NON-ENGLISH] for himself.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very nice.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "It was a, a, a monastery once.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And he built a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "It was close to the [NON-ENGLISH] River.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And, and I was sent there.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Two, two years because I, I-- he, he wants a specialist.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "He was looking for a specialist from my nationalities.",
      "word_count": 9
    }
  ],
