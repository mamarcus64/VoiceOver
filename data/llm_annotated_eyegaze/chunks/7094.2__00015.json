  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And also, I knew my mother was still there and I wanted to be with her, because I knew that she needed to me.",
      "word_count": 24
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And I jumped out of this train.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I was very slim at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And why didn't I take my sister with me?",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Tell me.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "She was younger than I.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She was blonde.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "She had all the attributes to survive, because if you were blonde and blue eyes, you had a certificate-- not for survival, but it was easier to survive than you-- if you had Semitic features.",
      "word_count": 35
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I was very looking Jewish, feeling Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Why didn't I take her with?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I try to live with this moment all my life.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] I don't think I went through life-- Stop.",
      "word_count": 9
    }
  ],
