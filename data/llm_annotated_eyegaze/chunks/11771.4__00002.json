{
  "stem": "11771.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "When I tell him the story also about Judy-- they took-- and he has very good connections with the SS in Voranava.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "And he says, don't go to this peasant, to these Polacks who Judy, Judy gave me, because he is-- he's watched 24 hours from the SS.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "Whoever goes in, in his apartment, in this neighborhood, in this surrounding-- they'll arrest him, the SS.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "He was a big shot in the Communist Party before.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So I said, but I would like to know the fate of Judith.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "He said, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I'll tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Give me a couple days.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I'll tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "He got very good connections with the SS.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "How did he have connections with them?",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "You know, [YIDDISH].",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Drinking.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I don't know what else.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Money.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] And I say, stay here a couple days.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you exactly what happened to Judith.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I went back to Jesl Livitowsky at home.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "We stayed.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I sleep over the night.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Meanwhile, the wound got healed.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I came back to myself.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "He changed me my clothes that Judith gave me, from like, like a shepherd clothes, you know, which doesn't fit on me.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And it's, it's, it's-- you can see it's, it's, it's, it's not a normal person.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "He gave me his son's clothes, who was in hiding but he never discover himself that I am-- he is there.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And after I talk, we sleep over, I eat.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Fall asleep at night.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "It was a Sunday night.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 5 SECONDS] They knocked in door.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "Somebody knocked in the door.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "They opened it up.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "Three Germans coming in.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "They're searching if somebody here from Ejszyszki or from Lithuanian, sleeping or remaining here when they are not registered as Voranava residents.",
      "word_count": 22
    }
  ],
