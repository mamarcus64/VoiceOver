{
  "stem": "11797.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "And they took over.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "My father didn't-- he didn't need to do because he would just-- he didn't, didn't-- there's no way to, to do anything.",
      "word_count": 22
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have-- the Jewish people didn't actually, actually have too much power in Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Because we were like second citizens.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And so whatever, whatever-- we were accepted, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "We were, like-- we were-- we were, like, passive people, very passive, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "We didn't believe in, in fighting for everything-- frantic.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Many times, I wish he would have done it, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He would have saved our life, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "But we weren't able because my father wasn't-- you know, we were-- we were day-to-day Jewish people.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We made a living, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Like they say in Jewish, you know, he was working seven days, you know, and seven days, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "He was trying to make a living in seven days.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] He always missed a day to make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Her, her, her father-- her father, not she-- not her.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Her father was a Zionist movement leader.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "She knew about it.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "But she wasn't involved.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "When my life changed, you know, when I-- when one time I was trying to go-- when I found out I'm being disliked.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "One time I went out.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "There, there were three or four movies were in Radom-- five movies, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "We couldn't go to certain movies.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't go because they wouldn't let Jews in.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't go to certain stores.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't go to a certain bank.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "We couldn't go certain sections where they-- of the church.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "We couldn't go to certain streets-- if there was a lot of non-Jewish people live, you know.",
      "word_count": 17
    }
  ],
