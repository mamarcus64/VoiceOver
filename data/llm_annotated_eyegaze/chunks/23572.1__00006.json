{
  "stem": "23572.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I don't even know my grandfather on my mother's side.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "But his name was Yehuda.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we met there.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I was too young to remember him.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Then later on, we went over to Washkovitz, and I met my maternal grandfather and his second wife.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "What were their names?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Oh, his name was Gershon, and he was-- I really don't know what he did for a living.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "But I know one thing.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He was inseparable from what's called the Vishnitzer Rebbe.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And as a matter of fact, somehow, we were distant, distant cousins to the Vishnitzer Rebbe.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Can you tell me about him a little bit?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "What, the Vishnitzer Rebbe?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "The Vishnitzer Rebbe was one of the great wonder rabbis of its time.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I remember one year, mother took us to Karlsbad.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Later on, you'll see that picture of him with the Vishnitzer Rebbe.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Karlsbad and Marienbad were two of those resorts where the Jews from Eastern Europe used to go.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "It was in Czechoslovakia, up in what's called the Sudetenland.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Later on, it became part of Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And they used to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And you had to go to see a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "He prescribed.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "You told him what ached you, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "In those days, everybody had some kind of aches.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And he used to prescribe certain drinks.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "They had these health spas.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "Certain wells.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "I once tasted it, and I don't want to say on camera what it tasted.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So one day, we came there.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And she wanted the rabbi, the wonder rabbi to bless us children, the boys.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I forget.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "She could hardly talk to him because the wonder rabbi doesn't talk to women.",
      "word_count": 14
    }
  ],
