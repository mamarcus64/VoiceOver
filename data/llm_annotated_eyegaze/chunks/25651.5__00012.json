  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "They were very daring boys.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And inside the room where we were about 30 boys, we made a sort of kernel of six.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And I was in this together with [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "But he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "This fella, [INAUDIBLE], he walked a little bit effeminate.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "He wasn't effeminate, but he sort of walked a little bit effeminate.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And he was terribly courageous.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And they went for potatoes sort of every week.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "And I was itching, you know, to go with them.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "I had been out with them once.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "We had to climb out from-- over this fence, go past the kommandantur onto the walls, and then, with a rope, down into the potato store.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And, I mean, two pounds of potatoes, perhaps a kilo, you would-- you'd be able to carry, because we had to climb fences.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 4 SECONDS] [INAUDIBLE] and [INAUDIBLE] survived the war in Theresienstadt.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "I don't know what Proteczia they had.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "And they both went to Venezuela, and they got killed robbing a bank.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "They got shot robbing a bank.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "Now, somehow they kept on organizing.",
      "word_count": 6
    }
  ],
