  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "That was the second miracle.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And my mother helped me with child and with the household.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And I could work.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "My husband was still not very good at work.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "But shortly before the war break out, we were lucky.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Our lift arrived from Vienna with the furniture.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "With the furniture, and he took-- he found someone with money, an attorney, and he opened some storage place.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And [INAUDIBLE] came all our furniture in.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And we sold our complete household, whatever there was.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "There was very costly furniture, antique furniture, and the most beautiful carpets.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And we sold everything.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And that started, you see.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "That gave us some money.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And we felt a little bit more secure.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And we needed money, because-- this is, speak of furniture, the only piece I kept, because it was from my grandmother.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "That was the only piece.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "And everything else was sold.",
      "word_count": 5
    }
  ],
