  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And in 1950, [PAUSES FOR 5 SECONDS] we went to Czechoslovakia thinking that from then on, we will find a way to get out because there was a, a-- I have to look for the English words for a lot of things.",
      "word_count": 42
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "There, there was like a-- like a, a group of people who helping out-- HIAS.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "It's called HIAS.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And by the time we got there, the HIAS couldn't take us any more people.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So we had to look for somebody who was taking us through the borders to Austria.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And we find a fellow who will take us at night.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "My son was three years old, and we had to go to-- from, from-- [? leave ?] where my husband taking us.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "He was called up-- excuse me, I have to go back to this.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "He was called up to be a soldier because if he consider himself a Czechoslovakian, he said compulsory to go to the army.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And he-- of course, he didn't want to go the army, so we, we went to Bratislava, which is the capital city of Slovakia, and we tried to find a way out.",
      "word_count": 32
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And he found a man who could take us out-- of course for money-- and we had to wait until a group of people got together.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And at night, we started on foot from Bratislava to Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] And [PAUSES FOR 3 SECONDS] of course it was very hard to keep a child quiet.",
      "word_count": 20
    }
  ],
