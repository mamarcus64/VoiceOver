{
  "stem": "8947.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "She didn't take the trouble to take my braids down.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "But she put the shields right into my hair.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And I was pleading, please leave me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "And I will never forget-- please leave me a little hair.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "Please leave me a little hair.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "And she shaved all, and then she pulled it, you know, so parts of it that strips were left.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "And the others-- I mean, it-- it was a terrible experience.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "And then I was so shocked, you know, I just felt a little kind of a little dull sound, as my whole crown of hair, you know, fell on the ground.",
      "word_count": 31
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "I looked back and I said, Magda, this is a nightmare.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "It couldn't happen.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "I was in a-- I couldn't even cry.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "I was shocked.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And then as I was standing, I feel a sharp pain in my back, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "One of the guards hit me because I didn't go now fast to the shower room.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And then you were pushed in the shower room.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Do you think you can take a shower, all the while all you hear is out, out.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "You can hardly get a little water, and you are chased away from that shower room.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And then you go into the dressing room.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Now the dressing-- see, all our good clothing were taken away, and what we got were the rags, you know, the-- the worst clothing.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And if you want to know what I get, are you interested, how I came out from this room?",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I got a dark blue dress, long, I was very lucky.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "God was with me that it was up to my ankles, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Because it was cold there at the roll call every morning.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And I-- we didn't get any underwear.",
      "word_count": 7
    }
  ],
