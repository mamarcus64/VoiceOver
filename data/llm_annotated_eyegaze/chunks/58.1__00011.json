  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "When we came into the Warsaw Ghetto, we were already beaten, like downtrodden, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "And we came into the ghetto, you saw already people dying in the street.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "It was not a nice picture, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 37,
      "text": "If you put half a million people in the ghetto, and you don't give them-- people that went to work, they took Kommandos.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 38,
      "text": "They're called the Kommando, they took 200 people.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 39,
      "text": "They marched them out, so at least they got food where they worked on the airfield, building airfields, and unloading on the train loads, you know, with ammunition.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 40,
      "text": "All kind of things.",
      "word_count": 4
    }
  ],
