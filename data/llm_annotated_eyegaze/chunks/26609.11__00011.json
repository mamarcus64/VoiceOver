  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "And a few people with me came in.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "It was a little-- a little room, half of this one.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "And inside were a few hundred people, women only.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "And they were all standing.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "There was no room to sit down or lay down.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 14,
      "text": "We were all standing.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "One supported the other one, back to back.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "That's how we stood there, for half a year.",
      "word_count": 9
    }
  ],
