{
  "stem": "12674.7",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "And when they called my boss for references, he says, yeah, she's very smart.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 36,
      "text": "But you can't depend on her.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 37,
      "text": "If she doesn't feel like coming in, she doesn't show up.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 38,
      "text": "Because he-- he didn't want to lose me.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 39,
      "text": "Because I was running the whole show.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 40,
      "text": "I was-- I was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 41,
      "text": "As soon as I found out, I went in and I said, I quit.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 42,
      "text": "He says, I'll never give you another reference again.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 43,
      "text": "I said, what you did to me-- he says-- you know, I asked him for a raise.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 44,
      "text": "He says, this is not a profit-making corporation.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 45,
      "text": "I says, well I am not a charitable institution.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 46,
      "text": "I can't work for nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 47,
      "text": "Anyway, any-- so when I found out that he had done this to me, I just-- he says-- he says, never mind.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 48,
      "text": "He says, I'll never give you another reference.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 49,
      "text": "I says, nobody's ever going to ask you.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 50,
      "text": "You're going to disappear from the face of the earth.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 51,
      "text": "And I went out right then, at 11:30.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 52,
      "text": "And I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 53,
      "text": "And I said, I'm going out now for a while.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 54,
      "text": "And I'm going to come back.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 55,
      "text": "And then I'm going to take my things and I'm going to go home.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 56,
      "text": "He says, think about it.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 57,
      "text": "Go out for an hour.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 58,
      "text": "Think about it.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 59,
      "text": "I-- I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 60,
      "text": "And I thought about it.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 61,
      "text": "And when I went in, I said, goodbye.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 62,
      "text": "And I walked out just like that.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 63,
      "text": "And I walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 64,
      "text": "And I found myself another job.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 65,
      "text": "And that was a good one.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 66,
      "text": "I went to-- to an architect's office.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I-- I went to an architect's office.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And there I was the head of the-- I was the office manager.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I did contracts and everything.",
      "word_count": 6
    }
  ],
