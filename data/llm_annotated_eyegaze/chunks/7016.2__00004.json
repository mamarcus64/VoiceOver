{
  "stem": "7016.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.5,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "We have to wear all the time the shoes, because in the morning you couldn't put back.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "They were so wet and swollen.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "So then I-- we worked and still got really cold.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "You cannot work frozen.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "You cannot work in the water.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "Then they give me another job.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "Uh, stones.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "We have to schlep stones from one place to the other place.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "We have to-- they didn't need that work.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "Just to torture us, to show that we working.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "[SIGHS] And this was the jobs.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "And I got sick.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "And every day with the-- with the malaria.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "This was-- this was a torture.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And then one time I get um-- my leg got swollen.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My left, uh, leg got swollen, and I couldn't walk no more to work.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And, um, you're afraid to say to somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Just, I fainted.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And they took me on a [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "A [NON-ENGLISH] is like a little hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And then-- then came like a-- she was a Jewish couple.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And she knows me from Sosnowiec.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And she came in that hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And she saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "She said to me, you know, if you're not going out from that tomorrow, they're coming and closing up everybody to the gas chamber.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And I said, you see my leg.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "It's swollen.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "You know, the past is coming.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "And she said, I'm going to talk to-- to the block, to the-- from the-- from the hospital.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "She should let you out.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "It doesn't matter how you're going to feel.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "You have to go out.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And she talked to her and she let me out.",
      "word_count": 10
    }
  ],
