{
  "stem": "16958.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "And I lie down.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "I didn't see nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "I lie down.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "One in the bag.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Second.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Filled up a full bag with ducks.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Grab it.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And we run to the cave.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "He come into the cave.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We touch those ducks.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "They were so skinny, it was only feathers.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "What shall we do with them?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Wait a second.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "We made a little place for them.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "We brought in from outside some hay.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "We put them there.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And there was already corn on the field.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And we fed them, you know, force-- how they call it?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "Force feeding.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Force feeding.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We were feeding.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And before Rosh Hashanah, we had the ducks.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have a [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My brother was a good [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And we-- we had-- it was about 15 ducks.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "All the families divided, and we had a-- we had a [POLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "How you call it, that fat.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And we cook-- we cook potatoes, and we cook the-- and it was-- so this was a very good-- a good job.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Then later on, come fall.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "He says, you know, we never had a little bit jam for year-- for a long time.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "How can we make some jam?",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So we know that's a one place there-- the-- those sugar beets.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "White sugar beets are going there always.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "So it was a meeting.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "A board meeting.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] I talk to my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "We are going-- going to go for those beets.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My brother Sam with Karl, they going to go for apples in the forest.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And-- and there-- there's a-- a guy that he has very good apples.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And at night, about 11 o'clock, two bag.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I take two bags.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "The shovel, with my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And we go.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And we had to cross a main road.",
      "word_count": 8
    }
  ],
