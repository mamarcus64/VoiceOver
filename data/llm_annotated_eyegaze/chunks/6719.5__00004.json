{
  "stem": "6719.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So, we are given, uh, uh, short straps of leather straps.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And some of the-- the guys got the iron hooks down there that are bent with a point down there.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And we're told to take the Jew bastards out.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And we had this odor, and you start to cough.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "They had gas masks on.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "We start to cough.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "It was like, uh, uh, [FRENCH], something like that, or-- or mustard or-- a horrible smell.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And-- and that sight, don't even ask.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "You see bodies that were-- [PAUSES FOR 3 SECONDS] some people had their-- their-- their fingers in somebody else's eye socket.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "You saw, uh, usually, uh, children on the very bottom, and you have people on top of them.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And then you see stronger people on the top, as-- as if if they would gasp for air down there.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And we had to drag them out, which we did.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Then we got hoses.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We had to wash them off, and we had to wash off the room.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "It took us almost until about, oh, 3:00, 4:00 in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And then there were some trolleys down there where we had to put them.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And then these trolleys went up to the ovens.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And then we didn't-- we didn't cremate anything.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And we were wet, and dirty, and filthy, and coughing like hell.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I should have gotten lung cancer down there.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And we went back to the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "I'm an amateur photographer, that's my hobby.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "If I ever wanted a camera, I wanted to have a camera, not to take to the dead people in the crematorium.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "I wanted to have a camera to put on the people that saw us when we was-- when we w-- w-- went to our barracks.",
      "word_count": 25
    }
  ],
