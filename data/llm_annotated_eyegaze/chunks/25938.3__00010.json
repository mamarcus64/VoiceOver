{
  "stem": "25938.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 14,
      "text": "I don't understand why people-- no one-- no one was around there.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 15,
      "text": "During that night-- during that night, my brother, again, went to that kapo.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Kaminski.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Trying after so many years, still.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Still.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "So he-- and he cancelled.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "He-- that-- he took me out from the-- from the block seven to block eight.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "That was semi-- semi-death block.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "Where would I would get a chance to-- to live?",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "The block seven, there was no [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "From there, they were taken to the crematorium.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "Over there, we have a few months lying there.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "And they-- they-- they cured me.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "That Kaminski came and said to the people-- to doctors, in Polish, you must-- you must save me this man.",
      "word_count": 20
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "He is a friend of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 13,
      "text": "I want to save that man.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 14,
      "text": "And they-- and they took care of me there.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 15,
      "text": "They bandaged and all this.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 16,
      "text": "And my brother used to bring me food sometimes.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 17,
      "text": "I was there in that camp.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 18,
      "text": "That was-- after that, when I became stronger, then I-- I joined the movement.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 19,
      "text": "But at that time, I was a Muselmann.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 20,
      "text": "I was-- I was a candidate-- a candidate for the crematorium.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I saw just from far.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I was working-- we were working at the crematories, a huge building.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And we see from-- we see that-- that chimney, the-- the smoke.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And we saw the people going.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "We saw people every day, every day, hundreds, thousands upon thousands marching to death.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "Marching, marching, marching.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Men and women.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And where they-- people saying in Polish, [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "They were going to the crematories.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And the way to the crematory.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "They wave to us.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "They said, take care of yourself.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "In Polish, [SPEAKING POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "They speak in Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "I can't forget that.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "Take care.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 11,
      "text": "Take care, brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 12,
      "text": "Take care.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
