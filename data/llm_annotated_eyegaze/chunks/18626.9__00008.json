{
  "stem": "18626.9",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The German doctors, I was a little at-- I had a little fear, but were all the time together with the Jewish doctor.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And I personally knew the Jewish doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He was from my country, Lithuanian.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And he was one of the biggest doctors, Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Berman. ?] He was the personal doctor to the Lithuanian president, Antanas Smetona.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And he was the personal president to the, to that president from Lithuania.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "Berman ?] knew me personal, because when I was in the camp, I was sick.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And they couldn't help me, when I got my pleurisy, pleurisy in the camp.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And he was as a doctor in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And he came to me in the barrack and he says, Moshe, I don't have no medicine.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "I don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "I cannot help you.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "In Lithuania, in Lithuania, I would have known what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "But here, I can give you only a pyramidon.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "Pyramidon is like a aspirin.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "I feel sorry, he says, maybe God will help you.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "And when I was liberated and he saw me, he couldn't believe it, that I was alive after being so-- with such a high fever.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "You see, like in a, like in the United States, 104, 105 in the old thermometer.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "You know, your pain is like 43 or 44 so.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "My brother was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Then after we're liberated, he were all the time with me.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Only he was not with me when I was in the German hospital in Schwabing.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So he was already in St.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Ottelien.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So when I came out from Schwabing and I went to St.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Ottelien, we stayed in that hospital one year.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I was in St.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Ottelien, taken care by the nuns and the Jewish doctors.",
      "word_count": 10
    }
  ],
