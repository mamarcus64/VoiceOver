  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And she left.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "She went to her seat.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "It didn't take long.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "This Rabinovitch-- the Jew which I mentioned left with us-- did come to my place and said, Toivi, I need $10.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "Because [NON-ENGLISH] the guide, want more money.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "Otherwise he's leaving us.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So I told him, all right, we know we're in trouble, because she just point at you that you are Jewish.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "There's a woman who recognized you.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And now you come to me.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And I'm in trouble.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "We must do something.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So he was thinking, what should we do?",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "He said, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "The next station, we are leaving.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And we will go to the-- change the wagons.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "We're going to change the tape now.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
