    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "But my brother was getting married while I was in the Air Force.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And he want to know if I would give him my half.",
