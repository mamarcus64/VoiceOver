    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I said, sure, you can have  my half.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "But it took so long for them to pay out the money that by the time they paid I was discharged from the Air Force.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I had absolutely no money.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "I had no clothing.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "So I used the money to buy clothing for me.",
      "word_count": 10
    }
