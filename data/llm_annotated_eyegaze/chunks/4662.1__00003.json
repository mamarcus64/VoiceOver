{
  "stem": "4662.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I give-- that same advice, I give to my children and to my grandchildren.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother-- my father had nothing to do with the children.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "He just worked and brought in a salary.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "You know how it was in those days.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "The man worked and the woman worked in the home.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And he got, he got his pocket money for cigarettes, and that was it.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "That was enough for him.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My mother paid all the bills, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Acrobatic and ballet.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes, quite a long time, but my father was a very, very old fashioned man.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was never allowed to take a job on the stage.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "He just wanted me to learn, because I wanted to learn that.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "But he would never let me take a job.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "He was against it, because he was-- he saw what was going on in the arts world, like it is today.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "It's worse today than it was then.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Because he always used to say, if you want to get on in the film business or in the stage business, you have to go to bed the director.",
      "word_count": 29
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And that was the case then as well.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "That's the only way to get on there.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Really, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "But I used to do it for friends, and you know, parties friends gave, and things like that.",
      "word_count": 18
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "I used to do it privately.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "He didn't mind about that.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I had a lot-- we had lots of friends.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "But I was never allowed out alone with friends.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I was taken to a party, I was taken back from a party.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Well, mostly, but a lot of my friends were much freer than I was.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I was the Prisoner of Zenda.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "My brothers used to call me that.",
      "word_count": 7
    }
  ],
