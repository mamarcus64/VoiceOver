{
  "stem": "18474.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I had a little Ukrainian girl picking the potatoes up-- going in back on me.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "If there's any potatoes, she used to pick them up.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And-- [CLEARS THROAT] --I see-- and this was near the roads, crossroads-- the road goes into [POLISH]-- three trucks with Ukrainian police, probably Germans, too, I couldn't see it, singing away, driving up to there, to that Jewish town.",
      "word_count": 39
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "The little girl comes over to me and says-- they called me fuhrer.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "You know, everybody know what the name [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I gave myself the name [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't call myself Moshe, so-called myself [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE], says to me, the Ukrainian, you see they're going to kill all the Jews today in [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Come on, I'm going to get some stuff there.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "You don't have no shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "You could use some shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "I say, oh, to hell with the Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "I don't want to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Sure enough, she left me on the field and she went away to [INAUDIBLE] and later in the day, she came back with two big bundles of clothes and shoes.",
      "word_count": 30
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And she was making fun of me, I'm stupid.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "You didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "You could have gotten so much stuff there.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "They killed off all the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "And that's the way it was.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "And later on, I was plowing a different spot--",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Go ahead.",
      "word_count": 2
    }
  ],
