{
  "stem": "471.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "Well here, maybe you can steal a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 12,
      "text": "Or here, maybe this.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 13,
      "text": "But it was all done in Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 14,
      "text": "But I learn, I learn.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 15,
      "text": "I learn.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 16,
      "text": "I learn the hard way.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't understand.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't understand any other.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "To cheder, I don't want to go to cheder.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "My mother couldn't do nothing with me.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Because I tell you the truth, I remember like today-- you-- you know, like here, you have to be Bar Mitzvah.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I don't want to-- I don't want to talk about.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "So my mother took me by hand.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And she took me, to sign me up for the cheder.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And over there, you have to pay for that.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And believe you me, it cost-- everything was cost-- costly.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Well, it was costly.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "Because we were-- we were average.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I mean, we were not big, not rich.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "But we were not poor.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "So my mother pay me for a whole month.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And after a month, she goes and find out how I'm doing.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "They propose to prepare me for the Bar Mitzvah.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "So the rabbi ask him, who is he?",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "How he look?",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "I never saw him in my life.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "So I got home.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "I-- I-- I got it from my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "My father never hit us.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "He was a good friend.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "My mother, that was the power.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 11,
      "text": "She wear the pants, let's put it this way.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 12,
      "text": "So she spanked you?",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Oh, and how-- spanked?",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Not with her bare hand, I got news for you--",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "--what good.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], I don't know how you call that.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, yeah, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Well, then I escape.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I was hiding.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I don't want to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I go on strike.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "So my mother send out my brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Hey, go look for him.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "The guy going to starve-- starve somewhere.",
      "word_count": 7
    }
  ],
