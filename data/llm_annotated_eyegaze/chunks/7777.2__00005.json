{
  "stem": "7777.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] They sent the people to work.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Here's the deal, you work in different places.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "One day they send you here.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "One day they send you here.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "On the one day, they send me to work construction, that building.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And they make, the-- the man what he was managing over there, they make a gypsy.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "This was for me very hard to take when a gypsy tell me what to do, and it was very hard work.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "I was not be able-- as I was thinking, anyway I will get killed.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "I will not go back to work.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "I come for lunch.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "We come home.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "The Judenrat give us lunch, and I will not go back to work.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And I went-- and I went out.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I come home, and I told my-- I live over there by [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I was living there.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "And I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was not home.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Two police come to look for me.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I said, I know what is-- if they was be catching me home, they was be killing me.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Only I was not home.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "The other-- the other day, I went to the Judenrat.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "You cannot stay home.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "They send me to work.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We worked and make-- I should say they make a-- a street.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "What they putting the Jews to work with the stones, heavy stones.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "This was-- the street was-- everybody was crying about this work, everybody.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "What can you do?",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "You have to work.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Well, we worked over there, I don't know, for how long.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Not too long, not too long.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And-- and it was a Friday, the 18th of August, 1941.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Is when we were in the Judenrat, it comes over a guy from the police.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "His name was [INAUDIBLE].",
      "word_count": 4
    }
  ],
