{
  "stem": "18865.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was-- if-- I felt like a stone, like there was no-- nothing inside of me.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I just said goodbye to everything I ever knew.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I said goodbye to-- to not only the people, but all the things, all the-- all my possessions, everything was left-- it was behind me, my whole life.",
      "word_count": 28
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My previous life was-- I had no idea what was going to happen.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I went to a country that-- where I didn't speak their language.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "They didn't speak my language.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "I left with 5 marks or 10 marks or something in my pocket.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I had no money.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And I had-- I was on my own, completely.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "But I do remember the-- when I heard-- when I was in Holland, this enormous-- this deep breath that I'm free now.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "My-- I have a new life starting, and I'll do the best I can.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "England?",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was picked up by the-- it was a farm.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I didn't even know exactly where I was going.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And there I sat with 11 suitcases around me.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My mother sent the-- she had the-- everything had to be washed, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "The-- the-- everything was wet, and-- and so my mother had all the-- all the table cloth and linens.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And she gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "She said, that will be for your dowry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "At least you will have that out.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "So my suitcases were all packed.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And there I sat with 11 suitcases.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And the farmer came, Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Sanderson came, stood there, and said which one is yours?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And I said, all of them.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He almost-- well, he was very surprised.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "He said, I have a little Ford two seater.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "There's just enough room for one suitcase in the back.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And so we had to rent a-- a truck.",
      "word_count": 9
    }
  ],
