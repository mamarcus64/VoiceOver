{
  "stem": "21919.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Fela Stern.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "F-E-L-A S-T-E-R-N.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "S-- well, I wasn't married then.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "So I didn't have that name when I lived in Poland",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was single.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Rojzenman.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "R-O-J-Z-E-N-M-A.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "A city called Wlodzimierz.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Volynsk, That's the province.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was born March the 18th, 1927.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Dov Rojzenman.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They call him Beryl in Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was Bella Rojzenman.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Her-- her name-- her maiden name was Frost.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I had two bubbes and two zaydas.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "One of them died before the war in '38.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "She died of cancer.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "My zayda was still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father's parents.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My mother's parents were-- my zayda was in Warsaw coming home.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They killed him on the border, [PAUSES FOR 3 SECONDS] apparently, according to people who knew.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And they humiliated him.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "He had a beard, and he was accosted.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "They were cutting his beard and-- and throwing things at him before they killed him.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "But-- we were no witness to that one.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1940.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My bubbe died with my mother and my siblings in first ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I had one sister, who was three years old.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And my little brother was born in ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He was just a couple of months old.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Tziril, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She was named after my father's mother who was in Jewish, [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "A lot of time.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "It was just a-- a two-room apartment they were renting.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And it had a big porch.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS] My grandparents from my father's side had a four-plex, which was four entrances into the house.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Each-- they were renting three of them.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And they lived in one.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Each one had a separate entrance from south, west, north, and east.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And there was a yard.",
      "word_count": 5
    }
  ],
