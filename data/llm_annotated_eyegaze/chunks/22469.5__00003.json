  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "One day, they didn't let us in because we were in factory, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "On the-- rooms-- rooms-- rooms, big rooms, they didn't let us in.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They took every clothes from us, groups.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They put in high [INAUDIBLE] oven-- steam.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And they-- they damaged every lice, everything that was possible.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And they went shower for us.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Hair, everything, up-- and it was everything.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "We come upstairs-- new beds, new blankets, new mattress, everything new.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "This was good.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Now, the privilege every day was a shower.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "The privilege was maybe 10 people to get-- I was [INAUDIBLE] have a beautiful shower.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] So it was doctors, and we have never saw lice anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Downstairs, I had my workshop.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "This was [? red ?] [? pine ?] and green powder.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Between the powder, I had tobacco, a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I was during-- working during the day.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And in the night, [INAUDIBLE] other people.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "When I came in the morning, [PAUSES FOR 3 SECONDS] somebody told me, you know, [INAUDIBLE] he want [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "He was looking in new cases about this.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And I-- I saw and they steal me some.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And I knew who is the [INAUDIBLE] one.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And somebody told me about [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I hit him.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I beat him, honest.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And not because he [? steal ?] me-- the people told me he came from Tarnow, what is another town.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Did you hear about Tarnow?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And he was after the Jews, gone.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "They were looking for Jews where they're hiding.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And they shot them, everyone.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He was agent for gestapo.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] And I hit him.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And director-- I said, director-- director listen.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "This is ?] [? an agent. ?]",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "This was [INAUDIBLE], you know?",
      "word_count": 5
    }
  ],
