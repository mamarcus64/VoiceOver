  "model": "openai/gpt-oss-120b",
  "elapsed_s": 81.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "And my mother give me lunch-- a piece of bread with not butter, but it was very expensive, margarine.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "And an apple.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "This was my lunch.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And when I came home, we eat dinner.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "And this is the way it was, my children's life.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "[PAUSES FOR 3 SECONDS] My second brother's name was Leopold.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "He was born 1923.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "And my third brother name was [?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "Emanuel, ?] and he was born two years later, 1925.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "My fourth brother was Chaim.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "He was born 1927.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "And my fifth brother was born 1929, I think, or 1920-- no, 1931.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "His name was Hersh Joseph.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He got his name from my mother's father, and mother father was a rabbi.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And he passed away in this particular year when my youngest brother was born, and he got the name.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "This is the way we give the names, from people, from family, to remember what's going on in the past.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Their birthday?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the bris!",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "A bris?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we have got the party in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We bring a mohel-- mohel, they calling it mohel, and the person which is a professional.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And you have a special cutting knife.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And what he doing is, uh-- they holding the penis and they cut it off, a certain part of the skin only.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They don't cut off the penis.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "A lot of people don't understand maybe what is going on in the Jewish religion.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "The skin-- they took off-- they picked up the skin from the penis, and they cut off a piece from the skin.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "The reason is, what you do that, and in 100 years before that, the people were sick from this particular item, because they cover up the penis, and they couldn't-- they are not breathing inside.",
      "word_count": 35
    }
  ],
