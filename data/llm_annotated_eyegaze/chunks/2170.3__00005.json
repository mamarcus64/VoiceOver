{
  "stem": "2170.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I saw the SS men coming from Brailov and looking at the ghetto, just looking like the wolves.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "How can they kill them, too?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But they couldn't because it was a Romanian authority.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But they were looking for my brother-in-law and my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "But mostly for my brother-in-law because he lied that he's going to come back.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] Couple weeks later comes a order from the Judenrat, Dr.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Herschmann, that all the Jews-- that was the night before.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He knew what's going to happen, but he did not tell nobody.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But he told to some people that tomorrow morning, you're going to be waking up.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "You'll be coming in the-- in the center of the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And what's going to happen, he didn't say.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "He did not say nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "We did not know anything, I mean, my family-- nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "That night, my sister, Hannah, slept with her girlfriend in another building there.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And I was with my mother and my other sister and my brothers.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "In the morning at 6 o'clock, in Jewish actually, it's-- was [NON-ENGLISH SPEECH], it's in July-- 18 days in [NON-ENGLISH SPEECH].",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "It was on a Friday in July.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And it was-- a matter of fact, my mother didn't know.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "She was very, very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And she didn't eat that time because it was [NON-ENGLISH SPEECH].",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "That was before Tisha B'Av.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "You fast when there was destruction of the temple in Jerusalem.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And she didn't eat that day until-- I remember it was a summer day.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "It was 10:00, after 11:00-- 11 o'clock because it's not dark enough.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "She didn't want to eat until so late.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "In the morning, when the Jewish police came knocking the door-- and they told us to go out.",
      "word_count": 18
    }
  ],
