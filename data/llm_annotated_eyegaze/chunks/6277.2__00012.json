  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "You don't have-- we had to stay-- to stay up anyway in the-- early in the morning, to begin to work.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't have to go you know, from one and the other side.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "So it-- it was a little better than to be in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Not with my uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I went in the ghetto later, when they took us already.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "In 19-- in 19-- 1943, in spring, they took us-- in the beginning of 1943, they took us to the ghetto, back.",
      "word_count": 22
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And then they began to send us to the peat bogs.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "We called it [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And then we-- there we spend the whole summer working there.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In the peat bogs, in [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS]",
      "word_count": 1
    }
  ],
