  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And my parents had decided that they would try to escape to Wilno, which was a town taken over at the time by Lithuania.",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Should I explain how it happened?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "When the war started, as you know, there had been a nonaggression treaty between Germany and Russia.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And around the middle of September, while Hitler was occupying the Western part of Poland, Russia came into the eastern part and ceded a part of Poland-- the northeastern corner-- to Lithuania.",
      "word_count": 32
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "It had always been a kind of disputed territory.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And Wilno, the biggest city-- which I believe is now the capital, as a matter of fact, of Lithuania-- was taken over by Lithuania.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "From Lithuania, it was possible to escape from Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And in fact, one of my uncles and one of my aunts made it, but we didn't.",
      "word_count": 17
    }
  ],
