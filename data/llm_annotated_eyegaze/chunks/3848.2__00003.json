  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] The station used to get so crowded that whoever found a spot to lie on the floor took it early enough.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "The rest of the people, because it was cold at night, and whoever could get in there, they were standing one behind the other, just leaning on each other and with their legs spread just to stay over the night.",
      "word_count": 40
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Food was very scarce, couldn't get food.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And there was [NON-ENGLISH], they call it, water.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They were boiling hot water for people to drink at the station.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the bread, they used to [? give ?] if you had some kind of a document to show, they used to give you a couple of grams of bread for the day, whoever could get into the line.",
      "word_count": 39
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And that's how you existed.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I decided, we were still about five people from the railroad, and I had my uniforms-- I was pretty dirty-- and I decided to go and see the chief of the railroad in Tashkent.",
      "word_count": 34
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "It was called [SPEAKING RUSSIAN] in Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "When I saw him, i-- I made an appointment.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I went up to his office, and I said, we have five people that were just separated from the group of the railroad people in Ukraine somewheres in-- in-- in Moscow.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And we're here for him to give us some work.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Lucky, he decided to send us to a-- a factory, a railroad factory, which was in Tashkent.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "It was called [RUSSIAN].",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And all five of us were working in this factory on the railroad for nine months.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "We were registered in the city.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "I worked as a machinist at one of the factories where they were making railroad ties.",
      "word_count": 16
    }
  ],
