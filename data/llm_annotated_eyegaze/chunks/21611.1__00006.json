{
  "stem": "21611.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So people got burnt to death, and the next day, they took them in wagons to bury them-- the ashes.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The Ukrainian took the ashes.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "But they took-- but they took the leaders from the community out?",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They took the leaders, definitely.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The leaders were the first ones to go.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We already didn't celebrate.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We knew what's coming.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We knew already.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Because we were locked in, and we knew there was graves.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "People talked, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "We knew there was three graves for us, so we knew.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And this was-- and in '42, Yom Kippur was on a Monday-- that I'll never forget-- and two days after, on Wednesday, was the killing.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They made [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "This means no Jews anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I was in the ghetto, and I was outside the ghetto because I was a shepherd.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And I was [INTERPOSING VOICES] with a very nice couple a few kilometers, not far from our-- from our city.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And this was a couple-- they didn't have children, and they liked me very much.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And he was a native, a German native, but he was the most wonderful human being.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Heinrich Elko.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And his wife was a Polish, Baginska.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "She came from a very-- and they really wanted me as their daughter, because I was a very friendly-- very friendly, and I didn't look Jewish at all.",
      "word_count": 28
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Even Jewish people couldn't tell that I'm Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So I used to commute.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I used to be there, and them to come to the ghetto to see my mother, see my brother, and see the rest of them, and then I used to go back.",
      "word_count": 32
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You had permission to leave the ghetto to work for them?",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They took me out.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They used to come and take me.",
      "word_count": 7
    }
  ],
