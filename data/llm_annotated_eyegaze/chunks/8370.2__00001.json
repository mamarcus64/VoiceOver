{
  "stem": "8370.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.8,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I remember-- I don't want to mention other nation who, knowing what's going on and why the selection was, was obvious, gave their child to a mother, to the grandmother, to save their life, condemning the child.",
      "word_count": 37
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Well, this was sad.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "But this was-- you see, everybody want to survive.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "I remember a story-- this, I will not repeat this what I told before about the two children burned live in the ditch.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "But I remember a story when I was still in the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And there was a selection done by Mengele, personally by him.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "And there arrived the trucks.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "It was winter, cold.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And the people who have been condemned to gas chamber had only really nothing on.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "Or they have been naked or in their white shirts, you know, looking like phantom.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "They had been loaded on the trucks and the trucks turning from the camp, from the hospital camp afterwards-- it was a hospital camp-- to the left, to the crematorium four and five that was there.",
      "word_count": 36
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And there was one Jew, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "It was probably a cantor from a synagogue with a very good, strong voice.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "He was a Austrian Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "And he was standing on the truck, despite the wind, you know, and cold.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "And he sung [SPEAKING GERMAN] all the way around from the hospital to the crematorium to the gas chamber.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "And since this time when I heard this song, you know, I see him standing on almost over half a [INAUDIBLE] higher than the others.",
      "word_count": 25
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "The others had been put down, you know, because it was cold and wind.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "And he was standing proud, singing this [SPEAKING GERMAN].",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "Well, I had a chance two or three times to save some people.",
      "word_count": 13
    }
  ],
