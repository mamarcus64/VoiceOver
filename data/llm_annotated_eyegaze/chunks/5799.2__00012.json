  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So I immediately looked.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You were not allowed to walk with the sidewalk.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "You had to walk with a-- with the street.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And you were not allowed to look at the German.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "You had to keep your head down But it shows you what bashert means-- what's meant to be.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "There was one killer who used to go out in the morning, and before breakfast, take his son.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And he would shoot a Jew so he would have a better appetite together with the child.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And one time, I see shining boots near me.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And I picked up the head.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Lo and behold it was this German-- forgot his name-- without the son.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I started talking to me.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I am all dirty in the rubble, working after the bombing.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I answered in German.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he says, and where did you learn German?",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I tell him, in school.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And he said he needs me.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And I-- he found me a job.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I was off the rubble.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE]",
      "word_count": 1
    }
  ],
