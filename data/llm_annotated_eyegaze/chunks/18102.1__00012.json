  "elapsed_s": 62.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "My father was one of those people that believe that little children ought to know everything that is going on around them irrespective of their age.",
      "word_count": 26
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And he would very carefully explain all events going on in the world to me.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "So I was conscious of things that maybe other kids my age weren't.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And he sat me down to explain that there was going to be turmoil, that the-- the chances were that the Germans would invade Poland, and that there would be or could be a war.",
      "word_count": 35
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I didn't understand what war meant, mind you.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "But I certainly was advised that things were going to be different.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Well, in the beginning before it happened, I didn't have any feeling about it except that I thought there would be sword fights in the streets.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I really thought the sword fights would be on the big streets, not on the street where we lived.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So I would really have to go and watch them to see who was winning.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "But certainly, I didn't think there was an impact on me personally.",
      "word_count": 12
    }
  ],
