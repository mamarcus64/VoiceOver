{
  "stem": "8002.7",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We're supposed to get shot in Pogulanka.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "That was six o'clock in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "The next-- at-- at night, they brought in trucks-- a lot of trucks.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And they put everybody in the trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And they brought us, with the trucks, to a freight train.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And they put all of us in a freight train.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "My-- me and my mother was in one freight train.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the other people was in another freight.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And they put us in like cows.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And the people said, we're going to Pogulanka.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "They-- they're going to shoot us.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "When we were riding the train, the train slowed down by the forest, when we reached-- because Pogulanka, from [?",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Dvinsk, ?] is about 25 miles-- something like that.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And there's a big curve.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And by the curve, the train slowed down.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "My mother-- there was a little window on the train, in the freight train.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "My mother says, we're going to run out from there.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And she pushed me from the window.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And after that, she went-- came out, through the window.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And then, we saw the train stopped.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And a lot of Jewish people-- I would estimate-- at that time, I was small.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "I couldn't count-- but I would estimate around 8,000 Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And they told them to take the clothes off.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "We was in the forest, about five minutes away, where that happen.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When we escaped from the train, we ran in the forest.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And then we heard all the commotion-- the noise.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "So we wanted to see.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "My mother says, let's take a look what goes on.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Then we saw the people came out from the freight train.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And there was a lot of Nazis-- German-- and a lot of [?",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Latvians-- ?] [NON-ENGLISH].",
      "word_count": 3
    }
  ],
