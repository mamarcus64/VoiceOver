{
  "stem": "10272.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we have now still a chance to go away to America, back to America.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "You don't have business here.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "The business is slow.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "My wife says, no way.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "He says, I'm not going to go back.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Now the house, the real estate is very low.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And if we go to American now, with my age, what am I going to do there?",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I don't have-- I used to go there as a young man, I used to work hard, I made money.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Now if I go to America, there is a recession over there, I read in the paper.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "Unemployment.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "What am I going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I don't have the money to go and invest in money.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "What is going to happen with all the Jews like the rabbi says?",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "That's what the rabbi said.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "What has happened with [INAUDIBLE] Israel will happen with us, too.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "We have [? to ?] trust in God.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We believe he will save us.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He will protect us.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "So we have to stay.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Well, and then I remember another episode.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Once we had a tenant in our house, and she was a German.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She was a business woman.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "She spoke German and a little Czech.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And she was dealing with-- we had a lot of wooded areas.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "They cut out all this, the trees, and [INAUDIBLE] delivering it on water through Czechoslovakia.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "There was a big river, the Tisa and the [INAUDIBLE]-- you heard about these big rivers?",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And she was the businessman who were coming and buying and dealing.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And she was living in our house and paying rent.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And sometimes we would invite her for a dinner on a Friday, on a sabbath evening.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Very nice lady.",
      "word_count": 3
    }
  ],
