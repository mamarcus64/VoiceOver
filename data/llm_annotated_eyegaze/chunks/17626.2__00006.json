{
  "stem": "17626.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And my father was interrogated for a long time, and he has some horrendous stories to tell.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "They wouldn't let him sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They would interrogate him through the night.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "They would interrogate him through the day.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "The beatings that he got, the sentencing that was-- that was a farce, pretty horrendous stories he does tell.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "None of them were.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We were so isolated from everything in the village.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We had a radio, which consisted of a plate, at the corner in the room up near the ceiling, whatever was broadcast.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "That's what you could hear.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "You had no choices.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "You had no dials.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "There was a newspaper.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "It was the Russian newspaper.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "We had no contact with other cities, no mail, nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "We didn't know what was going on in the world other than the war was going on.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "There was an army hospital in that, that village, and it was the Russians, the Russian soldiers.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The stories that we heard were the Russian stories.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "How could my father have been politically involved?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He never left the village for a minute, nobody came.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So it was just the five Jewish men, and all five of them were arrested.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "None of them came back, except for my father.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "How he survived, is sometimes-- I listen to the stories-- is beyond me.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Tell me how life continued for you and your mother.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, we lived for a little while in that little house.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "My mother was an usherette by now.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "She had graduated to an usherette in the movie house.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't a movie house as we know here.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "It was the big gathering hall with tables, and chairs, and benches, and whatever; a screen, and one of those cameras, which in the wintertime-- do I have to tell you?",
      "word_count": 31
    }
  ],
