{
  "stem": "15082.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And the reason he survived is not-- he had ran away before.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "And he joined the Russian militia [PAUSES FOR 4 SECONDS] as a young boy.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "He was in a Russian uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And he knew that his mother and dad were wiped out, and everybody.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "He was also an only child.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "And we stayed in Dubno approximately-- [PAUSES FOR 3 SECONDS] coming in there, I'd say, April, the beginning of April, the first week of April.",
      "word_count": 25
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "A lot of Jews did come, started settling in that town.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "My estimation would be that, probably, as they were kept coming, that we wound up in Dubno about 100 to 150 Jewish families.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "One of the surviving-- luckily, the rabbi from Brody, Rabbi Steinberg, Moses Steinberg, which was a very famous Hasidic family, survived.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "He was the [INAUDIBLE] Brody for years.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "He's-- he later emigrated here to America.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "And he was living on the west side.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 5 SECONDS] We cleaned out the shul in Dubno to make a back-- bring it back to some semblence.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "It was all destroyed.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "And he was like the rabbi in the community for these 150 families.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "My job was to go out once a week to collect some money so Rabbi Steinberg could live.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "I did that for the whole time that I stayed in Dubno.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "And we became very close.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "Matter of cat, when I got married here, he was the rabbi that married me.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 30,
      "text": "[PAUSES FOR 3 SECONDS] He and his wife survived.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 31,
      "text": "They had no children.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 32,
      "text": "They were a childless family.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in Dubno from 1944 in spring [PAUSES FOR 3 SECONDS] till [PAUSES FOR 3 SECONDS] probably January or February of 1945.",
      "word_count": 23
    }
  ],
