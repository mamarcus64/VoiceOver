{
  "stem": "2966.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And my name you know already.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father was a cabinet maker, but he had a-- a quite nice-sized shop of-- producing furniture, where was at least 10 to 12 people working all the time.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And there were-- everything was hand made, because there wasn't too many machines at that time.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we were quite well off.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We were not very rich, but we were not very poor.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We had quite a good life, and-- [PAUSES FOR 4 SECONDS] And things were going smooth till-- till the war started.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I went to public school [PAUSES FOR 3 SECONDS] in my part of town where we lived.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And-- and for six grades.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "From then on, I went to gymnasium, which is equivalent to high school here.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I went there for three years, and that was the balance of my education.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well we-- we really had no choice of subjects.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We had the-- that's not the system that was here.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Everybody had to take everything what the curriculum demanded.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I liked math and geography, were my two main subjects that I liked.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My goals as a schoolboy, to tell you the truth, we didn't think about these things.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The situation wasn't as materialistic as in certain different societies.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So a boy of 13 or 15 years old didn't think of his future doings.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Of course, in Poland at that time, when I was started growing up 1937, 8, and 9, the situation for the Jews were becoming very difficult.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "For a Jew to get accepted to a university was almost impossible.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "That was a-- a very difficult thing.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And anybody that was accepted to universities, their life was one life of misery because of antisemitism.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, antisemitism we experienced, and I personally experienced from a small child on.",
      "word_count": 13
    }
  ],
