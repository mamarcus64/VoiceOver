{
  "stem": "18865.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We had an aunt, a-- her husband was a cousin of my mother's, and-- but they were the very closest friends.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Very closest friends.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And she had a brother who was an American.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And they were in Chicago first, and they set it up for us.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "We sent-- she used our furniture that was sent there, and then she set up an apartment for us.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We lived in Chicago with them.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We arrived the end of May.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "In Chicago, Well, first in New York, and then we went to Chicago.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "On a ship called the-- it was the Cunard line, and it was called the Scythia.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They brought us over safely.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They went back and took on another load of refugees, and were sunk by a mine.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Nobody survived.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And we made it to America.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I remember being too-- I was totally exhausted from all the past and that this really was happening.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And on top of it, there were 150 soldiers, Canadian soldiers and sailors, on the ship.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And I had a-- really a wonderful time.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I was one of the few that didn't-- wasn't seasick.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And to see the Statue of Liberty, I think I stood out there and I said, I'm glad to meet you.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Not this euphoria, none of that.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I knew what was ahead.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "We-- I was full of-- of trepidation.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I-- when I hear people making all this-- no, I didn't have that.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "I was very calm and collected, realizing this is going to be a very different life.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I only knew that all the grownups were always so excited about it.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And it had something to do with freedom.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But I-- what did I know about freedom?",
      "word_count": 8
    }
  ],
