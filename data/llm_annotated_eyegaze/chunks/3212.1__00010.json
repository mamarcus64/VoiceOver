{
  "stem": "3212.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "He didn't eat, and he died because we left.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "Coming on to Vienna, I remember, we rented a three-bedroom apartment in Sweitenbitzirgen, the [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "I will never forget it.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "The apartment consisted of a living room, and three bedrooms, and a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "When we came to Vienna, we had already to wear a yellow star, written on it, Jude.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "We had to go to the Jewish community there.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It was, I think, in 1940.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "In 1940 we had to-- '39, '40.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Beginning '40, we had to leave our home and go to Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We had to register in the Jewish community there.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "The [GERMAN] they called it in Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We got the-- the star of David that was written on it, Jude-- Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And we looked for the apartment, and we have found the apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "But we had to move in there.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Our family, my mother, my father, brother, and me, in the other room, one room, moved in Malvin Fluss-- my brother's sister, with their three children.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My father's sister.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "In the other room was another sister-- No-- another--from my father's brother, the wife, Rosa Hacker.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And a cousin and his sister moved in, too.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "All of us, we moved in, in one apartment in Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And right on the beginning, my father on the beginning start looking for work, and found a job as a baker in a-- In a bakery.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And life was not easy.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We-- we kids, we had to go only to a Jewish school.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They had it in the 20-- in [GERMAN] in the 20 [GERMAN].",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "It was a different--",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Section of town.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We were in the second section.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "This was in the 20th section, that were only for Jewish children.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My father worked.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My mother was home.",
      "word_count": 4
    }
  ],
