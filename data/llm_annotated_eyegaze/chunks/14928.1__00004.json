{
  "stem": "14928.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "You had to put it in in a-- I don't know what they called it, like maybe you saw a masher in the drugstores that you mash something for the medication.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We had big ones made.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "My father made them.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "You put in the matzos in there, and we used to do it ourselves to make farfel, to make matzo meal.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My father used to bake matzos.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "This is when already, when I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Otherwise, somebody else was making matzos, so we got them there.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But actually my father was baking a lot of years, I remember, until-- I guess until the war broke out.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "He built a special oven, real big one, and he baked matzos for other people also.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We had a [NON-ENGLISH], which is called a [NON-ENGLISH] to bake matzos, was a [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And a lot of girls came to, to roll the matzos.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And you had to-- were very restrictions, like I remember that when they put in the flour, they had measurements, and if the girl that was pouring the water poured in a little bit more water, they had to roll it just the way it was.",
      "word_count": 46
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't add any flour.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "You couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Just the way one time.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Just put it in one time, and they kneaded it, and then-- and they-- you also couldn't put any flour on the boards where they were rolling it.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "It had to be without any flour, just the way it comes out.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "This is the way they had to roll it.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "If it was a little thinner, the dough, they made it a little heavier, the matzos, because they couldn't make it real thin.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "It would stick to the thing.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "But most of the time, it came out all right.",
      "word_count": 10
    }
  ],
