{
  "stem": "22889.8",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I'm doing it for my-- for my dad, the way I was brought up.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "I want him to-- if he's such a thing, maybe his soul's watching over me.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "Let him see me.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So, the chuppah, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So I promised my wife, when I'm going to be married 25 years to you, I'm going to make a wedding my own, the way I know.",
      "word_count": 27
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "The way my ancestor got married and everybody else.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So I had a wedding in my backyard, a chuppah and everything, a real you know, an Orthodox wedding.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I had it.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And, in the meantime-- you know?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "So, I raised my family.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I had a first child, my oldest son, six years later, after we got married.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And his name?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "His name is Michael, named after my dad, Menachem Zev.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "My father, his shalom name was Menachem Zev.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "So I named him after my dad.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He's the oldest one.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I had a nice pinyod haben.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "No, that didn't happen, because my wife was carrying a daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't have pinyod haben.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "For my grandson, I had a pinyod haben.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And six year later, we adopted my second son.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "His name is Mark, Mark Mendler.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "Mordechai Chaim.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "He's named after my wife grandfather.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "And now I have three grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "My oldest grandson is David Mendler.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "And the-- my two others-- he lives in Washington.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "My other two live in Derry, not too far from me.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "Name is Max Mendler.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "And we got a new one, about a year and half ago, Mickey Mendler.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "They're like M and M, [LAUGHTER] so name them M, M.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So here I am.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "When--",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Last year--",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Robert Mendler I become when I-- when I got my citizen papers.",
      "word_count": 12
    }
  ],
