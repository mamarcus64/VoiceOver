{
  "stem": "10839.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.3,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 7 SECONDS] They gave me the 200 mark.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 38,
      "text": "And I'm going away in the morning with the whole group.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 39,
      "text": "You went 5,000 people to work.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 40,
      "text": "And I came on the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 41,
      "text": "I'm going away from that group to my booth where I work.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 42,
      "text": "And I see a other SS man follows me.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 43,
      "text": "And the other one, I knew.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 44,
      "text": "He was the worst SS man from all SS in Markstadt.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 45,
      "text": "Because we knew each other.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 46,
      "text": "He was shooting.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 47,
      "text": "He was killing people.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 48,
      "text": "And I was thinking what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 49,
      "text": "I figured out that he got not to know that I have 200 mark for the other men for the [INAUDIBLE].",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 50,
      "text": "And I came in my room.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 51,
      "text": "I went fast.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 52,
      "text": "He was a man fast, too.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 53,
      "text": "And I was faster.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 54,
      "text": "And I came in right near the door.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 55,
      "text": "The floor was from sand.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 56,
      "text": "And I made a little hole.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 57,
      "text": "And I put in the 200 mark there.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 58,
      "text": "And I covered it up.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And he is here right away.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "In seconds, he was-- walks in.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Give me the 200 mark.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I said, who told you I have 200 marks?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Nobody gave me.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "You dream about something.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He start to hit me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "I took off my clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And he was pushing me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "He was kicking me.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "You can shoot me.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I don't have money.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Money?",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "I don't have even one penny.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "What you want from me with, with 200 mark?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "Nobody gave it to me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And I don't know what you're talking.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And he was in almost this time an hour.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And he was bothering me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "I will not walk out from [INAUDIBLE], he said to me.",
      "word_count": 11
    }
  ],
