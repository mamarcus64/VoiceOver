{
  "stem": "512.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "My sister-- [PAUSES FOR 3 SECONDS] the difference between my sister and myself was always that she had stamina, aggressiveness in her.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "I was the opposite.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "I found her, and she was always watching out for me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "I was the  older one, but she was watching out for me.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "She was always like a shadow behind me, watching over me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And then this is-- we asked the Blockfuhrer, it was called-- the girl that, you know, this happened to be a Czech girl which had been in the camp already for a long time-- where, where is the rest of the family?",
      "word_count": 42
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Where, where are my parents?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She says, did you see those big, tall chimneys outside?",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Those big, tall-- she said.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Did you see the smoke?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "We could smell, you know, like, human flesh burning.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "She says, those were your parents.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "So I said, she's so mean and such a misery.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And she tells us.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "Yet, she's, she's lying.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "It's all-- we cried, terribly.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "She's lying.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "Why is she being so mean to us?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "But those were the facts.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "So one day while we were in Auschwitz, we, we saw a band marching.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Because this was a, a women's camp that we were in, but for some reason we saw-- I don't even remember this how-- the, the men were marching and somebody shouting, anybody from Bilky?",
      "word_count": 34
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] My sisters and I said, yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "Who are you?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We recognized the father because my father wasn't that much different.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He couldn't recognize us because we've-- heads shaved off and in rags.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But we recognized him.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He says, is your brother with you?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Where's your brother?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Didn't you stay with your mother?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "No, and they said, [INAUDIBLE].",
      "word_count": 5
    }
  ],
