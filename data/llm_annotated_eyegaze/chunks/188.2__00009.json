  "elapsed_s": 259.9,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "If I remember correctly, I think my father spoke in German to him.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "It was a-- he was a child, [PAUSES FOR 3 SECONDS] and they, I guess, handed him over to the Allies.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I'm not sure.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Some of them settled down on the farm, stayed there at night.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "One very young soldier, who rode in a tank, took a great liking to my grandmother and was by her side whenever he could, and we didn't understand why at first.",
      "word_count": 31
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And then he said, she reminds me of my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And he drew a picture out of his wallet, and indeed, there was a resemblance.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And when he had to move on, when his group moved on, he had a puppy in his tank.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And he handed it to my grandmother and said, would you keep this for me?",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Because it won't survive.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was a little mongrel, which we kept for years, became our pet.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I rem--",
      "word_count": 6
    }
  ],
