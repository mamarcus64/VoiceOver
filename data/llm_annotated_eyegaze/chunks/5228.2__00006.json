{
  "stem": "5228.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I just was-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I didn't want it, more hiding.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Maybe because of my grandma, I don't know why.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, my grandma still was alive, and she was still home.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "She was close to her 80s.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Maybe she was already 80s.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Well, when they came to take her from the house, she was fighting with them.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They kicked her, the police, and everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "She was a fighter, my grandma.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And she was maybe 80 years.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She didn't want to leave from going out from the house.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Well, it didn't help.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And when they told-- they came-- I think was like after a Pesach-- they came, and they took us all.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I just put on-- I got a brand new coat, got some money and something-- a few things-- and I just put my hand in pocket, and I walked out from the house.",
      "word_count": 34
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "They took us in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They took all of in the city.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Just if somebody hides someplace.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But nobody was left more, not one Jew.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "The old and the young one, everybody was gone.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And they took us in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It was first [INAUDIBLE]-- Chust, Chust.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We was there in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "A city, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "The-- it was a city, this.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And they took us all there, and it was terrible there.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "It was old people, young people, babies, with children.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible, what-- what was in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I was staying in one room with my grandmother, yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And then the morning, we wait.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "In the morning, then we can go out from the-- not from the ghetto, from the house, from the barrack what we was there.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Then we'd go out a little, stand in outside.",
      "word_count": 9
    }
  ],
