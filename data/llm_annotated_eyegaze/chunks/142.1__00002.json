{
  "stem": "142.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And one of the-- the friends is-- was Daniel Bennahmias that later on we spent most of our lives together.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What was the Jewish community like in Salonika?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Was-- I wasn't involved too much as a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But the Jewish community of Salonika were-- before the war, the Jewish population in Salonika was close to 100,000 in 200,000 population.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It was 50%.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I remember that on Saturdays especially the port of Salonika was closed because none of the Jewish people would work.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And downtown was closed every Saturday.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "There-- there were a lot of synagogues and a lot of different other institutions that were helping the poor people of-- the Jewish poor people in Salonika.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "What about Jewish observance in your family?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "What was it like?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother was pretty good in observing the Jewish tradition.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I and my father were more liberals at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My grandparents were, you know, pretty-- pretty good.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They-- my grandparents and my mother's family were pretty religious.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Very seldom I went to the synagogue with my family.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But my mother I know used to go every-- every Saturday and especially during the Jewish holidays.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish holidays, we all went together.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We were very-- they-- they celebrate every-- every holiday, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There were so many-- so many Jewish institutions, so many things and schools and elementary schools and Jewish schools, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So it was very-- pretty good Jewish life.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My home, we used to-- to have our Jewish holidays.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My mother always saw that we were there for the Jewish holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My favorite was always Rosh Hashanah and Yom Kippur.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, these were the high holidays what everybody used to get dressed and, you know, like the old-- old time.",
      "word_count": 20
    }
  ],
