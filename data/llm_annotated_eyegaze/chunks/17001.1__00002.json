{
  "stem": "17001.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And my older sister, she was helping around the house until the situation got bad.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And then she got also a place where she was apprenticed to be a dressmaker.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Her name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Klara, ?] and she was born in '25.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And then I came next.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I used to help around the house.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "But then later on, when the situation got bad, I learned how to spin angora.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "This is like the-- we were raising the-- my brother was raising the angora, the-- the rabbit.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And he would shave the rabbit.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And also, we would buy angora from other people, because that was the big in things with the Jewish population.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And then after I was spinning it, we would color it.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And we would make-- my mother was an excellent craft or handworker, or whatever you want to call.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "She would knit.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "She would sew.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "She would crochet whatever you want.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And she would make hats for us.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "She would make gloves.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "She would make scarves.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "She would make sweaters for us.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "I mean, naturally, we were helping also.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "And sometimes I would go and help in any other way.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "Then my younger sister, Elizabeth, she was born in 1930.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "So while I was going to school, she was doing some of the chores around the house.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And she was going to school.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "Then I had my younger-- my other sister, Eva.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "She was born in '33.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "AND then my other sister, Martha, she was born in '33-- '35, I think, '35.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And she was such a cutie pie.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And-- [PAUSES FOR 8 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was my younger brother, Charlie.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] [DRINKS] He was born in '38.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] That was the seven children.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We had our own house.",
      "word_count": 5
    }
  ],
