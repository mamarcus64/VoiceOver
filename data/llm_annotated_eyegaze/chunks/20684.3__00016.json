{
  "stem": "20684.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I retained custody of my son that was looked after by my mother at the age of seven months, he was when that happened.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And we lived with Mum for a number of years until about 25 years ago I remarried to my current wife, Michelle, that had two children, also a son the same age as Peter, my son, Peter; and a son, Mark.",
      "word_count": 41
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "We also had a daughter that was two years older.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Unfortunately, our daughter died when she was 19, some blood disorder she had, a very talented girl.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "But life was cut short.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "The boys went on to Brighton Grammar, Melbourne University.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Mark finished chemical engineering, got a master in chemical engineering-- that's my wife's son and my son-- and lives now in Adelaide.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "He lectures and works for the Wine Institute in South Australia in Adelaide, lives on a farm, as well, has a lady friend, lots of sheep and cats and dogs and horses and everything else.",
      "word_count": 35
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Peter finished law, honors degree master's in law.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "He is now a consultant working for himself.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He just married recently and and his wife is also a practicing lawyer, associated in one of the large firms.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He's a consultant and he is lecturing at Melbourne University in health society occupation.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "He is not a permanent lecturer, he is what is known as a visiting lecturer.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "He's a research fellow at Melbourne University.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He has just recently written a book on the health and safety occupation with Professor [INAUDIBLE], so Rozen and [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It's been in the news quite often.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he's-- he's had a much better run than I, I think.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And so they live in Melbourne and what can I say about myself?",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I've started playing bridge about 30 years ago.",
      "word_count": 8
    }
  ],
