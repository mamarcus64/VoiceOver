{
  "stem": "747.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "But-- and for example, one day I opened up a suitcase and find a little dress in it, a red dress with little, white polka dots.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "It belonged to a little girl who was-- practically, I adopted her in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "The-- her mother, they were three small babies.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "She was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "She was three years old, little Susie.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And the mother was so busy with the babies and was miserable.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "The father was in a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And so that little Susie sat in my lap all the time, and I loved it.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "It was a cute little thing with a curly head of hair.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And I knew what happened to little Susie with her mother and the children.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And then I here-- I open up a suitcase and find little Susie's dress.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "What she-- it was her favorite dress.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And that dress meant so much, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "It was-- it just opened up my whole tragedy.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "It was just very painful.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And pictures I find from friends.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "You know, everybody tried to bring their photo album, hoping that they will save it.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And it was very painful.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Very.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Every piece of clothes we knew that belonged to someone who is not here anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And then from there, we had a chance--",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "That's what I want to tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "We could do a little bit of humanitarian work.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Since we, we opened up the suitcases, we find medicine, and sometimes a little bit of food, and clothes, sweaters.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And we tried to smuggle in whatever we could to the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "But was not always possible because were inspection all the time, where they stripped us naked by the gate before we entered the camp.",
      "word_count": 24
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And it was very difficult.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "But occasionally, it happened.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "For example, shoes.",
      "word_count": 3
    }
  ],
