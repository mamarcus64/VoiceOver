{
  "stem": "18572.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "You know, they say that math is like the last-- you-- you do math in the language that you know the most.",
      "word_count": 22
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "I never knew a language long enough.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHTER] I remember crying because I didn't have a language that I had held on to long enough.",
      "word_count": 18
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "I was still doing math in Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "Then I was doing it in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "Then I was doing it in whatever.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they would speak in Yiddish and I would speak in English.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "High school, right.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "History-- still sort of, I guess, thinking in terms of going to law school.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "But I-- somewhere along the line, I was told that that was not a thing that women do.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "My parents kept saying, you should be a teacher, because then you could take care of the kids after school.",
      "word_count": 20
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Being a teacher.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "A teacher.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And what year did you graduate from Queens College?",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "In '60. 1960.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I actually-- I was going to be a social studies teacher.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "But the first job I got, I wound up teaching a class of mentally retarded children in Greenpoint, Brooklyn.",
      "word_count": 19
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And then the following year, I started-- I had already met Adam and was getting married.",
      "word_count": 16
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "So I subbed.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And I wound up teaching in a high school social studies-- Aviation High School.",
      "word_count": 14
    }
  ],
