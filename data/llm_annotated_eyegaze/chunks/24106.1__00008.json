{
  "stem": "24106.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "It would be about an hour with the train.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "They used to come to visit us.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Before the war?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was already finished with school, because we all go to seven-- seven grades.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "It's seven-- I was about 14, 15.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to learn a-- a trade.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "I learn how to sew.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "A woman took me in, and she showed me how to sew.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I-- I was working like a year without money, and then she start paying me.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I was about 16 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In Rowne, yeah. 16, 17, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "So that's how I know how to sew.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Mirl.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Mirl Shmuach.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Her name was Mirl Shmuach.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "She was a very special lady to me.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "She taught me a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And she had small-- two small children, a boy and a girl-- [?",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Zizela. ?] And the boy's name, she used to call him [?",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "Engela. ?] She didn't call him by a name.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "She called them [?",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "Zizela ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "Engela. ?] Yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Not with-- not in the Polish, no.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Not by the Polack, we didn't have passports.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have any telephones.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Who calls on telephone?",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have radios till about 1939.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have radios.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "No telephone, no radios.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "Maybe it was a-- a telephone in the-- in the post office, but nobody called.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "It changes one, two, three.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "The Poles was-- in 1939, that was September 1.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Just Erev Rosh Hashanah, the war broke out between German there in Pole-- and the-- and the Poles.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "So it was right-- we felt right away the-- the-- the-- the airplanes were-- right away, they were bombarding.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "For three, four days, we couldn't go out.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
