{
  "stem": "25381.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "So he rented a room by a lady.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "She was a widow.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And she-- we should going to stay there, room and board.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And he paid-- he paid for this lady, until we'll find rooms.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And this lady was another lady, an elderly lady, that she rented the room.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But she was an American-- you know, Jewish lady, older lady.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She had children without food.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And-- and the lady gave us rent and food.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And they took my husband-- he had a factory, bolt and nuts, Michigan Bolt and Nuts, shipping, receiving-- a big factory.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Two factories, they had. on [INAUDIBLE] then one on [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So he took him-- the second week, he took him to work for $0.90 an hour.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And she used to cook just every single day.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "She used to give me one little piece of bread-- the white bread-- in the morning, and one little piece of bread in the afternoon.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "That's the lady, and she lived on Grand, and by Davidson, on the street, this lady.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And for the baby, she gave like not pure milk, but like blue-- 3/4 water, and 1/4 milk.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And she took advantage.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And every single day for dinner, she just cooked pea soup-- pea soup and pea soup.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I could hardly wait that he should come home from work-- I should have a little bit of pea soup.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't go out in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't touch the light.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't touch this.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I was like in a jail.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So this lady saw how she was treating-- and she goes to my uncle, and she says, she's treating us like-- like milk and honey, nothing but the best.",
      "word_count": 29
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "She was a liar, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And she took advantage with us.",
      "word_count": 6
    }
  ],
