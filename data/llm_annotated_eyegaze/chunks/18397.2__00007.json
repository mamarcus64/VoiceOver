{
  "stem": "18397.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And nobody will give you to eat nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "You ask for something to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "This way, I had my-- my clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I used to knock on the door.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "I used to say I'm a soldier.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I'm lost.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I have to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "They used to give you something to eat.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "So I used to walk nights.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "I didn't walk in the daytime, because I was afraid of the Russian.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "At night, I used to walk.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I was walking like this, I don't know, maybe without end.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I-- and then I came near Rowne.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Rowne, that's a Jewish city, where people were speaking Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "There was a guy who used to drive a truck or something-- I don't know-- not a truck-- and I asked him where is-- do you know where Rowne is?",
      "word_count": 30
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He says, not far, 50 kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He says to me, you want to go with-- I'm going to Rowne tomorrow, he says.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He said-- then when I came over there.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He says, this will cost you 50 zlotys.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I didn't have not 50 cents.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I didn't see how it looks, anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I said, OK, I'll pay you in Rowne.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But he wouldn't let you in, to sit-- on the thing.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You had to walk behind.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "What do you think?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "For-- 50 zlotys, he should let you ride.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So we walked like this.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And we came in Rowne.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And it was-- then on the way, he got another couple guys like me.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "You see right away who it is.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So they had some money ready.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Were they Jewish too?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Sure, who else?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We came to Rowne.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So he took us to the-- to the [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "You know what a [NON-ENGLISH] is?",
      "word_count": 6
    }
  ],
