  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I was working-- well, I worked in that lab.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And at that time, it was terrible, terrible conditions.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And so one fine day, I went to the Labor Department.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I said, I'm not going back there.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Probably had almost a nervous break-- it was just terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And they closed the place down because eventually they had other complaints.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And then I worked in a factory in, in Birmingham.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I-- let me see.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I worked-- yes, probably by '42, I don't quite know the chronology, but about-- I lived in Birmingham till about '45.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I guess I was still in Birmingham when the war ended.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, It was very exciting.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Of course, it was very exciting.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Everybody danced in the streets.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    }
  ],
