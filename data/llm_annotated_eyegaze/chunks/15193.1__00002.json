{
  "stem": "15193.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And it was-- I wouldn't say prosperous, but we made a good living.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was not that easy, but being that my father worked with farmers, sometimes he got a little extra.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we all had to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And it was a-- it was really at the beginning, as far as I can remember, very nice.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Life was entirely different.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We had-- my father was-- and my mother were very traditional, not orthodox, but very traditional.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "We never worked on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "We upheld all our holidays.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We always went to Shul, what they're called.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And we always went, and it was nice.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And we celebrated bar mitzvah, had the whole family come to Kaukehmen, and we had a big spread for them.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "It was delightful.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They came from Tilsit-- also East Prussia-- they came from Tilsit and from Konigsberg and from Heidekrug, all over.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And it was nice.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother worked in the business that she did the bookkeeping.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But she had enough to do with the eight children.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We did have help.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We had a woman come in on Sunday, the washing-- clothes washing-- that was a big procedure those days.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "She would come in and soak the laundry.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "The next day she would boil the laundry on a wooden stove.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And the next day she would rinse it, and we had to go to a big farm that had lots of yards.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And we would spread our laundry out there for it to be bleached by the sun.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And then we had to get up early in the morning, 5:00 to do that, otherwise we wouldn't get a space to proceed with our laundry.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And then at night, we would take it in, rinse it and dry it again on lines.",
      "word_count": 17
    }
  ],
