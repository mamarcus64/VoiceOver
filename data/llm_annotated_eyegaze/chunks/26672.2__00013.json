  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "In fact, my aunt was liberated six months before me in-- in that-- that camp, by the Russians, also by the Russians.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They just came in one day and says, right, that bag is going off, or they called out lists, and you're going off.",
      "word_count": 23
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how many left the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, Buchenwald-- I-- what can you say with-- it wasn't a-- it wasn't a holiday camp, I can tell you.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "The bunks that we shared were much more difficult to sleep in than-- than the-- the other previous.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Many more people shared those bunks.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And we all laid sort of like sardines, you know, one this way, one that way, and even across the legs and across the hands, you know, as many as you could put in.",
      "word_count": 34
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And there was a long-- a long bench-- all long benches, with wooden benches there, sort of in the center with the thing down.",
      "word_count": 24
    }
  ],
