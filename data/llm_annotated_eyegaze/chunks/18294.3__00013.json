{
  "stem": "18294.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I said, what do you have with me?",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "He was only six weeks married with me?",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "He will wait for me when he's already a year liberated?",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "So I didn't ask him that.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "So I come home.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "Is he married?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "He's married, what I have to lose?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "I go back.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I was afraid to ask him, because I had nobody in the world, just my-- that-- that was my whole hope to find him.",
      "word_count": 24
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "There was such a strong love.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know even I could be like this, really very-- and-- and when I come home, and the father was sitting.",
      "word_count": 22
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "He was sitting-- standing and-- and-- polish his shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And the father said to him, Mulke, don't see who's here?",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Rachel is here.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "He looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "He went quick to-- he was then a manager in a Russian food business-- so you we went and take a paper to-- that his wife come, and he have to go and see her.",
      "word_count": 35
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And then I went from there, when I meet him there, he come back home.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "He, and me, and my cousin all three, we sleeps in one bed together.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Who needs-- who needs a-- who needs a husband then?",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I was happy that I have a bed to lie down.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Maybe he, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "Because he was looking beautifully.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He was already a year liberated.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He was working by the food.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "He looks terrific, really terrific.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I was terrible sick.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "So he went then to the doctor, and they found out, they make an x-ray.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "They find out that I have two-- two holes in my lungs.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "They send me to first the place called [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "Who knows Vilna, will know the place.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "There was a sanatorium there.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And there was a Jewish doctor.",
      "word_count": 6
    }
  ],
