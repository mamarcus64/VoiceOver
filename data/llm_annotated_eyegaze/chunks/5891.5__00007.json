  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Plenty of those around me, you're dirty like-- you know, when you have to live that kind of life, you can't help.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But then they have the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Then they do it.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They spray you and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And they used to--",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The men-- more men shaved that-- that kind of work than the woman.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The woman just got the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They just cruel. ?]",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "You know, the men-- the men, if you shied up to them, they had to-- terrible, you know what you mean?",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "What do you think you've got there, and this and that.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, I mean, they make you feel like-- you know, the little bit of respect you had left for yourself even, they want to take that away from you.",
      "word_count": 29
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So that's the-- that's the way that situation-- situation went.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But I was going to tell you something.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "They were-- that's the word for it.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "The Russians were processing us, exactly.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] There was a tall gypsy.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "It was a Polish girl.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "They called her [?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Mamja ?].",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "They called-- we called her [?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Mamja ?].",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "She was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I wonder if we could walk down there, get ourselves some eggs.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We were dying for some fresh eggs.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And that [?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Mamja ?], that tall gypsy girl, said, oh, I'll go with you.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And the [?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Largle ?] said, oh, I'll go with you too tomorrow.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We'll do it tomorrow.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "We'll walk down there.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Well, that night, they had brought her in.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "She happened to be out when-- with the Russian guy in a [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "She got raped from so many.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I know how many soldiers, Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I said, oh, my god.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "How can that be?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They're not allowed to do this.",
      "word_count": 6
    }
  ],
