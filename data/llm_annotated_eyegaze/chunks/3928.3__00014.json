  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I know who can testify that's what happened.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And certainly, it sounds like, you know, like a fiction, you know, written for television.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I had to wait until I find people who-- who can testify, in my behalf, what I am saying.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And the funny part is this.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "You know, I showed you the tape, this hole?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It's another one, right above it, which is not open, because people don't know this was still there, because they-- we covered it up.",
      "word_count": 24
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And for some reason, this man, who came, he didn't know about the hole above.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And this one is still can be opened.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "That place still exists the same way as it was in Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My father and my brother, they were also in the underground.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And you know, it's a sad story, when you think of it, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Because I went there and visited them.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I gave them all the papers and everything what they needed in order to save them.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "But I was out to deliver two fliers to the partisans, because I had to do it.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And because of this, this cost my father's and my brother's life.",
      "word_count": 12
    }
  ],
