{
  "stem": "21259.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And after, you know, I got the-- in England, I remember, my aunt, Mama's sisters, and they send me-- they send me a diamond ring.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I, I-- they send me a diamond when I got married from Canada.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "She, she sent me that parcel.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "In the parcel she told me, she has in there a ring, you know, a diamond ring with money [INAUDIBLE] and she says, a pant.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "There was a pant, you know, [INAUDIBLE] pant.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And, and I got this package.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And there was [LAUGHS] a [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "Yeah, and they send me silver candles from England.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "You know, [INAUDIBLE], you know, in-- and I got this from my aunt.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "She gives me them back.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And I told my wife there, next wife, give me the ring.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "This said, this, no.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "She not give me it.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So she got married with a goldsmith.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He makes a gold ring, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "He took off-- he took off the diamond.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "He-- [LAUGHS] she send the empty ring.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "So where did you go in the United States?",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "United States, my-- right away, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My cousin, yeah, to New York, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "To my family.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They took me a-- they took me apartment, my cousin here, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He wants I should live with him, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I was-- I was live with him two weeks, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "After he took me, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And I was living.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And what kind of occupation did you do once you came to the United States?",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I was working for him [PAUSES FOR 3 SECONDS] here.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "You know, before I was working no furrier.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I was come in October, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "Till December, I was working furrier.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "When-- in Canada I was working, I make $80, $90 a week furrier. $90 a week.",
      "word_count": 16
    }
  ],
