{
  "stem": "15028.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "From-- From Goteborg-- from the hospital I got all these goodies, I met some other people they are from Romania, and I got to know them in the hospital.",
      "word_count": 29
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And one of them in particular already came-- woke up but he wasn't really normal I would say, a fellow by the name Shansin Goldstein, older than me.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And he start he didn't want to eat the meat.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "It was treif.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I know what it means.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "It came back to me too, and I still ate the meat.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And another guy and me and we-- three of us, we left to a camp-- they took us to a camp in Sweden in the mountains.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Kramppen.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Is that-- the name was Kramppen-- very barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "They had mostly young fellows like me.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "They 100 to 120 young fellows that came from Bergen-Belsen or from Germany to the hospitals in Sweden.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And they-- we should put ourselves back on the feet.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And there, the-- we've we ate good.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They gave us good three meals a day, and they-- if we wanted to, after a while, we were planting trees for the government in the hills a few hours a day, four or fives hours, little trees.",
      "word_count": 38
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And little sports, a little exercise and-- to come back to ourselves.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "From there-- How long would-- did that last?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "There we were-- I arrived there in '45, was liberated the 8th and-- to the 15th.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I went to Sweden May.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "By June, I-- I came to the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "From-- in June-- another-- we lasted there about over the summer two months.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And from there-- not-- not even-- two-- two months.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Two months.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And we were-- barrack where we were eating, and I was always sticking to these two fellows from what we met.",
      "word_count": 21
    }
  ],
