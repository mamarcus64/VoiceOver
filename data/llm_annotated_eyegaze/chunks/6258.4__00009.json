  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "This was the same guy, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The same guy, Alexander Weisberg.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "This was still in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And then, well, and then suddenly, we were supposed to go for some concert.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And my mother said, he was there with another.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Well, I said, no, I don't want to know him anywhere.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Bang.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "But-- OK?",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But two years, three years ago in London, someone who read my diary called me and said-- friend of my friends, Polish-- do you want to have photograph of Alexander Weisberg and his books?",
      "word_count": 34
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I said, yeah, why not?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I came there, and there I found four books written by Alexander Weisberg-Cybulski.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He is the guy who coined the term 'Iron Curtain.' He was a most important physicist, [PAUSES FOR 3 SECONDS] most important physicist who was director of-- in Russia, a communist.",
      "word_count": 31
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "He was supposed to be the director of that great communist-- of that great, in Kharkov, place.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And in 1936, he was, by Stalin, you know, sent to gulag.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "You know, this is very important.",
      "word_count": 6
    }
  ],
