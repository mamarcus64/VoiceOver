{
  "stem": "23730.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Ernest Levy, although I have a middle name as well-- Ernest Moshe Levy.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Bratislava in 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I'm the eight child of a Jewish family.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Levy-- L-E-V-Y.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Ernest-- E-R-N-E-S-T.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Benjamin, because I was the youngest in the family.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The date of birth as I said, the 25-- sorry, the 13th of January, 1925.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My age now is 71.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name is Leopold Lowy.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "In Bratislava, he was called Leopold Lowy.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Mother's name was Terezia Hauser.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "L-O-W-Y, with an umlaut on the O.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He was an agent.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He was in business.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He had marvelous agencies, about five major agencies, in Slovakia-- knitwear what his main line.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Father had Hungarian background-- he was born in Hungary, right?",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And served in the Hungarian-Austrian army in World War I.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And then he settled in Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And eventually from Vienna, he moved to Bratislava.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "There he met my late mother.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "A lot, an awful lot, he spoke about his experience [INAUDIBLE], yes.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And a Jewish soldier in-- in an army, you know-- yes?",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It was difficult to keep his Orthodox Judaism in the army, yes, he told us about that.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "But he managed, more or less, very well.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He was not in action.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was not in action.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He told us he was just a supply-- in the supply troops, who supplied the army.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Mother's background is a wonderful background.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Her-- her-- my grandmother from my mother side comes from Holland-- [NON-ENGLISH] a very wonderful family-- who eventually settled, also, in Bratislava-- which was then Pressburg.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And she also comes from a fairly large family-- very, very good background on my mother's side.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Pressburg became Bratislava when Czechoslovakia became a country after World War I.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Then Bratislava became the capital of Slovakia.",
      "word_count": 7
    }
  ],
