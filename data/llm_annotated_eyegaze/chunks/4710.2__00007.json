{
  "stem": "4710.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And he said-- he was looking after it until the very end of the war, that postcard which I've written to him, on the 18th of June, when we are marching to the preparation to take us to the ghetto.",
      "word_count": 40
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And one older brother--",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "--who was together with me in Auschwitz, my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Two brothers-- two older brothers-- they were already in the labor battalion but not in the same place.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Just came with us.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "She came with us.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "What happened in the school-- I just don't remember anything clearly.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Because possibly the children were not involved.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "But then they have-- then they have interviewed people.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And people-- people [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "They got-- they checked everything, whether they've got any jewelries, and taken away whatever valuables you carried-- jewelry and money, these kind of things.",
      "word_count": 24
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And the end of the day, it was a relief.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And we were taken into the wagons, into the railway station.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Kapuvar.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "To go to Sopron.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "To Sopron.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I remember I took my [NON-ENGLISH], which I just a year ago-- year before was bar mitzvahed.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That was my more precious things.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And maybe a prayer book-- I took a prayer book with me.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But it's very little what you can carry-- just a bit of food for emergencies.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Really very little, because you cannot take more than you can carry-- and beddings.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "It was a very short journey.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Because it's not very far from Sopron.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I think we arrived-- we arrived the next morning, I think.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Funnily enough, I don't remember much about that journey.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "All I remember when we were in Sopron is the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "That was a very primitive conditions.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Very primitive conditions.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "It was in a huge buildings.",
      "word_count": 6
    }
  ],
