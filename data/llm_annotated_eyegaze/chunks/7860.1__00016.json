  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And so I was kind of proud of myself.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And my little brother Reuben, the youngest one, left with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "And she-- he was going back in the ghetto like other children, and like other children, begging in the ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "Many children running throughout the ghetto saying, [NON-ENGLISH]-- please donate a piece of bread.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "And the Jewish people who were fortune enough to go outside the ghetto to do black marketeering, they cut up a loaf of bread in little pieces, squares the size of a dime, and give it to this children to eat, and took around begging.",
      "word_count": 45
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "So I accumulate little piece of carrots, little piece of bread that was daily received, and brag how successful he is also.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "And this was the last time I came back into the ghetto, when last time I see my mother and my youngest brother in the ghetto.",
      "word_count": 26
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "They were about--",
      "word_count": 3
    }
  ],
