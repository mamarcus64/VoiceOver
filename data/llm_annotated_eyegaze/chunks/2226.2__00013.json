{
  "stem": "2226.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "That fellow, Edek Galinski, he-- we worked together like a mechanic, the same-- whatever he did-- don't make a difference, whatever-- he was Pole.",
      "word_count": 24
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "This, and he was a student like a [NON-ENGLISH] they called it.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "He was a student.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "And he respect-- he was a old number.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "Because maybe 10 people from East Frankfort was alive.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "The rest, everything was finished.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 14,
      "text": "So the inspector, me neither, had nothing to do.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "So when we went to-- I went after for a year to Auschwitz-- to Birkenau.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I was not always in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "I stay in Birkenau another year before I got-- before I-- when I could blow the crematoriums up, then I-- I ran away from Birkenau.",
      "word_count": 25
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Tell me though, what-- didn't they try and kill you?",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "How did you get away?",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Who tried?",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Nobody know!",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I tell you, my brother didn't know.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "That fellow in Windsor, he knew it.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "My wife knew it.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No, it's not me, and I made it-- [LAUGHS]",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "--that I went and blow it up.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "There's no such a thing.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "This is-- you're talk-- we're talking cheap, you know what I mean?",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "That's it-- that doesn't go that way.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "You have to accumulate.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "You have to make it.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "You have to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "So I had a girl over there, from my city.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "And she brought the powder inside--",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] How many of you--",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "--the vagine, in the-- in the body.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "She brought the powder in.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "No, she didn't brought it so much like that another girl brought it.",
      "word_count": 13
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "And she took it from them.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "And she gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "And I made it-- a hand grenade.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "But that alone was no good.",
      "word_count": 6
    }
  ],
