{
  "stem": "23498.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "So they-- they had-- they had a car, and they also had a-- a few trucks, and he said to my father, we can go towards Russia and over there we'll see.",
      "word_count": 32
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So my father, of course, he was grateful and he agreed.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And my mother [PAUSES FOR 3 SECONDS] wasn't so very keen on it, and we started to cry.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "It was cold sort of and at night, and my mother said I'm not going.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So we took our belongings and went back to our flat.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Was this after your father had gone into hiding?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was a question of a few days because after they killed the 100 odd people, I remember going there and seeing the dead people.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was a distant cousin, and a lot of people couldn't recognize really.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "In Wawel.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "That was in Wawel.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "A sort of open area, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "One or-- or two was sort of buried with the dead bodies, so one or two survive.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But it was about 100, 120 people.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So we were living on-- in [?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Krakow ?] until we went to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "That was about 15 of November, I think.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "1940.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We had a-- I had a aunt who was living before the ghetto in-- in that area, and she had two rooms.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And she-- they gave one room to us.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I can recall that my father had typhoid and--",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "In [NON-ENGLISH], in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Because there-- there were lice everywhere.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we were-- my mother found one or two lice, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Also, we were walking in the middle of the road, but there were people everywhere, couldn't avoid it.",
      "word_count": 18
    }
  ],
