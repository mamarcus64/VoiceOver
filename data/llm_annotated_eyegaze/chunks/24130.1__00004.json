{
  "stem": "24130.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And my mother got cured from the TB, but somehow I became my grandma's pet.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And she wouldn't-- she lived in the same house, just a different room.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But I was my grandma's pet, so I remember my grandma more.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then when I was six years old, my grandma got-- my mother had cancer, breast cancer.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And she-- she went to the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And the doctor told her-- it was before the holidays-- that she should wait for the holidays, she should go for surgery.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And she had-- she went to a big city where they recommended a very good doctor, and she had a mastectomy.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And the doctor said that she would be fine.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "But she-- we didn't have any insurance.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "My father would pay the hospitals, it was very costly.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And my father-- my mother came home, and we were so happy that she's OK.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "But the cancer reoccurred again, and she had to go back to the hospital.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "She had another operation, and she came home.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And then she had to go back for treatments that give her-- Those years, they already had some kind of a treatments for breast cancer.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And she didn't make it.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "We were practically wiped out from that sickness, that my mother, because my father would sell field, my father would sell a cow to pay for the hospitals and the doctors.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And she died in 1936, she-- she died.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And she left six children and my father, with the six children.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "My sister, my older sister was only 12 years old, and my little brother was two years old.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So I don't know much about my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I remember my mother only going to the hospital, coming home from the hospital.",
      "word_count": 14
    }
  ],
