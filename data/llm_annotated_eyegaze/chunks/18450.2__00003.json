{
  "stem": "18450.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I was too young, really, to-- maybe I wasn't so young in years, that I was young in my mind, that I didn't-- I wasn't exposed to the everyday living like some other girls.",
      "word_count": 34
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, it started being normal, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The army start being present, the Russian army in the city.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And then they came up in one night.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And then they started making like they came up to our house and says, this house, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "That was when the Germans came in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They'll need this house.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So we had to vacate.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But before-- you mean before the Germans came in?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "The Russian army, really, in this day, they came up and they were telling you that-- [PAUSES FOR 4 SECONDS] that things sounds so good.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they-- it was the one they-- from the other parts who are nearer to the border.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They start marching back.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And you saw-- I mean, it was present just of Russian troops.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Nobody went into the outside, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Most of the people were hiding in their houses.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Nobody had any plans, nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Just one night, next door was a very rich man.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They had a leather good store, and they had other business.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They used to-- in-- of the day I was leaving, a Russian [INAUDIBLE] some, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he says that he came up and he said, the young people should really go away from the city.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And even they called up on my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And he says, he should.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Szloma was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "In the meantime, the Russians took away my brother to-- to work.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, that was [?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Abe ?].",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And they--",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Abraham.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They took him to the-- and then he went to the Russian army.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They took him, and then to the Polish army.",
      "word_count": 9
    }
  ],
