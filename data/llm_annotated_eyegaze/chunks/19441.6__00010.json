  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Now, if I take the position of her girlfriend, and she maybe have-- I don't know what position-- she will be bad to the Jews.",
      "word_count": 25
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And I don't need that at all.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So I said, [?",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Schulz ?] was her name, [?",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Aufseherin ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Schulz. ?] You know what?",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "I have a proposition.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "I am much better in counting the food, like the mathematic.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Counting the food, and I will be in the office.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And let her stay a kapo.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "She is used to it.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "But what will the commander say?",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He will be satisfied.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "If you think that he will be satisfied, that's all right.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "So I got the-- in the office.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And I was in charge to count out the food.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "How much that, and how much that.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The prisoners didn't know why their rations was doubled.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Because I now counting.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I counted everything double.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "But I wasn't there too long.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't there too long.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Because suddenly, they called--",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Ah, four weeks, about.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Maybe-- maybe not even four weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Two weeks.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "October, that was the beginning of October.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Say, in the middle of October.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Because I have to consider what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "So again, the lagerkommandant, with the black car.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And now I want you to sit in the car.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "So now I am going to take you somewhere.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Hmm?",
      "word_count": 1
    }
  ],
