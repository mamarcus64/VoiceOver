{
  "stem": "17374.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 425.2,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Because I always thought that I am.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I always thought that I can sing.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "But when first I start to something, my husband-- ah.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "That was his reaction.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And that shut me up for all my married life.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I'm not musical, but luckily, my true children are.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And my grandchildren are very musical.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "But I'm really lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "That was my wish that they take after that.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Yes, I met him.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "Through his brother I met him.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And we start to-- meeting.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Well, it was nowhere to go.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "The date was on the balcony.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "That was a big balcony.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "It was a bit darker, and we start to kiss.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And I enjoyed that.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And-- well-- after sometime, I said, what about we decided to get married?",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He lives in the ghetto with his sister.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And the sister-- sister-in-law.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Leo's sister-in-law and brother, Henry.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Did they live near you?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And lived in the same apartment-- not the same apartment, but the same complex of apartments.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Because it was a huge building.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "A very big building.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And, well, we kiss in the balcony.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I remember this.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And when we went to his sister's, she said, you [NON-ENGLISH SPEECH].",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "You're going to be married.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Here you don't know what you'll eat tomorrow.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And I said, it doesn't matter.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Whatever we have, we will share it.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And we get married.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We had a rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And my sister-- another sister-in-law.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Manci, she [INAUDIBLE] from the brother or something.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I got a suit, and I had little hat, because his sister was modest.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And little veil, a small veil.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And it was-- but his parents were not there already.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Not my father, because they were-- in June '42, that was selection, and they went.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Taken by German transport.",
      "word_count": 4
    }
  ],
