  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I'm surprised that-- you know, still sometimes I wonder how I came that I was not-- that I was not killed, because they still could have mistaken me for a German soldier-- ex-German soldier.",
      "word_count": 34
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "For-- till the Allied forces moved in, till the British, American, and French forces moved in and took-- and occupied their sectors.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Berlin became-- on July 4th, Independence-- American Independence Day-- the Allied forces moved in.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I watched them coming into the city, the little military convoys that took over.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Then the Russians only kept part of-- the eastern part of-- the eastern part of Berlin.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "It was divided in two.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I stayed there till August 3.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Then I went to Munich to look for my family, because they had lived underground, yeah.",
      "word_count": 16
    }
  ],
