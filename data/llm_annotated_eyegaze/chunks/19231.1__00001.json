  "elapsed_s": 14.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I don't remember if he was wearing every day or just for the holidays.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I can't recall that.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- he had a business.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He was a businessman, so a very quiet man.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "He was smoking a lot, all the time smoking.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Cigarettes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Made by himself, those-- I don't know what the name is of those, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They make-- they were making at that time their own.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And he mostly, you know, he was busy.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We-- we used to have a store from-- actually, not clothing, but fabric.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "People used to buy material to make suits and dresses.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "That's what kind of store he owned.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Zisla.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Manela was the last name.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, her maiden name was Manela.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And what type of person was your mother?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "She She was helping my father.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And she was not as religious like my father.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "She was more looking away.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "She was with the children more.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "You know, she tried to make peace between my father and the children when they were rebelling.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "She was more modern.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Little bit more modern, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that we did.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We We love our mother very dearly.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She was very understanding.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Especially, I was the youngest.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I was just hanging on her.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I thought I couldn't live without her.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But I survived like the rest of us.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I had six brothers and two sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They were much older.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "My mother had me already in her changes when she was over 40 when I was born.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I had a married sister at that time when I was born.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So there was a big-- in ages, there was a big different.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah my oldest sister, which is alive now, she is Lola.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Her-- maid-- her married name was [?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Rinski, ?] Lola [?",
      "word_count": 4
    }
  ],
