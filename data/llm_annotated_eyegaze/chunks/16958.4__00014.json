  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "Any event, with just friends, [INAUDIBLE] to a guy that he was-- his name was [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "He went with me to school.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "He became SS.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 26,
      "text": "And he came to this house.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 27,
      "text": "And they find him in bed.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 28,
      "text": "And the, the police-- the chief and the police, they are from the, the Russian.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 29,
      "text": "He says, don't blame me.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 30,
      "text": "[INAUDIBLE] where we were left to find.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 31,
      "text": "And we find ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 32,
      "text": "So they came there and [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 33,
      "text": "He says, I am sick.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 34,
      "text": "Then he open the basement and full basement of Jewish stuff, all Jewish things-- coats and suits and things.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So this-- then my brother had the auto-- automatic rifle with him.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And this-- he also was in the cave with us, went for a wagon.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "In the meantime, this [INAUDIBLE] curl up on the bed.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And my brother stays with the rifle.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We hear pow!",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "He sees blood already.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] came out.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He took a rifle and want to shoot my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And if my brother wouldn't have the automatic rifle which had like a disk-- it hit the disk and this.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And it his finger.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And then he--",
      "word_count": 3
    }
  ],
