{
  "stem": "21550.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "There were two boys and four girls.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "My mother was the only one married, except for my uncle in Israel who married too.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "But all the others waited one   for the other.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "They waited for the older to get married, because a younger one wouldn't dare getting married before the older sister.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So they all got stuck.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "None of them married.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "My uncle contacted typhoid fever in the ghetto, and he died from  it.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And the rest of the family [SIGHS] was taken to Treblinka, which was a death camp.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 8 SECONDS] I was working for the German railroad at the time.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "I was a young man.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I was 19 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And they used to take us every morning.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "They had some German come in, and we had a Jewish foreman.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And they would take us in the morning to the railroad where we worked until late in the afternoon.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And then they'll bring us back into the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "They escorted us with a-- a German railroad worker.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So one day I came home and they were gone.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They were picked up, and this was it.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Who all was taken?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "They were taken to Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this one, at one time, there was my grandmother and my-- and my four aunt.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And a couple of weeks later, my mother and Lilka were picked up.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I haven't seen them anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 12 SECONDS] [DRINKS]",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "There was nobody to tell.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My father said-- he was very, very distressed.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And he-- he tried to get her back by contacting a funeral home to bring her out in a-- in a box.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But unfortunately, as soon as they got brought to this place, the--",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It was a railroad siding.",
      "word_count": 5
    }
  ],
