{
  "stem": "3994.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And we all had said-- most of the people had the same experience who had experienced what I had.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Only, I had a worse one than anybody else, because of the child.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "But I talked to a lot of people.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And we were discussing it.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And then after a while, you had to live your own life.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Because you have to-- how should I say-- you have to establish yourself to make your living.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And my darling late husband, in between us was 22 years different.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "So I was the young one.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "I had to work more than him.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "And Judy was already nine years old.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "And we had to work to do something.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "So we don't-- didn't have time to social function or socializing with anybody.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "Because I worked seven days and seven nights.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, I was lucky.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I had my millinery experience.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I worked in [INAUDIBLE] for five years in a shop.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And my husband worked at the post office.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "So that time, it was excellent.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Because one wages you could put away.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And the other one, we lived on it.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So when we were established after five years, I went to another shop to work, a millinery in Bondi Junction for another three years.",
      "word_count": 24
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And then I had enough money to buy a shop.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And that's how I started my work.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "What shop did you buy?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "A frock shop.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In Auburn.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And there I was for 12 or 14 years.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In Bondi Junction.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Always lived here in Bondi.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They both-- one lived in Canberra and one lived it was here in Bondi.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And my two sisters had a shop established themselves in Kempsey.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They were partners together.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "So that's how we started our life.",
      "word_count": 7
    }
  ],
