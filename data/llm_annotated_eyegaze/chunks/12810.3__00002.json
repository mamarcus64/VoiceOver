  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they give it to her.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I think my step-mother.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She went there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No, it's in Hungary.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The Bible, Bible.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Biblical name.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And we was-- how I say to you.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Together-- we went to the high school together.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We went together.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Only when I go to the technical college, she went to-- she come to be a-- not a nurse.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "It's a-- in the countryside, you, you know, they look after the sick people.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Birth certificate, everything.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I only needed birth certificate.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "That's-- that's all what I need, because that's the everything.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And it was the same age, and how I know where the aunt is, and the grandmother, the grandfather name.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I-- I know everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And the priest had a [PAUSES FOR 4 SECONDS] holiday place, actually, in Balaton.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "It's a grapes--",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "A vineyard, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And he has a [PAUSES FOR 3 SECONDS] housekeeper.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And the housekeeper's mother look after his property over there.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So she was an elderly woman who lived alone.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So she was happy if I go to her and help her to the winery and things and the chickens, and the moo cows, and everything.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "How did you get there?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The first time in my life-- I never-- never was that side of the country.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I go with the train.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And when-- when the train is gone, then it's an air things come again.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Air raid.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And they put us out again, because that was the rule.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Have to leave the-- the wagon, or the--",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Carriage, you have to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So we're running down to the field.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I was hoping it's coming a moment, killing me, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I was so unhappy.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And I don't know why I live, you know?",
      "word_count": 9
    }
  ],
