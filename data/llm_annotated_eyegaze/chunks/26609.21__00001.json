{
  "stem": "26609.21",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "Georgia-- ?] the Polish woman-- her children were somewhere in the market or somewhere else.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "She went and gave them food.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "But no one gave me nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "But those people-- as I went, I didn't want to be all the time alone inside.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "So I went out, outside.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "And a woman opens a door.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "And it was evening for Christmas.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "And she threw out a potato.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "Just, she didn't give me.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "She didn't call me.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "But she threw out.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "And it fell outside.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "And I picked it up and ate it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 39,
      "text": "And it was a baked potato.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 40,
      "text": "And it-- to me, it was like the best chocolate, she said.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 41,
      "text": "And that was for Christmas that another woman gave her.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 42,
      "text": "But [INAUDIBLE] is the one who kept it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 43,
      "text": "She didn't give her anything.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 44,
      "text": "And yet, when after the war they want to take away from her, she screamed.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 45,
      "text": "And she threw stones after them.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 46,
      "text": "It means she wanted her only to give her to, for Jesus marry of Jesus Christ to offer her.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the one survivor-- it was here already, before when the first time to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And that was in '64.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I read in the Jewish news a story.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I read a story in the Jewish news that a mother, a sole survivor, a Holocaust survivor lost her husband and two, two grown-up sons to Hitler.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "She was alone, had nowhere to go.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "She went to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Where should she go, an old, old woman?",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "She was already old, because she got old in the war.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And when the war started, she wasn't young anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I can see [NON-ENGLISH] Street in Tel Aviv, because I lived eight years in Tel Aviv.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She went to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was in the paper next, written.",
      "word_count": 7
    }
  ],
