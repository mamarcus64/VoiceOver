{
  "stem": "3103.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, my father at the DP camp had the little store in the camp They had like a basement there where he used to sell groceries-- flour, sugar, fruit.",
      "word_count": 29
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "That's the way he made a living.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I had a wedding gown.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I had a beautiful wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I had the real religious wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They made me even go to the mikveh, if you know what this is.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Which I refused, but I had to go, or else the rabbi wouldn't marry us.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's that basin.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "It's supposed to be clean, and used to purify yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I guess in the old times, they didn't have the facilities, so that was maybe the only time that they have to be clean.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But you have to purify.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They dunk you, said a prayer.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember what kind.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I was scared for the water like hell, because they dunk your head under.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I was afraid for the water.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "They cut your fingernails.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "They had to be beautiful and clean.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "That's all I remember about it.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And that came a document to the rabbi that I am pure, and it was OK for him.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "My dress was a very pretty gown.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "My parents-- my mother, bought it for me.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I have a picture, if you would like to take the picture.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "We dressed up-- I dressed up my husband at the time very beautiful.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have anything, but if you want to know the episode, what do we did, you could buy on the market, on the black market, the pure wool American blankets that the army had it-- each soldier, or whatever.",
      "word_count": 40
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember how much I paid, but I bought a green blanket.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "They dyed it for me, and made it navy.",
      "word_count": 9
    }
  ],
