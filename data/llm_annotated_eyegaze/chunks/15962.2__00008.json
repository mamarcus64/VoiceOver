  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And here is the irony of all my sort of anguish that first you pack very carefully and, and make sure that you have the most the essential things to take with you.",
      "word_count": 33
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And then it's all taken away from you anyway.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "We were completely blinded and, and overwhelmed by this horrible welcome.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "The shock was enormous, especially, again, for the elderly that had a hard time walking.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "The exceptional situation to most other transports was, was that the famous Josef Mengele did not welcome us there and started sorting the, the work force from those who were to go immediately to the crematorium, to the gas chambers.",
      "word_count": 40
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "The preceding transport, the October transport I alluded to, welcomed us in this particular camp.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They were there by then three months had established the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And some of them had the-- performed some of the functions of being in charge of barracks or certain operations.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The, the the minor ones, yes.",
      "word_count": 6
    }
  ],
