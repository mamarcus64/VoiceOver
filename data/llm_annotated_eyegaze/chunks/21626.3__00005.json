  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] And then I heard, months later, that there was going to be a concert given by the Czech forces in Liverpool, and that President Benes and his wife are going to be the guest of honor.",
      "word_count": 40
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I nagged the Rainfords to let me attend.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And they said, we can't because of the bombardment, because of the air raids.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And I said, listen, if Precedent Benes isn't afraid, surely you won't keep me away.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And so Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "Rainford said OK.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "He gave in.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "I'll take you.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "We'll go.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I'd have to look in my diary.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I think it was-- 19-- the beginning of 1941, I think it was.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Yes, the beginning of 1941.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And it was a wonderful night for me, to hear Czech music and to see all these men I owed my life to and to see President Benes, whom to me was sort of a very [PAUSES FOR 3 SECONDS] special figure, you know, sitting there in the box, made it a really memorable night.",
      "word_count": 59
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And halfway through the concert, during the interval, armed with a visiting card which I took with me, I marched to the box.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And there were two Czech soldiers on guard there.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And I presented them, I presented them with, with a visiting card.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And I said, would you please tell President Benes that Vera Diamant is here to see him and would like to see him.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "He looked at this little kid standing there, but nevertheless amused, they went in and came out and said, please go in.",
      "word_count": 22
    }
  ],
