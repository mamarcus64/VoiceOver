  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we went in from here, took up a few-- a few boards, and we let the men in over there.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "After three days, you couldn't go out.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't move.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "So how you eat?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So we give them a few bread.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Salami, never, because the dogs smell it.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "You know, live things-- they smell the salami.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "So he was over there.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "For a few days, the siren.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "It's quiet.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "Three days, you can't go out.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "So we-- we took out that way.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And Molly, we took her out different.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Molly, she was like a [NON-ENGLISH] She was a [NON-ENGLISH] And like, she worked in the-- where you-- people coming in, and people were-- if you need anything, you go over there to-- to the [NON-ENGLISH], now, a place where-- where they marking down all the dead, all the alives.",
      "word_count": 50
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She worked over there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And she would run around from one place and another.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And she had that Edek Galinski, like a boyfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So Edek, how can I get him out?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So I took that-- that soot, [PAUSES FOR 4 SECONDS] and I gaved him that a day before.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And he took that soot and hide it.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It was over the [NON-ENGLISH] bunker, you know, where they keep the potatoes for winter, a bunker.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "So how can he see Molly?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And he put himself out like a soldier, like an SS man.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "So how can he see Molly?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And how can Molly see him?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "He-- he's a soldier.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "There's lots of soldiers where she can go into the wrong soldier.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "So we were talking.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I didn't know myself.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "I didn't know too much.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "The Russian taught me a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "He told-- I told him, here is the soot.",
      "word_count": 9
    }
  ],
