  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Kurvinkel was a camp which was under the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "Uh-oh, he gave you a signal-- under the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Kurvinkel, K-U-R-V-I-N-K-E-L",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "That's-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "You see, we were sleeping five in a-- a bunk.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And you want to turn over, you must tell everybody you're going to turn over.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "Because if you turn over, you cannot.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In the night, we got one-- one blanket.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "In the night, you didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And somebody grabbed the blanket.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "You all without the blanket.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Tomorrow, no blanket.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "It's cold.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "So you give the bread, and buy yourself a blanket.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "So why they're going to buy a blanket?",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "The night, they're going to steal it again.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "So we did it.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "We cut it up the blanket, the middle.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "And we put it on the blanket.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "Oh, that was smart.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have a choice.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And the rest [INAUDIBLE] we [? break ?] it on the-- for the shoes.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "But you cut it up, they're [? round. ?] [INAUDIBLE] we put [INAUDIBLE] the shoes make it.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "We come into Kurvinkel.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "It was under a hill.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "The breathing was only through a pipe-- no windows, no nothing, just a pipe.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
