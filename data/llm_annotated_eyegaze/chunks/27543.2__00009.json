{
  "stem": "27543.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Everybody wanted a good word.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "In Bratislava, I told you.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Didn't you mark that up in Bratislava?",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "That was in Bratislava.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "In Bratislava.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "That's [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "That was the capital of Slovakia now.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And some way, the Germans know it.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And they took them-- that was Christmas day, 1944, Christmas Day.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They took them.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "That was the worst thing I ever saw in my life, two to 10 years old kids.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The Germans, but we didn't see that.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I said I never saw a-- a German killing a Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "That was the worst thing in the world, and one more.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So we were coming back.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "The Germans tried to get private clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "They give everything, you know, just to have a different clothes not in German uniform.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We had to go with them ahead of them.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "We had to pack up the stuff what was in there.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They, you know-- the Swiss cheese was 4-- 500 pounds.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Everything in the world, the best cocoa, the best chocolate, the best booze, everything.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "The Germans had everything the best, what they stole from all the small countries.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Move-- Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there were thousands, motor bicycles, and-- and big trucks, and everything.",
      "word_count": 12
    }
  ],
