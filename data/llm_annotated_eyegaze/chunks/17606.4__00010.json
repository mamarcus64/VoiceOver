{
  "stem": "17606.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 147.5,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "His name is-- they said, what was his name?",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They said, [NON-ENGLISH] Greenblatt.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "So he said, if not for [NON-ENGLISH] Greenblatt, you wouldn't be here.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "You come over there, and you'll see, signed you this by Captain Jan Bednarczyk.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "That is your cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "When we were sitting, my parents last day in Lodz, in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He was sitting in the other room, signing-- he came special from Gliwice to sign the documents.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "Only we couldn't see him.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I could see him because I was-- I knew him from when we were kids together, in Betar.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I knew him, so parents wanted to show off that I am-- that he is alive, he does something.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] was the man who took charge of Betar in Poland after the whole war was finished.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH] and [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "They took charge, and they were leading the Bricha of the Betar groups.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And that's how she knew that I am alive, and that's how we made contact.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And as a matter of fact, the same [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I met her right after war when she come out of the underground.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Because she was arrested.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "She was caught, and she was sent to Auschwitz, and she saw my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And she told me, [NON-ENGLISH], I'm sure your sister is alive.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Because she escaped from the column.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And that's how I found my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Then one day, I went with my sister-in-law, the one who is now in Australia, to the Jewish community-- I was still in uniform-- to find out if anyone is alive.",
      "word_count": 31
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And I gave up hope.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "She asked if anyone was looking for her, and she didn't have any-- and I said, by the way, let me look.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "By chance, maybe somebody look for me.",
      "word_count": 7
    }
  ],
