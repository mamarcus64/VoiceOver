{
  "stem": "13469.8",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And eventually a man came in and he called off about 15 names, not me.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they went off and we were left there.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Then they called another 15 names and then another 15 names.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And now there was only about a dozen people left.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And we were just left there it seemed like hours.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And we were wondering whether we-- whether she hadn't got time for us or whether we'd come on the wrong day.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And we just waited.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "But eventually this man came and he herded along corridors.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And we kept on being checked whether we had the right name and we were the right order, because otherwise everything would go wrong kind of thing.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And we had to be there exactly at the right second in front of Her Majesty the Queen kind of thing.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So eventually I got to the ballroom entrance door.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And then I was told, when your name is called, you move forward and you do your steps kind of thing.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So I heard the name called and I forgot everything else, because one puzzle was, why I got it.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I never had anything in writing ever why I got it.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But it was announced Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Paul Oppenheimer, MBE for services to industry.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My wife heard it, fortunately, because I didn't hear it.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I was totally-- as soon as I heard Oppenheimer, I kind of moved forward, bowed.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I did everything all right kind of thing, and I stood facing Her Majesty the Queen.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And she was on a podium kind of thing, so she was slightly above me.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And she shook my hand and said congratulations.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And she lobbed the medal onto me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "We'd all been equipped with a great big hook, so we all had a big plastic hook.",
      "word_count": 17
    }
  ],
