{
  "stem": "7684.10",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing wrong with him.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, perhaps he had dysentery, who knows.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, we never saw a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "All these years not.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I didn't see a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "When I was pregnant I didn't see a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Once a doctor saw when the baby was very sick.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "[DRINKS] We were on the boat and everything was fine.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "The baby got sick and 24 hours later it dies.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "The boat was in the waters already on the [INAUDIBLE] Aegesa Sea.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "[INTERPOSING VOICES]",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And the baby was buried in the sea.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And 80 days later we were in Holland.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We went to Marseilles.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And the people were fantastic in Marseilles to us.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They were so very wonderful.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They give us to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And they want to stay-- we didn't want to stay in people's houses.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And then we went over Belgium.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And the people give us there to eat.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And then we came in Holland, and they say, more people?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "We don't have to eat for ourself.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And we stayed in quarantine.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Quarantine.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Quarantine because it's the Dutch people.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And then they brought us in a freight car, on top of freight car, to my hometown.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "That was in May.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We were in May in Odessa and we heard the war was over.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Somebody had a radio so you could follow that the war was over.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So that was in-- March, May-- April, perhaps.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "At the end of May.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "At the end of May.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Perhaps.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "The end of May.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Got to Holland.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And so and then we-- brought us in the freight car to my hometown.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I went to a town where my uncle and aunt lived.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know if they say to somebody, tell Dr.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Horen that Selma Engel is alive.",
      "word_count": 6
    }
  ],
