{
  "stem": "5328.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Farm-- not a farm, in a barn-- where rabbits were inside of that barn.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And was a lot of-- of old furniture in there-- in there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "A credenza, like a dining room set, which-- old one.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And I pushed myself.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I was very-- a small girl and very skinny.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So I pushed myself in a-- in a door from the dining room.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And-- and I heard [INAUDIBLE] there were a few more people in that particular place.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "But I didn't see anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And then I [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I heard that the Ukrainian and the SS man came in and took other people from where I was, maybe like 12 people in the same barn than I was.",
      "word_count": 30
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "As they came in, they dragged them out, and I was still in-- still in that place.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "I thought to myself, they'll open up that drawer, and I'm right in front of them.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "So I went out from that hiding space which is in the-- in the dining room drawer.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "I went out from there.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "And I hide myself under the-- the boards.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "I put boards on top of me, and I hide myself there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "Two minutes later, soon I walked out from my-- from this dining room drawer, they open up the drawer, and I wasn't there anymore.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "If I would wait another minute or two, I would be catched too.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "A cabinet-- the cabinet.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Right, a cabinet.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So I was hidden under that-- that board.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "In the middle of the night, we were-- I stayed there for 24 hours.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "In the middle of the night, I went out and I took the leftovers from the rabbits, that leftover carrots and cabbage.",
      "word_count": 22
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So those little-- I-- I wasn't even hungry.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "But just I knew I have to have something in my stomach.",
      "word_count": 12
    }
  ],
