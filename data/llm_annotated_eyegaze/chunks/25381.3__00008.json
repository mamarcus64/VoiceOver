{
  "stem": "25381.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "One day, the German people came in this town to-- to-- to hunt for-- for the Jew.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "So they came with sticks, and they came with-- with dogs.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "So two boys came into this house, and they say [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "That means goddammit, you Jewish girl.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "That means we hiding you.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "They knew already that I'm Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "We hiding you, you have to-- you have to live with us.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "You have to-- give us some sex for us, because we hiding you from the German.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "Otherwise, we going right away to the German.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "We gonna tell them that you are this, and they gonna kill you.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "And I said to them, you're not gonna get sex from me, because I don't care.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "You can kill me right now.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "I have nothing to lose.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "I lost my family and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "I'm the only one survived.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "I don't know how long I'm gonna be alive.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "And I'm not gonna give in to you.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "And I say, I'm still a virgin, and I'm not gonna give in to you.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So they were standing.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Over there was a pail that I prepared potatoes with water for the cows, for the pigs to eat, to take outside.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I was like from the table up to the window.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And I stood.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So they gave him a kick over here in this bone, in the back with their legs.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And they gave him a kick.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "So I jumped from there all the way in-- there was a big round pail with potatoes and water like for the-- for the-- real loose-- not to take.",
      "word_count": 29
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And I fell into this pail all the way.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So I couldn't walk, like quite a few days.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was like kind of broken.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It was so painful.",
      "word_count": 4
    }
  ],
