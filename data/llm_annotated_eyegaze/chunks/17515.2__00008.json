  "elapsed_s": 83.9,
  "sentences_input": [
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "So they don't care they-- what happened to him.",
      "word_count": 9
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "So they went on electric-- electric [? fence, ?] get-- get-- get [INAUDIBLE] get shock or get shot at by tower, by the SS men.",
      "word_count": 25
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Especially on a holiday, the SS, [INAUDIBLE] to-- to shoot a haftling, prisoner.",
      "word_count": 13
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "So the German Wehrmacht, the German SS, got vacation, two or three weeks, or more, for that reason.",
      "word_count": 18
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Anytime, anytime.",
      "word_count": 2
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we-- even the people going so close, the electric fence was so powerful, if-- if I stand that-- that close to the-- to that [INAUDIBLE], the electric pull me to the fence.",
      "word_count": 33
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "The [? electroactive ?] so powerful.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "It's very difficult for me, long days.",
      "word_count": 7
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Sometime, we-- on the lunchtime, we come to-- to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "They feed us.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "Sometimes when we worked far away, they-- they bring them the soup to the place where we'd been working, like a [GERMAN].",
      "word_count": 22
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "[GERMAN] been working on their [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 4,
      "text": "Different-- different places.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 5,
      "text": "Auschwitz, I want you know, Auschwitz is-- was a very rich place.",
      "word_count": 12
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 6,
      "text": "Auschwitz could support themselves.",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 7,
      "text": "Auschwitz was very rich.",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 8,
      "text": "There was race horses, race pigs, a mill, flour mill in Auschwitz.",
      "word_count": 12
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 9,
      "text": "Fishing, it was-- it was really-- no, Auschwitz was absolutely independent, like New York.",
      "word_count": 14
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning, there was like corn flakes, some kind of spinach.",
      "word_count": 12
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, it was different food, and later, it was very bad food.",
      "word_count": 14
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
