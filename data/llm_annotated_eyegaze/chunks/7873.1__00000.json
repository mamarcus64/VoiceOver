{
  "stem": "7873.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Allen Caine.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "C-A-I-N-E.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Cichowicz, C-I-C-H-O-W-I-C-Z, Ancik.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, Ancik.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "That's what they called me every place.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Call it that way.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "All-- they're the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I never had a birth certificate.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It got lost.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "That's a name that you use in the synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Only, right.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "A-N-C-I-K.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "May 5, '24.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "72.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Poland-- Ciechanow.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Then I'd have to look it up.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] C-I-E-C-H-O-A-N-O-W.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "We lived in-- lived in that town, nine of us-- father and mother and [PAUSES FOR 3 SECONDS] four-- seven kids.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Before, when I was born, we were only four kids.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "My father-- [PAUSES FOR 3 SECONDS] there was the-- my father's first marriage.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] When I was three months old, my mother died.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I was the youngest from the four brothers.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "My father remarried.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And the first-- from his second wife, he had two daughters and one son.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "They were much younger than I was.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I lived with my grandparents to make it easier for my father.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And the rest of them lived in one room.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In every way-- wasn't enough food.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "To get rid of one mouth-- it was a big thing.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And there was not even enough room to sleep at night.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It was only-- like I mentioned, it was only one room-- kitchen, everything.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It was one room.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "With my grandparents, it was a little easier.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They had two rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I was always with my grandfather.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I slept with my grandfather.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I ate with my grandfather.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Dinner, I used to sit on his lap and eat [PAUSES FOR 4 SECONDS] till I was-- from three months till I was 15, till they took me away to a prison camp, till the end of my grandparents.",
      "word_count": 39
    }
  ],
