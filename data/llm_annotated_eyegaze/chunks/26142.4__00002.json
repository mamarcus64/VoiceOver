{
  "stem": "26142.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "All of a sudden, I hear big banging in the floor, in the-- in the door, and in the windows.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Open up.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Open up.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So my brother jumped out of bed.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And he said, boy-- and we thought that those are those Jewish boys banging at the door to open up.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And just to tell you that this didn't even-- [PAUSES FOR 4 SECONDS] boy, am I going to get-- give them the [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "It must've been around 1:30, 2 o'clock at night.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "When we opened up the-- up the door here were gendarmes, Hungarian gendarmes with the-- those were-- those were a group of people, the most brutal group of people, that they-- they-- kept [INAUDIBLE].",
      "word_count": 34
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "They were known-- known.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And they gave us the order.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "We could smell-- we could smell the whiskey from them.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "They gave them a lot of whiskey to-- to-- you know, to encourage them.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And they ordered us-- you have a half an hour's time.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You get dressed.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And you get-- get the hell out of here.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "When?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Who said it?",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They had the-- the-- the-- rifles, rifle butts.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "They were banging on our-- in a very [PAUSES FOR 4 SECONDS] meshuggeneh voice-- voices.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "The way they were.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, anyway, this is how it started.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We-- we turned the lights on.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And we started getting dressed.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And they said to us that we are taking you.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] you have to get dressed.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "You can take-- you can take some clothing along.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We're going to take you to a labor camp.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "A labor camp?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But they took-- took my father, my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My mother was 60-some years old.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "My father was 67.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "My [INAUDIBLE]-- my mother was a year or two younger.",
      "word_count": 10
    }
  ],
