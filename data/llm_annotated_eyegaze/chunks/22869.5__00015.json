  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I swear to you that I could probably technically catch them in my hands.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "In an amazement of thinking all this time, how come I'm still--I'm still running?",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I felt-- I felt them on my body, actually.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And nothing happened to me.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And eventually I ended up in a chicken coop by a-- by a peasant there someplace, you know, on a farm.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I was completely out of breath.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And the chickens were all there, and I was hungry like a horse-- of course, from no food.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And there are a bunch of eggs that the chicken laid.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And I started opening these eggs, one after another, raw, and-- and drank them.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "In-- for about an hour or so, I sit there, and waiting what's going to happen.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And everything quieted down.",
      "word_count": 4
    }
  ],
