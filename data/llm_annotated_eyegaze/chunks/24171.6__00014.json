  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I see.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Do you see that one?",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Do you see-- all of a sudden, I hear, there is Moise [NON-ENGLISH] Rosenbaum.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And he was a cousin of my sister-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And-- so I found him.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And I-- he was in the Czech legion.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And he said, yes, I was with them.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I said, well, where are they?",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He said, well, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I got words from them.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Maybe they are somewheres here.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where they are.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "That's what he told me.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "But when two weeks-- till we-- we stopped in Budapest afterwards.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And-- and we were going on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And I'm sitting on top, going already towards our village-- so in Munkacs-- till Munkacs came.",
      "word_count": 16
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And when in Munkacs, we stopped with the train.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And I found there a-- a cousin's son, Srule.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And-- and I asked him, because-- Srule, do they give you-- you know-- did you see [NON-ENGLISH] or Leiser somewheres?",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And he looks at me, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And then he says to me, listen.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Sooner or later, you're gonna find out anyway.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I broke out in--",
      "word_count": 5
    }
  ],
