{
  "stem": "17526.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 92.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "There were prisoners of war from England, from Canada that we met on the plant.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "From Blechhammer, I went-- was shipped to Annaburg, A-N-N-A-B-U-R-G, Annaburg.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "There, this Annaburg was a camp where we were segregating or separating the clothes they were taking away from the ghettos and from the camps.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "Naturally, as soon as you got into the camp, you had to divest yourself of all the belongings.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "I remember I had-- I had-- I was artistically inclined.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "I used to draw at home and I had a little album that I drew on of Jewish types, rabbis, and it was bound in a little book.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "And this was my dearest possession.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "I held onto it.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "And one of the transition camps, we came and we had to unpack everything in a big appelplatz, on a roll call plat-- naturally, life in camp consists of getting up in the morning, but this is a whole chapter by itself.",
      "word_count": 42
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But you asked me where I was going from one place to the other.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Do you want to come back-- what life consisted of in the camp?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I'll tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was shipped to Annenburg.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Annenburg, we were segregating shoes and coats and clothes and also shipping whatever was usable for the Army, for the Germans.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "From Annenburg, I was shipped back to Blechhammer after a couple of months.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "It was the wintertime of '43 and it was so bitter cold.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And we were staying on this [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "[GERMAN] was a roll call place.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "As soon as we get up in the morning-- we'll come to that later.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I went back to Blechhammer.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Blechhammer was a long time there, till the evacuation, January 18, 1945.",
      "word_count": 12
    }
  ],
