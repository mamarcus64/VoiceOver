{
  "stem": "311.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "This was the only time where I was-- and what else would sting-- you know, like once a year, we had to stay on the corners, and give a little blue and white thing.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And the people used to give you a nickel, a dime, a quarter.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "You know, and everything.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Though this was for Keren Kayemeth.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Keren Kayemeth was about the only-- the main organization what you-- you send money to.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You know, I don't know, my mother couldn't go [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "You know, it wouldn't put in the [NON-ENGLISH], you know.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "There was a [NON-ENGLISH] that was Keren Kayemeth-- [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "This was the most important.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Now, there was another one.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Yes, there was a-- there was a charity for girls who don't have a [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I don't know how I explain to--",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "A dowry would be, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And then there was a-- this was a very important charity.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I remember once a big rabbi in [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I went to my aunt, and I had to go to the shul.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And all my cousins are Hasidim, you know, and I was-- and he explained how important the charity is, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, you know, and for a kid-- 12, 13, 14 years, it's kind of funny, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] It didn't get in.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "This has to cook a-- this has to take until you get all that to understand.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They were young people, mostly.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But you know-- like you know, you stay-- you say the honor.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I don't know, to [NON-ENGLISH] of that time.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And then there was-- who was the main from Hashomer Hatzair?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "What was very important?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I don't remember the name.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Not in Krakow.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I'm talking from the originators from Hatzair.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "No, this was the other one.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Trumpeldorf?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    }
  ],
