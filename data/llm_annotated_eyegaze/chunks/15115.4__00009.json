{
  "stem": "15115.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And we were there for a while, and then they start taking us-- spread around to different camps, the whole group of us.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Some went to Muehldorf.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "There was a camp named Muehldorf.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Me, they send me to Waldlager.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Waldlager means 'inside the forest.' This camp was already done.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "It was made up-- it was about 20 in a bunker.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "It was underground, with wooden boards.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And there was covered, like a peak.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Like a tent.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Like a tent, but we were underground.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We were sleeping there.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "There, I was-- again, I was very fortunate.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "As soon as I got down there, they wanted to kartoffelschaler, peeler, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I got down there, and then they wanted two people to cut sauerkraut.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Sauerkraut is cabbage cut them in two, and make sauerkraut.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Make what do you call-- like how do you say sauerkraut in-- sauerkraut--",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Like a coleslaw?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Coleslaw, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But the Germans are very good for sauerkraut.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The German soldiers, sauerkraut is one of the best meals they can have.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And as a matter of fact, when you go eat meat, they have sauerkraut on top of it.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, I was taught how to cut the things.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And they were sending me for awhile in the German house, cutting it and making the sauerkraut for the Germans.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And then I was working in the kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The camp, it wasn't bad.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "It was hard labor.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Very, very hard labor.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They were working baustelle.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "A baustelle is making bunkers out of cement, which the aeroplanes-- aeroplane hangars, but made of cement.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And they call it a baustelle.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Well, I was-- I never worked there.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I always work in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And I was good.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "But this little, it's a [?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Zakiniko ?] [?",
      "word_count": 3
    }
  ],
