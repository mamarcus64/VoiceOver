    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So I says, OK, let's throw it away.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "So my father says, he says-- there's no mother here.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You don't throw things away, because nobody is here is going to give you another shirt.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So he took me to the barrack of his.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And the next day, I joined him on his-- on his workstation.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And he worked in a smelter, where they were melting iron ore and scrap metal, making steel for the real heavy field guns.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "They put in a-- they stuck in a piece of steel into the oven, took it out, stuck in a bucket of water, put the shirt in, and that was how you did your laundry.",
      "word_count": 35
    }
