  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I know it was 1940, before the ghetto was established, where I was doing all this work.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I had never told him that I was doing the work for the PPS.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And [INAUDIBLE], when he introduced me to [?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Anielewicz, ?] he mentioned to him, do not ask him too many questions.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "He is one of us and take my word for it.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And that's how I remain.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "But when later around when I-- after I was caught in [INAUDIBLE] [?",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Pawiak, ?] and prior to the outbreak of the uprising in ghetto, [?",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Anielewicz ?] found out what I was [? on. ?]",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "He had-- he organized a small group of Hashomer Hatzair.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Hashomer Hatzair was a scouting organization.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And his prime interests were to build up a youth group which would be willing to go to work on farm systems in Palestine at that time.",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Without having any hesitation and need of looking for something extra special, but to build a land for the future of the people.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And the group was very, very small, 14 people.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They were meeting on a weekly basis, primarily on Saturday or Sunday, and--",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We were meeting in attics or very remote place, neglected place, in the ghetto, on Leszno Street, spelled L-E-S-Z-N-O.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, [?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Handelsman. ?] There were two people from [PAUSES FOR 3 SECONDS] college, from City College.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They also left the [INAUDIBLE] and came to Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Baharier. ?] I forgot the first name.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "There was [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Benny Rosen ?].",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "A number of these people.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "There was [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Vukovich, ?] there was-- I did remember many more, but I guess with age I'm forgetting.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "People were very young age.",
      "word_count": 5
    }
  ],
