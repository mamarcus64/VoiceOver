{
  "stem": "14091.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we had very beautiful two Seders.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They served the usual Passover, all the trimmings.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And started of course with [NON-ENGLISH] and [NON-ENGLISH] and fish and all kinds of meats and all kinds of wonderful nostalgia food.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I hope in-- very soon.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "In June, we intend to go to Chicago and to see our children.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Our grandchild is going to be bar-- bat mitzvahed.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And we are very, very excited about that.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And some-- my brother from Israel intends to come and family.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So we will all be together again.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My name is Slava Fintel.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "S-L-A-V-A F-I-N-T-E-L.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Cymer, C-Y-M-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born June 30-- June 2, in '30.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Today I am 64.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a small town, Szarkowszczyzna.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was in eastern Poland, not far from Vilna.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name Shmuel.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Lebe.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, we were seven.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I had two brothers, and with me five sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My oldest sister was Dena, my next was Miriam, and then [NON-ENGLISH], Zalman, Celia, Chaya, and myself.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My father was a merchant, and my two brothers were working with him.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My mother had a restaurant, and she worked very hard, although we had help, live-in help, a couple.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But still, I remember my mother working very, very hard.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Our home.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] [SIGHS] I have such a good memories.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] I was the youngest, and it was such a happy home.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "My mother belonged to a organization.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was Bikur Cholim, they called it.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And she used to do a lot of charity work.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I remember we had a very large room and a very big table.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And the table was constantly filled with people who couldn't afford to come to eat.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Our doors were always open.",
      "word_count": 5
    }
  ],
