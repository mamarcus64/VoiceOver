{
  "stem": "26914.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And every child has a number.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "The clothing was with the same number.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "The shoes, with the same number.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "So the children knew where to sit and what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Every child has to do what the rules say.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "If a child wasn't behaving it was a court.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "It was just like a little state.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "We had the court.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "We had judges.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "We have children which rehabilitate, the children which didn't behave.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 6,
      "text": "And every child which had somebody watching him has to write a report.",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 7,
      "text": "And the report was sent to Pani Stefa.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 8,
      "text": "She read it.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 9,
      "text": "If everything was OK, it's fine.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 10,
      "text": "If not, he was punished again.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 11,
      "text": "And he had a court order to behave.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 12,
      "text": "Otherwise he will go out of the house.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 13,
      "text": "We had one case.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 14,
      "text": "A boy was thrown out.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 15,
      "text": "We have paragraphs, which paragraph two says, if A did something wrong to B, the best thing is to forgive him.",
      "word_count": 21
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 16,
      "text": "Because maybe he was aggravated by a family.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 17,
      "text": "Maybe somebody died or what.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 18,
      "text": "And to forgive him.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 19,
      "text": "Then is paragraph four.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 20,
      "text": "If the child did something very, very good, reward him.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 21,
      "text": "Paragraph one, he did a bad thing.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 22,
      "text": "We hope that he will be rehabilitated.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 23,
      "text": "Paragraph 900, it is very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 24,
      "text": "He has to have somebody which rehabilitate him.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 25,
      "text": "If not, he will go out.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 26,
      "text": "I remember only one case, a boy was thrown out.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 27,
      "text": "Otherwise, it was beautiful, just like a country for-- for itself.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 28,
      "text": "Every child had the responsibility.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 29,
      "text": "And every child behaved.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Pani Stefa was a older lady.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "She was never married.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "I think that she met Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "Korczak in Paris.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "And they came together.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "And they start-- he start to build the-- the Korczak home.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "And she was working with him.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Wilczynska, Stefania Wilczynska.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "She came from a-- a nice home.",
      "word_count": 7
    }
  ],
