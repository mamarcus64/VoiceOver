  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Each lot of people, they had to appoint their own leader, and he had to put in the ration [INAUDIBLE] so they got their food.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And they registered the names of the people, and we reported these names back to brigade headquarters.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And they were notified to their respective-- it went down the line, down the channel of communication.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "But the-- [PAUSES FOR 5 SECONDS] It was a big job.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "My doctor established clinics, and we found a lot of these groups of people, particularly from Southeast Europe.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "They had doctors there, and they established their own clinics.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "Of course, we provided the drugs.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And then we had to establish bathhouses, and then, of course, clothing.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And I put a levy on the town of Neustadt, and I well remember the figures.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "I had-- I asked for 5,000 suits of men's clothes, 5,000 suits of clothes for women, all the children's clothes they can find.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "And I'll tell you about that when you're ready.",
      "word_count": 9
    }
  ],
