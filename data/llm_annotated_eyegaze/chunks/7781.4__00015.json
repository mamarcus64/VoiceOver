{
  "stem": "7781.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "He was getting paid $2.25, and I was getting paid $0.75.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "You know, everybody took advantage.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "But I figured, I got to-- I have to pay the price for it.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I had no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Slowly, slowly, but it paid off, because slowly, slowly, I-- I worked myself up, and I learned, you know, the way of life here in the-- in-- when-- you know, slow, it went better and better.",
      "word_count": 36
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "But it was not easy by a long shot.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "So your first baby was born in New York?",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The first baby was born in New York.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "In-- in the New York Infirmary, the women's infirmary.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And they didn't let me go up to see the baby.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "You know, it was-- it was very hard.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "You know, nobody-- by yourself, you don't know the language.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "You don't know, really-- and my family, it's comical.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "My family told me, we lived-- we had the-- we had an apartment building.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And they said, when your baby, when she's going to get ready, call the police.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "What do I know?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I called the police.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Two guys came, two policemen, three.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And the guy told me, it was no emergency.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "So he realized, that I'm a greenhorn, and he said you know what?",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "I'll call a taxi.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "And the hospital supposed to go is-- is New York.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "We lived in Brooklyn, to go to New York.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "So he said, I'll give you-- I'll get you a taxi.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "But you look at the meter, and you pay what's on the meter.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "He tried to educate me.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "So the guy took me to Brooklyn-- to New York, and I left my wife in the infirmary.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "And I went home, because they didn't let me stay there.",
      "word_count": 11
    }
  ],
