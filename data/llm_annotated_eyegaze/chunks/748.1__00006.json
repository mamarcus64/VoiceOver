{
  "stem": "748.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 7,
      "text": "And one day came in a SS man and hold a blanket, and grabbed me, and took me out, put a-- a blanket-- the-- the gray blanket, and took me out, and then, took me in a car back to the-- to the block where I was.",
      "word_count": 47
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 8,
      "text": "And one French girl was between, a young girl, maybe 16, 15 year old.",
      "word_count": 14
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 9,
      "text": "They took her out, too, This way, we survived.",
      "word_count": 9
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that I'm a mischling.",
      "word_count": 5
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "That I-- I'm-- this is not Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "It's not clear Jewish blood.",
      "word_count": 5
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "And then, they started to call me on the [NON-ENGLISH]-- this is to the high SS man-- what I saw it when I was in-- in the [NON-ENGLISH].",
      "word_count": 28
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "A-- a shower, a big room that they pack in a couple thousand people, and they let the water running.",
      "word_count": 20
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "Zyklon came out, the gas.",
      "word_count": 5
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "And there was, on the floor, you know, so much naked bodies.",
      "word_count": 12
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 3,
      "text": "And the SS man came in, and put the blanket over me, and grabbed me, and took me back to-- to-- to the block.",
      "word_count": 24
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Not block-- that of Yoli was the block [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "And she give care a while.",
      "word_count": 6
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 2,
      "text": "And then, I started to go, and they asked me questions.",
      "word_count": 11
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 3,
      "text": "And they tell me right away, you-- where you was?",
      "word_count": 10
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 4,
      "text": "Do you remember?",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 5,
      "text": "I said sure.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 6,
      "text": "I was in the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] But I didn't finish mine bath, maybe a second or two.",
      "word_count": 13
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 8,
      "text": "And Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 9,
      "text": "Hessler come and take me out, because I wasn't allowed-- they call me out.",
      "word_count": 14
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 10,
      "text": "[BACKGROUND NOISE] And this, I went maybe-- maybe three, four weeks, every day.",
      "word_count": 13
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 11,
      "text": "And they asked me the same thing.",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 12,
      "text": "They give me to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 13,
      "text": "They give me nice clothes, warm.",
      "word_count": 6
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 14,
      "text": "This-- this were in the winter time.",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 15,
      "text": "And then, they let me go.",
      "word_count": 6
    }
  ],
