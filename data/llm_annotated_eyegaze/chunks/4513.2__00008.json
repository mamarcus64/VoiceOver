{
  "stem": "4513.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "That was also a case-- I shouldn't say that, because there was also a book that my mother had me read about some Jewish fellows who had-- a Jewish author had written a story about some people in the South who were Jews, who had been discriminated against.",
      "word_count": 48
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "She had-- my mother had talked about a lynching that had occurred, in Marion, Indiana, where three black fellows had been killed.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "There was a lynching in Indianapolis that nobody really talked about it.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "They hung a black fellow to the Catholic church cross up near my house.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And I saw him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So we knew about segregation against blacks.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Because we never came out of our community.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I never went downtown to the movies.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I never went downtown.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "None of that.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "All that was off limits to us.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We had, we had our own movie in our own community, a little movie house that we went to.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Indianapolis.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Purdue had the same--",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Same problem.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "But Purdue didn't have a special place.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Purdue, for instance, Purdue had one elementary school that was all black.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And that was the only school that black kids went to at the elementary level.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But they went to Lafayette Jeff, which was a major high school.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But the high school was integrated.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Because there weren't enough black kids to build a separate school for them.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "So they went to school with the white kids.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Except that they didn't-- we couldn't-- if we went to the movies, we had to go up the back way and sit at the balcony, the second balcony.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Because we couldn't sit anywhere else.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I was a teenager, a young teenager, I went down-- I remember once downtown, I was attacked-- well, chased-- by a group of white boys.",
      "word_count": 27
    }
  ],
