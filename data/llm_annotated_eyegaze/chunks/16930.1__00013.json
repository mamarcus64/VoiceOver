    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They just-- I don't even know if they really knew what a Jew was.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I don't think-- know if those kids had-- maybe there were a couple of people who had really experienced anybody being Jewish, you know, had that knowledge and experience.",
      "word_count": 29
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Maybe one or two of the teachers had.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I don't recall any-- any of that specifically.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And-- and these were good people.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they were very good, decent to me.",
      "word_count": 8
    },
    {
