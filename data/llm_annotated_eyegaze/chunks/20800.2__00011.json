{
  "stem": "20800.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 5 SECONDS] At night, I feel-- I couldn't sleep for 30 days, as long I was there, because I was a frightened to scream out I'm a Jew too.",
      "word_count": 31
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "[SOB] So I was frightened.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "I couldn't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "I was a frightened to sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "As soon as I dream I was shaking like this.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I was 30 days in Gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Last time they took me down there, they called me in-- in head office, and told me that they give me a sentence of life in concentration camp.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I will be sent next day to the prison, and from prison to the concentration camp.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Next day, they took me to prison.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I was in prison, I think a month.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And from the prison, I was sent in concentration camp, Vodokachka.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Vodokachka was not far from Nikolaev, maybe a few kilometers, I don't know, maybe 100 kilometers from Nikolaev.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "It was-- it was still [SIGHS] summer.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "July, about July.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "'43.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Daily, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "If not physically, verbally.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And one time they-- they screamed, you a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And they knocked me, one SS come and knocked me with a big ring.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "This I've got still here.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "He said, you're a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "So they said, repeat.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "[POINTING] [NON-ENGLISH], This is her-- she's going.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
