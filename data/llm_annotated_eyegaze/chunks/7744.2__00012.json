  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And she did for me everything.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "She was wonderful, but I didn't appreciate it.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And I maybe didn't realize at the time, as I realized later, that they weren't able, financially, to do for me what I would have-- what I thought was coming to me, even.",
      "word_count": 33
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "They just weren't able to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "They lived in a-- in a little place.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "They worked hard.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "They didn't travel.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "They didn't do things for themselves.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And here comes this young kid and wants this and that, and there's no piano in the house.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "What kind of house it is without an instrument?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Without-- without-- and of course, Canada was without theaters and without-- without anything culturally sort of uplifting at the time.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And-- and I was disappointed.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I think we'll stop at this point.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
