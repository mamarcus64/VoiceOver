{
  "stem": "19939.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So all of these people--",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "All of these people--",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "--without papers, were rounded up.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Were rounded up, and my father-- this was the first aktion.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My-- my stepmother was working.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They took my father too, and the two little, her children, the two step-children, they were at that time probably five and three or something, or four and six.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "She took them, and they were in some-- some such a godly place, right.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "It a big thing.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "We-- I never saw it.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "The gestapo had a little, like a table set up.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And everybody was coming with their papers.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And it was already this rejection, like in the camps.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "I didn't see it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "I was told about it.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "Because I was home.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "Whoever can stay, whoever--",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So she took the children, and she went to this place to plead with the gestapo for the father, to my father, to something.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And when this gestapo saw their little children, they were blonde and blue eyes, really Aryan or something like I saw in Sweden.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So he picked them up and he, said, oh children that look like this deserve to have a father.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And they were able to take my father back from this-- this-- this-- this-- platz, whatever this was, home.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And I've heard later that my grandmother and the son and the daughter-in-law and the daughter had to leave.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They left behind, without our knowledge, the little girl.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "The mother left her, you know, that we should take care.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Because she knew that we were staying.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And I was told later that old people were taken on trucks, and they were taking them to the mountain.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We were already in the Carpathian mountains.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "This was the south of Poland.",
      "word_count": 6
    }
  ],
