{
  "stem": "12003.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And then he came out, and my mother prepared us that we have to go back home.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "That was in about 1939.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Helena Splivinska--",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "--her maiden name.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "She was born also in Poland, Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "She was very young.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "She married when she was 16.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So she was very young.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "She was very progressive.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "She gave us a lot of freedom.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "She bought us different type of toys that would stimulate curiosity in our minds.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And then, I come also from a larger family.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "So we had like our own kindergarten.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "My mother had seven children altogether.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "There was Freddie, my older brother.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I was the second, and my name is Frances.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Then there was Eva, Paula, Genya.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "There was Henry, the youngest one, that died in a camp.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And then I have a sister Julia, that was born after the war.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] Three.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Eva, Paula, and Genya.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] I think they were nine, seven, and five.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Because we were two years apart from each other.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "To that point, it was fun.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I sort of always took charge, because I was the oldest from the girls.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So they looked up to me, and we played together.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We tried to make clothes for the dolls.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And I remember one incident.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "One of my sisters took her scissors and went to my mother's closet and cut a piece of one of her beautiful, beautiful dresses, because she loved the material for her doll-- to make a dress.",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And I wasn't, I guess, smart enough to stop her.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "But I remember we were all punished because what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Still, my mother would never hit us too much, or-- or punished us.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "She sort of punished us in a sense-- don't ever, ever go into my closet.",
      "word_count": 15
    }
  ],
