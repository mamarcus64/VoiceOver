{
  "stem": "26359.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "More or less, or less, maybe a few, less than a week, not too long.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "When I was in the street in Dubno, I saw.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was written on the walls.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We need people to work for us in Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Young people from the age of 16 and 30, something like this, should register.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We're giving so many good things in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "We'll give them all benefits and so forth.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Even I read this, I figure-- it went into something in my mind, if I'm going to Germany, of course they wouldn't know.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "It wouldn't be people from my town.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And maybe that way I'll be able to work.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And I'll be sitting there working, and I'll save myself, and I'll survive.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "That's what I got it.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So it was written where I should go for interview.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "When I wet to that place to interview me, I of course, I told them-- first of all, I showed them the piece of paper from the German commander.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And then I had my baptismal paper.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And I said, I have a brother, I said, already working there.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I'd like to go to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I would help them, and so forth, and so forth.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And so they registered me.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They gave me a slip.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "They said, tonight, at 8 o'clock, the train will leave for Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But you have first to go for a medical commissions that is to see if you're OK, you're not sick.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Some people they couldn't accept.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "So after I was pronounced OK, I wasn't sick, I was healthy, and I wet.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "This was on June 8, I suppose, or June 1.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "June 1 I went to Germany-- that's right-- with I believe must have been a few thousand people in the train.",
      "word_count": 21
    }
  ],
