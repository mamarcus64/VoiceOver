  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And the baby was-- I made a bed, some pillow for something that slept in.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "So when we came home, the baby slept between us.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "Chaim built a bed, and the baby slept between us.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "It was so cold there.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "So we didn't have-- the wind came over.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So one of the Polish Jews who lived there gives us a-- but got something back, perhaps-- give us a feather bed.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "But in this feather bed were fleas.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And then at night went to bed, these fleas come out.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And I was-- it were [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He didn't have the problem.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I had the problem.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "The fleas came all to me.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "So finally, we got also a bed.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Chaim made a bed.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And now we got also a little feather bed for the baby, or something like that, finally.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And then Chaim started traveling far away for five, six weeks at a time to places where the Germans pull away, and to buy some soils, buy some materials, to make a living.",
      "word_count": 33
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "How can we make a living?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "We've come to the end of this tape.",
      "word_count": 8
    }
  ],
