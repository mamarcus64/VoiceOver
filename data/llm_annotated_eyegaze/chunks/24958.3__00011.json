  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And they found a violin for him there.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And they played together.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And they got to talking.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "So Henry said that he has a brother in America which went there in 1939, to the Polish-- to the World-- World Fair in-- in-- in New York.",
      "word_count": 28
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "But he doesn't know his address.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "So Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Morse says to him, what-- he's-- he's a pianist.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "He's a-- so the father of Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Morse was also a musician, and he belonged to the musicians' union in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "So he said, I'm gonna write to my father, and my father is going to find the address of George Rosner in New York.",
      "word_count": 24
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "And that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "And that's how we contacted my husband's brother, in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And he sended us affidavits.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And in-- in May-- on the 24th of May, 1946, we are landed in New York.",
      "word_count": 16
    }
  ],
