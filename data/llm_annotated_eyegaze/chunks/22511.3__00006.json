  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So they ask me what I wish to do, before I die.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I said, I have a little sister.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Her name is [?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Olania ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Hanoshac ?].",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We had, we have been there not as sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I, my name was Wolodimira Billa, and her name was [?",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Olania ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Hanoshac ?].",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I was in a little town called Jaktorow, and we wasn't-- we was not supposed to tell anybody that we're sisters.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Only before I die-- before my father let me in to the-- because that's all my father arranged.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "He told me, remember, you're a Jewish girl, and you're older than [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "You must make sure that when the war finish, you have to be Jewish, because you are born Jewish.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And this-- Daddy's words were very important for me, [SOBS] because I loved my family very much.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Every word, I try to remember.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And I wish to-- I told the nun that I'd like to see my sister.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "She is in Lemberg.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Her name is [NON-ENGLISH] [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Before I die, I want her to see me.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And they did send her to me.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And I told her, and she was very, very religious.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "She said she will never be Jewish. because Jewish people got first big [PAUSES FOR 3 SECONDS] [NON-ENGLISH], and this, to be Catholic, is much better.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And she doesn't want to know about-- anyway, I told her, remember, that's what Daddy wants you to be.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "If I be not alive, you must remember that you become-- you come from a Jewish family and try to keep it going.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And they send me a priest.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "And I, I had a [NON-ENGLISH], this is special beads.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "You go around, and you pray every day with it.",
      "word_count": 10
    }
  ],
