  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He said, if he can get me in the-- there was a famous textile academy in that town.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It was about 220, 250 kilometers away from-- from Bratislava.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "If we talk about 200 kilometers, it's different like here because it's a huge distance, right?",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "You travel four to five hours by-- by a fast train.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So he went there.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Before the school year started, the last week before a new school year, he packed a suitcase-- or my mother and father-- and they-- he took me on the train and brought me to this town of Brno, which was the seat of a much larger town that was the center of the textile industry in the middle of Czechoslovakia.",
      "word_count": 60
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And he-- he placed me in care of his friends, of this friend who arranged the enrollment in the textile academy in Brno.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I must mention, maybe, that the textile academy in Brno was one of the best in Europe.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "There was only other one which was equal-- that's what they said-- in Manchester, in England.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "Because Czechoslovakia, the-- the second largest industry was textiles, all right?",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And that was the-- the-- Brno was the-- the-- the center of the textile-- wool and cotton-- industry.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "So when I was brought there, like in exile, of course, you can imagine I wasn't very happy.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "The friend of my father enrolled me in the textile academy because it was very difficult to get in.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Only with connections-- only the children of textile manufacturers and-- and similar had the-- the ability to go there normally, because there were maybe 25 to 30 students per class, and there were only two classes to begin with.",
      "word_count": 39
    }
  ],
