{
  "stem": "9601.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "You know, back, looking back, every time somebody came, got a bigger beating.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "You know, broken noses, smashed up teeth, smashed up lips-- and when they threw them down the stairs-- you know, broken arms, broken legs, they were not actually broken, you know, they didn't dangle.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "They were cracked, because those people became, you know, cripples for the rest of their life.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So we went to see, you know, what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "All the kids went there.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So I'm not [? a next-- ?] you know, why shouldn't I go?",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And I went to that-- to that-- to that chute, you know, that potato chute.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "My father said, tell your mother to contact the [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "The Baranchuks they were another branch of the intellectuals.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Whatever it meant, I ran home, and I told my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if I even told her, maybe she was already on the road.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I came home, and I know my mother went and picked up her sister Eva.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Eva was the oldest daughter because all her brothers were there.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "All the men were there except teenagers-- you know, 13, 14 they didn't touch.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "But everybody about 13 or 14 ended up beaten up, bloodied up in the basement.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And the-- and my mother and Eva, her sister, they went somewheres.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Meantime the wagons were standing there.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "You know, meantime, there were couriers going back and forth.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Not Jewish couriers, the other.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "The women were summoned to come to that inn.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "There were latrines because, you know, people used to have dances there, and beer nights, and all kinds of things.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "First they hitched up a horse, and they smashed up the latrines.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "The women had to empty out that-- the latrine or the pits.",
      "word_count": 12
    }
  ],
