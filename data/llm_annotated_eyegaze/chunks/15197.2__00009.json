{
  "stem": "15197.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "That because I look like a Polish girl, there are a few others on the other side of the wall-- on the other side of the ghetto wall-- to get out and to walk in the underground on the Polish side to try to prepare, to buy on the black market guns.",
      "word_count": 52
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Whatever is possible.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And also to prepare some hiding places for children, if it's possible there.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "To find out.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And this is how I got out of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And I recall it was a big meeting in November, 1942, from the youth group of the Bund.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "And they were talking at that time about the organization which was formed, the Jewish fighter's organization, and the involvement and our responsibility that when the Germans will come to take us out from the shops, to stand up, not to go.",
      "word_count": 42
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "Whatever it is, to give a resistance.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And at that time each of us have got some assignment.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "I didn't get any assignment, and I felt very low that the only person-- it was a group of 28 or 29 people, young people-- and I felt really bad.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "But when everybody already start to disperse, their leader was at that time of this group, Abrasza Blum, came over to me and told me that your assignment will be different.",
      "word_count": 31
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "That you will not remain in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "Somebody will come and give you some information later on.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And you will get out of the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "The assignment will be on the other side of the ghetto to do the utmost for the fighters organization.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "And this was my assignment, how I got involved in the fighters organization.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Abrasza Blum was the leader of the Jewish Bund group.",
      "word_count": 10
    }
  ],
