{
  "stem": "1775.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 222.0,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 77,
      "text": "And they made a ghetto, and they pushed in all the people in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 78,
      "text": "And then they started to bring in people from all around again, from different little towns.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 79,
      "text": "They started to bring in the people.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 80,
      "text": "And people were coming by themselves, too.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 81,
      "text": "And three weeks later, again the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 82,
      "text": "You got to come on the marketplace.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 83,
      "text": "So we all went again.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 84,
      "text": "But since I was working, I had a permit to work.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 85,
      "text": "And anybody that had a permit to work was allowed to go to work.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 86,
      "text": "And the, the elderly people and the young children, they all went on the plaza.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 87,
      "text": "You never heard about them.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 88,
      "text": "They all just disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 89,
      "text": "And now we know where they went.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 90,
      "text": "They all went to the concentration camps to get killed.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 91,
      "text": "I think the first people that went from Miedzyrzec, they went to Treblinka.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 92,
      "text": "And that-- and this was September, October.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 93,
      "text": "Then it was a little quiet until they got a lot-- a lot of more people together.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 94,
      "text": "Then they took out a bunch of people to the cemetery and killed them on the cemetery in-- they are all there in mass graves.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 95,
      "text": "Then they brought some more people.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 96,
      "text": "Always, they kept bringing more people from the adjoining towns and the different places.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 97,
      "text": "And at that particular time, there was already-- November, I guess-- they decided that wherever-- women and children have to go.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So I was in hiding for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I didn't even want to go to work because I thought that when I'm going to go to work, they're going to just grab us.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Because that's what they did.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "If they didn't have enough, they just grab you.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "So I didn't go to work.",
      "word_count": 6
    }
  ],
