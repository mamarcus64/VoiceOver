{
  "stem": "268.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "My father, by that time, was almost skin and bones.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "How did you get to Camp Dyhernfurth from Karvina?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We again, we were marched to the railroad station and counted.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Put in boxcars.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Destination unknown, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So many to a boxcar, shut the door, closed.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Except this time, there was an SS man.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I'm pretty sure, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And he kind of had a blanket.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "He took space in the center.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And on the blanket and some stuff where he could lay down.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And put his gun down.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And he was in charge, kind of watching out for us.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And it was pretty cramped, but not as cramped as the first one that we went from the assembly place.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And after about a night's ride or so, we arrived the following day into this Dyhernfurth.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And again, assigned to barracks and the same detail again, being counted.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And the next day, report to so-and-so detail and go to work.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And mixing of concrete or carrying bricks, and we're building something.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "I had no idea what we were building.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "As it turned out, we were building more barracks, which I later found out living in, in those barracks.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "So that was my second camp.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "This camp?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Very sad memories, because this was the camp where I finally got separated from my father.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "That was where-- they liquidated that camp.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They sent me to another camp, but they didn't take everyone.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They took the younger people and able-bodied.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And my dad was already down on his weight.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I remember a man of-- he was of medium height, maybe 5'5', 5'6', perhaps in kilos maybe 130, 140 kilos.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "In pounds we're talking about-- I'm sorry, 60 or 70 kilos.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Maybe 140, 150 pounds.",
      "word_count": 4
    }
  ],
