    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I came to Kharkov and start another story.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And we must find a place to go, from Kharkov, another places, yeah.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "There was all kind of people, what we were--",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
