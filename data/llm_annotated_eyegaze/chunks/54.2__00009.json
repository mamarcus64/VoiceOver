{
  "stem": "54.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "When the Americans came in and open up the fence, and we were all of us like a bunch of sheeps, one fell on the next one, out from the camp.",
      "word_count": 31
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So in-- and the Americas came in.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He says, what about this guy?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Says-- we told him not to do nothing to him.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He saved our life.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Otherwise, he would be-- we wouldn't be here anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They took him, took off his belt, took off his-- his gun.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And they took him with them.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Where they took him, we don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But we open up-- they open up the gates.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "We run out from the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "The Americans said, now, all of you, behind us.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Walk in-- walk with us.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "They drove, you know, on the motorcycles and on the Jeeps.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And they took some girls on the Jeeps, whoever.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "The rest who couldn't-- who didn't go with them, we walked behind them.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "They took us into the camp where they were stationed the-- all the American soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And they said to us, we know you're hungry.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "You thirsty-- you're thirsty.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "You have no clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "We had only one uniform.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "We have to wash them at night, in the morning, put them on.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "Even sometimes I put my uniform on when it was stiff from when it was winter.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "It was stiff from the-- from the-- you know, from the cold-- from cold.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "It was freezing.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "And I put it on on me because I didn't have any other one to-- to put on, so I had to go to work.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "And I'd put it on.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "It was wet.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "And-- when-- when I put that it on, it was wet on me, and that's how I went to work.",
      "word_count": 20
    }
  ],
