  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "When you say a prayer that you understand what you're saying.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "That can come from your heart, not only from the mouth.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes, ma'am.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Well, to start being a tailor, it's very, very hard, because my father had to pay the boss to take me in, just to occupy a chair for me.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It had to be paid.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "On top of that, I didn't got paid for three years.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Only, you know I worked.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I started working where they teach me, you know, how to do this and how to do this.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "But later, when I was good, after a year time, when I worked already as a tailor-- so my boss liked me very much, that he start giving me lunches.",
      "word_count": 30
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Mind you, start giving me lunches, but I didn't have to come home to eat lunch.",
      "word_count": 16
    }
  ],
