  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "We had love-- it didn't matter.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Everyone had the same love, all the child, the oldest to the youngest.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In this time, it was beautiful.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "We had three rooms, [PAUSES FOR 3 SECONDS] and we had a beautiful-- see, over here, the living room, over there, the beds was in the-- in the living room.",
      "word_count": 30
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "It was a lot of pictures, and we had beautiful furniture in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And then was another room where we sit and eat for supper, and a very beautiful kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And there were six children with a grandfather and grandmother.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "We were eight, 10 people.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And a lot of people were sleeping on the floor too.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "My father and my mother slept in the big bed, then my two brothers slept in the side beds.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I was sleeping with my sisters, and my grandparents would sleep in the kitchen.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Look, this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "They were very nice neighbors.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "No complaint [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "It was a long time.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I finished public school, seventh grade.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I started seven till 14.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The rabbi came to the house.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "He taught me how to daven, when to-- you know, just like that.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Like history, geography, and Polish, and writing, reading.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "You know, one hour a week, we had religious-- a rabbi came in, a teacher, and taught us, you know, Jewish things.",
      "word_count": 22
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Just one, but, you know, what's her name?",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] She was hiding me.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I'm blank.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we went together, Jewish and non-Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "There were Jewish schools separately, but I went with them together.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Was no problem.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "There was no problem.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "It was OK.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Not-- not too bad.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Not too bad.",
      "word_count": 3
    }
