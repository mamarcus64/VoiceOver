  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "How you know that's a change?",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "Well, in 1939, I think the first week in September, the German armies attacked Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "The planes came in and start throwing bombs.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "So the start bombing our city.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "First we heard on the radio.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "Warsaw was bombed.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "Krakow was bombed.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "Next day, planes came in to our city and throw several bombs.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "Damaged a few buildings.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "And before we turned around, on the third days, the Nazi armies marched in and occupied our city.",
      "word_count": 18
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "And after several days, we heard that the whole country was occupied by the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 9,
      "text": "So it didn't-- so they didn't have much trouble to occupy Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 10,
      "text": "They came in from all around Poland.",
      "word_count": 7
    }
  ],
