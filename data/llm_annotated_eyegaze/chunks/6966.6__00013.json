  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "They want to stop me and my passport because I hadn't repaid them and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Well then I left France.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "I got my papers from France.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Oh, they're so particular.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "Through Belgium, very slowly, the trains into Holland, and I stood in front of the house where I used to live on the 10th of October, 1945.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "I'd been away three years and two days.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And I saw a young man on the streets.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "This was in evening.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "I said go there and there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "It's Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "Greenman.",
      "word_count": 1
    }
  ],
