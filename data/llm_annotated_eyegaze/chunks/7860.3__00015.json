{
  "stem": "7860.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Backed the Polish resistance to join forces with the Jewish resistance when they had the Jewish uprising in Warsaw, the ghetto uprising.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "It was the Polish uprising that took place one year later.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And I got myself caught in the Gentile Polish uprising.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "How did it happen?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I went to get some candy charms.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I got off the railroad station, the main station in Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I bought my supply of candy charms.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "As I'm trying to get back onto the train-- this time Warsaw was very strict.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't easy to sneak into the platform without getting at least a ticket to the nearest station.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "As I walked over to one window, two windows, three windows-- all manned by men.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Usually women would be at the ticket one.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They didn't answer me asking for a ticket to the nearest station.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "All of a sudden, I heard shooting going on.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I heard shooting going.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I look outside the station.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And there are men wearing white and red armbands, and shooting at Germans, Germans shooting at them.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And I run out of the station.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And I seen a street car loaded full of people.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And the only room was on the step.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "Everybody is hanging on the one step into the little streetcar.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And I hang on to body handle and the streetcar left Warsaw, outside Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And as it came to the outside outskirts of Warsaw, I seen a bunch of Polish people with their hands risen up in the air.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And held at gunpoint by Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And the streetcar was stopped, and everybody [GERMAN]-- it means, everybody out.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And they told everybody to disembark.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "As everybody was disembarking from the streetcar, I was squeezing myself deeper into the street car.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "I sat myself down next to the driver.",
      "word_count": 8
    }
  ],
