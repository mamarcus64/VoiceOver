  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I had my cousin's daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I had some family.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And I will take all your family.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I say, I am afraid-- turned around and left.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "After liberation, I am meeting-- I went to a Dr-- Dr.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], who was also in concentration camp-- in main camp, Kaiserwald.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "There I meet another widow of a doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And when she heard the word, Klebanow-- [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She said who said always my friend Klebanow-- Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Klebanow?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "I say, if somebody, it must be Blatterspiel.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "She say, yes, Blatterspiel very frequent to [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "She were-- went with these 400 woman.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He will always repeat, my friend, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Klebanow.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "The-- two days before the Russians, he send away all the guards.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "One day before the Russians, he told-- gathered them-- first-- the 400 people-- please, don't show up in the windows.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Nobody has to see that-- that you are here.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "It was a camp, camp with-- with barracks, and et cetera.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Don't show up.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Tomorrow are the Russians here-- turned around, and left.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Basically, he saved their lives, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Or in other places, other places there are-- it was the most brutal cases was a place [NON-ENGLISH], where my friend Dr.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] perished, where the SS put the-- commanded them to put the wood, and to lay down, and then to kill them.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And so, what-- whoever was in-- in the-- in the camp, you know, they killed on the-- on the wood.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They burned them.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, no contraceptive devices.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The women basically lived in the-- in women compound and the men in men compound.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in the-- I have a small revere.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It means a small hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And the-- she-- my wife was with the dentist of this-- we-- I had a dentist.",
      "word_count": 16
    }
  ],
