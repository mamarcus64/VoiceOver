{
  "stem": "5761.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] They owned a factory, and a lot of fields, you know, and thousands of acres.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Matter of fact, he was one of the wealthiest people in the area, and he used to be the main employee in the area.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS] And he was also the president of the Jewish community in the area.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "About 600 Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I would say the majority was religious.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We used to have the main shul and two smaller shuls-- which naturally, we were there 1989, nothing was left from the shuls.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The main shul was a very large shul, I would say, between 25, 30 foot ceiling-- beautiful shul.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I would say there-- they had a beautiful-- you know-- decorated and-- and I naturally, I used to go to shul every Saturday, and including-- I used to go during the week, too.",
      "word_count": 34
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I went with my wife, with my sister, my nephew, and my cousin, and her brother.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But in Poland, we were not all together.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Like, me, my wife, and my sister, and my nephew, we traveled together.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And they travel, you know, a different direction.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "But we met from time to time.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Lumber boards.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was building homes.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He was supplying the logs for the railroad.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "In any kind of lumber that you could think about it, he was producing.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And he was bringing in the trees, the logs, you know, from his own forest-- and quite a large business.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And he also put his two children, the two daughters, in the lumber business in different towns, after they got married.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We have-- we had the largest house in-- in town, which-- it was a four story house.",
      "word_count": 17
    }
  ],
