  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Did I ever go back to Germany?",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I have-- I wished him well, but, unlike my brother, he would like to go back to Chemnitz.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "But I have no intention of going back to Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "When I flew to Israel, I felt a little, how should I put it, a little pressure on my chest when we flew over the damn place.",
      "word_count": 27
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "But no, I didn't go back.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I mean, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] The British are a strange people.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We, my brother and I, love England very, very much.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Whenever we can, we go there.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And I could tell you fantastic stories about individuals, who went far out of their way to help us, be good to us.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "We-- we-- you know, I got a very good position from the refugee camp, from a group of local people who collected money for this purpose.",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "They didn't even bother to tell me they were a Christian-- a church group.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Didn't even bother to tell us, let alone trying to convert us, or something.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I could tell you that at great deal.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "But I can also tell you that, particularly British [? in ?] authority, you know, [? the priority-- ?] not the police officer on the beat, but the police inspector, or the undersecretary of state, or some [INAUDIBLE], you know, they can be about as, I don't know, stiff, and-- and-- and inhuman as you can get them-- now, wait a minute, this was going to be an answer to your question-- oh, yes, what happened in England?",
      "word_count": 78
    }
  ],
