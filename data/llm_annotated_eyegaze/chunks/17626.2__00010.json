  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "That was [PAUSES FOR 3 SECONDS] like being born at the age of nine.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "It was-- [PAUSES FOR 3 SECONDS] stores with toys.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "We played in Russia with broken china pieces, you know the floral dishes, and they had little-- little flowers on them, broken pieces of China.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "Those were the toys.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "And collecting them, you know, and trading them, that was-- what other-- we used to put together like this the earth, and make rooms in a house.",
      "word_count": 27
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 30,
      "text": "It wasn't anything tangible.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 31,
      "text": "It was just there came a wind, and you had no house.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 32,
      "text": "You made it all over again.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 33,
      "text": "You know, but these were the toys.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 34,
      "text": "Here, walking on the street, running back and forth from side to side, not paying attention to cars, not paying attention to street cars.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 35,
      "text": "We didn't know what they were.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 36,
      "text": "And seeing food stores.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 37,
      "text": "And seeing, you know, meat hanging, cheeses looking in the window.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 38,
      "text": "Two wild Indians, two-- our mothers couldn't contain us.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 39,
      "text": "We were-- [LAUGHS]",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We got-- I mean, all this time in Russia, in Russia you go behind the barn, or you make from the sunflower stalks.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "You know, in the summertime you tie them together for a little privacy.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] We got an apartment in [?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Walpshich. ?] And I thought they were really uncivilized.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I mean I really thought that was-- that, that was the end.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Can you imagine being too lazy to go outside?",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "They had-- they had special places in-- in the house-- in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Magic, with a turn of the handle, switches where I remember with, you know, turning not up-and-down switches, but with the turn of the hand, lights came on.",
      "word_count": 28
    }
  ],
