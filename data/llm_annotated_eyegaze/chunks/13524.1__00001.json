{
  "stem": "13524.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She was separated from her husband.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "There was another uncle-- a younger brother with a wife and three children.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We were very often together, especially on holidays.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "My two aunties lived in the same house.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "It was a family house belonging to us.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I even remember my grandmother was living in the same house.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And unfortunately, she passed away before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "But I do have recollection of her stature and the way she spoke.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Very much like my father-- tall, very distinguished-looking lady.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my brother did have bar mitzvah.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Very vaguely, I remember it was celebrated in temple.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was very close to Hebrew Gymnasium where he used to attend.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And so did my sister, and she completed Hebrew Gymnasium before the war.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "That's where we celebrated his bar mitzvah.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I went to school in Podgorze.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "First few years I went to a school called Jadwiga Dabrowska-- Dabrowski-- it was called Dabrowski school.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And later I went to Henryk Sienkiewicz school, in Podgorze, very close by.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, the first school was very pleasant, very small, and I got on very well with the teachers.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I liked them, and they liked me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And, I would say, because of my height, they very often allowed me to look after the class while they were busy in office or doing something, which sort of pleased me.",
      "word_count": 32
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But later on, when I went to Henryk Sienkiewicz school, I have less pleasant memories.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, one of the school teachers-- it was a very impersonal school-- larger.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And the girls were less known to me.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The school was [PAUSES FOR 4 SECONDS] close to where we live, and yet perhaps one or two girls I was friendly with, and I did miss the friends from the first school.",
      "word_count": 33
    }
  ],
