{
  "stem": "3928.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 29.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK, I witnessed interrogation, but not to such an extent.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I witnessed interrogation when people were forced to tell him this-- the interrogation I witnessed, they were mostly money, wealth.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Where is your money?",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Where did you hide your wealth?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Where is the-- your gold?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We know you were wealthy.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "You tell us, where is your money?",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Now, if this was a-- the policy, official policy, of the-- of the SS or this was a personal question from this certain officer, I don't know.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "But I seen this, for instance.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And they-- actually, what they did-- they bring in the family of the man.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And if they have a small child, they told him, if you love your child.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "I give you five minutes.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Either you tell me where your money is, or your child will be dead.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I heard this.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was there.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The man said everything what you want to know.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "People-- the next time I was there, people were telling people about hiding pieces.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Fortunately, nobody know about mine.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "But people said, that they look for a certain person, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "We know you know where it is.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "You were friends.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "We have to find him.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "Where it is?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And I says, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "He said, we know you know.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "We want you to-- They brought his wife in.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "And they said, do you want to know this-- we take your wife out and gave us pleasure?",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And the man said, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "I don't know nothing, absolutely nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "He said, take her out, OK?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And whatever happened to her, I don't know, because I left in this point.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "And I don't know if the man really know where was their friend or what they did to his wife.",
      "word_count": 20
    }
  ],
