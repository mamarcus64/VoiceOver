{
  "stem": "18520.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Anything she cooked was out of this world.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And my daughter-- you're going to meet my daughter, as sweetest person you ever can see, and she's number two from my mother.",
      "word_count": 23
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "She give away everything what she has, didn't care.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] In our house, in this building was not Hasidic Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I lived [NON-ENGLISH] 9, this was the street and the number of the building.",
      "word_count": 14
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "In [NON-ENGLISH] 7, one building on the side there, was a wooden building.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Over there you had 90% Hasidic, 90%.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "And a matter of fact, I still have a, a friend in Israel, although I saw him-- say, what year was it-- that I did a lot for this man in the camp.",
      "word_count": 33
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Well, I'm, I'm, I'm going to get off track in the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "You needed a partner in the camps.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "If he finds something to eat, he shared with me.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "I, I organized something, they used to say organizing something.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "If I found something to eat, I didn't eat myself.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "I shared with him.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "And he came from [NON-ENGLISH], [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Now he came from a, a religious home.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "His father is a shochet and a rabbi.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "I used to go even to him to learn.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And oh, religious, payos, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And the [NON-ENGLISH] payos.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "And we were kept together.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Not bad, not bad at all.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "It was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Because we all were like, even if you don't have the payos, but you eat.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "They used to say-- but they knew too what you're eating, even the whole building.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "They know each other, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "So they knew what you're eating, who is your father, what's your father doing, how you feel.",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "But everybody if not religious, they ate kosher food, they had good butchers.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Dror Habonim.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Dror Habonim.",
      "word_count": 2
    }
  ],
