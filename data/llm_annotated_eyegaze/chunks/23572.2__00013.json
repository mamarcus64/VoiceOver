  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "And we took the train.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "And then I went to the transport to Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "My mother and my brother stayed-- remained home.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I think in 1943, I heard-- I didn't hear from them anymore.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I-- as a matter of fact, I, I heard, after the war, that they were taken to the ghetto in Riga, Riga, Latvia.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And that, that-- because I met somebody in Israel who knew my brother.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "He went to school with my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And he said he was there.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "But he was transferred to, to Buchenwald.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And he saw my mother and brother.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And he said they, they were there.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "And then the whole ghetto, before the Nazis retreated, was, was, was eliminated.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "They exterminated everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "I inquired there, went through the Red Cross and the Vatican, and everything else.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And it was confirmed that-- but I have no proof.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "I have no death certificate, no-- nobody knows where they're buried, what happened to them.",
      "word_count": 15
    }
  ],
