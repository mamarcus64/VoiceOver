  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Here is nobody but me.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And as I cry and I see, and they told me this story.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And I say, OK, you see for yourself.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "You see me.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "You see me two eyes.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "Just because you was thinking I'm killed.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And nobody Jewish people here.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "Nobody's here.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So anyways, say to me, they-- they going to catch you.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And so you know, I'm not coming anymore after you.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And he told goodbye.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And then he came.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "The next day, the Polish people was killing him.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Then she came to me next day, up in the field.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They told me, do you know, Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Steinberg, you killed mine husband.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Nobody care about that you know, that I was still, I really didn't have place.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I decided anywhere I'm going to get killed.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "How much I can keep and to-- to-- [INAUDIBLE] to dead that to-- you know, to lying him and then tell-- tell, maybe, would go after every time-- every minute, coming to see however many we got-- we get now.",
      "word_count": 40
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "They told us the front is already near.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "The Russians were already near.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And I was over there till the end.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In this particular place, the last place, I was 18 month.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "No, of this place I was nine months.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it was-- I was-- it was a hole in middle the field.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "In the time when I was digging this, I was digging this place-- with [INAUDIBLE] permission.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He told me, out there in the field you can do everything.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Of this place I dig another hold, digging out not two week.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "But I know I-- I can't make enough-- digging out a hole in-- in one evening.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I dig up the space small.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And over the top, on the ground, I put long wood.",
      "word_count": 11
    }
  ],
