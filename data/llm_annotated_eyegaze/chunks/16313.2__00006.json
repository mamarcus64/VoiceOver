  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I like this stuff, and I--",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It's not a bazaar.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It's a store.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It's a store with all kind of items.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And you got to do with some items-- we got to do with-- what you got, I need it in the-- in the house?",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not, no, in the house, but you need some instrument, knives and this, and all kind of things besides-- besides this porcelain, all kind of porcelain.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Ceramics, all kind of porcelain.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They like this, and I got the shelves with this.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "My own business.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Probably I was about 25 or something. 24, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "So I got my own business.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I make some-- I make money over there, making for Citroen, because I was-- I was a technician in welding, electrical welding.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And they make-- we make the bodies.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "The motors came from French, from Paris, some places, and the bodies was done in-- in-- in Warsaw, all bodies by specification.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I was the technician on this because everything was builded by electric welding and some other type.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So I [? finished ?] some special [? school ?] for welding.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So-- so this was my specialty, technician in welding, electric, and some other things.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "After I was in Ukraine, I was hiding.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And they start to hunt for people from Polish, officers and something like this.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They start to hunt for these people, looking around, where to do, what to do.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "A lot of people signed-- Jewish people signed they won't go back to the homes.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And on the [INAUDIBLE] there, there'd be Russian [INAUDIBLE] they put on the list of these [? whole ?] people, and they start to people-- take away to Siberia.",
      "word_count": 29
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They catch me--",
      "word_count": 3
    }
  ],
