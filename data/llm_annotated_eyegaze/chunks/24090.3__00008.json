{
  "stem": "24090.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "This is the kind of ship she went on?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She sailed with the captain.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] She was determined to see her son.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And later on she took-- made a trip to Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "When Helmut left Peru and moved to Israel, she visited him there and his two boys so that she-- they could know her.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My future husband was a World War II hero, I think.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I met him at a party, which was a specific party from the B'nai B'rith young women.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And he was invited.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And sparks flew the first time we saw each other.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't long till we started dating.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And we married one year to the date that we met.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "His name is Earl Arkiss.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I was 21 when I met him, 22 when I married him.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Our life together went very well.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "He was a struggling young lawyer.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I was a legal secretary.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He didn't want me to work for lawyers.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "He knew how hard they were to work for.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "But I had a series of jobs.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Now, I did experience prejudice in those jobs.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "When I worked for Greyhound Post Houses, I was the only Jewish person.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And it was a large office.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I had an Irish boss.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And I said to him-- I had two bosses.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "And they-- I sat in the middle of the two of them.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "One was the chief engineer of the company.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "The other one was the purchasing agent.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I sat in the middle.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I said one day, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Stensin, I want to take off for the Jewish holidays next week.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And he says, you what?",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "You, you, you, you're Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "He stormed out and went to the personnel office to check that out.",
      "word_count": 13
    }
  ],
