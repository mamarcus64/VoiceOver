  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "The Judenrat give us rooms.",
      "word_count": 5
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 1,
      "text": "Everybody who got rooms, he got a place to take a family, he must take.",
      "word_count": 15
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "Just we was [INAUDIBLE] Kirschenbaum.",
      "word_count": 5
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 1,
      "text": "He was, maybe, related to us.",
      "word_count": 6
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] , one room, small room.",
      "word_count": 6
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "Well, we was one and then-- [INAUDIBLE] we was five people.",
      "word_count": 11
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "Maybe we got by himself, food.",
      "word_count": 6
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 1,
      "text": "This Kirschenbaum was not a rich man, too.",
      "word_count": 8
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Was not allowed-- no, we went through a village where we know the Polish people would give us something.",
      "word_count": 19
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "That's-- we, we got-- we got money but this-- when he, he don't want to give, he must not give.",
      "word_count": 20
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 2,
      "text": "No, it was a-- the same, what I signed, but the, the papers in here, in America.",
      "word_count": 17
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 3,
      "text": "Also, we went to [INAUDIBLE] in the lager, he give us to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 1,
      "text": "Oh, you saw this paper, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 2,
      "text": "What I signed in Baranow council.",
      "word_count": 6
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 1,
      "text": "He give us [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 2,
      "text": "We eat, we, we sleep, and the next day, we went back in the nighttime to the-- to the concentration lager.",
      "word_count": 21
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 3,
      "text": "Well, we got no place where to go.",
      "word_count": 8
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    }
  ],
