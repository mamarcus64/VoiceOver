    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And she got an entry permit to go to America.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I had my commander training in Guelph, Ontario, which was hard and tough.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And I can't tell you how long that lasted.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Altogether three months.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "We were put on a boat, and I don't remember the name of the boat, to England.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I joined the Royal Dutch Brigade Princess Irene.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
