{
  "stem": "27390.8",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "One thing we didn't want to go back was Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "We didn't want to go back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So then we heard that we going to go to England, that the British government is allowing thousand boys and some girls as well.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "There weren't many girls left alive.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we were told to start learning a few words in English, the basic [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And after sometime I think it was-- we were liberated in May.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "This must have been in July.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We were taken to Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And in Prague, we were about two weeks in Prague, because the weather was no- was bad, and the planes couldn't come over.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They sent over bombers, not passenger planes, for us.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "So they couldn't takeoff.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They couldn't land.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "We were two weeks in Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And that two weeks I must say the Czech people wherever we went, they could see we were ex-people from the concentration camps, the way we were dressed and the way we looked.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "If we went into a restaurant to get some food, they wouldn't take any money from us.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "If we went on buses or trams, they wouldn't take the fare money from us.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And we used to- there were a lot of German prisoners of war that did work in the streets.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "They cleaned the streets.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And we used to go up to say to the Czechs, we will show them how to work, to the Germans, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "You make the Germans work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "We will show them how to work.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And they used to beat them, the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And the Czechs, they clapped us on the backs, good.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "This went on for about two weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "So we got onto the planes, and we came over to England.",
      "word_count": 12
    }
  ],
