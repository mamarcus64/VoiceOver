{
  "stem": "14687.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "She-- she used to all these songs.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And then we used to cry and sing it.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So one night, the [NON-ENGLISH], the blockova, you know, the German came up.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "She was tall and blond-- said she is singing.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "She gave her on in the mouth.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "She broke three teeth from Frieda.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "It was her name.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And she was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Beautiful girl-- she was about 21, 22.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And she knew all the operas, you know-- opera singer.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And she lost all the teeth there, because the [NON-ENGLISH] came and beat her, you see?",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And after, we used to go sing daytime, you know, and crying.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "What work were you doing then?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I was work-- I was working in the factory.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "It's--",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "The factory nighttime and daytime.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "For one week daytime--",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And one week nighttime.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Nothing now.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "We used to go-- come to the-- all the time, since they took us to go away from that factory, we used to work every time, everyday.",
      "word_count": 27
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "In nighttime we use to sit, but it was not bad like Auschwitz, because I told you we had a-- everybody had their little blankets, you know?",
      "word_count": 27
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And we started to-- a-- a nice Jewish girl-- Polish, with her mother-- they were like sister and daughter.",
      "word_count": 19
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They look like sister-- two sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "You know, the German, she was in love with her-- German woman.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "They was making love with her-- the German with the Jewish girl in the block.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And we used to see it.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "They were kissing.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "She used to bring their food to her-- you know, her food.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "She used to put it in the little bags they used to have-- and these too.",
      "word_count": 16
    }
  ],
