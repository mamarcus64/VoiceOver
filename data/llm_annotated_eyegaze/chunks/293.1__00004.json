{
  "stem": "293.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "There was quotas for the school-- 10%.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Was easier to get to a a government school for the Jewish boy because we are excelling in-- in studying.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "We knew to-- to stay in the school, you have to be very good.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "University, the quota was very strict, particular to the things like medical school and the Department of Physical Education school.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Was easier to get to law or to other department with different qualification.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Engineering was very difficult to get in.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I went to medical school.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "The medical school with a special implementation to the physical education, but this was all more like preparing this young people to a teaching in a high school, in gymnasium, or university.",
      "word_count": 32
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "When you became a master degree or doctor degree, you could go and teach on the university.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I got only up to master degree, and I-- and I have master degree in education from University of Krakow.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I became a teacher in 1934.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "The minute I finished high school, I already got a job [INTERPOSING VOICES] because there were no Jewish--",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "In high school.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Even the first year I was in a Polish high school.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Because when they send me for the practice on the first year, I was assigned to the high school which I four years before graduate.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And all of my ex-teachers became my colleagues, and was little bit strange, but I build a pretty good reputation over there.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "With my sister, was a little bit difficult.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She couldn't get to the government school because they were not too many girl high school.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You remember that in Poland in this time was not co-education, not co-ed.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So there were mens/boys gymnasium and girl.",
      "word_count": 7
    }
  ],
