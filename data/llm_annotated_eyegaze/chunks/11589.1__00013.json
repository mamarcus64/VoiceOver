{
  "stem": "11589.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "A little, a little romance I had in that time, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Other people used to come over and visit, you know, there and bring some food.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "There was a girl over there, a Lithuanian girl, you know, used to come over.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "She was interested-- used to come over.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "It was times when people could come and visit you, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And she was [? with ?] them.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And kind of, we created a, a little, you know, friendship.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And one day in the evening, she thought she would bring me food, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "That was a time when nobody was allowed to come in, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "So she thought she would bring me food.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "I left with enough and maybe split with somebody else, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "So they caught her.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "They grabbed her, the, the, you know, soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "And they beat her up so, so strongly, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "She was bleeding.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "I heard about it later.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "They took away the food.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 13,
      "text": "And they, they used it, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 14,
      "text": "We never got this food, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 15,
      "text": "I never seen this girl again, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "She was a Lithuanian girl.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And she lived over there in Omsk with her father, a Jewish girl.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I never seen her again.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Oh, what-- I would say, close to 4 years.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "They control it.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "They check.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "Where you going?",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "What you're going?",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "Unless you had to go because they told you to go, that's a different thing.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "But no.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "There wasn't really a camp close, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "You could, you could run away, you know, and come back later.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "But when they catch you, you know, it's, it's not like a concentration camp, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "But it's far away.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "Where are you going to run, you know?",
      "word_count": 8
    }
  ],
