{
  "stem": "20405.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "The kapo was giving it to the-- so we were going-- we were thinking to going right away into the kitchen to get some margarine and some cinnamon, [INAUDIBLE].",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And this Raul Jahom, a gorgeous guy, so handsome, so strong, so young, he went over there some gold in the kitchen.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And I don't know how he got call from the SS man.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And he brought it to us over there.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "We were [INAUDIBLE] at the crematoriums.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "He told him to take off his clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And he laid down.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And that German shoot him right on the belly, not to kill him.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And, of course, this [INAUDIBLE], he was screaming from the pains.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "He was begging to the SS man to kill him.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And the SS man just shot him another-- another time right on the belly.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "He didn't want to kill him.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "It took three shots, because Raul was begging him to kill him.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "Three shots, and Raul to get killed.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Was another guy, [PAUSES FOR 4 SECONDS] I don't know why he did that, that guy, that SS man.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He put on some gasoline, and he put a match.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he told him to run right down the wires over there to escape from there.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "When he was along the wires, he shot him.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "He tried to escape, and I shot him.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "That was the reason.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Who was that?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Number 182 something.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Do you remember that man's name?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 11 SECONDS] Why?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They got about 200, 300 Greek people and put them to work at the crematoriums.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "The people they had before, 1, 2, 3, and 4 crematoriums was enough, because was at least 100 people working in each crematorium.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Why they took another 400 people, maybe, Greeks, 300 people, I don't know.",
      "word_count": 13
    }
  ],
