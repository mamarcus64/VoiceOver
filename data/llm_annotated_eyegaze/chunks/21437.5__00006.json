{
  "stem": "21437.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They went to other camps.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "But there were seven girls that were chosen.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And they were all from Bedzin.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "One girls was from Dombrowa, the oldest.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Six were from Bedzin, and the oldest was from Dombrowa.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "D-O-M-R-O-W-A.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So these selections by Mengele, when he was saying, du, du--",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He might have been there only in passing.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "But this was when I was selected.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "He was there.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I could not look at his face.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I just saw the shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So before he selected me, I heard his name.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And so this is how-- and I heard other names.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "So I can't tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "I wouldn't want to tell you something if I don't-- I am not sure 100%.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I know-- I just know that he was there.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And I stole a glance at him.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "But most of the time-- and I stole a glance at the others.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember the others' names, but I remember the highly polished boots.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "It was incredible.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I stole, sideways, a glance.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "No, I don't remember, really.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I just-- you know, at that stage, they all had-- just that he was tall, and that he was very impatient.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I just remember, you know, walking backwards and forwards.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I remember the sound of the whip.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "When the whip went through the air.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And he-- he whipped his boots.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "He went [INAUDIBLE] over his boots.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "You know, when he spoke, and you heard Der Fuhrer [INAUDIBLE] die Juden.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And you heard all kinds of things.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And then-- and then we were-- we were-- the seven girls were chosen.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "And I am not really sure, at that stage, how many men.",
      "word_count": 12
    }
  ],
