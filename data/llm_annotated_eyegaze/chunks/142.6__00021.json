{
  "stem": "142.6",
  "chunk_idx": 21,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 7,
      "text": "And we used-- we used to go-- Lensol used to put a close-out business.",
      "word_count": 14
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 8,
      "text": "And I was director of it.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 9,
      "text": "And I used to go all around the-- the US and buy millions of yards of different [? people. ?] And I used to-- I made him rich, the people.",
      "word_count": 30
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 10,
      "text": "And Lensol, with Lensol promotional sales.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 11,
      "text": "And I worked there for 35 years. 35 years, I made them rich.",
      "word_count": 13
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 12,
      "text": "And I had-- we had a deal with the two brothers-- Lenny and Saul-- that whatever-- I bought a 65,000-square-foot warehouse in 1620 San Pedro Street in Los Angeles.",
      "word_count": 29
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 13,
      "text": "And I used to go all over the US and buy all [? people-- ?] people they didn't want, and buy-- and they were $3, $4 a yard regular, and I bought it for $0.35.",
      "word_count": 35
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "I didn't-- for a few years, I didn't talk to anyone, really.",
      "word_count": 12
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I tried to get into the swing of life.",
      "word_count": 11
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 2,
      "text": "I-- I was married for 24 years, and I-- then I got involved with a few young girls, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 3,
      "text": "I always joked, every one lady friend that I had, when coming to me, you know, we got together, always I was 25 years younger.",
      "word_count": 25
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 4,
      "text": "She was 25 years younger than I was.",
      "word_count": 8
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 5,
      "text": "I want to go to the restroom.",
      "word_count": 7
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- you know, everybody thinks that I'm younger, that I look.",
      "word_count": 12
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "Even today, when I go, they say, you are not 92.",
      "word_count": 11
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "You are 69 to 70.",
      "word_count": 5
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "[CHUCKLING]",
      "word_count": 1
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "I tell you, in 1938, I went-- I was in an Italian school in Thessaloniki, in Salonika.",
      "word_count": 17
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And at that time, I wanted to go to Padua to become a doctor.",
      "word_count": 18
    }
  ],
