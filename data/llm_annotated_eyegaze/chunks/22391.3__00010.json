{
  "stem": "22391.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I just couldn't wait to leave the town, because everybody faces that I had seen when we were going away, they were so happy that we're leaving, that I just couldn't live with them.",
      "word_count": 35
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't find anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I did go out to the cemetery to my grandma's grave site, and that was the end of that.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "They, they tried, they tried to be friendly, but the incident that they did to me, I didn't trust them no more, you know.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I lost faith in everybody.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I, I just thought that-- and also, that one of them who lived next to our house, and they said, well, you don't have anything left.",
      "word_count": 26
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Whatever they left here, your parents, well, they took it away.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Meanwhile, over there, you had to go up to the attic from the outside of the house.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "You're going into the attic, and I-- when they open the attic, I could see there was some furniture of ours.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So I lost all the faith in everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And I just couldn't stay.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "It was a small place.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "It was like everybody knew everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And I just lost the feeling towards every one of them.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "Even the, the mayor was so good to my father.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And when he saw me, he told me that he has a few things for me, which he give back to me.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And he said, one thing you must do.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "You must take your birth certificate with you, whatever you go.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "That way you need eventually.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "So I, I got that.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "But they weren't good to him, either, because he was good to the Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "They took away his children to Auschwitz also.",
      "word_count": 8
    }
  ],
