{
  "stem": "24268.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Rosika, please come with me-- the Magda, the niece also.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I said, look, I like you very much, but I had a home and parents who they love me.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And I have-- if I don't find them, someone, then I promise I'll come to you.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "She said, remember.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "She got tears and crying.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "She didn't want to leave-- please, the bus is waiting.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Come, come.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "I said, no way.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "I have-- I had a home, which I love my parents, they loved me, and I wish they would be alive.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "Anyway, so I didn't want to leave.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And she told me to remember at least the name.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "It's Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "Fried.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And I never forget this place where they lived.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "I heard the husband did survive.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "Anyway--",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I went home-- sorry?",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So after the liberation, for a few weeks, I remained with two ladies which we'd been-- they were older than I was.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "She was 37.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But I cling always to the people, because I need mama.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I think it was the turn away from the parents, so suddenly, I think.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I needed this warmth.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And she needed, because they had small children, I think-- one of them.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "She was a wonderful person.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And she wanted-- she stayed with me.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] she has a sister in there, which she didn't go to the sister, she stayed with me.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed after the war together in Peterswaldau.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And then, after a few weeks, decide to go home.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I went back.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "There was no transportation because-- we couldn't get no food.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "I went into the camp and get some potatoes, something to get to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And we traveled.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "It was-- most of the time, there was no connection.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "I went for the first time back home.",
      "word_count": 8
    }
  ],
