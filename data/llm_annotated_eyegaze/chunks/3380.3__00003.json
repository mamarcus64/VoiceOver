{
  "stem": "3380.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And they told him that [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "You are dying with the heroic death.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Honest to God, you see.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "I will remember this for the rest of my life.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And they pushed him back that he should go to the left, [GERMAN].",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "First of all, we did not have any-- three days, we were without clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We used to push [INAUDIBLE] in barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "For three days, we were only-- they had-- they chased us out.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we had to rub on the others' back to keep the bodies, the blood running.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "If not, they would freeze to death.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Then, then the third day, they gave us clothing.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "When they gave us clothing, we didn't recognize each other.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "We didn't even recognize who is who, because they cut off the hair.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And the gave us-- you know, a short guy got a long sweater or long jacket.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You know, they didn't care.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "You got a jacket, slacks, and pair of shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I don't think that they shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "No, we didn't have any shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "They gave us no shoes at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And we were waiting.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And every couple days, the SS used to come.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "We used to have to go twice-- every day, we had to go on the roll calls.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And they used to make selections.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "Whoever is not fahig, they put them in right to the gas chamber.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And then we have seen the four chimneys.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "The four chimneys were going in full swing.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "The sky was light-- was lit up red, not just at night.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "Even during the day, the sky was red.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "Four chimneys were constantly-- you could see the flames going above the chimneys maybe 15 to 20 feet.",
      "word_count": 18
    }
  ],
