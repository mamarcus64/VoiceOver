    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "She was with another man in another group.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Later he took this wife from another man.",
