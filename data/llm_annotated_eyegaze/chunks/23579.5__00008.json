  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Because he was only the first one, but other one too.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "He said, my wife and the children are already long dead.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "What for I have to take care on them?",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "But this lesson what he gave to him, would never find another woman or child in the forest by themselves.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "When we came to Israel, the wife from this man, said, you know, you are a killer.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH] was the whole-- something.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "This is for the Bielskis.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They did something [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And they give them the orders, and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They said, you're a murderer.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He said, Zusia, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She said, you killed my husband.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "He said, why did I kill your husband?",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Because he left a woman and a child, not his, in the forest.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Why did you not take her?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, and he said, I'm very sorry that I killed him.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I'm very sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But he was worth it to be killed.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And this was finished.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "In [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In Israel.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In Israel.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "At the time that he had left behind the other woman and the child.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "She was with another man.",
