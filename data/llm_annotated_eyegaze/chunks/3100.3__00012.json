{
  "stem": "3100.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And then-- and then I said, I've got to go back to Washington, because my daughter got already 15 years old, and I didn't want that she started to make, you know, homework with non-Jewish students.",
      "word_count": 36
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid thus.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "Also I got back to Washington.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "And I was there in Washington for seven years.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Until--",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Until the rabbi came up.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "They wanted to use women for the minyan and give them full participation.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And I'm used to it today, but at that time, I wasn't used to it.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "That's [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "And I just-- then I, I notified the congregation.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And I quit the congregation.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "And the Cantors Assembly told me, we applaud you for it, but--",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "But this is--",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "--the newest style.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "They said, the trend.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "You have to get used to it.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And then I didn't have a new shtele.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "I said, I don't want a new position.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "It's, it's-- I couldn't take it anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Then I get a call from the-- from the conservative movement, and from, from the Cantors Assembly, who was-- he was an officer with the-- what do you call this?",
      "word_count": 30
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "The United Synagogue.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "And he calls me up, and I knew him.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And he said, Morris, would you like to go to Canada for cantors for-- A shtele.",
      "word_count": 16
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "--for a shtele?",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I said, well, give me another call.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I mean, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "Not for a shtele, but just for Rosh Hashanah, Yom Kippur.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Oh, just Rosh Hashanah and Yom Kippur.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Hashanah and Kippur.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I said, you see, my wife isn't here.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "When she'll come back, I'll discuss with her, and I'll call her back.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And he gives me all the information.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "He said, you have time to call me till about 7:30 in the evening.",
      "word_count": 14
    }
  ],
