  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "He said, ah, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "[NON-ENGLISH], here's a girl.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "Your father stays here.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "And she cried-- a Czech girl.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "And he took her number and put it onto me.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "And I went into the wagon, onto the [NON-ENGLISH], you know, onto the cattle train.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 29,
      "text": "And I was happy-- not in the same as my grandparents.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 30,
      "text": "They were in different-- because they were already two, three trains-- I was happy.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 3 SECONDS] Suddenly, the door closed.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 32,
      "text": "Poof!",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 33,
      "text": "Dark.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 34,
      "text": "You hear the train slowly driving away.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 35,
      "text": "Wintertime it was-- '43 December the 14th.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Each car must have been about, at least 100-- 75 to 100.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Hell.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Hell happened in that car.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "On the way there, everything dark.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have any food.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Somebody gave me sugar from Czechoslovakia-- from Prague-- said, take sugar with you.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Sugar is always-- you had that-- when you eat a little sugar, you have food.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Shit.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They had to shit.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "There we were.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "By the-- by the time we got there, they were shouting, water!",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Water!",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH] --the whole time, [NON-ENGLISH] , every meal.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And suddenly, then, after three days, and three nights, the door opened up, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Raus! 4 o'clock in the morning, Birkenau, November.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "[SPEAKING NON-ENGLISH]!",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "At that moment, you thought-- we thought we were in hell.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] In hell!",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "You didn't know-- the lights, and the dark spots.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "They were standing on-- the SS-- with the dogs barking.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "They had pins in their-- in their-- in their-- hand sticks.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "You know, how did-- the SS were standing with pins in, because that was ice on that.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "It was like a skating rink.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Raus!",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "The people went out.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "The old people, they fell.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "The kapos were there.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "Mengele was there, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "[NON-ENGLISH] was there, they're the icons.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "[NON-ENGLISH]!",
      "word_count": 1
    }
