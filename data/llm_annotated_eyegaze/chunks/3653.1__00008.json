{
  "stem": "3653.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "But the most Russian of the prisoners, the Jews, they killed [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "A little bit soup, water.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "In the morning, they used to give you like tea, you know, but nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And then in the day time, later, for supper they give you a piece of bread with a little bit soup, watery soup.",
      "word_count": 23
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And that's it, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "They woke in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Sure, they [INAUDIBLE] work in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "They came-- they came here two soldiers.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "They-- they took you.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And you have to go with them to work.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "And one time, we worked there outside the camp, not too far maybe, across the road.",
      "word_count": 16
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "So in the meantime, the Hitler Youth came to this camp, to the Jewish camp.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "And they start beating the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "The Germans [INAUDIBLE] with us, we were about 10 people working there.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "He was a very nice, good German.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "He saw what was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "But 4 o'clock-- it's 4 o'clock, you have to finish the work.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 12,
      "text": "But the Germans, a law's a law.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 13,
      "text": "It's a law to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 14,
      "text": "And it's a law to this.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "So he saw what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "When he will take us there, we'll get beaten up.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "But he has no choice.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "So he told us, clean, clean, clean up good.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "Clean up the [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "Clean up good.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "Just to take a couple more minutes until this go over.",
      "word_count": 11
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "He was a very good, a good German, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 8,
      "text": "Do you remember his name?",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "But he knew, he was for sure, you know, we were going to be beaten up there.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "So he kept us a little bit more, more just to save us.",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] a lot of the people was injured, crying.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "So what are you going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Crying.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "Crying to God.",
      "word_count": 3
    }
  ],
