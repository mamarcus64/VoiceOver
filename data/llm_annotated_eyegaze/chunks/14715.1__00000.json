{
  "stem": "14715.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Morris Kesselman, M-O-R-R-I-S K-E-S-S-E-L-M-A-N.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name was Zidenfeld.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "December 30, 1926.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I'm 69.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lodz, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The city of Lodz was a big city, I think about a half a million people.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Half of the people were Jewish, a quarter of a million Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Very industrial it was.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And they called it the second Manchester because it was a lot of textile factories.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "A lot of observing Jews, very Orthodox.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Jews lived among themselves in certain areas.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "Jewish kids went in their own schools, although there were public schools, but we did not mix with non-Jewish kids or girls.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "It was strictly a boys school.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My home life was a very orthodox home.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father was in textile business.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My mother never worked.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We lived in an apartment house.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was a tight life.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "We had a decent life.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We were not rich.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "But family was a big family.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And I went to school from 7 o'clock in the morning to 7 o'clock at night.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Osher in Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He had a textile factory, which we made linen towels.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And most of the time he was selling it to Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He was traveling every other week or so.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Very religious.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my father was involved in medical institutions, helping poor.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And also he was also involved in a sort of bank, a free loan bank, which poor people came in and got a loan and they paid back very little.",
      "word_count": 30
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And very seldom did I see my father because an early riser, my father.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He went off and I was still sleeping.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And when I went to bed he was never home except Saturdays or Friday night, when we went together to temple or we had to get a supper.",
      "word_count": 28
    }
  ],
