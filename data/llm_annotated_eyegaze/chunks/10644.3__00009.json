{
  "stem": "10644.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The fetus was-- I don't-- you don't care.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I don't care what it is.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "No, it is--",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "When it weighs 600 grams, you know, what do I care?",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I am in a concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "I know the results.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I know the results that she-- if the baby is alive, and she's alive, they both will be killed.",
      "word_count": 19
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I don't know what my sanitator, you know, did, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Probably went somewhere and buried-- buried them in the premises of this-- of this-- compound.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Hold on, I didn't finish.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] She was starting to get a little temperature.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And I decided to keep here for one, two days.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know what is the reason for the temperature.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Maybe she has some TB in the lungs, you know, and a temperature.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "But on the second day, or on the third day, I-- someone from the camp comes running to me, Visner is here.",
      "word_count": 22
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "Visner is-- we are now a part of a concentration camp, Riga [NON-ENGLISH] Kaiserwald.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "We are a part.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "That's when the SS people came.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "That is everything part of the concentration.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "But we were Arbeitslager.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "We were working, working, working for their very important part.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "They don't have any other workers but Jews to work on the airport to enlarge and maintain.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "And Visner was the-- there was-- the doctor of this Kaiserwald was a man with the name Krepsbach.",
      "word_count": 18
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "He was in the rank of major in SS, Sturmbannfuhrer-- Sturmbannfuhrer Krepsbach, nickname Dr.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Spritzbach.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Spritz, you know, what means-- injection.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He was known-- he was before this, he was in Mauthausen-- Camp Mauthausen.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And he was with terrible reputation came.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "He was injecting phenol intravenously, and the terrible pains, which in ten minutes, they were dead.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    }
  ],
