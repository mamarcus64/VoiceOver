  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "You know what a ball bearing is-- it's like what cars, trucks, and things like having in the wheels.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And of course, it they didn't give us anything to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They didn't give us any money.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "But we got-- I got some money.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I bought some basic food.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And it went on for about six weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "After six weeks, we were taken by train to the Austro-Hungarian border where they were keeping us in a kind of combination concentration camp and-- and-- and forced-labor camp.",
      "word_count": 29
    }
  ],
