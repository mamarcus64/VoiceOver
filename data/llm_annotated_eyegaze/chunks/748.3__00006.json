  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 8 SECONDS] Didn't you remember, in this moment, when I took you out from crematorium?",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "I says, there was no time to remember this.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "This was one drop of-- of a-- of a ocean, what you did.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "You take me out, and another young girl, and 3,000 woman, they was killed in this-- in this time-- 3,000 woman.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "Then, you can imagine.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "You were in Nuremberg for how long?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh, three weeks I was in court, day and night, with [NON-ENGLISH], the one that I was-- is afraid that they will kill me, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "When I went from hotel, I wanted to a restroom to go.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Then the [NON-ENGLISH] come with me in the restroom.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Just tell me this what you lived, you saw it.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] But one day, I couldn't anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Then I fainted.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] And then, the [?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Mayor ?] came in when I was in there.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "There was a nursery there.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And he says, with this, what you fainted now, today, you give them all a string of the-- And I went-- they give me a airplane to go to Poland, because I was sure that my son is alive.",
      "word_count": 39
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And I came there, and I saw the old lady.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "To Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They bring me with the airplane.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And the airplane wait for me, because I say I will not be in this city or in-- in this-- the Pollacks was very, very, rough, especially for the Jewish people.",
      "word_count": 31
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I went back, and I went to the old lady.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And she got a stand with cigarettes-- because her husband was killed.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "He was a-- a-- how to say-- a [NON-ENGLISH] in Russia-- airplane, he was killed.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Then she got a privilege to sell cigarettes-- a stand.",
      "word_count": 10
    }
  ],
