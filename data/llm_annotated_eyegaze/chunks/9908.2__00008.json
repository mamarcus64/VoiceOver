{
  "stem": "9908.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I had a-- a cousin, that is where my father had the shop-- in their house till the ghetto-- her and two little children-- a little boy and a little girl.",
      "word_count": 32
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "They all went.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "My mother wasn't beside herself.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Her life had ended while they took her little baby.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So now we are in Ozorkow ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We're going out every day out of the ghetto by cart-- to work.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So they gave-- again, my father a shop, and was sewing again for the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And there were other shops, too, not just my father.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And there were dressmaking.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "The Germans came like in a paradise.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They took them in in a big building-- the-- the sewing machines, the mirrors.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Everything they took to the shop.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And they cried.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They came over there for-- for having things done-- the-- the ladies with dressmaking, with everything.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "There was a section-- a new section developed, which lived only Poles.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Because a Yid wouldn't live there.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "[DRINKS] Because a Yid in the shul need [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they wouldn't live there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "But the Poles made-- up a hill-- I don't even remember where it was.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "They chased out the Poles.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "There were little single dwellings.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And in one dwelling there were three family.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "The Germans putting us, another man, and another lady, three rooms-- each room one-- one family.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "There wasn't much left of the Yidden.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "The elder Yidden didn't come in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Like when they hang those people and they took us in to that Reich school, the 1/2 of the Jewish population was taken already to the gas chamber.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They didn't go to the gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They went to Chelmno where one transport had to dig for the other one the graves.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "First, they dig for themself.",
      "word_count": 5
    }
  ],
