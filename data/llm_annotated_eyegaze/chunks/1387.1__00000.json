{
  "stem": "1387.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Boskovice, Czechoslovakia, in 1918.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My family lived in Poland in a small town by the name of Zasow.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "During the war, First World War, my family was evacuated from my hometown, Zasow, into Czechoslovakia, for safety reason.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Because the front line was there.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And it was dangerous to remain.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So the government, or whoever was in charge at the time, transferred the population from Zasow to Czechoslovakia.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "My family wound out-- up in Boskovice, where I was born July 10, 1918.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] In 1921, my family moved back to Zasow, where I remained throughout my youth.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "My father, Jacob Perlmutter, was born in 1989.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "1889.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And the first recollection that I have is that when I was almost three years old, or a little less, when there was still war going on between the Ukrainians and the Poles, I was hidden in a basement with my family.",
      "word_count": 42
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I wanted a drink of water.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So my father went up into-- upstairs to get me a drink of water.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And a shrapnel hit the house.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And for quite a while, my father did not appear back into the basement.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And we thought we-- he might have gotten hit.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "But, thank God, he survived.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And that's how I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "My first recollection was the war between the Poles and the Ukrainians, the beginning of 1921.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My sister was the oldest in the family.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "She was born in 1914.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "My brother, Max, was born in 1922.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I, as I mentioned before, was born July 10, 1918.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "My father was a very educated man.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He was-- professionally, he was a Hebrew teacher-- a graduate Hebrew teacher.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And he met my mother in the same school.",
      "word_count": 9
    }
  ],
