{
  "stem": "19231.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.3,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "In fact, we went to-- to-- Austria-- to-- to Austria.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "There was like a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "It was like a temporary place for us.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And my brother came from Germany to Austria to greet us to take us over to where he is in Germany, to Landsberg.",
      "word_count": 23
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "She's survived.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "They were in the concentration camps, Auschwitz, Buchenwald.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "They-- they survived.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Two survived.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And four wasn't that-- weren't that lucky.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Maybe.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I think one brother told us that he saw one brother died right after the war.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He was so sick, he couldn't go on anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And they didn't know from all of them or my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Two were in Russia and two in the concentration camps.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "So we were all together in Landsberg, Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "We were in the DP camps for our-- that's where I met my husband.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "And then we separated again.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "Because my brother, in 1948, he was married.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "You know, after the war, he got married.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "He had a baby.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "He went to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "And one brother was also married.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "They had a little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "They went to Australia.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 12,
      "text": "And my sister came to United States and so did we.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "In the--",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Aron.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I met Aron in Landsberg in the DP camps.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "In fact, somebody introduced us to each other.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "Somebody from his hometown, he said to me, you know, I know this guy.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "He's a good guy.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "He-- I know his family from home.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "I know his parents.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 7,
      "text": "They're good, very nice people.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 8,
      "text": "And he talked a lot about-- good about him.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 9,
      "text": "And I said, oh, maybe I should decide.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 10,
      "text": "Because I was scared for somebody that's going to be not nice to me.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 11,
      "text": "So I decided we were-- you know, we knew each other a short time.",
      "word_count": 14
    }
  ],
