{
  "stem": "25381.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The conditions in the bunkers are like-- one bunker, we were like my cousin with the two children and I, and his brother that his wife got killed, and their father.",
      "word_count": 31
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He died, he was 104 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He died here in the United States in Livermore, California.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So we were like, three, four, four, six in the bunker.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Some bunkers, there were like two families.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "As I say, the baby got killed, so child couldn't breathe, so they got saved themselves.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And every time the baby, you know, my cousin's little boy, he used to cry, so we used to give him a tablespoon with whiskey, and he fell asleep.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And it was-- he is the one that [INAUDIBLE] saved the life, the uncle used to take care of him.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And we went to the houses, or at night we went on the field, and we take the-- the corn that was already ripe.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And we used to come home and peel it.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We tore bunches, and we used to come home in the bunkers and peel it, and eat this dry corn.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "Or we ate mushrooms, the dry mushrooms, or like potatoes.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "So we dig outside.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "We used to steal from the farmers at night and eat their potatoes, dig potatoes.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "It was-- we were full of lice.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "We were full of lice.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And we used to get up in the morning and take off the lice, and then to lie down again because we didn't bathe ourselves.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "We didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "We couldn't, not anything.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "Until when the [NON-ENGLISH] it was already on the end when they-- already the American soldiers came in.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And they already pulled the German back to Germany.",
      "word_count": 9
    }
  ],
