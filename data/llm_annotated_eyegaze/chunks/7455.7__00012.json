{
  "stem": "7455.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And I told her about the documents.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And she said, you give me your birth certificate and your documents.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I'm going to go-- she's a Ukrainian, which are Greek Catholic.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "But she's going to go to [NON-ENGLISH] to the Polish priest.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "She's prominent.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "Perhaps they know her.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And she's going to present my papers.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "She'll say, I'm sick.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "And on the basis of my birth certificate and christening from the church and all that, they'll give me a document.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "She went there.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "And she obtained it.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "And I kissed her and hugged her.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "She went there, and I was to know whether she was successful.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "Because she was so prominent, they didn't even question and doubt.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "And that evening, after I put the cow and everything was taken care-- I asked Mrs.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "Winer's permission, I'm going to see Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "Popel.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "Hania was being quiet already.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "Popel took me into her room and hugged me.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 26,
      "text": "She said, it was like [? bop-- ?] like [INAUDIBLE] so easy.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 27,
      "text": "She said, he didn't asked question because he knows me.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 28,
      "text": "And so he stamped it.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 29,
      "text": "I have a paper.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 30,
      "text": "And we kissed and hugged.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 31,
      "text": "She said, that calls for a celebration.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 32,
      "text": "She took us some wine.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 33,
      "text": "We drank, and I left.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 34,
      "text": "Having those document-- I said, I have my birth certificate.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 35,
      "text": "I have this paper.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 36,
      "text": "I have that.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 37,
      "text": "I'm safe.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 38,
      "text": "I slept better that night.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 39,
      "text": "Now, I told Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 40,
      "text": "Winer-- Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 41,
      "text": "Winer kept asking me.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 42,
      "text": "I said, I wrote to my stepfather-- stepmother.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 43,
      "text": "Told my father to send it to me, this paper, there.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 44,
      "text": "Two weeks left before the deadline.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I showed her.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "She said, you go tomorrow morning to register.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And the whole day I'm thinking, I have to present my documents tomorrow.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "How do I know that they are real?",
      "word_count": 8
    }
  ],
