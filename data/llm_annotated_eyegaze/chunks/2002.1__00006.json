{
  "stem": "2002.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Were you wearing tefillin in the morning?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "My father would make me, if I liked it or not, to put on the tefillin every morning.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And he would take me to the-- Friday night we would all have to go to a mikvah.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And we would have to get ready before sundown to go to shul.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And we did it.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "As-- as long that he had the-- the power over us.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "When we grew up already, like my brother, I don't think he influenced him as much as when we were younger.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "My oldest sister was [?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Sura. ?] After [?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Sura ?] was born, came my brother Moishe.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And after Moishe came Esther.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I think some time-- I don't remember 100% who is first and who is second.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And after Esther came Itzel.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And after Itzel came [PAUSES FOR 3 SECONDS] came Luzer.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Gittel ?] I think.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "Gittel ?] No.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "Esther.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "Itzel, [?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "Gittel ?] then came Luzer, and then Srulke and then me.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I am the youngest one.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We were eight children.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was about [PAUSES FOR 3 SECONDS] 18 years old, 17 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "That's the time I started to work, which I would go get about 30, 40 cents for the day workin'.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Hard work.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I would go in in a basement, throw out dirt with a shovel-- I didn't know anything-- just to make something.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And the work was good, because I knew after the day I'm gonna have enough money to go buy bread.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And I also remember I started to work for a Polish man as a cabinet man.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "He was making cabinets.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "The first thing he did, he brought me a half a loaf of bread.",
      "word_count": 14
    }
  ],
