{
  "stem": "8703.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They took the money.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And also, my sister when she was-- I mentioned that she was working in the-- in the vodka factory.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "She didn't get paid money.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "But she got-- when she left, they figured out how much they owed her.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "So they said, we owe you about 15-- what do they have-- liters, I think, over there, vodka.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So she came with 15 liters of vodka.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They took also the 15 liters of vodka.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They thought that I'm-- that we are doing business with vodka, but we didn't.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "It was her, her vodka.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "She told them, here, I've got to show you.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "That's where I was working.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And this was the vodka that I got paid for my work for many-- for several months.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They took everything.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And they locked us up.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] My sister went-- terrible, aggravated, for nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Well, and they locked us up, the police, in, in, in this-- in prison.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "But we-- she came-- that she had to look for that captain that I mentioned before.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He was a captain in the Polish Army.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "From the police-- also, he was assigned to be a police-- and work in the police, in the Polish police, as a captain.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And you have to help me because my brothers, my two brothers, are in arrest.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They were-- they are in prison.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And he went up-- he was a captain.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He went up to the police.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And he said, how come you arrested my two cousins?",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I was not a cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "But I was a good friend.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I helped him out.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "When he came from school, he didn't have a single penny.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "He wanted to go out with a girl.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I gave him for cigarettes.",
      "word_count": 5
    }
  ],
