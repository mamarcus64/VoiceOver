  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And Marco was another adult, which was in charge of buying food and bringing stuff to us.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "And a few other ones which helped in the group.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "And he started classes.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] We had regular school classes, actually, there.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "It was a small manor house.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was empty for many years.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And it was used previously-- and I'm talking about now perhaps 80 years back when the Austrian-- [PAUSES FOR 3 SECONDS] before the First World War, when they had [PAUSES FOR 4 SECONDS] royalty.",
      "word_count": 34
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was used by them as a, you know, location.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But for us, it was godsend.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we had, even, a little garden there, where vegetables were grown.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Lesno Brdo.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "It may have been August.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We would have stayed there for the end of the war, till the end of the war.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, the Yugoslav people started to revolt against the German occupation.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "The partisans started to become very active, under Tito.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And in our area, the partisan group was under the command of a Yugoslavian by the name of Cernij.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
