{
  "stem": "979.1",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They already told us to do those things, but we didn't know.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Some went to the mountains.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "My father-- we are Sephardic Jews, so we could have make a-- we could go to Spain and take certificates.",
      "word_count": 20
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "You could do that, but we didn't do it.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "They-- no, we didn't know we could do it.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "My other friend that I had-- I had one friend who was-- she really had the Spanish certificate, although she was Sephardic Jew.",
      "word_count": 23
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "She-- she wasn't from Spain.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "But she-- she stayed in Greece.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "They didn't touch her, because she had the certificate, you see?",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they left in Greece.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "The very end-- the very end, they brought them to Belsen-- you know, to Belsen.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "But no, they didn't harm them.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "They just put them there, and then they send them back.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "They didn't want-- they didn't die there.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "They came to Belsen right across from us.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "We saw them.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "So-- and then came the moment when-- it-- so my sister, we decided they would get married.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "And we got-- they got married in the backyard with a few other girls.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "They thought, even if you don't-- you-- you know each other, but just get married, because this is better to go there when you're married.",
      "word_count": 25
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "That's what they said.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "So when my sister got married, and in the back--",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In the backyard with a few other people.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    }
  ],
