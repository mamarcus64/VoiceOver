{
  "stem": "12462.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "The British, particularly under Sir David Maxwell Fyfe, who was the deputy chief prosecutor-- and he had come from the Tory government, the conservative government, and had actually been the chair of the-- the representatives from the four powers in London when they negotiated the London Agreement and the London Charter.",
      "word_count": 51
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He was very instrumental in influencing the-- not only the keeping up good relations between the four powers-- he was extremely good at that.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He was an unusual diplomat, a man of exceeding great ability.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He later became Lord Chancellor and was Lord Kilmuir, K-I-L-M-U-I-R.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "By the time the defense case came along, the president of the tribunal, who was British, and Sir David Maxwell Fyfe would often, right out in open court, say, well, Sir David, will you take care of doing this?",
      "word_count": 39
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Will you go and-- and be sure that the defense gets this document or that?",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "That if they want some witnesses from other countries, will you help make arrangements for that?",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So he became a really tremendous force in the trial, far beyond his rank.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The British had only eight [PAUSES FOR 5 SECONDS] barristers there, and they had several attorneys who were not barristers but never appeared in court.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Only those eight did.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Whereas the Americans had a total of some 27 attorneys who became trial counsel, actual prosecutors who appeared before the tribunal.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And I was one of them, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In January or early February, I presented two cases.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "The first case was against Baldur von Schirach, the youth leader and the Gauleiter of Vienna after 1940.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] The second one was Hans Fritzche, who was the main Nazi propagandist.",
      "word_count": 16
    }
  ],
