{
  "stem": "6736.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And the friend took her outskirt from Proszowice, Stogniowice.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "There was a farm.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "And he rented an apartment, a one-room apartment, for my mother and the five children.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "And the mother wrote-- my mother wrote to her brother in ghetto that she lives near Proszowice.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "And my father left Ozarow.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "From Ozarow, he went to Strasshof and picked up my brother.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "Then he came to [NON-ENGLISH], Neustadt, and he picked me up.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "I was by a family [?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "Strasburg ?].",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "The boys I went to cheder, to Hebrew school together.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "And I wrote that I am there.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "And we all marched by foot towards Proszowice.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "One night, again we were afraid to go in at night to Proszowice, so we slept by a farmer.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "My father had a few zlotys.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "He paid the farmer.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "And he gave us some food, and we slept.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "And we walked down past a house.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "And that house was covered with a sheet.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 36,
      "text": "And little did we know that in this house my mother with five children lived there.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We went all the way to Proszowice.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And the guy in Proszowice said, are you coming from your house?",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My father said, where, where's my wife and children?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He said, you didn't see them?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You go in this direction.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "He said, we passed by.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "We didn't see them.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So he took us by the arms and we walked back a few miles.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And we came into the house.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And there was my mother, five children, then my father, and my brother, and myself.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "We were a family from maybe September, maybe beginning of October in 1941.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "We were all together.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In the end of '41, they wanted to take my father into a labor camp.",
      "word_count": 15
    }
  ],
