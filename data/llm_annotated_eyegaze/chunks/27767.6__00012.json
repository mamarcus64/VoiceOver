{
  "stem": "27767.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "In Baia-Sprie we found that 300 people who were living there before, there were left only about 15 or 16 people.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my house was still there.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And my brother was living in that house at that time, because he was there a few months before.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And so he was living there, and a few other friends, younger people who escaped.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And in the beginning we were cooking together there.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Then we had a woman there who cooked for us there.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And then later on, my-- when I went there actually, when I went home, my brother and two other friends, they had a store.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "They opened a store.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And they were trying to make a living there with that store.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So when I arrived, I had already my brother was there.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He had a little money, so-- Were you able to find some of the things that you had left there?",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We found some of the linen that the neighbor, they gave us back some of this linen and some dishes we left there.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "No clothing because we didn't have anything else.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And we found that little jewelry what my mother had, my father-- and actually my wife had that.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I gave to my wife that--",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Not earring, I gave to my daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And the ring I gave to my wife.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
