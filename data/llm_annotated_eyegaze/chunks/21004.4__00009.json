{
  "stem": "21004.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "And you have to go take out all the stuff from the septic tank.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 20,
      "text": "Some of them didn't have septic and to take with their hands.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 21,
      "text": "They say everybody has to take and go and take and, you know, throwing it at-- on the top of this man when he was in the ditch.",
      "word_count": 28
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 22,
      "text": "It was really horrible, so horrible-- unbelievable.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 23,
      "text": "And later, when he was already later throwed back mud on him.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 24,
      "text": "And he was already thrown in the mud up to here.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 25,
      "text": "They say, go ahead.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 26,
      "text": "Pull him out.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 27,
      "text": "Pulled him out.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 28,
      "text": "And then later say, they throw him back in.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 29,
      "text": "Three times, they throw him back and in.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 30,
      "text": "And later, it's already in the afternoon.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 31,
      "text": "Later in the afternoon, sit down.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 32,
      "text": "They didn't give us nothing to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 33,
      "text": "The second day, he was laughing and screaming.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 34,
      "text": "And the third day, they came with trucks.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 35,
      "text": "The big trucks, they came, one Gestapo on one side and one on the other side the truck with whips.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 36,
      "text": "And everybody Jew, [SPEAKING GERMAN], on the truck, filled in a truck, locked it in.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 37,
      "text": "And everybody, you know, bloody-- some of them, some of them catches, some of them didn't catch, and took us to Lemberg, Janow ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 38,
      "text": "It was a horrible place.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 39,
      "text": "Yanov ghetto, they let us in in shacks.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, later, I was in the hard labor camp.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I was eight months.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't remember now.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "It's hard to remember.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I know he was the head from the Jewish committee.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "This I know.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "How they picked him, I don't have no-- yeah, they know how to pick him.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Because when they brought them to Janow ghetto from each state, from each city they know the names from the head from the Jewish, from the Jewish committee.",
      "word_count": 28
    }
  ],
