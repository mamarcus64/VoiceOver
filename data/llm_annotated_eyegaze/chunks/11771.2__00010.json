  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "I never saw his face.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "He was so in hiding, his face to his leg.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And we are marching.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And [NON-ENGLISH] tells me the same thing-- before we're coming to the edge, of [NON-ENGLISH], my teacher, my Talmud teacher-- say what he's saying?",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He's saying a prayer.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He's saying a prayer.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I remember the prayer.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "He says, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "What does that mean in English?",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "King David says that when he was in hiding or running away from when they were trying to kill him, actually.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Even if we'll fall from your thousands, and 10,000 from your right side.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] They will never come to you.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They'll never come to you.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "At the same time, my father tells me, [NON-ENGLISH], don't worry.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "You will survive.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "You'll retaliate.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 6 SECONDS] Well, I accept these words as-- I-- I feel better.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I feel good.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "It makes me feel good, these words.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Even I have no hope.",
      "word_count": 5
    }
