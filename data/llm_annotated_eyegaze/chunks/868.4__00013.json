  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "How do you answer a heavy loaded question like-- like that on the spur of the moment?",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "My message?",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "How they should live their lives?",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I would say that the prime requisite, to me, to my mind, is decency in all dealings with other people and yourself.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I also wonder-- the heroic efforts of these priests-- I've often wondered if we had been in the reverse situation, would we have done what they have done?",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I hope it will never come to the test.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I hope anything like that never happens again, period.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But it is happening all throughout the world, right?",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "You have cruelty and injustice and [PAUSES FOR 4 SECONDS] maltreatment of one group of people versus another.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "You see it in the daily head-- headlines.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I don't think the world has learned anything from-- from-- from that.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Except, perhaps, to resist absolutely fascist government, centralized, one-man power.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "That's where the danger is.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Tolerance.",
      "word_count": 1
    }
  ],
