{
  "stem": "1733.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 232.6,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And the bad times didn't start till a little later, when we grew up a little already.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, for entertainment-- there wasn't much time for entertainment, because you had-- you were always busy with studies.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Like I mentioned before, the cheder and the public schools, and we were playing on the outside during recess in school-- football, soccer, stuff like that.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "It really didn't have a name, no.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It was just known as a Czech school.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They also had Russian schools.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But primarily they had-- everybody went to the Czech schools.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The name of the street that we lived on was Masarykova Ulitsa.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "That was the name of the founder of Czechoslovakia, was Masaryk.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And he was raised in the United States, or grew up in the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, when we went to school, we went to Czech grammar school.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "But when we graduated from grammar school, we needed to go to high school, and there was no Czech high school in the area.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So we had to cram for a two-month period-- there was no vacation time-- to learn the Russian language, and to read and to write Russian, to be able to be accepted in the Russian high school.",
      "word_count": 37
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And we had accomplished it and we went to Russian high school.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "We went to visit aunts and uncles not far away from our village.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They lived in the area also.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And we had experiences where my uncle that lived in Seredna-- or rather my uncle and aunt, they had about eight or nine children.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "By the way, none of them survived.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Not one of them survived.",
      "word_count": 5
    }
  ],
