{
  "stem": "25381.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And when it came their holidays, it was-- you know, we didn't go to them because we were very religious.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "We kept strictly kosher and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And they knew, so they respected us.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I went to synagogue every Saturday with my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "I had to go to synagogue when it came Yom Kippur.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I had to fast.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "I was 11 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "I had to fast already because my mother said the children, that they-- they don't have any father, so they don't have any mothers.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "Children like that, we have to start earlier.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So every year, I had to stay with my mother by the-- hold the hand, especially me, because I was the youngest, and to be with her in synagogue every holiday.",
      "word_count": 31
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And every-- and then from the villages, oh, there were a lot of Jewish farmers.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They used to come stay in our house.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We welcomed them with food and sleep and everything, because they want to go to-- to synagogue for the high holidays, mostly for the Rosh Hashanah, Yom Kippur.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Because they didn't have any synagogues in the small villages and the farmers.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So we used to have, like, a couple of two families at our house.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They slept even on the floor at our house, but they were during the holidays.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "With my sisters, we were very friendly.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We were very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We never knew what means fights.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And my mother-- we loved my mother dearly.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "When I came from school-- see, here in United-- the life was there very hard, especially in the small towns and the small cities.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I used to carry water by-- with a pail I used to carry on the shoulders, two pails on the shoulders, like a half a mile from-- how do you call it?",
      "word_count": 32
    }
  ],
