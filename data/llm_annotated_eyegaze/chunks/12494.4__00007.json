{
  "stem": "12494.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We-- we applied for-- my father applied for all of us for an American immigration visa as soon as we got to Switzerland, early 1945.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And we were notified in late 1950 that the visas have arrived.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Because the Hungarian quota was very bad at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And so I didn't want to go because I felt I had a good job in Switzerland and was on my way to becoming a professor.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "My dad said he'll pay for the trip, and so I went and liked it, and then went back to Switzerland for half a year to complete my contract with the Institute.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And then in August '51 I came definitively to the US, joined General Electric.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No, quite a few members of our family came to the States.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My parents did not.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They were more the exception.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Several of my uncles came.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My dad died in '85, and my mother died in '86.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And they came us-- they came-- they visited us regularly, [PAUSES FOR 4 SECONDS] until they became advanced in age.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But you know, for many years thereafter, we-- I didn't talk about the Holocaust to anybody.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I became deeply involved in my profession.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I've had fairly exciting experiences professionally.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It just was something I tried to suppress in my mind, up to a certain point when it came up.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I'm not trying to suppress it today at all.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But you try to be normal.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "One tried to be normal.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "One tried not to, you know, call attention to oneself with [PAUSES FOR 3 SECONDS] odd stories that most people wouldn't understand anyway, that would fill them with horror, and-- and that maybe people wouldn't believe because they would say that such a thing isn't possible.",
      "word_count": 46
    }
  ],
