{
  "stem": "21004.8",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 39,
      "text": "They'll go-- they'll shoot after you.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 40,
      "text": "I want to have another bunker where we can jump in and hide.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So I build in a section farther away, I build another bunker.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And then when you build up the other bunker, we went into that bunker.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "After a month later, start coming out water.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "A well came out.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We needed water badly because we have to go far away for water.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So this was very good.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Well water.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But then it start coming out more and more.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We used to take the water out, throw out the water.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Throw out.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "It come out in the hundreds of cans.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So I say, it's no good.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "This is after three months.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I say, we'll have to go.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We came in the spring.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I say, I'll go with [POLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And we'll go and clean out the other bunker.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Open 'em up.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "You know, fresh air go in.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Clean it up.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And we'll go back to the other bunker.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And that's what we did.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "After a couple days later, it was dry.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I took everything out from this bunker-- because the water keep coming so high up to our [POLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We lived.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And we used to say-- my wife used to say-- we saw once a cat in the forest.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And my wife say, here the cat goes freely.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "She goes whatever she want.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Nobody touches.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "But we are not free.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We can show our face to nobody.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It took a very long time.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We not depressed.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "But just my wife was more depressed than me.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "She say, it's time to go.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Let go.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Let them take us.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And forget about it.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And all of that stuff.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And my son was depressed, my little stepson was depressed.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Once, we had soup.",
      "word_count": 4
    }
  ],
