  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "But she was half-dead.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "The girls, they took her, with all the power, just not to go to crematorium.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "And he enjoyed it, just because she threw over a small piece of bread for somebody.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "German.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I knew the German language.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I took some lessons in Hungary, German lessons.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I knew German.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And the Jewish language is very similar to the German.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Of course, I was not fluent.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "In fact, it happened once a case, when I was by this Dr.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Epstein's office.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And one day, he told me that, bring me the waagen.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I knew the Jewish [NON-ENGLISH] is a wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And waage is a scale.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I didn't concentrative.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Bring me the waage, so I figured, bring me the wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And there were used to, if somebody died, there was a special room.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And they picked him up, with this particular wagon, with two wheels.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "It was only with two wheels.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And they brought them to the place, where, from there, they shipped them to the crematorium.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "He told me, bring me the waage, so right away, [NON-ENGLISH], and right away, like it's an order.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And I bring him the wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And I go into the room.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "He's sitting by the bench.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "And he says, so bring it in.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So, I cannot bring it in, because the waage is bigger than the door.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "How can I bring it in?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And he says, in German language, [GERMAN]?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "It means, are you crazy?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You cannot bring a little scale in?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But he didn't know that I'm being a wagon, that I-- I-- I'm not bringing a scale.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "So I started to laugh.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "That-- so the-- what I want to bring you out from this, I wasn't so good in German.",
      "word_count": 18
    }
  ],
