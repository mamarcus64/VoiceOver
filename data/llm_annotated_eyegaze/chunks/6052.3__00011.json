  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I suffered from the cold when I encountered it at the Hachshara place which I mentioned-- Steckelsdorf near Berlin.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I encountered the cold when I was in Pflichtarbeit and Zwangsarbeit in Leipzig.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It was cold, very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But nothing, of course, as my mother and sisters and my father encountered in the concentration camps.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I or we stayed alive.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "We overcame all this.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They were not given the chance or opportunity to overcome it because they were murdered brutally, in a most brutal way, murdered-- murdered.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "All was taken and murdered.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "All was taken.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "They were murdered.",
      "word_count": 3
    }
  ],
