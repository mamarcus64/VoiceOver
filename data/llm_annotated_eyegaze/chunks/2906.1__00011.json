{
  "stem": "2906.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And we worked there-- we stayed there for a couple months.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "They had to go in the field and work.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Everybody from there had to.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I was the only one, and then every woman invited me to come and to sew, because they didn't have anybody to do this.",
      "word_count": 24
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And-- and they-- you couldn't go out and buy anything.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "They had materials [?",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I never ?] wear, so I sew for them.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Then we decided we cannot stay there.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Because the war is coming, Hitler start going closer.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And we said we had to run away from there because--",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "They had radios.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They had a radio, and they were talking.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And the radio were talking.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "The people talked between them.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And they say, it's coming.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "So we decided that we have to-- as a matter of fact, this man, he was like our leader.",
      "word_count": 19
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "He said we have to go from here, to go and it's-- it's getting cold for winter. and we don't have clothes.",
      "word_count": 22
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have anything.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "And he said, we have to try to go to Stalingrad, back, and from there go to Asia.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "Because Asia is not so cold.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "So this lady, she was very nice, she baked me bread.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "The president's wife.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "She's the only one who knew that we are running away.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "She said, you go and I wouldn't tell anybody.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And she-- she baked me bread, and she gave us food-- just for myself, and for my brother, but I split with the other people.",
      "word_count": 25
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Just going there, and at night--",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "There was 30 of us.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "All 30, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "We were all together.",
      "word_count": 4
    }
  ],
