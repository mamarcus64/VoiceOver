{
  "stem": "19130.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 93.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So we went-- and they-- everybody, you know, went somewhere else, from our family.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "In the morning-- so we slept all night.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "In the morning we-- we heard Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "A lot of Germans are talking.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And they-- they are around the house.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "So we were already, alert.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "We were afraid already.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So later we heard the Germans are going on the ladder.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Have to go to us, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "So because they were with the horses, and they want hay for the horses.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They didn't think about us.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "But that-- so but we were already-- they will come, and they're going to kill us with the-- so what-- what-- what can you do?",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "But the-- the roof was, in that time, and it was from straw.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "You know, the roof was made from straw.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So we-- we made a-- a hole.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And we jumped.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And brother and I, we jumped.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "There was a guard.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "The guard, they notice.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "They notice us and they started to go hard, hard, hard.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And they start to shoot over at us.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "We were running, and they after us.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "There was a-- a little-- [PAUSES FOR 3 SECONDS]",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "How do you call?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We had to escape.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "A-- a-- a fence.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So I-- I jump over the fence.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And I-- and my brother doesn't-- and I didn't see my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "They got my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "So I-- I run away.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And I was all-- this was in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "All day long, I was in the-- in the fields, you know, corn fields. you know, corn fields was that.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "So I was hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "What happened to my brother?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "You know, I was afraid to go-- you were-- you were afraid to go.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Doesn't matter where, but in that time.",
      "word_count": 7
    }
  ],
