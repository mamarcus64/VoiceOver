{
  "stem": "11296.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We had, you know, like they're saying, you know, news.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "It was traveling, the news.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And they came to us, they said when we're going to find money, when we're going to look through the clothes, not to give to the Germans.",
      "word_count": 27
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "To hide it in places.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And they told us where to bring it.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "So there was pots, and kettles, and things.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So we always-- there was a special place where all these pots and the pans had a barrack.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They said to throw the money in, and to take a big bundle, and to bring it there.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "There, somebody was there who took the money from us.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And they told us, this money goes for the underground organization, and they're buying bullets, ammunition, whatever they can.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We was happy with them.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Before they took the money-- when I found the money already in [INAUDIBLE], I went in the toilet.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I had full pockets.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And I pulled the chain, and I never put in the money to them.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I put everything, all the money, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "So now I knew something, so I took the money.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And so we heard something is going to happen.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And one day it really happened.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "This was, I think, October.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I think October, she says, in the papers.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We heard a boom, shooting, and they blew up the crematoriums.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Near my barrack was one crematorium.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They don't use that.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "The people, the sonderkommando, lived in this block.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I run out and there was a bench.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I stood up on the bench, and there was-- between me and them, there was a big fence.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I stood up on the fence and I heard shooting, and the block, the building, was on fire.",
      "word_count": 18
    }
  ],
