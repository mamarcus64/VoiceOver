{
  "stem": "8703.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We had two tenants.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But later on, my sister got married in 1941.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And she occupied the other two-- the other apartment--",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "--in the same house. --sister, --sister, Frida.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "My sister, Frida, married a husband, Kwashnieski.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And she occupied the-- with us the other apartment, which, which was rented before.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She-- later on, she had a child by the name of Baruch.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And [PAUSES FOR 3 SECONDS] Baruch went.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "She lost him by the, the Nazis.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "They took him away.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "They took away the baby.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "The baby was only six weeks old.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1942.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "But before that, in 1941-- before the winter, [PAUSES FOR 3 SECONDS] they called for 100 people-- 100 young men to go to a labor camp--",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "--near Kielce Wisniowka.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And I was among them.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We had to go.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "If they called, we had to go.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I lived at home.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "My home.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And after a while, I saw it was terrible over there.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "The Ukrainian [GERMAN] were in charge.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And the beating--",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "--didn't stop.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "[GERMAN], they call it.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They called them.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "It's a German word, like police.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Like police.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And pardon me.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] The beatings didn't stop.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And I thought to myself, this is not the way to be.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And this is not for me.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And I started to investigate and find a way to get out.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And after a couple of weeks being over there, I decided I have to go.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I took with me a good-- a good friend of mine and another neighbor of mine, also who got a terrible beating, terrible beating.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And I couldn't see the way he suffered.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And I asked him, you want to stay?",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Or you want to go with me?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I decided to go.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "OK, that's it.",
      "word_count": 3
    }
  ],
