{
  "stem": "17044.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "I forgot to tell you before that the weapon what I hide in the building near me in the ghetto, I don't know who guide me, but I was afraid they will find a weapon in the ghetto, they may blame the whole ghetto or something.",
      "word_count": 46
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "So I smuggled this out, out of town in a little mountain [INAUDIBLE] down there, and a big tree with I used to play there, climbing the tree under the-- between the roots.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I dig the hole.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I took the weapon in a can with grease.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I digged it down there, are I hide it there.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But now, I had a problem, how to get this back.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "When I-- when I put the-- the weapon on the mountain there, it was a part on the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And then when it was a year later, this was out of the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "So I had a problem how to get this back.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I was a shepherd on this farm.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "So I used to take the cows closer to this mountain.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "If they ask me, I would say, the-- the cows ran away and I'm going to bring the cows back.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So I sneaked.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "It was close to this [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And I took out the weapon.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And I smuggled the same back to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And I gave it to my uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And October 1st, 1942, this farmer, the head of the farm what the owner find out from this [INAUDIBLE] commissar, this is the last day from the ghetto.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He want-- he went.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He told my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And my mother went to the leaders from the ghetto to warn them.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And they went.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They deny it for their leader.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But we know the truth already.",
      "word_count": 6
    }
  ],
