  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "He said, Major, Major.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "He said, he ain't got no back on his head.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And we turned him over and the whole back of his head been sheared off, and his brains ran out in my lap.",
      "word_count": 23
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "So we put him down.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And we knew that there would be another shell coming in in a minute.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And sure enough, I dived-- I heard the next shell coming.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I dived for the ground so fast, I dived out from under my helmet.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And I ran back to the command post cellar diving under tanks and things.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "That's when you suddenly realize what war is, somebody's brains running out on the ground.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
