{
  "stem": "14810.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 17,
      "text": "There was about 200 people, because they-- you know, the Judenrat, you know, they had a lot of friends and just tried to put in more people as possible.",
      "word_count": 29
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So I remember the SS man, his name was Haase-- H-- can never forget this name, H-A-A-S-E.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Pronounced it Haase.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "He was a sturmfuhrer-- he was in charge.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I could hear him.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "He was angry, very angry.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "He said, I gave orders for 150-- and here you've got 200.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And he came and he started picking, 50 people, picked them up.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "My mother was among them, and they took them about 50 feet further from us and lined them up, and we could see, and they executed them all right in front of us.",
      "word_count": 33
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "That was September the 3rd.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "It was on a Friday, 1943.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And then they came and picked 20 guys, young guys.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "We had to take the corpses and put them on a place.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And they told us we had to cut up wood, and put them up on the piles.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "And they gave us gasoline, poured on them and we burned the bodies.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "And that was also the same day.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "And I remember that was in the evening.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "So I tried to pull out my mother's body.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 9 SECONDS] Just one-- [PAUSES FOR 8 SECONDS]",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "There was grass, and I tried to pull it out.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And I thought, maybe, they wouldn't see it and I'd be able to bury the body later at night.",
      "word_count": 19
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And this SS man was there, guard, and he noticed that and he came up to me and kicked me right, kicked me so hard and he said, what is she-- what are you doing?",
      "word_count": 35
    }
  ],
