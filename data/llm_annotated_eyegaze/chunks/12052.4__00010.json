    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "They went to great school, what was very good.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And then they went to City College.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] They knew.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "They asked me, so I told them.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Only we didn't, didn't disclose.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Matter of fact, I had, believe it or not, I-- we befriended a very nice family, and they were Germans.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And matter of fact, Miriam and their kids, like small kids, they, they played together, and we celebrated things.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I had friends from all walks of life.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Like we have here friends, two friends, they are doctors and from all walks of life.",
      "word_count": 16
    }
  ],
