{
  "stem": "26359.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And I heard this conversation.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I got scared.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And I got scared.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I say, what should I do next?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I think they're suspicious.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They think that I'm Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And when I went on the street just to see, and I saw rows and rows and rows of people are going, walking.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And this-- and there was their action in Korsze, must have been in May-- must have been in May there.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "From Korsze, when I left, this was in Korsze, or this was in Dubno.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Dubno.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "This was in Dubno.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "After I passed Korsze, in Korsze I was staying with a few people.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I tried-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I forgot one thing to mention about Korsze.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "When I was in Korsze, Korsze is closer to Krasnostav than Dubno.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "The first place was Korsze.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I tried to get-- as a matter of fact, with my certificate that I got, I went to the [INAUDIBLE] Germans and tried to get a job.",
      "word_count": 28
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "I figured the Germans wouldn't recognize.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "Ukrainian people would know more or less and recognize me more as a Jewish girl than the Germans.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And I got a job.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And they gave me, and I begged them to give me a piece of paper, a recommendation, if I need somewhere I go.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And they put in there in the recommendation that I am a Greek-Catholic.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "This, they put it in the recommendation like this.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "The girl, Marie Filiniuk, mentioned Marie Filiniuk, is Greek-Catholic.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And she's in the [INAUDIBLE] that I'm working with them.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "I wasn't long working with them because I saw somebody from Krasnostav working on a telephone pole.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "And I remember he was working.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And I was afraid he was yelling something.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "And I came from work.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And I was afraid that he recognized me.",
      "word_count": 8
    }
  ],
