{
  "stem": "15115.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "First of all, my mother used to give us a bath.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Me, the-- even my father used to give a bath at-- at home.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The mother was everything.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "She used to prepare the-- what do you call it?",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "The meal, which was a good meal, like Mediterranean meal-- salad, fish.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have the chicken noodle soup.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Like, we-- we are a different type of [PAUSES FOR 3 SECONDS] Jews, let's put it this way.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And we had our own-- the famous meal was beans.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "After having the fish and the salad, there was, for Friday night-- was a good-- like cholent, but in a Greek type of cholent.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And we used to have the kiddush.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And-- and there was-- we used to tell many things-- what happened, the whole family.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And then the big brothers used to go out for a good evening.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And of course, I was young at the time.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I used to stay home.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Only in-- on holidays.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Only on Rosh Hashanah, Yom Kippur, and-- that's about it.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I never-- I never learned how to daven in Hebrew.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So I-- I did not go to the synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But my-- my father, he occasionally used to go for mikvah when he used to finish work.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He closed the shop.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He used to-- because our synagogue used to be only about 400 to 500 yards away from our building.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So it was close enough to-- to go there and to do the service for half an hour or so.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The family celebrated Rosh Hashanah--",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we celebrated it.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Pesach, the eight days of Pesach.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We used to have exactly the same as, a matter of fact, we do here in-- in Canada, Pesach.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We used to do the same thing in Greece.",
      "word_count": 9
    }
  ],
