{
  "stem": "752.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And there wasn't much less anti-Semitism than it was before.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "There were very big anti-Semitism.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't want to raise my children in the same atmosphere that I didn't want to stay during the war time.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we had papers to go to Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We eventually got it through the Polish government.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And we went to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I stayed there for [PAUSES FOR 3 SECONDS] maybe 14, 15 months.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And then we came back.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "In Haifa.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "On the Ahuza.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I was selling my own clothes to live on it with my two children.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I brought clothes, suitcases with clothes, a trunk with clothes.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I was going every day.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "My Rena was that time five years old.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She was looking after-- 5 and 1/2 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "She was looking after Rachel.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "She took care of Rachel.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And I went every day to the bazaar, sell something and buy food.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "My husband wasn't working.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There was no work.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "The only work it was is to go to the construction.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he wasn't built for it.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So we lived on that.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Sure, a lot of people, a lot of people from Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They recognized me, too.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And I met a lot of [INAUDIBLE], which I used to belong to the same, [PAUSES FOR 3 SECONDS] you know, club.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, I've met people where a man gave me one room without running water, without toilet, that I could stay with my children in Israel, in Haifa, in that place.",
      "word_count": 32
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very, very hard life.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Because at that time Ben-Gurion wasn't sure what he was doing, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "It was the-- the beginning.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "From Haifa, I came back to Austria, to Salzburg.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "There was a lager.",
      "word_count": 4
    }
  ],
