{
  "stem": "22086.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And there was an elderly man by us in town.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And he acted as a rabbi and gave us [YIDDISH], like you say.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The marriage vows.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't much of a-- a ceremony, just that he pronounced us man and wife.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In the 40-- I-- about the beginning of '42, or end of '41.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I don't think exactly remember, but I always considered that my-- we got married in '42.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "It-- it was not-- there was no place to do it.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I mean, we didn't have a place of our own.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "We just did it because of my mother and his mother.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "My husband didn't have a father either.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "His father passed away before.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So because they wanted it, so we did it.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And he went to his house, and I went to my house where I was, until it came the time to go away together.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "My husband had four brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And they had a business in-- in town by us.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they were involved with a lot of people.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And they had connections.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They knew things.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Like if something would happen, they knew.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They were told about it.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And-- and they knew, at that time, that something is gonna happen, that they gonna make our town free from Jews, and that it's time to go.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And we were just waiting for the time when they'll tell us to go.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What did I-- not a thing.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Whatever I had on my back.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My husband's oldest brother-- we came from work that night, and he said, you have to go.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My husband's three brothers with their wives.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Their mother didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She didn't want to go.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "She says she's not going.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Whatever will be with everybody will be with her.",
      "word_count": 9
    }
  ],
