  "model": "openai/gpt-oss-120b",
  "elapsed_s": 272.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And I was told by the man who gave me that assignment, who happened to work at the Jewish Council as-- and in the high school he was my Latin teacher-- and he told me that you are going to go to the Andrassy Avenue, Andrassy [?",
      "word_count": 47
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Route ?] 60.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Now, that was one of the most feared address in the city, because that was the headquarter of the Arrow Cross Party.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And he said, you will deliver this package which contains a key to an apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And you will call on so and so, and gave me a name.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "He is very high up in the Arrow Cross Party's hierarchy.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And if it's possible that you should give that key to the address in the envelope in the-- in the envelope there is the address and explaining it, what-- what do we-- we want him to have.",
      "word_count": 37
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So I got on my bicycle, arrived Andrassy [?",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Route ?] 60.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And in front of the building at the door, half a dozen armed Arrow Cross uniform people were standing.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And nobody ever would dare to walk up to any of them with the Jewish star on one side of your chest and the arm having this blue sign saying, the Budapest Jewish Council and Budapest Jewish Community Council.",
      "word_count": 39
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And tell him that I am looking for so-and-so.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And he says you're looking for Brother so-and-so, [SPEAKING HUNGARIAN].",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "That means Arrow Cross brother.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "That's how they addressed each other.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And it looked very unusual that a Jewish boy comes and says, I came from the Budapest Jewish Council, and I have to meet him personally.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So the guy took me up.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And a room-- door opened.",
      "word_count": 5
    }
  ],
