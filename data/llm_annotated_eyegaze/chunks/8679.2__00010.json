  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He was the one that never seen enough bread on the table, that never seen freedom.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But we all had that hope, that if we endure, if we try to cope with everything, we might.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He always said, how long can the war last?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It's got to end eventually, which made absolutely sense.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We are going to stop now for changing the tape, and when we come back we will go to find out what's happened to your father, how he died, and also your marriage to your first husband.",
      "word_count": 37
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I would like to say that.",
      "word_count": 7
    }
