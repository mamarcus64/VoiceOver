{
  "stem": "21004.9",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So when I came before a couple of days, before she goes in the city to buy something, and there was a gypsy.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And the gypsy said, come on, I'll tell you all your life story and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "She say, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Maybe it's a good idea.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "How much you want?",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So she says $50.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "You want 50 rubles.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "That's a lot of money.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "So he said, you want to know the truth?",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "So she gave her the $50.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And the first thing what she told her, you have a husband [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "They called me [INAUDIBLE], the Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "You have a husband [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "He's coming the 5th of May.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "But she'd never know when I'm coming.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He is coming.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "The Russian army let him go.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And the 5th of May, he's going to arrive here.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Now you're going to be very happy.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And you're going to come to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You're going to travel through an ocean faraway.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You're going to have another child, you're going to have.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And that's what he tell her.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "She gave him $50.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Now, she came to the house and there was three more people, families, and she was in Lemberg, they supposed to go together.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "She told them the story.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She said what, you're believing in a gypsy?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "How did, she say, how did he know Leon's name, [INAUDIBLE], and the date he is coming?",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She say, I'm going to go and check.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And she went to a station.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Lemberg had, a big city, it had three stations.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "She went to check with another station.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I was in another station.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "So when I came, and I went right with a, with a taxi-- horse and wagon those years, you know-- with a, with a taxi man.",
      "word_count": 26
    }
  ],
