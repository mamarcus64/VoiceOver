{
  "stem": "9908.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But to go with the-- you know, to the borders to go back to-- you had to go-- you had to cross Czechoslovakia then to go into Germany.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So six of us.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "One-- one of the fellows who lives now in Atlanta, Georgia, he went in somewhere, and he-- he found a pair of SS boots.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And he put himself on the boots.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And when we came to the borders, and the Germans-- the-- the Americans saw him, he said [NON-ENGLISH]-- I am Gestapo.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "He said, no, I just-- just picked up a pair and I put on.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I'll never forget this.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "So who were these six people that were with you?",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they're all alive, thank god.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Well, there was one couple, us, yes, as we go back, the five days, which I was in Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "My husband said, you want to get married?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I said, of course, there's nobody here.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We start crying, where's this, where's that.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We got married.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My husband?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Charles.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Aaron Charles.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Aaron-- And Aaron is named after him.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Bless him.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So my husband said-- I said, oh, yeah, I'm tired.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "He said, look, are you coming with me-- I was married already-- or you staying here?",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "We are not staying over here with the Russians.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In Ozorkow.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] married us.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have a ring.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We took some-- something.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Got married, when we came then to Germany, we had to go over everything.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "This was June-- June '44.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "May, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Or end of May, June '44.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, this was '45.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "We just found something from a cigar or something.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And when I came-- we came to Germany, I'm wearing that ring.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And we went back to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "It took us a long time.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the way we stopped.",
      "word_count": 5
    }
  ],
