{
  "stem": "3757.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "So it was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And then we came back.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And in the meantime, somebody moved in in my apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "I came-- somebody was living in my apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He said, I have the right, because I was bombed out.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "I said, I have more right than you have.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And I run around.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "I always can find some connection.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "So I got back my apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And then these two interesting-- three little interesting things.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I-- which one was it first?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So I went-- I opened up again my business.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I need that letter we made that time, the [INAUDIBLE] with letter.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "There was no letter.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And somebody told me, listen.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Here in a small street is somebody who could hide some letter, and you can maybe get.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "So I go there, and I told who I am, and I want letter.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Are you Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Mautner?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And he brought me this little slide.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I said, how did you get to this?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I show to you that I am with a child on my arm.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And he said, in your apartment, one of my friend who was in this Arrow--",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "--Cross organization, he lived in your apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And he found this little slide.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And he kept this in his pocket.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he said, I had a feeling that the Virgin Mary and the little Jesus-- Jesus-- and they saved my life.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And if ever Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Mautner comes back, give it to him back with a thank-- thanks.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "One day, I am in the business, and I see that somebody comes in.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I recognize that this was this Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH], who was in the sanatorium and who asked to talk to him.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I was so grateful.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So I came out, and I say, are you Mr.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And he says, yes.",
      "word_count": 4
    }
  ],
