  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Saul Weitz.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And in the hiding wood, he took care of me.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "We were going out.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We used to go to  dance.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We was not-- I was not setting a wedding day date.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "But I want everything be perfect.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "I say, I'm not getting married.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And move in not with my mother-in-law, and with not my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "I say, I want my house.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "We went shopping, just to got ready the lace for my curtain-- for curtains for the house.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "We used to have the stone, the bricks-- everything ready.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "But where my father wanted to build the house, I didn't like the piece of lot.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "I wanted a different one he should buy.",
      "word_count": 8
    }
  ],
