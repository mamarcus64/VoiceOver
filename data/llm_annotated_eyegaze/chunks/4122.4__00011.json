  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And we were walking there, to Tarnow, and the way was full of dead people from the front and animals, horses-- dead.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But everybody was running from this group.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And at one point, I was already so tired.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't have any shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "My feet were bleeding from-- it was sand and snow altogether.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And I just-- who could ran a little better?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Went, and I was left there.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I thought I cannot go any further no more.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So then came a man, also.",
      "word_count": 6
    }
  ],
