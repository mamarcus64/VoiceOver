{
  "stem": "12343.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "--not for long, because after that, we were not far from the war.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You have to go some-- Yom Kippur.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Yom Kippur, Rosh Hashanah.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Saturdays, my mother, even she left [? nothing ?] [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She [INAUDIBLE] every Friday.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[CRYING] They come.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Men-- used to go, in Poland, used to go [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Poor men used to go for-- go around to every house, to give them a penny like this.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "She go home, and go back, and take some of their own for eat.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "Friday night.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Even she works hard.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "She was-- she was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "[CRYING] That I can't ever forget it.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Jewish.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "No, not Polish, most Jewish, all Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Even the public school, only Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Poland was not so good.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Polish were anti-Semite all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in Poland, terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I used to belong to [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We used to go [INAUDIBLE], all the group.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I used to a stick in my hand, put it here, because I'm afraid of the Polish.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "It started before [? the war started, ?] the Nazis.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And the youth in Poland, we used to call them [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And the Nazis, they call.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Oh, boy.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "One time I used to go to work to my uncle, wasn't in-- in lunchtime, after we come home, going back, they run after me, with the Gestapo-- the Polish [NON-ENGLISH] with knives in hand.",
      "word_count": 35
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And I ran so fast.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I ran-- if I don't run, they will kill me.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Poland's not good.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "The worst-- worst country for.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "I never want to go back after the war because of this.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a young boy.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I used to belong to a sport club.",
      "word_count": 8
    }
  ],
