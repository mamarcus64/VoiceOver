{
  "stem": "1249.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And you get, let's say, a cup of something they call soup.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And the people from you-- or let's say I'm the first one.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "They put me always in the back because they tried to hide me because I was the youngest.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Who is the first one, they get the cup of so-called soup.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And this one cup, everybody had to have this one cup because they didn't have any more.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "So I don't know, five people or 10 people-- I think five people were-- so for five people.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "If somebody was sick, what they can do?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "You are so hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You have to drink it.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I remember one of-- front of me, this woman, she had all kind of [MOAN] open wound all over, on the mouth, and everywhere.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Right now, I would say I'd rather die than drink it.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But I was desperate.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I drink after her, and the other people after, and the other people.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It was awful.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So this was 10 days.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And 10 days, again, Zahlappell went every day.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And one day, they said, again, Zahlappell.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "This was in daytime.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "In the evening, started to train terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "First, was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "The evening was so rainy.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Everything was soaking wet.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And they said, we are going to take you somewhere.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We went to a cattle car.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And my sister said, what's going to happen to us?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We were freezing because of cold and the rain.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't change.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They did not give us dry clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So we went in the train.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And we were crying and crying.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And we were waiting in the train, and-- I think five, six hours waiting.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And they took us to Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Plaszow was next to Cracow in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And we were there six weeks.",
      "word_count": 6
    }
  ],
