{
  "stem": "11175.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "All kind of, you know, ideas.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And then they stopped it on the road.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "The training, they started-- train start to move.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And it stop somewhere.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "They-- we looked it up.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "We asked the SS a little water to drink.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "He says, oh, you're gonna have water.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "You're gonna have water.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "They didn't give anything-- not to eat, not food, not water, nothing, anything.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "If you have to go, you excuse me, and sit in a corner.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "You have to-- everything was together, women, and the men and whoever was there.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And there was one couple.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "That-- I see them, a young couple that looks like they had some poison with themselves.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "And they killed themselves in the-- in the train.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "They was laying there both together, hugged together.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "So I see them laying there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "And so we were-- instead of-- the whole trip has to take from Warsaw to Treblinka.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "The maximum is about two hours you could be in there in Treblinka.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "We were traveling around almost about 20 hours.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "This place.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "Stop this place, and this place, and this place, and without anything.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "Without any food, without anything.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "We came to that place.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "Finally, we came, and we come over the train, and we see a sign, Treblinka.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "[PAUSES FOR 3 SECONDS] The sign on the station, Treblinka.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "Everybody's oh.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "Everybody start to cry, and everybody start to hug each other, and everybody start to kiss each other.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "I said this is the last [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "No-- no more, no more life.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And they start to take us out from the-- from the train.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] Then we went out of the train.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So this kapo, they tell us we should take everything.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We took them out, they're dead.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They were dead.",
      "word_count": 3
    }
  ],
