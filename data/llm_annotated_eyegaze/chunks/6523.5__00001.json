  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And I stock them until, um, the guys came and take it away.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Then we-- l-- helped him to load them.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "But I checked how many.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "Give the woman specialty done repair sh-- [INAUDIBLE] that brought the baskets from many different states and different places to repair them.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "The woman repaired-- let's say each took, uh, so-- so much time to repair, eight or 10.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "Uh, my wife, I took away 10 good one and then gave her 10 good one.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "You know how to survive.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "You try to do.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And I [? accept ?] my wife [?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "Edith ?] to help me in [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "When they come, instead they give you like pens, and jacket, the stripes.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "One was for a guy.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "Let's say he's 7 feet tall, and, uh, so many foot wide.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "They give it to you.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "They didn't give you-- they give you one shoe, a big one, and one.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "And this time, my Edith came to help.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "I give her the-- uh, the suit.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "She took it to her barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "And she know how to sew.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "She made it a beautiful suit, like, like [INAUDIBLE] the factor or [INAUDIBLE] from the tailor.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "[PAUSES FOR 5 SECONDS] This-- over there, was a lady, a SS lady.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "When she brought the woman, the girls, to work, in this field, to the oil field.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And she saw me when I was wearing this suit.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "And I always tried.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "This was very important.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "Your appearance was very important.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "I always, uh, tried to-- to give away a part in your meal or whatever to have a blade to be shaved, and things like this.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "And she saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "She called me into the office.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "And she took me [? for ?] whole people, or whole [INAUDIBLE].",
      "word_count": 12
    }
