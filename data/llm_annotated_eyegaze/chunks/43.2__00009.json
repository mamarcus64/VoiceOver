  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I told them I-- I need-- [INAUDIBLE] was in another camp.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I need those [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I-- I was thinking maybe-- maybe somebody, I left them all in the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Maybe somebody's alive.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So I-- they took me.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] They took me, and we was going to [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I came in town.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Can you hear me?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "You have time to hear me?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I-- I came-- it is written, this.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I came to [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "No-- no one-- no-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Arshun ?] was a synagogue of my father's name.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "No, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I even don't know where-- where I was born, where [INAUDIBLE] was.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But [? our ?] [? rose ?] was near the synagogue.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And in the middle was a cemetery, maybe 100 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We didn't-- in my day, we didn't use this.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Was only for [INAUDIBLE] over there.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And I didn't see nobody from my family.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "So I sit near-- near the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And I was so crying that I remember them.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "My mother used to say that the [INAUDIBLE] is where [INAUDIBLE] 200 years.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "When-- when she got married when she came in this town.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "My mother was from another town.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "When she got married, she came the deferment in [INAUDIBLE] was over there.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "So I was sitting and crying and I didn't know where to go.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "Came a Ukraine [? came. ?] She used to come a-- a sister of my oldest sister.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "She was sewing only [INAUDIBLE] for ladies, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "For-- no, for men's soles, an apron to wear.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So a dear-- a dear Ukraine, she used to come to my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So she remembers me because I got all the children.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But my mother, she used to come.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "The sister was living with Mother.",
      "word_count": 6
    }
  ],
