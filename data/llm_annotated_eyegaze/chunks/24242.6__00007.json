  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Then it's Estelle, my sister, and Tuvia.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And this picture is this is our mill and the bridge.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And this is our land, what you see there.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "This was taken about in 1939 to '40.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My brother had it.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "This is my brother-- I'm sorry-- Asael during the partisans years.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "This picture was taken during the war by his wife.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I made it bigger from a small photograph.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Welcome.",
      "word_count": 1
    }
  ],
