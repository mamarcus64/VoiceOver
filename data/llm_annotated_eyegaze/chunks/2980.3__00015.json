{
  "stem": "2980.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "Quick, quick, it's burning!",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So they jumped down and jumped out of the house.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And the house was all on fire.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I'm sitting there, and the dead people are here.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And the house is burning.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And I watch the, the straw burn.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And everything is straw and hay.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And the fire's coming to me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I'm sitting, and I don't know what, what, what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I was sitting there till it started burning on me.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Then I jumped down quickly.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And I broke a window, and I jumped out.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "At that point, they heard a window breaking.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "So they ran back.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "They were chasing me.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "They tried to catch me.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "I ran into the fire, into the smoke.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And I, I don't know whether the saw me or not, but I covered my face with a coat.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And I was just staying there for another five minutes till I heard that they left with their wagons.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "There were wagons there.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And they-- and they, they took off.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "That's when I ran out to another hiding place.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And I stood there.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And I thought-- I woke up in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "I thought maybe it was a nightmare.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "Then I realized that my mother's not here, nobody's here.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "I am the only one.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "I realize that, that this is the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "I walked out, and I still saw the house burned.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "Then I went back to our hiding place, and I started looking for a knife, or something to, to, to just go wander or give myself up.",
      "word_count": 27
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "It was on my birthday, in January, 1944.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "The Russians were already close to, to-- not far.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "You could hear the, the, the cannons coming back.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "And, and, and I didn't know whether anybody's still alive.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "I had no communication with anybody.",
      "word_count": 6
    }
  ],
