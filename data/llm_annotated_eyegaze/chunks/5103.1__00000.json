{
  "stem": "5103.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Cornelia.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "C-O-R-N-E-L-I-A, S-W-A-A-B, Aaron, A-A-R-O-N.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Cornelia Swaab.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No-- well, they call me Corrie for short.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Second of the second, 1936.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm now 59.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Bergen op Zoom in Holland.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my family continued to live there for a, a short while, because I was born in 1936.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And as things progressed with the, the war, 1940, they had to move.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My parents were from Amsterdam.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Both born in Amsterdam.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "They moved to Bergen op Zoom because they got married.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And they started a business there in the [NON-ENGLISH], which was a furniture business.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my father had always been in the furniture.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And he went on his own there.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And that's where I was born.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Only a little, because I think I was born.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They were married in 1934, and-- in December, 1934.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "So I was born in 1936, in February.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "So I don't think there was much time then to be in the business.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But they had a lady working in the shop, and a man.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Both my grandparents lived in Amsterdam.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we used to visit.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But I was small, and I remember, you know, just going, and my grandmother sometimes coming to us there.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But I don't really remember visiting.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I remember only one thing, that my mother had a, an operation.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "She had a stomach operation, and I went to my grandmother in Amsterdam for a very short time while she was recuperating, and, you know, I was spoiled a little bit.",
      "word_count": 31
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I, I don't know how the kilometers are.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But I remember, six years ago, I went from Amsterdam to Bergen op Zoom.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And it's quite a, a distance, because it's on the Belgian border.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So it's, it's good drive.",
      "word_count": 5
    }
  ],
