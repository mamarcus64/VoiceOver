{
  "stem": "14687.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "If they see you-- you were helping somebody, they hit you.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "Never mind I was sitting in the floor in Auschwitz with two stones and my knees down.",
      "word_count": 17
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Because she punished me for nothing, to help somebody to-- like you say, they were walking to go to the-- to the-- the morning, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "When they used to call us, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And somebody, if she's sick, to help you-- we mustn't help.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "We must leave them there to die, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And the punished me.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "They put me, and they hit me here, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And I had two stones.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "And my knees, they were down, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "On the snow?",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "On the snow.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And the water--",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "The water it was like this color brown, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "The water it was very thin--",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't drink water.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] It was snowing.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "You put it in the mouth.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there were plenty.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Because my block-- we were in one block where all these people that they were dying.",
      "word_count": 16
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "So they changed to a-- a nice little block, who was a nice [NON-ENGLISH], you know the [INAUDIBLE] Jewish girl.",
      "word_count": 20
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "But she was very good.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "In charge.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "She was very good helping us, because we didn't know the language.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "It was very hard, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And many people they used to speak French a little bit, Italian.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "So we used to--",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Not myself.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, what they told you.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Every day.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "We [INAUDIBLE] with the numbers.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] I don't know the number.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "It's A-24444.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "A-24,444.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Auschwitz, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "It was sore.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yes, because they did it with a pin, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And people-- I put it like this, because somebody told me put it like this, and then you can't see it here.",
      "word_count": 22
    }
  ],
