  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 61,
      "text": "Stutthof had a crematorium.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 62,
      "text": "[PAUSES FOR 5 SECONDS] And the crematorium was inside the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 63,
      "text": "[PAUSES FOR 3 SECONDS] The smoke and the odor from burning flesh, people, was horrendous.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 64,
      "text": "And I was taken one morning, they picked me up, put me in a group of people who were supposed to go to quote 'the shower.' But obviously we knew better than that.",
      "word_count": 33
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 65,
      "text": "We had no place to go.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 66,
      "text": "[PAUSES FOR 3 SECONDS] I was able-- had enough-- seemingly had enough [PAUSES FOR 5 SECONDS] common sense and enough [PAUSES FOR 3 SECONDS] resolute in myself, in my system [PAUSES FOR 3 SECONDS] that I walked away from the column of people who were on their way to the crematorium.",
      "word_count": 51
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 67,
      "text": "[PAUSES FOR 3 SECONDS] I remember being caught by an SS guard seeing me move or walk away from this column of people.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 68,
      "text": "[PAUSES FOR 3 SECONDS] I remember being beat up by him, telling me to get back into the column.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 69,
      "text": "[PAUSES FOR 4 SECONDS] And I don't remember much after that.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 70,
      "text": "Seemingly, I didn't have enough strength to go back into the column.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 71,
      "text": "Next thing I do remember is being back in the barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 72,
      "text": "[PAUSES FOR 4 SECONDS] Eventually I got better [PAUSES FOR 3 SECONDS] and [PAUSES FOR 5 SECONDS] came out of it again.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 73,
      "text": "[PAUSES FOR 5 SECONDS] I didn't eat, couldn't eat.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 74,
      "text": "[PAUSES FOR 6 SECONDS] There was very little left of me, but the will to-- to live was there.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 75,
      "text": "[PAUSES FOR 4 SECONDS] As time went on-- this was '44, [PAUSES FOR 3 SECONDS] end of '44.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 76,
      "text": "[PAUSES FOR 3 SECONDS] And then the early part of '45, I miraculously recuperated [PAUSES FOR 3 SECONDS] and got stronger.",
      "word_count": 21
    }
  ],
