  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And a few other.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "But I go seldom to the synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "It's too-- it's too difficult for me.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "I have no transport there.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "I don't drive.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "I drive, because when I was, I think 70, I decided to take driving lessons.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And George said, you never will get a permission.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "And I passed the test.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "So I could drive, but I never wanted a car.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "Yan wanted to buy me a car.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "I buy you a little car, and you will drive.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "I didn't want the responsibility of a car, and all that.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "I take a mini-cab.",
      "word_count": 4
    }
  ],
