  "model": "openai/gpt-oss-120b",
  "elapsed_s": 241.2,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "My father starts going to night school, gets a diploma that he's very proud of, reads My mother's English comes slower because she's not so much out in the world.",
      "word_count": 30
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "She's furiously calling up friends and relatives, asking them how to prepare meals.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Because she's never cooked before, really.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "I don't know how we did it earlier.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "But now she has to learn how to be a housewife.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "She does it very well.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And she does it.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "It's not-- she doesn't, you know, not do it.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "But it's not easy.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "It's, it's pretty hard.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Still speak Polish in the house, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And my sister and I, of course, less and less so.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Certainly, out of the house, we're speaking English.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "But at home, my mother-- partially because her English is poor and partially because she doesn't want us to lose the second language-- always says, speak Polish, speak Polish.",
      "word_count": 29
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "However, the feeling about Poland and what's going on, that's a whole area unto itself.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Because my [PAUSES FOR 3 SECONDS] father is trying to get news constantly about his sister and his brothers.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And he's-- you know, I remember him writing letters and [PAUSES FOR 3 SECONDS] waiting to hear the news.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And the news is never good.",
      "word_count": 6
    }
  ],
