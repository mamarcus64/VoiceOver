  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And then through the week, if we wanted chicken to have or something, then we went to him, other he came over and he did it.",
      "word_count": 26
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Thursday, he used to go in in every village.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "He was-- he used to live in our village, although he was to go in three villages.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "The same shochet.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And whatever was prepared, cows--",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I didn't show on the film.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Him son lived in Florida.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I talk-- I talked with him a long time ago.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "He was a nice, nice shochet.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We used to go into the shul in the morning, Daven and prayer.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "It was a big shul, the room we was sitting.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "It was meet-- a [? matzav. ?] It was woman next door, and the men used to sit next to it.",
      "word_count": 21
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And my mom-- mother was so religious.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "She always scared she didn't pray enough.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "She used to come home-- [CRYING]",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "They was very-- when I speak about it.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] My father-- we was eight children in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He wouldn't-- he never hurt nobody from us.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "He used to howl at us, don't do this, don't make noise.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "He would never touched us.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "My mother, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "She-- she was a little different with-- well, she was in house the whole day with us.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Although my father, he wouldn't kill a fly on the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "He was so honest, and died so ugly.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] But it's over, that.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And died young and ugly, and that's it.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They was both young.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Something in the 50, maybe.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Well, they married young.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "They got children.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "They got grandchildren already.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "They was young.",
      "word_count": 3
    },
    {
