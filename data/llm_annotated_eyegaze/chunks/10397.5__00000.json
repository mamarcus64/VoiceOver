{
  "stem": "10397.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--Brand.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Wonderful.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "The first time I talk so much.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "K-R-Z-E-M-I-E-N-I-E-C.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Russia Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I met my cousin, and I met his wife.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I met four other Jewish people there, a doctor, his wife, and a boy-- and a son, and a couple without children, and her uncle, and my cousin, and me.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And she fed us all.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She was a business woman.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She saved his life.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "This doctor was in the woods, somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The other people, I didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So she was trading American cigarettes for bread, for chickens, for-- for honey, for food.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And she fed us three meals a day, this woman.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Then she-- then he was drafted.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Russia organized a Polish army.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "A Russian-Polish army.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And she drafted my cousin in the Russian-Polish army.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And she concealed her pregnancy and joined, volunteered in the Polish army, herself.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And the other Jewish people left, because they made their-- you know, they found a-- And I remained with the uncle.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And the uncle was a farmer.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And I went with him every Sunday to the church, to the Polish church, the Greek-- Greek Catholic church.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And yeah, and I joined-- I went to work in the hospital, a big hospital, 100 beds.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "I was the only doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "There were 25 doctors in Krzemieniec before the war.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "The Jews were killed, and the Polish doctors ran away with the-- with the-- with the Germans.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "They'd rather be with the Germans than with the Russians.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "They were afraid of Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And I was in charge of the whole hospital and did operations without any much training.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "We had all kind of diseases, you would not believe it, amputations and eye removals, pneumonias, and typhus fever.",
      "word_count": 19
    }
  ],
