  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Then I met a French officer.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "My father had a family in France and had a brother there.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "'45. '44, '45.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, '45. '45.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "My father had a brother, and I remembered the address in Paris.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "So I asked the French officer who spoke German.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I spoke to him.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "So I said to him, you know, I had an uncle, my father's brother in Paris.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "This and this address.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "But I-- there was no mail.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Would you be so kind.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Find him and tell him that I survived.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And he went to him.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "He went to my uncle and talked to him.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And then somehow the mail was starting to come.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And my uncle sent me a little package from France, from Paris.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And I got it.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] And my uncle told me his story.",
      "word_count": 11
    }
  ],
