{
  "stem": "11671.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And my father forbade us to be Zionists, but the Zionist youth movement, the general Zionist youth movement was very strong in our city.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And we all secretly belonged to it.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And my oldest sister was very active in it.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We were still a little bit too young.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "But she used to go to meetings regularly.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And my father forbade her to go.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And sometimes she would, we would prop up the pillows in the bed, pretend that my sister was under covers sleeping.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And she would sneak out.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My father locked the doors, made sure she didn't go out.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But she would sneak out through the window to go to a Zionist youth group meeting.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And she even had certificates to go to Palestine in 1938, but my father forbade her from going.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And her friends all went, and they survived the war and live in Palestine.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were, we were very Zionist-oriented.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And we children, we used to go to the meetings-- not as much for the younger ones.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My sister is four years older.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So we used to go to the meetings and learned the songs and sang and hoped for that in the future we will be settling in Palestine, that we will make aliyah one of these days, and we will establish a kibbutz.",
      "word_count": 42
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "So we were always with that hope and that we will someday will go and learned all the songs and, and used to take classes to study a little bit the history of, of Palestine.",
      "word_count": 35
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "As children, our hobbies-- our main hobbies was walking.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We used to go to the park a lot and play.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And reading, that was one of the main hobbies.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I did a little gardening and learned a little cooking.",
      "word_count": 10
    }
  ],
