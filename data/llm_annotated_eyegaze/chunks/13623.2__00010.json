{
  "stem": "13623.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I had never heard of this town-- of this city before.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "After we passed Krakow, not too long after, and they see the-- the German-- by the way, in Kaschau, when we stopped in Kaschau, the Hungarian army pulled back.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And the Germans took over.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 6 SECONDS] After we passed Krakow-- I cannot remember how long after that.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] They always timed the arrivals of these people like us into Auschwitz at night.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] People are more confused.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "For whatever reason they had, we-- all these transports came at night.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] It's in the middle of the night.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "The train stops.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "At this point, we never heard of Auschwitz, Birkenau.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "We don't know where we are.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Soon as the train stop, we hear what sounded like rifle butts hitting on the sides of the cars.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] The doors are being opened up.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "We see the SS.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] And the orders, they hollered at us.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "[NON-ENGLISH], the dirty Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "[NON-ENGLISH], get out.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "Disembark.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 4 SECONDS] When we-- we were all confused.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "We didn't know what was happening.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 4 SECONDS] We had to jump off the train.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "There was no-- no way of-- of walking down the step from the railroad car this high up of the ground.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "We had to jump off that train.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "Soon as we jump off the train, we-- there is confusion.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "[PAUSES FOR 3 SECONDS] People lose each other.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "The-- the SS had German shepherd police dogs next to them.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "The dogs are barking.",
      "word_count": 4
    }
  ],
