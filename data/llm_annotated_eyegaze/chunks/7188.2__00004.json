{
  "stem": "7188.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And with the way he said no, I know that something is wrong.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "I said to my uncle, why can't you see Ma and tell me how she's doing?",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "He said, I'll try.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "There was barbed wires already made.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "He was before, a few months in Majdanek.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "What happened when you first got to the camp?",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "What was the process like of the registration?",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They enclosed us, took the clothes off.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They gave us their own clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "What is the clothes?",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "KL marked.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] It was red marks, KL.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "K-L.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Concentration camp.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They gave us clothes, and they sent us the next to work.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in a barracks in Majdanek.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "The barracks wasn't so bad.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I slept with my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] How many?",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Young girls.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "All young.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "In Majdanek, I met my cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They came before us.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And they said to us, is that you, [?",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Gina? ?] I says, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "She looks so swollen, blown up.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I says to my sister, what's wrong here?",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They were blown up from hunger.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "When you put a needle, the water would explode.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "That's how big they were.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "They didn't live long.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] Majdanek was a death camp.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "What happened when you first got there, that day?",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "You said that they put you to work right away?",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "In Majdanek, we did in the gardens, vegetables picked for the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Lettuce, carrots.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Every day, we worked like this.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Then we worked for brick, the Jewish houses, to take them apart, the bricks separating, build the road from the bricks.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "We helped them to take care of the-- what do you call it?",
      "word_count": 13
    }
  ],
