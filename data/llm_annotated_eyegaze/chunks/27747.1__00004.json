{
  "stem": "27747.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And in the morning, he would go back to shul in the morning-- Shabbos morning.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "I do not remember that my mother went to shul on Shabbos.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "But on the holidays, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "The holidays were wonderful, really wonderful.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Starting from the spring, Purim.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Purim was-- was especially interesting, because the out of town young people would come and perform for-- for our town.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "That was probably for food stock and for-- for charity.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "But at first, I would be afraid when I was very young, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They would come in in outfits and costumes.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And later, I loved it, because they sang and they performed and they would leave, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "They would be fed first, and then they would leave.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Then Passover was such an ordeal of preparing.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The-- the Passover stuff was stored, part of fit, in the buffet in the living room, dining room area.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And the rest, pots and pans, in the attic.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And everything would come down and be washed and [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Matzo was-- was prepared in-- in special places of [PAUSES FOR 4 SECONDS] matzo baking.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "It was baked by hand at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Town.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Town, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It was large ovens.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And I would run in to see and taste a piece of matzo.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Sometimes a lot of children from the school would also go and participate and help in matzo baking.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we had a very nice Seders.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Two hour Seder would come my aunt from Dombrovitz.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "She and her husband and the two children and [?",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Gania. ?] And [PAUSES FOR 7 SECONDS] Uncle [INAUDIBLE], [CRYING] his two children, [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] is a survivor.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "She survived in Russia, and she's now in Washington DC.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Yosef, her brother, is somewhere in Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "We-- we don't know where.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We're not sure.",
      "word_count": 3
    }
  ],
