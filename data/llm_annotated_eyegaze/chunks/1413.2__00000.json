{
  "stem": "1413.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Now, if you're 19 years of age, I think about the time 19, because it was 1942.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was 19 years of age.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And if you realize now that I'm 71, what I did, what I had to do-- what they made me do-- [PAUSES FOR 3 SECONDS] you can understand I get emotional.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "There were only Jews there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] So you can imagine who it was for.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I have a paper here.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I looked to it last night.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I'm going to show you that later, if you're interested, that to my surprise-- really, one or two-- on a partial list, a very small partial-- very, very small part-- that two died in Westerbork.",
      "word_count": 36
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I was stunned last night, because now they came-- all ages, they came there.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I got admitted because my family was from-- from one year old to my father, the oldest-- [PAUSES FOR 4 SECONDS] 61 years old at the time.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I have a very, very small list here, very small-- only from the two-- two families' name-- my wife's, second wife's, and my own.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And maybe later on, it is interesting to pick that up there, because I got it down on a-- on a printed piece of paper.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "From-- I don't-- my wife says my daughter got it in [NON-ENGLISH], but she might have gotten it in Holland.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember where she got it.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Bragging-- everybody can brag, but nobody-- I mean, so many who brag who can back it up, but I can back it up.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "The word, [GERMAN]-- you might know in German, you don't have to go.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "The-- I don't know the English translation.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You don't have to go because you're-- you're-- I can't translate it.",
      "word_count": 12
    }
  ],
