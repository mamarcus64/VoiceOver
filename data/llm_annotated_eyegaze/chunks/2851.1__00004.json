{
  "stem": "2851.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Everyone tells a-- told another story, what's-- what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We'd been in-- I've been in ghetto one year.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Then they used to-- when they killed, in the other ghetto, the people, they took us out from their houses and they killed them.",
      "word_count": 24
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "The name of the place was [NON-ENGLISH] in Kowel.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "So in one day, they killed my mother, my brother-in-law, my sister and the two children.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And-- and me and my sister were together in the other ghetto because we worked.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, people came.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people came.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "They run away, so they came to us and they told us.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And-- and left other people that there was hide there.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They couldn't find them.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They find them in a few days and they brought-- they brought the people to us.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "So they told us what's what was.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] It was-- we were-- we were last.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "We knew it will come a day and we'll go.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "But my-- my sister has a boy-- had a boyfriend, and he worked not far from Kowel.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "It was Kosz-- the name of the place was Koszary.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "He worked whatever he had, outside on the-- [PAUSES FOR 3 SECONDS] he made, like-- he helped one man make the-- the fence, like some-- some things like this.",
      "word_count": 29
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Motl Fisher.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And he heard about everyone was killed.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "So he took a man, he paid him, and he came into the ghetto.",
      "word_count": 14
    }
  ],
