{
  "stem": "11167.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We came from a orthodox home.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "My uncle, and-- and auntie, and my cousins went to Israel in 1928.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "It was a long time ago.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "It was a long time ago.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And he was the one what he used to always the speeches in-- in-- in synagogues, you know, to make-- to make aware the people what is going to happen-- what is going to happen.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And they was-- they still-- I've got still two cousins from-- from this side in-- in Israel.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My mother was from, also from not a big town.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And she was young.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "She was a young person-- a person what always worked.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "She used to help people.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Friday were-- you know, Poland was very cold-- very, very cold-- behind 20, sometimes more.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "She used Friday-- Friday morning-- call these people-- you know, people what they really didn't have.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They used to come for coffee, and sandwiches, and that was her standing all the winter still, start to be a little bit warmer.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Poor people-- you know, people what they used to buy eggs and chickens and sell, you know, for just the [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "That is the-- the same--",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "This is the same kind of people.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Did not all.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "There was a 10 of them in our district, but they used to always come to us.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And that was the standing quota for winter.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Still-- you know-- still they could manage to-- on their own.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "My oldest brother was the governor in shul.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We was-- we was people what-- we wasn't extremely rich or extremely-- but we-- we managed to be in-- in with everybody, like you say, to help one another.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The holidays was beautiful-- in one way beautiful, in one way not, because we didn't have my father.",
      "word_count": 18
    }
  ],
