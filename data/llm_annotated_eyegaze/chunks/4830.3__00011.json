  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But if I move in, I will immediately write him 10 IOUs, and every week I will cash one for him, because gradually I will the money.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I thought that the Russians will be there in a week or two, so there will be no problem.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "But-- so he agreed that this is probably the best solution under the circumstances, and we moved in.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And we lived there during the siege of Budapest.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Everybody had a function there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "My father was a night porter, my mother was in the laundry, my sister was in the kitchen, I became a member of a rescue team, and my younger brother was in charge of the central heating of the house, which meant that he kept feeding the coal-- it was based on coal-- into-- into this central heating equipment.",
      "word_count": 59
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So this is how we lived there when the siege came, not too long after we moved in.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And the siege of Budapest was as bad as I expected it, but somehow I felt that we shall survive.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "At least I hoped so.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I was always concerned about my younger brother who could not really, in my opinion, take care of himself.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So we were-- he was in the same team, initially, but I arranged that we had eight hours service, eight hours being readiness, and readiness-- and the eight hours sleep.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And instead of him, I took the other eight hours because I knew that I can be more careful than he can.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how you're careful during the siege, but I was, and I was successful.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "So he stayed in, which I think for which he is still grateful to this day.",
      "word_count": 16
    }
  ],
