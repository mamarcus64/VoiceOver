{
  "stem": "353.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I was playing soccer.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And the president of Hakoah in Vienna got to know that somebody of the name Viktor--",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Vienna, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Right He created the Hakoah there.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember his name.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "But I will tell you this story, how do I got to Vienna.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So he, the president of Hakoah Vienna, decided-- got to know some boy is in-- is in Bad Ischl and plays soccer for-- I used to play soccer for the Austrians, and I used to play soccer for our Jewish-- Jewish team.",
      "word_count": 42
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "So he came in, and asked me I would like to join his club.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I said, I don't know whatever you're going to offer me, but we'll see.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Second time he came, so he brought his team and he said, your team gonna play my team.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Let's see who's going to play better.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And my wife gave birth to my daughter the same time exactly, the same day.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Bad Ischl, on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So I said, I'm not going to play today because I became a father.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "So-- somebody else is going to play on mine.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He said, no, I want to see you playing.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "He took a-- a bouquet of roses and went to my wife to hospital, and I went with him.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And he asked her if she would let me play today a game.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "She said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And I played the game.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I hit two goals.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I scored two goals and then he said, I'm going to bring you to Vienna.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "But he didn't bring me.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "I went myself to him.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I went to play with some of his players to Vienna once but later on I moved along to Vienna.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was playing soccer and a little bit I had myself on other things.",
      "word_count": 14
    }
  ],
