    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Traveling all around Poland-- not Poland-- Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "Because before the war, Poland was beautiful.",
