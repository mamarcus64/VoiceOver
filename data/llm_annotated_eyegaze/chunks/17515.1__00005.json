    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "I get on at the castle in Wilanow, a beautiful museum.",
      "word_count": 11
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 6,
      "text": "So I travel during the daytime, Saturday and Sunday.",
      "word_count": 9
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 7,
      "text": "Because it costs me nothing, only time.",
      "word_count": 7
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Very much, especially the old town, [INAUDIBLE].",
