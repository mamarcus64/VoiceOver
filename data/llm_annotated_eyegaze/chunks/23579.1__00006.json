{
  "stem": "23579.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She was working very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "She wanted the children to know everything.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We had tutors in the house, Hebrew tutors.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I remember that a rabbi was coming and was studying with the boys [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You know what it is?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I remember now.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Because they were [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They were not very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "So my mother said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You're not religious, but I want you to know about the religion because I'm a Jew and you are a Jew too.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "So they gave it to them everything in a house.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "So they knew everything.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "They're studying everything.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And full with friends.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Full with friends.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The house was full with friends always.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Saturday night, were about 10, 15, people eating by us.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Saturday night was like this written in the calendar.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "They were eating potatoes, herring, cream.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Everything [NON-ENGLISH], not meat.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Dairy.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And for sitting about 15, 12 people.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And they were talking about the politics, and about Israel, and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "This was it.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I was not always there, the truth because I didn't believe in this.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I went to a Polish [NON-ENGLISH], a Polish school, where only 2%, 3% Jewish girls and boys went.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So I was far away from them.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I never belonged to [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I far away from this [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "You see, my brothers were in the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They were working there.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And they took in many boys and girls, but they didn't have it how to study.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So there, in the [NON-ENGLISH], they gave it to him.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "This for study with them.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They were learning about Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They're learning about [NON-ENGLISH] Israel, and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "What language was spoken at home?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "But my brothers were very fluently in Hebrew.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Me?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was attending high school, from the [NON-ENGLISH].",
      "word_count": 8
    }
  ],
