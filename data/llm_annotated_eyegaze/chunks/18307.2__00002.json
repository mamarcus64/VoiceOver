{
  "stem": "18307.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 95.4,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "The boys could not go out because if they caught-- that they were more known than a girl and if they would catch a boy, they were circumcised so they knew right away that they-- you know, they were Jewish.",
      "word_count": 40
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So they send me.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I was the older.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "One day-- believe it or not, this was a month before we were liberated, but we didn't know we were going to be liberated-- Unubra's son, he had two sons and a daughter.",
      "word_count": 33
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The daughter was very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "One son was in Germany in a labor camp working as a [INAUDIBLE] and one was a-- he was no good.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "He was a collaborator with the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And he told Unubra at the farm, he says, you get rid of the Jews because I'll give them out if you don't get rid of them.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "So they had to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Unubra comes in cryin'.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "He was such a good man.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "He was cryin'.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And he said, you'll have to leave because my son, of all people, is going to give you out.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "So I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "One day I went out for bread and I saw this farm on a hill all by itself.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "His name was Yaski, the guy that owned it.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Can you spell that?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Y-A-S-K-E.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He lived with his wife on that farm.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "But at night he would go into Mlynow because he was afraid of the Ukrainians-- they're going to come and burn his farm down because there was fights going on between Ukrainians and Polish.",
      "word_count": 34
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Mlynow was my hometown and there were more Polacks there so he was safer there than the farm.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Because if they would burn down the farm, he wouldn't-- he would die.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They would kill him.",
      "word_count": 4
    }
  ],
