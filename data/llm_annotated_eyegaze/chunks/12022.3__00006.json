  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And the next day, everybody who wasn't registered was shot.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And me, and my three brothers and a cousin, they pick us out to pick up the bad people that try to run away.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They give us all some [INAUDIBLE], [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And we start to pick up the people.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We picked up about 80 people.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "No one [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I walk in.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I saw a woman sitting with a baby, about a year old.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 16 SECONDS] [INAUDIBLE] [CRYING] Yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "They was even both shot.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "The woman was sitting dead, and the baby, holding the baby, dead.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And by the baby was hidden out a piece, a chunk of meat from an animal.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I don't know, from a cat or skunk or something like that, some kind of wild animal.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "Naturally, ?] I put it in the wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And we pick out all the dead people.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And we are talking about-- I think it's all, they're all picked up.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Finally, I see a man is walking with a blanket-- thrown over in a-- in a blanket on a [INAUDIBLE] baby.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "They was hiding in that place about 30 people.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "It was about a month old, the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And the baby start to cry.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And they start to yell, do something to the baby.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "Finally, the father quieted down the baby.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And when he brought the baby, give it to me handle, to me.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "And he said, I'll get murdered for my baby.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "I'll ?] [? get murdered ?] for my baby.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And behind him was standing a little girl.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And she was looking at me, so sad.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] And actually a little-- this little girl-- [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "You hear about her?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And I took the baby.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I put the baby in the wagon.",
      "word_count": 8
    }
  ],
