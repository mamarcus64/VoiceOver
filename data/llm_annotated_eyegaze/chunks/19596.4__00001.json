{
  "stem": "19596.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 47.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I did, because a couple of times I was cleaning-- I was selected to clean or deliver laundry in the later stage to them in their homes, like a laundryman, so I saw that.",
      "word_count": 35
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I saw the Jewish children playing there, beautiful dressed and all.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to the Union.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We worked in ammunition factory together with women.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We had connection with women.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "So a lot of men wanted to have that connection with women and they paid me for it.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "For delivering letters and notes and finding out which women are with me, or-- some women which are working there are working with their wives in-- in Birkenau.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They had to pay me in bread or in rations or in cigarettes, mostly cigarettes.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Mostly I took cigarettes.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They could-- they could change it themself into cigarettes and pay me in cigarettes.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Cigarettes was a currency.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I risked my life.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I risked something.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "If they find notes for me from somebody else, I get 10 and 15 on-- on my back.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Nothing is without risks here.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And why should I do it for strangers?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "In the factory itself, pretty good.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They were-- because the SS who were [INAUDIBLE] were specialists like engineers and things like that.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They put them in there.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They were in the SS uniform, but they were engineers and turner and fitters and things like that.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They were professional people.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "They were not animals from the bush, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "So they treated the prisoners like a-- like a professional, like their apprentice or something.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And then there were overseers, which were not professionals.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "They were in charge of the whole group of prisoners.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, not so good.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Screaming, shouting, pushing, usual thing.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Oh, hitting, yeah, sometimes.",
      "word_count": 4
    }
  ],
