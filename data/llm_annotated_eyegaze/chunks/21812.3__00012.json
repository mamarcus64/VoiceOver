  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "I don't know whether the-- how the steamer trunk-- whether it followed me or what.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "Did eventually wind up in Bradford.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "And I got on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "It must have been about a five hour trip.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "And so actually, it took two days before I got from, got from Vienna to Bradford.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "And on the station, Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "Hurst was there, and welcomed me.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "And, and his designer, I think, was there too.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "And he spoke Yiddish, so that helped, till I started-- and I went to school.",
      "word_count": 15
    }
  ],
