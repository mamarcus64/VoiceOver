{
  "stem": "3206.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "One guard, whether he was a Czechoslovakian, I think, maybe, or maybe a Ukrainian, I don't recall.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But the way he was speaking to me-- so he came over to me, and he says, what are you-- why you crying?",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Be quiet.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "If not, we're going to shoot you.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I said please, do that, because I can't survive, because this is the end.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You can see-- he said-- said to me-- he gave me a piece of sugar.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And he said to me, don't think about it.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The war is soon going to be over.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "You're going to live.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Don't think about it.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So I said to him, how am I going to live?",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Here in the ground?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "In the cold ground in March?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "I'm going to live?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I can't move.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My feet were swollen like that. just as you see-- so broken.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My back was broken.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My ribs was broken.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "My [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I was broken up to pieces, and I couldn't move.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So he said what's the difference to me, whether the war is going to be over?",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I can't survive this.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "He went away.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "He'd see what's [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He went away with the whole group back to the barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I was lying there on the ground-- March.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "So I got tired from crying, so I figured, what the hell?",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Another hour, another two hours.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So it's near then.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "All of a sudden it got dark.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "From nowhere, here came, a wagon-- a small wagon with a horse and buggy.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "A Werkschutz, a Ukrainian, he took me, put me in that wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "He took me back to the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I said, what is this?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "Couldn't figure out.",
      "word_count": 3
    }
  ],
