  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 15,
      "text": "And, and, and I have a-- it's a good job, because I have the possibility to, to, to travel a lot.",
      "word_count": 21
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 16,
      "text": "Because this is the, the railway.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 17,
      "text": "And when I find out my brother is in [NON-ENGLISH]-- the accident.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 18,
      "text": "Because I've been in the-- in the-- in, in Kiev.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 19,
      "text": "And they start to organize the Polish, Polish-- [PAUSES FOR 5 SECONDS] the people who run.",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Refugees.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "They're all refugees, Polish and Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "They start to organize.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "They call this [NON-ENGLISH SPEECH]-- the Polish patriots to go back to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Polish--",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Polish and Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "A special organization, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And [NON-ENGLISH SPEECH] they call this.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I have-- and they-- and they-- it must be somewhere.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "No, I haven't got.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And, and when I was there, it was a, a, a, a, a lady, a girl, a woman, was coming from [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "And she says, he, he knows the same name in [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And [NON-ENGLISH] [SOBBING] is 3,000 kilometers from, from, from Kiev.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And yes, I find out this is my brother.",
