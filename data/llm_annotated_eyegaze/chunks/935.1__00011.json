{
  "stem": "935.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "It was-- oh, yes, it was called And I remember that I really, I had the first word.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I had the last word.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And mutti called it type casting.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "It was absolutely right for me.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You must know I grew up in an era of the theater which was fabulous.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I really got to study and to learn with greats, the really the great, great, great actors of that time.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "So it was very thrilling.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I mean, I wouldn't have exchanged this childhood for anything.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I started later.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "As a child, the director of one of the theaters was Dr.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Leo Strauss.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "He was a descendant-- direct descendant-- of The Waltz King Strauss, the Strauss family.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he kind took me under his wings, like-- like-- you know, protection-- artistically only.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And he told mutti that as a child I should not study, because then I'd lose my natural-- you know, then it becomes too stilted or something like that.",
      "word_count": 29
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And it was good enough for me just to use my-- no, listen and use my natural talent.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I started much, much later.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "When it became time, he said to my mother that now it's time for me not only to use my talent but to learn the craft.",
      "word_count": 26
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And I studied with the very, very best.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "There were certain schools in Vienna, like Max Reinhardt or the Academy, Professor Wieland.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I was-- well, I played all through.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I started with-- well, I started dancing much sooner, of course.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I started to study dance-- ballet, modern dance, all of it-- much sooner.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "But when it came to acting, I was 14 or 15, something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I started, know, speech, diction, music, singing, composition, the entire history of the theater.",
      "word_count": 14
    }
  ],
