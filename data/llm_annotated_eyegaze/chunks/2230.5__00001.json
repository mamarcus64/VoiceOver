  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS] And we decided to [PAUSES FOR 3 SECONDS] buy him a ticket.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "Everybody had to pitch in.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] To make a long story short, of the $60, I had $10 left when we landed in Haifa.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "We landed in Haifa.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "People from the kibbutz take-- took us to a place called [INAUDIBLE], which is on the Lebanese border.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "My daughter, Leah, was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And we were there for five years.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] My wife, my kids, and I--",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Jay.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Decided to come back.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] So we came back.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I became a Fuller brush man.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I became a salesman.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I became a cook, a waiter, you name it.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "One good thing is that I was never out of a job.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I always had a job.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Not one day was I out of a job.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And then in-- [PAUSES FOR 3 SECONDS] my daughter and my son were asking questions, and I just could not open up.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The minute they asked the question, I would turn around and walk away.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I would say, leave me alone.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Don't bother me.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They tell me that now.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "But they wanted to know, and I couldn't open up.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't say a word.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And then, in--",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "She was born in Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] And [PAUSES FOR 4 SECONDS] my daughter said, you must go back to Poland.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "She says-- in order to get me there, she says, for my own therapy, for her therapy, I have to go.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So how many kids have I got?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So I told her, I said, you pay, I'll go.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She paid.",
      "word_count": 2
    }
  ],
