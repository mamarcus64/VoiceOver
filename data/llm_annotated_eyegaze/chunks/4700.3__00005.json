{
  "stem": "4700.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My mother didn't want to leave, because she had a little pension there.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She had a little flat.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "She had a few pupils, and--",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "She could lead a stable life.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, she didn't want to.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And then when I got the permit-- and I didn't tell her anything.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I got my passport, and I did my-- get my visas and everything.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I only told her right at the end.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "22.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And she was awfully against it.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And meanwhile, I had a boyfriend who was also awfully against it.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But I left.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was rather funny.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I, the people I-- the person I've worked for, whose secretary I was, my first job-- he went to Australia, while I was at the Hebrew Aid Society.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I was in charge of transportation at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And somebody dubbed him in that he tried to get some money out or whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And he-- somebody told him they were going to fetch him that night.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And so he came in desperation to my office, said, can you do anything for me?",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Can you get me two seats?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We've got passports.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Can you get us two seats on the train out?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And so I said I'd try my best.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And I did get them two seats.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And he said, Edith, if you ever come to Australia, our home is your home.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I said, what will I ever do in Australia?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And I sort of forgot all about it.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And then, when I knew I was coming here, I had the address.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "The lady's brother was in Australia, and I had his address, because when they left, they gave me his address.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "So I wrote to him that I was coming.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I heard nothing anymore, so.",
      "word_count": 5
    }
  ],
