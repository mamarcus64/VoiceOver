  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There was a cabinet, and glass, and one [NON-ENGLISH]-- a-- a-- a General, sitting, looking on the papers, or some-- looking there.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I knocked to the door, just opposite him.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And I knocked at the door.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I didn't open the door.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING GERMAN] That is just to disappear.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I risked already to go through the whole city.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And risking so, and to go back, not to have the stamp from the Feldkommandantur?",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was around, around, around, around.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "It was a colossal cabinet there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And behind him, was another door.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "It was very hard to find out.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "There was an opening there?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Or was not an opening?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "But I find another door.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And so I didn't knock to the door.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I went to him.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I sat next to him to-- there, on the left side.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING GERMAN]",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING GERMAN] Where-- where have you [INAUDIBLE]?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Where-- so I was only just putting.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And he was not looking on me, and just his stamp was going on.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And so I-- I-- I arranged an [NON-ENGLISH] This mean a camp of Jews what they haven't got the arbeitscheins.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "That was-- we called them that time, [? lebenschein, ?] a schein to leave.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "A--",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And so-- and they were working all the time [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Names?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Boruchuovicz, Nelkin-- a daughter is here-- lives here.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The father's name?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Oh gosh, name-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Forgot.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But the-- Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Gross' ?] father-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Gross, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Gross-- ?] She's a-- she's a [?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Gross ?] wife.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "The father was amongst them too.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "It was a German, a general, a-- a high ranking-- a feldkommandant.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I didn't show it to him.",
      "word_count": 6
    },
    {
