  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And they gave us rags.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And [? we ?] [? coat ?] was in the wintertime.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And we put the rags around our feet.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "They were swollen.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "We-- and we couldn't walk.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "It took us a couple days.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "And then I took my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "And we walked the 12 kilometers to Rovne. with [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "And we left the children.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "Then a couple days later, he took the children in a wagon and covered them with straw until I find a place where to be.",
      "word_count": 25
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 11,
      "text": "And he brought the children, that same guy.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 12,
      "text": "He-- they died.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 13,
      "text": "I was sending them packages.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 14,
      "text": "I still send the package.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 15,
      "text": "Last year we supposed to go to see the daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 16,
      "text": "But we got a letter, she died.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 17,
      "text": "And we didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 18,
      "text": "I, and my daughter, and my granddaughter, they [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 19,
      "text": "We had already the papers and everything to go.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 20,
      "text": "And she died.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 21,
      "text": "So I stopped sending packages.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 22,
      "text": "[SOBBING] So the first bite of bread, the first dollar I made in America, I send it.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 23,
      "text": "Because things [INAUDIBLE] real life.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 24,
      "text": "I'm not so happy my life, but my daughter's alive.",
      "word_count": 10
    }
  ],
