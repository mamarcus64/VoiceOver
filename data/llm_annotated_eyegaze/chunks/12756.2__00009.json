{
  "stem": "12756.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And we have to go from Rivne to Kostopil.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And then I drive to Kostopil.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "We came close to Kostopil.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "The other city is in a ring again.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "Then I ran it again further.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "Then we ran to a farmer.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And he tells us, stay-- no, then, I'm sorry, from then, I went-- I went to home to Berezne.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "And my parents still were there.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And the sister, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And then just a little story once.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "You want farther now?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Then--",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "There was the same.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Low on food.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I don't brought them any more bread because you know that.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And then I went back to working at the same job.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "When I came at the same job, between work and the job, I picked together-- farmers was owing me bread.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They give me the bread.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And I thought in the morning, I think they got lots of bread.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I go on back to Berezne and give my parents the bread with everything.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "I walked out three miles from the village, comes over a Ukrainian.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "He knows me, because I used to come and give him clothing for bread.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "He said, where are you going?",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I said, what do you mean where am I going?",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I'm going home, you know that.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Don't go home.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "The whole city is in a ring.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And they are killing all the city, the whole town.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] Today they are going to be all killed.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And they started-- I heard the guns shooting, shooting gun noise-- the guns.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Then I thought, I don't go anymore to Berezne.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "There is no use.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "They said, if you want to be killed, go.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Then I knew a farmer.",
      "word_count": 5
    }
  ],
