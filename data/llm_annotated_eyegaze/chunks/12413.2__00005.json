  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 4 SECONDS] The doctor was in charge of the building.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "Was a former Polish officer, a doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "He was more [? poor ?] than a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "He spoke fluently German.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "He was a good friend of Captain Degenhardt.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 42,
      "text": "[PAUSES FOR 4 SECONDS] I think [PAUSES FOR 3 SECONDS] he liked him because he was just a [INAUDIBLE] man.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 43,
      "text": "One day, or one night, it was June or July.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 44,
      "text": "[PAUSES FOR 4 SECONDS] Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 45,
      "text": "Wahlberg got an order [PAUSES FOR 3 SECONDS] by a Polish cop to go for interview, for a meeting with Captain Degenhardt.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 46,
      "text": "It was dusk.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 47,
      "text": "I was in the little window looking into the street, which was totally deserted.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 48,
      "text": "The headquarters of the SS was in the street at the corner of Garibaldi-- this was the street-- and Wilson-- Wilson street.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 49,
      "text": "And then, after 15 minutes, there was a shot [PAUSES FOR 3 SECONDS] resounding in the street.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 50,
      "text": "[PAUSES FOR 3 SECONDS] Something very unusual, because the street was empty, deserted.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 51,
      "text": "There was a big warehouse for the Jewish property.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 52,
      "text": "Furniture, all kind of clothing, shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 53,
      "text": "Then after 15 minutes, a Polish cop came running.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 54,
      "text": "My father opened the gate.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 55,
      "text": "He went down.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 56,
      "text": "His wife, the doctor's wife, and his daughter, age 16, were living in this place.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 57,
      "text": "[PAUSES FOR 3 SECONDS] He said to her that her husband was killed by [?",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 58,
      "text": "Willy ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 59,
      "text": "Unclebach ?].",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 60,
      "text": "Degenhardt wasn't even present, he was in Krakow for a meeting with a Governor Frank-- F-R-A-N-K, Frank-- who was the governor of Krakow.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 61,
      "text": "And he took them.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 62,
      "text": "And he transferred them, as far as we know, alive, to the Aryan part of Czestochowa.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 63,
      "text": "[PAUSES FOR 3 SECONDS] What happened to them, I have no-- no idea.",
      "word_count": 13
    }
  ],
