{
  "stem": "58.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 48,
      "text": "It was like to-- [PAUSES FOR 4 SECONDS] can't find the word for it.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 49,
      "text": "To downgrade us, let's say.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "This is the best-- To break your spirit.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "This is the best I could figure out.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Well, we worked a few days on this.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Then they took us to other work, to load, to unload.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "You know, it's a war.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Passed a couple of months, the winter came.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "The winter came, they start taking us to-- this is no pay.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "No food, no pay.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "The parents used to bring us some food, cooks they still had some-- everybody had some money yet, so it lasted for a while.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "They took us to, to clean the roads.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "They had no plows.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "They had plenty of people, plenty of Jews to clean.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And if you took four or five people, they make you shovel-- clean the snow with your hands.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "This is the truth.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Clean the roads, the snow, with your hands.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "You came home-- you cleaned the roads, you went out about 10, 15 kilometers.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "When you were walking back, the wind blew the snow back to the road.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "You walked in the snow, up to your knees.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Before your clothes dried, in the morning, 4 o'clock, they took you again to work.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "This went on until they start bringing in, they told us to stay in one area.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "It wasn't actually like closed ghetto like with the police or SS.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "But they told us-- they start bringing in people from villages, from small towns.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Ours was considered a big city, as cities go in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And in the same, meantime, they took over the post office.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And the SS moved in, for a torture chamber.",
      "word_count": 9
    }
  ],
