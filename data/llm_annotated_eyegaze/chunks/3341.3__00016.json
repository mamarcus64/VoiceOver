{
  "stem": "3341.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So we, we had to have as many machines as possible to create a work room, like a small factory.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And the students learned the, the technology from paper, and then they go the half day in the work room and see how it is done.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It is much easier to learn.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So my, my first activity I can remember, I persuaded the headmaster, who I didn't know before, but we came very friendly.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "He said, look.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I speak, I spoke already a better German.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And most of the little factories in the vicinity-- because usually, industrial area is dotted with other small victories.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And they were mainly in German hands because we had a lot of ethnic Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And the director of the school couldn't speak only Slovak.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He said, all right, Horak, or Hirschmann.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Horak was not my name then.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "He said, I give you a letter and you will go to Kezmarok.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Kezmarok was the nearest town and it was completely a German-- like a, like a island.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Because we had a lot of villages which were completely German.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "They came there in the, it was the Huguenots.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "They were persecuted as Protestants in the 18th and beginning of 19th century.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And they settled in Slovakia in many times-- many towns.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And they established the textile industry or glass industry or specialized, small industries in various places.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So I went with such a cheek, with the letter of the school, of course.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They didn't write-- and I didn't-- I was young.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I didn't look Jewish, not so much.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And I went to these German factories and begged them, please give us some old machines because we need it.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "On the first trip, I got four machines.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "The machines were worth 5,000, 10,000 crowns, you know?",
      "word_count": 9
    }
  ],
