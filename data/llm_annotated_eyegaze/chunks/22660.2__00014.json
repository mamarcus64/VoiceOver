  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And my very first job was really at Rockaway Beach, Long Island, as a baby nurse.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And since I didn't have to talk to the baby, I learned English as I went along there.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And I did that for about six weeks or eight weeks, for the summer.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And I left Montevideo in March, so I spent April and May with my relatives.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And then [PAUSES FOR 3 SECONDS] I can't even remember.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "Before I even arrived at my relatives, I was in New York visiting my uncle.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "That's what it was, my father's brother.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And I loved New York so much, so that's why I got the job as a baby nurse, so that-- because my money had run out too.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "So that's how I started really my career in the United States, in Rockaway Beach.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
