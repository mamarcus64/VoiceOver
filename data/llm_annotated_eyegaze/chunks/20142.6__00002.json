  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And this was perhaps one of the foremost successful operation against the Germans of trying to save 300 people from devastation and deportation to [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was directing the people to the hiding places prepared for them [PAUSES FOR 4 SECONDS] during the operation and after the operation.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I also participated in the messenger services for Anielewicz and Antek Zuckerman.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Antek.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- a really Polish-looking fellow, very excitable and-- but totally devoted to [INAUDIBLE] causes, how to succeed of this operation and get the upper hand of it.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Really looking realistically of chances to see if we-- how long can we prevail in fighting the Germans' ghetto?",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Anielewicz was perhaps more calm than Antek Zuckerman, and of great sophistication than Antek Zuckerman ever had, because of this-- of his educational background.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He was attending one of the gymnasiums in Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Never-- I never have seen my mother after I--",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "There was no way of finding out.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "There was nobody in the-- the place where we were living, so I presume that she was taken with the deportation of the Warsaw, the first waves of July of 1942.",
      "word_count": 31
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Where they were taken, it's very hard to tell, but most likely to Treblinka.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] The other things that I remember from fighting the Warsaw Ghetto, that there were many youngster, I mean really children, the age of 12 and 14, that somehow managed when the fighting started [PAUSES FOR 3 SECONDS] on April 19, 1943, and the Germans rolled in the tanks--",
      "word_count": 52
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "There were calm-- mostly calm situation.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "There was sporadic shooting and devastation of ghetto by the German artillery.",
      "word_count": 12
    }
  ],
