{
  "stem": "428.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And he came back, and he married another woman over here, 20 years younger than him.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "She's still alive.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And we met him.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "And she was with his father, in Stuttgart, before I met her.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "Father was very good to her.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And I used to come to them.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "I have pictures to them-- with them.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And then I married her.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "Before-- it was already-- I had already pictures, papers.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "I know my cousin is going to send papers for me to [? enter ?] United States.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "So I wanted-- I know I'm going to marry her.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "So I married her.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And he sent me papers for her, too, and we came to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I came to the United States with-- with $5.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And we got an apartment by a woman, Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Goldman.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And she asked me, you don't cook nothing?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So I told her, we told her, no, we eat outside.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have money to buy food.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So the next day, or a few days later, I walk on the street, I met a woman what we was together in Germany, from our-- from our-- from my friends.",
      "word_count": 31
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And she had already $50.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She told me, you have money?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I told her, I have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So she gave us $15 or $20 at this time.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I was already a millionaire.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHTER] I had $40.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You know what that means.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then she got-- I got a job.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I got a job by Barton's Candy Store.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They have a little machine shop on DeKalb Avenue in Brooklyn.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I start to work on Monday.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And Friday was payday.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Friday, I didn't have $0.15 in this time for the train to go to work.",
      "word_count": 15
    }
  ],
