  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "But if you will be like that, I will not give you my friendship.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "But I will kill you.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I remember one thing.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "This is the first and the last time you should do something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And they became very good friends.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "They give away all the food.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "They give away everything.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And Zusia send them back to the puszta.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "If Zusia would not be there, they would not have the food and nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "Zusia was always under a [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "If somebody went out from Tuvia's people there, he was always watching on them.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, and he was watching always on them.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And this is the time we need to watch them.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Because there were Polacks there.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And they were worse than the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "This was the white Polacks.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And they were terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "They will find a Jewish girl, or Jewish boy, they were to kill them.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Take away the boots.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And nobody knew what happened to them.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Till we caught them.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And put about five-- killed them.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And no more was something like that.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "You see, you have to be very smart with them.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "You killing.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "I will show you.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I know how to kill too.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And this was the only medicine for them.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "That was a very good medicine.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The Russian?",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The Russian are very good people.",
