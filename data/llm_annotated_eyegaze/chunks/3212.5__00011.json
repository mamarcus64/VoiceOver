{
  "stem": "3212.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Her mother, a [YIDDISH], I don't know in English means--",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "An angel.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Her father, all her family.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She had two sisters, one sister was married.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They took me in, in their home.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We were married.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Her mother made ready the wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Everything, the cakes cooks, everything.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "We were married, my wife and me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "We had five Israeli pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "On our honeymoon we went to Tel Aviv, and another cousin from Rehovot Hobart gave us 10 pounds.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And that's all what we started.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] She got married, and she left the army, and I started working.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "After the army I learned to be a plumber, welding.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And after that, I became-- went on my own.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "A year later, I became a contractor, plumbing contractor, welding contractor.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I did new-- new kibbutzim, new villages.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I put the pipes in.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "I worked on the Syrian border.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "Then I worked with walkie-talkies on the excavator.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Now you can work, now you have to go back.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "In the morning, we found bombs in our pipes.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "It was not easy.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "In 1952, my first son was born.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "His name, we gave him the name of her-- her father, my father, Adi Samuel.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "And but it was very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "I worked outside the cities in new villages, new kibbutzim.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "I came home once a week and once in two weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "My first son-- when I worked in the village near Tiberius, I had a dream one day-- it was Thursday before we went home-- that her mother sits next to us and tells us kids, don't cry.",
      "word_count": 37
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And then when I came home, [PAUSES FOR 3 SECONDS] one of my-- I went through the city-- through the street where my brother-in-law lives.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "My wife was standing with friends.",
      "word_count": 6
    }
  ],
