  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Now when the brother and sister [? hears, ?] I gonna take you out-- [? it's true-- ?] the brother and sister-- Hela help us too.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "It's a big cellar, a lot of potatoes there.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "She eat the potatoes raw.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Raw potatoes.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And take her out.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE] she said, listen, here's a brother and a sister.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Help him take.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "It's [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "You know what it mean?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] Not a good word, no.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "To German, it look like this.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And I'll take that.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I'll take the two girls in the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And the boy in the back, and the police from [?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Latvia, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Latvian ?] police, watched there.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Shoots to him.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Now, shoots back.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He's drunk.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "The officer is drunk.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "The brother and the sister have clothes on them.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Now, my friend, she didn't have nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "She had on a gown-- nightgown.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I take that to the Polish family that give me shoes, stocking, a dress, and a-- and a coat.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "She get this.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They said, you free.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She ask them, why you doing this?",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "You're German, and I'm Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "He said, I believe in God.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I'm a religion man.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And I want do the something for God.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I saved her life and one person.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I killed a lot of people.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "That is some story.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Wait a minute.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This is not all.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "She [PAUSES FOR 3 SECONDS] she went-- she is in the-- [PAUSES FOR 3 SECONDS] she is in Kovel.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And she meet her sister.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "This was before-- from there, from the ghetto, she left to look her sister in Kovel, [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And she find her sister.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And she find her sister in the same town the Germans take every Jew from one place to take to Auschwitz.",
      "word_count": 21
    }
  ],
