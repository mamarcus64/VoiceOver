{
  "stem": "210.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I married this man that, you know, I didn't even love at the time.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But I felt that maybe that was the purpose that I survived.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "You know, I just stayed there in the bedroom and cried.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And my-- my friends and my cousins, everybody came in-- control yourself!",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "You know, come out of this room.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "You know, they wiped my eyes and put my makeup.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And, you know-- again I started crying.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You know, it was just-- this went on for hours.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "Anyway, I finally pulled myself together.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "In the meantime, they had, outside they had a party, you know in there.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "My cousin prepared, and my friends-- you know, it was-- then we got married.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "And we-- I didn't-- we didn't go back to Opoczno.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "We stayed with my friends.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "My husband, since he didn't go back to Opoczno, he-- there-- and we lived on Pomorska.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "Your-- your father will probably know the address-- on Pomorska 39-- 41.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "It was a gorgeous building.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "It was like a closed-in building.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And next-- and next door was like a-- was a house with a empty lot.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "So my husband bought the house.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And in the back, he built his soap factory.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "And he took my friend in as a partner.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And he started producing soap the same as his company was before the war-- parents' company before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And while he was, you know-- and at that time, there was very little soap and very little thing being produced, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was right after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And this company was very well-known before the war.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And it became such a success.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "A lot of people that were here-- do you know Charlie Newman?",
      "word_count": 12
    }
  ],
