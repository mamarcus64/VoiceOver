{
  "stem": "21494.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And they went out, woman and man, and they took them, and they killed them not far away in a forest-- killed out over all the 200.",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "This was by-- a small, a small-- a [NON-ENGLISH], you know.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Without name.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Near Ostrozec.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember north or south.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Near Ostrozec.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Around Ostrozec.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Until the ghetto, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "To the ghetto, I have to move when the ghetto start.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was in 42nd year, '42. '42-- was summertime.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "They gave-- they gave a small place-- a small place that, for instance, in a room was like three, four families-- more, even, in such a room.",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "They concentrate, and they closed up.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "What you say, please?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My mother and my brother and my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Wasn't far, because was a [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Wasn't far.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "What part of the shtetl?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Was like-- could be not half of the shtetl.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They divided half.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "The Germans came and gave order to the Judenrat, and the Judenrat master will do that.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Whenever was an action or something, I wasn't there, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I was outside.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And when I was coming in, then I jumped in a garden, hiding some place.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "They didn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "But if they would saw me, they would kill me.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "But what-- later on, the Fogel, I want to mention.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "You can be SS.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "If you want to be good, you can be good.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "He fell in love with one.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "She was from Hungary.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "She married a Polish teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "He was an exhibition in Hungary, in Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "He went there and he fell in love with her, and he married her.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And he-- they took him.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "He disappeared.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "Then he fell in love with her.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "And Troyanow was his name, the teacher's.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "She was Troyanowa.",
      "word_count": 3
    }
  ],
