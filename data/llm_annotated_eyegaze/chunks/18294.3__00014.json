{
  "stem": "18294.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And he had one lung.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And he said to me, if your husband supply me with food, you'll be the healthiest woman in the world.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "He was working, but there was no shortage of food.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "And he bring me from the best.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And the doctor used to come in the room.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "And it was like-- he was-- he was-- he was so happy.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "Every time he come up, the-- the blanket went up, the blanket went up.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "After six weeks, I was a healthy woman.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In Vilna my husband was sitting with the company, and my [INAUDIBLE], what is now on my sister-in-law, she come and she said to him, you know what?",
      "word_count": 28
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Muelke ?] your wife is-- is alive.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "He said, what are you talking about, so long after you're already divorced, [INAUDIBLE]?",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And where is she?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "You said you liberated in March.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And she's not here.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "It's already May.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So he said, you know what that tell you.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Here the 14th of May, the 15th-- here is 14.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I wait till the 15th.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "If my wife didn't turn up the 15th of May, I don't want to know her.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Exactly the 15th of May, I open the door and went in home.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And this was-- that was Sam and I.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And then I was very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I went to the-- to the sanatorium.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "After six weeks I was healthy, I mean healthy.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And when man and wife together, with my husband together, we start pregnant, and I was pregnant with my daughter, with my daughter.",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I stay in Vilna till 1946.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "In 1946, there was in December, it was very, very cold.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And then we come from-- in Lodz there, and we stay-- we stay in Lodz for three months, or something approximately like that.",
      "word_count": 23
    }
  ],
