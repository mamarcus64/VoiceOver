  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I have been told that the child was somewhere with her father, but I put, you know, [NON-ENGLISH] father in Polish, not the real-- I didn't believe, and I knew it's not the father-- with a father, so-called father.",
      "word_count": 41
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "She's somewhere here in Germany, [PAUSES FOR 3 SECONDS] and gave my address.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "If she's somewhere here with-- with that man, Mehr, please contact me under this name where I worked, under the address, and I gave my address.",
      "word_count": 26
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "She was there.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "It was in Kassel.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Kassel is top the-- it was very far from [?",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "Munchen. ?] How, how far, I don't know exactly.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "But you have a whole night to travel to go to Kassel from [?",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "Munchen, ?] or Nuremberg.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "She's very much resembles, not only-- she resembles.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "I mean, she had some character, too, and I have it from my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "Whenever I find a-- a newspaper, I have to read it, whatever's there.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "I find a piece of paper and I have a look, I want to know, before I throw it out.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "I never throw out that old papers.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "The-- even old papers.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "I don't-- I don't throw them out.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "I just want to know what is there.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "She was there.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "It was a camp much bigger than I was in.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "Ours was a model camp, clean, you know, and houses there.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "They lived in huge houses, people, families together.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "That man, how he's-- Mehr, my name, it's the same as I, no relative at all.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "Lwow, I was born in Grodek by Lwow.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "I was later in Lwow, lived in Lwow, but he was born in Lwow.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "His wife-- my daughter was born in '39-- his wife and I, two Mehrs in the same hospital near each other.",
      "word_count": 21
    }
  ],
