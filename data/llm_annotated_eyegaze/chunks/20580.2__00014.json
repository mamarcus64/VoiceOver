  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 32,
      "text": "They went away, and that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "But later on, when Bandera came out with the thing to make independent national Ukraine against the Russians, against this, and the Jewish, no question about it.",
      "word_count": 27
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] Then this guy, one from the gypsies, I meet him there to work, because I was the manager from the party, from the-- they called it-- was the boss from the tannery, and I need workers.",
      "word_count": 37
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I took this guy sometimes to work, to cut wood, something like this.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I spoke to him.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "How did you manage it?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "The other one is dead, and I'm alive.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Another story.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "It's a big story.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "We'll stop here.",
      "word_count": 3
    }
  ],
