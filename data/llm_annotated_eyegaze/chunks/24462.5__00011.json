{
  "stem": "24462.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And then I heard that the train is going tonight to Bari, where the conditions are much better.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So I enrolled.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Somehow I got on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And we went by train to Bari.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And we landed in Bari.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Later, we landed in Bari Palese.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And then later, we were transferred to Barletta.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And this was a huge camp in Barletta where I stayed a year and a half in Italy.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "My daughter was born there.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And I was working as a teacher at the local school-- local-- the camp school.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "I have pictures from the school with the other teachers and the headmaster.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And I was teaching in Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "Physics, and mathematics, in Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "Because the children didn't know any other language.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "They didn't know any language.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And we were waiting for migrate-- for State of Israel to be established, which it was.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "We didn't go to Cyprus, because we had a little child.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "So with children, they didn't accept to go to Cyprus.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "You know the story of Cyprus.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "And then we arrived in Haifa, on [INAUDIBLE], '48.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "This was the 26 of October, '48.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "When we came to [?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Naples, ?] with our little daughter and the-- the transport of fellows-- fellow people, we went to the port to see our ship.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And we saw huge ships that day.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And between the huge ships-- ships was a small boat.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "This was the boat.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "This was the [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "On the [INAUDIBLE], we had four days.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I was sitting on the stairs.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "My wife was non-existent from sickness, from seasickness.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "Some other people were sick.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And I was keeping the little daughter and feeding her special biscuits, Italian biscuits.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "We had special baby biscuits.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "So this was the passage to-- to Haifa.",
      "word_count": 8
    }
  ],
