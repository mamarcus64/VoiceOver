  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Was a committee of the joint that when anybody need it, they helped out.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They didn't help you the way you should be helped, but they help something.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They gave me some clothes for the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And it was warm, so you didn't need bundle up, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "You had a diaper, which I made from, like I say, those long, long underwear, my husband's.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And later, they gave me some diapers, and they gave me some clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "[SOB] I gave up.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I didn't-- I didn't want to run.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "When we were running with my husband, and the bombs was coming, and I could see the German like I see that light.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They were throwing bombs when we were traveling through the journey through the Ukraine.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And I said to my husband, you know what, Michael?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I have enough.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I don't want to go anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So he grab me.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And then a bomb explode not too far from us.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Everybody got killed.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And us both didn't kill.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Destiny.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "To-- like my grandmother said, that one person would be when a new generation comes.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That it is written in the Bible, she was reading to me.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And I lived with that all my life.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And I tell my children that.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And I believe in God.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I talked to God everyday.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] And I still believe in God.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "My children believe that their father died recently, [SOB] that he is with us.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I'll take you to my bedroom and I'll show you.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "My granddaughter wrote me a thank you note for her bat mitzvah.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "So she write, Bubbe-- I'll bring you, then I'll show you-- Bubbe, she says, Zayde is with us.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "He looks at us.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So I took the card.",
      "word_count": 5
    }
  ],
