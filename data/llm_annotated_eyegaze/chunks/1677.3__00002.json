{
  "stem": "1677.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 449.8,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And I held the golden button and pulled her towards me.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And I called [NON-ENGLISH] three times.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And psychiatrists of the universe are trying to break that pain I have in me that my mother didn't turn around, because she could have lived.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "I would have pulled her over.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "I blame myself that I wasn't quick enough to pull her over with me.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "I held my sister by her button when Mengele run after me-- pooped me under my scarf and pulled me back, and said to me-- in very good German-- I send you before over there.",
      "word_count": 35
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "There is a reason to it.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And in my history of psychiatric wards all over the world, every night, sister was told never to shone a torch at me, because I go off my brain.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I go quite hysterical and very nasty on many occasions.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And so I was there with all these women.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And then came the drill, which you know-- that strip naked.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Me with all my panties and my bras and all the-- jazz, which I took.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I-- we had to get out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In a big hall-- big, big hall.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It was called Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I don't know for what reason.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And there was a woman standing next to me.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And they told her, hurry up.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH], everything, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Get dressed.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "She said, I am Frau Irriza-- Irriza.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "My husband is a rabbi from Galina.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "He has never seen me naked, and you will not see me naked either.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "So he hit her so hard.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "She stripped faster than I.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And she survived with us, with me.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And I visited her in Israel just before she died.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And she had a daughter, Stella, who was with her.",
      "word_count": 10
    }
  ],
