{
  "stem": "19596.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We carried our dead-- in the evening, we carried our dead back in.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And the fellow who is in charge of the Kommando announces that there are 250 less 15 dead.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And they counted the dead ones and the half dead ones as well.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "As you go through the gate.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Everybody had to be there.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "About 10% [PAUSES FOR 3 SECONDS] because some of the-- some of the German Kapos, the more dead they brought back, more cigarettes they got from the SS.",
      "word_count": 28
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Because they told me.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] After.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "That's-- that's after.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They get extra rations of cigarettes if they bring a few more dead back.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "They didn't kill them.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "The Kapos killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "The Germans didn't kill them.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "The Kapos killed their people.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Criminals from German jails who murdered their mother, their father, their brother, their sister, or somebody else.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Mass murders, serial murders, who have been life timers in-- in-- life timers in-- in-- in-- in security, in top security in Germany.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They took them out of there and they put them in concentration camps in charge of people.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And they were wearing a green triangle.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And they called [GERMAN], criminals.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And they [INAUDIBLE] in charge of people.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, not criminals.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Only later.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "In-- in-- in much later, there was one Kapo called Schultz.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] [INAUDIBLE] I worked in-- in other Kommandos, like outside.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I worked in loading trucks, loading-- loading soup, 50 gallon-- 50 liter soup, with big gloves that you don't burn your-- your feet-- your hands, loading them on trucks.",
      "word_count": 29
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "To go-- all the trucks went from the kitchen with that soup on the different Kommandos that people are working.",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Delivering.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Delivery trucks.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "So they had to be loaded with soup.",
      "word_count": 8
    }
  ],
