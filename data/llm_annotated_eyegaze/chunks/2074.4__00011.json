{
  "stem": "2074.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "We had to start from scratch without a penny, without a penny.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "One day my cousin said, bring your laundry to wash to my house.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "And I will never forget.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "The bus ride was $0.10.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "And a quart of milk was $0.10.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "I decided to walk maybe 20 blocks to my cousin's house way in the east end to save the $0.10 for the quart of milk.",
      "word_count": 25
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "I froze up my knees.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "And she got mad at me, scolding me why I didn't take the bus.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "It was 20 below zero in February.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "And I walked that far with a bundle.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "That was only one of the incidents.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "We struggled bitterly.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "My husband shoveled coal for the Minnesota Power and Light Company.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "Then he's got a job.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "He lost that one.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "He got a job.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "He did not know the language.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "Then he got a job to carry the junk in a junkyard, just carry, loading trains, loading trucks.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "That was his labor work.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "But he did go to-- to school.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "I couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 39,
      "text": "I had to be home with the baby, because a babysitter had to cost $0.25 an hour.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 40,
      "text": "So I couldn't go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 41,
      "text": "So I just send him to school to learn the language to have a job.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 42,
      "text": "And he worked himself up in the same field.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 43,
      "text": "And he came a part boss down there in the business.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 44,
      "text": "And he worked there for 37 years.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 45,
      "text": "And right now my husband's at a nursing home, and he's dying at this point.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 46,
      "text": "We were waiting.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 47,
      "text": "My son is going with me home.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 48,
      "text": "We were waiting.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 49,
      "text": "At least he held up for me to go away.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 50,
      "text": "So he's living on water already, six weeks-- just an intravenous, nothing else.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 51,
      "text": "And he's damaged from the Holocaust, in my opinion.",
      "word_count": 9
    }
  ],
