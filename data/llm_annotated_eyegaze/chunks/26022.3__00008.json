{
  "stem": "26022.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "When they had a railroad car to fill, to go to Dachau or wherever, [PAUSES FOR 3 SECONDS] the Jewish community had the honor of providing the names of those that go.",
      "word_count": 32
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We need 30 more, or 50.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I mean, they-- they collected enough.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "But they still had a few places in the railroad car to fill it up.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And the Jewish community had to provide the names, which was a heart-breaker.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I don't have to tell you that.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I went up to the Jewish community for some kind of a document or something.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And somebody said they were absolutely crying because he had to put down the name of his former teacher.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "That was an old lady, no-- no-- you know, no family being pulled apart or whatnot.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he had to.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I mean, if not, he had to go.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "You know, things like that.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My father had gone to England.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "My mother and I had not been able to leave when we thought we would.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We were there without winter coats and without much of anything else.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We were in the Jew house.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I told-- [PAUSES FOR 3 SECONDS] well, in June '41, but how did we survive?",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I told you that the lift van was confiscated.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "My mother was always very capable in design.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And she designed my ball gowns and what have you, and she could sew very well and embroider and all of this sort of thing.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And she had a very good sewing machine, a Singer that could do everything and anything, which was also in the lift van.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "We had an uncle who had emigrated to Holland, and who sent us a box containing a big Edam cheese.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Mmmm.",
      "word_count": 1
    }
  ],
