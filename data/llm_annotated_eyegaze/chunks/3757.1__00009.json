  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was a business letter from the same name what this man gave me.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And he wrote, dear madam, you must-- this must have been a [? hoax ?] or somebody-- I-- I don't understand what happened.",
      "word_count": 23
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "But, I saw what it is all about.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And I have no children.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I have nobody in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And even I saw what is the situation.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I went around in the whole town and asked if somebody knows something about that.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So it was-- until now, I don't know why this man came, why he told me this story, why he was crying.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He didn't want to have money.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I don't understand.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I got two-- two more news this way about my husband.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And after the war, I found out that all was a lie.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I don't know why.",
      "word_count": 4
    }
  ],
