{
  "stem": "11552.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And then rumor started flying all over the ghetto that 600 leading citizens who were detained at the registration, because some of them were let go, were taken into the forest and massacred into open graves.",
      "word_count": 36
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "For me, it was very difficult to accept that my father was just shot.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "You see, my father was a hero in World War I.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "He saved 38 high ranking officers, German officers from the Russian Cossacks.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "So I thought maybe my father tried to escape.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "Maybe he was wounded while escaping.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So I went into the forest looking for him and calling his name the whole day.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And then I was very tired.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I fell asleep at the edge of the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And my brother Zachary found me.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "He lifted me into his arms.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And he said, Alicia, our father is not coming home.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I was 11 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And that's when my childhood stopped.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And my father never came home.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "In 1967, I was asked to come to German consul--",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a Swedish subject.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "She still had her citizenship.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't that easy to leave Poland because we were such a big family.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "My grandfather sent a lot of money to Switzerland to get to the Swedish consul, to get the whole family out.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "But you can't only a few people left.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "The whole family had to leave together.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And people wouldn't really have let my grandfather go.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "He was supporting so many people.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "He was in charge of so many people.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "I don't really know what went on.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "But I know they tried to get out.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "Because during the Russian occupation, they couldn't get out.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "But when the war started in '39, they tried to get out.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "But it isn't just getting out.",
      "word_count": 6
    }
  ],
