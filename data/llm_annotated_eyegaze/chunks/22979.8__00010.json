{
  "stem": "22979.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I mean, she is in Arizona in Tempe in college studying anthropology.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And my daughter has another son, Elliot, who attends the Hillel Brandeis school very good student.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And my daughter, after getting her masters, she was offered a job in Wells Fargo Bank, her first job.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And for her first salary-- how many years ago, 20 years ago-- was $25,000.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "First job.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "Then she succeeded.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And she went to Bank of America, when she-- when she got doubled her salary.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "Then she went to, I think so, Schwab, where she was four or five years with double over.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And now, she works for Intuit in Palo Alto.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "I don't know anymore how much she makes.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "My grandson is in the Hillel Brandeis.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Although, my son-in-law is not Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "He's Catholic, born in San Francisco and raised in Catholic schools.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "But I think so, he knows more about Judaism than my daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "My son, the same.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "When he was in El Paso, he met a Mexican girl, married her.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "He was still in-- in the Air Force school.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Then, when he finished and he went to Germany, he brought her over to San Francisco.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "She stayed with us.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And they had a little girl, which is now a big girl and the mother of two, Caroline.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And he was there two years in Frankfort, stationed.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "When he came back, he didn't want to take the job what they offered him in his profession, because he wanted to be in San Francisco.",
      "word_count": 26
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "So we opened another retirement home in Daly City, and he was manager again, his wife.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "But he very good in computers.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "He divorced his first wife with the two children.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "And he has now his third marriage, which he's very happy-- a Chinese Soviet International.",
      "word_count": 15
    }
  ],
