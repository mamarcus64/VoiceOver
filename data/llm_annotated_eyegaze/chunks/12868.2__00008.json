{
  "stem": "12868.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "But-- but it is not-- was true.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "We get out because everybody was young.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "You know you get to work.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And the rest of them, they-- they went in Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "They told us-- they gave you a place where to go in the barracks.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was-- you are going, this is your place-- barracks number one, barracks number three, barracks number five.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So many, so many room barracks-- when I got to remember my barrack.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And they give you only a-- they give you a blanket.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And they give you-- later, they give you the-- they give you-- you got to-- the clothes.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "You got take off all the clouds, naked.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And they give you the blue and white, you know, uniforms, the Dachau uniforms.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Everybody got to forget your name.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Nobody names were mentioned, only a number.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And they give you a number.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "My number is there and there.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "But-- but names, you forgot.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "You don't have a name, you're told.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "Nobody got a name here.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "Here is a slave, slavery.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And-- and you've got a-- every slave got a number.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And they didn't care.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "They give you a uniform.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "They give you, let's say, a big one.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "For a small man, they give you sometimes a big one.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "For-- for a big man, they give you a small one.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "They didn't care.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "Only-- later, you got to change if you wanted with someone.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "Who's big, you get the small.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "The same way was like with shoes.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "They give you a pair of shoes, now go.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 31,
      "text": "You didn't-- you-- if you say you don't want it, you get shot.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 32,
      "text": "You see, there is no such a thing you don't want it.",
      "word_count": 12
    }
  ],
