  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Were there refugees in your home?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have a home.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We went-- in Horodok, it didn't happen.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "In Lida, I had one room for all of us.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Where should we take in a refugee?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "My-- my stepmother he had brought to Lida-- as soon as we settled down a little bit, she brought from Vilna her mother and two sisters.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "My-- my father took for them apartment, and he paid the rent for them, and they lived not far from us.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "This is an individual thing.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Some of these responded very nicely to them, and some rejected them.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They [? wanted to just ?] think about it.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Because we knew about the capitalism and the communism, and my father was in there as a capitalist.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So they don't-- they didn't like them.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They would gladly take away everything, because before they sent them to Siberia, they took plenty away for themselves.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "But if somebody else should have, he's a capitalist.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] They didn't like business.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When I met Tovia, [PAUSES FOR 4 SECONDS] it's a coincidence.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He lived in my girlfriend's house in Lida.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "That was the only girlfriend that I told you I took a liking to her.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I'm trying-- her name should come back to me.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Raja I got to know in-- in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And he had a room.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "He escaped from [?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Subotnick ?] and he came to Lida too, in the time of-- of the Russians-- of the beginning-- the end of the Russians, beginning of the Germans already.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And he took a room by them.",
      "word_count": 7
    }
  ],
