  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "It could have been Asia and so forth.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And my father-- I think he bribed some officer of the Guatemala Embassy in Paris to have two visas issued for my brother and for me.",
      "word_count": 26
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And this was sent to the Gestapo in Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "You know what the Gestapo was.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And then they issued the release for-- for us to leave.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "That was the way we could get out.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "Of course, the moment the war started, it was-- it was over.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
