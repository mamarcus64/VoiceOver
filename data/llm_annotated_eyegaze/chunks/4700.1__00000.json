{
  "stem": "4700.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Edith Sheldon.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "S-H-E-L-D-O-N.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "On the 7th of January, 1927, in Prague, Czechoslovakia.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "P-R-A-G-U-E.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "D-R-U-C-K-E-R, Drucker.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My mother came from near Karlsbad in northern Bohemia.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Her family had been living there for over 300 years, in the same little place.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "They had to have the castle permission to be allowed to trade and to live there.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "My father came also from northern Bohemia, in-- he was born in Lovosice.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And the family then moved to Theresienstadt, which is rather funny.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] And the family lived there till the deportations.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "My mother used to go for holidays to Theresienstadt, because her two aunts lived there.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And she used to spend the school holidays there, where she made a friend with a girl-- became friendly with a girl who had an older brother.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And that older brother eventually became my father.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "It was a childhood romance.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And they courted, I think, for 10 years.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "The war intervened, World War I, of course.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And then my father had to finish his engineering studies.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And finally he had to get a job.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Because those days, you didn't get married till you had a safe future.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "We lived in Prague, which is the capital or was the capital of Czechoslovakia.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "But my father died when I was two.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "He contracted middle ear infection.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And being very conscientious, he continued to go to work, because he was building the first reinforced concrete building in Prague, a big palace-- a business house, actually-- a, a big house on the main square.",
      "word_count": 36
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "And he was very concerned, because the winter was particularly cruel.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "And he was concerned that the mixing should go on properly.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "And he disregarded his temperature and later his fever.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "And unfortunately, he died very quickly.",
      "word_count": 6
    }
  ],
