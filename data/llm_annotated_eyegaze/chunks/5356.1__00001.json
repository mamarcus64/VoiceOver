{
  "stem": "5356.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather was born there.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Further than that, I don't know because I didn't know my grandfather.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Because I'm named after him.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And my father was born in 1869 in Opatow.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "My oldest brother was born in 1891 in the same city.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "His name was David.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And I had-- we were nine brothers and three sisters in the family.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And most of my family were-- went with the [INAUDIBLE], with the, you know, to Treblinka.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Some of us were in concentration camps, labor camps.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "One of my brothers, Aaron, he died on-- in 1945, on the way from Auschwitz to Buchenwald.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My oldest brother's name was David, next to him was Pinchas.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "After him, was a sister, Yittela.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "After that sister, it was another brother, Baruch.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Than another brother, Shimon.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And then a-- a sister, Yohevet.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Then my next brother's name was Moshe.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He died in 1939 in the Polish army, defending Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "As a matter of fact, it was in Modlin-- which was place where he died.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And next to him-- him was Aaron, then Shmuel Maier, and then Benjamin, myself, and then I had a younger sister-- two years younger-- her name was Golda.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "My mother's name was Esther.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And she and my sister and-- went away in-- in 1942-- '41 in October, with the [INAUDIBLE] from our hometown to Treblinka.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My-- my-- this was his second marriage.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And my-- the first wife died.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He had six children with his first wife.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We were from the second marriage.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Moshe.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Moshe, Aaron, then Shmuel Maier, Benjamin, myself, and my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We lived in a-- we had our own house.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We lived in this-- we were all born in the same house.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We had our own backyard with our own outhouse, which a lot of people didn't have.",
      "word_count": 16
    }
  ],
