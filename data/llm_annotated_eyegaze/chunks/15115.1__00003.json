{
  "stem": "15115.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "But you only needed one loaf of bread or two loaf of bread, so the rest of the money was-- bought food they would grow in Greece, like a lot of vegetables and so on.",
      "word_count": 35
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they managed.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But when it comes to clothing, they had to need a helping hand.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And my father used to take them and-- to the big people they used to do business with, and used to buy certain things.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But as far as I was concerned, we used to be well-- quite well off.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We used to go to buy good clothes for Pesach and Yom-- you know, and the holidays.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And as matter of fact, we were quite well.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "My brother, and my oldest brother, and my sister, they used to have camel-hair coats.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "You know, they were-- they were really, really up to date.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "They had a sewing machine at home.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "We had everything.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "You name it, we had it, till this-- the war started in 1948-- in 1940, October of '40, which with the Italians, were the first people who attacked us in Greece.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And then we didn't have not much problem.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I was, at the time, at the sixth grade of public school, which actually was second grade of high school.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I went from the fourth public school to the first high school.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "I got-- instead of having six years of public and six years of high, was four of public and two-- and eight in-- in high school.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] so happened, I was-- we only were two Jewish kids in the whole school.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The school that I did go-- was only two Jewish boys.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "The rest of them were all-- because we were near my house where I used to live.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    }
  ],
