{
  "stem": "3002.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "The local militzia, the Ukrainian militzia did the dirty job for the SS, taking them from one Jewish house to another Jewish house.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They knew everyone.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And they guarded us in the middle of the street.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Every-- sick people from hospitals.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I remember we had very good friends which owned a drug store in the town.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And they had two sons.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Their mother was in the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And they had to carry their mother on a stretcher.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So that was-- they guarded all the Jews in the middle of the street.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They guarded us on the sides with the machine guns.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They kept us in line.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Because there were-- people was-- were wild.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There were such a screamings, and cryings, and praying.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So they-- when they got out of line, the machine guns pushed us back into line.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It's like live cattle.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And they marched us like this maybe for three miles.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And it was a terrible, hot day.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "All-- all you heard was raus, raus, and raus, and the machine guns.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They marched us for three miles to the outskirts of the city where it was a big, big, place.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And then it really started.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "It was so hot.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have any water-- no food, nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And they put us in lines.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "If I remember well, when we arrived there, we saw a big hole digged out and some SS lying on their bellies around the hole with the machine guns, like this, pulled out.",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "In the meantime, they put us in lines on this-- in this place.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And they started pointing their finger-- one.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "They took us-- the younger men, and separated them to a separate line.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They took him.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "No, no-- the parents.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They were old.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They took only--",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "--one.",
      "word_count": 1
    }
  ],
