{
  "stem": "12022.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "His name was Czeslaw Wieckowski.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And he was from the beginning.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And finally, we saw something is not right.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So-- but then, the-- one-- that time he said something.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "But we don't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And one time he said, the Polish underground caught him.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And he was arrested by them.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And he ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "I, like a ex-soldier, and everything is not so easy to run away from that kind of thing.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And the [INAUDIBLE] you start to keep an eye on him.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "Got to keep an eye on.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "Finally, the-- then the was attack on our group.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] There was attack on our group.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "And killed, I think, about-- about 10 people that time.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "And a few ran away.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "And they met.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "And they ran away in a place.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "They met a guy, what he said, they got some more people in the woods where they'd been, already, a winter.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "Five people-- Russian military men.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "All military, Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "And they set up a meeting with-- with us.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "And he was living in the [INAUDIBLE] because, down there, they took over a piece of land.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "And they include the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "We wasn't like in [INAUDIBLE] Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "Finally, we set up a meeting with them.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "We have already started to do it a little bit work.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "And he saw us.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "And he really like us, that-- that-- that leader of the group.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "And he was a lieutenant from the army, from the Russian army.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "When he was the secretary of the Communist party.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Ivan-- Ivan Ivanovich Stepenko.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And he really like us.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Finally, we went with him.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Then they move to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] was doing a little bit work, little by little, to-- to spread some kind of news to the-- he was a very talented man.",
      "word_count": 25
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "News.",
      "word_count": 1
    }
  ],
