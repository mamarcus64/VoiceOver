  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And they took us all three up to the-- to the upstairs where all the people was there, not far-- maybe four or five blocks.",
      "word_count": 25
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "That's the way where that time that was Tisha B'Av.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And that day, they took my-- my mother, and my sister separate.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And then my grandfather, they caught him later on.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "I saw him he-- sitting on a piece of stick.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "He had a walking stick.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "He was sitting on the stick.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And they didn't tell him to go.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "They didn't tell him to stay there.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "Then later on, they told him to sit down, too.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And then they took them away.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So that day was my mother and my sister and my grandfather and his wife.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That night, they killed 2,500 people.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Let's cut here.",
      "word_count": 3
    }
  ],
