{
  "stem": "5799.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They tried their best.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "They didn't cop out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "I could have become an alcoholic.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "I could have been on drugs.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "I have an excuse.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "How long will we go on blaming somebody for what we do?",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "So weaknesses-- and when I see what's going on in this country I ache because it's mine.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "Did you think of going to Palestine?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I go there visiting all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "My husband didn't want.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, I mean before, at the end of the war.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I said, George, we sat in the woods all the time.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Let's go and fight for something of our own.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And he said, the war is ended.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I want to build a life without any wars.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I had enough.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I am the only one of my old brothers-- they were six brothers and three sisters.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "He didn't know that his brother in Russia is alive, or his sister.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "We weren't in touch yet.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "One sister, one brother.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "His sister is dead.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He said, I am going to America.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I said, do you have anybody there?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He said, if I have, I'll find them.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Who needs them?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I'll build my own way.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I said, I have family there.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He said, you want to?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Your right.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "So this was how we came to the States.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "We came to the States January the 24th, 1947, and Anita was born in America.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "You came by ship?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "By ship, the worst one you could ever think.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, God.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Half of the ship was throwing up.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We left January the 7th, we came January the 24th.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Even the Marines were sick there.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "The staff, everybody was throwing up.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I was in the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "One woman died next to me, was buried at sea.",
      "word_count": 10
    }
  ],
