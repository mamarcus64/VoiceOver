{
  "stem": "12674.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And so, you know, parts of a millimeter, very thin-- they wanted it for aircraft insulation.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And they used it.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And they, they-- we had to split it.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "That was the Jewish job.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "I had to sit.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And they had barracks.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And we were sitting on this table all day long and do this, split rocks in two.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And it turned out after the war, they never used it.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "They found sacks and sacks of that stored in the catacombs in Theresienstadt.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "But this is neither here nor there.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "There were-- no, the men lived in the-- in, in, in this-- these stables.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Women lived in-- men and women did-- there were separate assignment things.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I lived in the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I, I was assigned to something called the west barracks, which were five barracks on the outside of town.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And we were living in three.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And there were-- was an epidemic of bedbugs.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I mean, there were trillions of them.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I used to come down.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And I lived on the third floor because I was young.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "I could climb the ladders.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I lived on the third level.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And we used to come down in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And I used to shake out-- bend over and shake out my hair because it was full of bugs.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And we didn't-- we didn't have anything.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "You would-- sometimes, you, you would take a, a, a-- we got-- our ration was a slice of bread about an inch thick across a loaf this wide, you know, like this, a day.",
      "word_count": 34
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] 2 ounces-- 2 and 1/2 ounces of margarine a week, 2 and 1/2 ounces of sugar a week.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "In the morning, you got something which was called coffee.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "I don't know.",
      "word_count": 3
    }
  ],
