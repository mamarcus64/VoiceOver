    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And after we were fighting for eight years, I even went to Canada and sought help there, which really wasn't what we expected.",
      "word_count": 23
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I lost him here.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "On the 13th of January, '74.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He died one day before my birthday.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And he had the birthday card on his desk, and he couldn't fill it in anymore.",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "I have it here.",
      "word_count": 4
    }
