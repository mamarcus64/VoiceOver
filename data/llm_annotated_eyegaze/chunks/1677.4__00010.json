{
  "stem": "1677.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 372.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And he said, Ziggy, there is somebody for you.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "She is going to Port Moresby.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And they got up in snow white startched uniform, a young man.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And he said, Otto Hermann Siegfried Rozeroff.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And I was such a fright, me and my breakdown.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I packed 200 Valium tablets, because I had it all worked out.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I had no intention of going to New Guinea.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I was going to commit suicide on the boat.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I will swallow all these tablets.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I will be buried at sea so that I'm of no embarrassment to my son.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "That's all what worries me, that he should never see me in that terrible [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And I had it all planned.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I said it all to the Ziggy straight away.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And he told-- was as old as me then.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And he told me that he-- all he wanted to be is a captain in the German [PAUSES FOR 3 SECONDS] merchant navy.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And then the end of the war and no captain, no German navy.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And he escaped to the Foreign Legion.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And he said, what's your cabin number?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I said, number 12.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I said, I come and see you.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And we will talk more about your Valium tablets.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And that Otto Hermann Siegfried Rozeroff sat with me every night after duty.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And, one day, we took the tablets.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And we buried them at sea.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And he is still this day my good friend.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "He's a complete alcoholic and in [INAUDIBLE] somewhere where I visit him sometimes, a highly intelligent, brilliant man.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And every time, when the [?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Brayside ?] came to New Guinea, I got a cable.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Ziggy's coming.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And they kept me alive in the beginning in Port Moresby, which was dreadful.",
      "word_count": 14
    }
  ],
