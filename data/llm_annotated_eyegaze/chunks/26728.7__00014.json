{
  "stem": "26728.7",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "There were ware-- within six miles of this camp was a bakery that could bake 6,000 loaves of bread a day.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And they-- this, well, this is all second-hand stuff.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I didn't talk to anybody that was an official there, but I have tried to make a study of it, because one of the most frustrating things was that-- is that they just let them die.",
      "word_count": 36
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They just didn't give a damn.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "One of the subordinates to the commandant said-- and he was the doctor-- you know, there must be something we can do to get water, at least get some water.",
      "word_count": 30
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And he said, I don't give a damn.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Let them die.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Now-- and of course this guy, to save his ass, told the British liberators that this is-- this is what he said.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Because the British had water to them that same day they liberated the camp.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Beg your pardon?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Didn't see any crematoria.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see-- no, no crematorias, no gas chambers.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Uh, lots of barracks, lots of people laying around on the ground, very sick.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Uh, they-- they were tending to people as fast as they could.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They had-- they had American medical personnel.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They had English personnel-- medical personnel.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They had French and Belgian medical personnel.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And they were just totally overwhelming.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "What they did was they moved them all out of there into the cities, the towns around, and they burnt the whole thing to the ground.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "That they-- and it was all burned.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Bergen-Belsen was burned, leveled to the ground.",
      "word_count": 7
    }
  ],
