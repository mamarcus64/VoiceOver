{
  "stem": "26609.11",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 21,
      "text": "I don't remember why I went out, looking for some-- for somebody, someone.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 22,
      "text": "And I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And there were big stones.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And a German asked me, where do you go?",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "He thought I wanted-- it was near the gate that I want to go out.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And I did that I don't understand, even.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I didn't answer [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "So he hit me, threw me down because I didn't answer him.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't Gestapo.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "It was must be an SS man.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "They came in.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "You could find them always in the ghetto, around, looking.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And I hit my head against the stone.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "It was bleeding.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And there was-- I couldn't go to a doctor visit.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't broken, the bone, but a cut-- a deep cut.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "He didn't say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "He left me.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I fell.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I got up and ran back quickly.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And there was this doctor that later helped me with the child.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They gave me the injection.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I couldn't go out, and I couldn't go to see a doctor, and there were no doctors.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Maybe there was one in another building, but I didn't know.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "But this doctor, that [INAUDIBLE], he had something visit.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And he just sew it together without anaesthetic, without anything.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "He sewed the skin together.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And it healed up, without anything.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Not only anesthetic he did it, I didn't have anything, even not a bit of alcohol, nothing.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And it just healed up.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And it still-- you can still see.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I was only two weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't know the people.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "There were people from all over Lwow.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know them.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I knew only my immediate family.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And in two weeks' time I was always with my child, so-- And other people, yes, they came in.",
      "word_count": 19
    }
  ],
