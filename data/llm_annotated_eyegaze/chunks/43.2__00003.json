  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I-- I came and I found it-- I see somebody over there.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "She was all naked.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Breast was cut in pieces.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "She was such a beautiful lady with colored black on the hair.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And-- and the [INAUDIBLE] in the [INAUDIBLE] place of mothers, you know the place, they put out such a big-- stay and look for [NON-ENGLISH].",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So I decided-- I decided I will try to go on with life.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Because they will catch me.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] They will do the same thing not to [INAUDIBLE] on their end.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "This make me-- so I decided.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I was standing, crying [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I decided I think go.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't let my body [INAUDIBLE] on their end.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "You see, I was there in the-- in the deep [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS] And what shall I do?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I came back to the-- to the-- and I-- my-- and I look.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't know I was [INAUDIBLE] or to stay here or go out and go up.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And then I was looking [INAUDIBLE] pieces of paper, our piece of paper.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Over there, I start writing in the grave here.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We got [INAUDIBLE] with grass from the [INAUDIBLE] used to cover us.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Nobody was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But sometime, was-- was a little raining or was-- we-- we put it out and [? no one ?] was writing.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So this-- first of all, so the nanny, she gave my boy papers and pencils and crayons because he was [? over ?] to-- for six-- when he was six years old, he was [? over ?] in a big town in a school.",
      "word_count": 44
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I got to-- letters from the-- from the teachers.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I-- your child will be somebody.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It was whatever he saw.",
      "word_count": 5
    }
  ],
