{
  "stem": "20848.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So they decided to wait till spring.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But by the time spring came, they-- they created the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And we had to go out of where we were living, and we had to go together with other Jewish people to certain area, which was the ghetto.",
      "word_count": 28
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Yes, both my uncles.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "My father-- both my father's brothers with their families came to Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "My father's sister didn't.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "She was a single girl still.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "She didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And my mother's sister and her children didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "They stayed in Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "But my uncles both-- the brothers of my father-- they both came with their families to Lodz--",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "--to Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I remember because-- before, I must tell you if you are talking about my uncles, my uncle-- the older brother who was a dentist-- he-- he died before the ghetto was created from typhus in Warsaw.",
      "word_count": 37
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And when we went to the ghetto, you asked me whether I remember.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I remember because there was a bridge.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "There were actually two ghettos.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "There was a small ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "That's why they call it Little Ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And there was a large ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And there was a very big bridge.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "They built a big bridge.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "That was the way you were going from one ghetto to another.",
      "word_count": 12
    }
  ],
