{
  "stem": "1391.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.3,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And my mother, with the other children, go to Belchatow.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In this time, was no ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was still like Tuczyn, a little town.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The mother go this way, and I go this way with my father.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Then, he took the cow in.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And we go to-- and I knocked the door by my sister.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "She start to cry and everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "She said, oh, I hope they don't come to me doing the same thing.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And we didn't know, unexpectedly.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And my sister's husband say, Adam, come down when get dark.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "We go.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "You take your father and go for the cow.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And we go put it in [? to ?] my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "We come.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "He opened the door.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "Right away, I saw, I saw how fast they go in the back.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And he say, run away.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "Because the German go catch you.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "Run away.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "I say to father, let's go.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "Please leave the cow.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "We go back.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "And he say, look, I don't can ruin your life to my sister's husband.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "I go into Belchatow, to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "It was no at this time ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "I go to Belchatow.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "And over there, they used to say that we're making factories, you know, and this.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "And that's what they did in the beginning, for pens, for the blouses, for everything.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "And we-- and he go to the-- he united with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "And I was staying with my sister, with my brother-in-law.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "Meantime, was a time, was the Polacks have to move.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "And from five houses, they make one house.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "And this was maybe 10 miles away from where I was with my brother-in-law.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 33,
      "text": "They moved out the Polacks.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 34,
      "text": "And they come in [SPEAKING NON-ENGLISH] Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 35,
      "text": "They said [SPEAKING GERMAN].",
      "word_count": 4
    }
  ],
