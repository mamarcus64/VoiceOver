{
  "stem": "71.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "You-- in two weeks, you are going to be free.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But I don't know what's going to happen to me.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "So that Helenka said, well, Frau Obersturmfuhrer, maybe you come in with us here.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "She says, oh, no.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "I wish I could, but I can't.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And at one time at the newsreel when they were showing, I saw her being latched to be hanged in-- in Bergen-Belsen.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I recognize--",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I-- I don't remember her name.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In Bergen-Belsen I saw her.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, she was latched to-- they said that she's going to be hanged.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And apparently, she knew about it.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "She knew exactly.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And it happened exactly to the two weeks the way she said it.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "We will be liberated.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And we were liberated in Theresienstadt.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And the Czech people were just marvelous.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They were the nicest people that I ever confronted.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "They were really, really nice people, very, very fond memories.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They brought everything we needed.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "They showered us with everything we needed.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They opened-- they had places where they were-- took away from people that came into Theresienstadt.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They opened them.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They brought-- they brought sugar.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They brought chocolate.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "They brought everything we-- we really needed.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And we stayed there, and then we left.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "We went to a small town.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And then we came back because we wanted to immigrate.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "So we went on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "We went to-- on the way to Israel, but the transport was stopped.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, you'll probably be very surprised, but we lived in a barrack.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We were 14 girls in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And it was the end of-- of the barrack, the last [INAUDIBLE], and I heard a very heavy vehicle.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Very heavy vehicle.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So I start running towards the street.",
      "word_count": 7
    }
  ],
