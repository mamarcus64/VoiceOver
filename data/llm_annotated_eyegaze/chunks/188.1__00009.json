  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 76,
      "text": "But they have-- some social workers have been there, and these children are going to be reunited with their family, or they're going back to Rotterdam.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 77,
      "text": "They can go home.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 78,
      "text": "They were not at the house anymore when I came back.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 79,
      "text": "And at the risk of his own life, obviously.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 80,
      "text": "And miracle of miracles, they let him go.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 81,
      "text": "They said-- they did not hold him.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 82,
      "text": "And two days later I think it was, we were actually reunited [PAUSES FOR 3 SECONDS] with my parents.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "They had been in several hiding places.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They had been in a small room in our hometown.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And in retrospect, when I think about the courage they must have had to let their children go, it is incomprehensible.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And the agony that not knowing what-- what-- is happening.",
      "word_count": 10
    }
  ],
