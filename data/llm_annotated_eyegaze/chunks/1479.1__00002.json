{
  "stem": "1479.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And right from the beginning, he started to employ Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "However, I had over there a little bit different experience because when they brought us, and they lined us up in fives, and the managers from different departments, they would come and select people for their department.",
      "word_count": 37
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "I was the only Jewish girl taken out from the group and was brought to the Nazi family.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "And I was over there working as a maid.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My sister worked in the garden.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Later on, she worked in the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "At the age of 15, I was already in a forced labor camp.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "This was a forced labor camp.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was on the grounds of the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was a big building, a beautiful apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They had a maid, and I was brought over there as a helper to the maid.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "There was also a woman who was a special woman who knew how to cook and bake.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But we would basically, the two of us, the Ukrainian girl and myself, we were just cleaning the house.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "When they took us during the night, we barely took a few things in our hand.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It's-- you could say next to nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And everything by force.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And [INAUDIBLE] you just didn't know what to do.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You followed orders.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In the German family, I must say they treated me rather very well.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I had no problem over there.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And when they were entertaining-- again, they're Nazis.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They were entertaining their friends, Nazis.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And many times, the lady of the house would take me with pride by the hand into the dining room as to give me a-- a special favor.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "She would smile, was telling her guests what a cute, Jewish girl she has in her household.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was over there 24 hours.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I ate.",
      "word_count": 2
    }
  ],
