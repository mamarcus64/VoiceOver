{
  "stem": "21482.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "If we stayed in Auschwitz another hour, she would have broken up in scarlet fever, they would never have let us go.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "We would have been sent straight to the gas chamber.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Herte.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Herte.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And then, you know, the train stopped and the doors opened.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And there stood Oskar Schindler, just, just the way you saw, that you saw the movie, just the way Oskar Schindler was with his green Tyrolean hat with the feather in the hat and the cigar in his mouth.",
      "word_count": 39
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And he stood there and he said, you are finally here, and I'll take care of you.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And you have nothing to worry about.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And of course, he took care of us.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "He risked his life.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "He risked his fortune.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He asked Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Schindler to come to Brunnlitz, and she did.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And she helped take care of the sick.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "She used to go to the village and try to get some extra food for the sick.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "They got some farina for us, for the young ones like me.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And she cooked the farina.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Every day for two weeks we walked across the factory floor to-- they had a little apartment off the factory floor.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "They had a beautiful villa.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And they never slept in the villa, because we were afraid when they would be away from us that we would be killed by the guards.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "So they always stayed.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "They never went away together.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "If he went away, she would stay.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And of course, Oskar Schindler was arrested twice.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "And he was released because he had such high connections.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "And Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "Schindler knew exactly who to call to help.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Gestapo.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Who were the guards in Brunnlitz?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "One was, you know, SS.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "There was SS.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "His name was-- the commander was Liepold.",
      "word_count": 7
    }
  ],
