{
  "stem": "17301.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They beat her up very, very badly, and they made her kneel down on gravel, on very sharp, sharp gravel, from early morning on until 6:00, 7 o'clock that night, [BACKROUND NOISE] without any food, without any-- any water.",
      "word_count": 39
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She-- they didn't give her anything.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And she was still lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Because a lot of people were shot right there on the spot, and she was not.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Because maybe she had-- she was blonde and blue eyes.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And they tried to spare her.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "But that was-- she did that for me, and I was forever grateful to her for that.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "She suffered an awful lot because of me.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "She did a lot of things for me that she should not have done.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "There was no place to go.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We just stayed in that small compound.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We-- we didn't go anywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "We went from our-- our barrack, where we-- where we lived, where we stayed, into the barrack where we worked, and to the shower, and back into our-- you know, place where we lived.",
      "word_count": 34
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "No, mm-mm nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Never, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Mm-mm.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "No, we always-- we had to turn everything over.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But I don't know if I told you that I took some of the very valuables and I buried them in the ground.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Because I didn't want the Germans to have everything.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Because we found an awful lot, lot of valuables, a lot of valuables.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And there was one German oberscharfuhrer that for some reason, must have taken a liking to-- to my mother and-- and the two of us.",
      "word_count": 25
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Because they weren't supposed to know that we were related.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And he somehow had a funny feeling that we were standing always together that we might be related somehow.",
      "word_count": 19
    }
  ],
