{
  "stem": "24650.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Because I have small children.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "You can't leave them alone.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "I didn't have money to pay for somebody to look at them.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "So we lived up to '57.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I gave my papers in '56, in December month.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And in '57 marked the first I got the papers.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I got alone.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "My husband didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "He just came when he had to sign.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "So when we get to Poland, there I got my real papers.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And we were in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "The Polish people gave us everything.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "They gave us where to live, two and a half months, food, train tickets, money, everything.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They picked us up like Holocaust survivors.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Of course, they knew.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We came to our country.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I was the who was born in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And then when my husband looked for work, he couldn't speak of word of Polish.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "He couldn't speak good Russian, either.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "But they liked him.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And they gave him a green number to have a taxi, a cab.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "But we-- we didn't have the money.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "So a friend of ours had the money.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "So my husband took his cab.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "He got 70% and my husband 30%.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "What would you do?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "We're going to break here and go to the next tape.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "OK",
      "word_count": 1
    }
  ],
