{
  "stem": "17372.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.8,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So I dressed, dressed him in this suit, white and blue, the same striped suit and hat.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Schindler was afraid of Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "About three or four of my friends.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They been driving the car.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And he pretend to be also one of them.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "He was afraid of Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He was afraid of Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He wasn't sure about the Americans, either.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Some, some-- first shoots, then ask questions.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And although he had a letter from-- with 1,300 signatures from Jews that he saved our life.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "He luckily came to American Zone.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And up there, the Joint, a Jewish organization, [PAUSES FOR 3 SECONDS] bought for Schindler and his wife-- bought a farm in Argentina.",
      "word_count": 27
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was already end of the war.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Nobody could listen.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You see, one day, you see, I was-- I was-- all the war I was in good health.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And the last day, my nerves gave up.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They took me to hospital just for one day.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And this is the day when I haven't seen Schindler sayings to all the people, you are free now.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "You can do what you want.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "You can go where you want.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Say goodbye to them.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And this is when one of the inmate took out a crown, a gold crown.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And my brother-in-law, Joseph [?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Gross, ?] is here, husband of a sister of my wife which died three years ago.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "He made the ring, gold ring for Oskar Schindler.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And they smuggled him out.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And next day, we've seen Russian there or come Russians already there.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So we moved out.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We, we went to some-- after Germans, some apartments, we spent few days.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And then we took a open train, good train, going somewhere.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know where to go.",
      "word_count": 6
    }
  ],
