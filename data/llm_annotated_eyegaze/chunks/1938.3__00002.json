  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That's how-- the children-- my statement is, the children what was raised in not such a-- a big luxury, they came out very, very good, and the best professionals and the best people.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "The children that are raised with all the luxury, reaching for dope.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And then it comes one day, they don't have what they needed, they commit suicide, and nothing is good.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "So this-- when I say something my children say, what do you want?",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "You have great two kids, and you don't owe us nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "You were always good, we had everything we needed.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "That's how they-- I think that's wonderful.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I'm very proud.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Very proud.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Six.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Three boys and three girls, and they're all good-- very good.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Good in school, and good behavior.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Everything's good.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "On the train where they took him-- I don't know where.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Just like a march, like we do.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, open thing.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So he looked at other people, and they cut the veins, they cut themselves.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They got crazy from hunger, from everything.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So he said to himself, what I can lose when I run-- when I run--",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was a running train.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He jumped off, and the guy what saw him, it shoot after him, and he shot him in the back.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "The [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "So he saw--",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Probably near Mauthausen, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When this-- when this happened, he saw a little house, and he knocked the door.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And they got very scared, and they decide to be very friendly, and they told him, come in.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And when he come in, they-- they went in the other room and they called the police, the Germans.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And when they come in, they took him to Mauthausen, to the mountains.",
      "word_count": 13
    }
  ],
