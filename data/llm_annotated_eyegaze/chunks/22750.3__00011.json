    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Somebody has a gun and goes by.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "He wants to kill the dog.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "He kills the dog.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And the same situation with us.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "All kinds of people and all kinds of times.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "Was good people, too.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "Was bad people, like I mentioned to you.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "I had some people-- maybe I'm not on the subject-- but they gave me life.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "They gave me life, not God, because they gave me shelter.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "They gave me help.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 13,
      "text": "And at that time, was also not everybody was the killer.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    }
