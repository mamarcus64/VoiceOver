{
  "stem": "311.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He looks like his son, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And I know his son was taken out from-- from concentration camp, brought in to Polacks.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And-- and-- and I ask him, you know, are you-- is your father this Gunther, you know, he was from Cracow?",
      "word_count": 21
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "He said, I don't know what you're talking about.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "He didn't want to-- So I said, all right, I'm sorry, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "But I could have swear it, it was him.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "You know, he was the main engineer.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 9,
      "text": "And that-- but he was so good to me.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 10,
      "text": "I had the pick of the crab, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Like there was a-- a-- a computerized cash register that's at least 400 pounds.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "He give me 60.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "All right, and I reply.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "He say, OK, you know, it's all right, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "But the dies are too much, and the piece part and so on.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "But the dies were practically for nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "I add up $0.02 to every piece, you know, and give him for nothing the dies.",
      "word_count": 16
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "I got--",
      "word_count": 2
    }
  ],
