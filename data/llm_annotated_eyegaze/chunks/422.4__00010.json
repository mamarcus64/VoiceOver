{
  "stem": "422.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We escaped the town, that I knew that I knew that the Russians were there already.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We escaped the town, because we didn't want to be with the Russians.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Which I was looking at the minute they should come in, but I had to make up that story in order to-- to survive.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I said to her, [NON-ENGLISH]-- you don't admit that you're Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And the minute you admit you're Jewish, we're dead.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And I knocked at the door.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And a young woman, a German woman, opened the door for us.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "It was very early in the morning still.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And I told her the same, the story that I just told you.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I loved them very much, I came to Germany to work for them.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And I-- and I left behind my whole family in Warsaw-- in Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "By this time, I didn't have already nobody, no family, but I had to lie.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And we went and our group, stood-- took a rest the train, we went down to look for some--a drink of water, and we missed the train.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "The train left without us.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "This was my story.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And the woman starts telling us her hard luck story, that her husband is already two years on the Stalingrad fighting very-- she didn't hear from him two years.",
      "word_count": 29
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "God knows if he's still alive.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "She started crying.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "In the next room, was two little kids were sleeping.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "She showed us, on the wall was her wedding picture.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And she was friendly.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "Because if you were note Jewish, she was friendly.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "Said we were Polish girls.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "First of all, I said we were frozen.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "We were-- we are cold.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "So she gave us hot coffee, she gave us homemade bread.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "And we warmed up by a wooden stove-- wooden stove.",
      "word_count": 10
    }
  ],
