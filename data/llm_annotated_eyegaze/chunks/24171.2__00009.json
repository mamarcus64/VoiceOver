{
  "stem": "24171.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I don't know where they were, probably already in the-- in the-- in the ghetto, in [INAUDIBLE], because there were two ghettos.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And-- and we slept there in the shul, on the floor, on the chairs sitting, by the [INAUDIBLE], by the whatever.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I cried there too when one from our village, he didn't came home.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "From my family was my parents and me and my sister with four children.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "The husband was already in that-- those working.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I never could say it, forced labor or labor force.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And another sister with two children without the husband, and there was a sister-in-law, which my brother was already away too, and [PAUSES FOR 3 SECONDS] from [INAUDIBLE], from that next where we pass by, that village where one of my brothers were living with two children.",
      "word_count": 47
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We find him already there in the shul.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "He was in the morning taken away or what.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "So [PAUSES FOR 3 SECONDS] as I said, sister-- two sisters and a sister-in-law were there, and then my sister-in-law had a mother there and-- and my sisters.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] No other sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I don't remember if was there-- yeah, [?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Shia. ?] Yeah, [?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Shia ?] and his brother with a wife.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "That's my-- an uncle from my niece's which they-- so that's how many we were there.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And from [?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Polyana, ?] that brother that they did not let through to the bakery, he was-- he was in the other.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "It was like in the same city but another there.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "There was brick factories.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So we came to [INAUDIBLE], we slept over there.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And on Shabbas, they put us on a civilian train because there was no-- so on a civilian train, we went to Mukacevo.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "A regular train.",
      "word_count": 3
    }
  ],
