  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "You know, and this group has to wash, the young ladies, they wash clothes and was divided.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Was a-- good divided.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Two years.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "It's very cold?",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "It was not too cold in the forest.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "From beginning we made fire outside and-- and around the fire.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And then we have the-- those tents and-- and we find by Ukraine people those iron [PAUSES FOR 3 SECONDS] wood.",
      "word_count": 21
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "You-- we survived.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "For the-- for the cold weather, we-- we were not afraid.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "We're afraid only for the Nazis.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "They called me [?",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Saria. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The commander.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Because Faygeh is more Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "So they called me Faygeh.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "The commander gave us the names.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And my husband's name was [?",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Zelenko. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "Zelenko ?] is-- [? zelano ?] is green.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "Forest is green.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "They called him [?",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "Zelenko. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH SPEECH]",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "He left.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "By the Red Army.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "For sure.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "By the-- because our commander, he had a diary.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And this diary he made, they took us to Moscow.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And-- and then my cousin find this book in Russian language.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "He translate it into Hebrew and we translated into English.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And-- and my son, Jack, he's a writer.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "So he wrote a lot of books.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "They find it in-- in Moscow.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I think this was found already after the war.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Oh, this is the book.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "You saw?",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "You saw this book.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "After war, you're on you're own.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "So we went to the bigger cities.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "We went to Rowne.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Rowne.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Rowne is a big city.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And there we find an apartment, one-room apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "But was-- our houses was bombed.",
