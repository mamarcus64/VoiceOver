{
  "stem": "2830.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "Her daughter worked in the office, in a doctor's office.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And there was a nurse from Warsaw, that Polish woman.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And she was the nurse.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "She had an eye on this doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "And this doctor fell in love with a Jewish, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "She worked in the office.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "She was the most beautiful woman that I ever saw, tall, beautiful.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "That started.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Being me, you know, my age, this nurse sort of got-- she liked me.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And she told me things.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "She said, there are Jews hiding out here.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And I know it.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "There is specially one of them I have to get rid of.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "So there was day after day I knew.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "And I-- we were afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "Among ourselves, we knew who was Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "I had a feeling that who was Jewish already, but we didn't.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "We didn't talk among us, because-- It's too dangerous.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "--you even afraid--",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "--to talk among your own.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes you go into the ladies room or what.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And you just-- I said-- I said to her [INAUDIBLE] that, you know, we in danger here.",
      "word_count": 17
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And I knew they are sending a spy.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "She spoke about [INAUDIBLE] maybe 20 languages or so.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And we were called in one by one.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "She asked us some tricky questions, things.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And one Friday they came in-- did I told you about where I worked there?",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "They put me to work on a machine.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "They have-- they brought aluminum in sacks, like sugar or what.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "It looked.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "And there were big machines like press machines, like-- like-- like printing presses, big machines.",
      "word_count": 15
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "So after, the aluminum was emptied into things that melt it.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "There was a big fire.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "And it melted to liquid.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
