{
  "stem": "5644.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We been Jews, having friends, Jews and Christians but knowing that we're Jewish quite well.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Mother's side was all-- including my grandfather-- socialist, more to the left.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Father was not involved with socialism, but in his business and his home and children.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I lived in a very comfortable, very comfortable life.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We did have a very comfortable life-- parents which never screamed at us, never put their hand on us.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Our punishment was done in a different way, where if we did want something and we did something which wasn't right, that was refused to give us something or to help us in the way.",
      "word_count": 35
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "That was the punishment.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Nothing else-- no screaming, [? nothing. ?]",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Can you tell us from your brothers and sisters, how you interacted with them, played with them, spoke to them?",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We been all three years apart.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "When I was, for example, 12, my older brother was 15, and the oldest, 18.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "The younger brother was nine and sister, six.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "That was always, that every three years, a child-- five children.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Did you-- you went to school?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I went.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I went to school, to private school and then went to a gymnasium.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I haven't been very good at school.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And at the age of about 15, I left school and have a private tutor in my home.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I always been looking to be together with father in the business.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I never did want to go to school and be happy at school.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So we decided that the best way would be that I'll have a tutor home and help father in the business, which I did.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Mother's completely not religious, mother's family, including my grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Not specially.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We used to go out to some events, sporting events, but no.",
      "word_count": 12
    }
  ],
