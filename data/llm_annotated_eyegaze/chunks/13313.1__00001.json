{
  "stem": "13313.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Then he brought my mother a couple of years later.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They-- they married in-- in Belgium.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They married in Belgium.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "That's what I think that-- I believe so.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My-- my parents were very hard-working people.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They started from scratch and opened up a beauty salon.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "My father had quite a talent as a hairdresser.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And one shop after the other.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And eventually, ended up with one of the most prestigious salons in a beautiful area of the city near the National Bank, which was near the Central Park.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "A very nice place with lots of staff, and the best people came to the beauty salon to do the hairstyling for many women.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Is there a name for the neighborhood?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I-- I know the-- I know the-- well, it-- it was called the better part of town.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It was near where the-- where the-- where the Palace of Justice was, the National Bank was, it was a better-to-do area of the city, if you look.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, he was pretty good.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "In 1936, I believe he won a gold medal in Paris at the World's Fair.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, also very busy.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Both worked on their feet for seven days a week.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "One of their big motivations was to help out their own parents in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Matter of fact, my father went back and bought them a house from the earnings that he-- that he had accumulated.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And so we were looked after by hired help, really.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And then Sunday we had a few hours together with our parents.",
      "word_count": 12
    }
  ],
