{
  "stem": "12674.7",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "So then I worked someplace else.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And by that time, I was already-- by that time I was already a bookkeeper for-- for-- I had three people working under me.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And then I stayed home.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And then I became pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I had a few miscarriages.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But then I finally became pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I had a baby.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "It was Gregory.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He was born in April 27, 1957.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I was home for-- and then I had another child, in 1960, my daughter, Pamela.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She was born on July 24th, 1960.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I was home until 1968. 8:00 And then my marriage started to break apart.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I decided that I was going to go back to work.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And when I went around, they gave me tests, and decided that-- [PAUSES FOR 5 SECONDS] --I was overqualified for the job.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I went to [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I was going to become a margin clerk.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And they said, in four weeks I was going to tell her, the-- my boss what to do, and they didn't want me.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Because I came out too high on the test.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "You know, the aptitude test they were giving.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And the phone company, the woman that tested me, she said-- she said, don't work here.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "She says, this is not a job for you.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "She says, you're the first person that I know that has completed the test in under a half hour, and no-- no answers wrong.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And most people take an hour and a half.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "She says, you don't want to work here.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I was looking.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my sister-in-law kept saying, before you can walk, you have to learn how to crawl.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I says, I'm not crawling anywheres.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I decided to become an accountant.",
      "word_count": 6
    }
  ],
