{
  "stem": "11722.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 61,
      "text": "I remember we had a line.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 62,
      "text": "We had to hand four bricks at a time like a chain gang.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 63,
      "text": "The brick was like sandpaper.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 64,
      "text": "It wore off-- the tips of my finger became nothing but flesh.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 65,
      "text": "[PAUSES FOR 3 SECONDS] And we had to work I don't know how many hours a day.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 66,
      "text": "I worked there for awhile, and then I worked in a coal mine.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 67,
      "text": "The rations were starving rations.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 68,
      "text": "Very few people survived three months.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 69,
      "text": "Within three months they dwindled down to nothing but skin and bone.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 70,
      "text": "[PAUSES FOR 3 SECONDS] They had to stand in line for selection.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 71,
      "text": "And we had to run through naked through the Nazis and overseers.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 72,
      "text": "And they took our numbers.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 73,
      "text": "All those whose numbers were taken [PAUSES FOR 4 SECONDS] were selected.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 74,
      "text": "They would put them on a truck.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 75,
      "text": "They were carted back to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 76,
      "text": "And they were in--",
      "word_count": 4
    }
  ],
