  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Because if he would have wanted, he was the commander, he didn't have to have kids in an outfit like this, where--",
      "word_count": 22
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, he knew.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "All Jews, yes, and they had Jewish partisans there from Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "There were a few Jews who were Russian Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "A little Yiddish, but mostly Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "But Yiddish, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Well, we though that Messiah came when we saw them first, because you could sleep, you could make a tent, you could relax, you could make a fire at night, you could laugh.",
      "word_count": 33
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "You felt like you were human again.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "They were trained, and they--",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Quiet, yes, they had to be quiet.",
      "word_count": 7
    }
  ],
