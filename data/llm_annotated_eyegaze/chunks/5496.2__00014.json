{
  "stem": "5496.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "But by then, I know that she is well, and that is only a matter of time.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "They told us that the elderly will follow later-- not elderly, but the ones who are older.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They will follow later.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I went to-- my final destination was Montreal.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We landed in Halifax.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we--",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "1949.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "From Genoa, we were taken by a ship, SS [INAUDIBLE], which was a warship.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we were taken on the ship.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And I don't recall as thing, because I was sea sick from day one until we landed in Halifax.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I always say, only my clothes marched out.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I must have been left behind.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "But I did wind up in Halifax.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And then by train, we were taken to Montreal.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "We were given badges.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "We were domestics, and we were requested by the government to work in Canada.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, to-- God must have looked down on me, because I was assigned to a lovely family, Dr.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Levine ?] on [INAUDIBLE] Avenue, in Montreal-- who, indeed, took me in as their own daughter.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I never had to do, quote unquote, chores.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They treated me like their daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And he's the first one who got me back on the medical field.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He got, eventually, got me a position in the Jewish general hospital in Montreal, where he was, himself, one of the physicians.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And I worked in the office of the hospital for about a year.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "At this point, I was fine.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I had only one problem, which remains with me to this day.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And this is why they never let me work.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I have a chronic dislocation of both my shoulders, which happened in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They made us carry, at one time, must have been food, to the best of my recollection.",
      "word_count": 17
    }
  ],
