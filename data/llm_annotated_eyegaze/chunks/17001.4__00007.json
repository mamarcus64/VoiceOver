{
  "stem": "17001.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "These were all Hungarians, only the-- the Blockaltestes and the Lageraltestes who were Polish or French or Slovak.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And at one occasion, we were standing [GERMAN] and it was on a Friday.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And as we were standing [GERMAN], there was this woman, Polish woman, with her daughter.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "She was the Blockalteste, and her daughter was like the assistant, sort of.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And she had a walking stick, not a-- not a rounded handle.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Just a stick with a very sharp metal end to it.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And as she is counting, you know, in German, she seen this beautiful woman standing on line.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "She starts to call her all kinds of whore.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "All kinds of dirty language.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "You were sleeping under the cover with your lover.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And you were fornicating.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And you were having a good time while I was here.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I was burying my child.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "I was cutting as an ice block out of my other daughter, taking her to the crematorium, and you were still having your stomach filled with goose liver, and you were having all the good things.",
      "word_count": 36
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And as she is talking, she is winding herself up to such an extent.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "Then she starts to hit the woman.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And she poked her eyes out.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "She poked her eyes out right there.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "So the poor woman gave out a scream and she fainted.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "And then she just kicked her and throw it.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "And she throw her at the end of the-- the barrack where they picked up all of the dead ones and they were taking them to the crematorium.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And later on, I heard that she was lighting candles.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "She lighted the candles Friday night.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "And then she said, my dear children, behave yourself.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "And be good.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "Then you won't go through the chimney.",
      "word_count": 7
    }
  ],
