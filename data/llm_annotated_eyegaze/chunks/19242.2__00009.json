{
  "stem": "19242.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.3,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "A plan is to get more guns so we can operate more efficient and-- and go out and get food.",
      "word_count": 20
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "From them, from the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they were by the railroad station.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And it's-- they are-- and they-- what do you call it?",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "There are certain section of the railroad station.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "They were-- what do you call-- they were guarding.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And we though this was like 10 of them or 12.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And we thought that we can get only three of them, we would be OK.",
      "word_count": 15
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "But somehow, it backfired.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I don't know how.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "That backfired.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "They started shooting at us.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And everybody, we were on-- and you know, you couldn't-- if you don't have enough guns, and you know you're going to, so some of them took off.",
      "word_count": 28
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "I was the only guy who got hurt.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't think so.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "You don't have no-- nobody has a radio or anything.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "How you're going to tell them?",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "I mean, here you have radios.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "There was no radios or any communication.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't talk on the outside world.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No more home after that.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "But, I mean, the same token--",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I knew what my mother was killed.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And we got [INAUDIBLE] communication with it, with the town.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And they told me my father was alive.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "From everybody, my father was alive.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He got killed too.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And did it.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "It was two shooters.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "The one was-- the one was-- like I told you, one was [INAUDIBLE] and one was [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "He was the last one.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother was [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "He was the last one.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "We have to go out by the farmers and beg for food.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Some of them, they used to have like potatoes.",
      "word_count": 9
    }
  ],
