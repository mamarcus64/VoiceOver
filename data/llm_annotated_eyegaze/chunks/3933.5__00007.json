{
  "stem": "3933.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "They emigrate to Israel-- to America many years ago.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "I don't know why my father didn't do it.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "I do know now.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "I was told because there was health reasons.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "My father was very bald.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "I never knew him for having hair-- and something was an infection, and they wouldn't let him pass through.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "This is fate, damn fate.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "When those brothers-- OK, those cousins, I went to them in 1956.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "I stayed a few months.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "I couldn't depend on them too much.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "But I could get a visa.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 40,
      "text": "I went back, and I applied for a-- for a green card, and they said I can emigrate with my husband, and my son didn't want to go, and I was a very big mistake to leave my son and go.",
      "word_count": 41
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 41,
      "text": "But I wanted so much to get rid of him, then I figure I'll get a divorce in America.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 42,
      "text": "When I receive the-- from the American consulate as I am entitled to emigrate, I told him, go, go.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 43,
      "text": "I will follow you.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 44,
      "text": "I have four months time, says the visa.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 45,
      "text": "I was so happy to get rid of him.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 46,
      "text": "He went.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 47,
      "text": "He wouldn't leave me alone.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 48,
      "text": "He kept writing letters.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 49,
      "text": "I--the first opportunity I came out there, I eventually left here, and I went to Mexico for a Mexican divorce, and I divorced him finally, get rid of him.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 50,
      "text": "And I should have gone back to Israel, which I didn't.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 51,
      "text": "It wasn't-- I didn't have the money.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 52,
      "text": "I didn't-- I find a job here.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 53,
      "text": "I started out working.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 54,
      "text": "He married about another three times, four times.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 55,
      "text": "Pig.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 56,
      "text": "And then my son used to come-- my son went to the army.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 57,
      "text": "I went to visit him, and I went visit there, and visit back and forth.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 58,
      "text": "And-- and that's it.",
      "word_count": 4
    }
  ],
