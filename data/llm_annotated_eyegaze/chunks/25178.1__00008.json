{
  "stem": "25178.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "She got mad at me, and she told me to listen to her.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And she told me, I want you to jump right now.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And so I jumped.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And I ran.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I had no idea where to go.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS] So I went home and there was nobody home because everybody in the house was gone.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So I went out again, and I tried to find out where they took the truck.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And I found out that they had taken the truck to a school, and they had rounded up all the Jews on the playground.",
      "word_count": 28
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And the school was-- the entrance to the school was being guarded by German soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I sneaked by the guards.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 14 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And I found my mother sitting on the suitcase, crying.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And when she saw me, she was furious, and she told me to leave her immediately.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] So I left.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And I sneaked past the guards again.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I sneaked out of the school.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I went to some friends of my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And I knocked on their door, and they took me in.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] And they were-- they were not Jewish people, but they were very close friends with my brother and my mother.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And she had connections with the underground, and they contacted the underground.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And somehow they were able to tell my brother where I was.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And he came the next day, and he picked me up.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And he took me with him to the preventorium [PAUSES FOR 4 SECONDS] in Westmalle.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Westmalle is about-- it's a little village 24 kilometers out of Antwerp.",
      "word_count": 12
    }
  ],
