{
  "stem": "23131.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Favorites between them that I never knew who was called what.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "What did your father call your mother?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In the Russian names, all kind, you know, like baby, like sweetheart, like-- I never heard her name called by my father, until I asked one time.",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I said, Mommy, do you have a name?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "She said, what's the matter with you?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So she told me the story.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "There was a real very fantastic life.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "But this was absolutely nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "My father got very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't-- he couldn't cope with it.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "He smoked a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "He stopped eating.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "His whole intestines were shot.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And the doctors decided-- we took him to-- [PAUSES FOR 3 SECONDS] to Vilna to a doctor.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Then we took them to Bialystok and the decision was that he has to go to a convalescent home where they start feeding him by spoon by spoon, you know.",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And he was seven months in a convalescent home.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And from all over, I remained alone from all the luxury, from everything.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "My brother was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "My-- my father's brother came, you know, and my mother's brother came.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "So they stayed.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "They took turns to stay with the-- with the kids.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "I had to go back to school.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "It was not easy after such a tragedy.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "And Mommy used to go away for a week to see my brother in Bialystok.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "It was a tragedy.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "I was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "I was screaming.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "I didn't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "I didn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "Mommy, Mommy, Mommy.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "And here Mommy was taking forever.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 29,
      "text": "And I just couldn't get to the idea.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 30,
      "text": "And here knowing maybe I lose my father too.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 31,
      "text": "It was a terrible time.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 32,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] I-- My brother took me back to school.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
