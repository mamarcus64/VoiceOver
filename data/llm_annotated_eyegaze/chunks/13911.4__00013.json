    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "But listen, a little discretion.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Even a Pole might maybe sometimes-- witness.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Why have witnesses?",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "So-- ghetto.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "A new ghetto, with 7,000.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "A kitchen opens.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "They give us coffee or the soup.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And, again, we get-- how do you say it-- the-- [PAUSES FOR 3 SECONDS] They put us and place us-- you live here.",
      "word_count": 23
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "People-- we were, like, five girls-- young girls-- living in a little cubicle.",
      "word_count": 13
