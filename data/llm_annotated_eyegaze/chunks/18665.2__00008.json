{
  "stem": "18665.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 333.0,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "From there, I moved on to Springfield, Ohio, where I took a job as a plant manager, another four years. 1952 to 1956. '56 we came out to California, because a company here hired me to run their plant.",
      "word_count": 39
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And worked there for two years and then started on my own.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But I think I wanted to say something about Shanghai yet.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "All the work that I've done in Shanghai.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "That I think would like to have on record.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "During the war, I worked on-- in bakeries.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I delivered coal from house to house.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "All kinds of odd jobs.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I was a night watchman in a Japanese school.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We're talking about '42, '43 until '45.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "During the height of the war.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I even dealt on the black market--",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "--just stay alive.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Exchange dollars, and all kinds of odd jobs.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "My dad was a broken man.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He-- he just couldn't work.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Uh-huh.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Well, there was times when my mom worked as a home worker, also.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Even as a-- as a matter of fact, lampshades.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "She did that.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And so did my grandmother, during the war.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But anyway, life began in the US.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "All of our children are born in the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Two of them in Minneapolis, Minnesota, and two of them in Springfield, Ohio.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "1956, following a job.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And then in 1958, like I said, I started my own small business in my-- in my garage in Sherman Oaks.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Manufacturing in leather goods.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And, well, the company at that time, actually, was Matzdorff House of Leather.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And one little episode, while I was working in my garage, and my neighbor and I, we shared our driveway.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And one day Al came home and he looked at me, and says, what are you doing here?",
      "word_count": 18
    }
  ],
