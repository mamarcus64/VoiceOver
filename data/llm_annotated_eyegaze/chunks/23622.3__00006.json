{
  "stem": "23622.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Only when sometimes my mom came to visit, and we arranged it with my brother, who lived next door, if they come, knock on the wall and said, who is there?",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "That we knew that my mom was visiting me, too.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You could go from the back into my house.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So it happened once.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My mom came, and my brother, bang, bang, bang, bang on the door.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Mom is here.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And she will be right over!",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And we were just sitting on the dining room table, eating supper.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I went the plates.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "They went all over the place, in cabinets or whatever, only two plates from us.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And they went upstairs, all the way up to the attic, and closed the thing.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And they were sitting there.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And my mother came in, and there were just two plates on the table.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We were finishing our dinner.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Those things-- and it happened more often, of course, because we knew-- all of a sudden somebody came, they-- woosh-- they went up in the attic.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Not to look for them, but once, what I was trying to tell you before, that was on a Saturday.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My husband went for his paycheck to the city, and he had our little son.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You know, we took every week Harro, our son, was allowed to go for a little trip and see the grandmas and so on.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "So he always went with him.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And that was in 1944.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Our second son was born in August '44.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I think he was about six or seven weeks old.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And it was on a Saturday morning that my husband went into the city.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And he stayed away for a few hours, used to.",
      "word_count": 10
    }
  ],
