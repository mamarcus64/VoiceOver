{
  "stem": "7414.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And if you need something, you know where to find me, and I will be always ready to help.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And I am going now back to Przemysl, and I will try to reach your parents in the ghetto and tell them that I saw you.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And very decent young man.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Ukrainian.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So I'm staying in this Warsaw-- in this Krakow place.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And this woman was not very happy with me.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It means she started to panic.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I was very high then-- by then.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And she started to panic that I am going to have a baby in her place.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And she was ringing every day to-- to Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Take her back.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I don't want the baby here.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I don't want the complication here.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And that, I was end of the seven months.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I had no roof over my head.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "She did not want me in her place.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "In Warsaw, there was no room for me.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And I was sitting there.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Then in two weeks time, everything-- this, they told me to come.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Come back to Warsaw, and I did.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And I stayed with the-- the whole family.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "It means my sister was there, my brother-in-law, and their daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And the-- the-- the couple, the Polish couple.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Their name was Paula and Frank Prowiszak.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And as we will talk later, I will call her Aunt Paula, and him Uncle Frank.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Because she introduced me to everybody as her niece, a daughter of her brother.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "First, it was because she wanted to cover us as the resistant people.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You know, the resistance people.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And after a while, she just loved me.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We just went on so well.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "She was like a mother to me.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And she told to me-- not-- not once, but very often.",
      "word_count": 11
    }
  ],
