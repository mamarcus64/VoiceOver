{
  "stem": "26728.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Ferree.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Ms.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Walters.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Charles, C-H-A-R-L-E-S.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Victor, just like Victor.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Ferree, F-E-R-R-E-E.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Same.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "June the 30th, 1924.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "72.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Prescott, Arizona.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother's maiden name was Contreras.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Her ancestors were from Spain and Mexico, and she-- her nationality was Spanish, Mexican, and Indian.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Her family were ranchers in the Miller Valley in Arizona.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They had a huge, big cattle ranch.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Seven or eight brothers and sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My father was a railroad man.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He worked for the Southern Pacific Railroad and Santa Fe Railroad.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "His name was Ben, Ben Ferree.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Not, Benjamin-- Ben.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he, he worked as a freight-- on freight trains as a brakeman and passenger trains as a conductor, and also as a fireman, stoking coal into the engines.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I was raised in Prescott.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I went to Catholic school starting at about age 3.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And it was not an orphanage, but it did have children in there that were-- that had no parents or were very poor.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "My education started in this Catholic academy, they called it.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So, by the time I was five, I could read and write as good as most kids that were seven or eight years old.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We moved-- my family moved from Prescott to Tucson in 1929, in the middle of the Depression.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Things were very tight.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "My dad worked at a variety of jobs.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "We-- my brother and I were farmed out to various families temporarily.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "We were never-- we always knew our parents were there, but it was kind of a very awkward situation, because we didn't get to see them all the time.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "That lasted for three or four years.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And we were also placed in the Catholic orphanage at one time during the height of the Depression.",
      "word_count": 18
    }
  ],
