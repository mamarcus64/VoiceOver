  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "But I run again in the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "It was a lot of dead soldiers.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I was falling right away.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And I was rolling, I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And when we left-- we were fighting there-- we started the war Friday morning.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The whole day, the whole night Saturday, without food, without everything, [PAUSES FOR 6 SECONDS] Saturday the whole day, Saturday night, the whole night till 3 o'clock in the morning when it start to rain.",
      "word_count": 35
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "When it starts to rain, we were in the-- in the-- you know?",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "How you call this?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "In the-- Trenches?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Down there, we got holes they made to-- to hide and to shoot from there.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
