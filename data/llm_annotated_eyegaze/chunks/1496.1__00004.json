{
  "stem": "1496.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "For us, personally, it changed immediately, because actually, the ghetto was created in the area where we-- where the business was, and where we lived, actually, when I was born, and I grew up.",
      "word_count": 34
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Where my parents' house was.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So actually, we didn't go to the ghetto, but the ghetto came to us.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So this was already 1941.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "How did your family's life change?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Was the ghetto walled at the beginning?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "This ghetto was created in one of the sections of Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They ordered all the non-Jews to move out from this section.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They fenced this off.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They closed it up completely, and it was only a few blocks from the city.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And they-- there was very, very little room for everybody to get an apartment.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "For us, personally, change-- it was a big change, because we had a large apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And we had to let in some relatives and friends into the apartment, because the people living outside, when they came in, they had to have room to stay.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "So in one-- in the one room, you could have as many as three or four families living in one apartment.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "You could have five or six or seven families living.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "It was very, very crowded.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "There was no privacy.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "The kitchen had to be used by everybody, and conditions were very, very bad.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In my-- in our apartment, as I recall, was about, I would say 12 or 15 people.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We had four rooms, four-room apartment with kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So actually, it was five rooms.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But it was very, very crowded.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Conditions were bad, because the food was rationed.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "There was very little of it.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "The Nazis created some shops, factories, where all the work had to be performed for the Nazis.",
      "word_count": 17
    }
  ],
