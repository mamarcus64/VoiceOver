{
  "stem": "14737.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "There was nowhere to work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And that's how people lived there for centuries and so on.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Actually--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, now, my father's name was Jacob Schwimmer.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My father was also born, not in Dolha, nearby, a few kilometer, by a place where they call it [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It's on the map.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And my father lived there almost-- when he married my mother-- since he was 24 and lived all those years.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "My mother's name was Grunwald, Celia.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She was also from the nearby town.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "As far as our family is concerned, we had-- my mother had more children, but only five have survived.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I mean, there were sicknesses and illnesses over there.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "People used to have eight and ten children.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "If four or five survived, it was very good.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So we were five children.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I had a sister.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "My older sister, Helene was born in 1908.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Then I had a brother, Abraham, was born in 1910.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Then I came in 1915.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Then I have another brother, which is [?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Moshe, ?] which was born in 1918, and another sister which was born in 1919.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Her name is, was Dvora.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Now, from the entire family, from ours, only the three brothers remained alive.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "One of my brother died recently.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "My older sister, Helene, who was married and had two children, perished in the Holocaust in Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "She was married to a man by the name of Weinberger in Beregsaz.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "She was about 36, 37 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "She had a boy of about 13 and a girl about seven or eight.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Entire family perished in Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "No one survived.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "Her husband was working in Auschwitz and later on in Wolfsburg.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "But also, he didn't survive, so completely the entire family.",
      "word_count": 10
    }
  ],
