{
  "stem": "3848.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "The station manager never saw so many people on the station.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "He called the police.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "We were arrested-- taken to jail.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "They wanted to send us back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And we claimed that we were Greeks.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "We had our documents already taken out and prepared.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "We didn't know the Greek language so we spoke Hebrew.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And the police arrested us-- we were in jail.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "But we asked to see a representative from the Jewish organization [INAUDIBLE] in Czechoslovakia, and they worked to let us out.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And they told them that we were not staying in Czechoslovakia, that we were going to Bratislava, and we were getting into Austria, from there Germany, and so on.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "So finally they let us go, and we managed to come to Bratislava.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "From Bratislava, we went to the border of Czechoslovakia and Austria.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "We had a group of 200 people.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "The documents-- we had the release from the Czechoslovakian government only for 20 people to let out-- to cross the border.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "But the Bricha made it out of 20-- they made 200.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "They paid off the guards on the Czechoslovakian side with American cigarettes.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "But the didn't look too close.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "They let 200 through.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "But on the other side of the border it was the Russian part of Vienna, and we had to face the Russian soldiers.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "It wasn't easy for me to see them again, because I just left Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "Here they had the Russian zone of Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "That's where we got in.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "And I didn't talk to them.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "And they were also shown the 200, the name-- 200 names, 200 people.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "Actually it was 20.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "So they gave them vodka, and they let us through into Vienna.",
      "word_count": 12
    }
  ],
