{
  "stem": "22047.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And at the same-- near the same time that I was married to my first wife, she married Richard, Dick, Cosgrove, Thomas Richard Cosgrove.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And she-- she went to Van Nuys High School.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She's three years younger than I am.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Went to Van Nuys High School.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "She was there at the same time I was, just before I graduated and went on to UCLA.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "She really, again, was a housewife.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Did some-- some jobs.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "She was a sales person at a-- in a department store, I think, in Van Nuys.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "But in the-- in the main, she-- she was-- took care of the home, and her husband painted all over Southern California.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, quite close.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We have drifted apart in our later years.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Of course, she lives there, and-- she lives now in-- in Tehachapi.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They bought a house in Tehachapi, so she lives there.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "She lived in, and her husband lived in, Woodland Hills, not too far from my parents for a number of years, [BACKGROUND NOISE] until my father moved to Canoga Park.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And like I said, she's-- she's now 69 and waiting for the big 7-0.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Very much.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I-- I really enjoyed school.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] When we moved to-- moved to Santa Barbara, moved there in 1929, and I started grammar school in the first grade at a-- at a school called Roosevelt, Roosevelt Grammar School, Elementary School.",
      "word_count": 37
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Went through grammar school there and then went to La Cumbre Junior High School.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "We had moved from the-- the original house we lived in on Panchita Place in Santa Barbara-- no, I'm sorry, Sola Street, in Santa Barbara, to Panchita Place, and then to Anapamu, which was right across the street from the high school.",
      "word_count": 42
    }
  ],
