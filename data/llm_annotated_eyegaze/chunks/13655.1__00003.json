{
  "stem": "13655.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was all kind, like in any other small city, small towns.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It was all kinds.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there was a nice beautiful synagogue, very-- a nice one.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Very-- And there was a big [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It was a few [INAUDIBLE] went they went to daven.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "The rabbis I remember is-- his name was [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I was-- in a few of-- mixed.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They-- [INAUDIBLE] The rabbi was not a teacher for the children.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "[SPEAKING IN YIDDISH]",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They came in for the-- they went separate, but-- but [SPEAKING YIDDISH].",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was also they went, but separate.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "All the holidays was favorite, because was-- everything was-- Pesach was the most popular holiday.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But together, by the Seder, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Mamaloshen.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "All of them.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Was not so bad, but was no good.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They was-- one thing of the Jews, Yiddish, this and that.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "But it was not too bad.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Anti-Semitic was at that time also.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "In my-- in my hometown even, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Very small.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "One bedroom, one living room, and one kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We used to sleep two, three people in one bed.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Not far away.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "About half a block.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It was a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I went to the Polish school.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Seven grades.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] [INAUDIBLE], Polish [INAUDIBLE] School, and then I went to cheder.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And I went to a private teacher for writing and reading Yiddish.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And the [INAUDIBLE]-- And this was--",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We had to help the parents to make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't do any other things.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "We got this-- after the bar mitzvah, I had to help out already.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "It was a-- a very poor bar mitzvah.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I went to the [INAUDIBLE] to the Sefer Torah, to make the barucha, and say the haftarah.",
      "word_count": 17
    }
  ],
