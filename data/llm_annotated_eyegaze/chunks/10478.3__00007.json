{
  "stem": "10478.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.8,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Political prisoners.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "You are not allowed to go out of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Like the people who were there to work in Germany, they were allowed to go to work outside of the concentration camp.",
      "word_count": 22
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "We were not allowed.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "About 4,000 or 5,000 prisoners were there, you know, in barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, there was only that kind.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Some-- some black-- who were involved in the black market, we ran into sometimes, yeah.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I saw a few Jews, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, when the [?",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "ATF ?] suspected you, that you was a Jew, you have to undress yourself, and they will see if you are circumcised, yes or no.",
      "word_count": 25
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And they found a couple of guys.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And they had a very, very hard time, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Very hard time, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I saw one guy, and he had to go and stand in front for the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And loaded a heavy gun on his arms, and had to make bending knees all the time.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "But he fell down.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "He couldn't do it anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Well, they brought him to his cell, and then they brought him to another camp.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "If they-- if they-- they were suspicions, you know, then they-- then they hit-- they hit you quite a bit if there was a Jew, yeah.",
      "word_count": 26
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I think that the food was terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "It was more water than food.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And lots of people had dysentery there.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "We got only a little piece of bread.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And you had to live on it that for [INAUDIBLE] the whole day.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "So it was [? everybody ?] was [? hungry. ?] A bad time there, yeah.",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We lived in barracks, in bunk-beds.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "You know, three-- three on top of each other, to [? them-- ?]",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Triple bunk-bed.",
      "word_count": 2
    }
  ],
