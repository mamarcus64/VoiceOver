{
  "stem": "2373.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I forgot the name of the hotel.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "It doesn't exist anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "But that was so terribly expensive.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't-- we couldn't afford that.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "So we-- we went around.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And we found a room.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "He-- he was straight away-- engineers were in such a big demand.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "But anyhow, he didn't work.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Neither could I.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "He didn't work as an engineer.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "He worked as a draftsman.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "He got a job straight away.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And I-- [LAUGHS] I got a job as a machinist.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "In a clothing company-- shirts-- men's shirts.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And after a few unsuccessful attempts, I finally learned how to-- how to work on the machine and how to-- and I was a machinist for nearly seven years.",
      "word_count": 29
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Many companies, [LAUGHS] I-- because they-- they were sending me away.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't very good.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I sew-- not shirts, only part of shirts.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "On one place, I only did the cuffs.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "On the other place, I only did that.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "But gradually, l learned the trade.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And then I-- and then I ended up in a factory where I did skirts-- whole skirts.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And I was so good in it that I worked in piece work.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And I made five skirts in one hour.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "The boss said I am the quickest skirt machinist in Sydney.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Well, that--",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I worked there for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "It doesn't exist anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "It became Suit Master.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "But when-- when I worked there, it had a different name.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "It doesn't exist anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We arrived in '50.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Until '57 I worked as a machinist.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Well, in between I had three miscarriages, and so a little bit off work, on work.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And-- and then I thought, that's enough.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And I started.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "I looked for office work.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I got a job.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And I studied at night.",
      "word_count": 5
    }
  ],
