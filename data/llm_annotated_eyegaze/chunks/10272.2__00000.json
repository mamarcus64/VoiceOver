{
  "stem": "10272.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "In Chust, Chust.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Ah, [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So a junior high--",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Secular school.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Very, very well.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No--",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "There was no incident in-- no incidents in school.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "But outside of the school, when I came home-- at that time, even before this crisis of, of Munich in 1938-- it started already in 1934, after Hitler came to power.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I noticed, when I went to visit my grandma, which is in Terebla-- she lived with my-- with my sister.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They were under a-- also a grocery and a [PAUSES FOR 3 SECONDS] drinking-- serving drinking for people there, alcohol, wine.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "When I was on my bike-- I was riding there.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "When I came to that village inn.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "In our town, Bustino, I didn't hear no, no, not-- at that time, I came, and they-- I was there as a Jew.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "I, I dressed as a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I looked like a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "The kids would run from their houses to the-- to the fence and see who is passing by-- oh!",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And they start screaming at me and throwing stones and rocks on me and slur-- Jewish slurs, like, Jew, go to Palestine, and all kind of slurs-- 'dirty Jew.' I would hear already at that time from 1935, 1936, 1937, 1938.",
      "word_count": 41
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "But in our school, we were only Czech, Czech people.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "In this area was many ethnic groups where I was part of that area.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "There were Ruthenians, Hungarians, Czechs, and also Romanians, and Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I went to a Jewish Czech school.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "There were also Hungarian schools and the Ruthenian schools.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Many Jewish people entered other schools.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "There were-- all schools acknowledged by the government, Czech government, as legal schools for education.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But my father sent me to a Czech school.",
      "word_count": 9
    }
  ],
