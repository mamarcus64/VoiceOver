{
  "stem": "7777.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "When I was in the freedom, I went to meal over there what I work-- fish to give me something to eat.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And later he gave me a little bit flour to have what to eat, and you go home.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "Going back from over there-- because we lived over there-- is going back from over there, is a guy for register for the military.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "He asked me my name.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "He read out my name, and he had tell me to come to the place to register for the military.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "I know I cannot walk on my legs, laying in this bunker so long.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "And I was thinking probably they will not take me to military.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "I'm not-- was a Jewish doctor what he was before working for the Russian.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "Even with the Russian, and he works in this [NON-ENGLISH] in the military.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "I ask him, Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "[NON-ENGLISH], I cannot go to the military.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "He said, you will go.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "We will send you in a hospital for six weeks, and later you will go.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "I didn't want to go fight.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "Is I have a cousin from-- my sister-in-law has a cousin.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "He worked for the train.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "And when the Russian went, he went with them.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "And he come back.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "He took people for work by the train.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "He was trying to take in people and to send them to work.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "I go down to him, saying [NON-ENGLISH], they call it.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "And I tell him the story.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "He said, we have to send people what they can't find the German.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 48,
      "text": "You the guy-- whether you can fire against the German.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "We need you to the military.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 50,
      "text": "He was a communist, and he was working for the Russian government.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 51,
      "text": "I say, Chul, you know, I'm one left.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 52,
      "text": "Nobody in the family.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 53,
      "text": "Nobody.",
      "word_count": 1
    }
  ],
