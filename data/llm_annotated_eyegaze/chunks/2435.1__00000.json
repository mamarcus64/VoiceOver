  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Interview held on May 9, 1995 with survivor Eva Bergmann, born Reiche.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The interviewer is Barbara Traub.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And the interview takes place in Jamaica New York, United States of America.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And the language is in English.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "This is an interview held on May 9, 1995 with survivor Eva Bergmann Reiche.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And the interviewer is Barbara Traub, and it takes place in Jamaica, New York, United States of America.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "The language is in English.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Berlin on November 16, 1916, in Berlin, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Reiche.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I had a brother who was a little older than I.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He was two years older.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Was Hans.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father in Berlin was a theoretical physicist.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He worked with many quite famous physicists like Professor Lauer, Professor Ladenberg, Professor Einstein, and as a main physicist was also Professor Planck, Max Planck, who was the founder of the quantum theory.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He worked for many years there until 1923 when we moved to Breslau because my father got a position there as a professor at the university.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My mother actually didn't have any job in Berlin.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "She was a housekeeper, although we had a maid, and we had a cook.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And she had [NON-ENGLISH] where she met every week with some other friends.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And they had coffee and tea.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And they were talking.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And she went even swimming in summer into a very nice pool in Berlin.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And she was-- we were very happy in Berlin.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The original address where I was born, yes, was Friedrich Wilhelmstrasse number eight in Berlin.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But I did not immigrate from that address.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Much later on, I immigrated in '41 from a different.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, I couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I would not know anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    }
  ],
