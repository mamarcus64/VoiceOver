{
  "stem": "14002.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 55,
      "text": "I don't remember that they even gave us any provisions, on the way, till we came to Czechoslovakia.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 56,
      "text": "But Czechoslovakia, they dropped us off.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 57,
      "text": "I think it was a monastery, because I've seen nuns over there.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 58,
      "text": "On my luck, I came right after they finished lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 59,
      "text": "[PAUSES FOR 3 SECONDS] I came over there, I could hardly walk.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 60,
      "text": "I was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 61,
      "text": "I came over there, and the nun says to me, we don't have no more food.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 62,
      "text": "I'm sorry, you came after lunch.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 63,
      "text": "But I think I got a-- something.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 64,
      "text": "She came out and gave me something to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 65,
      "text": "I've seen that I don't have anybody here.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 66,
      "text": "I don't know the city.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 67,
      "text": "I don't know nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 68,
      "text": "[PAUSES FOR 3 SECONDS] I went to the station, to the railroad station.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 69,
      "text": "Of course, I don't have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 70,
      "text": "I'll be honest.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 71,
      "text": "I begged for food.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 72,
      "text": "Came to the station, I took the train.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 73,
      "text": "I knew I have to go east to my hometown.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 74,
      "text": "I came to a city in Slovakia.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The name?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "What was the name?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Bratislava.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I think it calls, what, Pressburg in Yiddish.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I came there.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I found over there people from our town in Bratislava.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And he told me-- that was the person what told me about my brother, that my brother is alive.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "This is how I knew that my brother is alive.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "From Bratislava I made myself, little by little, to Budapest.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And from Budapest, I made myself all the way up to our town.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Of course, sometimes, I had to ride on top of the train, because there was no room inside.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "There was no such a thing as buying tickets or anything.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Just, you go on the train and-- and you ride, till I came to our town.",
      "word_count": 16
    }
  ],
