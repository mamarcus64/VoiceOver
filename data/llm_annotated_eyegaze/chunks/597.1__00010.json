{
  "stem": "597.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "We used to go-- you had to go bring the water from the-- from the-- they had a pump-- water pump.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 20,
      "text": "I used to go with a pail, and pump water, and bring it in the house.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 21,
      "text": "This was not easy-- like here.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 22,
      "text": "Here is easy in life-- and do the things.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 23,
      "text": "And you had to scrape the floors.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 24,
      "text": "I helped my-- me and my-- little girls, we has to start scrubbing, cleaning, and washing, and washing the dishes, helping out mother.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 25,
      "text": "Mother used to go and help my father to make a living.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 26,
      "text": "That was my daily work every day.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I went to the religious school.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And it was kindergarten.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I started right away in the-- in the beginning, when I was five years old-- for religious school.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And then I went private-- to religious school after school.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Learned.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "[HEBREW] We went to learn all the-- the Jewish prayers.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "In fact, I'm-- when I'm going-- if I go to synagogue here, I pray.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I know every-- all-- all the prayers.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And that was taught by me by my rabbi, you know, in-- in the-- in my town.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "We had a yeshiva, too, in our town, a big yeshiva.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "You know a yeshiva.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "What will-- this yeshiva have-- Jewish house of learning.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "All boys are going there.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "Girls didn't go there-- only boys.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "Boys used to come in from the different towns.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And they didn't have-- we used to station him-- each family used to take a boy for eat-- to eat, because they didn't ever have like, a boarding house.",
      "word_count": 29
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So the families used to take him by day, every day in a different-- different house to eat supper, or eat a lunch, or the breakfast, whatever it is.",
      "word_count": 29
    }
  ],
