    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we were uncovered towards the end.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They found us towards the end.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Although the resistance went on for months after, but when the ghetto was burning.",
