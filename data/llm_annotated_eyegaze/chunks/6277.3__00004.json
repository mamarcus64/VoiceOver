{
  "stem": "6277.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And then they would help the German-Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "Especially-- especially the first time, when they arrived.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "A lot of support.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "There were a-- there were a-- in to ghetto was an [NON-ENGLISH], they called it.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It was people from the Jewish people who would organize a job, where you go to work-- workplace you-- you go.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There were-- two of them were working there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And there was-- the-- the elder of the-- of the-- of the-- of the small ghetto, the elder of the small ghetto was [?",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Max ?] [INAUDIBLE], [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He was a German refugee in Riga.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He came to Riga before the war began, as a refugee.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And he became the head of the Riga ghetto, the elder of the Riga-- of the small ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And during-- during the killing of the police, of the Latvian police, of the inside Latvian-Jewish police, he played not a very nice role.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And people were-- were suspicious.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And he participated in that case.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And before the ghetto was liquidated, the small ghetto, he was found killed in a cellar.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "It was the end of him.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I stayed in the ghetto till-- till beginning of the summer of 1943.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And then we were sent for the peat bogs, to [INAUDIBLE], our group.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "There were different-- we did different parts of Latvia, that people from the ghetto were sent.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "We were sent to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "They were a small group, about 50 people.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And we would work there.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Hard work.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "But it was better than in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And we were-- the whole summer we were there.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And then as part of us, they took to the farm to dig potatoes and other stuff.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And we where there till September, or end of September, not-- till September, September 1943.",
      "word_count": 15
    }
  ],
