{
  "stem": "25027.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 6 SECONDS] I have the original ticket for the ship [PAUSES FOR 3 SECONDS] that brought me here.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "It was the second Navy ship, [?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "Marite ?] Perch, that brought me to this country.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Bremenhofen.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was May 9th-- May 10th, 1946.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "She went, she applied-- she said I had relatives in the States.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She applied for the visa.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "The HIAS gave me-- got the visa for me.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] They found the tickets that were still outstanding, that my grandfather bought before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I was given one of them, and the other three I told them, give them away to whoever.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And on May 24th, we arrived in New York Harbor.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I didn't get off until May 26th, which was my birthday.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And that's practically the end of the story.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "A beginning.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "A new life.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "21 Years of age, and I was alone.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Most of the passengers who came off the boat had somebody.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I knew I had somebody, but I wasn't sure where.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I had the address of Mr. and Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Weiss.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "There were a few of us that were all single men or single women.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The HIAS came over to us, and they asked us, do we have anybody helping us, picking us up?",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I said, no, not that I know of.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And they brought us down to 103rd Street and Broadway to the Hotel Marseilles.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And that night they made a party for us.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Some elderly Jewish ladies came, with all makeup, [LAUGHS] in their hats and their high heels, and all [YIDDISH], all dressed up.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And one of them shoves a cake-- a chocolate cake-- in my hands.",
      "word_count": 13
    }
  ],
