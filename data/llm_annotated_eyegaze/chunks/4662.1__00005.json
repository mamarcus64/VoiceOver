{
  "stem": "4662.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "That was about 20 minutes.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "After I studied to be a hairdresser, I got married.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "I went to-- my, my grandparents lived in Antwerp.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And my mother said, you have to go and see your grandparents.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "They're getting older.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "I never did want to go to, to see them.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know them.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I saw them once or twice when I was little, because they went to live in South Africa.",
      "word_count": 19
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "But when they came back from South Africa, they lived in Antwerp again.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Diamonds.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather was in the diamond business.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "Diamond cutter, diamonds-- everything in diamonds, anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Johannesburg.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "I still have family there.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Your parents, though, never moved there.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "We went there.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "We went there--",
      "word_count": 3
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "--once.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "That was when I was about-- you see that photo, the photo there?",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "I was about-- I was about three years old.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "That must have been a very long journey.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was in those days, I suppose.",
      "word_count": 8
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "I didn't notice it, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "It was-- you know, every kid is pleased with thinking, of liking to go to another country.",
      "word_count": 17
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "I was about 18, 19.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "I took my youngest brother with me, because I wasn't allowed to travel alone.",
      "word_count": 14
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I met my husband, we were in Antwerp to see my grandparents.",
      "word_count": 14
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "And my cousin was engaged to Louis' brother.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "So she said, you know, I have to go Friday evening to my parents-in-law for dinner.",
      "word_count": 16
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "And what are you going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "And she said, I would like you to go with me.",
      "word_count": 11
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 5,
      "text": "I said, I'll go with you.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "So I went with her to see her parents at dinner, and I saw Louis coming out of a shoemaker shop.",
      "word_count": 21
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "So she said, oh that's my fiance's brother.",
      "word_count": 8
    }
  ],
