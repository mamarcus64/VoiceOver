{
  "stem": "16792.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 289.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "Lodz is a-- is one of the largest cities in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "The first city, the biggest, is Warsaw, and the second city is Lodz.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And Lodz is very, very big manufacturers.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "I was going down there to buy merchandise.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "Then I told my [INAUDIBLE], I told him we must hire somebody else, additional person, which he did.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "I got good paid, very good paid.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "See-- Especially religious people was more tempt for-- for-- for this particular part.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You have got people in Poland which didn't very pious.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Only the religious people did.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And the Poles was starting with this type of people which they are religious.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "They threw stones-- stones for the Jewish schools.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They break windows in the Jewish schools.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "They break windows-- a lot of time, they broke windows in our house.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "This is anti-Semitism, and this particular anti-Semitism is-- is bring up by the parents from the children.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "The children didn't even-- the Polish children didn't even know what they're doing because the parents told them to do it.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "This is the way it was, a problem in Poland, a big problem.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And Poland was 3 and 1/2 million Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "It was a lot of Jews, and we got-- every city has got their own Jewish congregations, big congregations, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Like a mayor from the city, but he's not a mayor, but he is a mayor from the Jewish part, which the Jewish part help people.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Before Poland was invaded, I was in Krynica, a city like Palm Springs here.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I left Scoczilas, the business.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "It was too much for me.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I remember when I was young, my grandfather took me to-- I was seven, eight years old, nine years old.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Every year they took me for vacation with him.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He liked me very much.",
      "word_count": 5
    }
  ],
