{
  "stem": "9215.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "But then, all of a sudden, I remembered, it was on a Saturday night.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And we hear, like, we talked-- I think it was thundering, or something.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I said, my God, it was a beautiful day.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "How come all of a sudden?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Then, after another, another, another, and then, the neighbors, we came outside.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And it wasn't thundering.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "It was the German.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "The German-- how you say?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Start on the Russian, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "They attack the Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "The Russian didn't-- they didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "They didn't expect it.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And that's the way start the war.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "Right before the-- the war started, can you tell me what was going on in your-- with your family?",
      "word_count": 19
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "Were you-- were you still in school?",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "Were you working?",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "When I finished school, the seven grades, I went-- I went to learn for dressmaking.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "There was a-- a-- a Jewish lady.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I went to her.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Rachel.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "She's in Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "She's in Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "She left before the war.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "She's in--",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "After when I finished the seven grades, I went to her.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I learned.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "She learned.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "She taught me how to do, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "My mother told me I had to go to learn.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I got to help, to give us, to help something in house.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I give my mama.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Whatever we made, I give my mama a few zlotys.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "She needed.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "It was six children.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "She didn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "What can I say?",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "She suffered plenty.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I remember lots of times, a lots of time.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I remember one night, she didn't get supper for us.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "She didn't get.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And then, we been sitting, she says, you know, I'm going outside.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I'll be right back.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She went.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "I don't know where she went.",
      "word_count": 6
    }
  ],
