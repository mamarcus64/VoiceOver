  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I'm in this-- of Lwow.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Nowhere a hotel or a motel where to go to sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But OK, from the farmers what give me a piece of bread.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Till I came, I have a piece of bread.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Then-- then I see where to sleep at night.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Then I see a jail.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Then I go in the jail.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And I tell, listen, they ask me who I are.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I tell them, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I am from the city of Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "They tell, OK, the jail is open.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "You have a mattress.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "You can sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I sleep over and after there, I need work.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "Then working in the-- in the city, I see street cars.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "I put this together.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "I go there where the shops and the street cars is, and I come there and I tell, listen, I am a mechanic.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "I can work street cars, painting.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "Right away from the place, yes, you are in good luck.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And yes, and they give me right away.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "And they ask me, look at the ration already.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "If you need bread or other thing, come in the restaurant.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "You will eat to give you a few ruble.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And then I worked there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And after a few days, I decided to go back when I'm in civil already.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "More with energy to go back to Lodz to my wife.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "After all, I love my wife.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "She is kind.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "There are no [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Nothing divided us between border Russia and Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "You stay here.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We go to Lodz and we give everything what you ask, and you will bring-- we'll bring them over.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I don't like them, but they pushed me down from the train.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And they, listen, we are not workers on this.",
      "word_count": 9
    }
  ],
