  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And the two weeks I spent with them-- and we were constantly on the move-- there was sporadic fighting.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "So yes, I was aware of what was going on.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Mostly, we moved from place to place.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was rainy part of the year, and was very muddy and cold.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And it may have been the beginning of the end for the Germans, because they were really, at that point, moving around so much.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And the partisans had been harassing them so badly that it was almost like a constant movement.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "There was no-- we'd stop to eat or rest, but we weren't in one place for very long.",
      "word_count": 18
    }
  ],
