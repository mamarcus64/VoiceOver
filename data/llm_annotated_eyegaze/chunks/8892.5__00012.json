{
  "stem": "8892.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Last 25, 26 years, my husband was in a meat business working for his uncle.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And as the children was growing up, I was restless and I was kind of unsatisfied with life and all.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I'm going into business.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And he says, are you crazy?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I says, no, I'm not.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And my girlfriends were already in business in a drapery business, and one day we went out to [INAUDIBLE] visit them.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And he inform me that he wants to sell a business, and I said, I'm buying.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And my husband looked at it, what do you mean you're buying?",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "You don't know nothing about it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I says, I'll learn.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And which I did.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I went to work for four weeks for him.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "By that time, we already signed a deal.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Everything was done.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I went to my uncle-- I didn't have enough money-- borrowed money from him, and he was willing to give us.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And my husband says, what are you going to do?",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "I said, the kids are in school.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "They were already 13-- older.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "By the time I bought the business, my son was graduated from high school.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "He was ready to go to college, and he wanted to go to University of Michigan.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "That was his dream.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And that's that year we moved here, and I said to myself, how are we going to do it?",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "We can't afford that.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "And I begged him to stay in town.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "No, he was too good of a student, and he wanted to University of Michigan.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "So when this opportunity came on, I said, I'm going to buy.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "So I went into the store.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "It was Lincoln Park, at Sears Shopping Center, a drapery store.",
      "word_count": 11
    }
  ],
