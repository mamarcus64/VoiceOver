{
  "stem": "2581.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And then they started the beatings in the street and they started to take the people, grab people from the street to work.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And in my case, they took me to clean latrines by hand.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "You know, toilets to clean with the hands, not-- they didn't even give you a shovel.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "Everything was so shocking that you couldn't comprehend what was-- what was happening.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Nothing, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But everything started gradually.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Everything started gradually, because the goal was to dehumanize us.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Not humiliate.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Dehumanize.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Yes, that was their call.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "That was their purpose.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And I think in the long run, they did it to themselves, but we were the ones that suffered physically.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And this was the beginning.",
      "word_count": 5
    }
  ],
