  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "So anyway, [PAUSES FOR 5 SECONDS]",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "You know, I believe even now-- always I believed in fate.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "When you are born, it's written what will happen to your life.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I always believed that.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And you can do nothing against it.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "It was meant for me to survive, because I wasn't even in the city there in Budapest.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They didn't take people on the street that time to put them in ghettos and all those things.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "So anyway-- [PAUSES FOR 3 SECONDS] when I got the stroke, I believed in that, too.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "God had it for me that I should go through some more miseries here, too.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I went plenty in this country.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "You could say it's [NON-ENGLISH].",
      "word_count": 5
    }
  ],
