{
  "stem": "1917.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 381.0,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "It's like a golden globe surrounding us.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "It was like-- it was the most beautiful thing that I can remember.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "It was just like welcoming us.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "Many people got off the ship, kissed the ground crying.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "My uncle who was working in the port came up to us.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And actually, I don't remember him before he left, because we were just born.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And we hugged him and kissed him.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And he was very, very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "And he said, that he would visit us.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "We have to be in quarantine for a while.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "And he would meet with us when he can.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And we were taken-- my aunt and uncle were taken to a grown up quarentine.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "We were taken to [?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "Yusalia. ?] I didn't know what that was.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "But there were lots of children.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "And we were taken to a village named Magdiel near Ramat Gan near Kwasaba-- between Ramat Gan and Kwasaba.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "And the-- the first night we arrived there was a Friday.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "Well, everybody was going to the dining room with white-- gleaming white shirts.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "And we're saying the [NON-ENGLISH] and kiddush with the wine, and singing all kind of Israeli songs.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "And it was absolutely-- I couldn't believe that there was that many Jewish people in one place.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "That night after the Shabbat services and the dinner, we all went to a big, huge hall where everybody was dancing all kind of Israeli dances.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "Two girls were assigned to us to kind of teach us how to dance and start.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 36,
      "text": "And it-- it was I was in [?",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 37,
      "text": "Yusalia ?] for two years.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 38,
      "text": "And I can honestly say that it was the only two years that I had a childhood.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 39,
      "text": "I never feared going to sleep, or being called a dirty Jew, or worrying about anything.",
      "word_count": 16
    }
  ],
