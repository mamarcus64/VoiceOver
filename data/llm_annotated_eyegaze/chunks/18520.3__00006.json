{
  "stem": "18520.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But they [INAUDIBLE] at the end of the buildings, you know, no matter what-- always was filthy dirt from the people.",
      "word_count": 21
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "They-- they're screaming, and they're clawing.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "They see they're going to dead-- to die.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "So this is what we used to clean.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "You had this road-- the-- the-- the wagons on two wheels-- they did-- with one wheel.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "You lift it up, and the whole thing folds up, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "So we used to be close to this.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "We have the ashes stay out.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Ashes of people, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Used to fill up ashes they used to throw out.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "If I'm not-- they used to-- this was hidden, but they used to have-- I believe they used to have their people-- farmers-- coming in the back.",
      "word_count": 27
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "There was a ditch there lower down.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Over there was ashes galore.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "They didn't know where to put it.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "They tried to dig holes to dig it to cover this, but they used it for farms.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Fertilizer.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "But when you had the wagon with the ashes--",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "In the hole, in-- in a ditch, all the dirt around it.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Oh, quite a few people.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "A month, month and a half.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I went away.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I went away already.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I went away to the other camps.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Transferred to Dachau.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No, no, they-- they-- each time, when you stood in counting.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "They're counting.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Every morning.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "They count every morning-- who everybody's at work, the people that working that day.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "So this-- so they used to-- sometime every week or every two weeks-- asking for professionals-- who was a shoemaker, who was a barber, who was a everything, you know.",
      "word_count": 30
    }
  ],
