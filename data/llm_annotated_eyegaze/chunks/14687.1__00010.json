{
  "stem": "14687.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "We-- we.",
      "word_count": 2
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 2,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 3,
      "text": "They used to take, [NON-ENGLISH] Outside!",
      "word_count": 6
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 4,
      "text": "We used to go down.",
      "word_count": 5
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 5,
      "text": "And the waters of the toilets, you know, they used to go up, the German, and throw away the water, the dirty water on top of you.",
      "word_count": 27
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Wee, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the buckets full of--",
      "word_count": 5
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "The buckets of-- yeah, they used to throw.",
      "word_count": 8
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "And it was very hard in the train, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, on our people.",
      "word_count": 4
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "We used to come out from the truck--",
      "word_count": 8
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "From the train.",
      "word_count": 3
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "And they used to throw that water, dirty, on top of you.",
      "word_count": 12
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "Over you.",
      "word_count": 2
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 1,
      "text": "In the meantime, the young fellows, they used to bring the water--",
      "word_count": 12
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "--to put in the train.",
      "word_count": 5
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "They used to have a-- a barrel.",
      "word_count": 7
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 2,
      "text": "And these young fellows, Jewish fellows, they used to take up on the train--",
      "word_count": 14
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the drinking water.",
      "word_count": 4
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "No food.",
      "word_count": 2
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 1,
      "text": "I think-- I remember they put some watermelon.",
      "word_count": 8
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] I don't-- a piece of--",
      "word_count": 6
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "Dried things, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "And then we were there in the train.",
      "word_count": 8
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden, it start going, the train.",
      "word_count": 9
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 1,
      "text": "They-- we stop and the-- the every thing.",
      "word_count": 8
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 2,
      "text": "Like, [INAUDIBLE], we stop.",
      "word_count": 4
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know where we stop in any case.",
      "word_count": 10
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 4,
      "text": "There were Red Cross.",
      "word_count": 4
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "They used to bring plenty food, never gave us nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 1,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 2,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 3,
      "text": "So the people, they were throwing things-- little apples, a piece of bread.",
      "word_count": 13
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 4,
      "text": "Never mind, they gave us bread.",
      "word_count": 6
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 5,
      "text": "Who was throwing that?",
      "word_count": 4
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "The people that were there.",
      "word_count": 5
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 1,
      "text": "Maybe they-- the civilians from countries which we used to pass.",
      "word_count": 11
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "They used to throw it in the train.",
      "word_count": 8
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, with the thing.",
      "word_count": 4
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 2,
      "text": "And the bread, inside there were little knives, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "To cut the wood, to escape.",
      "word_count": 6
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 1,
      "text": "But we didn't know nothing-- how can you leave?",
      "word_count": 9
    }
  ],
