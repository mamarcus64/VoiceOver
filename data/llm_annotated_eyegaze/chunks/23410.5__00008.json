    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In the death brigade.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And he always sang 'La Donna E Mobile' to them.",
