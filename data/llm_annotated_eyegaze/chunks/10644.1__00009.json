  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "Kapinski, ?] who knew more about religion, put her hand down, and we left, and he told her that a rabbi will never give a hand to a woman.",
      "word_count": 29
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "He didn't give us any suggestions.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "I made many suggestions.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Nevertheless, maybe indirect, nevertheless, in Jewish hospital, one died.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "We can-- we-- we-- we got this-- this body, and we had a body to-- but we didn't have-- so we needed at least, four or five bodies, you know, but it is with only one body, so 20 some, one would section the arms, the other with the-- the-- the legs, and the other the bowels, and the other--",
      "word_count": 60
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Finished, you brought back, you know, brought back to a burial.",
      "word_count": 11
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "To a Jewish burial.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was-- I was accepted.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "I was not accepted-- I was called to go for one year to the Polish army, after I graduated from medical school.",
      "word_count": 22
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "1933.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was, you know, [INAUDIBLE] pleased.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "I would-- I like to go straight, you know, in-- into my profession.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "But if I had to go for one year to the army, I went to the army.",
      "word_count": 17
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "It was in-- in-- in-- in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "It was a special medical-- military medical school for professional doctor-- for professional military doctors, and-- and we were all a part of this for only [PAUSES FOR 3 SECONDS] when we were called to duty.",
      "word_count": 36
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "We-- we went--",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I was happier in the school, medical school, this military medical school, where we-- we had a-- from one side, simple medical-- simple military education.",
      "word_count": 25
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "And the-- and the-- besides we had lectures on military medicine.",
      "word_count": 11
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the students were already-- we were-- Jews were already only around 10 in 120.",
      "word_count": 15
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Something-- we have to stop?",
      "word_count": 5
    }
  ],
