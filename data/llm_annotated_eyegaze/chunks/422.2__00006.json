{
  "stem": "422.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "In 1938, shortly before the war broke out, he bought an expensive radio.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "At that time, it was, for a tailor, too much money to spend.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "My mother was arguing with him.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "She wanted to spend the money for clothes and for shoes for the children.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "But he set his mind.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "It was a German name, Telefunken.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "The first invention of talking radios.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Before, we were listening on the ear phones.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "This was the first one that could speak aloud.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And this was that time 600 zlotys.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "It's like $600.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And my mother said, no.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "We cannot afford to do this.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "But he bought-- he bought it on installments.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And-- and we had it only for one year.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "It was a beautiful, big cabinet.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "We could hear auditions from the-- from all Europe, from all the countries.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "We had a lot of enjoyment listening to this-- to this radio.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "But then Hitler came out in-- came in in September, 1939.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "We had to give up everything to the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "Fur coats, radios, jewelry, money.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "Everything all of a sudden became their property.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So my father-- we had to pay-- we paid up already the radio.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We had to pay one more installment.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And my father said, I won't give them this radio.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But he couldn't hide it either.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "It was a big cabinet.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "So my mother came up with an idea to take the radio down to the basement and to chop it up in small pieces and let it go down in the drain in the sewer.",
      "word_count": 35
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "That's what we did.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And we all started crying.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We loved that radio so much.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We had so much enjoyment.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And all of a sudden, my father stays with an ax.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I still can see it, the way he chops the radio.",
      "word_count": 11
    }
  ],
