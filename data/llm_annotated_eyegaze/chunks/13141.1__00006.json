{
  "stem": "13141.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And that company was-- [PAUSES FOR 5 SECONDS] had to be sold to, to Christians because Jews-- they gave them a certain amount of time to get rid of their businesses.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Of course, all of those businesses were sold under, under pressure.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And the owners got relatively very little money on account of this.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So that business, when it was taken over, well, I was thrown out there, too.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No, '36--",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "--out of the gymnasium.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Then I went as an apprentice in-- I went to Czechoslovakia.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I came back to my grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I went to the [GERMAN] as an apprentice.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Then I was thrown out of [GERMAN], the, the dress factory.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to a, a men's garment factory, Gebruder [GERMAN], in Stuttgart, also.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They made men's suits and coats in the Paulinenstrasse, Paulinen Street.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And there again, after a very few months, that was when the limit came.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I mean, you had to sell your business now.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "They just sold their business at the last moment.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "They got very little for it.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And then I was thrown out, too.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "So there was no possibility anymore for Jews to work anyplace or to go to school.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The only possibility then was to become a construction worker.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And I became a plasterer, [PAUSES FOR 4 SECONDS] working with gentile people who have been plasterers all their, their lives.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And it was on the-- on that little suburb of Stuttgart, in Feuerbach.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "The company's name was, was A.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH] and Company.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And there I worked inside buildings, building factories, outside the buildings, [PAUSES FOR 3 SECONDS] helping to paint the buildings, too, sometimes.",
      "word_count": 22
    }
  ],
