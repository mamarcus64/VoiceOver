{
  "stem": "9215.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The men used to daven, pray, every day.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "If they didn't went to the synagogue, they used to daven in home, with the [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "But the ladies, not everybody from the ladies went to the synagogue Shabbos.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "But my mother went.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So do I.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So do I.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Oh, come on.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "You know, I remember my mother, for Passover, in the table, she-- she made [NON-ENGLISH] a special, a cover, a--",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "A [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "A cover, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "On the-- on the table.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She used to scrape the table, and wash and this.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And then, after this, she put a, you know, like a what you call it?",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "A cover, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And I used to say, Mama, you washed the table and everything, and what you need this?",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I say, don't ask me questions.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "You're too little to ask me.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "You don't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And then she used to have, every Passover, a tablecloth, she didn't use for all year, only for Passover.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And even the chairs, she used to cover with this.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I said, Mama, we only sit at the chair.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "We don't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Don't ask me questions.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "Sometime, you kids, you put on a piece of matzoh, piece of this.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "Supposed to be covered.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "This was my Mama.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "This is, she got glasses only for dairy and for non-dairy.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "[LAUGHS] [INAUDIBLE] it's a lot to talk about this.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "This, [INAUDIBLE] not only my mama, my grandmother and every-- the whole family was like this.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Like here, same thing.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "My mother used to go, but not, we were children.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "But I remember, I used to go with my sister on Rosh Hashanah, you know what it means?",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "To hear the shofar [? blow ?] on Rosh Hashanah.",
      "word_count": 10
    }
  ],
