{
  "stem": "21004.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So-- and we were-- so the two Jewish boys we found, they say maybe if you wanted, you can sleep by us.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We have a big house.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You could sleep by us.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And they allowed the storekeepers to keep open.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They told them, keep open selling whatever you used to sell with Polish zlotys.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "You can sell everything from the store.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So we now bought new clothes, bought valises, bought new clothes, shoes, everything, everything from up to bottom.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Money we had, so we put in packed up full valises with clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And we had a good time, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "By Jews, we sleep there.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "We went out.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "Until after five days, I came to Lemberg.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "Other ones went in different directions.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "One of my friends is still someplace.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "He's in New Jersey, Feiler.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "He is still in New Jersey.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "I met him in Bad Reichenhall and then I met him also once here.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And to go back.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So I came to Lemberg.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And from Lemberg I went to Jaworow.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to see my grandma was yet in [POLAND], and my uncles.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "By then, I didn't want to stay in the village, so I went to Jaworow.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I had friends there, so I stayed in Jaworow.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They were in Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They were in Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They stayed in Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But they sent out my both brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "They send away before the Germans come, because they were-- first they were taken the boys, the men to work or hard labor camp or whatever.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So my mother send away-- send away the two brothers of mine.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And they came-- one came to a village in [POLAND], what he was working there by the Russians.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And one brother was in Jaworow.",
      "word_count": 6
    }
  ],
