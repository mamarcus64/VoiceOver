  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And she wrote a very good children's series, which we read all that.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And of course, we read It-- it's-- it was translated from German by--",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes, of course.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And Emil-- and there were-- that had a sentence-- Eric Kastner.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That had sentences.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But they have not mentioned anti-Semitism, or any-- or very little was said about rise of national socialism.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Well, there were not too many actually, available.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And the woman did not participate that much in religious serious as they do nowadays.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "The synagogue was still segregated.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And the men sit downstairs, and the woman sit upstairs and eating.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "It was preparing a food and preparing of Shabbas.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "It was the main occupation.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We had relatives and friends in Warsaw before the war, just much smaller than it is now.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And I enjoyed very much.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "It had a good Jewish theater, which actually came to Rowno with a very famous actress-- Ida Kaminska.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And they put many old Jewish plays.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "I also saw It's a very famous book by Ansky.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "The man written still in 19th century.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "Dybbuk means a person who is obsessed.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "That was made to a movie.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And I like it very much.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And it was scary, [LAUGHS] because it ends badly.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And we saw some movie even-- even a bit-- Molly Picon made here, but they were given in Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "Molly--",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "--Picon, P-I-C-O-N.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "It's in New York-- Atkins.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I saw her in life when I came to United States.",
