{
  "stem": "18575.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And they-- this was part of the Russian zone, the Soviet zone.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So we moved out and moved to a town, Germantown Lubec.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That's L-U-B-E-C.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And how long did you stay in Lubec?",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And in Lubec, we only stayed very short time, perhaps a week.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "When we next moved to Hamburg.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And in Hamburg, was already under British occupation, British control, British zone of occupation.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They already organized the British assembly place, or a thing for survivors, concentration camp survivors.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "We were assigned an apartment, two-room apartment in Hamburg.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "We were given a-- coupons for civilian clothing, for one suit, one pair of shoes, to German stores they had to issue.",
      "word_count": 22
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And we were out on our own.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "After we were in Hamburg for a while-- [CLEARS THROAT] [COUGHS] --we are in contact with the, with the Palestine, the Jewish Brigade, that was fighting for the British army.",
      "word_count": 30
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "With the British army.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They came in.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I register for aliyah to go to Palestine.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want to go back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "There was nothing there.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "I knew my family was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "It was no-- something that I go there and find somebody.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "There was nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Everyone I knew was murdered.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I registered to go to Palestine.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "At that time, it was through Cyprus, that the British diverted the, the thing.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But something crazy happened.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I was with the two boys, and we met a Jewish girl.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Her name was Nina-- N-I-N-A, last name a Rodznek, R-O-D-Z-N-E-K-- who was a survivor and she has very bad asthma.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And the doctor-- we took her to a doctor, and the doctor said, she must go to a drier climate, to a better-- to be able to breathe, because Hamburg is very moist-- it's a port.",
      "word_count": 36
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "It's right on the sea.",
      "word_count": 5
    }
  ],
