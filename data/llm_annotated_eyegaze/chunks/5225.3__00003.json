{
  "stem": "5225.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "We opened the window, or we going to close the window?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And one day we want to open the window, and he answer you can or you don't.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Nobody answer.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We call again, nobody answer.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "If you seeing this, people are running.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They're saying the war is over.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "So the war is over.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "We go down.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "We go down, and people said to me, it's stupid.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Where you going?",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Let's go to the basement.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "The basement, there's bread, and there's [NON-ENGLISH], and there's everything over there.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We go down-- there was really blocks of-- fat, so big, big blocks, bread and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And we take it, and we start eating, and instead of eat bread in butter, we eat butter in bread.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In the evening everybody's on typhus.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The Russian they liberated us, and we all in the hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Typhus, everybody got typhus.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "In Theresienstadt, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we was over there till the crisis-- a lot had died.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "A lot, a lot had died.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "When the crisis passed they start giving us goulash, three times a day, meat.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I can tell you maybe I weighed 90 pounds and when I got finished with a-- I was four weeks over there-- maybe I got 120, 130 already.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Had three times a day how much meat you want.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Just brought the kessel, they put it on the plate.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You want any more?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, give you more.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So you ate a lot?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[WHISTLES] So we want to go home.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He say you can go home.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So how can you go home without bringing something for your mother and for your father, something, a present?",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "You thought when you got home everybody would be there?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And that's the reason we didn't know.",
      "word_count": 7
    }
  ],
