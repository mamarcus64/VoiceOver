{
  "stem": "14928.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "At that time, a girl couldn't get married no matter what if you didn't have any money.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So he tried to save some money to-- so he could give dowries to the, to the daughters.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, I, I don't know what-- at that time, everybody was religious.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Now there's something that religious is separated.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My father was a very hard worker, went to shul twice a day to daven, left the boys working, and he went to shul in the morning.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He went to shul for mincha, maariv.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He never wore a suit.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He just wore the long, [NON-ENGLISH] or whatever you called it.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "A [NON-ENGLISH] during the week.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It was a, a lighter weight coat.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He never wore a shtreimel.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Shtreimel were not worn in our part of the country.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Shtreimel were, were, worn in Lemberg.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "In that part of the country, they wore shtreimel, and everybody wore it-- a taxi driver, everybody wore a shtreimel.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "In our part of the country, they did not.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They had-- it's called a [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I think that's what my father's wearing on the picture.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It's just a round, like a, cap.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember without a wig ever.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She always wore a wig.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "No, she didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My sister just wear, wore her own hair.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "She did not wear a wig.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was very, very religious.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We children, no matter how old we were, we played outside.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We have to be, had to be home Friday when the Tata came from davening to sit down and for dinner, the Shabbos dinner.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "My brother used to go with him to daven, but girls didn't.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't the style.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "So we could bum around, whatever, but we had to be in the house.",
      "word_count": 14
    }
  ],
