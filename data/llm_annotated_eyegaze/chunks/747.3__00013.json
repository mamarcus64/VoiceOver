  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 16,
      "text": "And we loved to-- loved to look at them.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 17,
      "text": "And then one day, there was no more song and no more soldier.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 18,
      "text": "So soon enough, we find out through the grapevine that one night, all 5,000 of them got sent into the crematorium.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 19,
      "text": "Nobody ever heard of them again.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 20,
      "text": "I wonder if the Nazis made a note or if they had anything left behind.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 21,
      "text": "But I think about it so often that these 5000 mothers were crying somewhere, never know that-- what happened to their sons.",
      "word_count": 22
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 22,
      "text": "I still-- I hear their singing in my ear.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 4 SECONDS] Unreal.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 6 SECONDS] Well, I should be fair to tell-- to tell you that it was at least 85% or 90% were Jewish inmates, but there were others.",
      "word_count": 29
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 25,
      "text": "I had a very good friend who was a German woman.",
      "word_count": 11
    }
  ],
