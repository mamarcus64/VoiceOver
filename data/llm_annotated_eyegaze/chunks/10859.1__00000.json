{
  "stem": "10859.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name-- do you want to know my name how which they used to call me in Europe?",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The original name when I was born, they used to call me Itzik.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "It would be I-T-Z-I-K, Itzik.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Gorenstein with a G, G-O-R-N-S-T-E-I-N, Gorenstein.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My birthday was January 3, 1916.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born-- it was not a city.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was a very small little village, a village I would say.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We only had about 100 families, 100 families maybe was with 500, 600 people with the children.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We lived--",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The name of the town was, in Jewish, they used to call us Lozisht.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It spells like L-O-Z-I-S-H-T, Lozisht in Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "In Polish, they used to call this Ignatowka.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It's similar like [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The Polish version, Ignatowka, would be I-G-N-A-T-O-W-K-A, Ignatowka.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It was in Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The names of my family member, my mother, her name was Rochel in Yiddish, Rochel.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And in English would be Rachel.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Weintrob, W-E-I-N-T-R-O-B, Weintrob.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Father, I don't remember my father.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Because my father died in 1918.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was only 2 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I really don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The irony is I never saw a picture of him, not in my house.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Until today, I never knew how he looked.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Because the true story is in the old country, Europe, before the war, and especially in small places, people never made pictures, never made pictures.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The oldest brother, his name was Moshe.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know him either.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Because he left for America when I maybe just was born.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Or maybe I wasn't even born.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I can not know these things.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He left to America probably the year 1918 or maybe in those times, whatever, or maybe in '17.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I never met him.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And he died in 1933.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I never met.",
      "word_count": 3
    }
  ],
