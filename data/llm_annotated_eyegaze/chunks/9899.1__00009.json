{
  "stem": "9899.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My mother took the jewelry, which the Germans had not found, and so did all her sisters.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Whoever was able to find some jewelry took it with them hidden in their undergarments, because we knew that this would be the only way we could survive.",
      "word_count": 28
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Barter had become the common way of getting to-- to food.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Money had absolutely no worth.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "In the ghettos, they gave Juden money to the people.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And you were only allowed to use that specific money that is only for the Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "Then during the day, if a Jewish family left the ghetto to walk, wander on the streets, and get away from that, we were not allowed to visit the parks.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "The Jews were not allowed to walk into the beautiful parks that were the pride of the city.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And there was a castle on a hill that belonged to a family Potocki.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And when my mother wanted to enter with the baby carriage, the [INAUDIBLE] nurse from the-- the servants of the Graf Potocki would refuse us entrance because we were Jews.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "It was not allowed to show up in the stores that sold butter, sugar, milk, or bread, white bread.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Those foods were not the staple of Jews.",
      "word_count": 8
    }
  ],
