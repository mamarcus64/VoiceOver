{
  "stem": "9230.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "They says they-- they would let them live.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "Her son lives in Israel, her only son.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, every few days, every few days.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, from all around Lodz.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "From [INAUDIBLE], from-- from-- all around.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Sure, if not, there wouldn't be nobody.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that's right, from the small town, all around.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They didn't change.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The only thing, what they take out people.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "No, but us, it was really something.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We got the apartment downstairs.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And when they make-- they-- they-- they-- it was still 5 o'clock was allowed to go out. 5 o'clock, everything was closed, and they came to pick people.",
      "word_count": 28
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Everybody has to go out and to stay in the line.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And the younger people they take this way and the older people, the children, in the oven, they got killed, the older, the children.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And my sister-in-law gave birth a day before to a little boy in our home.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "She was in bed.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And the people were staying here by the window.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And she was covered like a bed is made.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And the baby wasn't crying.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And we were staying outside and we were-- we were-- were scared to death.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And my mother she was, at that time, in a very bad condition, and she was also covered in the house.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And the SS men passed through to look at us, and they came out alive.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "They didn't catch my sister-in-law nor the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "After three years, she has to give him up in Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "And she went with the baby because she didn't want to give him.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "She didn't know that they were going to put in crematorium, both of them.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "All few months.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "All few months.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "The old people, yeah, yeah, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And there were Jewish police.",
      "word_count": 5
    }
  ],
