    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it's in the synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Matter of fact, I added-- because they are building now in the-- over here, you know, a memorial center.",
      "word_count": 19
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And-- and my mind came, the synagogue is not forever.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Today it's there.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "Maybe because he is-- my son is active there too.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And he's got-- [PAUSES FOR 6 SECONDS]",
