{
  "stem": "15900.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.2,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "All four, All five.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Three brothers married.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Oh, with the wife.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "We brought the wives too.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "After-- after we-- we-- we-- we-- when we were in Bialystok, we-- we have somebody to bring the wives there.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And we were there already with the families.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I was not married.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "We were there with the families.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes the children were--",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were five brothers with the wives, and then 11-- 12 people.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "My-- my younger brother, who you see there, he was married at 18.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And he had a little boy.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And my other brother who was in the picture, he had two girls, a boy and a girl.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And my oldest brother had two girls.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, five children.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "They got a job.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And I took a job to work in the steel.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Like a mechanic, and I was working there, and I got better with them.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "They work hard-- later on, we got letters from Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Hitler did this.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "Send for your children and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And told them how you were fine here and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Why do they have to stay there, you know what I mean?",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And we got a letter from my father.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "Anybody who has the children there, has food and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They're working.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "It's pleasant.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Come back.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "Now where was he still?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Where was your father?",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "He was still in-- in Blonie--",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "--in the little town.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "He said, come back.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "But at that time, in truth, I think there was more food there than it was with the Russians.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "The Russians didn't have so much food.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "But wait a minute.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "He had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "There was a ration.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "But the German told him how to send a letter to send to the people who ran away.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Come back.",
      "word_count": 2
    }
  ],
