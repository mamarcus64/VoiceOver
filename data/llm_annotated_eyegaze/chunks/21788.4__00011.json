  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "I stood in line twice a day to get us some hot food from a central kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "My father went and started selling some of our goods.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "Being that we were one of the last people to get into Shanghai, we had quite a number of very sought after items.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "My father always believed, don't buy one.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "Buy a dozen.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "So the dental equipment that he brought over, we had a lot of teeth-- false teeth-- which were non-existent in Shanghai.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "We had a lot of amalgam fillings and some other things.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "That was some of the stuff that we were able-- that weren't confiscated.",
      "word_count": 13
    }
  ],
