{
  "stem": "18665.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 363.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "Also, I was fortunate that I was a German quota, because in those days there was a quota system in the US, and the German quota was wide open.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And my wife-- we were married one year.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Although she was born in Austria, but she traveled on my quota.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And-- and my parents were able to come in because they were at a certain age where they received a permit to come in.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "So that's how we finally ended up in the US in 1948.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "It was again in April of 1948.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We came into San Francisco on a ship called the General Meigs, which was an American [? present ?] line, a converted troop transport, men and women separate.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "My wife and I, we found a spot where to meet.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And my parents were already in the US about three months, four months earlier.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "My wife and I decided not to leave yet, because we were not in a big hurry, because my grandmother was still alive.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She was born in Prague, Czechoslovakia, and could not get a visa to come to the US.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So we had to make arrangements for her to go back to Germany, to an old age home at first.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And once she was all taken care of and she-- she left, that's when we came to the US.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we settled-- we first came through San Francisco, like all of us.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Everybody threw the penny at-- in San Francisco, in the Bay under the bridge.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed there for a month, again thanks to the Jewish organizations.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Because I only had $30 in my pocket when we arrived.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "There was HIAS.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We got stamps to eat in the cafeteria.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They put us up in a-- in a hotel in San Francisco.",
      "word_count": 12
    }
  ],
