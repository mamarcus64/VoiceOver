{
  "stem": "22047.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "One weekend, I had a leave to go up to Tulsa.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I, along with a couple other officers, went up there.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And one of them had met a girl in Tulsa earlier.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And so I went with them.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And we-- we hired a taxi, I guess, and went all the way from Muskogee to-- [LAUGHS] to Tulsa in a taxi.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And I met his girlfriend.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And-- and she found a-- a-- a girlfriend for me and for the other fellow.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And we-- this was on a Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to meet her.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Gosh, what was her name?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Ora Fay ?], [?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Ora Fay Jones ?] was her name.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I was going to meet her on Sunday.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "But for some reason, she couldn't make it.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And so this girl knew of another girl.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Her name was Sally-- Sara Straton.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And so I met her on Sunday.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And we went to a picnic out on the park in Tulsa and got rained on.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And we went back to this girl's house and-- and had our uniforms pressed and-- [LAUGHS] because we got soaked.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And that was my-- my meeting of Sally.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And we had, I think two dates after that.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I went up to Tulsa to a football game.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Tulsa-- Tulsa High School, I guess, was playing some other team, and I-- no, it was Tulsa University was playing some other team.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And so I went to the football game with her.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And then one other date, and-- and I went overseas.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And we promised to correspond.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So we-- we wrote letters back and forth.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And that's when, really, our plan to get married when I got home happened.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know each other from nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] What was her full name?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Sara Florence Straton.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
