{
  "stem": "597.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And he brought me into that-- Storazuk-- Tedoch Storazuk.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And that was his daughter-- is Nadia.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He had one daughter-- that's only-- the son and a daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "The son was mobilizing the Red Army.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And he didn't-- he didn't know where he is.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So, I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And that-- and they give me food.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They kept me hiding on the attic in the straw.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "They had straw a lot in the village.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And I hided there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And it's a barn-- and a big barn.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "On the barn on top is a lot of straw.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "They keep it for the-- for winter.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "They keep the straw-- straw, hay.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "For the animal, he had some cows, and sheeps, and chickens-- well, like on a farm.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I was in there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And every evening she-- twice a day to-- he would bring me food in the evening-- in the morning and in the evening-- soup, bread, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Whatever they had, they give me food.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "One day, they had a big dog.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "The dog was very, very-- were-- on a chain-- barking terrible.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "He barked like anything.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "One day, my mother didn't have no place where to go.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "She came up in-- on the ladder-- by the ladder.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "And the dog didn't even give one bark.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "And she went up on the ladder, and she came up to me.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "And she said, I have to stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "I-- I-- Rachel-- I put her by another man or a lady for a while.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "I don't know how long, but I don't have where to be-- go.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "So I came up here, and we stay with the other.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "He should know nothing about it.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I was happy to see my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And I hided her deep in the straw in the hay.",
      "word_count": 11
    }
  ],
