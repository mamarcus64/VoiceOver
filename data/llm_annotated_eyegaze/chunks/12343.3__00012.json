{
  "stem": "12343.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 474.8,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans is dragging in the ditches.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "They let us go like this.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "Or they come back.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "And they will find a way.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "I've seen they are close.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "We cannot do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "It was warm, summer, already, the spring.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Come to spring, it's already.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Oh, you see, a lot of people more-- And so many in the fields and berm.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I never can explain so many-- walking, and walking so much, so far from Colditz, to Czechoslovakia, to walk all the time.",
      "word_count": 22
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "You walk until you  can't.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "In the night, some people run away, in the night, in the woods, in the woods.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "In the [INAUDIBLE], there's woods now.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "They run away.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I walked in the woods too.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "I figured.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "Still, I was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "I was frightened man.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "My convictions said, don't do it.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "You've had a life [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "There you go, and I didn't do it.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "I think they get us to Theresienstadt, Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "Over there, we're going by there was another camp other there.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 14,
      "text": "We went past them.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 15,
      "text": "They say, hi!",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 16,
      "text": "Hi!",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 17,
      "text": "You know, people over there too.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 18,
      "text": "[INAUDIBLE] was ready for them too.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 19,
      "text": "They took us over there in a basement, a temple basement.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 20,
      "text": "Sitting, all night, and crying, cry.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 21,
      "text": "We was looking.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 22,
      "text": "Nothing happened.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 23,
      "text": "In the morning-- [KNOCKING] [NON-ENGLISH]!",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 24,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 25,
      "text": "Everybody, life.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 26,
      "text": "They took us out.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 27,
      "text": "The Russians do that very good.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 28,
      "text": "I don't care what America talk about the Russian.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 29,
      "text": "The Russians did that better than the American.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 30,
      "text": "I'm going to tell what's happened.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 31,
      "text": "It's not happening, over.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 32,
      "text": "They did very good.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 33,
      "text": "They took us out.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 34,
      "text": "They dress us.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 35,
      "text": "And take us, and we take a bath.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 36,
      "text": "They took a German woman to give us the bath.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 37,
      "text": "They dress us, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 38,
      "text": "The German woman.",
      "word_count": 3
    }
  ],
