{
  "stem": "8234.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "You  had to push cars from the tunnels out of the tunnel and dispose of them.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "A lot of work was there.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "It was hard work.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "I didn't have a chance to have food either, so I lost my fat-- my baby fat, of course.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "It was tough for a time.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "And one day, I worked-- yes.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "I worked me a locomotive.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "And the meister told me to throw some coal in that-- in that furnace.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "So I did.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "And he says, well, I think I'm going to keep you here.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "He went to my foreman.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "He says, I want that Jew with me.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "And I was on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "On the locomotive train.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "It wasn't bad because nobody chased you.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "I used to-- not only coal, but I used to jump out in front of that locomotive and change the railroad.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "If you want to go right or left, I have to change it, and jump back off the train rail.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 44,
      "text": "That was-- everything was fine.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 45,
      "text": "I worked a while over there.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 46,
      "text": "One thing happened to me that-- when I was changing, yeah.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 47,
      "text": "Sometimes you have to took the wagons in the front of the locomotive.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 48,
      "text": "So we pushed it.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 49,
      "text": "And while he was coupling, he lost some steam and burned my hand.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 50,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 51,
      "text": "He sent me back to the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 52,
      "text": "He sent me back to the camp and the Germans were funny.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 53,
      "text": "Terrible but funny.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 54,
      "text": "They could kill you at that work.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 55,
      "text": "But if you have an accident at work, you are something else.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 56,
      "text": "They took care of you.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 57,
      "text": "So I went  to the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 58,
      "text": "He put some-- some stuff on my hand and a glove.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 59,
      "text": "But all my skin went off the hand.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 60,
      "text": "It was this hand, but you don't see it anymore.",
      "word_count": 10
    }
  ],
