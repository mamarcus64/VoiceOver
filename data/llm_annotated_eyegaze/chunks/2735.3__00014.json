  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He says, I'll help you.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And he was not drunk.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He was a wonderful person.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But most of time he was drunk.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And I started to-- I don't remember if I worked, or I just got-- and I saw the first Jews that came out from partisans, and that lived in a group.",
      "word_count": 31
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I didn't see anybody from camps or anything like that.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And then they made us-- that's when I came for good, and they made us look when they hung up those Ukrainians.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "That's when I-- yeah, that's when I came the second time.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "So and they made out papers for me.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Took a month.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And meanwhile I met, in one house, a lot of partisans that were in the woods then.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And they lived about 20 people together.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So once we made the papers, [PAUSES FOR 4 SECONDS] we had to go on a train.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It took us a month to get back, you know.",
      "word_count": 10
    }
  ],
