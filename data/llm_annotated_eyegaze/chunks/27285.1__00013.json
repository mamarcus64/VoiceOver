  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning it was Magda, she went on to the east, which we later knew it was to [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And then was Laura.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And this is quite a story because I didn't want to see her, or talk to her at all, because she took the place of the first one, and I was loyal, still, to the first.",
      "word_count": 36
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And slowly-- I was at that moment, at that time, I was sick, I was in some quarantine-- separated.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "So I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And she already won over the whole group of children.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And in the end, of course, me, as well.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Because I gave her my diary, and that was like the opening.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And she took me-- actually, any child who did not have parents in the camps was assigned a lady, or au pair was assigned to take the children as their own.",
      "word_count": 31
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "So this Laura [INAUDIBLE] was my foster mother.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "Luckily she saved me, my soul, my being, and also my physics, until I came to Palestine later.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "Because the whole time I was with her through all the camps.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And after the war, as well, she made a place for me to stay with her.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "That's why I didn't--",
      "word_count": 4
    }
  ],
