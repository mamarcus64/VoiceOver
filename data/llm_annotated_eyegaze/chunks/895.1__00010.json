{
  "stem": "895.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And when we were there, all our clothes were taken off.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And we were sitting there, freezing.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "It was in November.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And my friend-- who's living in Montreal-- he's the only one [INAUDIBLE] me from where we were.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "He lives in Montreal.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "His name is William Pollock.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "But we were to-- through him I came to Canada.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "But then, when we were there, sitting there, nearly 24 hours, freezing and cold.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And then, all of a sudden, the SS came in.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "You've got to go in the sauna.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "We had to be washed in the sauna.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Well, our heads was bald already, so we didn't have to cut it.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "And there we stayed.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "They gave us a uniform-- you know, the white stripe-- the striped uniform, the stripes.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "And there I was-- went to Birkenau.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "Birkenau was-- first was Auschwitz and Birkenau, were connected to one another.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "That's where their gas chambers was-- in Birkenau.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "And there we went into quarantine.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "Two weeks.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "That was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "Mengele-- my story, I have a story-- Mengele came in our barracks.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "They say, Mengele's coming.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "And Mengele came in, after two weeks there.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "We had to all undress-- stand in a line.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "We were about 350.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "And then he started pointing.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "This side to the left, to the right.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "Only 17 of us went to the right, and I was a one who went to the right.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "All of them went in different barracks, screaming and crying because they knew they were finished.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "The next day, when I went out my barrack, it was empty.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "They all went to the gas chamber the next morning, every one of them.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "And I remember my uncle, who I met there, walking-- help me, help me.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "I couldn't do nothing.",
      "word_count": 4
    }
  ],
