{
  "stem": "1873.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 514.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "And he said-- I heard the voices-- now let's collect the money, and we will put them-- we will dig it.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "We put them in grave tomorrow.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "At that point, I did get up and escaped.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "There was a old brick factory.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "And I was hiding in the-- I went to-- it was an [NON-ENGLISH] center-- brick factory.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "And over there, with the help of my teachers, Polish teachers, they-- they did give me food.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "And later, when they were chasing for me-- because always, they were looking for me.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "Because they were aware, if I survived, they'd be in trouble.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "I managed to go to another village.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "Over there, I attached myself to a Polish underground organization.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "[NON-ENGLISH]-- this was a peasant partisan organization.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "They didn't know I'm Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "And I was over there till the liberation.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "After the--",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The Russians, in 1944, in July.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I-- I was-- I was-- a Polish lady told me-- she was a friend of us, and she was-- she owns a bakery.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And she told me, [NON-ENGLISH], don't be all like another Jews-- just business, business, [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Go to a decent work.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Be a baker.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know much.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I was 12 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And my whole center of the world seemed to be to be Izbica.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Even now.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Now I was 16-- 15, 16.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "16.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So anyway, I start to work in a bakery.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But she told me, don't go out to the streets.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I-- I was wondering.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I'm-- I'm liberated.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Why shouldn't I?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And once, they knocked on the door, and she hid me-- some people.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And later, they left.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "In a fork over there, Perchesky told me, Tom, don't stay in Izbica.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Run.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Because you'll be in trouble.",
      "word_count": 5
    }
  ],
