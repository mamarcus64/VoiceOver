  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 55,
      "text": "He needed two men to be his messenger, messenger from the, from the command, from the high command.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 56,
      "text": "We were, our regiment was standing like two rows.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 57,
      "text": "And he was going between the two rows.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 58,
      "text": "And he hold a little stick like a conductor from a orchestra.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 59,
      "text": "He hold a little stick.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 60,
      "text": "And he walk.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 61,
      "text": "He walks slowly.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 62,
      "text": "He look everyone in the face.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 63,
      "text": "When he come in front of me, he hit me with the stick in my-- [INAUDIBLE] touch.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 64,
      "text": "That's mean I to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 65,
      "text": "He pick me.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 66,
      "text": "Pick me up and, and another Russian boy.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 67,
      "text": "Same thing like I was look all right, was looking good.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 68,
      "text": "They took us to headquarters.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 69,
      "text": "They give us a lesson [? high ?] our duty will be to be a messenger, what we have to do.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 70,
      "text": "After a few days, I was running to the headquarters with a message.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 71,
      "text": "A sniper, a German sniper, was somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 72,
      "text": "I didn't see him.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 73,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 74,
      "text": "I will hear the bullets by my-- eight or 10 bullets was next to me, was shooting.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 75,
      "text": "Chk.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 76,
      "text": "I hear.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 77,
      "text": "Chk.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 78,
      "text": "Chk.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 79,
      "text": "Chk.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 80,
      "text": "And as you run, you don't run straight.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 81,
      "text": "You run bent, like that.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 82,
      "text": "You don't run straight, you run like that, zigzag to meet, to meet his eyes.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 83,
      "text": "But he got me in my left arm.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 84,
      "text": "He shot me.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 85,
      "text": "Went to the-- I went to the place where they was, I was.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 86,
      "text": "My regiment was already gone.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 87,
      "text": "I can't see my regiment, already gone.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 88,
      "text": "Because in the army, you're not-- in the front line, you don't stay on the place for weeks.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 89,
      "text": "You go [? and start. ?] I already got another reg-- another people, another regiment.",
      "word_count": 15
    }
  ],
