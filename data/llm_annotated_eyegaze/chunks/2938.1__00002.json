{
  "stem": "2938.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Because everybody used to belong.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "The youth, the whole youth, belonged to organization.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "So everybody belonged.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I joined, too.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My-- my older brothers belong mostly to the same organization.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I joined also.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "From an organization you mostly get--",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "--hope for the future.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, the organization, they build us a future.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They teach us what we should wait for the future.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "This was the organization's purpose.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "While we are waiting for the future, in 1939, the war break out where the Nazis marched into Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And in three days' time, they run over the whole country, and occupied Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had twice a weeks meetings.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We had lectures.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We had outings.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember too much, to be honest with you.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember too much any more.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "It's 50 years gone.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Hard To remember after 50 years.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Wasn't a fighting organization.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Was right-- a right-wing organization.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "More to the right, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Zionist to the right.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we were active politically.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Politically in the city.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "In the country.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, plain, simple member.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Listen to the leaders.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "That's our future.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We cannot build a future in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Poland is an anti-Semitic country.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And we have to prepare ourself to leave the country and go build a country, Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But they never gave us the chance to go there.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Well, people, most people used to learn trades, professions, to be prepared to make a living in the future country.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My father in the lumber business, we knew how to manufacture, fabricate lumber.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "With my dad.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Dad, and my brothers and the family in the lumber business, right.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Cutting wood, measuring wood, and preparing, you know, the wood, to prefabricate difference things.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, it's nothing to do with Betar.",
      "word_count": 7
    }
  ],
