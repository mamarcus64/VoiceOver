{
  "stem": "22469.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "After I saw Schindler, we've been together, and I saw how he speak to me, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I said, director, you took me from my wife.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "She's there.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I am here, and I want-- I working.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Please, send me return, or bring me my wife, here-- stupid, I was stupid.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And he said, OK, don't worry.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "OK, don't worry.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And the people, my friends around, saw that I got with Schindler very well.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "Victor, you got a wife.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "Yeah, I have a wife.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "My wife is there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "Do something.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And every few weeks, I said, director-- don't worry.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "I'm working.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "I'm working.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And suddenly he said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "How many wife you [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "Make me a list.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And maybe 20, 40, I don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "Make me a list.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And he said, I am going to try.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "Never said a word.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And after a few weeks, he said, excuse me.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "Tomorrow, your wife is coming.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And she came, with all the wives.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "And he was there, and he said to-- show me your wife.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "Nice girl.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "[LAUGHS] She was proud, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "[INAUDIBLE] Schindler.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "With whom?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He was so-- he was so-- when the officer came, they were always drunk with [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I-- I can tell you another fact, with names.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I had a friend, is a Roman bull fighter, a Roman bull fighter.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And he got connection with Polish people outside.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And he-- because the Jews, they get [INAUDIBLE] [? money ?] to the Polish people.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And this bull fighter sent a letter through a Polish boy to another Polish, and they caught him.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And the Gestapo-- two Gestapo men-- came to our camp.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And they wanted a Roman bull fighter.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Gestapo, [INAUDIBLE] director-- yes sir?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And the Gestapo [INAUDIBLE].",
      "word_count": 4
    }
  ],
