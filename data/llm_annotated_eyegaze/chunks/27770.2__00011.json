{
  "stem": "27770.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "As I arrived, let's say we arrived 5:00 in the morning, what I did to my barrack, and a Polish guy was there already many years.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "He told me Jewish, [NON-ENGLISH], come here, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "Come, I want to show you something.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "He say, you see on this side?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "You see they go in, young people?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "You will see in an hour, hour and a half, they will come out dressed up, shaved up, with striped suits.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "You see on this side, you will see nobody to come out.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "You will see only the oven will burn.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And you will feel the smell how they're burning them up.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So I knew already the first half an hour what's going on.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And that was the reason I write it, I made a note for myself in my mind, not on paper, without a pencil.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "This was exactly three days before [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We counted Jews [INAUDIBLE] so you know there's three days before [NON-ENGLISH] they died, and that's how observing from the whole family who mostly did not survive.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Three days before [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Most of the families were together.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Grandfather and uncles and [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I have here family pictures I want to show it to you from those.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Not even 5% came home.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And even somebody with my-- I had from my father's brother's son who was in my age, and he became free, and as we became free, we all started to eat, and we became all sick.",
      "word_count": 36
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And he died there in Mauthausen.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I saw many die.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Those of us in my age.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "With a train.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "With a train what usually they're transporting animals.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't push in so many animals, cows or horses, in such a way as many as they put in human beings.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Little windows.",
      "word_count": 2
    }
  ],
