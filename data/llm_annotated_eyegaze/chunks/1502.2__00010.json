  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The Wannsee Conference decision of the final solution started to apply in Belgium.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They started-- they started with a raid on the trains.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "In Belgium, the majority of Jews lived in Brussels and in Antwerp.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "In Brussels, there were about 25,000 Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "In Antwerp, there would have been 40,000 to 50,000 Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And then, there were other towns, were 5,000 Jews amongst all the other towns in Belgium.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Now, Brussels is 50 kilometers from Antwerp, just like 35 miles.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And-- and they decided to start raids on Jews on the train, between Brussels and Antwerp.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "That's where my brother's wife was caught, one of the first victims.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "They caught a few hundred Jews on that train.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "They sent them-- they sent these Jews to Breendonk for a few days.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "They did not mistreat them in Breendonk, like the other prisoners.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "From Breendonk, they sent them to a camp called Mechelen.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Mechelen is the name of a town almost exactly halfway between Brussels and Antwerp.",
      "word_count": 14
    }
  ],
