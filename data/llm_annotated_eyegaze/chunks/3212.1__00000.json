{
  "stem": "3212.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Ernst Hacker-- E-R-N-S-T H-A-C-K-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born April 29, 1929, in Schwarzenbach, S-C-H-W-A-R-Z-E-N-B-A-C-H, Schwarzenbach, Wienerneustatt, W-I-E-N-E-R-N-E-U-S-T-A-T-T.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Austria.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Vienna, Austria.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My parents from my father's side.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My father was born in Schwarzenbach, too, in Austria.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "His family, his father and grand family, 400 years back, were born all in the same neighborhood.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "There's gravestones in [NON-ENGLISH]-- that is next to Schwarzenbach-- that have the Hackers, for 400 years, stones.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "That the people-- my family-- was born there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "My mother's side came from Luckenbach.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "That is in [NON-ENGLISH], closer to the Hungarian border.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "I don't know how long they were there, but I know my grandpa from my mother's side was born there, too.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I knew my grandmother very good.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather from the-- from my parents-- the-- from my mother, the grandmother I knew very good.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They lived in Luckenbach.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "There was a big Jewish community.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They had a big temple, synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And I remember, as a child, when we went there, the women was separate, and the men were separate.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And from my grandmother in Luckenbach, I always remember, when they came there, she made noodle soup-- chicken noodle soup.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And she made the noodles, everything, by herself.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "She cut the noodles very thin.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I never forget the taste of it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "But Schwarzenbach was a little village.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "A farmer village, actually.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And we were only the two Jewish families in the whole village.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "That-- the name was Holzer, the other Jewish family, and the Hackers.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "That were the only two Jewish family in the village of Schwarzenbach.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "Schwarzenbach is a little village with farmers, surrounded by mountain and forests.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "In the back of our house, we had a little lake.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "Not like a lake-- running water, like a--",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No, it's water running.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "River.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "A little river.",
      "word_count": 3
    }
  ],
