{
  "stem": "20684.3",
  "chunk_idx": 17,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I've had a good run.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I've become eight years ago a grand master in bridge.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "In 1992, I was-- represented Australia in the world championship in France and in the Olympics.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was OK this time.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "This time was OK.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "This time was OK.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It's different.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Well, I only met my cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "My auntie and uncle perished.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Just my cousins, so it was nice.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "It was nice.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "It was my first return.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "I was very lucky, actually, that I had-- that I was able to make a stipend because I like to make-- I tend to be a vindictive sort of a person.",
      "word_count": 31
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "I don't think I'm a real nice person.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "I mean, my wife tells me I'm not.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "She doesn't know why she's married to me for so long.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "It's just that I think fascinate her, she said.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "I fascinated her when I was young and now she got used to me like old slippers.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "I think that was the term that she uses.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "But she was fascinated by it, by the mixture of sort of-- of good and bad and my moods and my pretense and my masquerading, which I have always had.",
      "word_count": 30
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "I think it goes back to the day I was a little girl, when I was masquerading, that I can adapt.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I feel very comfortable with everybody and I try to make everyone feel comfortable with me.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "But who is the real me?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Because my stratum of friends really is from very high to very low on a scale of whatever you want to name it.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "So I feel quite comfortable with everybody and so I don't really know who I am.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "But that doesn't matter.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I know I'm here.",
      "word_count": 4
    }
  ],
