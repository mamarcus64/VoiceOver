{
  "stem": "22734.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "And they always had food.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "They brought tomatoes and potatoes and cucumbers or what have you.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "And that was bartering.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "So-- and [?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "Ruda ?] worked in the garden for a while too.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "We had-- we had potatoes and all of that.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "And then, my cousin-- I'm jumping, but it's part of the story.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "My-- one of my cousins, the sister of the cousin who is in England was a physician.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "And she worked in Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 32,
      "text": "And she heard I was pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 33,
      "text": "And they send me parcels with diapers.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 34,
      "text": "My mother was climbing the roof.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 35,
      "text": "And she never believed me that I was not pregnant because they insisted that we get married.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 36,
      "text": "They-- they said they cannot justify it in front of the Germans if you don't get married because they got us out, because I was pregnant and got married.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "So we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "And that was a stage.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "It was not a memorable ceremony, but it was there.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "The girls brought me from the garden three chrysanthemums, three white chrysanthemums.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "And somebody made us out of margarine and sugar and coffee sort of a cream.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 42,
      "text": "And we had a-- we had a celebration.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 43,
      "text": "And then, we had this wedding night on the-- in the attic where the millions of flies attacked [?",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 44,
      "text": "Ruda, ?] and nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 45,
      "text": "The-- the flies don't like me.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 46,
      "text": "Not flies, fleas.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 47,
      "text": "They don't like me.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 48,
      "text": "They don't touch me.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 49,
      "text": "And they all moved to him.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 50,
      "text": "So that was-- and the next day, I got scarlet fever.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 51,
      "text": "I got high temperature.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 52,
      "text": "And I had scarlet fever.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 53,
      "text": "And they moved me to-- they were very scared, the Germans, of any infectious diseases.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 54,
      "text": "And I was locked up for months in-- in a barrack for infectious diseases, where upon my mother decided I had an abortion.",
      "word_count": 23
    }
  ],
