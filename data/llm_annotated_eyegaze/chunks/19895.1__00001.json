{
  "stem": "19895.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 80.3,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Could you tell us the name of those individuals?",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "My father's brother was Laszlo Lichtmann, the same as my middle name.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And the two sisters were Anna and Margit.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Lichtmann at birth.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother name-- my grandmother's name on the mother's side when, when-- the maiden name-- is Roza Friedmann.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my grandmother name on the father's side, the maiden name, is Eszter Zeisler.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "F-R-E-- [?",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "F-R-I-E-M-A-N-N-- ?] Friedmann.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And Zeisler is Z-E-I-S-L-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes, I was close to both grandmothers.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But the grandmother on my mother's side is probably the one I would remember being closer.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Because on a number of occasions as a young boy, I went to the countryside from the capital city of Budapest to visit with them, visit with my grandmother and my uncle who lived in that location in a town on the Hungary and then Czechoslovakian border called [NON-ENGLISH].",
      "word_count": 49
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I don't think I want to spell that.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "That's a very long name.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I have very wonderful memories visiting there on summer vacations as a young boy from about age six till about age 12.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And on the lady who is actually my father's mother's sister who raised him, lived also after World War II in-- survived and lived in Budapest.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I had often chance to visit and see her.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "As a young boy, I enjoyed very much going to the countryside.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Because grandmother kindly came to Budapest to pick me up.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So she was my companion on the train, which those days took us some six, seven hours train ride.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And many stations, we had to stop.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And, and I enjoyed very much the train ride.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "It was, it was just like nowadays.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "One would look at all trains with the smoke and the big engine.",
      "word_count": 13
    }
  ],
