{
  "stem": "26358.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "Nobody can say nothing to me.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "And everybody was talking.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "This mother's killed.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "This father's killed.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "I said, I don't care.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "My father and mother is dead.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "And I have a wounded brother in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "And I have another sister in the concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 48,
      "text": "And I'm here.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "We all three apart now.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 50,
      "text": "And my mother, my everybody took us.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 51,
      "text": "Sadly a week later, the Gestapo decided to pull in all us in the main concentration camp.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 52,
      "text": "No more private.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 53,
      "text": "What happened, nobody have a money to pay him to be in private concentration camp.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 54,
      "text": "See, we paid like 10,000 marks to be.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 55,
      "text": "I know my father paid 100-- 1,500 marks to be private.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 56,
      "text": "Not in main, not to be-- the Gestapo was sitting at the balcony.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 57,
      "text": "When you passed by the yard, he was shooting you.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 58,
      "text": "That the only thing was a little bit released.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 59,
      "text": "See, he used to sit of the balcony, and he didn't like you, how you walk, he shot you.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The main camp.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "In the main camp, we went, was like four weeks in '43 before Passover.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "After-- after Palm.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And [NON-ENGLISH] came my cousin have a family in the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "The Gestapo used to pull together like 1,000 marks a Sunday morning, and get passes to go and get to visit the parents, family.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "It was one Sunday morning, my boyfriend say, we're going-- I go visit my mother in ghetto. and my sister.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "You're coming along with me.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And he paid 100 mark for me.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And I went to see my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "When my cousin came back from the city where the ghetto was.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And he say to me, [NON-ENGLISH], your brother is very sick of typhus.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "He was burning up.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "That was Thursday.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "It's Sunday.",
      "word_count": 2
    }
  ],
