{
  "stem": "12810.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "He said-- then he go to the other room with his wife, and then he come back and said, you can't stay here.",
      "word_count": 23
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "I can't risk my family.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "I said, I am not your family?",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] He don't answer me.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "And then the bell ring, because he has a lock-up gate, you know, lock-up piece.",
      "word_count": 15
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "And it was that man come to my father whom he give money to tell him what's happening to me.",
      "word_count": 20
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 7,
      "text": "And he said, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 8,
      "text": "Now they take the girls away.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 9,
      "text": "Your girl is in the wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 10,
      "text": "She going to out.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "So he give him again money and said to him, thank you very much.",
      "word_count": 14
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And again, if you heard something, you come.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "So then he gone.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "And I said to my father, what you want I should do?",
      "word_count": 12
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "He said, you can't stay here.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "I said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "Give me a piece of bread.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] And I know my mother have a friend in-- a lady friend in Rakospalota.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 8,
      "text": "That's where your holiday house was?",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "That's a-- that's a next town--",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "--like a Bondi and Paddington, so--",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Suburb, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "I said to him, I-- I go to her.",
      "word_count": 9
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "Maybe she give me--",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Non-Jewish friend, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "So I tell him the address, and there I go.",
      "word_count": 10
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "And I went to there.",
      "word_count": 5
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 3,
      "text": "I walk about 1-- 1 hour, 1 and a 1/2 hour.",
      "word_count": 11
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Nobody stopped me, because I was-- have-- you know, that modern way I put that scarf on, you know, to-- like a holiday girl.",
      "word_count": 24
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "And I have a sleeveless frock on, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "Because I haven't got my working things on.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "And I was a pretty girl.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "And nobody think I am Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "And I-- I walk.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 6,
      "text": "And I walk, and I [SIGHS] went to her.",
      "word_count": 9
    }
  ],
