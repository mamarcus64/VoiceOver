{
  "stem": "6076.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "She was standing so shivering and praying that chicken that my father will come out from his [NON-ENGLISH]-- that means from the other room-- and he will say the chicken is kosher.",
      "word_count": 32
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "What will she do when she goes home with unkosher chicken?",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "What will she give her kids to eat?",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I looked at the woman, and my heart was beating many times.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I said, please, God.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "That chicken should be kosher.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I was a little girl.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "My father should only pronounce to the woman that chicken is kosher.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, I could not face that woman.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And my father used to come out with a smile, I knew the chicken is kosher.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He says, it's kosher.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Oh, thank God.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "The chicken is kosher.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "She blessed my father.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And she ran home so fast, of course, to cook the chicken for her family.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "But many times my mother will open the chicken and she will say to my father, [?",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Shlomie. ?] I find something in the chicken [NON-ENGLISH] chicken [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "My father says, wait a minute, wait a minute.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "Let me see it.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "He walked over, and he looks at the chicken.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And he says, it's [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "It's on the other side.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "It's kosher, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "So my mother was happy.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "She gave my father a smile.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "Oh, she was so happy.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "Then she started to work on the chicken-- to pluck-- you know, pluck the feathers, to make it kosher, and so, and so.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "Hard work went on in that-- at home and in every home in our shtetl.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "In many shtetl around Poland, that was the life.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "That was the basic life of Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Beila.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was--",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Teitelbaum.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Teitelbaum.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Before Shabbat--",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I will tell you.",
      "word_count": 4
    }
  ],
