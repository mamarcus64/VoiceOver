    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I come here to enjoy it.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Wherever I can, I want to grab [INAUDIBLE].",
