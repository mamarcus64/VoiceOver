    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I'm born in Tuczyn till they threw us out.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Is this OK?",
