    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No, ma'am.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
