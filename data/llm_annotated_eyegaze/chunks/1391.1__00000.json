    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I am Adam--",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I am Adam Schwartz.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Tuczyn, 1912.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
