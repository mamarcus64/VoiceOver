{
  "stem": "17135.5",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "It-- it's a famous Czech town where they make the beer, and they adopted that.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I work for a Czech family.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And the name, [?",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "Benes ?] who was once the president of it, is like Smith.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And my name is [?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Benes, ?] and I-- they adopted me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "I slept there, and I never told them that I escaped from a concentration camp, because I knew there was not a Czech family in all Czechoslovakia that at least one was killed, or in the concentration camps.",
      "word_count": 38
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "And I would endangered their life, or they might get frightened, and report me to the-- to the Gestapo.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So I'm the Frenchman.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And, by the way, I spoke-- when I spoke with the Germans, I spoke half French, half German deliberately, so they couldn't understand me.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH SPEECH] half and half like-- like Frenchmen did.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They spoke half German, half French.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I learned this, because I had contact with those people.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I was there from the mid of March until the end of April.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And they gave me [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "It's-- it's [NON-ENGLISH] and-- and-- and-- Butter.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH]-- no, [NON-ENGLISH] is fat-- fat.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They-- they [? put ?] me up, because I was totally emaciated.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I never took off my clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "God forbid, they see my number.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I was afraid also, more than anything, that at night, I might talk in my sleep.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I was afraid, or get frightened.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "I had nightmares then.",
      "word_count": 4
    }
  ],
