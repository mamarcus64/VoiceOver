  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And we knew it was just part of it.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "They just-- they were so disgusted.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "They were so unhappy about Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "They found out about the family being deported and so on.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They never wanted to go back and live in Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "They weren't sure where they wanted to live, but we had to leave Switzerland.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Switzerland didn't want to keep anybody for an extra minute if you could leave for anywhere.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "So my parents just went back to the last place that they were, which was Lyon.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And I stayed because I was in school.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "I wanted to finish the school.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, it-- it was all over.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "It was extraordinary in 1945.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Everybody knew.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I mean, it was very easy to know in Switzerland.",
      "word_count": 10
    }
  ],
