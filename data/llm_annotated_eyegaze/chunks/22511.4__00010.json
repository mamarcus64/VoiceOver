  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I-- My first business was in Victoria Street Houghton.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "That's why I'm very for Houghton.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I like Houghton.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] The children like St.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Kilda, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I like [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Houghton. ?] This is why I-- and then I had a milk bar in Dickens Street.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "With the children, it was very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "One of my son had asthma, too.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And it was very hard, because in a milk bar, you have to work from morning till night.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And when he had an attack, it was very hard.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I had to take him to Alfred Hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "The doctors were so good, so nice to me.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Really, Australia is something what we have to remember them for all your life.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "They helped us.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "They support us.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And [PAUSES FOR 3 SECONDS] the-- [PAUSES FOR 3 SECONDS] and then I decided to have a factory of lingerie, and we opened a factory.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And I was the-- the salesgirl, and I sold to all Australian people.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Used to be Tredway, used to be a lot of businesses.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "Today they're called different.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And I used to come to them, and I-- they always tried to help me.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "They would-- even Susan Lingerie, which belonged to Jewish people.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "There was a lady-- Italian lady, only she's, like, Australian-- always gave me orders.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "I never came out from a business which I didn't get orders.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And Myer's, they had buyers, Australian buyers.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "They were very nice.",
      "word_count": 4
    }
  ],
