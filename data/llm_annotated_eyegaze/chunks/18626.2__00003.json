{
  "stem": "18626.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Because in my grandmother's house, my grandmother had a cellar.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And all the family went in-- into the cellar to hide.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Not my family.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We were still, we were not living near my grandmother.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "My grandmother lived on [INAUDIBLE] Gasse, [INAUDIBLE] Street, which is a real Jewish section, the same thing like in New York, the [INAUDIBLE] Street.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] The same was [INAUDIBLE] Gasse, like the [INAUDIBLE] Street.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And they were all hiding in that cellar.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And the cover of the cellar was covered with a carpet like in my house here.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And a table was after they went in, they let down the thing with the table and chairs around.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And when the pogram started and the Lithuanians start to kill, house to house and [INAUDIBLE] Gasse people, the woman, Gentile woman who used to help my grandmother sometimes, and my grandmother treated her really well.",
      "word_count": 36
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "She used to eat by the same table with my grandmother and grandfather and with my all uncles for years and years.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "She came in with a lot of the Lithuanians hooligans, partisans.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And she heard, she heard the voice of Janova that was her name, the woman who was taking care of my grandmother's house many years and helping her.",
      "word_count": 28
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And she said looks like nobody is here.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "Maybe they are in the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "In the new synagogue, there was the name is [INAUDIBLE] Shul.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "The Gentile woman said to other partisans, the Lithuanians, let's go there.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "They must, they must all hiding themselves in the-- in the new synagogue.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And they all went to the new synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And there was a lot of the Jews hiding really there.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And they slaughtered all the Jews in that synagogue.",
      "word_count": 9
    }
  ],
