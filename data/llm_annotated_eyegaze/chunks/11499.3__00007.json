{
  "stem": "11499.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "My grandmother, in 1939, left Warsaw to go-- she had two daughters in America-- to come to America after my grandfather passed away in '32.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And she was in Paris with my-- with my uncle.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And she was-- when The Germans occupied Paris, she was walking in the street.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And she was taken, in the street, and never heard about her or anything.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "So we don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I worked.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And then I went to-- went to school.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And I worked in the garment industry, in New York, for many years.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "When did you arrive, did you say, in America?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I went to school in New York to learn pattern making, designing, chick-- chic school.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I did-- made a very good living.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Then my uncle-- I had an uncle, my mother's brother-- had a big pocketbook factory in New York.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And he gave me-- told me that, look, I'm getting old.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "He's getting old.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "He would like to take it easy.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He would like to-- he should go with his sons, be with his sons in the business.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You learn the business, fine.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I said fine.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So I went to work with my uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I did very well.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Not financially, but very well what-- how-- what I learned.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I learned more in three months than he learned in 40 years.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "That he-- I was-- so, after a few months, he let me run the factory.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I had 300 people.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And he went on a-- on a trip, to Argentina, to see his brothers, he didn't see for 40 years.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Then I had an out fall with him after five-- four or five years with him.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I just left him.",
      "word_count": 5
    }
  ],
