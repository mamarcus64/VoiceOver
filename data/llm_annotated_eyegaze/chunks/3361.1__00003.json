{
  "stem": "3361.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And he slapped me and threw me out from the house.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't have where to go, so I went to Cracow to look for a job.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I look like I'm seven years old and I-- because I was short and skinny.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So I said, I'm older than I look.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I am already 11 years old, and I want a job.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They offered me food.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I was hungry, but still I said, no.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I'm not going to take any food unless you going to give me a job.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "So they-- who's going to hire a kid to work?",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Finally, I went so far till I found a man who was very intelligent, and he listened to me from where I coming from and everything.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I told him the story that I haven't got where to stay.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I didn't-- my brother threw me out.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I told him the whole thing, the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And he said, OK, take a-- I sent for food to-- you should eat something.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I'm sure you're hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I said, I wouldn't eat unless you give me a job.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He said, take the broom and sweep the floor, and I moved away everything from the corners.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I said, oh, it's so good that I-- he should give me the job.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Then I finished sweeping.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "He says, now you're going to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "OK, now I'm going to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "The first time in my life I had food enough what I wasn't hungry no more.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Eggs-- he gave me whole-- he sent into a restaurant and they brought in all kind of food-- bread, and butter, and eggs, and salad, and everything you-- tomatoes.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- the first time I was-- ate till I not hungry no more.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It's was Shayek--",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Mine--",
      "word_count": 1
    }
  ],
