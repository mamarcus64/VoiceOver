  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And although, legally, my parents could have kept her, and my mother was a very religious person and a righteous person, and she felt that perhaps it would be best that she go to live with her aunt.",
      "word_count": 38
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "Her aunt kind of appealed to her religious fair being, I guess, if you will.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Aviva, and first name is still Aviva, A-V-I-V-A.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "That's her first name.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And her maiden name was Feldman, F-E-L-D-M-A-N.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And she has a family now.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She lives in Israel, and she has her own family.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And her married name is-- last name is Morami, M-O-R-A-M-I.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
