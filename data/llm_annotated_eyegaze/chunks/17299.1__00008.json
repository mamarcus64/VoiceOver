{
  "stem": "17299.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 214.1,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And then I worked for the reclaiming and recycling company for nearly a year.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Really, the change after Rosh Hashanah in 1941 when we have to wear the Star of David.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "A cloth, yellow, with the Star of David printed in black, and then the German word for Jew, 'Jude,' was printed in, and you had to wear on the left-hand side of the vest.",
      "word_count": 34
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "On the outer clothing only.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And we were restricted.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "We had to be in the house at 8 o'clock in the evening.",
      "word_count": 13
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "You could not go out, and you could not leave the town unless you had a permit from the Gestapo.",
      "word_count": 20
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "The next action was that in December beginning-- no, end of November, 1941, we got notified we would be deported to Riga, Latvia, for to do work over there.",
      "word_count": 29
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And at the same time, my parents got told, since they're over 60 years of age, if they want to they can stay back, but my parents decided to go with us.",
      "word_count": 32
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "It did not come in a form.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "We were told to come to town hall to the police department there, and the fellow who was in charge there and also representing the Gestapo read us that we would be deported.",
      "word_count": 33
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "That we would be able to take 40 pounds of clothing along, plus blankets, and our food cards would be validated for six weeks so we could take additional food along.",
      "word_count": 31
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "We could take eating utensils along, and that was it.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "When we got the notice, my brother and I myself wanted to get married because we both were engaged.",
      "word_count": 19
    }
  ],
