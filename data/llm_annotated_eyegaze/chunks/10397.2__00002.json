{
  "stem": "10397.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But in general, it was a very close family.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It was  a big family.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But I remembered the wedding-- [?",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Faiga-- ?] Fanya-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Faiga. ?] And she married-- she was tall.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Her husband [INAUDIBLE] was through a broker.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "She was old maid.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And she was the only woman who kept house for my grandfather until he died in Radziwillow.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And she-- she couldn't get married.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "She didn't have much money.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "She was not-- she [? get ?] a lot of brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "The brothers eventually got together and married her off.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "But they brought-- brought a husband for her.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "He was about three feet tall-- shorter than she or two feet shorter.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "It was funny when they walked around on the street.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "He was walking on the tip of the toes to hold-- be able to hold her under his arm like it was supposed to be.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "But they are-- they're very wonderful family.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "22nd of May-- 22nd of June, 1941.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They invaded Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And yeah, it's-- in 1939 September.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "That's when I was in Otwock working.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I remember it was the 7th of September.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They invaded the 1st of September.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And by the 7th of September, they were bombing Warsaw and bombing Otwock.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I was helping the chest surgeon with an operation.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And suddenly, the lights went out 11 o'clock in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And bombs started to fall because there were sanatoriums, tuberculosis mostly.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "They were pine woods.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And there were was a sanatorium for children.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "There was a military sanatorium.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "There was many private sanatoriums and resort-- and resort houses, you know, where people came in from Warsaw after a six-day work.",
      "word_count": 22
    }
  ],
