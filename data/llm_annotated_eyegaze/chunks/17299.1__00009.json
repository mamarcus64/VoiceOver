  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "My oldest brother got permission to get married because there was one official in the town hall where he was living was very friendly to the Jews despite the Nazis, and he got the Gestapo gave the permit for one to be married.",
      "word_count": 43
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "And they could get married within three days in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "Otherwise, it takes two weeks to get the permit.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "So they got married on December 6, 1941, and four days later, we got deported.",
      "word_count": 15
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "The Gestapo denied it.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "December 10, a policeman took us to [NON-ENGLISH], on a train to Dusseldorf, to the cattle house of the slaughterhouse.",
      "word_count": 20
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "We were received by the Gestapo and treated like cattle.",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Everyone was frisk, and anything what the Germans thought was good for the war effort or things what they figured we didn't need was confiscated.",
      "word_count": 25
    }
  ],
