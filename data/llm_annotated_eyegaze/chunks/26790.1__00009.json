{
  "stem": "26790.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And somebody give to me a few schillings.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And from that on, you see, I was like that.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "How do you like it?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Oh dear, again, again, again.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Please don't force me to try.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Don't force me, please.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Let me-- give me a chance.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Give me a chance.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "I'll say it's already after 10 o'clock.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "You finish, it should be 12 o'clock.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And I will have the time to tell you everything that is important, important.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "Spiegel-- let it-- Spielberg-- let him-- if he will listen to this-- to this video, he will find out the way we were living.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "I think that I am the first man which you are interviewing, what you are listening to some stories like that.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "I'm [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "Because I say the truth that was.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "I'm not ashamed.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "You saw the film, You saw the film, You saw that-- Tevye, Tevye the milkman.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "He was saying, I'm not ashamed I was poor.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "I'm not ashamed I was poor.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "He was saying, I'm not ashamed I was poor.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "It's not my fault.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I haven't got it, go head.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "You ask me again the questions.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "The life of apprentice?",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I started working, the first day-- the first day I got 10 cents from the boss, wages, 10 cents, 10 grosze.",
      "word_count": 21
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I saved that 10 grosze until I got 2 zlotys, 2 zlotys, 2 dollars, something like that.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "The first two dollars I went with my mother to a second-hand shoe shop.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And I bought my mother a pair-- a pair of second-hand shoes.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Because the shoes she was wearing, they wouldn't-- the shoe repair didn't want to repair, because they cannot repair.",
      "word_count": 19
    }
  ],
