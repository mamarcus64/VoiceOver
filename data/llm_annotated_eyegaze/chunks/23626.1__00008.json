{
  "stem": "23626.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I-- I just came from school, [PAUSES FOR 4 SECONDS] and we were playing in the street.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, it was my-- you know, school, the public school, was over already.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "But I was still going to [INAUDIBLE], which was a Jewish school.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I-- I was playing with my friends and we heard the march, and [PAUSES FOR 3 SECONDS] I found out I hear the Germans are here.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "They just marched into Poland, to Cracow.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] But nobody expected anything will harm us.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I-- just the usual.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I mean, nobody expected anything goin' to happen to us.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Excuse me.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] They hunt for the Jews in the streets-- easily recognizable because we had to wear a yellow Star of David-- yellow armband-- Star of David on our arms.",
      "word_count": 32
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Removal of the armband was punishable by death.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] They forced us to clean their homes, barracks, offices, clean their cars, sweep the streets, shovel snow later.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "They enjoyed seeing very well dressed women to do very heavy work, and they forced very religious Jews to pray and sing and dance in the streets while they were cutting their beards and their earlocks.",
      "word_count": 36
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "New regulation came out limiting free movements for the Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] We were not allowed to use public transportation.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And we were not allowed to use any educational facilities.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Everything stopped.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] All the synagogues were turned to barracks and warehouses.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "All the beautiful belongings were stolen by the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "All the large businesses-- big businesses-- were taken away from Jews, with the exception of small stores like coffee houses.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "Small businesses.",
      "word_count": 2
    }
  ],
