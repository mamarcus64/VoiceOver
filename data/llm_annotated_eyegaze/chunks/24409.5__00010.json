{
  "stem": "24409.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We will have-- make a trip for 2,000 people, a big ship.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And for this, I got in touch with people whom I knew in Romania.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And they told me, you can get a ship for 2,000 people.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But they want 3,000 pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember how much.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I believe it was 2,000 pounds advance payment in order to come through the port of Sulina.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I was ready to take 2,000 pounds there.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Robert [?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Mandler ?] I had a cousin of mine who was a real go-getter, a very capable businessman.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Not a Zionist, they called him a Zionist.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "He was only a businessman out for money.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I had met him, put him in the charge of our [INAUDIBLE] in Slovakia.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And he organized the transport without a ship yet.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And then I told him, I have a ship, but I don't have the money.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "He said, Eichmann is after me.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "I have to send the people out.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "He called me.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "He thought we might come take him. then.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "Because he gets him to Romania, and the Jews in Romania were safe for the moment.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "But the only thing is, they have to get on the ship.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "So I told him, I can have a ship.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "But I don't have 2,000 pounds.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "He said, I have the 2,000 pounds for you.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "I was sitting down.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "He was only appointed two months ago.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "And he had 2,000 pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "The guy had succeeded to get from the Czech puppet government under the auspices of the German, the permission to get every for every Jew who leaves Slovakia a certain amount in foreign currency.",
      "word_count": 34
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "I see, I see he got very much money, of he made very much money on it.",
      "word_count": 17
    }
  ],
