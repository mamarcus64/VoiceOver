  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] The older people went in one side, the kids in another side, the middle-aged people came in another side, and the young kids came in another side, like in four-- in five places.",
      "word_count": 37
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "My brother was in another place, my brother-in-law was-- men-- men-- men were separated.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Separated, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Women were separated with the men.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I never saw anybody again.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We went with the young people.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was written Majdanek concentration camp when we walked in.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Majdanek, really not concentration camp, but Majdanek.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I didn't see anybody anymore, just with the young I went.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "There were kids I think from 13 till 20, not any older ones than that.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Just girls.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And they took us to a place where stood a lot of Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We went like in a alley.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In an alley.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "There were little rooms like you have for dogs or for-- for horses, little rooms.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Stalls, right.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Just doesn't come in the right time.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And they took us like 20 at the time, 20 in one time.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And at every 21, it was a German at the beginning and a German at the end.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And as we started walking, they started saying, dresses off, [? and we threw ?] the dress.",
      "word_count": 17
    }
  ],
