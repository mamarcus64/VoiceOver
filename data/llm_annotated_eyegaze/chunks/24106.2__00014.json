    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "But soon as I saw the people, young people, in their '20s, I said, OK.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "No problem.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "We'll do fine.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "And then, I go with my-- with my youngest son.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "He has a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "We're going there for the-- for the 22nd of November till the-- 22nd till the 27th.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "And, there's everything in Yiddish there.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "So I'm also-- I'll teach them how to cook and how to-- sometimes I sing for them some things I'll-- It's-- it works out good.",
      "word_count": 25
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "I do my time good.",
      "word_count": 5
    }
  ],
