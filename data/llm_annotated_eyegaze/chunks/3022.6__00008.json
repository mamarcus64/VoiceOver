{
  "stem": "3022.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And eventually, I went into a partnership with somebody who was in the camp was me.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And the machine shop was in Brooklyn and then eventually moved into Jamaica.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And I came-- in 1968, I moved in from New Jersey to West Hempstead, where I'm presently residing with my beautiful wife.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My children-- we have two sons.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The older one is 37, he's an attorney.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He's married, he lives in Santa Fe, he's got a year and a half old son.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "He's very much involved in pro bono work.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He works for the Native Americans without pay, represents them.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "My younger son graduated Union College as a political science major.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "He spent one year as an intern in Albany, one year in England as an aide to a member of Parliament.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "He was responsible for re-election of this member of Parliament.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "He instituted American campaigning methods.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "One year he spent in Washington, working fro a Congressman.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And his senior year, he wrote his thesis and he graduated from Union College.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And he was selected from among many applicants to be one of the 48 Coro candidates.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "The Coro Foundation is an organization that trains people for work in public service.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Many of our senators and dignitaries are graduates of it.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "Senator Feingold-- President Bush and Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Buchanan were turned down.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "They were not qualified to get into that particular program.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "By the way, Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Bush was honored, I think, by the Coro Foundation, about three years ago.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "He spent one year in St.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "Louis as a trainee.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And then he volunteered for one year of working for the organization in Los Angeles, where he created a program for high school children, from mostly Chicano sections, where he took 12 children every three months, and he trained them.",
      "word_count": 40
    }
  ],
