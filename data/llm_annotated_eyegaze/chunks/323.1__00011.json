{
  "stem": "323.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We didn't get food-- we didn't get--have enough food, because we didn't get, you know, the ration cards.",
      "word_count": 18
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "My mother, we had chickens in the backyard, so we could have some eggs.",
      "word_count": 14
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And we had to make do of what we had.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "More and more people were deported to the various concentration camps.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "Fewer and fewer Jews were left.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have a temple anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have a school anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "My father got me a job, because he didn't want me to hang around just at home.",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "At the time, I was maybe 11 or 12.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "And I got a job as a messenger for a German firm.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 11,
      "text": "They made ties, a tie manufacturer.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 12,
      "text": "And I delivered things, [BACKGROUND NOISE] just to keep me busy.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they paid me.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "They even paid social security for me.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "I mean, this is amazing.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And now I'm getting social security from Germany because of that.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Josten.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "J-O-S-T-E-N.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Josten Company.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "About a year.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And they were not Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And they also-- you know, there was risk involved in hiring a Jewish kid.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "But they did it anyhow.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "There was-- they had about one or two people working in the factory.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "But there were hardly any Jews left.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "Towards the end, we were three families left, four.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, not really.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know that there was-- [BACKGROUND NOISE] [PAUSES FOR 3 SECONDS] we didn't know that there really were concentration camps the way-- we thought they were going into a ghetto and just lived together in ghettos, as I-- you know, learned before about Polish ghettos and things like that.",
      "word_count": 50
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't think there were any extermination camps or anything like that.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "You mean before Hitler?",
      "word_count": 4
    }
  ],
