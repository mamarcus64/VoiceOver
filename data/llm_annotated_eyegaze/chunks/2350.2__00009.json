{
  "stem": "2350.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And then when it was raining, those shoes got stuck in the lime.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And we couldn't get them out.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "We came up on the-- on our bed, there.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I have to say bed.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how to explain this-- the [NON-ENGLISH] they call it.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And the shoes and the feet were with lime.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "They were drying out at night.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "We were to scrub off the, the dirt from the night.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "We didn't wash.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "We didn't brush our teeth.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "We didn't have-- we had two meals a day.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "In the morning, a little [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "And then in the evening, a, a portion of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And maybe they gave you a tiny little salami liverwurst and, and the little soup that was like the dirty water when you wash the dishes.",
      "word_count": 26
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "That was black water with maybe one bean or something in it.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And that was the food that we lived on.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And people were fighting for it.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I was just, just, what's gonna be the next?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "What's gonna be my end?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "How will it feel to die?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Or, or how will I ever die?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And the winter came.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And we didn't have warm clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They gave us warmer dresses in the stripes and the shoes.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And we were staying day in and day out on the Appells in the morning.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And it was cold and frozen.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And somebody was missing.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And we stood maybe for five hours, completely-- the people were falling down freezing from the cold.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I was holding my older sister next to me.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And she was-- when after the countdown was done, they let us in into the barracks, I lay down on top of her.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "With my body, I warmed up my older sister.",
      "word_count": 9
    }
  ],
