{
  "stem": "21089.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Somebody-- people ask me what, what, what kind of impression I had from his talk.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "The closest I can come, when, when I see a monkey in a cage and screaming and jumping and running and gesturing with the hands, this is the closest what I can describe how he behave, how he talk and the message that you screamed.",
      "word_count": 45
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he had all these youth on his own side because every talk was to the youth.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And he had the youth on his side because he promised them, and he was studying them.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Austria will be part of Germany, and he liberated Austria.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And the routine of speech, which he had always in other-- all other countries.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Actually, this was when-- March 15 was Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And we supposed to-- this was a-- Saturday was a half day work, that day.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "At the Institute, we had only art classes till noon, and I supposed to go.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "In the morning, I wake up, and the whole city was covered up with little swastika-- die cut from newspapers, like snow-- and excitement and big signs.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Already signs were before, but we expected something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "But big swas-- swastikas and Hakenkreuz all over.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And Nazis had been marching in uniforms.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And German police and German troop-- and German ar-- army was marching, patrols.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And youth also in troops screaming slogans.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And the music was martial music all through the-- all the mic-- microphones, over the, the radios, and all German martial music.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "A festive occasion-- everybody was excited.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "The real Austrian, the real patrio-- patriots, they realized that they lost their freedom.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I can't hear you.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The, the Austrian, the old Austrian people, the Aus-- because they realized that the German youth took over Austria.",
      "word_count": 19
    }
  ],
