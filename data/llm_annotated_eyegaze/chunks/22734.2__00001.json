{
  "stem": "22734.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "When I was nine and a half and I went to the gymnasium, so the first [PAUSES FOR 3 SECONDS] time I was allowed to go alone on the streetcar.",
      "word_count": 30
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And then I walked alone to school, which was also a miracle of miracles, [PAUSES FOR 3 SECONDS] after I was 10.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Until that time, even-- it to the grade school, they walked me and picked me up.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] So that was that.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I belonged to Girl Guides, and I liked it very much.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "But they sent me one year also, just before I went to gymnasium, to a Girl Guide camp, and I hated it from the bottom of my heart.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Really hated it.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Slept in tents.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I didn't hate it because of the tents.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I hated it because I had no friends there.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was a completely new group, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And girls are very cliquey.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "So it was not a success.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "How did your family spend holiday time?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, my father-- if you notice that my father never spent any of his leisure time with us, and never on any of his holidays with us.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So-- and so it was always my mother and I.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And sometimes we would go to the mountains in Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And sometimes she would take me to Austria and to Italy.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was very nice, very, very nice.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Once my father met us in Austria, in Salzburg, for-- for a week.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "But-- and they were long holidays.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "They were nice holidays.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And then-- [PAUSES FOR 3 SECONDS] but I was little, you know.",
      "word_count": 12
    }
  ],
