{
  "stem": "393.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "There were a few lucky who lived through that.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "Over there, that were the necessary thing.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And I think that's the end of my life, too.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "I lost my mother, of course, and my father, and I lost Moisha, and [?",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "Raisi, ?] and all my uncles.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "I had seven aunts and uncles.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "I had I don't know how many.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "Because there were big families that time.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "I don't know how many cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "I tried I once to figure out.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "I always forget the number.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "It really doesn't matter one more or less.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "Maybe it matters for that one.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "I lost all my friends, my neighbors.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "I went back to my hometown, to that little town where I growed up.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 37,
      "text": "You know, the whole town looked liked a cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 38,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 39,
      "text": "Nobody was there, the families.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 40,
      "text": "And I had some young friends who got married before me.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 41,
      "text": "Because they were very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 42,
      "text": "But they didn't survive.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 43,
      "text": "Because they had the children.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 44,
      "text": "You see, who had children didn't survive.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, what bothers me most-- those who dare to tell that wasn't a Holocaust.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "How can they tell such a-- that bothers me more than anything else, if I hear that.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Sometimes I hear it on television.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I-- I-- am aghast.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "You know, what do they think?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Where are those people?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Where are all those-- where is [?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Warsaw, ?] where millions of people, even-- the whole Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "You see, where are those people?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We were-- where are the mothers?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Where are the children?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "Where is everybody?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Not one of my uncles survived-- not one of my aunts.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I had seven or eight.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And of course, the children.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And even the grownups-- you had to be very strong.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "You had to be strong, bodily.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "You had to be strong--",
      "word_count": 5
    }
  ],
