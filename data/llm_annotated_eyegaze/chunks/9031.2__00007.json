  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "They don't know who kids is that, but they like to help them.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And the kids, when they came back from-- to Kovno, the fathers and the mothers, they was killed.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And the old kids, they hold it in this place to help them.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I was in the-- was there.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And later on, they open a Yiddish school for us.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "They're learning us only Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And they try to-- to be happy to us.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And they try to tell us, you must be happy.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "You survived.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And later we do a lot of things.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "We was open songs, clubs, and to play on the piano-- to be happy.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Two years.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "When I was in ghetto, when we have the school to learning Lithuanian, we have a couple songs in ghetto too.",
      "word_count": 21
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "In ghetto, the people, they like to remind the people about happiness.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they do the words what happening in ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And we was kids.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "We grew up like that.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And we would sing songs in the school, in ghetto--",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "--a lot of songs.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And after the war, we was-- can-- we was-- have a big club.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And we talked to people.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And we explained to people.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And we sung to them a lot of Yiddish songs from ghetto.",
      "word_count": 12
    }
  ],
