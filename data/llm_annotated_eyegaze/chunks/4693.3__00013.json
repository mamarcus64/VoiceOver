  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "The next thing, towards the end of the war, I got a Russian major who was second in charge of the financial department of the Polish army, and I got for him a leave and sent him to Russia, to Bukhara, to get my wife.",
      "word_count": 45
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I arranged with a Russian colonel, who was in charge of a transportation unit, that if they bring him to-- her to the border between Russia and Poland, he will put a Russian uniform on her and bring her in a truck over.",
      "word_count": 44
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But the guy did stupid things, this major, and he was for a few months away.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "After a few months, he came back without my wife.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "He was asking the security service for a visit to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Security service told me we can't give any visas to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "This is the foreign office can do it.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "So he was drinking all the time over there and then he came back without her.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "We are still going through the war time, yes?",
      "word_count": 9
    }
  ],
