  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "But we learned through that, we had a radio, which I had manufactured myself, one of those wire coils with a sliding contact on top.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Later on, of course, we had a regular radio.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "But that was still early in Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "With the lamps, the-- the tube radio.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And the newspapers in Vienna were very well-informed.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "So it-- we knew that Hindenburg, being a senile old guy, couldn't do it anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And he appointed Adolph Hitler as chancellor.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In that-- in that respect that in our apartment house, in a sub level room was a storage and a small store.",
      "word_count": 22
    }
  ],
