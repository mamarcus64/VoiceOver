{
  "stem": "150.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But I know that my Larry, who was a child of a survivor and was married to a child of a survivor, that marriage did not work out.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Whether it's my fault or Hitler's fault, I don't know.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The one in Pittsburgh I talk to on the telephone maybe once every couple of weeks.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He is much closer to his mother than to me, always has been.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Just worked out that way.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "The one who is here, oh, we see each other, like, every week or so.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "The relationship-- we like and respect one another.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I really can't say that we have the really warm, huggy, touchy feely relationship.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "It's not my nature.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Maybe that, too, has somehow been destroyed within me.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And maybe somehow-- I've thought about this a lot, why it is that I have-- I make-- it's so much easier for me to relate to groups than it is to individuals.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I'm totally comfortable speaking before 100, 150, 200 people.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I'm not all that comfortable developing a one-to-one relationship.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I'm not a very warm person, and I'm aware of that.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And I think that conceivably, maybe there is something in the back of mind that is afraid that if I get close to somebody, they'll be taken away and killed.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And things have happened in my life [PAUSES FOR 3 SECONDS] where a a number of people died that I held very dear.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And you know, and each time, I guess it reinforces it.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "It's a stupid way to live, and it's a stupid way to-- and I can't help it.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My mother died 12 years ago in Los Angeles.",
      "word_count": 9
    }
  ],
