{
  "stem": "27351.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She had maybe three, four years of school and started working at a young age at a factory of dolls.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "It was celluloid dolls.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She, at work, met a young man-- not a Jew, a young, Christian Pole, and it was a great love of, but, of course, there was no way for her family to accept a Pole.",
      "word_count": 35
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So around the age of-- I believe she must have been 18 or 19, just before the end of the second-- the first World War, she left her family, and she lived with this young man.",
      "word_count": 36
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The family said shiva, as if she died.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I never knew my mother's family.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "She never had any contact with them anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "At the very end of the first World War in 1918, the young man was in the street and he was killed by a stray bullet.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Of course I never knew this story before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I mean, when mother was alive.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I only learned it after the war when I met a former friend and the neighbor of my mother's family.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And she, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "[POLISH] was-- knew a lot about my mother, and she told me this story.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had a brother who was 4 and 1/2 years older than I was.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "His name was Heinrich-- [POLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He was born in 1924.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So the-- the three of us-- I mean, as far as I can remember, my-- my father did not live with us.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "He was in Warsaw, and we would join him as a family only during school vacations.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "So every summer vacation, all three of us would go to Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And sometimes when there was money, they would rent a little place in the country close to Warsaw.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And this is when we were together.",
      "word_count": 7
    }
  ],
