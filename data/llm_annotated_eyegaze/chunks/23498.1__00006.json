{
  "stem": "23498.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "For instance, my grandmother was so clever that she sent all the daughters to the high school, Polish sort of-- Polish high school.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "The intention was that-- that if they go to a Polish school, they won't meet boys.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "Because they never, never will go with a Polish boy out.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And if they would go to a Jewish school, that was when I heard of it.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I thought, she must have been very clever in her way.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Because I don't approve of it.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "That doesn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But it was really very philosophical.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "So therefore, they-- they were very modest and very beautiful girls.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And they were all married before the war, except one, who was a beauty.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "She was a brunette, really beautiful.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "It's a pity I didn't prepare-- I've got one photo from before the war.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, so during the liquidation, she went after her parents.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She was so attached to her parents.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "She went to Umschlagplatz after her parents.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Actually, not me.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Because I was already used to sort of antisemitism.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I didn't feel it on myself so much.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "All my friends were-- nearly all my friends were Polish, except friends from the school.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't bother about it.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "It was my country.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "I was living there.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I was very patriotic.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "I remember when Pilsudski died.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "You know, I was crying.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "It was my hero.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "It was my country, and I loved it.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "I would never, ever emigrate it.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my father.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "My father.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yes, my father--",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I am not-- I don't know exactly.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Because I heard later on.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "He was-- yeah, it could have been '37, '38.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "My father predicted, sort of, this thing which came after.",
      "word_count": 10
    }
  ],
