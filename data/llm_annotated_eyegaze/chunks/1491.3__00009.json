{
  "stem": "1491.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And they brought it to me to save my eyesight.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Did you see him personally during that time?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I saw him, but I never talked to him.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I never got near him or anything like that.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No, I would be afraid to go over to-- whom am I to go thank him?",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But the people who appealed in that or from the clinic, I don't recall how it happened.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And he saved my eyesight.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I used to see him coming to check-- I always work on the night shift.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Because here on the night shift, late at night-- in the evenings I used to knit, then I used to go on the night shift because I used to get extra plate of soup.",
      "word_count": 34
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] They were-- you were hungry.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "You were hungry, but maybe other people were-- were near Schindler, or they knew, whom you knew too, you know, people in kitchen.",
      "word_count": 23
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But we were very helpless.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Otherwise, I wouldn't have knit those sweaters.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "But you could live on the ration.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "I mean you didn't die, but you could live on it.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "He gained 700 places they gained in Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "When the men were sent away?",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Were sent to-- to-- to Mauthausen.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "This I remember, my mother-- he was shocked, Schindler, when he saw different men.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And he says, where are my men?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And my mother went over to Schindler to bring my father.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And he-- he had the list to bring the men back.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "From Mauthausen.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "But once he got there-- Mauthausen was the main concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And they had little camps, so everyone was sent to a different camp.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Ebensee-- [PAUSES FOR 3 SECONDS] I forgot the names.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They had quite a few-- Melk-- quite a few little camps.",
      "word_count": 11
    }
  ],
