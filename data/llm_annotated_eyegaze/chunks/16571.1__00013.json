    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And really and truly, when we got to Auschwitz, it was-- the-- the doors of the trains opened.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "Everybody out.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And leave your luggage.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "Everything will be taken to your rooms, and all the rest of it.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "So it's-- it's hurt to me even now to think that-- that the parents were thinking of, obviously, for the best.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "But that's how we were deceived.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "Because, you know.",
      "word_count": 3
    }
