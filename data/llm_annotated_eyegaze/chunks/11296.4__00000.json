{
  "stem": "11296.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So they found all the girls and nobody-- I don't know, the other girls was talking.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "These other girls stayed in the same new place where I stayed.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And Rosa-- Rosa they took to-- direct to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They had there a jail.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And-- but afterwards, we had what kind of trouble they gave her.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "She was beaten, she was electric shocks they gave her, and she didn't squeal on nobody.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So this was [PAUSES FOR 3 SECONDS] a few weeks after everything.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Really I lived in this-- this place, I was maybe six weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So this was--",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In this new--",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In the new place.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And this was in January.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We came back from work.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And we were staying in appell-- this calls appell.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They was counting us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And this-- and there was the gallows.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "It was already ready.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "They brought in Rosa.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I don't remember there was another girl.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I remember Rosa because I knew Rosa from-- from the place, and I talked to her very often.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "She's not far from my hometown.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And she was walking high with her head.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Just like today, I remember she was wearing a black dress.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And she said to us in Polish, [SPEAKING POLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "This means freedom.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And hold your head high.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And there was already the lights on.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "Around the-- around the-- the-- the camp was lights.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And there was a man standing.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "He was, you know, he was a man from the concentration, too.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "His-- his job was to hang people.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "They-- they assigned him this job.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "He had to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "And they hanged-- we saw it.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "We had to stay so long till they hanged this Rosa.",
      "word_count": 11
    }
  ],
