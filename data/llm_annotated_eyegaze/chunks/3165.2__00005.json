  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] The Gestapo-- actually, at first, it was the Ukrainian police, got my two sisters.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Somebody told them where they were hiding.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "And they picked them up from this house and they were taking them sort of towards the city.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And on the way to the city, they saw a ditch, this Ukrainian police, [PAUSES FOR 4 SECONDS] which they were like the Germans in uniforms.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And they saw this ditch, and they told my-- my-- they stopped, and they told my sisters to get out, to get undressed, and to go into the ditch.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "They shot them there and killed them.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And this is what this lady told my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And I'm listening [PAUSES FOR 3 SECONDS] how they were killed.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "So now just my mother, my sister, and I, my youngest sister, and I, left alone.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] And again, my mother-- I don't know how she-- you know.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "She still tried and still hoping that-- that maybe the two youngest ones will survive.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "She just told us, pray, kids, pray.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "God will help us.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "[SOBS] [PAUSES FOR 4 SECONDS] Of course, after that, these-- these women didn't want us anymore.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "They told us-- told my mother, you have to go and look again for other places, because we cannot stay there anymore.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "My cousin was hiding in a different place.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And after that, I haven't seen him.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "[PAUSES FOR 3 SECONDS] And at night, my mother would go out and find another place, and then we've have to go there.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And-- and this Ukrainian peoples would keep us-- I don't know-- two, three days, and tell us to go-- to go, we must go.",
      "word_count": 24
    }
  ],
