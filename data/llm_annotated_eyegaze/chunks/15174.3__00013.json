  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "And we went in and she had-- she saw us and she welcomed us.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "And she took us in.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "She had a fire going.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "And when my feet warmed up again, I-- I-- I didn't realize-- my mother realized, because I kept telling her my toes hurt, that they had been frostbitten.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "And fortunately, it wasn't a severe frostbite.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "But-- and so nothing happened.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "Except that, even today, when I-- when it's very cold outside or when I go skiing-- when it's gets very cold, I can feel those toes that were frostbitten.",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "I still-- they still hurt when they get really cold.",
      "word_count": 10
    }
  ],
