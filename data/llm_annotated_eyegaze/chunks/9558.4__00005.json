{
  "stem": "9558.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And the people were screaming and yelling.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And they went on the loudspeakers.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "They was not going to join.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH] was not going to join.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "He says it's going to be shot.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "It's going to be-- eat up alive.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "We had no other choice.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "We went ahead and we joined the group.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And this is how the death march started.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, thousands, I think.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was told that it was 14,000 to 15,000 on that march when we started up.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We walked from Poland to Germany to Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We walked out January the 18 from Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Schindler came--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "--on March 30, something like that, 29, because I know I was about five weeks--",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No, no, by Schindler.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was on the march.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "From January 18 to March the 29, 30.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I think by March 30, we were 150 people out-- [PAUSES FOR 3 SECONDS]",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Whoever couldn't walk, they shot him.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My friend from Toronto helped me a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Without him, I wouldn't be around.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I helped him.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "He helped me.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "With snow.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "If you walked into-- walked through a town, if the mayor was a nice guy, he used to cook some soup.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "More people died going, getting the soup, than to live without the piece of soup.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "In the beginning, I was strong, so I carried a hop sack for a German, for the SS men, so he used to give me a piece of bread.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Or when they cooked some soup, so I used to tell them, I don't want to go there.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "So he tried, and he brought me a little bit of soup there.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "In the beginning, I had a pair of shoes.",
      "word_count": 9
    }
  ],
