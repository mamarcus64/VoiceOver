  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I brought them some food, which I got the food from my coworker, the meister, the Polack, his wife.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "He brought himself food.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "He brought me also.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He brought me too.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I paid him for this.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So I brought it-- I brought it to my father and mother, to give them a little bit, that they should have what to eat.",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "They didn't-- they didn't have food.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Well, he didn't ask me if it's kosher or non-kosher.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And at this time, I said to my father that, you are sitting and studying Talmud.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Is this any help of you?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Does this give you any satisfaction?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "He says, Moshe, who knows?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Maybe you are right.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I don't know any more.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Because he saw what was going on and what they were doing with the Jews and with the children and with the beautiful children, with the-- maybe, he says, you are right.",
      "word_count": 32
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "And it didn't take long.",
      "word_count": 5
    }
  ],
