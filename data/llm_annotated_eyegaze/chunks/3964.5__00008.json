  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 138,
      "text": "[PAUSES FOR 3 SECONDS] It was just like [PAUSES FOR 6 SECONDS] a terrible nightmare.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 139,
      "text": "[PAUSES FOR 3 SECONDS] The SS came in and just [PAUSES FOR 5 SECONDS] killed people left and right, beat them to death, shot them to death.",
      "word_count": 27
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 140,
      "text": "[PAUSES FOR 5 SECONDS] I-- I have a feeling that they were drunk [PAUSES FOR 3 SECONDS] and came back from their party or whatever and just went through the camp we had there.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 141,
      "text": "Weren't too many people there, probably about 120, 140 people.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 142,
      "text": "[PAUSES FOR 4 SECONDS] And [PAUSES FOR 4 SECONDS] the next morning they hauled all the dead bodies out of the barracks.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 143,
      "text": "And those who were still alive and on their feet were assembled.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 144,
      "text": "I was one of them.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 145,
      "text": "[PAUSES FOR 3 SECONDS] And we all marched out to the harbor.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 146,
      "text": "On the march from Danzig to Rehagen, [PAUSES FOR 3 SECONDS] we probably lost half of the people which started in Stutthof.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 147,
      "text": "[PAUSES FOR 3 SECONDS] Couldn't continue marching, walking, or killed on the wayside, died on the wayside.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 148,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And of course, the thought always went through your mind, when it's your turn.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "You going to be next?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Do what you can to stay alive.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I always used to say that to myself.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Do what-- do what you can to stay alive.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Maybe you'll make it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Make it to what?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] We had no idea.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I had no idea what was going on.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I had no idea about that the end of the war was imminent.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I had no idea that there would be another world for me, there would ever be a world for me.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "So you're just fighting [PAUSES FOR 4 SECONDS] against dying.",
      "word_count": 10
    }
  ],
