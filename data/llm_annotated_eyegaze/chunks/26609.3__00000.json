    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And she took me along.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "She grabbed me by my hand, took me with her.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And people made me sing there-- a little girl of six singing Hebrew songs.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I didn't know the Hebrew language then.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "I don't know if I didn't mix it up, but I sang in, [INAUDIBLE].",
      "word_count": 14
    },
    {
