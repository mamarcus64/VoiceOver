    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Hashomer Hatzair ?] [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I remember I was only six years old when my daughter-- because I could sing.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And my eldest-- eldest sister was [?",
