{
  "stem": "25287.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "You know, to-- because we don't have it nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "So I went to buy this cup, and he was at the coffee shop.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "After that, I just think about in Auschwitz or when we came back, maybe he meant that I should disappear.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "You know, he went to the coffee shop.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "I went to the store.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "He had many [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "How can I disappear, leave my older parents and sister in the temple?",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "So I went to the coffee shop.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "Tell him we can go back to the temple.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 4 SECONDS] You know, it's-- it's-- I'm not regret, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "Because I would be so guilty, then I would-- you know.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "So from the ghetto-- in the ghetto was baby born.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "People died.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "There was wedding.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "And then there came some news that we're going to go other side of Hungary to work.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "But cannot take more than 3 kilogram.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 44,
      "text": "So we pack and [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 45,
      "text": "And things people came where we lived with many other people to cut the blanket to be small to able.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And [NON-ENGLISH] was when [? order ?] was.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And day before, I went visit my cousin and uncle.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And next day, they disappeared already.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They went the second transport or-- or went we went the third.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I cannot remember.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we needed to go to the cattle wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "About [INAUDIBLE] how long.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "From Pesach till [NON-ENGLISH], that's two months, or maybe a month and a half, or two months.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was a gate.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Not-- not only gate, a fence.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "People went under the fence, came back.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "For instance, my first cousin wife.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "My first cousin was killed but the wife with four children one night disappeared.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The husband from Budapest sended down somebody.",
      "word_count": 7
    }
  ],
