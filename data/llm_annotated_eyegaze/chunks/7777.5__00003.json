{
  "stem": "7777.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "And I was sleeping over there by a guy, he was a tailor.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "Over there, my cousin lived upstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "So there was no place.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Putlepnik was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "I was sleeping over there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "And one day, I was on the truck, and I go to two Russian soldiers was, and I ask him if you have something for sale.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "They took me in to the commander.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "And they ask me.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "I told him I don't have what to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "I ask him maybe if they have something to sell to me to have to eat something.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "They let me go.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "They don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "Until long, they let me go.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "And I was on the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "I was all right until the truck was the Polish government was in Lublin, and the military was going [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "And they took later Sachsen.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "This was-- and I was liberated at 21.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "The 22nd of July 1944, and this was already in May 1945.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "It was liberated Sachsen.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 46,
      "text": "I went to Sachsen.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 47,
      "text": "On the train, when we went to Sachsen, I meet two young boys from Chelm, not far from our town, about 20 mile.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 48,
      "text": "We went together to Sachsen.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 49,
      "text": "And we come to Sachsen, they say that we was the first 11 people where they come into Sachsen, Polish people.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 50,
      "text": "We was three Jews and eight Pollocks.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 51,
      "text": "Over there, what we find that there are a room-- a lady.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 52,
      "text": "Downstairs was a little grocery store.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 53,
      "text": "Was empty shelves.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 54,
      "text": "I said, we open up a store with the two boys.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 55,
      "text": "We don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 56,
      "text": "I don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 57,
      "text": "They have little bit salad, bacon.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 58,
      "text": "They got about 10 kilos like this when we open up the store.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 59,
      "text": "Meantime, they start to bring in different things, the Russian.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 60,
      "text": "And the German were eating.",
      "word_count": 5
    }
  ],
