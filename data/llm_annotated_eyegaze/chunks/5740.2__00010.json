{
  "stem": "5740.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I got out of the-- I just-- you know, it wasn't yet a ghetto that you-- you-- you had to pass something.",
      "word_count": 22
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I just went out.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And I found a job in a German laundry.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "I was washing every day the washing that come-- came from the front-- full of lice, full of bacillus, full of dirt.",
      "word_count": 22
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "And I was-- there was no washing machine.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "There was no dryers-- scrubbing like this.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "And, of course, my hands got swollen.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "My feet got swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 9,
      "text": "And I was-- I was really pretty, pretty bad off.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 10,
      "text": "But I was young.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 11,
      "text": "You know what it is when you are-- you're one day not well, and then the next day you're well.",
      "word_count": 20
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 12,
      "text": "And my-- and I was able to bring some bread home to my family too.",
      "word_count": 15
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Outside the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Returned--",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "--every night to the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I most probably-- no, when I was going out of the ghetto, I wasn't wearing.",
      "word_count": 15
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Illegally-- illegally going out of the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I was illegally going to another city to give-- to bring food to the-- to the family of my boyfriend that lived there, to bring them news, even horrible news, that his brother and his sister-in-law got killed by the German.",
      "word_count": 41
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And one day, when I came home from this laundry, there was a man there.",
      "word_count": 15
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "And he-- he handed me a little note.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "And on the note was written, please trust this man.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "And I recognize my mother's handwriting.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "And my mother sent him.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "She paid him most probably lots of money, because he was a smuggler-- to smuggle me back to her, because between me and my mother was a border.",
      "word_count": 28
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 8,
      "text": "Where I-- where I was, it was called the German protectorate.",
      "word_count": 11
    }
  ],
