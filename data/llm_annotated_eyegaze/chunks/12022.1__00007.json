  "sentences_input": [
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 9,
      "text": "Ravel ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 10,
      "text": "Kruvski ?] from [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 11,
      "text": "He was a very good friend of mine.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 12,
      "text": "And there was some others I don't remember anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "It was very difficult.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "I'll give you a sample.",
      "word_count": 5
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 2,
      "text": "When I was a recruit and I come  in in the army, and my brother-- was a list from the same regiment, in the same unit, exactly.",
      "word_count": 27
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 3,
      "text": "When I-- when I come in, and they brought me in the lines, and that officer was reading the list from their recruits, and he find my name, and he said, that's the same-- that's the brother from the same Asner what was over here?",
      "word_count": 45
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 4,
      "text": "And somebody said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 5,
      "text": "Said, don't answer anything.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 6,
      "text": "I'll go by if I'll recognize you.",
      "word_count": 7
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 7,
      "text": "He come.",
      "word_count": 2
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 8,
      "text": "He was walking to me.",
      "word_count": 5
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 9,
      "text": "When he come to me, and he stopped, and he looked at me, he said, you Asner.",
      "word_count": 17
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 10,
      "text": "I said yes.",
      "word_count": 3
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 11,
      "text": "He said, you'll be like your brother, it will be all right.",
      "word_count": 12
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
