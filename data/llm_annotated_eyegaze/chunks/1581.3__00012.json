    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "We were stripped to our skin.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "All our clothes were taken away, and of course, all of our meager possessions which we still had.",
      "word_count": 18
