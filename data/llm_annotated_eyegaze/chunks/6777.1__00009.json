  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "You see, I've been a full-time student.",
      "word_count": 7
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 2,
      "text": "And I worked at the same time as a teller in a bank, because there have been two shifts.",
      "word_count": 19
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 3,
      "text": "The late evening/night shift, I've been a teller.",
      "word_count": 8
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 4,
      "text": "And at the same time, I have been studying full-time.",
      "word_count": 10
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 5,
      "text": "And being Jewish on top of it, you had to work really hard.",
      "word_count": 13
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 6,
      "text": "So there was not much time.",
      "word_count": 6
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes, because being in this Jewish hostel with the students-- you know what it is with students, as always.",
      "word_count": 20
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was quite evident that a war was coming.",
      "word_count": 10
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "I remember a demonstration in front of the English embassy in Warsaw when they declared that they support-- they come to aid of Poland.",
      "word_count": 24
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 2,
      "text": "There was a big demonstration in front of the English embassy.",
      "word_count": 11
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "For, because England has-- you know, they've been supporting the Poles against the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "They declared war to the Germans.",
      "word_count": 6
    }
  ],
