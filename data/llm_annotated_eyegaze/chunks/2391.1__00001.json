{
  "stem": "2391.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And it took them seven years before they could get married, especially since my father was a Cohn and he only wanted an Orthodox rabbi to marry them.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "So they-- he traveled all over trying to find a rabbi who would be able to do that until he found one in Budapest, in Hungary, where he was during a business trip.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And this Orthodox rabbi studied the Talmud and he found-- I don't remember what it was, but he said it's OK.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "He found a loophole.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And so my father sent a telegram to my mother, and he says, come right away and let's get married here.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "It's now or never.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And the family-- the parents didn't know, neither his parents nor her parents.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "So then when they were married, my mother did-- she said she was very scared.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "[LAUGHS] And when they were married, he sent a telegram to his parents that he just got married.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And my grandmother, surprisingly, did not put her head in the oven-- [LAUGHS] when she found out.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "And they went to the train station to meet them.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "And then she-- she hugged my mother and she says, well, I was against it, but it's done now.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "There's nothing I can do about it, so I accept you as my daughter.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she converted.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And she was actually very good.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She had a-- she learned for quite a with a rabbi.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And she was very good in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "She did-- I remember her helping me with the prayers when I was little.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "She knew everything.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "She kept a kosher house.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "She was wearing a sheitel-- had her head covered.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Very strict, for many, many years.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Very strictly kosher.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And she knew everything about Judaism.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And it pleased her.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "She liked it.",
      "word_count": 3
    }
  ],
