  "elapsed_s": 397.5,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And during the night-- I'll never forget that.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "That was in our Saturday night.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "We had shooting and screaming and yelling.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And that was like right next door to us, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "If we would-- we were afraid to walk over to the windows because it might-- we could maybe see what's going on.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "But we were frightened.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "In the morning when we woke up, right in front of our house were three people hanging on our lamppost.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "But they were not Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "They were three Poles.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] And [PAUSES FOR 3 SECONDS] I still don't remember.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "I think they were drunk, the Poles.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "And-- and the Germans were drunks.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "And-- and they hanged them, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And that's how they were hanging for maybe 10 days under the lamppost.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And that was the-- the first impression, you know, from German.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "Then they start, you know, to close down all the Jewish stores.",
      "word_count": 12
    }
  ],
