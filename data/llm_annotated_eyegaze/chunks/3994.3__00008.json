  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I met somebody who gave me a job and gave my husband a job.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And-- but before, we went out-- we went to Greenwich-- I forgot to tell you that I just remember when we arrived in Darwin-- no, when we arrived in Karachi, the plane went down.",
      "word_count": 34
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Because he had to [? fool ?] the w-- [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And we were there for a week-- for a day.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "In Karachi.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And I was pregnant that time when I came out--",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Again.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I lost it in Karachi.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "About three months.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And I was bleeding, so they took me there to hospital in Karachi.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And I was there over the night.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And the next day, they picked me up from there.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "On the plane, I was very, very ill.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So I arrived actually here before I went to [?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Bougainvillea. ?] I after the Royal Women's Hospital, they have a [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And after that, I couldn't walk again, because I was very weak.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And in [?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "Bougainvillea ?] when I was, that's why my relation came out.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "And we went to Greenwich.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And from Greenwich, I went back to the hospital, because I was very weak.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "And then from the hospital back to Greenwich, and then we started [INAUDIBLE] out life.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I loved every minute of it.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Only when we arrived in Darwin, and I said, oh, it's so hot here.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "How will I work there?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't-- I don't know how we'll stand it.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "But I have to.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I have to.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I have to.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And when I arrived in Sydney, we were all very happy.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And that's how we started.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Well, first of all, there were [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "A lot of people came.",
      "word_count": 5
    }
  ],
