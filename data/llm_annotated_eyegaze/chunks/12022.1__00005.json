{
  "stem": "12022.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 86.6,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "Like every Tuesday, to this person, we come to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "Like at Monday, to this person come to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "And some-- then when we bartered, people from the what we eat the teg, they used to give us a dollar, a zloty, Polish zloty.",
      "word_count": 25
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "It's enough for one day to eat, [? even ?] one we bartered for that.",
      "word_count": 15
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it depends.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Depends on-- some was pretty good, and some was not very good.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Depend on what-- which person.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "I have seven persons a week, seven balabustas, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And then some one was not very good.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "Just I don't have a choice.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I remember one name was [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "She was a very pretty girl.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "And she was-- and she used to give me the food.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "She was a very, very nice to me when she was giving it, very nice, the best food that you can get.",
      "word_count": 22
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Include you?",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "It include meat.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Oh, I used to get meat, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Some, yes, though not everyone.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Some areas.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "On like Shabbos, they used to make [INAUDIBLE] and all kind of stuff, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I used to come home for the holidays and for Pesach.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "And this way, I used to be all summer there and all winter there, just for the holidays.",
      "word_count": 18
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "And then beginning another semester, I used to go back.",
      "word_count": 10
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "My mother is arrange again, every year.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No, by horse and buggy.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "My mother-- my older brother used to pick us up with horse and buggy.",
      "word_count": 14
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "We had a horse.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Like a mother.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] She was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "She used to come, used to play and-- play with the kids together.",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Really, I wasn't any favorite.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "And I was not particular to the dishes.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "I was good anything.",
      "word_count": 4
    }
  ],
