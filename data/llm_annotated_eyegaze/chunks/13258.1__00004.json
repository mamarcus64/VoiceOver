  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] She went to a camp at the age of 12, survived.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Came early to America as a-- with the help of HIAS or Joint, whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Got a education in America, has a-- two bachelor degrees, a master degree in-- in librarian sciences, and worked for over 20 years for the United States Army as a civilian employee, as a librarian, the last, oh, since 1970, long-- the last 20 years in Germany, and before that, five years in Korea, and about two years in New York at the Veteran's Hospital.",
      "word_count": 65
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, we got along pretty well, as with a 10-year difference, age difference.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "At first, it was a little toy-like to-- to have around.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Later on, I loved her.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She loved me.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "She-- she-- she, especially when she got a little older, and when I had a bicycle, she would wait when I come back form work and that I put her on my bike and drive around a little bit with her.",
      "word_count": 41
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "The only time she was doing mischief to me was when I was collecting postage stamps.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I had the stamps sorted out on the table, and her nose would just about reach the level of the table.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And she would blow-- [LAUGHS] the stamps away, [LAUGHS] which did not make me very happy.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "But otherwise, we were getting along very well.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We didn't see each other very much.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We parted when the-- when the war started, when she was eight.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I saw her briefly when I came out of the army, and I found her.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "She was 14.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And then she went to Germany, and then, subsequently, to America where I see her-- I didn't see her for another 13 years.",
      "word_count": 23
    }
  ],
