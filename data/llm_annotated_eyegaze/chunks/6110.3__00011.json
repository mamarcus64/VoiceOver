  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And, and that's-- they were very unhappy, but they didn't say a word.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They were sitting quiet because they were afraid to say something.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "We had a nice social life.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "There was a lot of our people came from the camps.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "We made a community, Jewish community.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "We had a synagogue.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Americans were helping with everything.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Because they was calling the people.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "The American Army was calling to the people wherever somebody wants to go.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "So when they asked me, I was called by a high rank officer to ask where I want to go.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "He was registering.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I said, I tell you the whole truth.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "I don't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "I don't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "He said, so don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "You are going to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "This is the best place in the world.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "You're going to be peaceful.",
      "word_count": 5
    }
  ],
