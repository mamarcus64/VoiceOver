  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I think this was in 1933.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there was a-- a few organizations.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I belonged to the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And that was a lot of [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Like in-- like in every small town in Europe, it was [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "It was-- [PAUSES FOR 4 SECONDS] let me just remind myself.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "There was the-- like in any other state.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "He was very proud of me.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "They were in the meat business.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And they-- they struggled very bad, because account of the-- of the non-kosher law came out.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Every Polish-- maybe not every, but a lot of them, they already mentioned Hitler's name.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Hitler's going to come on you.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "When he has something, Hitler's gonna come.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And we started to suffer a lot already when Hitler-- when Hitler became in power.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Polish governments kept together with a relationship.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And anti-Semitic was jumping, growing from the ground, in moments everything.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "What happened at that time?",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Go ahead.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Don't press me too much politically.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I was not.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    }
