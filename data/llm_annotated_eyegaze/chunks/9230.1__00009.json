{
  "stem": "9230.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 13,
      "text": "And they were staying 27 months.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "27 months.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And they give them a carrot every day.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "They give him-- he was poor.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "He hasn't got for himself.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "You know, he share what he got for them because he got the whole family [INAUDIBLE] and the daughters-in-law.",
      "word_count": 19
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "All they live in the same house.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "So he share everything with them what he got.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "So he-- And after 7-- 27 months, he didn't know what to do, to let them out.",
      "word_count": 17
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "Because he was scared maybe the, the Russian come.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "So he went to the-- to a Russian office-- to a Russian office-- general.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "And he says, I have to ask you something.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "He says, well, I have to show you something.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "He took him by the hand, and he open the hole.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And he took out my sister-in-law.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "She die on the way to the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And my nephew, he was a year old, and he came out like that.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "He loves now in Portugal.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "Like that.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "And my brother, everything was teared from the rats.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And my friend says, Jakob, I have a surprise for you.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "I found your two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And they live in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I give them a home.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "My sister was in Bergen-Belsen, because she was-- a few weeks before she got to be married.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Now he died here four years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "That's my niece, where she took me into the country.",
      "word_count": 10
    }
  ],
