{
  "stem": "21731.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 41,
      "text": "I think it was 9 pounds a month, in Elgin Crescent, that is near Portobello Road.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 42,
      "text": "It was a Maisonette.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 43,
      "text": "Each of the boys had a room.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 44,
      "text": "There was a very big kitchen, which was also the dining room.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 45,
      "text": "It was-- and I had my room, and a bathroom.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 46,
      "text": "The landlady was very old.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 47,
      "text": "I suppose she was much younger than I am now.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 48,
      "text": "And life went on.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 49,
      "text": "I worked.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 50,
      "text": "The boys studied, [PAUSES FOR 3 SECONDS] worked in their free time.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 51,
      "text": "That means there was no free time.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 52,
      "text": "Yan was a conductor, was a postman, was a-- worked at Wally's Ice Cream, Eldorado Ice Cream.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 53,
      "text": "They had to earn some money, because I earned 7 pounds 10 a week, which was not enough for three people.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 54,
      "text": "But they gave me 10 pounds, and 10 pounds was-- they got a grant from a Polish organization, for 20 pounds a month.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 55,
      "text": "So I got 10 pounds, and they had 10 pounds for their lunches, and whatever they wanted.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 56,
      "text": "So there goes my life in Elgin Crescent.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 57,
      "text": "Then George was already a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 58,
      "text": "He lived in a hospital, as house doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 59,
      "text": "And Yan finished the Imperial College, worked in St.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 60,
      "text": "Albans at a firm which made airplanes, which he didn't like.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 61,
      "text": "And one day he told me he is going to immigrate.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 62,
      "text": "That was in '56 or '55, to immigrate to Canada.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Out of the blue, I had no idea.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He had everything arranged.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He had the medical.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "He had a job in Toronto-- in Montreal.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And he's going.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So what could I do?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I had a life insurance taken out, because when my husband died, I thought, if something happens to me, the boys can't study.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I took one out for, I think I paid 50 pounds a year.",
      "word_count": 13
    }
  ],
