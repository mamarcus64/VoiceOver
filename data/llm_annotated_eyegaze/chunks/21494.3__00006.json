  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Maybe we'll need to ran, and we left for what to buy something.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was, you know, hidden.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And when we ran out from the ghetto, to-- to the-- to the-- to the-- farm, we take with us a [NON-ENGLISH], dollars, them-- this gold--",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "--coins, and jewelry-- and jewelry-- a full, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And, you know-- and I think, OK.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "You know, you have.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Maybe someday I'll give this.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I'll give-- I'll buy a bread.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, we need to divide, because three-- nobody wants to-- to hold us.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "We divided after the-- the time when she went to take bread, and it was three people, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I say, what?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "To catch and to-- to kill three people-- maybe one will be alive, maybe.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Then--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "This was-- this was when we already-- this was '43-- '40-- end of-- this was '40-- end of-- end '42 when wintertime end-- '42.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Then I start to go alone.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I start to go in there, go alone.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I started to go alone.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And I went here, there.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I-- I was in-- in a-- where the the cows at night.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I came in there The goy shouldn't know.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I went in-- in straw, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Hidden-- wintertime, wintertime.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I have lice, all in the head.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I-- my-- my whole skin was eaten up-- end of.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "When I-- when I was-- I used to-- to take-- I had nails.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I didn't wash myself for two years.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I had big nails.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "When I came on the snow-- it was black, the snow.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And I had a fur.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Everything they took away from me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "I went with schmattas on the feet.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "They took away-- I had, you know, very nice boots.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And inside was this fur.",
      "word_count": 5
    }
  ],
