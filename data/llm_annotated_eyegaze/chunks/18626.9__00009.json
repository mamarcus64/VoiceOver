{
  "stem": "18626.9",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 427.0,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And we get all kind of best food, and the best medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And God bless America, and thank the American government and the, and all America.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Did any Jewish agencies help your?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was the, it was the Joint.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "At that time was Joint and UNRA.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And they gave us care packages.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And we opened it up, the care packages, and it was all the goodies inside.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And we felt like we're in paradise.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Then a lot of people start to come from different camps.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And people start to meet people.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And regards, oh, I saw your sister.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She's near Warsaw in a small little place there in a camp.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Oh, I said, which sister did he see, Miriam or Faiga?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "She says, Faiga.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And then another came, [? regard ?] because trucks came with people from all over Poland, from all different around, from the liberated camps, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So that's how we start to find, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "When people are alive, eventually, you know, you get a regard.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "When people are dead, sorry, we cannot get no more regards.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't get no regards from my father, and from my mother, and my little brother because my sister Fay told me that to the last minute, she was with my mother when she was taken away with my little brother, Solomon, to the crematorium.",
      "word_count": 45
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Where I was that?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Auschwitz.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Miriam was liberated, and she was in a camp for a little while in Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And from Poland, she didn't know what to do.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So she went back to Lithuania where the Russians are.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And she felt sorry.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And then she find out that we were liberated and we are in the United States.",
      "word_count": 16
    }
  ],
