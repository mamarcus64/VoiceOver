  "elapsed_s": 2.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Because the area where I was born, that was Silesia, and it was always either Poland or German.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "The language was going back and forth.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "So they were-- [PAUSES FOR 3 SECONDS] they were Germans that could speak Polish as well as the German language.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And-- and I was amazed when I saw what was happening in a-- in a few hours.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] The city was occupied by the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I don't remember any bombing or destruction or any kind in Oswiecim.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] So-- [PAUSES FOR 3 SECONDS] but I was-- we locked the door to the apartment, and we stayed inside, and-- waiting to see what will happen next.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "What happened next is they [PAUSES FOR 3 SECONDS] occupied the city real quick.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And about a week later, or two weeks later, they changed the name from-- the main square to Adolf Hitler Square.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And they made us use arm bands with the Star of David, [PAUSES FOR 3 SECONDS] a yellow band.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And then they changed this.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And later on it was changed where you had to sew up a permanent yellow star and said Jude.",
      "word_count": 19
    }
  ],
