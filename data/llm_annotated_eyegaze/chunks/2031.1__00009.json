{
  "stem": "2031.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And we went to [INAUDIBLE] to Vladich.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And the place was the name [INAUDIBLE], a [?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Cesky ?] place.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And we-- on the way we saw two Nazis with a Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "So we was thinking, this is-- they will kill us.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "But they could hear how we was frightened, how we was afraid.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And they was afraid for my brothers, or they were sad for us.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And we went this way.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "We didn't say a word.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And they went this way.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "They didn't touch us.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And we came up [INAUDIBLE], and the boy, Vladich, was waiting for us.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And we went up the stairs.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "Tomorrow morning was a rumor that they saw Jews with two beards walking up the [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And Vladich came over to my-- and they made up with my brother, they will not-- when he will come to feed the horse, he will not come.",
      "word_count": 28
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He will make, uh-hmm, so we will know somebody's there.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So my brother when that-- he says, you know what?",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Last night two Nazis saw people going, and two children on the--",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "He says, we didn't saw nobody, nobody saw us, and I don't know about nothing.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "This same day, the people from when they went back, they made a factory in this [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They made a factory for old cars, the cars that has to be fixed, and this, and this.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "When this night, we wasn't able to go out, forget it.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "It was the [INAUDIBLE], it was there day and night.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "It was the people that they was watching the place.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And this night, if we wouldn't be able to go out, forget it.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "We would have died there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So we came and so my brother says, we don't now nobody.",
      "word_count": 12
    }
  ],
