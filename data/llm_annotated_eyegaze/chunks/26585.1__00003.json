{
  "stem": "26585.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And what I'm sure the Nazi regime did not know-- had they known, they would have never done it-- the Jewish children got the finest education anybody could ever ask, because our teachers were professors from the-- Jewish professors from the university.",
      "word_count": 42
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Our chemistry teacher was a professor, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Manheimer.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "We had the finest.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It was.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "You were-- you weren't hated any more.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You were among your own.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Yes, it was.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I would say we had a happy childhood, even then.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "For himself.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In German it was called [GERMAN], chemical factory Electro was the name.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Mostly dyes for leather.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "But they also-- they also made soap.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I remember, there was a carpenter shop.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "That's really all I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "150",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "The only Jewish person I remember at that time was his cousin, who was his private secretary.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Work there, yeah--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Very much.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I was too young to remember that.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But I have read it in speeches and in newspaper clippings that-- they named a street after my father in 1984.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And so I-- I read it there.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "During the Depression-- I guess that was all over the world in the late 1920s-- my father hired two women and rented a building.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And there was a soup kitchen that went day and night for anybody who needed it.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "He did-- he did so much that one newspaper article said that the neighborhood children who were so poor, before they went to school in the mornings, they stopped at the Schohl house to get-- pick up sandwiches to take to school with them.",
      "word_count": 44
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And at Christmastime, my mother and the two maids fixed baskets upon baskets.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And one time, she took me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "I must have been seven or eight years old.",
      "word_count": 9
    }
  ],
