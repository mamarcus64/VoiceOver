{
  "stem": "20580.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "It was in the corner from that wall, which we have-- in the corner wall, we have a bell-- a-- a thing, hole, which you adding some leather, and we planning out 2 o'clock till 5 o'clock.",
      "word_count": 37
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "I have time-- four hours to finish the letter.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "I didn't finish it.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "You know the way it is.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "Then they was watching me.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "And we're planning.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "That-- I'm going to be in that corner, and this corner we make all 2 o'clock at night, and we're going to get out.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 28,
      "text": "But right now you have to go to the gypsies.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 29,
      "text": "I went down there, and I was standing in the corner wall. 5 o'clock, 6 o'clock in the evening, comes out that guy over here, takes X-ray.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 30,
      "text": "That was the law.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 31,
      "text": "Take X-ray from the people before they got killed, and later X-ray when they got killed.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 32,
      "text": "Is the picture in Germany someplace.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 33,
      "text": "I was standing with a [NON-ENGLISH] with a white shirt and a [NON-ENGLISH] like this, and I was in the corner wall, which we're planning to make that all should get out. 12 o'clock--",
      "word_count": 34
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "How feel?",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Over here I feel-- not the pain.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I told you about.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "You feel [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "You know what [NON-ENGLISH]?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Bitter-- terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And the eyes is blanking.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I feel the sun is light and beautiful.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "You feel just blank.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And actually, we understood each other with a wire.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I got on this corner.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They make the X-ray-- one X-ray, second X-ray.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And 12 o'clock at night comes the [NON-ENGLISH] Gretzner.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "He comes to change the Ukrainish-- five, six people each, he comes to change.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "[SPEAKING NON-ENGLISH] He says, in Danish, could I have a drink?",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I was very thirsty.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "So yeah, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING NON-ENGLISH] Hide yourself.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING NON-ENGLISH] He yells to me, [SPEAKING NON-ENGLISH].",
      "word_count": 8
    }
  ],
