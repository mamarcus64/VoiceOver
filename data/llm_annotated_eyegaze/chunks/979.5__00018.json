  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "People should love each other, I say.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Because if we have-- we have too much hate in this world.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "It's not fair.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "It's not right.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I say, we are all humans.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And we're all the same.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "We're people.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "So if they-- that people should think twice before they do something so horrible to other people.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "But as I say, Hitler, Hitler-- people like Hitler will never learn.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "But we hope that other people will stop them before it's too late.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "You know, because here they should have stopped them then.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "But they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "But now they should-- that's a lesson to learn.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
