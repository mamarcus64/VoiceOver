{
  "stem": "9110.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "That means where the filth comes out from the [PAUSES FOR 3 SECONDS] toilet.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "This was the day when my sister came with my mother back from Radom.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And I was-- my aunt took me in, and she gave me a bath from head to toe in a barrel.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "We didn't have showers.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And that-- that was my life.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I went to school, but we only had seven grades.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "But I think the seven grades was, like, almost, here high school.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We were orthodox, but my father was, like, orthodox, but he wanted the best for the kids.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My sister wanted to marry a boy, but he went to Israel in 1938 or '37.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And my mother said, not in her life.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She wouldn't send away a child.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And my father said, I want to hear good news from far away.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "But nothing came out of it.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And she's now dead, was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "She lived in Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "She married a nice fellow, and they lived comfortable.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And they had one child.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And when the war started, she came.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "We took-- I was there for the last few months, because the first, when she was pregnant, she lost two children-- twins.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "So by the second, the doctor said she should take care of herself.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "She should stay in bed the last few months.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "So my father sent me to Warsaw, and I stayed over the 1939 bombs in Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And I tried to help her as much as I could.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "I stayed in lines for bread, for milk, to bring her something to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "What was what like?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Shabbat.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Well, everybody had to be Friday night by the table.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Once I had Gentile friends, too.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I was a young girl, and we played.",
      "word_count": 8
    }
  ],
