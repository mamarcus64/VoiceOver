{
  "stem": "2996.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And said, look, there is a cocktail party in the home of Carl Laemmle.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Carl Laemmle was the founder and the president of Universal Studios.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Would you like to go along this coming Sunday?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "So I met Carl Laemmle, Sr.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Laemmle came from a little town in southern Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He was the main-- what should I say-- contributor to that little town.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "The main street was called Laemmle Strasse.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The library was called Laemmle Library.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he had a lot of relatives by the name of Laemmle.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And all of a sudden, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Hitler comes to power.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And Laemmle Strasse was no longer Laemmle Strasse.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was Hitler Library or Hitler Strasse.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And he brought many of his immediate relatives out to Los Angeles.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And they were all put on the payroll.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So he enjoyed talking to me about the whole Nazi business.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And the wind up was at the cocktail party, I want to come to work for me.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I think the job he created, he wanted because he liked me, and he loved to go out to the beach and walk up and down at the beach and talk about his hometown and what has become of it.",
      "word_count": 40
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I think it was not a real job.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I think-- I should think up new themes for new films that would be up to date at a given time.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "For instance, today might be the 200th anniversary of something or other.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Build a whole film around it.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I think it was strictly that way.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I went to work-- went back home, gave up my bachelor apartment and came out to Los Angeles.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Carl Laemmle, Sr.-- Carl Laemmle, Jr.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Got credit got credit as the producer for-- of which won practically every Academy Award there was.",
      "word_count": 17
    }
  ],
