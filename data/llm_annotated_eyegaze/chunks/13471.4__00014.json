  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 13,
      "text": "I said, well what am I gonna use to get back and forth to the-- house and here?",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 14,
      "text": "He says, you can take my Jeep.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 15,
      "text": "He'd been in town four days.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 16,
      "text": "His Jeep, see.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 17,
      "text": "This is Wallie's.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 18,
      "text": "So all right, go.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 19,
      "text": "Take the car.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 20,
      "text": "It came back repainted, new springs.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 21,
      "text": "They'd redone the engine.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 22,
      "text": "They had re-upholstered it with-- guess what-- Army blankets.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 23,
      "text": "And [LAUGHS] in the center of the dashboard-- now, get this.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 24,
      "text": "This is a typical Kraut touch.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 25,
      "text": "There was a cut-glass vase with a rose in it.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 26,
      "text": "Jeez.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 27,
      "text": "I said.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 28,
      "text": "Wallie, you are now special administrative assistant.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 29,
      "text": "[LAUGHS] And we're going to take a break.",
      "word_count": 8
    }
  ],
