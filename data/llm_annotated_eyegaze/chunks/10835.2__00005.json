{
  "stem": "10835.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Because my brother was sent to a male camp.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Actually, my brother was sent to Markstat, and we never saw our parents again.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "That time, we were sent to that place in Parschnitz, to a camp which was housed in an old factory building.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And the owner of the fact-- the old factory building had-- the new factory was placed in a different building in a town called Trautenau, which was six kilometers away.",
      "word_count": 30
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And we were brought to that place.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "We marched 6 kilometers on foot, back and forth.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "We were brought to that place, where we were assigned jobs in the factory.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "That factory produced-- I wouldn't call it yarn.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Thread.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "From the first process, where the raw material was being brought in.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And all us girls were employed in this factory.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And my sister and I were assigned to the same department.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And this department was, like, in chain of being-- of the material being processed, we were, like, the second [PAUSES FOR 3 SECONDS] form of processing.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "It was very dirty type of work.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "The machines were was huge.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "It was-- they were high up to the ceiling, and each of us was working at two machines.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "We were-- the machines were being fed by that-- raw material was being thrown into the front.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "They were being combed out of the-- of the dirt, and then it was being fed into that huge machine.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And it came out in ribbons, like.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "They were about four inches wide, and they were-- they were coming out of the machine into barrels.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "These barrels were later sent out to different departments, where they were being refined and refined and refined Until they were being put on spools and shipped somewhere else.",
      "word_count": 29
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "That was our job, working at these machines.",
      "word_count": 8
    }
  ],
