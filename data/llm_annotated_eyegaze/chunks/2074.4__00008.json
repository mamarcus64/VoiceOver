{
  "stem": "2074.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I don't why-- because I was sick during the pregnancy, which I went through so much, it was hard.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But anyway, that's a separate story.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "They-- they found me, the nuns of the hospital found me on the hall floor laying alone with the baby head halfway.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "On the floor, unconscious, they picked me up.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They brought me on the table and told me to count.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So I knew I have nothing to live for.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They told me to inhale as much as I can.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So I inhaled so much that I couldn't wake up.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't wake up.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "They were waiting for me to wake me up, and wake me up.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And nothing doing, the whole crew was waiting.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Nothing helped.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Until I feel a slap in my nose and a cry.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I look.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "There's a baby on my chest.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And they-- they had nothing to dress.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "The baby naked.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "The baby's crying.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "It slapped my nose to wake me up.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "I opened my eyes, and the crew of the doctors and nurses are around my bed.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And everybody is smiling.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And I say, whose is that?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "It's a big, fat pig, and he's all yours.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "He tell me in the German language, it's a big, fat pig, and he's all yours.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "And he's all right.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "He weighed almost 10 pounds.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "So anyway, this was another miracle story.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "There they want to take the baby and kill me, probably with him.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "So I survived that one.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "And from that time on, I came home from the hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "I find a letter.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And the letter reads, I am [INAUDIBLE], your cousin from Montreal.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I know you survived.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I heard.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I'm sending out letters, like Noah sent out the doves from the ark, all over Germany.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
