{
  "stem": "24125.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They were looking for very rich people.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "So when they came to us, they are right away is how rich are we?",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Well, they found out that we were not.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And if we did, then they didn't find out.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] So my father still was operating the mill.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "We still were living in our borders, and we all went to school.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "From the beginning, maybe a little bit because they didn't know us.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "It's the rich people.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "They did get Mogenitska out of the-- her place and ruined her beautiful house with books and everything else, I remember, and sent them to Siberia.",
      "word_count": 26
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Not with us.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "These [INAUDIBLE] were the only ones.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Ostrog?",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, two of our neighbors-- actually, one neighbor-- at night they took them and took them to Siberia.",
      "word_count": 22
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No, they were Jewish people.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people wealthy.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Very wealthy.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "They lived practically next door to us.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "So that I remember very well.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "As far as the other people, I know that there was a lot of people that were.",
      "word_count": 17
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And some of them willingly left Poland.",
      "word_count": 7
    }
  ],
