    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 48,
      "text": "[PAUSES FOR 6 SECONDS] My father, being the president of the kolkhoz, was afraid that when the German army will come to our town, he will be the first victim.",
      "word_count": 30
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 49,
      "text": "[PAUSES FOR 3 SECONDS] So we decided to flee, to go to Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 50,
      "text": "My mother was always helpful in the business.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 51,
      "text": "She was also a very energetic woman.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 52,
      "text": "So she said to my father, if you'll be safe, I think I can take care of myself and the children.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 53,
      "text": "As long as I know that you will be all right.",
      "word_count": 11
    }
  ],
