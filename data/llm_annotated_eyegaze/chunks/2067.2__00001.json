  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "They were beaten and thrown into a truck-- in trucks-- by the SS and taken away.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "The Dutch gentile population saw that, and they rebelled against it, and called out-- the workmen of Amsterdam called out a strike, which developed into a general strike in Amsterdam.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "The Germans took hostages-- i don't know how many, but it must have been more than 25-- and executed them-- gentiles.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And that broke the backbone of the strike.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "But as it is called in Dutch, [NON-ENGLISH]-- the February Strike-- lives in the memory of Holland, because it was the first time of violent reaction against the German oppressor.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "Those 400 young Jewish men were all sent to the concentration camp of Mauthausen.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "And not one survived.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "[PAUSES FOR 4 SECONDS] In June, while we were playing tennis, [?",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "Dottie ?] was sick at home.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "I got the telephone call through the-- to the tennis courts.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "It was [NON-ENGLISH], that's the Dutch abbreviation-- [NON-ENGLISH], or [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "Said get-- get away with Max.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "Max was another friend of ours.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "Get away with him.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "They are out in the street to-- and they are catching young men again.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "We jumped on our bicycles, Max and I.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "And we left the tennis courts, and saw already our respective mothers coming to get us.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "They also had heard the rumors that round-ups were again busy in Amsterdam.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "They brought us clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "We went into the bushes, changed from the tennis shorts, et cetera, shoes, into regular clothes, jumped on our bicycles, and left for a-- it's not exactly a suburb.",
      "word_count": 29
    }
  ],
