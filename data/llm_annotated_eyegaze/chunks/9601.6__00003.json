{
  "stem": "9601.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And she had three sons and a daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Sarah Yedlin was a widow.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "The Yedlin children-- Sarah's children were contemporaries of my mother and her brothers and sisters-- same age.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "All five of them survived, as a unit.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I don't know how, but they survived, all five.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Then there was-- you know, I'm going according to geographical layout of where they lived.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Then, there were the Kobylanskis, my father and my mother, my brother, and I.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "This is number two family that survived.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "We went into hiding, and we came out.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "This is amazing, by anybody's account.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Don't forget, our Grandmother Kobylanski lived also in the same village with us.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "She lived one time-- you know, what they do with old people?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "You shift them.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "One-- one-- sometime, they live with one son.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Then, they live with another son, or son and daughter, whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Shared.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Grandma Kobylanski lived with Uncle Chaim on the other end of town.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And Uncle Chaim married-- I told you earlier-- married a cousin of my mother's, who I found out was-- I thought she was always my aunt, but I didn't realize she was a cousin also.",
      "word_count": 35
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So she lived with them.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They had two daughters-- a little girl, Chaika, and a little smaller one over there.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And Reizel [INAUDIBLE], you know, the wife of Chaim, she had a brother, Jonathan, who also lived there.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "He survived.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Reizel did not survive.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Reizel got thrown into a well.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "But I assume, probably, after torture.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Chaika, Uncle Chaim's daughter, perished in one day.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "She was in [INAUDIBLE] for a few days.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "She came to her father.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And her father thought he was doing her a favor.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He sent her to another village, which was known to be anti-Semitic, hateful, this group.",
      "word_count": 15
    }
  ],
