{
  "stem": "11641.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't-- wasn't a normal business anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My uncle remained there.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "With everything in it.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He stayed-- he stayed in Chorzow for a while.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And a lot of-- a lot of my people knew him.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They lived in my apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know that they were there, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And he eventually sold the apartment, and then we found out that he moved someplace else.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Because we-- when we moved to Czechoslovakia, the Czech-- because I had the pass, I was rehabilitated in-- in Brunnlitz, told us that if we move someplace else, they will give me an apartment.",
      "word_count": 34
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "So we moved.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "We were four couples together, at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So we moved to Usti nad Labem.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It's a-- a company that produces [?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Shift ?] soap.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It's a very well-known soap in-- in-- in Europe at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So we went there, and we were-- we were introduced to a Russian captain, who happened to be Jewish.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So when he found out that we were Jews, they gave us a beautiful apartment with crystals, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Must have been German apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And we-- we stood there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And in the meantime, I remembered I had an uncle in America, my father's oldest brother.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And the different between both of them was at least 18 to 20 years spread between ages.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And I wrote to him a letter.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I wrote to him in Polish, one letter, separately in German, and another separate, I know a couple words in-- in English.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Because in my high school, I took up English, But I didn't remember much when this.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I said, Sally, whatever it is, we have to have a permanent residence.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So we stay here until we get an answer.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "After four weeks, we got an answer.",
      "word_count": 7
    }
  ],
