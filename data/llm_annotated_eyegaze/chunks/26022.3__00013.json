{
  "stem": "26022.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "It was impossible.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "You could write to them-- it went into a wastebasket.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "You never got an answer.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "When they were good and ready to call you, you came.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "So finally, they called us, and decided that my cousin's affidavit wasn't strong enough.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "There was one postponement after the other.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "And I-- while we were there, we saw how families were torn apart.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "Now, Vienna is a very windy city in the spring.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "There's a lot of-- of dust from the cobblestones.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "And conjunctivitis-- eye inflammation, red eyes-- is not unusual at all.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "So one of the children had a little eye inflammation.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "They said, could be glaucoma.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "We can't give you a visa.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "And all the papers ran out for these people.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "And this little boy was supposed to bring all kinds of-- of doctors' affidavits and whatnot and come back in six weeks or some such thing.",
      "word_count": 26
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "In other words, this family was condemned to stay.",
      "word_count": 9
    }
  ],
