{
  "stem": "1704.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.1,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "Political prisoners, Frenchmen, and all different-- Belsen was very, very big.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "It had lot of small camps.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "None whatsoever.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Just Bergen-Belsen.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, hold on a minute.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Yeah I think so.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I think so anyway.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, well as I said, my friend gave me the little boy.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I looked after him for a while, while she worked in the kitchen, which was outside the camp.",
      "word_count": 18
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And I did laundry in the camp for all the old people's home.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "That way, I could look after him.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "As she could smuggle out some food sometimes.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "Very dangerous, but she did it.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "On the body, in between two scarves and different ways.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "She was very clever.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Bread, bit of sausage.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I can't even remember.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "But she did it.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And that all for the child.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "I got some.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "The toilets, if you can call it toilets, was a long row of holes.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "You sat back to back, next to each other.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "The latrine, as they called it.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Once in a while, we had to go to the baths, which was outside the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "We had a German to come with us.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And we had to undress in front of him in one room, walk to the showers naked.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes, just women.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "But you know, old women children, anyone.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Well, [PAUSES FOR 3 SECONDS] I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, the first few times, you felt terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "You walked with a towel like this.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "But later on--",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "That didn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Didn't matter at all.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "About similar to Westerbork.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, you got something that looked like coffee.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "But what it was, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "Some surrogate.",
      "word_count": 2
    }
  ],
