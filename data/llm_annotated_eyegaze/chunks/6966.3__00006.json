{
  "stem": "6966.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "You only had a trouser and jacket.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And if you were lucky, you had a vest or pants of people that were killed off.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "That's how it was.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So the water's turned off and you got to lay on a wooden ground on the floor to dry.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And then some who stand up, some walk about.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It's only a small barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And in comes a man with a beret, wearing a beret and wellingtons.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And he walks amongst us.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And then one of our men say, tell us, where are the wives and kids?",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "He looks and puts up his arm like that.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "[POINTS]",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And he walks away.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Then we say to one another, man can't talk, something's wrong with his voice.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "What do you mean with this?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "[POINTS]",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Five minutes later, he comes back.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And another man ask him, tell us, where are the wives and kids?",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Again, that hand up and with-- pointing the finger.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "[POINTS] They're not allowed to talk.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They're not allowed to tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Later on, we understood.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Gas chamber, killed.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "The bodies are taken out and cremated.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Everything goes through the pipe.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "[POINTS] Door to pipe, through the chimney-- smoke, ashes, whatever it is.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And that's the end of your wives and children.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "But they didn't tell us that.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Later on you understand.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And what about the gold teeth they knock out of your-- your mouth?",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The bodies-- they'll open the jaws, take your gold teeth out.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They collect it and sent to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Well, my wife had no gold teeth.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] No.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So now we marched out, chased out into the open, after being given a civilian pair of trousers, a civilian jacket, and a cap.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Later on I get my beret.",
      "word_count": 6
    }
  ],
