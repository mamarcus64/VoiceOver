  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And we were placed in barrack number 13, which also partly housed-- it was the punishment barrack where people who have committed an infraction or so-called crime, or tried to escape, were imprisoned.",
      "word_count": 33
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was surrounded by other officers.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I just have a very vague image of how they stood there in their neatly pressed uniforms, and shined boots.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Because there were-- we were actually told that, and also there was a-- [PAUSES FOR 3 SECONDS] a-- a secretary of the camp who kept all the numbers straight, who took our numbers.",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Whereas those who were going to stay, they were just sent outside the-- the barrack.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They were sent to the gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And my father stayed behind, and [PAUSES FOR 3 SECONDS] I think it was the second or third night after we arrived at this other camp that we knew that our [PAUSES FOR 3 SECONDS] parents or brothers and sisters were sent to the gas chamber.",
      "word_count": 46
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And that was July 11.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My mother sent a message that she was in a woman's camp, and later on we heard that they were shipped out of Auschwitz.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "That. we didn't know where.",
      "word_count": 5
    }
  ],
