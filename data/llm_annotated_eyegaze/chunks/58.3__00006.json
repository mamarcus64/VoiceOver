{
  "stem": "58.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We go in-- we lived-- the bunker was [NON-ENGLISH] 5, we had to go to the 13.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "But when you walked, there was cracked glass, broken glass from the windows from the shooting.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We walked in socks, not in shoes, but they could hear on the other side, walking, cracking the glass.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So we run across near the-- near the wall-- if they shoot, they cannot hit us, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Unless they threw a hand grenade or something.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And we walked, we ran into her house, and we picked up all kind of food, we put it in bags.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You know, and I carried the cast iron, with the fat in my hand, and something in the other hand, my gun was in my waistband.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And as we walk out of the door, a burst of machine gun.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I remained with my--with only the ear of the pot in my hand.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I could laugh about it now, I was scared stiff, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And we-- we run across right away, against the wall.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We came back, and I kept the handle to show that I had the pot, but I-- there isn't anymore, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And we walked across, and we came in with some food.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We came into the bunker, we told her what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "As long as you're back alive, to hell with the food.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "When-- then we walked out again.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "We wanted to silence this machine gun.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We were 18, but we were always the head of the group.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "He says, Hakiva said, we have to Shlomo, we have to go.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "We take a couple Molotov cocktails, and throw across the-- the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "We have to silence this machine gun.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "If not, we haven't got a chance to walk out here.",
      "word_count": 11
    }
  ],
