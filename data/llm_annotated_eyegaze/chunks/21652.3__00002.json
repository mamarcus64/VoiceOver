{
  "stem": "21652.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And we were just stacked in sitting position, 150 girls.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We couldn't lay down.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "We could barely stand up.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "We just had to be remain sitting.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "We were given some food.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And the following day, there was an appell, to go out to the yard in Bergen-Belsen.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And after the appell, a girl by the name of [NON-ENGLISH] came over to my sister, and she knew her from Sosnowiec.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And she says, Esther, you're here.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "So my sister said, yes, and my sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "This girl was in Auschwitz, and she was transferred-- she survived Auschwitz-- to Bergen-Belsen.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And she became a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "It was kind of a group leader.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "And she had a lot of influence in Bergen-Belsen.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "And she told Esther, I'm going to help you with whatever I can.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "And she assigned my sister [PAUSES FOR 3 SECONDS] to work.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And those who worked sorting out clothes-- those who worked were able to move into a room where there were bunk beds.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "That if you could sleep-- I mean, that was a far relief from being stapled in like staples in a sitting position in one room with 150 girls.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "She took us out of that room.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "She assigned my sisters to sort out clothing, and she assigned me to work in the kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] And our lot has improved greatly by being able to get a night's sleep and going to work.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "We were given food but not adequate food.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "And we would exchange.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "My sisters took some clothes out and brought it to the room and exchanged it with other people at the camp for food, for bread, or potatoes.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "So we had additional food in addition to the food we were given in Bergen-Belsen.",
      "word_count": 15
    }
  ],
