{
  "stem": "15900.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.3,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "She went back to California.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "She went-- she went back.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "She got married.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know about it.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I almost collapsed.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "If-- if-- when she came back to the funeral, she was already married.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Never told me, because she was going with a Mexican.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "She was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I told him, if he come into my house, get out of here.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "She's not for you.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "But anyway, she fooled me.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "She lied.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And I give-- and I give her some money.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And when-- when she-- when she was-- I looked on her pocketbook how money left, and I saw a certificate.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "She got married.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "I told Lois.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "Lois was-- unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Lois was almost-- out of her mind.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Later on, we got used to it.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "It's your daughter.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She got pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "She had a baby.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "He's going-- he's going to the temple.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And my son-in-law wants to become a Jew.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I said, you don't have to become a Jew, so long as you-- you--",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "He wants to become.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I asked the rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "You know, she's raised him Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Eventually he's gonna become a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "He is very devoted to her and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Look, what are you going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "If my wife would be alive, she died.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Find out that she's married this boy.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We will love him, and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "He's good to her.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "He makes a good living.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "So what are you going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "They're young people.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I tell--",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I told them what I went through.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "They know about it.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And my younger daughter wants me to write a biography.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I wrote it, but it's 20 pages in Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "And I stopped it.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I give them a message--",
      "word_count": 5
    }
  ],
