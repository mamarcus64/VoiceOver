{
  "stem": "26790.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "The, these Russian soldiers, they tell her that I am a Jew from Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "She come to me.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "In Polish, she asked me from where I come, what town I was living in Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "From Chelm.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Chelm.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "She just come from Chelm.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "She was in Chelm.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "She told me her story.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "She is from Danzig, a town, in Polish, a town like Danzig.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "Her husband was mobilized in the army, in the Polish army, in the first day, 1939.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "She didn't hear nothing from him.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "So she decided, she went back.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "She went so far till she come to Chelm.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "In Chelm, she stopped, because she doesn't want to go further to the Russians.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "She stopped at Chelm.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "And she told me what shop she got, a stationery shop.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "The Germans give it to her.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "Maybe she was a very good lady for the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "The Germans give it to her, a stationery shop.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "She told me the name from the shop, [POLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "She told me where she was living.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "She was living in Doctor and [INAUDIBLE] building.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "That doctor, that [INAUDIBLE], was a very rich man, a Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "He bought it, this building, a big building.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "He bought this building before the war, a few months before the war.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "And he kicked out all the Jewish people that were living in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And he take in, took in Polish people.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "So the Germans give it to her a flat in this house.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "She was living there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "Finished the, the talk.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "She left.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 39,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 40,
      "text": "This woman, [INAUDIBLE], she went to told the [INAUDIBLE] hospital that I am a Jew from Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 41,
      "text": "At that time was a regulation in the Red Army.",
      "word_count": 10
    }
  ],
