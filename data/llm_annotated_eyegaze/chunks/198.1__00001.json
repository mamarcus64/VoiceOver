{
  "stem": "198.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It was about seven miles from Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I knew two of my grandmothers.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They were beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "In my eyes, they looked old, but they probably were very young, because I'm going back now 50 years, and I was 15.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So maybe my grandma was maybe 50.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But they were beautiful ladies.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I remember I used to go to Shabbat, and she always set for us food and cookies and fruit.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "It was just a loving family.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I never liked my school.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I always felt that I was fairly discriminated being Jewish, because my math teacher always used to call out my name, Masza.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And Masza was a really a Jewish name, not a Polish name.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I always hated this.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "In my mind, I always felt when I was very young, if I ever, ever grow up, I'm going to leave this country.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And I'm going to go far away where I can do whatever I want.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We were always afraid to go out to play because they were always throwing stones at us.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I was always going with my older brother Leon.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He was my protector.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We had to walk to school.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "School was maybe a mile from home, and I was a pretty good student.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I finished-- I was, my education was a eight grade, and [SIGHS] I really don't remember much more.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "When we were-- I was young, I was going swimming with my brother and with my friends, and the Polish boys, they hated us.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They always hated the Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We were always felt to be discriminated, so they would-- I would never go alone without my brother.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[BACKROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was always afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "After-- after--",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Before the war.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Well, [SIGHS] I loved to go to my Hebrew school.",
      "word_count": 10
    }
  ],
