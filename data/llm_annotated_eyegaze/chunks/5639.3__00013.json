{
  "stem": "5639.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "So what happened is, that while we were sleeping in the ghetto, the underground moved into our rooms, and I-- I had friends.",
      "word_count": 23
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish underground.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "It was a small group of people, of my friends.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "So they hid in the cellars, and by 6:00, when we were marched off to our place of work, to the factory, which was just outside the ghetto, they moved into our room.",
      "word_count": 33
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "It didn't arise any suspicions, because they were people my age, and very often, you know, people stay overnight.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And they used our room for forging papers, preparing people who were ready to go on the Aryan side, telling them what place in the pictures, telling them about facts of life-- how to walk, how to look, what not to do.",
      "word_count": 42
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Don't turn around.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "Don't turn about your shoulders.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "Don't run.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "How to dress, how to say prayers, what are the latest Polish catchwords, and so on, and so on, and so on.",
      "word_count": 22
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "Apart of having a very primitive machine, where they duplicated, they forged papers, and so on.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And the time was quarter to six, and my father said, I am not going.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "The last night, I want to spend on my bed.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "I was desperate.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "More than anything else, I feared my father's ire.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "And I said, I am going.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 15,
      "text": "And my mother said, if she's going, I'm going.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 16,
      "text": "And my father said, you are blackmailing me.",
      "word_count": 8
    }
  ],
