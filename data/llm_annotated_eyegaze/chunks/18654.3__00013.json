  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But that was-- we soon found out that unfortunately they all perished.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were very, very hard up.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "So I didn't have a big white wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I mentioned before that I had a very, very distant relative here in London, and she made a tea party for us.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I made my own dress.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I didn't have bridesmaids, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And it was a very simple wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "It-- it was quite a nice wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Unfortunately my marriage didn't last forever.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I'm married to a different man now.",
      "word_count": 7
    }
  ],
