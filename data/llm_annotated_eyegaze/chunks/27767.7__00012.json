{
  "stem": "27767.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So I spoke one Tisha B'Av night.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And the young people, especially, were very interested to hear this.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And then, when I heard about the Spielberg, I was a little late calling up.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I called up, I think a year and a half ago, something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I wanted-- I said to myself, I want to give a testimony.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I wanted to be able to-- the world to know what's happened.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And I forgot something tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You were asking about the holidays in the camps.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I'm just remembering-- I told you about Yom Kippur.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Once we were in Allach, in the concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I was working in the kitchen already.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we knew it's Yom Kippur evening, starts Yom Kippur.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And we were praying in the kitchen there, in the place where we were peeling the potatoes.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And we had the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "We were more than 10 there, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "We were starting praying.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And at that evening when we were praying, I tell you, from the other concentration camp near us, there were some Russian prisoners there.",
      "word_count": 24
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "They threw some stones to us.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And I said to myself, look at that.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "Even here, it could happen this.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And I-- and I was fasting the whole Yom Kippur.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "I didn't eat nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And that holiday, I remember that's what we-- we kept.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
