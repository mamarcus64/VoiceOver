  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "People were-- what's the matter?",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Just because it's your birthday, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You can't tell everybody why you're so happy.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "No, nothing at all.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] That is my grandfather, Mr.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Felix Schoenfeld.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "The picture was taken in Hamburg.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] This is my grandmother, Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Annie Schoenfeld, born Feig, and the picture was taken in Hamburg.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] That's a picture of my mother, Gerda Rodewilg, born Schoenfeld, and it was taken about 20 years ago.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] That's another picture of my mother, Gerda Rodewilg.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "It was taken 1990, so it's six years old.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And I don't have a current picture of her.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In Hamburg, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, she is.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In Hamburg.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    }
  ],
