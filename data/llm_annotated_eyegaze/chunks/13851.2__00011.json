{
  "stem": "13851.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "He was standing in line, and he was on one side putting on headlights.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And we had to go around and take up the hands.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "He'd look around and see if we had any scars, or anything sick or what.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "In any case, when I came to him, and he ask me, [SPEAKING GERMAN]?",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "That means how old are you?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "I said I'm 18 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "He asked me, [SPEAKING GERMAN]?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "Can you work?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "I said, [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 19,
      "text": "I can-- I can work.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 20,
      "text": "I can-- [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 21,
      "text": "So he put me to the place that they're going to be sent away.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 22,
      "text": "So what happened, the people that were selected they sent to Buna.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 23,
      "text": "What happened from Buna when a lot of people couldn't work, they brought them to Auschwitz to be sent to the crematoriums.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 24,
      "text": "What happened to the people that night after you were selected to go to Buna?",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, so--",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Those who were not selected--",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "They were taken to ovens.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because they didn't take us to work, so the old-- mostly people waiting, well, that was the end in Auschwitz and Birkenau.",
      "word_count": 23
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "But we were-- I was selected to go to Buna.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "In the time [INAUDIBLE] Buna, I met my brother after a year and a half.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I was close.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I'd say a few feet away.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I mean, two or three feet, that's all.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Because we had to go close.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "He looked at us like, you know, you look up at a person, how he is, so we were very close.",
      "word_count": 21
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "He was a very handsome man and very cool.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Black, dark eyes.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "He was nice officer, straight and there was a few SS around with him.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And that's when he asked the question.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "To Buna.",
      "word_count": 2
    }
  ],
