  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "So he said, you kids can stay with us.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "And he helped us quite a bit.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "He-- he fed us a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "And after we got into that ceiling of the fire hall, it was very small, we climbed with a ladder.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "And he pulled the ladder back to the top so nobody would know.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed with him for a few weeks, not too long.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And things, I guess, got hot.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "What I mean by hot, they were getting closer to us, the Nazi sympathizers, the ones that were chasing the Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    }
  ],
