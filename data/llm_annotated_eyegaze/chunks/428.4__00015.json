    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 38,
      "text": "I feel sorry for her.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 39,
      "text": "You live without a person for so many years, you have no problems.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 40,
      "text": "For the 40 years-- lived with her.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 41,
      "text": "So it's-- it's terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 42,
      "text": "You feel alone.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 43,
      "text": "Whenever I came home, she used to be in the window, waiting for me.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 44,
      "text": "Now you come home, [PAUSES FOR 3 SECONDS] nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 45,
      "text": "The-- the walls-- talk to the walls.",
      "word_count": 7
    }
  ],
