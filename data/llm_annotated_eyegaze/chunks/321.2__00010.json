{
  "stem": "321.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And he would sort of say, remember.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] And that sort of was a tremendous burden all my life.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "I was never really young.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I had to toe the line, do what was the right thing to do.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I still have a hard time being naughty or doing things just for fun because of that.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And I think you can empathize with that one.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "We were never really young.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "Anyway, I went back to London.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And I had decided I'd go on strike.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "I wanted an education.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I wanted to get my matric, which was the graduation from high school.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And I called my father and mother and said, I'm coming home.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "1934-3-31-1941.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So I was away for two and a half years.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And the doodlebugs were still on and there were still incendiary bombs.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I said I just didn't care.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I wanted to be with them.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I wanted to get some education.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And I was an air raid warden with my father.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And my mother was working with the WVS, the women's soup kitchens and, you know, really with the British.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My brother stayed in Nottingham, because he was in high school.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And he got his-- he stayed with that Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Marta's ?] relatives.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "My brother's a very different, accepting kind of a person.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I was more rambunctious.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I kicked more than he did.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He accepted things very calmly.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "He has a different personality and doesn't remember very much.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Now he's in England, he does not recall very much at all.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "He never realized that I came on the Kindertransport.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And this is something that's fascinating.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "You're so-- you were so intimidated.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "You were so insecure all your young life.",
      "word_count": 8
    }
  ],
