  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "We had relatives in Kansas City, also by the name of Gerson, who were related to the Gersons of Oberwesel.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And they sent my father an affidavit, indicating that they would support him, and he would never become a charge to the United States.",
      "word_count": 24
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "At that time, the United States had very severe immigration quotas.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And it was not easy to enter the country as a refugee.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "So when he did make that voyage, he arrived in New York, and settled there.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "Then began the process of sending affidavits for us.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And we received affidavits.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "But the Germans would not give me an exit visa, again, part of the harassment.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
