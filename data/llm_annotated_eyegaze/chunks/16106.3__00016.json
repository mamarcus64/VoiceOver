  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "Because we were lots of people in this one little place, in this wagon.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "We hardly only could stand.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And we were on the same wagon with, with that lady who had the abortion.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "She was bleeding so terrible!",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "She was in-- and we had no water.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "And we-- and the train was standing.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "It didn't even move!",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "I mean, from Liepaja to Riga should have done in two hours.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "It took-- I don't-- forever, it seemed to me.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 20,
      "text": "And there was no toilet.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 21,
      "text": "There was only this horrible little pail.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 22,
      "text": "And it was hot.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 23,
      "text": "It was October, I think when, when we leave us.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 24,
      "text": "It was a hot time.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 25,
      "text": "It was stinking.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 26,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 27,
      "text": "When we arrived at the, at, at last in Kaiserwald, people can't--",
      "word_count": 12
    }
  ],
