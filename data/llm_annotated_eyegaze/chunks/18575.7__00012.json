  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "There were no Jews in Denver.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I don't know any while I was there.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But then I came to conclusion that it will be a sin, that, you know, would be another victory for Hitler.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And I turned around, became very active, Claire and I, in the Jewish community, we were.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Claire was a president of the women division.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "I was a vice president, an honorary president of the-- of the whole Mammoth County, in many positions.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And of course, in the [INAUDIBLE], I was.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "And in fact, my children used to call me the super Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "They never saw us.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "Every evening, we were somewhere other, some other things.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "But I told them very early.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "Ok.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In fact, they don't wanna-- my daughter, who-- Sari, while she was at Brandeis, she worked as a volunteer in video production with a professor who was a video professor.",
      "word_count": 30
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And he-- she was a assistant producer.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So she brought once a camera similar to that camera, and she took my statements on her being the operator, probably, not near as good as she.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "But-- and she never wanted to show me the tape.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But they know everything about it.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "The main thing that I try to-- I don't know what success.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "When I speak, I speak to the high schools.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I speak to general schools.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I speak yearly to US army in Fort Mammoth-- is that simple, supposedly innocent, expression demeaning any group, being the Jews or the Italians or the Greeks or the [?",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Huns, ?] dehumanizing will lead to murder.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It is the first step, because if you dehumanize a person, [PAUSES FOR 3 SECONDS] you can then as easily step on him as you step on a bug.",
      "word_count": 29
    }
