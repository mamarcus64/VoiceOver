  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "I couldn't take the, the climate over there.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "It's funny.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "During the war, I was fine.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "But I get to New York, I, I couldn't stand it.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And I came to Los Angeles.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "I had a friend of mine also from Mlawa.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And I got the first job as a cutter.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "They assumed that every man who, who comes from New York must be an excellent cutter.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "And the first, the first week, I got about $25.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And I worked about 60 or 70 hours only.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "And I learned the trade fast.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
