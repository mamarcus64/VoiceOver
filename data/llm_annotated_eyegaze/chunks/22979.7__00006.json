{
  "stem": "22979.7",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "The Communists took over and won the elections and became a satellite of Russia, like all the countries.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Ours was in '48.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "But one thing which I forgot to tell you.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I have to mention.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "The welcome when I came back to my parents' house where we lived for many, many years, the [NON-ENGLISH] it means the house was sold for $1 to the [INAUDIBLE] the Nazis, the Slovakian Nazis.",
      "word_count": 35
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "And when I came back I knocked-- to Stropkov-- I knocked on the door.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "It was not a door.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "It was a gate.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "You know, those houses in small cities, whole wooden, big gate.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "I knocked on the gate, went to go in.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A guy came out and asked me, what do you want?",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I said, well, I want go back to my house.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "He looked at me, slammed the door.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And he said, go back where you came from.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "That was my welcome.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So then I said-- I left, and never returned there.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "To Bratislava, back.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I said, we won't stay here anymore, because nobody wants us.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "We applied, when we get-- we got married for an American visa.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Fred had his family, his mother's sisters, who came to the United States in the 1900s.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He had nine, or eight aunts.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We-- we registered in 1946.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "In 1948, we had to wait for the quota number.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "In 1948, we still didn't get.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "You know, we didn't got the turn.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't get the visa.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "When the Communists took over the country, they closed the borders.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And we couldn't leave.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "We were trapped for 20 years in Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "We applied to leave the country year by year, always denied.",
      "word_count": 11
    }
  ],
