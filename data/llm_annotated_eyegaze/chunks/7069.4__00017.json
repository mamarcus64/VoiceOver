  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Number two, she was a diabetic that needed insulin, which of course, in the camps, you never received.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And then of course-- again, I mean this lovingly-- as gullible as she was, when these people offered her medical help-- and she arrived the same station, the same that I described, the same scene-- when they asked for sick people that should be-- that, that are needed to work, come over here for treatment.",
      "word_count": 55
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "She, of course, went over there.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And by that time, she-- witnesses told us that she was gravely, gravely ill, and very weak.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And so she hoped, of course, that they meant it.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "In any case, these sick people were loaded up onto the trucks like the children and went in the same direction.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And this is what we heard from people who with her to that moment.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "A person that we met just by coincidence-- I don't know the name anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Almost, almost immediately afterwards in, in Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
