{
  "stem": "18813.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "He was a businessman.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "So home, we had nothing. you know.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "We had no money, no nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "Everything we had was in the business.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "So then they took the keys-- all the businesses.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "They took the key, and they left.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "And that was the end of the business-- for beginning.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "About a week later, they came back and put the-- they didn't know how to open-- was something-- they needed my father.",
      "word_count": 22
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "My father was always scared to go because it was that tragedy already.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And they opened the business and came-- and they put the commissar.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "Commissar was somebody who took care of-- and all the money, they were collecting.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And I was working with her, with the woman.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "She was a German woman.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And she took over the business.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "Before us, when I was-- she let me be there.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "That was a good thing because I could-- like, one day, I brought a painter.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "I said, the business is stealing everything.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 11,
      "text": "Whoever can, steal at night.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 12,
      "text": "So we brought-- I brought a painter, who put merchandise in the ceiling, painted over, and made the hole and hide something.",
      "word_count": 22
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 13,
      "text": "So we had for after the war when we took it out.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Merchandise, like clothes for-- suits for mens, shirt for men.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "We had only good things, really, velvet, you know, better merchandise.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And my father never went back to the business-- not my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I was the only one going there.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And that was the end of it, the end of the business.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "After they came to the house and-- for silver.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "If we had fur coats, if we had better clothes, they took everything away.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "About a week or two later.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "It was very rapidly going-- everything.",
      "word_count": 6
    }
  ],
