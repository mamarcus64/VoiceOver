  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The Americans' MP came running, because he saw me.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And by that time, I pushed my mother through, she just walked through.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "In the whole commotion, she walked out, out of the station.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I nearly got arrested, I couldn't care less.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "The Yanks took me and put me out there, and you should not talk to the Limeys.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Limeys, they called them.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "The British, they were called Limeys.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "You don't know the-- Limeys.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Anyhow, I went out and she went to my uncle, and I went to Brussels, and everything was well.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I went to the-- a-- an open air dance.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I danced with a girl, jitterbugging and jiving and all that.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And she did was a good dancer, slim, lovely.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And then we discovered-- I discovered she's Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "I got taken in her home, she introduced me to her parents and things like that.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Her-- her-- her parents were in Switzerland, Genoa.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "They came back.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And I was taken like a son there, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And then-- and I was in America.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "'47.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Came to Australia.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "By [INAUDIBLE], a troopship came to Australia under [?",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Kohler, ?] God bless him.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "If that wouldn't be for [?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Kohler, ?] there wouldn't be any Jews here.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Arthur [?",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Kohler ?] was his name.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I lived in [?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Carden. ?] Funny.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I was very fascinated, new country and all that.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You know, I never had a peace, I never had life, I never had youth.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I was very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I had a rehabilitation [? code, ?] which the Americans paid for.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I learned cut and design and ladies' fashion.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I worked in Flinders [?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Lane. ?] The Americans paid for the course.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She worked at [?",
      "word_count": 4
    },
