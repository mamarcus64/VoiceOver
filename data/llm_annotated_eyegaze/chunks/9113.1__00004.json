{
  "stem": "9113.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We had an uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We had an aunt, my mo-- my mother's sister.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "She used to live not far from us.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "We used to visit her, like, I would say, at least once a week.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We went to her, like, on the Shabbos.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "After-- after-- after Shabbos, we used to go to the aunt.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And we were sitting by the aunt and [INAUDIBLE], she made her coffee.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And when she come to us, we made her coffee-- like, not the coffee.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "It was tea.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Tea, mostly.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "It was tea.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And this was our life.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Yes, I had cousins.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Which they were-- we were very close, very close.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And we-- and that's the way we spend our days.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Too much goals we couldn't have-- we couldn't, because we could never-- I could never go out of town to a high school because, first of all, it was very expensive.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They didn't accept Jewish-- like, Jews in the high-- in the high school.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And it was very, very expensive.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And besides everything, my father would never allow me to do that because I have to travel.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I could never dream to travel on Shabbos, [INAUDIBLE] Shabbos.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "This was-- this was a very great sin, and I wouldn't have the guts to ask my parents that they should allow me to do this.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I respect my parents.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "My parents had a chair-- my father has a chair in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Nobody would be able to sit on this chair.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Only my father.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "My mother has a place.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Everyone had a place in our house, and I would never take my brother's place, and my brother would never take my place.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And from the father and mother, there's no question about it.",
      "word_count": 11
    }
  ],
