{
  "stem": "1491.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So she says to me-- she calls me in Polish-- [NON-ENGLISH], I don't remember how old I am now.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Could you tell me?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "She remembered everybody's birthday.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "My grandchildren and children.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "But I think the medication has a lot to do.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "What she's taking, or whatever the agent.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "So she says, you know, my head doesn't work anymore, so good.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Could you tell me how old am I now?",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "This was a very depressing thing.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "How do you think that the experiences you went through influenced the way you've raised your children?",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Experiences-- I tell you, when I had my children, I didn't know what to do.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I was never exposed to small children.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't exposed to a family life, if you want to think about that logically.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "From the age of 10 to 16 I was locked up.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "What was my upbringing?",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Murder, fear.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And I was afraid that I'll make a bad mother.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I was so scared that you can't imagine.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Then I started reading Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "Spock book.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "He was my guidance.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "[LAUGHS] He was my god.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "And my kids couldn't swear till today probably.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "[LAUGHS] I never hollered at them.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "I never-- I never lost my temper.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "I used to always sit and talk, discuss what was something wrong.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And I have to say, I have two wonderful children.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Really, two nice kids.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I-- I would punish them.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I said, I will take away from you this and that, because you shouldn't be doing, but I never raised my hand.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I never lost my temper, which people couldn't understand, especially years ago you had the windows open, you had no air conditions.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So supper time you heard everyone screaming at their kids.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "My neighbors used to say, how come you never scream?",
      "word_count": 10
    }
  ],
