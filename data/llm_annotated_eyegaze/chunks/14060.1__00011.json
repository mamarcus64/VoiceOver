  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "But there was an implied and actively pursued antisemitism by the virtue of the fact that from the 1920s onwards, there was numerous classes where Jews were not allowed to attend universities anymore, or in very small numbers.",
      "word_count": 38
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "In other words, they were immediately excluded of higher education and professional training.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "In my time, they further extended this to apply to grammar schools.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "In other words, after primary school, from the age of 10, you were excluded to attend the good schools.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And therefore, what I'm trying to indicate is that it affected one in the sense of one's life generally.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "It was maybe not financially immediately.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "But the direction was going into the way of a restrictive existence.",
      "word_count": 12
    }
  ],
