  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I know-- I-- I knew the names-- Pinkus, Esther; Richard Drecken.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Who was-- Dora, Dora, Dora, [INAUDIBLE] I forgotted the name.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "A few names [?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I got. ?]",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "When the Russian came, I had my friend with his wife.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We took a small house, and we were-- food, the check they give us, food.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And they prepare a train to Krakow, [INAUDIBLE] beautiful for everyone, bed and food.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So we went to Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I took my my-- my-- you know-- my [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "My [INAUDIBLE] 10 kilo potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] Czechoslovakia and some clothes what Schindler gave us when he left for everyone, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "For coats, for-- when they came to Krakow, I said, [?",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Hela-- ?] she is from Krakow.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "I am from Krakow-- you stay here in the station.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I'm going to my flat.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to see what-- I walked, I walked, I walked.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "No hat, no coat.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Police patrol, police solider and Russian-- stop.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Where are you?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE]?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "I said, I'm from concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "They spoke Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Oh, you are from [INAUDIBLE], all right.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "OK, go.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "It was small market, square.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "And-- this was [?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "Droska. ?] You know what is?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "A-- a horse without [? that. ?] It's a taxi.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "I go, excuse me.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I came from concentration-- in Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "My wife in-- in the station.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I haven't got money.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "If you want, take me there and take me there.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Maybe I'm going to find some friend who is going to pay you.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "So he went.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "He took us.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We came to our place where I was living from before.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Outside is my friend, Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I said, [INAUDIBLE], first, pay him.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "OK, he paid him.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "He said, who is here?",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "This is some Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Your cousin is here.",
      "word_count": 4
    }
