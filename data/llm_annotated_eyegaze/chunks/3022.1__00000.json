{
  "stem": "3022.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Norbert Friedman, N-O-R-B-E-R-T F-R-I-E-D-M-A-N.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "That was my name at birth.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I had a nickname in-- in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Practically everyone had a nickname that ended with E-K, so my name was Nolek.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "N-O-L-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "December 20, 1922.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "72.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In Krakow, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "K-R-A-K-O-W.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "As I said, I was born December 20, 1922.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was born to a observant Jewish family.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I was the first born.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My father was a kosher butcher, one of 12 children.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "His father was also a kosher butcher, so were two of his older brothers.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "My father was born in the small town of [?",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Vialopolis ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Krinske. ?] Later on, his parents moved out to a small community of [?",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Zaubuoche, ?] which was adjacent to the town of Zywiec.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Jews were not allowed to live in Zywiec because the Archprince of Zywiec prohibited Jews from living there.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "So although they worked in-- in the town, they lived in the adjacent small town.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "My mother was born in the town of Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "She was one of six children.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "She had three sisters and two brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "My grandmother-- my grandmother's-- my grandmother's house was actually the house in which I grew up because, although we moved out to a different address, I spent most of my time and my childhood up till the age of eight in her house.",
      "word_count": 43
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And she was probably the dominant influence in my thinking and my set of values and my ethical and moral standards which she tried to explain to me in common terms, but were based mostly on Jewish ethical teachings.",
      "word_count": 39
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "My maternal grandfather came from a small town of [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "He was an Orthodox Jew, and he was a wholesale fish dealer.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "My grandmother was a descendant of a very well known rabbinical family.",
      "word_count": 12
    }
  ],
