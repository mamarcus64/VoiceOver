{
  "stem": "18932.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 105.5,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "This was before the ghetto, right, what I just told you about the beard being pulled of this, this Jew's-- you know, the whole beard from his face.",
      "word_count": 28
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Just grabbed and pulled him.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was just too horrible to remember to think.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "That's why I, like, distanced myself.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Like, I--",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No, I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I really was.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I was never hit.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I never--",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we were on a train.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And we were on a train for a long time.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And then we arrived to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And we looked out.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And I saw a lot of people running around with stripes uniforms.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I says, well, what's going on here?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They looked like they-- from some kind of inmates [LAUGHS] or something.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "So we went to-- they told us-- they opened the doors.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And they told everybody to get off.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So we got off the train.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And I was with my mother, my aunt, and that little cousin, and, I don't know, some neighbors or something.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "But going halfway through, I told my mom, you know, Mom, I think we left the passport on the train.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And I left a little pot-- a little-- you know, a little pot because we won't have where to cook something.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So my mom went with me back to the train.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And my aunt and my little cousin went with the rest the people.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And that's the last we saw of them because they-- because of my little cousin was so young, my aunt went with him.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And when I came with my mom, we, we went-- we didn't see anymore-- I saw my other aunt.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "There was my other aunt from my father's side-- was with a little tiny baby also.",
      "word_count": 16
    }
  ],
