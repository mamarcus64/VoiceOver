{
  "stem": "14737.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But usually those days, girls made their dowry and small things.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "You know, they had collected linens from their early childhood, was making embroideries, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "In all, they've been very poor.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So we take also our bundle.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "The shul-- the synagogue was filled up.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Men are not home.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Only women are at home-- older women, younger women, children.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Children age 16, 17, they didn't go.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And here I find myself a man, a young man in my late 20s.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And everyone is looking at-- toward me.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "I've already experienced.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "I went to labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "I know everything was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Forget about radio and paper, newspaper.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Even there is a newspaper, you're not allowed to read it.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Who was going to see you to read a paper?",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And beside this, in their paper is written only what they say.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They forbidden all these things.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "All this coming on Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They beating up Jews again.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But still, we don't see one German.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "It's only Hungarians.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "It comes the last day of Pesach.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "The day was the 7th of April.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "It could have been on the 14th or 15th of April.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "It was on a Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And we hear-- this was almost three weeks after the Germans are there, three weeks.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "We hear that neighbors are coming saying from the other towns, they took away the Jews, the entire community.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I looking-- who took away Jews?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Where, what, for children?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And from [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "How do we hear?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Peasants are coming who are walking there.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "They went down there to work and saw it with their own eyes.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "The last day was on a Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "They took all the Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Now Dovhoje, they didn't take.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] The next day, Saturady morning-- Sunday morning, I woke up.",
      "word_count": 14
    }
  ],
