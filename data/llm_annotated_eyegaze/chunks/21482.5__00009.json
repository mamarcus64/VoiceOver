{
  "stem": "21482.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And it was not what I dreamt of during the war, but we wanted very much to-- to work and make money and build a life.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So I worked in that factory till I was pregnant, and then I quit.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then I just stayed home till my children were born.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "How did you get to the United States?",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My girlfriend's uncle in Peabody, Uncle Harry White, who didn't know us, who was not a rich man, just the opposite.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He sent papers when Sonia and Blanca and Norbert came to the United States and told him that we had-- they had friends who didn't really have anybody.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He sent us papers.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So when we came to the United States, we came to Peabody.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We came on the first ship with displaced persons to Boston.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "All the other boats before came to New York.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "But we came to Boston, and they had an apartment waiting for us, and a job for Mark in a leather factory together with Norbert.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And then Blanca and I work in a-- went to the shoe factory.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, my-- our first one, our oldest one, was born in October 20th, 1950, had a birthday on Sunday.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And then, 14 months later, we had Marilyn.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And then four and 1/2 years later, we had Debbie.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And-- and they're married and-- And they all-- they are married, and of course we have six grandchildren.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We have five grandsons and one granddaughter.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Would you like to tell me about Anita?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Well, Anita got cancer 10 years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And she had breast cancer.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But when it was discovered, it was too late.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It never really showed in her breast.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It-- she never had a lump.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "But it settled in her bones.",
      "word_count": 6
    }
  ],
