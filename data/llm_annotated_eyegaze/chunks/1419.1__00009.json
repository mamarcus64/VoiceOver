{
  "stem": "1419.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And slowly, slowly, they took more people in from the-- the Judenrat called more people in, more people in to different kind of work, to building roads, to building barracks, and so forth, to building-- to building an airport, which was not too much of an airport, but you know, to fix an airport, stuff like that.",
      "word_count": 57
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "Every, every week, every, every month, more people started to be employed by the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "Now they would have to work for the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We used to go to work and come home and, and, and get food from there.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "If I was glad to have the work?",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I don't know I was glad.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "It was not exactly up to me.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But I, I was not happy to go to work, no.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "It was better to have work, right.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "It was better to be employed than not to be employed.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Well, this started when they didn't have no employment, if they were not [INAUDIBLE], as they used to call it.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They picked them up and they sent them out to-- supposed to be a transport sending out to the east.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "You never heard from them again.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We worked from 19-- I worked from 1939, starting late in 1939, till, till 1941.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I worked in Nowy Targ, my hometown.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "In 1941, I was sent to Zakopane, which is not too far from Nowy Targ, about seven kilometers.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "It's a little city right on the-- on the border.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And that's, what they say, [SPEAKING POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Resort, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "This was a winter and summer resort.",
      "word_count": 7
    }
  ],
