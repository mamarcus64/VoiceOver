{
  "stem": "26888.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "My sister was very sick there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "One day she told me, you know, yeah, my sister had a big stomach.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "She had a big stomach, and uh, and she thought first that she's pregnant.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "She didn't see it right away.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "She didn't say right away nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "But after that, she told me that she can't keep my sister because she has a big stomach and she thinks she's pregnant.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "I said, no way.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "My sister is not pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "My sister is very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "She had a full stomach of water.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And one day she told me that she can't keep her anymore, because she's sick.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "She was up nights with her, she says.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And she was alone, didn't have a husband.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "And she doesn't think she could keep her.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I says, listen, if she have to go, I have to go.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But where?",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We haven't got a home.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We don't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She says, well, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "She needs a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And somehow, I don't know, she said she has a son, a doctor, but he lives in Prague and that's very far.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "But she'll see that my sister should get a doctor because she saw I'm crying, and she got pity on us.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And um, and they brought a doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And they give an injection, and he said she has tuberculosis, very bad one, very sick.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And he give us some pills.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "She got better.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Postrekov.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And that's how we were staying til- til, uh- May the 5th, we were liberated.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Those people had three Russian soldiers hiding on top-- you know, on top of the house.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Like we had-- most Europe, they have that.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They had three soldiers hidden there.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "One day--",
      "word_count": 2
    }
  ],
