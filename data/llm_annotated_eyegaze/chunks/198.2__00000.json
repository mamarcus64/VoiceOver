{
  "stem": "198.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had in the ghetto, we had so-called, a Judenalteste.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Rumkowski, ?] And he was leading the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Before the war he was a president of an orphaned home.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And the first people who, every month in the ghetto, they had to deport so many and so many people.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So the first, he gave away his children.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "So he deported all the young children.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "We never knew in ghetto what was happening in 24 hours.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We all could be gone.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We lived just from day to day.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "We-- in the court I was living.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "They was-- they maybe with 50 tenants.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "Everybody was very cramped in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "The winters were very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "We just lived.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "We were heating the houses to cook the smaller rations we got, what we could get a hold-- boards from the floors, boards from whenever you could get a piece of wood.",
      "word_count": 32
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "By the end of the ghetto, we had no one-- not even one board on the floor, because we used it for fuel.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "We went to the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "We got one ration of soup every single day.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "Who was lucky got a potato, and who came the last didn't get any, got just a little bit of water.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They had commune kitchens.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have a kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They had commune kitchen, and we were getting a ration every day.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Only the people who worked, but the people who didn't work didn't get anything.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "The daily food consist of a little soup and one slice of bread.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We would go to the kitchen with a little-- whatever we had, the utensil.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And we took the soup back home, or we took it back to the factory.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Every day we got that soup.",
      "word_count": 6
    }
  ],
