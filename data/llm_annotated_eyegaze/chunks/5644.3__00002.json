{
  "stem": "5644.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So 7 was the one Muranowska, and then the next Muranowska, 9, was Platz Muranowska.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "That was a place where I actually brought in Karski.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Professor Karski.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I brought in [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I brought in, through from Muranowska 6, the Christian side, to Muranowska 7, our Jewish side.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Wild mean that was cleaned up by the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That's no more the Jews are living there.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "In smaller ghettos, closed in, when they made the cleaning-- the cleaning in Mila Street, when they took out--",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Not 18 Mila.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, not 18 Mila.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Mila Street was a cleaning--",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "--before, three months before the uprising was a clean three, four months, and they took all the Jews to sort out the ones which are working.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And they left in Warsaw about 40,000 in their opinion.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "In our opinion, 60,000.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I did, except that I got some people left over from the ones which I select.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We moved quietly.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We moved from room-- from house to house.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "We did have openings in every house, from one house-- we could move streets, not to be seen--",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "--but from one street across the street, we did have to go over the top.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Holes in the cellars.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "We could move streets, full streets.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No, not under the ground.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "In the cellars.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Because every house did have a cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "From one cellar to the other one, from one house to the other house.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We open it.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Completely.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "But when we got to cross a street-- the, the, the, the, the--",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "--the road, we did have to go out of the house and cross the road to the next--",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Across the road.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Across the road.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "To same street, but across the road.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "If you want to cross, we got to go to the normal street.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We smuggled.",
      "word_count": 2
    }
  ],
