{
  "stem": "18520.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 469.5,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "So I got the first time they sent me, I was good.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Send me for a week, five days, go in the bakery, vacation.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "So I worked in the bakery.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I know that my-- everybody is laying there dead, no food.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And here is so much bread.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "My father was a, a finger, toothpick, a toothpick.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't even move the, already the, the jaw.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "Dead people.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And the brother that came back, he didn't want to go.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "So he was laying in this side of the bed.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "He was laying in this side, dead people, dead.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "Nothing to do, nothing to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And my mother, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "Nothing, kids, nobody had to eat, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "Nothing to eat, really nothing-- a week, two weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 8,
      "text": "You eat grass.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 9,
      "text": "You pick grass.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 10,
      "text": "You did.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 11,
      "text": "You-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "So I, I, I was crazy in this bakery.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "So what I did, so I used to go and when the dough-- they made the dough, the machines-- nobody were there.",
      "word_count": 22
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Just [INAUDIBLE] you know?",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "So I used to go and rip a piece from this one.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "To the next one, where the fire is burning from the wood to cook this.",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And I used to put the coal on the side.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And I used to put this in.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "If they ever seen me, they would give me a bullet in the head outside.",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "But I took a chance.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "I didn't think.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Rumkowski people, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I saw him in the streets a few times going back and forth.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "I saw him, I saw him coming to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And, and, and then behind him, and the Germans they were nice.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "Who is your relatives?",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "Oh, everybody, everybody had a whole bunch sticking to him.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "When he came to Auschwitz.",
      "word_count": 5
    }
  ],
