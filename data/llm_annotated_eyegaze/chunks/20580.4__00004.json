{
  "stem": "20580.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was late, then we, we go away, about six, seven wagons.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "On the other side we come in [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "[NON-ENGLISH] is the village name.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And they put us on, and he says, listen to me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "We give us all the clothes that belongs to you, everything belongs-- we're the bosses.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And you organize the leather fact-- the leather.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I take this leather which I find with the Polacks and Ukrainish, all the leathers belongs to them.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And you organize, and we make our factory from leather.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "We put out all, and I-- now go, find workers.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "I say go to the-- they have workers, the Poland the Ukrainian, they have everything.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "They say we've got liberated-- everybody is liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Only come to us.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "And I find Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "And we're working.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "They're digging down a big hole, and putting up to make that leather-- boots, you know, belts.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And I start to make that leather, and we have two horses.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And we grind the, the wood.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "We have to be grind it like powder.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And we make that leather.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "And I make that leather.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "And the leather which I make it, then I go to the city.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "I could go to the Lwow and be free.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "I had a-- a name, a different name, a different passport, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "I could go to-- to Lwow, a big city.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I changed my name.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But I go-- I go to Luck, the big city.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We had lunches down there.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And we look for material.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "In Luck I look-- I look in the restaurant, [NON-ENGLISH] 28, the street, [NON-ENGLISH], in Luck.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I see the restaurant.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And the guy which is with me-- go with another guy with me-- he says to me, you not go in the front.",
      "word_count": 23
    }
  ],
