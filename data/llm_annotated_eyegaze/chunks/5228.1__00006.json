{
  "stem": "5228.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "That was our second language.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And then when we would get together with the Czechs, we'd speak Czechoslovakian with them.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And it was not-- I mean, we understood each other.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "We understood very good each other.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "Through the war and after, I saw how wrong I was to trust them with everything.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I got girlfriends and friends.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "In school, we was going together, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We used to sharing things.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "But then during the war, when they start, it was changing overnight.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "One girl, she was working in office.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "There-- OK, here, I have to on already, when was the war.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I was in-- in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "She was coming there.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "She wanted to help me to run, and then I run away in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "I didn't want it.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I have not for myself.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I have from my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But he was-- got beaten up, and he was a good student.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Just while he was-- the teacher was against Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I can't forget.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "He come with such a swollen hand.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "He beat him.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Not too many.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Not too many.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I remember more good things like that.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I remember that we was together, used to help each other.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "If they-- it was like the Shabbat, they saw it's raining.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We got something outside.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They just came and they took them.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They know I-- we were not doing this.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They helped us and we helped them.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "We did not to hating each other.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "That's what I think.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I didn't know to hate them.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I was thinking they're just-- just like we are.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "No difference.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "It looks-- to go on here, they used to make weddings, to inviting each other.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I mean, not to the dinner, not for this, although not in the synagogues to invite them.",
      "word_count": 17
    }
  ],
