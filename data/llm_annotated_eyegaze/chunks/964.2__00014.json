{
  "stem": "964.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And I was handy, so I-- I did it.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "Then he told me to wash the truck, and I did it.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "Then we had to pump it up by hand, truck tires, which was a hard job to fill up the-- the-- the air.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "And then he saw that I'm handy.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "He said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "You come tomorrow, come again.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "Because he had friends.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "So they-- I'm going to do for his friends, too.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "And-- and-- and while I was working there, he went for lunch.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 17,
      "text": "They had lunch.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 18,
      "text": "So he didn't eat the whole thing.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 19,
      "text": "So he brought back half of the-- his-- what do you call it?",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 20,
      "text": "Army-- they have this pots and plants.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 21,
      "text": "What do you call it?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 22,
      "text": "They're carrying always with them.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, so he brought back a half of his lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "So they gave it to me because I worked fine.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "He gave me a piece of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "He said, come on.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Tomorrow, come again.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "So I say, you have to tell the guy that he should let me go.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "So he told him.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Next day, I-- I-- I came again.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And he-- he gave me to clean the car, wash up to truck, to wash the truck.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And I worked with him.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "After a while, it looks like he went in-- they had a-- a repair shop.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "They owned a portable repair shop.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "Like, he had-- he had trucks.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And he opened the both of the sides of the trucks, and becomes a big, big, huge platform.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "They have lathes there, electric welding, all this kind-- all this kind of things.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "When I got there, my friend from-- from-- which is in Canada, and I have another guy which lives in Israel now, they were working already there.",
      "word_count": 27
    }
  ],
