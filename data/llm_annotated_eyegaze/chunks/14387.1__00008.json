{
  "stem": "14387.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we didn't have beds, the plumbing didn't work, but we thought that we really-- our humor was not bad, because we really thought that the British were going to come and get rid of the Germans.",
      "word_count": 37
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We really thought so.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "So we were just kind of waiting.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We were just sitting in Halldale, with very little money, because all they'd taken was petty cash-- they hadn't taken-- were not able to take money out of the banks.",
      "word_count": 30
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "They'd just taken petty cash.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And we just waited.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And then we finally realized, the British are not going to come.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "The British are not going to come to save Norway.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So we thought, oh, what are we doing here in Halldale?",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We'd better move to the city.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So we got-- all got on the train again and we moved to Stockholm.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we moved into a place in Stockholm.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Now, the Swedish government had moved-- they'd transferred the king to Stockholm.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And they were very anxious to help their own citizens, so they helped us find a place to live.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in Stockholm for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "We did receive a little, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We did receive a little.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And my husband did find work, because he had a trade.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "You see, that's what saved his life.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "His brothers couldn't do anything-- they were businessmen.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They always had been successful businessmen, but you just don't go out and start a business when you come to Stockholm like that.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "My husband was the one who had found work.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I had packed this one suitcase with clothing, and I had-- we had a lot of silver, and I had put silver in the suitcase.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Because I knew that would be valuable.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "That's what I had.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Myself?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I didn't work.",
      "word_count": 3
    }
  ],
