{
  "stem": "9230.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 10,
      "text": "Every time when she came for money, and they says, oh, Hannah.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 11,
      "text": "I'm sorry we don't have now.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 12,
      "text": "Maybe next time.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 13,
      "text": "Next time.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 14,
      "text": "Anyways, when the German came to take them out to send them to Cracow, and she says, I'm not going to Cracow.",
      "word_count": 22
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 15,
      "text": "I go the-- for-- to the farm what my grandmother gave me.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 16,
      "text": "And I want to die over there.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 17,
      "text": "And the baby was one year-- one year old.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 18,
      "text": "And the snow was so high.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 19,
      "text": "And the Polack, he likes so the, the, the town, even he wasn't able to work, and he came every day to look around.",
      "word_count": 24
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 20,
      "text": "And he heard babies crying.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 21,
      "text": "So he, he went in that place where the baby was crying.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "He says, oh, they kill all Jews in Cracow.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't like you should go there.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And he says, wait a few minutes.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "I have to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And he ask his wife what he should do.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "He came back [INAUDIBLE] for them and for the-- for the baby.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "He took them.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "He got under the house.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "He got like a hole.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "He got the-- the German, they took away from them everything-- potatoes, what-- what's growing on the fields.",
      "word_count": 18
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "And he cleared out, and he let them.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "You put them in that hole.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And after three days, he went to let them out.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "He knocked.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And my brother didn't answer.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "He knocked a few times.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "And my brother says, what is going to happen is going to happen.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "We are not leaving.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "They was laying on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 10,
      "text": "They wasn't able to stand up because it was only for-- to put some-- And he says, and make this.",
      "word_count": 20
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 11,
      "text": "You know what.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 12,
      "text": "And he says, what is going to be with us is going to be with them.",
      "word_count": 16
    }
  ],
