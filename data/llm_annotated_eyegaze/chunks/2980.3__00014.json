{
  "stem": "2980.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And he said-- the one that was in charge-- he said, what else have you got for us?",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He took off the boots of somebody else, this guy, Shiya.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And he wanted the watch.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "He says, I don't know where the watch is.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They realized that I was not there.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But I was up here, looking down here.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I saw everybody here in this little room.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And they're guarded by so many Poles with guns, and weapons, and hand grenades.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Then the, the big guy, the guy that was in charge, he says, lay down on the ground!",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "All of you, lay down!",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "So they start screaming and yelling.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Then he ran into a corner, and he grabbed a machine gun, and ddrrrr, ddrrrr, emptied out two, two, two things.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And they screamed and yelled and screamed.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "Then there was no more screams, no more yells.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And, and, and before that, they spread them out.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And they said, you're going to burn.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Burn them!",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "He says, count how many there are.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And they saw that one was missing.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "He says, [NON-ENGLISH], one is missing.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "He says, go seek!",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "[NON-ENGLISH SPEECH].",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "Quick, go look for him.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "So two guys went on top of the attic.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "And I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "And I was-- saw they're coming up.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "And I climbed up on the wall through, through the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "I didn't have a ladder.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "So I ran, and I hid myself, and I covered myself with straw and hay.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "And two guys came up.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "And they started-- one stood with the boot on top of me and looks for me.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "I was very small, skinny.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "And he's looking for me.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "And while, while he was looking, they start-- I saw that it started burning.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "They started yelling, [NON-ENGLISH SPEECH]!",
      "word_count": 5
    }
  ],
