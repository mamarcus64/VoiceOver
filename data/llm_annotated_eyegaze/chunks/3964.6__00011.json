    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We're married for 37 years, I think, or is it 38?",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I'm not sure.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Very happily married.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And at this point in time, I'm enjoying life.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I'm retired.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I retired in 1989.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And life is good to me.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I really appreciate the privilege of being able to record this for whatever purpose, for other people in the future to know that Holocaust was real and not a figment of some people's imagination.",
      "word_count": 34
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
