{
  "stem": "22856.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Allen Donald Goddard.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "G-O-D-D-A-R-D.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born with the name Gutherz, G-U-T-H-E-R-Z.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Dolek.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "D-O-L-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And Jewish name is [?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Abraham ?], [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is the 22nd November, 1915.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Next month-- oh, no.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "This month I will be 81.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cracow, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "C-R-A-C-O-V or K-R-A-K-O-W.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Cracow.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Leon, L-E-O-N.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "His surname was Gutherz, G-U-T-H-E-R-Z.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He was a private-- private firm employed.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "As bookkeeper, salesman.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was well-oriented in politics, in social work.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But generally speaking, he was a old soldier.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He spent 25 years in the Austro-Hungarian army and then in Polish army.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My mother was always at home.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Gustawa, G-U-S-T-A-W-A, or Gusti.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And the Jewish name was Gitla, Gitla-- G-I-T-L-A.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I had a brother, Joseph and Henry.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "All younger.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They're the youngest in the family.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We-- we lived in a flat, generally speaking.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "My father was a private employer, employed people.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "We couldn't buy any houses.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Our finances were minor.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, never.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Generally it was the Polish language, but my father and my mother spoke very fluently in German language, and little bit in Jewish.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "My father was a professional soldier, so he expected that we are always at his arm lengths and fulfilling his orders.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My father was really brought up in Germany, so he wasn't a great believer.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But when he married my mother, he promised the grandfather that he would help to bring children in Jewish faith, and he always adhered to.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He always went with me to the synagogue in Cracow, in temple where I had a chance to bless, because we are kohanim.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My mother was kosher, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We were members for years in Temple Cracow.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "It was a Orthodox, yes.",
      "word_count": 5
    }
  ],
