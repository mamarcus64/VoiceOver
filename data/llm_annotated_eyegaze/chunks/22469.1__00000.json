  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Victor Dortheimer.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The first name is Victor.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And the second I'm going to spell you.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "D-O-R-T-H-E-I-M-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "V-I-C-T-O-R.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Before?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Wigdor.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "W-I-G-D-O-R.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "16 September, 1918.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "How old I am now? 78.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Cracow, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We lived-- we lived together, my parents and three brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The one is-- The oldest was David.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I am the middle one, and the youngest was Michael.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "The age, two years.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We had a flat.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Three room flat.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Middle.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was enough for us.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, with my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oldest brother, David.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Another room.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Which street?",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The street was Cracow 22, Kalwaryjska 70.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "K-A-L-W-A-R-Y-J-S-K-A.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "For example, 80% of our neighbors, they were Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Catholic Polish, not Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I remember my nearest neighbor was named Kowal, like K-O-W-A-L.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "You want to know more about my neighbor?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They got four children.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "One of the son was with British army.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And he went to-- after the war to Scotland.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Unfortunately he died two years ago.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And he got one son what living in Dumfries in Scotland.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "With Polish peop--",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They're best friends.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They're best friends, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My friends, 80%, my friends, they were Polish people.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Catholic.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Catholic.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Of course, I got.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But majority was Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Not in our circle.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Generally, there were anti-semites in Poland, but not in our area.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "The first school, this was normal school.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And the name was [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "From 6 until 10.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And after, I went to gymnasium.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "This was gymnasium [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I went five years to gymnasium.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "All were in Cracow.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Everything were in Cracow, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Normal teacher.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Very, very difficult.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I've just a few names.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "One was Balala, and another, I don't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But in gymnasium, I remember their name, like Professor Harasek, Professor Krauzow, what was a woman.",
      "word_count": 16
    }
  ],
