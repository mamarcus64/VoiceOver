  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 60,
      "text": "He started, you know, the prayer after the death.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 61,
      "text": "He was singing it, you know, with his shivering voice.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And a Gestapo man passes by.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "He says, [GERMAN] 'Is he delirious?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "He's singing.' I said, no, he's not singing.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "That is the prayer of death.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "His friend died during the night.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And so, he just left them there.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So another friend of mine ran away, somehow, from work.",
      "word_count": 10
    }
  ],
