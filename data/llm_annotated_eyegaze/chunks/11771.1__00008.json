{
  "stem": "11771.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "He was asking me with such a-- worries, that I couldn't refuse him.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I couldn't say no.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "But from the other hand, I knew it's just impossible.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "We'll never make it to get out.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "But I say, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Let's try.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I was going to make in the front, a little window was open from there.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The Lithuanian allowed, because of the-- because of the air there.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I took Judy.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We went through over the whole things, and we got out the windows.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Nobody stopped.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "When I took her to Radun, at night-- it was already night.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I know the back ways to go.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I took her to Radun, and I left her in a-- a-- second cousins of my father, in their home.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They call her [SPEAKING NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Who was doing oh, things from wood.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He was doing all kind of work for-- for the peasants, for the-- for the farmers, when they were weaving the-- the knits.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
