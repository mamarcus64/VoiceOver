  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 4 SECONDS] Later on, they started to-- when there was no more-- only like 12 people there, so they came in and they said-- my-- my cousin was near the door.",
      "word_count": 33
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "And they said-- they took her out.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Oh, she was about 25.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Brenda.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I have her in the picture there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So when they took her out, we heard a scream-- screaming.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So we knew that something is wrong.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And then I said, I-- now when they'll come in-- and they locked the door again-- when they come, in I'll tell them that I'm going next because I don't want to no more hear and see what is happening.",
      "word_count": 40
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "When they came back, so they said-- I was right by the door-- by the door, so they pushed me back.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I-- they didn't take me out.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But they said, [RUSSIAN] in Russian, I shall lay down.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So I laid down on the floor with my face down like this.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I thought he was gonna shot me like this.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "He was with a gun.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "But they said, the rest shall lay down.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "So on one side, on my right side, my little cousin from nine years laid down.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And he put his head on my neck.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "[CRYING] They asked the rest people to lay down.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] When they were all laying on the floor, [CRYING] my-- my husband's sister was there.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "She was with two children-- [PAUSES FOR 4 SECONDS] five and seven years old, two boys, such beautiful boys.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "[CRYING] And she was, like, hiding them under her.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And they were all killed.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "They start to shoot them, one after the other one.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And I don't know, I was laying there on the floor.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "[CRYING] But I-- I didn't feel that I am shot, nothing.",
      "word_count": 11
    }
  ],
