  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Till-- till I was-- till I was 20 years of age, I was only working, and reading, and learning.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have anything, till I was-- after 20 years, I started to go out with-- more- more-- more-- more with boys, with girls, started to out.",
      "word_count": 27
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Then I started to be a little bit-- a little bit more public life.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise--",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Goldfarb, Goldfarb.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "G-O-L-D-F-A-R-B.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "For sure, he was a good man, till the last minute.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Here.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Till the last minute, till the last-- when the war started, he was not good.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "But please, please, please, I was wasting that much nights, to speak, to tell you all the story.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "This is a good lesson for you.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And you not let me.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "You now--",
      "word_count": 2
    }
  ],
