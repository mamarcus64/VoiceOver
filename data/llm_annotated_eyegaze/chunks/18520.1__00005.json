{
  "stem": "18520.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 468.9,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And my father used to bring from restaurant, from over there, from other singers, you know, they used to sing [NON-ENGLISH], little short pieces, [NON-ENGLISH], used to come, a chazzen, you know.",
      "word_count": 32
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Used to come there, and [NON-ENGLISH] and this and that.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH] he used to sing.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "So he used to write it down, bring it home for Saturday, Friday night.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I have it in my head.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "But I-- I-- you know, it's, it's over 50 years, 55 years.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "You know, I think if would be normal situations, I think you would remember everything.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Because you repeated.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish, Yiddish.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Every holiday.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We used to-- we have this-- we had a-- we had a sukkah [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "A joint, a community sukkah.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had a--",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Downstairs in, in, in the-- in the-- in the back yard, in the back.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "So we used to big [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "So I don't remember, six families, five families together.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Every time, we couldn't leave it.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You, you-- fresh, fresh.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Because we're lucky that every time we went down that it's still there.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "Because some-- some kids-- not kids.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "Even grownups, they broke it, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "They broke the wall, broke this down.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "They ripped the, the--",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The s'chach on top, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "They were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "Are you kidding?",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "This we eat.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, we ate there, sure, even it was broken.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "So we just quick put it back up, a little bit, and we showed the light and everything was there.",
      "word_count": 20
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Passover.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "They bought me new pants.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I got new pants, a new jacket, new shoes, new socks.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I know the young kids, they got-- the big brothers already-- I don't know what happened there.",
      "word_count": 17
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "But they were dressed not bad.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "My mother.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "No help.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Some cook, some cook.",
      "word_count": 4
    }
  ],
