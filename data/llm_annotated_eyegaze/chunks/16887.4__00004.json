{
  "stem": "16887.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "If you wouldn't be her sister, I wouldn't tell you where she is.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "But being that you her sister, I have no right to forbid her to see.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Please come in.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "As we walked into the house, the first thing I saw was her picture from communion, in a white dress and veil, standing on the dresser.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I broke down.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And then she told me that--",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I broke down because my emotion was-- I broke down for happiness.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "That my sister is alive.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It was Saturday.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "By then, it was Saturday evening.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "She told us that she's in a Girl Scout camp, which was-- by the river in Plonsk.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I can't remember how-- how far it was from Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And she says, there's one thing I could tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I would have gone with you tomorrow, Sunday.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "But my son is in a different camp.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "So my-- my neighbor is going tomorrow to visit her daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "She could go with you.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I agreed and didn't think of anything, that I could be killed.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "I remained there.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "It was after the [NON-ENGLISH] program.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I gave money my neighbors to take a buggy home-- home.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "And I remained overnight there.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "We both didn't sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "I was crying for happiness.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "She was crying because she knew she was gonna lose her.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "And then, around 4 o'clock in the morning, the lady knocked at the door and we left.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Before we left, she told me, I have one wish to tell you.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "Please don't tell her what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "Let her do what she feels to do.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "Don't-- other words, don't give her any ideas.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "I promised her.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "We went to the bus.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "I can't remember how long it took-- maybe an hour, maybe two.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "We arrived to-- to Plonsk.",
      "word_count": 5
    }
  ],
