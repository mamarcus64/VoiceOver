{
  "stem": "22856.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "One day I didn't go to the employment office because the rain was-- and to work in orchard when it's rain is impossible.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "So I-- instead to go to work, I stopped the bus and I went to Netanya.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Netanya was a small place which was just starting to develop.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I had to go to Netanya.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And the man was waiting for me in the central bus stop, the [HEBREW].",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "He welcomed me very much.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "We talked about this, about that.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And he said, listen, I promise my friend-- [NON-ENGLISH] was his name-- that I will keep an eye on you.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "All right, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "Next week, you're going to Jerusalem, to [NON-ENGLISH], to learn Hebrew and find out what are the tax problems.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "It will take some time.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "So I will send to your wife every week or every month, money-- that will be a loan-- to keep her waiting for you.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "When you finish the [INAUDIBLE], you come back.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "You'll find out where your accommodation in my office.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "Go now back and find out what your wife thinks.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "I come to Ra'anana, and I told my wife all the story.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "And she say, look, on the table is the lending permit to go to Australia.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "One son, Michael, was born in Krakow, in Bielsko.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes, because they wanted to re-privatize some houses, some properties their parents left and so on.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Oh yes, there were many of them.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "There was the synagogue, or the temple.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It was used by Germans during the war as a store.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But lately, they would clean it up.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But there were only a handful of people who came to Mignon, very little.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I went once or twice when I was in Krakow.",
      "word_count": 10
    }
  ],
