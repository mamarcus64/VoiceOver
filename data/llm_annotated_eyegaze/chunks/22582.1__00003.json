{
  "stem": "22582.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I remember my mother used to-- always used to say that in her family, everybody is eating everything put on the table.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I have one sister, which was-- she was the oldest one.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I had two old--",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Minka.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And then I have two older brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "One was Moses, [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Monek, ?] and one was [?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Benek, ?] Baruch.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And naturally, was a big difference in-- being that I was the youngest one, it was a big difference in-- in the year-- in the age.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "My-- my sister was 11 years older than I was.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "My brother was seven and a half years older, and one five years older.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "So I was the youngest one.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I was going to a private school.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It was a school which was formed about two years before I-- my-- I was going-- before I started school.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And my brothers didn't-- my other brothers didn't go to this school.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It was a Hebrew school where they taught the regular-- regular public Polish curriculum.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "On top of this, you had to have the Hebrew history and Hebrew language and Hebrew-- and Hebrew religion.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So we had about six hours every day school.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And it was six times a week.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "History.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "History was always my favorite subject.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I'm still very interested in history and politics and what takes the world goes-- [PAUSES FOR 4 SECONDS] the current history I like, too.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "So that was my favorite things.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "After school, we used to play soccer.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "That's what-- we called it football.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I was very interested in all kind of sports.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I was playing ping pong.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I was playing soccer.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I was playing all kind of sports, actually, whatever I could, didn't cost too much money.",
      "word_count": 17
    }
  ],
