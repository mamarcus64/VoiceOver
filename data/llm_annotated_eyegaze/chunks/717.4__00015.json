    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I nearly choked to death learning to smoke, but I learned.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We had everything, food clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "We lived in that apartment in town, in Furth.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I worked there for quite a few months.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "That was, say, in September.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I worked through September, October, November.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "December-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Some friends sent me-- I don't know why-- sent me to Feldafing, which was south.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "It was near Munich, to a camp.",
      "word_count": 7
    }
