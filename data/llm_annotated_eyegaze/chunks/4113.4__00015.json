    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "So the next day I was just biting off tiny little crumbs and kept it in my pocket.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "The soup was beet.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "Beets.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "Beet soup.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "Water.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And it depended what you got dished, because the guys who were dishing out the soup had their favorites.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "They got the bottom.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "I got the water.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "I peed maroon for weeks thereafter, because that's all I got, you see, and some ersatz coffee.",
      "word_count": 17
    }
