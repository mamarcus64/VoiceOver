  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "And he went, and he survived.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "He brought the Sefer Torah back to us.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "He was all black.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "I still remember him, like distinctly now, when I'm looking at him, all black.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "The whole-- and he had-- he-- he managed to wet the blanket.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "So the fire wouldn't-- the burning would go around him.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "And-- and then in we stayed for one night at the river.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "And in the morning, the German planes started circling.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 26,
      "text": "And they saw us running.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 27,
      "text": "So they start shooting, I mean from the-- from the planes, and lots of people died.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
