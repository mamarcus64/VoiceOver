{
  "stem": "4189.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And we lived in that apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And we got married in 1949.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And then after about approximately two years, we bought a house here in Flushing, this same house here where we are now.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "And we moved here to Flushing.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And then after another couple-- no, when we moved here, my wife was pregnant already.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "My, my daughter was born here in, in this house-- I mean, in a hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "But we stayed here in this house, my older daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And then about two years later, my other daughter was born, also here.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And so I said-- like I said, I have two children.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "The older one name is Heidi.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And the younger one is Elizabeth.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My wife's name is Laurie.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I have four grandchildren.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My older daughter has one child.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Her name is Amanda.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "She's three years old.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "My younger daughter has three children.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Their names are Jonathan, who is 11 years old, and his sister, [PAUSES FOR 3 SECONDS] Allison, who is 10 years old.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And then the younger one is Shawn, who is six years old.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And my daughters, both my daughters went to college.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "My older daughter is-- has an MBA, a master's degree in business administration.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "She works in Washington for the Postmaster General's office.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "My younger daughter also went to college.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And she majored in, also in business.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "But she majored in accounting.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And later, she had a job in-- with an accounting firm.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "But then when she had the children, of course, she's not working.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "Because she has a full time job, take care of three children.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "So [PAUSES FOR 3 SECONDS] I go into the--",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, I tell you, in the first early years, I could not talk about what had had happened in the-- during the Holocaust.",
      "word_count": 23
    }
  ],
