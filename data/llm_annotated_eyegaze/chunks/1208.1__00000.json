{
  "stem": "1208.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Let's see if we can go to it.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "If not, I have coasters in here, too.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Laura Hillman.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And it's L-A-U-R-A H-I-L-L-M-A-N.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Hannelore Wolff.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "H-A-N-N-E-L-O-R-E W-O-L-F-F.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born October 16, 1923, in Aurich, Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It was Ostfriesland, East Friesland, near the North Sea.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Martin and Karoline Wolff.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Also Wolff.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "There were a lot of Wolffs in our little town.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Distantly.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Rosel, Hildagard, then myself, and my brothers Wolfgang, and Selly.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Proportionately, there were a lot of Jewish people in our little town.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I believe we were 200 families.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And life centered around the synagogue and Jewish life.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We would walk to synagogue with my father on Friday nights.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And Saturday mornings, also with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And we had lots of youth clubs, a good [INAUDIBLE], and others.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And Saturday afternoon was a time to get together with family and friends.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "It was comfortable.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was spiritual as well because my mother would read to us from a book called [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I remember it so well because it always touched on something I had to know each and every week, year after year.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Both my grandfathers died when I was very young.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I do remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "But vaguely.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But the grandmothers were the matriarchs of the family.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We would pay our respects and go and get a Shabbos blessing.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And we had to curtsy.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And she would look us over and see if we walked straight enough or if our shoes were polished well.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "But it was loving, very loving.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh, holidays were wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The entire week before, the house was readied and all the foods.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Many people were invited.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my father would always bring home stray people from the synagogue.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Not only on holidays, but Friday nights, too.",
      "word_count": 8
    }
  ],
