  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 30,
      "text": "And we used to clean the floors and wash the floors, and all these sort of things.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My job was to connect a radio, repair this, a plug, or this or that electrical.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And the plumber, also, something there.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And that was when we-- we didn't overwork there.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And the girls used to have quite a lot of money.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Shall I say it in details, more in details?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Tell me, were the girls Jewish, Motel?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, there were no Jewish girls.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "There were only Lithuanian and Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They wouldn't accept Jewish girls, because, they said, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "So they wouldn't accept Jewish--",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "When the-- it was for only the soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It was the-- the brothel was only for ordinary soldiers.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "They used to come in at the door.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "They used to be examined and paid three marks, two marks goes to the girl, and one mark to the doctor.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because the Germans did not allow any Jewish mixed blood.",
      "word_count": 10
    }
  ],
