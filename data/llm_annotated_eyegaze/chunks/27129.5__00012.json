  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "We didn't have-- [LAUGHS] And we took on Cedar, on East Cedar and Holly, we took an empty store next to the J and M, an empty store.",
      "word_count": 28
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And we put in the fixtures, the chairs, and plumbing, you know, and we started working.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "And good enough.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "We had good clientele.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "We had a manicurist, a shoeshine.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "We opened up a first class shop with all the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "[LAUGHS] And so I didn't stay with the barbering too long, but a couple years, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "And then after one year, I went to the west side.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "I changed with another guy.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 19,
      "text": "You know, he took my part of the barber shop for his West Colfax.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
