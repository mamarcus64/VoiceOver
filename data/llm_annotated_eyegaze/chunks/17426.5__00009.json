{
  "stem": "17426.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The very main camp where we were delivered, with the sign, 'Arbeit macht frei' and with the orchestra playing and with the double fences and with the, with the electric wire.",
      "word_count": 31
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And we were told, as the barbers were shearing our hair off, that here you don't walk, you run.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And if you don't like it, you can go to the fence and end it there.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "There was a sign to that, proclaiming that.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "You have arrived in Auschwitz, which is a concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "You're going to be working here.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And if you are strong, you may survive three months.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And if you are very strong, six months.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And if you don't like it, you can go to the fence and end it now.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Needless to say, I didn't have this in my mind.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I wanted to survive.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "I wanted to go on, as long as I could, at least.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And so we were transported from Auschwitz-- after three weeks in this death block, quarantine block-- to Furstengrube.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "It was only about six, seven hours of walk.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "It was near Magdeburg, in Harz, in-- no, this was in Furstengrube.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "It was not far from main camp Auschwitz and not far from Buna.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "There we were sent to the coal mine, where we were to dig coal after-- at night, the foremen were blasting off the coal off the walls.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "We were to pick up the coal and put it on lorries, transporting lorries, out.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I had no instruments.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I have not-- no one of us was employed.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We were waiting to either be exterminated or be assigned to some kind of work camp.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, we did, we did, we did.",
      "word_count": 8
    }
  ],
