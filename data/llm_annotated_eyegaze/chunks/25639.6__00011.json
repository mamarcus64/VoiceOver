  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I just-- I remember the major ones.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We all-- we all had lots of whips.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Because, you see, in the camps, they told us-- somehow they let us know it's breakfast time.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Breakfast.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Zahlappell time.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And there was a small exit from the barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And we would all try to rush out, because they were beating us.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And somebody was beating us on the other side, and somebody was beating us from this side.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "So very often there was cuts, and slash-- I don't know.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "I got it many times-- but-- from these things.",
      "word_count": 9
    }
  ],
