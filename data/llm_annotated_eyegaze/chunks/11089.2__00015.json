  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "But even from the ghetto, they were taken-- the young boys and young men-- with trucks to go to work for the Hungarians in the forest, to build bunkers for ammunition and so on, and at night, we were brought back.",
      "word_count": 41
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "So it was very poor conditions.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "We were about five-- five weeks in the ghetto, altogether.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "But we had a meal every morning.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "The Chust rabbi, [NON-ENGLISH] he survived.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "His name was Shia Greenwald.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "Also from [?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "Sackmeuller ?] dynasty.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "I used to make him, every morning, a meal.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "And 1944, [NON-ENGLISH], which is beginning of June, [NON-ENGLISH] end of May, we were davening.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And they took-- they brought through a ghetto from a village.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "They threw in stones into our windows, and we couldn't finish our prayers.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "After that, he said to me, [INAUDIBLE], come over.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "Bring a scissors with you.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "Please come and help me cut my beard.",
      "word_count": 8
    }
  ],
