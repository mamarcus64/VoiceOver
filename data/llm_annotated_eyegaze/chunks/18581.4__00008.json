{
  "stem": "18581.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.3,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, strange enough, I hoped to do exactly what I did, because I-- I wanted to work in the foreign ministry.",
      "word_count": 21
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And that's where I ended up in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I was liberated on the 13th of July, 1944 by the Soviet army.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "The whole front of the Russians-- of the Germans collapsed.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And all of a sudden-- all of a sudden, we found ourselves free.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "At that time, since there were many Lithuanians and many units of partisans still on the loose, of Lithuanian partisans, the priest said, don't remain here.",
      "word_count": 26
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It's dangerous.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Go back to a big town.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I said, I-- I was in Vilna.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "He said, go back to Vilna.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "A day before that introduced me again to my friend 'Zirnofsky,' and we went together back to Vilna.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Well, I found very few Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And everybody was looking for somebody.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I was looking for an apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I don't think my apartment was in existence, so I was free.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So I found an empty house on Gedimino, on the nicest street.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And I made some changes, you know, a new lock and a few things.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I found some artisans and I got together a little furniture.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "And I lived there and-- What did you do to support yourself in that time?",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "In the beginning, I still had a little money from my boots, the golden coins.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I had a few.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And then I started immediate to work.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And it was a Jewish community and I started to work for the Soviet government that re-established itself.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And I worked in the ministry of light industry. | used my work there to help Polish Jews-- I mean, Vilna Jews.",
      "word_count": 22
    }
  ],
