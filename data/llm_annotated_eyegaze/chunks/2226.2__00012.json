{
  "stem": "2226.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "But I keep my ammunition.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "He keep mine ammunition, that man-- still alive-- 90 till-- over 90-- 90 years old.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "I'll give you the name.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "He lives in Windsor.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "His son is a rabbi in the shul.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have nothing to lose!",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Listen.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "The same thing-- I-- we talked by hand.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "What could we lose?",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "You see, every day so many people.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "There was the Hungarian come-- and go like sheep, they said.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "They didn't go like sheep, believe me.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "They had no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "Like I walked through.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "I could have gone in-- in the-- I went in crematorium every day.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 9,
      "text": "I was in crematorium every day like a mechanic.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 10,
      "text": "I was every day in crematorium.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 11,
      "text": "I know that Otto Moll who-- who burned the people.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 12,
      "text": "He was--",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "--the head-- the head man.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Moll.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Moll.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He after-- he come to [NON-ENGLISH], and they opened a camp in his name-- Moll.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 9 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I-- I took her out from-- I could have got her away from Auschwitz every day.",
      "word_count": 16
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I had that-- I had that suit, SS suit, and I had a gun.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And I had the papers-- everything.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "That fellow in Windsor.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "He keep that for me.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] That's another story.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "As soon I come, I was with a fellow, but the-- they hanged him in Birkenau.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "He had ran away with that girl.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "I give him-- I-- I took him out.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "His name was Edek Galinski.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "His number was-- he was from the first.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "When he come with no shoes-- nothing-- he had-- he was going to the same school like Pope John here-- then the pope from-- from-- from Rome, he went with him to school together.",
      "word_count": 34
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "And how I got it, you wondered.",
      "word_count": 7
    }
  ],
