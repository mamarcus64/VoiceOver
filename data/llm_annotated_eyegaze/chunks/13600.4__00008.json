  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] Now, you-- you had your-- your traffic officer's job on board the The left Marseilles.",
      "word_count": 19
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yes, on the way to Palestine, to Haifa.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "And about a day before arriving to Haifa--",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I'm not sure, but I would say 10 days as a guess.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was, on a guess.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember suffering from lack of food on No, that was organized by the Jewish agency.",
      "word_count": 17
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "And water, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "The only thing was the amenities were very bad, because you couldn't cater for so many people.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Huge over-crowding, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "A day out from Haifa, the English.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "The English were shadowing us all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "I don't know English warships.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "You could see the color of a warship is different than an ordinary ship.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "You see, you could see warship?",
      "word_count": 6
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "It's grayish, the same you see in Australia.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "It's always all over the world the same.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "A warship is different than the other one.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Yes, [INAUDIBLE] all the time from the very beginning.",
      "word_count": 9
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "From Marseilles, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Let's say a few hours after.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "The-- the intelligence was quite OK.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "They knew that we were coming out, trying to break the blockade.",
      "word_count": 12
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "In Haifa, the English approached us.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And the loudspeaker is telling us that we are not permitted to enter Haifa, Palestine.",
      "word_count": 15
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "July.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "I don't know dates.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "July definitely.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "Date I couldn't tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "'47.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "The middle of a hot summer, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "The British?",
      "word_count": 2
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Well, the-- the [PAUSES FOR 4 SECONDS] people who organized the ship were the Haganah.",
      "word_count": 15
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "They started throwing-- when they approached, they started throwing on them vegetable.",
      "word_count": 12
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "There was no exchange of fire, of course.",
      "word_count": 8
    }
  ],
