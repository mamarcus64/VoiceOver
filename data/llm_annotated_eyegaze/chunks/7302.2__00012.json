  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "They are sometimes missing a little button when it comes imported from there-- or a stitch, or--' 'Oh, yes,' I was saying. 'I-- I can do that.'",
      "word_count": 27
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] And they hired me.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "They were saying it was before Christmas time.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Well, I could-- I have been doing at home embroidery some, and I-- I have been good with a needle-- fine things to do.",
      "word_count": 24
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "In Simpsons, I worked for 18 years-- close to that.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I-- I could have worked longer.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "But my husband-- after 18 years, I worked.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "He retired by 65.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "I haven't been 65, but he retired.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "I thought it's time for me to quit too.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I was saying, they-- they have been shocked.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "How can you quit?",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "My customers, they loved me.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "How can you quit?",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I have been awarded there a couple of times for good work, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "They liked me very much.",
      "word_count": 5
    }
  ],
