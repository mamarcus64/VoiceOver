  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Pushing a little cart with ammunition from place to place, loading and unloading.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Until one day, one of these men, when we are sitting and eating lunch.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And it was not lunch like on [INAUDIBLE] lunch in-- on Sixth Avenue.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "There was nothing to eat but your fingernails.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And this man approached me face to face.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He said, I know that you are [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And then he handed me half of his sandwich.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And he said, I will help you out.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Just say [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I accepted in good faith, and didn't answer him, and kept going.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "After the lunch, and the following day, he left again half of a sandwich.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And then I realized that there must be either a trick or-- or something else going on that I don't understand.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And then he told me that he is from the party, and he will do everything possible to arrange for me to escape.",
      "word_count": 23
    }
  ],
