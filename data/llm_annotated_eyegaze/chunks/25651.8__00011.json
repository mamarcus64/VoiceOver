    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I think he was preparing the ground.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Don't forget, he-- he was a very intelligent man.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, for the end of the war.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It was summer of 1944.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "The Russians were on the other side of the Vistula in Warsaw, which is a very short distance away from Auschwitz.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "But the Germans must have seen the writing on the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I think that they did it-- it would look good in front of a judge.",
      "word_count": 16
    }
  ],
