{
  "stem": "11916.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] Mother was a childish person, but she was a very, very charming person.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Her life was more like again for music, dancing.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "She was an outgoing person.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "She ever liked to go to parties.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Have a lot of friends.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "She also liked to play cards.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "She have a little group weekly.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] She took her daughters every night out.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "We used to have a park where people used to come together.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "You show your daughters.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "There was, you know, boys there.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "They met with their companies.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Especially in the summertime, from there for you go maybe a little treat, cup of coffee, piece of cake.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And there was always music in the park.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "They was allowed to stay out till 10 o'clock.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "After 10 o'clock, you have to go home.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "The town is become quiet, nighttime come.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And it was pretty well the rule.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "When you go home, you met with boys there.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "They take you home.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And you only call them inside when you going seriously with some boy who probably will marrying you.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "And we also have a lot of other companies in the house.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "The house was never empty.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "Filled with people and animals, whatever you please.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Only my grandmother and grandfather was there, also, my uncle, a brother of my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother name was Josefin.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And my grandfather name was Farkas.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father's parents.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My uncle name was Bela Pollak.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My grandparents.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents originally came from Czechoslovakia where my grandmother born.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My grandfather born probably in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And they did not live in their young life in Gyor.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They was living in a smaller place more like a village.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They have there a shop, like a grocery shop.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Plus, my grandfather have a business.",
      "word_count": 6
    }
  ],
