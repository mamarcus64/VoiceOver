{
  "stem": "19130.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 374.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I thought we were lucky that we came back, you know, after that.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Since then, it was still a dangerous time.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Since then, we never went there.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Oh, to-- oh, Poland, we left in 1960.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We-- I came in 1957.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "It was a time, you know, it was a time when the same thing, like-- my brother filed the papers in Russia at the same time with I to go.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He is a Polish citizen, too.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So he filed the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And they go to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And in two weeks, you could go to Israel, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It was a transit.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But when we came, it, it was some reason they didn't give me-- so, yeah, Russia, they didn't let me go so fast.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They keep me there for few-- four months.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And they, they find all kinds excuses that I'm not-- my papers are not good.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Something that maybe I'm not from-- not a Polish citizen.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They didn't-- but finally, they let us out.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And when I came, it was already closed.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "They-- you couldn't go to, to Israel anymore, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "It was a-- but after three years, they opened again the-- in Poland, you know, I worked like a furrier, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In Wroclaw-- it was Breslau, Breslau.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Breslau, B-R-E-S-L-- [PAUSES FOR 3 SECONDS] V, I don't know-- Breslau, Breslau.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Used to be-- in Polish is Wroclaw.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They used to call Wroclaw.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I work in a-- in the beginning, I, I start to learn to work by meat, and then I think it was like a-- later, I work in a [NON-ENGLISH], you know, like a delicatessen in Israel.",
      "word_count": 37
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I live in a-- in the beginning-- in the beginning, we live [NON-ENGLISH].",
      "word_count": 13
    }
  ],
