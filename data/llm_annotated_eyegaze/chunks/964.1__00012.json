  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I went into Turek, and there I met my mother already.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "You know, you are so mixed up, so tense, that I did-- forgot to ask her, well, how did she get there?",
      "word_count": 22
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Probably she got there hitchhiked on, on, on, on a horse and buggy, something like that.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And then we, we, we-- my brother left his wife there.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And we went on the way to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Because in Warsaw, they-- the Poles used to say, well, the Germans are so heavy.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "They have such heavy, heavy equipment that they'll never make it because it's--",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Because it's-- the, the, the roads are dirty roads, and, and they get bogged down.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "This what they were trying to tell us.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So we--",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We've got to do it.",
      "word_count": 5
    }
  ],
