{
  "stem": "26447.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "That it was in the year 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The [? pogrom. ?] And I wasn't old, just a baby. 18, 19 years old, approximately. 18 or 19 years.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "You know, and the time is-- I don't remember now the months or the date.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Who can tell now?",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "It was a time to the fall-- closer to the fall time.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "That's-- approximately, it can be August or in that time.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "But it was not cool weather.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Because when I jumped, I didn't got so clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I was only-- my pants and a short and that's all.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "When I came to the first house, I need-- I told you that I need to come to my village.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I need to come out through a river.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Because we didn't got a bridge.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "The bridges was in Kolki, but I didn't went through Kolki.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I must go through the river.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "When they come to the house, I was asking the people through the window.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "At nighttime, I'd knock them.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "It was a big mistake, my mistake, what I've done.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "No, I was done.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And a lady answer me, I cannot come out.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "I am afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "I have small children.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "And I stay like, I don't know-- I'm only alive or I am dead.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "I am afraid by myself.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And she began to tell to me like that.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I'd say, I cannot do nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And go-- she's telling me, go to another house.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "Maybe somebody will come out in nighttime, and they will take-- with the boat-- they will take you on the other side river.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "I went from that place to another house.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "I came to another house.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "It's happened the same.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "I knocked at the window at nighttime.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I have the [INAUDIBLE] in my hand.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Everybody got afraid at nighttime.",
      "word_count": 5
    }
  ],
