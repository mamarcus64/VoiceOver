  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] So I said, OK.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Better in Russia than here, even though Stalin was just as bad as anyone else, as Hitler.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And I thought that really during the night when I slept, I said to myself, now next-- tomorrow I'll be in Russia.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "I thought about it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "But things changed.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Because next morning what happened is, during the night they sent all the others to concentration camps.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They wanted to empty the prison, to empty it out.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So all the others went to concentration camps.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And in the next day, during the morning, they called again the seven people together.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And it was in the evening.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "It was in the evening.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They said to our seven, you are free.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Go downstairs to the office and get your papers.",
      "word_count": 9
    }
  ],
