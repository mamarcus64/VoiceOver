{
  "stem": "27687.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But somehow, on the way to Lyon, we passed through Grenoble.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And when we came to Grenoble, they mixed us up.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They had assembled all the Jews from the whole district to transport them to Drancy.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Drancy was the concentration of all the people to go to Poland and the concentration camps in Paris.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "It's just outside of Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "So actually, I was lucky again.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Because I didn't end up in Lyon to be interviewed or interrogated by the Gestapo.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And we ended up in Drancy.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And I stayed in Drancy about a week.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And they loaded us up in cattle cars, and they brought us to Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "We didn't come in into--",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "--Auschwitz.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Go by train?",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in the cattle cars.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I think it took us four nights.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Four nights-- four-- three days, four nights.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They didn't open up.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They-- they gave bread.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "So many people in the car-- they gave us so many breads.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And they gave us so many buckets of water.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And they gave us so many buckets empty-- to relieve ourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And there were whole families.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "There were men, women, and children.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I was alone.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And they never opened up the wagons.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And by the time we got to Auschwitz and they opened up the doors, we had six dead people.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In our car, we had six dead people.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Out of the six dead people, we had one child what was maybe-- maybe-- five years old.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But one.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "One little girl.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Anyhow, when the doors opened up, the SS was there.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "They said, now, we are sorry that you had such a bad ride, but the bahn-- the train was delayed.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "But we're going to-- we're going to compensate for it.",
      "word_count": 10
    }
  ],
