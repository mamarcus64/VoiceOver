  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "I-- at that point, I destroyed every paper of mine.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "I could been called Tom Jones, except I can't sing.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "So it-- and I could have been born wherever you like.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "Anyway, I was given an identity paper, which didn't look like me at all.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "We went into the bus.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "They sometime used to-- Russians-- check the buses in Wiener Neustadt on the way.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "And my luck, the radiator of the bus started boiling up.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 46,
      "text": "I spent two, three hours on the roadside with people who I didn't know and it didn't-- wouldn't have taken them long to find out that I wasn't from the locality.",
      "word_count": 31
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 47,
      "text": "Came another bus from Vienna.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 48,
      "text": "I went up, and I arrived in the 18th bezirke in the Hernals, which the [INAUDIBLE] which was the parallel camp to the [INAUDIBLE] in Vienna for immigrants and refugees. 1949, April.",
      "word_count": 32
    }
  ],
