{
  "stem": "8002.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "Well, we didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know, because we didn't even figure that we're going to survive.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "Sooner of later, we didn't think of surviving.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "We thought when we're going to get killed.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "That, that was actually our expression.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "Because we didn't mean anything but surviving.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "We were survivors.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "We tried to survive.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "But in our mind, we know we're going to get killed sooner or later.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "Did anyone try to escape from the train from Kaiserwald to Stutthof?",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, but they tried in Stutthof.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And they caught them.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And they, they, they feed them to the dogs-- two people in Stutthof.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Isaac was one.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Isaac Berkowitz was one.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And there was-- [PAUSES FOR 4 SECONDS] I think it was-- Chaim, Chaim Liebowitz.",
      "word_count": 14
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "They tried to escape.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "No, they weren't shot.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They've wished they would shot-- be shot.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "They caught them.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "And they had maybe 50, 60, dogs there.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And they fed them to the dogs.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "They, they put them in a circle.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And they sic the dogs on them.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And the dogs rip them apart, limb by limb.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "No, we have to stay to attention.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "We had to stay to attention.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And if you turned your head, you got hit.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "We had to stay in, in attention, like an appell, they used to call it.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in rows-- maybe about 12 in one line.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And we had to watch.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Everybody had to watch.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Oh, maybe an hour, hour, maybe an hour and a half.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I didn't count.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "I didn't think.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "But we had to stay and watch.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "And the dogs was ripping them apart.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "In beginning, there was screaming, And then it was quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "It was very light.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Was very light.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "We used to go out work 6:00 in the morning.",
      "word_count": 10
    }
  ],
