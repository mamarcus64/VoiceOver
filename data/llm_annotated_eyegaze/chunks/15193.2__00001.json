{
  "stem": "15193.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The other brother, who also had a tremendous job already in a-- in a business in East Prussia, [NON-ENGLISH], also felt the pressure.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And he went to a [HEBREW], because you couldn't get into Israel unless you were able or wanting to work for a farm.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So they-- he went, and he left for Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So when, then, came that we were going to send Lea, the youngest, to Israel, my mother felt, perhaps the boys will look after her.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "But Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Henrietta Szold ?] took her and hundreds of children with her.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And my mother, and I, and my father went to the railroad station to see them off.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother almost collapsed.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was a terrible thing.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was there, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And so she went.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was-- I must have been in the 20th, in the 20th.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And so in the meantime, I still worked for that brewery industry.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And we were very honored with the brewery industry.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We had to go to the companies and taste all their beers, because we controlled the beers.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And we had to-- and we had to be-- we had to be there all the time.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "But my eyes and ears always were open.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And finally, finally the big boss called me in.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And he said, [NON-ENGLISH], we cannot keep you anymore, because the government wants to have their hands in our business.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And we have to give them the names of every employee and every background, and we know you are Jewish.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And you wouldn't last.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "So they gave me six month wages to cover me until I found another job.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "That must have been in 1935.",
      "word_count": 6
    }
  ],
