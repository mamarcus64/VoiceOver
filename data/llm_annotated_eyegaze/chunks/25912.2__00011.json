  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And I handed it back to her and ran off.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We had a rickshaw, which was a means of transportation in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And we were in a rickshaw going to the big ghetto, to the police headquarters, when German units passed us on the way to the action.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "We spent a whole day there, and then in the evening-- the Germans were very organized.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "They only did the action between certain hours.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "So the nights were quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "They were sleeping, and so were we.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "So once the action had finished, we went back.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] And that is another of my very, very, vivid memories, when we arrived at the workshop.",
      "word_count": 20
    }
  ],
