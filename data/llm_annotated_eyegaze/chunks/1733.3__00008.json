{
  "stem": "1733.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Some people thought-- were very proud that they are Jews and they survived, and they put their nationality as Jewish, later realizing that that was a big mistake that they made, because once you were Jewish and you were born in Russia, you became a Russian citizen immediately.",
      "word_count": 48
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I gave 'em-- I gave 'em the nationality Czech, and I became Czech on my identifications.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I don't know how   long I spent in Prague, but somehow I got on a train.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And we all were gravitating towards home to see who survived and who didn't survive in the concentration camps, and wound up in Loucky again.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't aware of being liberated because I was sick.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I was sick in the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "You know, I only knew when I was getting better that the war is over,  and everybody is free.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I went to Prague.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Not-- not any more than 10 days or so.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Oh, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "One of-- one of the men-- boys that was liberated with me, in the same transport, later became my brother-in-law, Esther's husband, [PAUSES FOR 4 SECONDS] Morry Eisderfer.",
      "word_count": 28
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, I found nothing was left in our house.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was empty.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Everything was stripped.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Nobody was living in there.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] Some of the neighbors wanted to know how come we weren't killed.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] My present-- Etta's home became the center of our activities that was supported by the Joint Distribution Committee.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "We set up a kitchen there, and anybody that came home, we were cooking there and feeding everybody.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "At that time, we were waiting to hope, to hear from all the-- whoever survived.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "One day, my two sisters came home.",
      "word_count": 7
    }
  ],
