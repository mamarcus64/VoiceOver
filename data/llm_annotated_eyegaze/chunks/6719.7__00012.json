{
  "stem": "6719.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "That was my-- the baggage that I carry around.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And that's the unfortunate part.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "You know, I've-- I think I've said it before, but I going to mean-- I say it very quickly again, there are people that I know that were in camp that can't forget.",
      "word_count": 33
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "But they can live with it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "In another words, they don't want to talk about it.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Uh, sometimes when we get together we talk about incidents, or something like this.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "But I live with this bloody thing form the moment I wake up until I go to bed.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "There's always something that turns me to think about events that happened at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "But let's talk about my wife.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "She was the most beautiful-- oh, was she gorgeous.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "She still is.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "She's beautiful.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "But she was-- she was-- she was my lifesaver.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "She uh-- she calmed me down.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "And uh, we think that uh-- OK, so a year later, we had uh, our daughter.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Claire.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Claire.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "C-L-A-I-R-E.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Claire de Lune.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Ah, what do you mean, her maiden name?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That's her-- that's her name, Claire.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you mean her maiden name.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Uh, Kimmerling.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "K-I-M-M-E-R-L-I-N-G.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I think it's two M's.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, uh, I met her at the street car stop.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "There was a guy down there-- oh, this is funny.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "It started to rain.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I had a Jeep and a driver.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And the driver was a Dutchman.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And uh, all of a sudden, it stopped.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "It didn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "The machine didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "So I got off.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And uh, it was opposite the theater.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "There's a theater down there called [NON-ENGLISH] in Salzburg.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And there was a street car stop.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And uh, so uh, I stood there.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And it was raining.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And all of a sudden, a guy comes up to me.",
      "word_count": 11
    }
  ],
