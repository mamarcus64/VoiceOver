{
  "stem": "1419.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "I had some family which was aunts and uncles, which they emigrated before the war to Israel.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "So I decided to-- I had an uncle here in, in United States, the one who came from, from England.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] So I wrote to him, I want to come to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "So he, he, he wrote me letters, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "It's very hard to get out from Israel to United States on the quota, on the quota.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I had to go back to Germany and to come back on the-- on the-- on the [INAUDIBLE] quota again.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "So I went back to Germany in 1950.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Luckily, I, I was mated.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I met my wife in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And we met in Munich.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She was attending the art school in Munich.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And in 1951, I came to United States.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I didn't do much in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I just waited for papers to come back to be-- to, to get my papers to come to United States.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We got married in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I left because my wife had the papers to come to the United States, so she had to come on her own paper and I had to come on my papers.",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So we-- I came to the United States in May 1951, and she came in, I think, in August or September, something like that.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "She will tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And we got married in, in November in 1951 in, in the city of Vineland, New Jersey.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We had some friends who had chicken farms in Vineland, New Jersey.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So we moved to Vineland and we married.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And I-- and I came to United States.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I had already somehow-- some kind-- some kind of a trade.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I was a machinist.",
      "word_count": 4
    }
  ],
