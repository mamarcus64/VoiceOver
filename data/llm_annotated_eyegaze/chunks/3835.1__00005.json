{
  "stem": "3835.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was my-- downstairs, where we were living, was a boy by [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I went to school all the years with a boy by the name of [NON-ENGLISH], and [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We had quite a few, quite a few names.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Saturday afternoon, when my father and mother went to sleep, after dinner, we had free from-- from like, 2 o'clock to 6, 7 o'clock.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Then we played.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Wintertime, we ice skate.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And naturally, it wasn't 100% kosher to take the steel-- metal skates, but I hide it under my coat.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And I went out of-- away from the city, when we could enjoy ourselves.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "In summertime, we went also to play ball, soccer.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "This was our-- and a couple of weeks, we had swimming, also.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "When it was a Jewish holiday, like Tisha B'Av, or-- we went swimming, whenever we had free.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "But a whole week, we were busy from 8:00 in the morning till 8:00 at night.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And then sometimes I worked on my lessons till 12:00, midnight.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And my father said, when are you going to sleep?",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Cut off the light already.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "It's late.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And sometimes I wasn't finished at 12:00 and 12:30 at night.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Were any of your friends Gentiles, Christians?",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Christian friends, no.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Since I was maybe 10 years old, I was in Zionist movement.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And later on, I was in Betar.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Matter of fact, I was [HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "The last two years, before the war, I was the head of Betar in my town, in Ostrowiec.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "To tell you-- to tell you the-- [PAUSES FOR 4 SECONDS] what do you-- what do you say there?",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "The idea of Betar.",
      "word_count": 4
    }
  ],
