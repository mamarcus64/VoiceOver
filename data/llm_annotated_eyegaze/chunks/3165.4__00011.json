  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And all my friends in the orphanage-- it was just one bathing suit-- oh, they were so envious, you know?",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Then, in the summer, I put on the bathing suit.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And also, I remember I was getting boxes of oranges-- big oranges.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So of course, when I get the box-- and it was on my name.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And when I get the box of oranges, I would share with all the kids.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "My sister, of course, with all the other kids in the orphanage.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And we just-- It was so good.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "It was so delicious.",
      "word_count": 4
    }
  ],
