{
  "stem": "25835.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And one day, when I was almost OK, came Aufseherrinen-- [INAUDIBLE], this mean SS woman.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And she asked me something.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "I, answer in German, in proper German.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "She said, OK, go with me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "You will not go to ammunition factory.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "Go with me to work in warehouse, where they kept food for [PAUSES FOR 3 SECONDS] all people and for SS group.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "I suppose that will be better.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "No-- [LAUGHS] 16 hours daily.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "I am like skeleton, like shadow, working so hard to clean this barrel, to, to clean floor.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "But I had some possibility to steal something.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 25,
      "text": "My highlight, my goal, was to bring in small pocketbook to my mother and my sister.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 26,
      "text": "But I-- slowly I stop to talk because I was depressed, going without hair, without dress, without underwear.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 27,
      "text": "I was passing urine like crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "When I was still in factory-- and they took us at 5 o'clock in the morning with a shepherd-- German shepherd dogs.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We were-- we were going about couple kilometers to this factory.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But everybody wants to be on the front.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Because when was on the end, the German shepherd was [PAUSES FOR 3 SECONDS] biting people on the end.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I remember that my mother was so, so weak.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We had to help her and to carry her, almost.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "In this time, it was cold, wintertime.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And I had frostbite on my leg here.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "It was open wound-- pus going out because was open.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And also passing, without knowing, urine.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I tried to put some rags or something, but it doesn't help.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "This time was very hard for me-- losing weight.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I remember one day, when was hurry to go to factory, I was not enough fast.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "This commandant of our Kommando said order to German Shepherd to get her.",
      "word_count": 13
    }
  ],
