{
  "stem": "4122.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "She was killed in there in bed, because they couldn't, she couldn't go out.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "So they killed her in bed.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And they, they brought hundreds and hundreds, thousands of people to, to the trains.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And they put them in, in wagons for cattle-- for animals.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "They took them to Belzec.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "This was when my father was taken away.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "I'm so mixed up.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My brother was taken this when we were at home.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I didn't say this.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They were taking men to-- when we were still in Zawalow-- we can not go back to this tape, could we?",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "When we were still in Zawalow--",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was in 1940 or '41.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No, '41.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "It was in 1941 still.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "But in the beginning, so they took him to a camp--",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "To a work camp--",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "--to Buchenwald, and to Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And I went from there, from home, to bring him some food when I came there, where he was in the camp.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he was only 14 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "He was older and so tired he couldn't even walk no more.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "He didn't want to, he didn't want to come.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Always when, when they were working there was music playing, such loud music, music, and they were beaten.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "When I, when I came there and he was told that his sister came.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I came with another girl.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Her husband was taken also to this camp.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So they took, they told him, and he walked out of-- he got up when he heard that I am there.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He said I, to me, I don't know where I took the strength to get up and to come to see you.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I brought him some food.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He was so hungry that he hardly can, could talk.",
      "word_count": 10
    }
  ],
