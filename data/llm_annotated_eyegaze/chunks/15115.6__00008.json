{
  "stem": "15115.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "What my wife's going to have?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] he's sort of mellow.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And then his wife got mixed in.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I says, well, this is a family [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I says, OK, that's the case.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I says, Lou, I'm quitting.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Here's the keys.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I give you three weeks' notices.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "He says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] keep your keys.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "When three weeks come by, then I quit.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't prepare myself at all.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I was completely out of-- I was lost.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Here I was, a busy man.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "I was working seven days a week, 70, 80 hours.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "But I was getting paid, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "I was making good money for me, and for him too.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And all of a sudden, I'm out of a job.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And I am miserable, real miserable.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "So I couldn't sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "I went to bed, couldn't sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Then I went to New York, to the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "I went to eat at a butcher shop.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "I told him.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "He said, what are you worried about?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "He said, come over here.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "So I couldn't go to the States anyway.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "So I got a couple of drinks, and I went back to Toronto.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "I came back to Toronto.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And there was a store across the street.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "Then I was sore that they rejected me.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "You know, they reject the offer.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And there was a store across the street, also an army.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It was for sale.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I was going to buy it and be in competition with them.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I went to the bank.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I-- Sunday night, I took stock of this [INAUDIBLE] market, [INAUDIBLE] the store.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I took stock, and there was $40,000 worth of inventory.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And the bank-- I went to the bank next day, which was across the street.",
      "word_count": 15
    }
  ],
