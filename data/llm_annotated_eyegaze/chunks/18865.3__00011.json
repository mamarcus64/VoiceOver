  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I really don't think I had a concept of what freedom really meant, especially since I didn't find it that exciting, that obvious in England.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Like I told you, this-- the way she said, but she is nice, this seemed to come up more than once.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "This is my-- it was always the fact that I want you to meet my new Jewish maid.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Always the word Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Why did she have to put that in?",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I didn't realize it then but it did-- there was something there that was wrong.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I was just a girl who came, a refugee, but why always this word Jewish?",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We have to change tapes again.",
      "word_count": 6
    }
  ],
