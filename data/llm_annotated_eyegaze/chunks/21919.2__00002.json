{
  "stem": "21919.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They-- but they rounded up most woman, children, sick people, and old people-- put them on big trucks and took them out of town, where big graves were dug by Jews prior to that.",
      "word_count": 34
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And they were told the digging was for oil tanks.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't know it was their own graves they were digging.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And there were three huge graves like that.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "They're still there-- huge graves.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It was out of town.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was, I would guess, a few kilometers out of town.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And they were lining them up like sardines, on both sides of the graves, and then shooting one, who fell with their heads this way, and the others over that way.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "They told everybody to take their clothes off, to take their jewelry off, and throw them in a certain pile.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And certain girls that were really good looking and beautiful were spared.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They told them to go away, to the side.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Most of the others were shot.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my mother, who had the two children, and my grandmother were in one of the trucks that went with the first pogrom.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And they were shot.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And me and my father were outside the ghetto working.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Actually, I wasn't supposed to be, but he wanted me to go so I could help him bring some food home.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Because you were in the fields, you could bring potatoes home or exchange something for milk, and bring for the children.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So I was out of the ghetto with him.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And that's how we survived.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Immediately, people were coming from town.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We were in the fields outside of town.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Immediately, everybody knew about it.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "[SIGHS] And to confirm that they not there, my father told me to go in to the ghetto the next day and check.",
      "word_count": 23
    }
  ],
