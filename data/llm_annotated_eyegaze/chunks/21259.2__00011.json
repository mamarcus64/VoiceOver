  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "And-- and I used to love.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "The father was-- how you say-- oh, it's something, nice-- nice family.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "They had got two sons in the army, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Every Friday, they invite me, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And she bake challahs.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "She baked this.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I--I-- I was close to.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And after was common-- and was common who wants to go to Poland back.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "But General [?",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "Shakorski, ?] the Polish [? meister, ?] they told, who wants-- who was born in Poland, they can back to Poland.",
      "word_count": 21
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "This is the reason I went back to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "But I couldn't believe, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "My family had got killed.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "Did you go in with the Russian army into Poland toward the end of the war?",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Not with--",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No, not with the Russian army.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I went with the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "In 1946.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "It ended in 1945.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I was in the hospital, I-- yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I-- you know, I'm-- I'm wounded twice with the--",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "With the-- with the shrapnels, from when the shot.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In the back.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "This was in 1942, 1943, yeah. 1943.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "This was in Stalingrad by the bridges.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "By the-- where you build the bridges, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "They shot and-- and I got wounded.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "This was in 1943 or '44.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "But I was in hospital in Stalingrad.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "The ended till the war.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "After, when-- when I-- when they release me, no-- no more war, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I got the, you know, a passport to go in restaurants, not won medal, to restaurants to eat there, you know, to eat their lunch.",
      "word_count": 25
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "This I got till I went home.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Of course, will, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "This I went home.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't believe, you-- I couldn't believe, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "I can find nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "You see, this is the reason I went.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, directly to Zawichost.",
      "word_count": 4
    }
  ],
