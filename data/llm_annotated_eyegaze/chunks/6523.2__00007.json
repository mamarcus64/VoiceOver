{
  "stem": "6523.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "In Radom.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "The-- let's say you've got-- like I said before-- like 35,000 Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They give them-- let be 1/10 of the city, a part where the Jewish people used to live-- concentrate.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "With-- with everybody-- with my parents, with my friends, with-- with-- with-- with the leadership.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Like the hell-- where you got to learn to--",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "You learn to live with this.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, let's say if-- if my parents lived in-- let's say in a house, like a-- well, let's say, like, here, I would say a three bedroom house-- you-- you went-- they-- if they make a place like this, you-- you have to take it in people.",
      "word_count": 47
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Let's-- the 35,000 Jews lived-- let's say they give you a place where 1,000 Jews lived-- 10 in a-- in a-- in a room, or whatever.",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It's a lot to make-- it's going to be a big story.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "You see, it was not so easy, it-- [PAUSES FOR 6 SECONDS] People, they had money.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I actually, like I said-- I came back.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And I tried to salvage.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I accumulated.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "You had some money in comparison with people what they haven't got money.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "It's-- for money, you could try to, say, to-- to-- get a better place to live.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I had a place.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "We used to have-- let's say, a-- a-- job in place for in china, a job.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "We've been jobless.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "It's a wholesale.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "I had a-- a office over there.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "And I moved in the office.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "You pay money.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "The administration-- you know, the Germans, they haven't done the-- the dirty thing.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "The dirty thing, the Poles had done.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "It's for money, you could stay another month, another two months.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "You find a time like this.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You-- you find a--",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
