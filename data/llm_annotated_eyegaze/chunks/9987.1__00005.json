{
  "stem": "9987.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "It was [NON-ENGLISH], they used to call it.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "In other words, food, and-- and living, and money.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So approximately 10 workers were there, and the four of us.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So there was always a full house.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "When it came lunchtime, the big serving, when it came breakfast, the big serving, it came evening, the big serving.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And especially Friday night and Saturday.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "My father was working six days a week.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "His schedule was he got up in the morning about 6 o'clock in the morning.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He went to shul to-- for services, came home about 7 o'clock, had something to eat.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And he started to work.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And he worked like this every day until Friday, before Shabbos.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "That's when he quit.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "We all went to shul.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And when we came home, there was a big dinner.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "At the dinner, sat down there seven, eight workers, the four brothers, my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And my father always used to bring a couple poor people from the shul for dinner.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "At this dinner table some Friday night and Saturday night, there were always discussions among the four brothers.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "We were four brothers with four different organizations.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "My oldest brother, Moses, used to belong to Agudath Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "He was a frummer.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "My second brother, Joshua, he was in [NON-ENGLISH], which is a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "I was a Betar.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And my youngest brother belonged to the Hashomer Hatzair.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "In other words, if anybody knows anything about Jewish organizations, we were at four different corners of the beliefs.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And at every dinnertime, on Friday night and Saturday night, we had political discussions.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "Everybody wanted to be right.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "But I was very aggressive, belonging to Betar.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "At that time, it was already during the time that Hitlers came to power.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And they were wearing brown shirts.",
      "word_count": 6
    }
  ],
