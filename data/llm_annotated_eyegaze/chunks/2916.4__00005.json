{
  "stem": "2916.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And I ran off to tell the blockalteste, or the head of our barrack, who was also a Jewish girl.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "But she was already very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "And she had been there two years.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So she-- when I wanted to talk to her to tell her somebody should replace that plank because it will break, she became very angry at me because it seems I addressed her when she was trying to talk to somebody else.",
      "word_count": 42
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So she gave me a slap on my face.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Such as slap-- I have very high cheekbones, and by now I was pretty skinny-- that the my skin broke, split.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I had immediately blood coming out.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And I staggered backwards.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And of course, I ran back to my barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And I pleaded with the women to move off.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "There is one plank which is cracked.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But everybody was hysterical because we had just come.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "We just gotten our numbers.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We were exhausted.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Everybody was soaked because just before they drove us into the barrack, a sudden rainfall came.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Everybody was drenched.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And the food was being distributed.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "We hadn't eaten now for-- this was the fourth day.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "So everybody was hysterical trying to get the food, and they paid no attention.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So in the meantime, my mother was in a sitting position.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "She had just gotten her, her food in a bowl, and she started eating.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I was lying down because I didn't get my food yet, and I was a little dizzy.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I was lying down.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And at that point, the plank cracked, and also the one next to the broken one.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And the 12 women came crashing down, together with the two planks, on top of my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So my mother was flattened like this.",
      "word_count": 7
    }
  ],
