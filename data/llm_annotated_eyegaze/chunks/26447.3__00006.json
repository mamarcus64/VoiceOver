  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "And he come in a barren place what it's warm.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "Believe me, you cannot stay in a-- like, some things-- something your body is shaking with so much lice in the body.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "Now, I told you what.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "It's become worse with time-- worse and worse it become.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "The full time begun-- the first time.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "[COUGHING]",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Winter time, what to do?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "What we can do?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "One guy give us advice.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "You know what?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Make from wood, and put hay-- put something to make them more barren.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "The forest froze.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "The cool come-- that from 1942-- the winter time-- from 1942 to 1943.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We made this impossible to stay.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "The forest night, you cannot stay.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We don't have the clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I got a clothes-- only pants.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And he was asking somebody from the Ukraine-- from the people-- they give us a jacket.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "No, it's not warm.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "It's cool.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "It's winter time.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "It's Russia, frozen in snow.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "One guy-- the other guy-- tell us, you know what to do to save your body?",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Take-- dig in the ground.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We begin to do this.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "We take-- one guy, he give us a shovel.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And we begin to make the place to stay in the ground.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Now, what to do.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We need to make the ground, but nobody can see that's what-- we take the ground and we put them in forests.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Places where nobody can see what somebody was doing a job to take a ground.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And we take some-- all we was working night-- the daytime, we didn't work-- at nighttime.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "We was worked-- what nobody can see.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "We've got afraid that the day time-- we make the hole.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "We put in the cover.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Cover to cover, it was pieces wood.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Then we make a hole to come inside.",
      "word_count": 8
    }
  ],
