{
  "stem": "25114.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Primitive, but she taught them songs, she-- she taught them the alphabet, you know, because there was a lot of small children.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we put out concerts.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And then came we had custom-built zemilyankas.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Out of the big zemilyankas, we built smaller ones.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So everybody picks somebody he wanted to be with like-- and they looked like houses.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So because my husband was in the warehouse, and next to it was the bakery, and next to us was the-- the sausage making and the cows.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So they put us in a zemilyankas, custom made for me, my husband, and my baby.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And then there was the one who was in charge of the bakery, and there was the one who was in charge of the sausage making.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Three families.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They build us a zemilyankas.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And made a-- they build us a stove.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I had hot water service there.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They got a hold of a big kettle, they build it in, and something-- even there were that thing were you could bake.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "While the stove was burning, the water was sitting.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And I had hot water for my baby's-- for the bath and for the washing.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I never put the-- the nappies was from old torn up peasant sheets, but I never put anything on her that wasn't ironed.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I had this one, this iron set with charcoal.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "You had to blow on it, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "This was one of the things we used to borrow from each other.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Never put on her something that wasn't ironed.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "She never had any-- any mark on her skin.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And driving like-- like I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But of course, I was breastfeeding all the time.",
      "word_count": 9
    }
  ],
