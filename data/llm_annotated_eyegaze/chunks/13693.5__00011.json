  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "And we were about ready to go back.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "And when we started to go back, suddenly from nowhere on the-- on the mountain we see a group of the Armia Krajova from the-- from the Polish.",
      "word_count": 28
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "Maybe-- maybe we were about 18.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 26,
      "text": "They were about 35, 36.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 27,
      "text": "And they started to shoot.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 28,
      "text": "I was at that time the first [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 29,
      "text": "I had the [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 30,
      "text": "I had the machine gun.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 31,
      "text": "Before I notice, all of the group went to the woods.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 32,
      "text": "They went already with the horses, with all-- with all this stuff.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 33,
      "text": "And they were almost ready to go.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 34,
      "text": "I want to remain by myself.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 35,
      "text": "I did not see them how-- how they left it.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 36,
      "text": "And by remaining by myself, they-- they neared to a kill.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 37,
      "text": "The army [? crew. ?] And when we get-- [INAUDIBLE] a machine gun, it was really trouble.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yohanan Maggid was the head under the cover of-- of a wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He came into me.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He hit me over my back, and said, what are you doing?",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "So I before I notice I said, the thing is-- Come!",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Come!",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "I followed him.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And this way he saved my life.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And this is-- this is the way Maggid.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I met him in Israel and I thank him for it.",
      "word_count": 11
    }
  ],
