{
  "stem": "27443.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] It's very hard for me to say it.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I was a young girl then, and when we arrived from Majdanek-- there were-- as I said, a lot of people were there from before the war, from surrounding area, that lived in the surrounding area.",
      "word_count": 36
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "That they came from the same city, from Skarzysko.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That they came into the camp, to work there.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "A lot of people-- to us it was a novelty, because we came from Majdanek, not having anything.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And a lot of people came from their homes, that they had normal clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And to us it was a novelty.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "Over there, I met a young boy, my age.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "That he became a friend of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "You see, Skarzysko was-- we weren't allowed to be in the same [PAUSES FOR 3 SECONDS] block, to live in-- we were separated, men from women.",
      "word_count": 26
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "But at the time when we went to work in the factory, we were able to mingle men and women.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "After the Majdanek, this was more a normal life to us.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "Because it was not a concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "It was an Arbeitslager.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So I met that young fellow.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "His name was David.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And he came out from the same town, from Skarzysko.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They were very well-to-do people.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And he was there with his two brothers.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "When we arrived from Majdanek, it was an alarm out for his older brother.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "He escaped from Skarzysko.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And there was an alarm.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "He lives now in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He was spared.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "But I was-- this was my first friend as a young girl.",
      "word_count": 12
    }
  ],
