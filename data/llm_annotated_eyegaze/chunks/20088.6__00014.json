  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 57,
      "text": "And [PAUSES FOR 3 SECONDS] so we still said it's too dangerous to-- we didn't we didn't know what to do.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 58,
      "text": "But then one morning we were in the camp looking, again, for more clothes and more things, and we heard, again, movement and things.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 59,
      "text": "And we saw at the camp-- we saw-- I saw a huge figure standing and all covered in snow and fur.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 60,
      "text": "And the first minute, I thought it was a bear, and I wasn't quite sure, should I go there or what.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 61,
      "text": "And then I went a bit closer and I looked, and I saw that it was a man.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 62,
      "text": "I saw it was the first Russian soldier who had entered the camp.",
      "word_count": 13
    }
  ],
