{
  "stem": "23540.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "You know, you don't need the synagogue to pray. 10 people, they can pray.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "But I don't think so.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you can-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "And when to the ghetto, was people can go in and out, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Was very good German on the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Guard.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "And people do what whatever they like.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "It was not so bad.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Friend of mine, she run away.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "From work, from [NON-ENGLISH], she went to work.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "And one day, she run-- she-- they go here, she went this way, and vanished.",
      "word_count": 15
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "It was a little bit problems.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "But she-- she went away, and she saved herself.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "She live in America.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Luciana Wac.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "What's that?",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "We still think.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "We always think about this, but never happened.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "We never have a carriage to go.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "People want to hide us here and take us there.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "But I don't trust them.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "Maybe I was a coward.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "But when I go, I was thinking, what will be with my husband?",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "You know, a friend of mine, she wants to run away.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "And she wants to take me with-- with her, and I told him.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 11,
      "text": "And he said, you go.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 12,
      "text": "You-- you save yourself.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 13,
      "text": "You do what you can do.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 14,
      "text": "But it was not so easy.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 15,
      "text": "I didn't want to go with her.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 16,
      "text": "She's alive, too.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 17,
      "text": "She live in Austria.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Tosha, Tosha Bakschlak.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "It was her maiden name.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Now, she-- I don't know what's her name.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "I used to know.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was a hospital, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "Thanks God, not.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "The hospital was not so easy.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "Not so-- it was danger to go to hospital, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "German come, and they don't like sick people.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "They can shot you.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "It's a Jewish doctor.",
      "word_count": 4
    }
  ],
