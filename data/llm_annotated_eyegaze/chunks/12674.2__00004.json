{
  "stem": "12674.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was not pretty.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "She was told she was nice-looking, nicely built, but she was not pretty.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "She was completely white because when she lost a child, her hair turned white overnight, which is really true.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I only knew her with white hair.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And she was a good cook, and she was a good mother, and that was her life.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "She didn't have any outside interests.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Sometimes they went to-- went to a theater, or they went out to dinner, but she-- she-- she lived with her family.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Every Sunday she was there, and during the week sometimes she'd meet a girlfriend in the afternoon.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "But she went to the market every morning with the market basket and bought fresh food.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And then she spent three hours cooking dinner.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "The big meal was eaten between 1:00 and-- and-- and 3:00.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "You know, we ate at, like, 1:30.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "My father came home from work.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And then we went-- we-- when-- when we were older, after 10, you go to school from 1:00 to 3:00 also.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "But before that, you only went until 1:00, and there was no school in the afternoon until 10.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And my father went back to work, and we went back to school.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "And she sometimes would see a girlfriend.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "But she had-- her life was in her family.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "She was-- I guess she was an unhappy woman, because her-- she was very shy.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "I don't know whether she was-- she was not unhappy.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "She was sort of-- had sort of a-- sort-- sort of a sad edge to her because her mother had cheated her husband out of something she had promised, and she felt that--.",
      "word_count": 33
    }
  ],
