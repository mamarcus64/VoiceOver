{
  "stem": "24242.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] Their name was-- the younger one was Kostas, the other one was Mikhas, and their sister was Anzhia.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] None of them are alive.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Only one of those brother's wife is alive, which I visited them a couple of years back.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Those are the people that actually saved my life, in a way.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember all of them.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I remember the good and the bad.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] So they were actually very good.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "They were the best, I guess, of the neighbors.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "But all of our neighbors were good people, except one, the Polish family.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I guess, as far as I'm concerned, they were bad.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] Their name was Kuszel.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] When the war started, [PAUSES FOR 4 SECONDS] nobody was home except me and my parents.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] My two brothers-- those main two brothers that I will talk about are Asael and Zisl.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "They were in the Russian army.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So I was actually the only one, as far as the kids go.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And Abraham and Yankel-- after a week or so, they came also home from the city.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "After a week of what?",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "After a week-- in a week after the war started.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "This is what I'm telling you now.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We were they only one in the village that actually did have a radio, correct.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I remember people from all around the area, like 20 kilometers away, would come and listen to the radio.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I think this was-- when we got the-- the radio-- I don't recall, really, whatever-- it was '39 or '40 or '41, one of those three years.",
      "word_count": 27
    }
  ],
