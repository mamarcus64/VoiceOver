{
  "stem": "24554.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I ask her, can I offer you a cup of tea or coffee?",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "No, thank you.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She don't touch nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "So she was there a half hour, hour.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She asks so around nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So when I was asked for my British citizen, I was invited to the Home Office.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "There come two men.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "So, again, my English was bad.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "No. ?] They have Information where I work.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "They told me the Director of the Home Office was asking about me.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "So they ask around.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Again, from Czechoslovakia.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And the-- and the silly question was, where have you been when started the German Czechoslovak War?",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry, Gentlemen.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember about the war.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I must tell you the German took with help from [? this ?] Prime Minister, I think Chamberlain-- took over Czechoslovakia without a war.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't a war.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "The border was open with help from Britain to take over Czechoslovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "They look one with the other one.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They don't say a word.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "So it was finished.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And in a half a year, I got this certificate for the British citizen.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I must go to the out to swear for the King-- Queen-- that we are true British citizen.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And again, I come back to the work.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I say, I am very proud I am a British citizen.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "So [? the ?] one man [INAUDIBLE], a Englishman, he was a nice man, said Albert, I tell you true.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "When you open your mouth and started to talk, you will be always a bloody British foreigner.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So it was my British experience.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "When you open your mouth and say two words, you are always a bloody British foreigner.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "It is true, yes?",
      "word_count": 4
    }
  ],
