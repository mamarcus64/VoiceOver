{
  "stem": "512.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He knew him back home before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He knew the family well, and that's why he approved very much of Morris.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I wasn't quite ready.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I was 19 years old, and I didn't know what I wanted.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "You know, didn't have time yet to think for myself.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "But he would say, he's a stable man and don't look for somebody that knows how to dance well or the other things.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I never had a date.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I never went out with a boy.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I have never even talked to a boy.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I was very young, and in my community, at that time, if the boys were of age, then they were taken into the services.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And at my age, they were still only students, the kids that went to school with me.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And there was-- there was no going steady or anything like that because it was war.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "So I cried a little, because I wasn't ready to get married.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "But I figured he's my uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "He knows better than I do.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "So I married him ten days after he proposed to me.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "Well, it wasn't somebody that came in that I didn't know.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "It's my uncle-- my uncle said it.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "My poor uncle, he says, my mother's wish was always that I should take care of you because you stayed with her so much.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "But he says, all I can give you is this prayer book.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "It's all I have.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And he says I would like to see you all settled.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "I wanted very much to continue school.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And I had no opportunity.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "And I had a girlfriend that she married a soldier.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "He was in a Czech uniform, and he rolled out the red carpet for her.",
      "word_count": 15
    }
  ],
