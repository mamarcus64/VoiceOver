  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I think maybe we should run a picture of it, because that's a historical facts of the whole town.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "She has a very interesting story.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "She has-- she was called for deportation.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And she was a housekeeper for a high German officer-- again, because she could speak German.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And he-- she went to him.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And he was there.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And he intervened.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And he was able to get her out.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And the second time, I think she literally escaped and was chased.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "She literally escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "She had a lot of guts.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, no, she stayed-- she stayed in the little ghetto.",
      "word_count": 10
    }
  ],
