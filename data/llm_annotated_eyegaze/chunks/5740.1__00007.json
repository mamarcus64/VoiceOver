{
  "stem": "5740.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "The friendships still today, the connection-- not many of us are left.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "But the ones that are left, we're still in contact.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "When I go to Israel, there are reunions all the time of the school friends of mine.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The academic that was the highest standard of academic, so high that when we were done our matura, which is when we were doing matura--",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "The highest school certificate.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "They didn't-- they didn't send anybody from the [INAUDIBLE] to be present.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Our director was good enough to be present there.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Anything.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Anywhere.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Not in Poland, because in Poland, it was [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Some [INAUDIBLE] had-- faculties had [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "That means that nobody was accepted.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No Jew.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "No Jewish person was accepted.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And some had [NON-ENGLISH], which mean that only a closed number-- closed number of people that were-- that were able to enter the university.",
      "word_count": 24
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And they had to sit on the left side, because they were Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible, absolutely terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "I-- I had never been there, because I was too young.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "But I heard about it, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My brother started-- we-- my brother finished school, most probably, in 1920.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Yes, you can see 1923, he's quite a big boy there.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And then he studied in Warsaw, and then he studied in Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Oh, all his friends-- I used to know all those names, like [INAUDIBLE] and Nancy, all because they were the universities where my-- where the friends of my brother were studying.",
      "word_count": 31
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Nobody studied in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I met later on, a friend, who studied medicine.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "Also, that was already during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "He studied in [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Elsewhere.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I don't know any-- I-- I have a friend here who studied law in Warsaw University.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "But he-- she had to sit on the left side.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Constant.",
      "word_count": 1
    }
  ],
