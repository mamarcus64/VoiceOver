{
  "stem": "12337.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And my mother and I were beaten up terribly.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They threw my mother back into the courtyard, and they beat her with-- with guns.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "She had-- I remember my sister and I were standing on the doorway, and we were screaming.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And her blood was gushing out of her head, and I remember that sound.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "It went like sszzhh-- that kind of a sound.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And after a while, she stopped screaming, and they said, well, you know, she's done.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So my sister pulled me away from the doorway.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And the next thing I know, I was lying under a bed in a bedroom.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And apparently, they were looking for me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And I must have been unconscious, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "But I opened up my eyes, and I tried to get up, and I tried to say, here I am.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And I realized that nothing was coming out of my mouth, and I couldn't move.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "There was something lying under the bed, and I tried to reach it so I could get up.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And I couldn't do that.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I probably went-- was unconscious again, off and on, and-- because I remember waking up a few times.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And they were looking for me.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "My mother's brother, Friedel, came to help.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And the next thing I knew, I was lying on a couch in the living room.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And I was covered with a sheet, or the-- I think I had a-- like a sitter under my head.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And my father was crying.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And they said-- and my uncle and my father thought I was dead.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And at that time, I was seven years old.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And I thought they're going to bury me alive.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "I was like so frightened.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "I kept thinking, oh, my God, I'm alive here.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "I'm-- I'm alive.",
      "word_count": 3
    }
  ],
