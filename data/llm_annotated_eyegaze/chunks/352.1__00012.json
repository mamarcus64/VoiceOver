  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And then, my mother was bartering.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "She was selling.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And people would give her money-- I mean, food.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "Because money-- there was no-- you worked for bartering.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "And our breadwinner was sick.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So my baby, our baby started getting sick.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I said, Luba, why is the baby sick?",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "She said, because he has no food.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Mama cannot nurse him.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "She cannot give him milk. ,",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And then then one day, my mother was still sick in the [? heart. ?] My sister would go 12 kilometers to the city.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And always, and always, she would come back.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And she would say, mama is not well yet.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know how many weeks it took, but it took close to a month.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And one day, she came back.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And no, my baby died first.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "She was still in the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And the baby was-- I guess if you don't get food, if you stop all of a sudden nursing at close to a year-- he was a couple of months old.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He was I think 10 or 11 months, my sister told me.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And he started getting sick.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And he lethargic.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And I would say, how come the-- so we would give him our-- we had a little bit--",
      "word_count": 18
    }
  ],
