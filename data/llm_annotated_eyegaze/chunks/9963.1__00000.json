{
  "stem": "9963.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Mendel Flaster.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Spells M-E-N-D-E-L F-L-A-S-T-E-R.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born April the 23rd, 1920 in Grybow.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "That's a little town not far from Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Ezak Wolf Flaster.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "You want me to spell it?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It's E-Z-A-K W-O-L-F-- Flaster-- F-L-A-S-T-E-R.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Baila.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "B-A-I-L-A.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Baila Flaster.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Her maiden name was Birkenfeld.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "It's B-I-R-K-E-N-F-E-L-D-- Birkenfeld.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had three more brothers and two sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The oldest one was Sara-- was spells S-A-R-A.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Later was one of my brothers, Naten.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "What is N-A-T-E-N.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Chaim-- is C-H-A-I-M.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And later was a girl-- Rebeka.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "It's R-E-B-E-K-A.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And mine other brother was Mosez-- M-O-S-E-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Mosez.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The youngest-- I was the last of the group.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Grybow.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It spells G-R-Y-B-O-W.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Grybow.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, at that time, when I was in Poland, it was a little town.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It's-- it was a lot of the Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was several synagogues over there.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And it was a very nice little town.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "It was very clean, beautiful.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "We had a beautiful, beautiful lake running through middle of the town.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "What the lake was coming from the mountains.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And it was very, very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And it was the-- in this city, the majority was Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "But around the city, of course, we were the minority.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "But it was a nice little town.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Our house-- we had a old house what was from generations handed down to my mother from my grandparents.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But that old house was so old already that we had to demolish it, and build another house.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My-- one of my brothers was working as a very good place in Krynica-Zdroj.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "This is another city not far from us.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And he made very good money.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And he's helped to build a new house.",
      "word_count": 8
    }
  ],
