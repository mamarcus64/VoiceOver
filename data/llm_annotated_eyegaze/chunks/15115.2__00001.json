{
  "stem": "15115.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "So we sold those.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "We got quite a bit of money, because gold was still gold.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "There's no paper money.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We kept going for a while, but no-- money wasn't coming in.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Only what I was getting during the day that I was going.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Because my two brothers and my father were completely absolute nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "No- no-- no income whatsoever.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Then came to the end that I sold my oldest brother's camel hair coat, which was a fortune.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "At the time, nobody could afford a camel hair coat.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "It was a year's salary.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "You had to work a whole year to be able to afford-- a worker, maybe over a year, would have to work to make the money to buy a camel hair-- navy blue camel hair coat.",
      "word_count": 36
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And the same one I had my sister's, but I didn't sell my sister's.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I sold my brother's.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "We got quite a bit of money down there.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And then the money was also gone.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "I sold-- we had, at home, we had some basins made of copper.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "Big, big round basins which we used to wash, make the wash on Monday to wash the clothes.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "Monday was washing day.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "Before the war my mother use to have a woman to come and help her, you know, like a maid for Monday.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "But I sold those too.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "We were coming to the end that I cannot sell, so then we starved.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "We used to get a loaf of bread, we used to divided it.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "Share and share alike.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "I used to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "I used to leave my share.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "Not eat it.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "I used to go back again and try to hustle a few bucks here and there.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "That was-- we really had hard times until they started taking us to the ghetto.",
      "word_count": 15
    }
  ],
