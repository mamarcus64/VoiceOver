  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I said, well, I had a pound, you see, because I have prepared Australia money, and I knew this-- this fellow, way back from Warsaw.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And he took us to the boarding house in Grey Street, St Kilda.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And on the way to our room, you see, we saw a couple of dead rats.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "You see, it wasn't pleasant, but we were tired, and we went to sleep.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And the next morning to-- there was breakfast, you see.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "That means you could get toast and bacon and eggs and all sorts of things, and we were very happy about it.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He took me downtown [PAUSES FOR 3 SECONDS] from the boarding house, and he-- I bought a hat and a pair of shoes, because I still had money.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "You see, I came, I had 450 pounds, you see, in a check.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "PX, from the job I saved up with the Americans.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 3 SECONDS] and then he went into a youth agency and bought me a calling street directory, a little book.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he said, brother, now you're on your own.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I went back to the boarding house.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I said, well, I want a room.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And he said, look, rooms are being advertised, but if you want, if you really want a room, you go down to the H at midnight, and when they throw out the first packet of newspapers, you have a pair of scissors, cut the string and take a newspaper and see the room vacant and run to the-- to the place it advertise.",
      "word_count": 63
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Study your street directory well, and knock at the door.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I said, look, how could I wake up a landlady.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He said, that's-- that's the usual thing, because if you get the second newspaper, you won't get the bloody room.",
      "word_count": 20
    }
  ],
