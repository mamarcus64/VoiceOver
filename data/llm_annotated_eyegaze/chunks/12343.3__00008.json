  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 36,
      "text": "Lucky, still not lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 37,
      "text": "Still lucky I was [INAUDIBLE] 1945, that's when I was lucky, not before.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 38,
      "text": "If I was lucky, I'd be there.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 39,
      "text": "The train was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Work-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "There's something.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I [INAUDIBLE] clean up.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "That's is all the work.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Bring you back.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Appells, appells.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "You know, to count you're back.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Where you're going is no good.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Every place is kaput.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I know these things.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In Buchenwald?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "It was strangers all.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I know when later on, I find out, as my wife, they took her away in another camp.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And my wife said a cousin was in Buchenwald too.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I find it out.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And I was in Tschenstochau.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "I helped them out.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And I find out these were the children, and he can help me out.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Somebody was coming, from another-- the boys, the young, the children, that they feed better than all of them.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And when you come to them in camp, I said, you know, they're [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "He said, [NON-ENGLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I said, tell him I'm here.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Maybe he can help me too.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Never happened.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I was good when I there.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Buchenwald?",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Until they take me to-- no, they make selection to take people to work out.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And still, and we still go.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Every morning, they took out people to the gas chamber.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Or one, he still was alive.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "Shove them in and everything, like this, when they were still alive.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "They always took them every night and day.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "Every night and day.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "You can see the smoke goes up, every night and day.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You still was alive and they run.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "What can you do?",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "You see yourself.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "You never know what's going to be now with you.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "My health?",
      "word_count": 2
    }
  ],
