  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Now, [PAUSES FOR 3 SECONDS] I remember the group that Elie Wiesel was, they wanted to have kosher food, and so they were separated.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I remember him saying that, oh, sure we doubt God, but I'm going to study and find out what it's all about.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "The rest of us-- there was somebody that we used to call Stalin, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It was-- at that time, you know, Russia was in everybody's good books.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "So he was very socialistic-minded, you know, and he sort of talked all of us into believing that there is no God.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And he says, I'll show you guys what we should do.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "He was a little older.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And so there were these different groups.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "The Poles stuck together.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "The Hungarians stuck together.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And-- and they started separating us.",
      "word_count": 6
    }
  ],
