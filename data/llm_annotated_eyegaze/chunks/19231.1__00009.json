{
  "stem": "19231.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.9,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "But when it came to us, they didn't-- they must have [INAUDIBLE] back farther.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "Like, they took only maybe 200 people or-- so I don't know if it was luck for me that I didn't go back.",
      "word_count": 23
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "Because maybe I wouldn't survive anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "So we didn't go back.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And it didn't take long.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "Then the Russian took us.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And they send us away to Siberia.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Communists, I believe.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not at all, not at all.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "We-- I-- I don't think-- see, when they sent us to Siberia--",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No, before that when you were still in that--",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "In the Polish occupied by Russian?",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "We did no communication.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "No, because the war was going on already.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "We had no communication.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "When they sent us to Siberia, no.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "We-- we separated.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No, we had no choice.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "They just came with a-- like a-- by our door.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "And they knocked at our door.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And they said, we should go, come out.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "And there was like a truck.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "We went into-- on a truck.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "And they took us to the trains.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "And they said everybody will be there.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "Because I-- I-- I had my sister that was separated during that time.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "She was supposed to come to-- to register to go home.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 10,
      "text": "She came a couple of days later.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 11,
      "text": "And meanwhile, we were to sent out.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 12,
      "text": "So, and she was sent out also to Russia into a different part of Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 13,
      "text": "And we never saw each other anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "She had two children and her husband, thank God.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "In a different-- different parts of Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "She was sent, I think, to [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "To Siberia.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "We were take in cattle cars.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I don't think I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I don't-- they must have give us some food.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Maybe a-- two weeks.",
      "word_count": 4
    }
  ],
