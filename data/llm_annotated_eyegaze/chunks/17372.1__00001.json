{
  "stem": "17372.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 520.1,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I had plenty of brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I had, first of all, Regina, my sister, the oldest one.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "She was with us in concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And she died after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Then Henry-- Herman, the violinist, he was second oldest.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "He was with me in concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And he died also six months ago in America.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Then brother George, pianist, who lives still in America-- great pianist.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Then was sister Mary or Mirysia, a very intelligent girl.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "She spoke five languages before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "She played piano.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "She sang.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And she died during the war.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "They took a group of women, Jewish women, on the boat and sank the boat in middle of the sea in Stutthof.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "Then I had a young-- another sister, Mela-- Melanie.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "She was a very good accordionist.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "She was married.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And when the-- in ghetto in Cracow was a segregation.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "She didn't look very strong physically.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "Well, they put her to the left, where she was holding her little boy of two and a half year in her arm.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "One German grabbed the child by legs and hit against the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "I never seen them again.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "Then was one year older sister Bronia-- Bronislawa.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "She died before the war tragically.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "She fall, by accident, into big pot with boiling water.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And then am I the next one, and then younger brother Sam or Samek, a very good violinist.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "He was with us in Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And he went to [PAUSES FOR 4 SECONDS] Dachau-- not Dachau.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "I think Dachau.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And he died one day before the end of the war from hunger.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "Then the youngest brother [?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "Willek ?] or Bill, he's alive still in America.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "So from nine children, all what left is two brothers in America.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "And I'm here.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My mother was Freidel or [?",
      "word_count": 6
    }
  ],
