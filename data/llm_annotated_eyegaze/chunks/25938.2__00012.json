{
  "stem": "25938.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 4,
      "text": "People told me people were-- committed suicide.",
      "word_count": 7
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 5,
      "text": "Men are dead.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 6,
      "text": "They-- they used to beat people to death, some people, for-- for little things that they just didn't like.",
      "word_count": 19
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 7,
      "text": "They-- they used to-- to-- to torture them to death.",
      "word_count": 10
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 8,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "There were many.",
      "word_count": 3
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "Many non-Jews too.",
      "word_count": 3
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "In the barracks, it were-- were not only Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 3,
      "text": "Birkenau was not a camp only for Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 4,
      "text": "There were many Poles there, and many other Germans, and the homosexuals, and the gypsies.",
      "word_count": 15
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "We-- we had-- I think I told you about [INAUDIBLE], that man [INAUDIBLE] Erlich.",
      "word_count": 14
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 2,
      "text": "Shayek, Shayek.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I mistake.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 4,
      "text": "If I said [INAUDIBLE], it's a mistake.",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 5,
      "text": "Shayek, his name.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 6,
      "text": "Shayek Erlich.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 7,
      "text": "He was a good friend of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 8,
      "text": "He worked in the underground.",
      "word_count": 5
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 9,
      "text": "Later-- later-- later, I learned that I read about him, that he was one of the leaders of the movement.",
      "word_count": 20
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 10,
      "text": "I didn't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "A man came over to me in the-- in the barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I think his name was-- it's a one-syllable name-- I think, Munk, or Funk or something, I remember.",
      "word_count": 18
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you know, we need people to-- to help us in the resistance movement, for the underground movement.",
      "word_count": 20
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 3,
      "text": "And they were doing-- we're helping people, are doing something for-- for-- for the prisoners.",
      "word_count": 15
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 4,
      "text": "Do you want to join us?",
      "word_count": 6
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 5,
      "text": "We-- we heard about you.",
      "word_count": 5
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 6,
      "text": "And we think you'll be-- you'll be-- you'll fit to be a member.",
      "word_count": 13
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "They observed me, maybe.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I said, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "And from then, even my own brother didn't know.",
      "word_count": 9
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 4,
      "text": "When I came to Philadelphia, I told my sister-in-law that-- that was a surprise, that-- that-- what I found in the library.",
      "word_count": 22
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 5,
      "text": "I think-- my brother didn't know that, that I was in underground, being in Birkenau.",
      "word_count": 15
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "I think, yeah.",
      "word_count": 3
    }
  ],
