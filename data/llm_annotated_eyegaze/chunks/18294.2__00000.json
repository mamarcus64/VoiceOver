{
  "stem": "18294.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "There was a group like the partisans.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The partisans, they took a lot of young people, like if my cousin was a partisan, he come, he could take his sister.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He could take his mother, if they wanted to go.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And he come, from the partisan, it's true.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "But they didn't want to go.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "This was the group from the partisans, what I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Another groups, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The partisan group, no.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "No, I remember there was-- they used to keep in the ghetto yellow signs, and this sign, who gets the yellow sign has a right to leave.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So my father get a yellow sign, because he was working in the German place.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I was-- when we leave the ghetto, we have to leave-- there was like an exit, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So when we leave the ghetto, you have to have the yellow sign with you.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Then you have the right to walk out of the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "The people what's left in to ghetto, they was all shoot in Ponary.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So my father had a yellow sign.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He took me, and my brother, and my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Just, I was dressed so much clothes on me, living in the ghetto, that I looked like his wife, not like his sister-- like his-- like his daughter.",
      "word_count": 28
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "So they took me straight away-- away to kill me.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And my father and my brother and my-- and my brother, went out-- out the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And my father didn't lose control.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He come up straight away to the German, and he said, look, I'm working for this-and-this German.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Why they took my wife away?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "So he come back, and they take me out from the-- from the group where they shoot-- have to shoot.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And where was your mother?",
      "word_count": 5
    }
  ],
