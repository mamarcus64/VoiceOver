    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "He bribed them to give him money.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And afterward, he was vulgar.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "He say in Yiddish, [YIDDISH].",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "You know what this mean.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "He said to sh-- shit.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "Don't care.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "He, himself, after-- he'd been very, uh, personal with this people, because he got over there the 400, 500 from Krakow.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 15,
      "text": "That's what he lived to get [INAUDIBLE] in Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 16,
      "text": "For they worked for them in the, um, manufacturer for pots and pens.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 17,
      "text": "Let me finish this.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 18,
      "text": "I got enough.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 19,
      "text": "This is Schindler comes.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 20,
      "text": "Schindler was-- there's a lot of story in this.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 21,
      "text": "It-- it's make believe.",
      "word_count": 4
    }
