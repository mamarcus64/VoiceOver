  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "There were about, maybe, 2,000 people.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And we stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And we-- they fed us.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "There was a public kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And we stayed for 10 weeks, but my wife got sick right after the war.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "She was, in fact, in my home town, she was in the hospital.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And she got sick there, too.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "She was in the Rothschild Hospital in Vienna for two or three weeks, and then we decided to go to Germany.",
      "word_count": 21
    }
  ],
