{
  "stem": "26609.18",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She has to arrive from Lwow in Nuremberg and she will tell you she knows all about your daughter.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "How?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Because she was in her place, too.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She knows all about it, how she got out of that Polish woman, how they rescued her.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "The Polish woman didn't want to give her back.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But wait until she come.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "You'll receive-- you'll-- I tell them I'm in contact.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "You-- you will receive a letter from her to come and see her, and she will live in Nuremberg.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "That was not far from my place where I worked in Furth.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I waited.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "About three weeks later came a letter, came to see-- come to see me in my place.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I went to Nuremberg, in Nuremberg it was.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "You know where the trials were, all in Nuremberg, the trials of the Nazis?",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I was in those trials, too.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I came into her place.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "As I opened the door, she was with a survivor that-- his, her daughter got killed.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Her husband was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, I found out later that her daughter was together with me when I was in school.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I opened the door and she started to scream.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] her, her son was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Not a young one.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "He was in the, he was in [?",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Menachem, ?] in the committee, too.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE], come quick, and others, she had in-laws there.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "They all survived, and they were in Nuremberg in a private house.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Not all were in camps, in DP camps.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Some were privately, too.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And she called out, [INAUDIBLE] come here.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Come, come, come, she said in Yiddish, and see God's [NON-ENGLISH] [? wonder ?] [NON-ENGLISH] Everybody started to run, and they looked at me, and looked at [INAUDIBLE].",
      "word_count": 28
    }
  ],
