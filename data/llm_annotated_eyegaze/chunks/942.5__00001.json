{
  "stem": "942.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "I was too weak, And a [INAUDIBLE], I remember, was walking by, and he showed me this sign.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And you know, this sign meant that you're going up in smoke.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So I sort of accepted this, that at the end of the day when we were going back there, they would just drop me off, and-- near the crematoriums, you know.",
      "word_count": 31
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So anyway, I was-- at the end of the day, two guys had to drag me back on my rear end.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Each one of-- each of them was pulling me by one leg, and they pulled me like that all the way back to Auschwitz.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And they took me to the operating room, and the doctors operated on me.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They stitched me up, they cleaned up my head, and I was put into a bed.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I guess this was at the beginning of the week.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And came Friday, I was no, not much better.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I could not walk.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I was just too weak.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And in hospital, they gave you a bowl of soup a day, but it was made from cream of wheat.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "It was like a white substance, like cream of wheat.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "That's the best I can describe it.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And you were in a bed all day, and the doctors came, and they changed this bandage on me.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "There was a French doctor, a Jewish doctor that did this every day.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And usually every Friday, the camp doctor, the [INAUDIBLE], who was a SS high-ranking captain.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "He was a [INAUDIBLE] doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "He came with-- and a truck stood outside in front of the hospital, and some SS orderlies came, and all the people from the hospital were taken on stretchers.",
      "word_count": 29
    }
  ],
