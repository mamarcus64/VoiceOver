{
  "stem": "12810.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "It was a nightmare.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "And-- and even-- when we went to Czechoslovakia, then that was a shock of my life.",
      "word_count": 16
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "The-- the men who we paid a good dollars in Hungary, he disappeared and let us down.",
      "word_count": 17
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And then we have to find ourselves.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "And we don't speak-- we only speak Hungarian.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "And we find somebody who said, for money, we take for my little girl, a dolly.",
      "word_count": 16
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "And we put some dollars and gold in the-- in the-- in the dolly, inside.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "So every time when somebody asking, we opened the dolly and we give some money.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "And [LAUGHS] we-- we go further and further.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "And they put us in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "And they put a cupboard in front of it.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 12,
      "text": "And they said in 24 hours you can be here, and then you have to go.",
      "word_count": 16
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "So next night was Friday night.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "And I said to myself, I go to the synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "You don't, daddy.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "I go.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "So I went to the synagogue, and I looking around-- Where was this?",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "In which town?",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "In-- in Kosice.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "And I said, I was looking around in the synagogue, and I go to one of the men.",
      "word_count": 18
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And I said, look.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "We are coming from Hungary.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "I have a little girl and a husband here.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "We want to go through further.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "Could you help us?",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "He said, you know, you let somebody buy you a ticket to the--",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "--railway.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "And you go to [NON-ENGLISH] And from [NON-ENGLISH], you can go further, to Vienna.",
      "word_count": 14
    }
  ],
