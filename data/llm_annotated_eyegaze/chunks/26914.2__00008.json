{
  "stem": "26914.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Not everybody came back to Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "It was before the war.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "It was 1934 or '35.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Lots of people were standing there.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Mine life would be different.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "So, but I had a good lesson there.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "They cured me completely.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Lots of Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Lots of Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We had partially groups. 10 in a group, 8 a group.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I didn't see big groups.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Only in demonstrations.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "We had demonstrations on the streets were big groups.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "But otherwise, little groups, 10, 8 in a group.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "So we weren't in a big--",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I didn't want to look, probably.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I-- I don't remember this.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "I felt lots of communism-- uh, of anti-Semitism on the streets, in the papers.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "A Jew couldn't get a job even to be a janitor.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "It was very hard to get a good job.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "This I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I heard-- I saw in the paper lots of things.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "But [PAUSES] I didn't pay much attention to it.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "I was busy with myself.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Now, I understand.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "But at that time, I didn't understand why.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "They just didn't like Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "They didn't like other nationalities.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "I didn't pay attention to it.",
      "word_count": 6
    }
  ],
