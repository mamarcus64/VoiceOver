  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Was a Polish school already.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Polish school.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "The school.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Polish school.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "There was-- there what I started, they used to call it Talmud Torah.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Maybe you understand what I mean?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "There, we was only Jewish children there, until fifth-- fifth grades.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "If I want to go to finish seven grades, only until seven, that's all.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Then I'm supposed to leave the Talmud Torah and go [INAUDIBLE]-- a different street that was only Polish children.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, I went there for two years.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] they used to call us [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Like here you finished the high school.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "No more.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Everything-- everything like you studied here.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Same thing.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Polish, math.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Only when I was in Talmud Torah.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There was a Jewish teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He used to-- yeah, he used to.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I remember it was-- the name was Itzhak Shapira.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Itzhak Shapira.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I remember when he was, came, and he introduced himself.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He was a Jewish boy.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He was, you know, very religious.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Itzhak Shapira.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And then he got married with a teacher, a Jewish teacher.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "That's I remember then.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "After this, I don't remember.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I-- I-- when I left the Talmud Torah, and I went to the Polish school, he wasn't there.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "He was only the-- in the Jewish, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "There was a lot-- there was not only one.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Was a few.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Was a big one.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I think I got a picture.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "A big [? shul. ?] And there was all kind of was.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It was to whom you belong.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Like Hasidim, like theirs was a [NON-ENGLISH] synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "It was original, it was [NON-ENGLISH], it was [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] It was even, you know, all of schusters and schneiders, you understand what I mean?",
      "word_count": 16
    }
  ],
