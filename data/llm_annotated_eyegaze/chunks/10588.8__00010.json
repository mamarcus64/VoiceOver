{
  "stem": "10588.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I put in a hot plate.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And from the sinks, from the regular sinks-- there was not a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I think I made a kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "That's how we lived.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "But after Auschwitz, that was heaven.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I didn't complain.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And we went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "In-- in Sweden, the big meal is during the day.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "So every day, we would go, you know, for lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "So we took shifts.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "One day, Bina went home and warmed up the lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "One day, I.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And I was always fast.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And I'm rushing to go home to warm up the lunch.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "The homemade noodles that I made, with the chicken-- you know, like, still like home cooking, because I didn't even know that exist ready-made food at that time.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And as I walk, bingo, I'm all on the ground.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And somebody picks me up by the elbow from-- and I look up, and it's a man.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I thank him.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And we start talking.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And he tells me that he's also a survivor of the Holocaust.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And his name is Abram Shmolevicz.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "And he lives on the same street.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And he helps me home.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And he was going to bandage my knees.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "I was still a modest girl, even after Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "So I says, oh, no.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And I cleaned up my knees.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "And I warmed up the food.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "And he says to me, oh, smells so good.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "I would give-- gladly pay to get a meal like this.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So I said to him, I don't run a restaurant.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But on Sunday, when we are home, you're welcome to have-- I heard he's a survivor.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "You come up and have dinner.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And he was-- start to-- I don't know if I should call it date-- but he liked me.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And he came up.",
      "word_count": 4
    }
  ],
