  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He said to me, listen, David, you have to tell me the truth.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Or you gave [?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Lazer ?] the money or not?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And what you did with you kids?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And what you do with your sister?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And what you do with the money?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "When you tell me the truth, nothing will happen to you.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I said, is this a good Jewish world to allow the Jew or just talking?",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I told him this in Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "I shake hands.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I tell you the truth and do you do nothing to me.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I don't have to-- he, he was too big to shake hands with me.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Only he said, I told you, say.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Otherwise, you going to Auschwitz, too.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But ?] [? him ?] the Auschwitz, he puts me in among the, the, the, the other people that were supposed to be sent away.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And I will go, too.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I said, I will tell you the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I said, first of all, I have a right to buy out my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I have a right to save my nieces.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] Tell me the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I have a right or not?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "He said, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "You have a right to do that.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Then I gave [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Lazer ?] the 200 mark.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And the other guy who went, [INAUDIBLE]-- he what-- what he told you, it's not nice from him.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Only, he told you already.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "You know already.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Then what you will do now?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You send me away to Auschwitz?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "You go home.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And your sister go home.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And the policeman's not going to be [INAUDIBLE] of a policeman.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Only, he's going to be in Sosnowiec a policeman.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "This was the punishment.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Only, the policeman didn't do nothing to me.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He helped me.",
      "word_count": 3
    }
  ],
