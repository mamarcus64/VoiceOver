{
  "stem": "11593.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Most of the Jewish people were some-- were professionals and business people.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "They operated the breweries and the mills to grind grain for flour.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And they exported, I believe, 70% of the flour from our area was exported to the rest of Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "They also exported, as I said before, hops and lumber and agriculture.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "Also in our town was a cement factory because we had lime mines.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "The most important industry in our city was the railroad.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "We had a beautiful railroad station.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "It was an important stop because the railroad station repaired all the-- all the machinery for the railroad because it was connecting east and west.",
      "word_count": 25
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "Other words, coming from Russia going to West Europe, you had to pass the station.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "The majority of people who worked in the station were the Poles.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "The Ukrainians were basically farmers-- small farmers and some larger farmers.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "Most of the Czechs had large farms and also were farming the hops for beer.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "Between Rovno and Zdolbunow was a big brewery in this town named [POLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "Was a Czech village.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "While I was attending school, I used to come in the afternoon and work in my mother's store.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "I enjoy ?] [? staying ?] at register, make deposit at the bank.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "And they used to quiz me in arithmetic.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother's store was a country store, where they sold from groceries to whatever they needed, even materials, textiles, and [? all. ?] And life was quite smooth.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We played soccer.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We played volleyball.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We used to skate a lot in the winter, ski a lot and sled.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "We played with our non-Jewish friends, the Christians.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] [CRYING] We used to attend the holidays.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "They would attend our holidays.",
      "word_count": 5
    }
  ],
