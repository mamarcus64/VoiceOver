{
  "stem": "24364.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My full name?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Liselotte Ruth Steckl.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Liselotte Sander.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "L-I-S-E-L-O-T-T-E [PAUSES FOR 4 SECONDS] S-A-N-D-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Jihlava, or Iglau in German, in Czechoslovakia.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "J-I-H-L-A-V-A and Iglau is spelled I-G-L-A-U.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "8/30/21.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "75.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Franz Sander and Margarete Buchsbaum.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's her maiden name.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Both of them?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "F-R-A-N-Z S-A-N-D-E-R and Margarete is spelled M-A-R-G-A-R-E-T-E and Buchsbaum is B-U-C-H-S-B-A-U-M.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I had one brother.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Hans, or Hanus in Czech.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents owned a small manufacturing company.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They were making paper bags.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We had about nine employees or 10 employees.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We were a middle class family, doing quite well.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I had a very good childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "My home life was definitely satisfactory.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "My parents were strict but very loving.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] I don't think we were spoiled, but we certainly got most of the stuff that we wanted.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "We did quite a bit of traveling.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "I did a lot of sports.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I played tennis, I skied, I skated.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I played table tennis.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Actually, I was quite good at it.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I played for the school.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And that's about all I can remember.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Obviously, I went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And I was a reasonably good student.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Actually, very good.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I went to a German school.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "The Jews in my hometown since Iglau really originally was a German town, they're mostly German speaking, even after World War I, when Czechoslovakia became independent.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I think that's one of the things that the Czechs really didn't like, that all the Jews spoke German.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I was sent to a German school, whereas my brother, who is four years younger, already went to a Czech school, because of the-- [PAUSES FOR 3 SECONDS] how should I say-- [PAUSES FOR 5 SECONDS] resentment of the Czechs.",
      "word_count": 41
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Jihlava in my time was about 50-50.",
      "word_count": 7
    }
  ],
