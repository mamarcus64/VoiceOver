{
  "stem": "27409.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "Afterwards we were friend.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "He was parachuted in occupied Romania as British officer.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "And he told me just the man who could help us.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "And I joined up with them.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "Officially, I was a Russian officer, could move around, because they as British officer could not move so easily around [INAUDIBLE].",
      "word_count": 21
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "I could move and began to move weapon towards endangered Jewish places.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "So I came in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "I came in different places, I came there.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "And then, I was sent off as emissary officially of the [INAUDIBLE] Jewish Congress.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "You know, it was all for different name.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 25,
      "text": "But officially, it's Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 26,
      "text": "Then I was sent because they started organizing military unit, training, giving training.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 27,
      "text": "So that was my job to go.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Young people, which came back from DP camps.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "For Israel, to go in Alia to Palestine as it was.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I was in civil already.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I went-- I-- you see, I was officially on a leave of duty until I had to come back, until they called me.",
      "word_count": 23
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I arranged this, you see.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't come back.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "I had my other jobs, you see, and I was moving around.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "But still, when needed, I put the Russian uniform on, make myself the papers.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "We had all specialist which could falsify even Stalin's signature.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "Since I moved-- I had papers to move around, orders.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "But I went to Lugoj, where a friend of mine had organized two groups.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "They were one agricultural and one industrial, which prepared for work, training, work training.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "Here, you had two groups.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In Romania.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "In the [NON-ENGLISH] near the Yugoslav border.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Lugoj.",
      "word_count": 1
    }
  ],
