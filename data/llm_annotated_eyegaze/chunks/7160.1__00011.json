{
  "stem": "7160.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Which in Auschwitz, it was nice barracks, not like-- like in Birkenau.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Birkenau was-- was a very bad place.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So we had-- we stayed there two weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "They put us on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And they took us to Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "We went in Warsaw over there.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "They count, and we see if we got 1,000 people there.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "They counted over, they find 1,001.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "They count again, 1,001.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "They-- they-- back and forth, they keep us about two, three hours counting back and forth.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The extra person was me-- the 1,001.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "It's supposed to be [LAUGHS] 1,000.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So I took an extra trip.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we come to Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It gets very cold there.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And we find out, where is the camp?",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "This is the camp-- an open field-- no barracks, no water, no nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So the following morning, they took us in a place over there where the ghetto was.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "We saw thousands of corpses on the floor, on the-- rotting on the floor with worms, flies, and everything, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And they make us, the Germans, to pick them up with bare hands, you know, rotten and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And we used to take windows and doors from the-- from the building the bomb-- the Germans during the Aufstand.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We call them the Aufstand.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But the uprise, it was.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And we used to burn them.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And we were doing it for a few-- three, four months.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "We were burning the-- the corpses from the people.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "There was all kind of ages, from one year, from one month, till 80, 90 years old people, all ages.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "It was there.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "We burned them up.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "So-- and the smell was terrible.",
      "word_count": 6
    }
  ],
