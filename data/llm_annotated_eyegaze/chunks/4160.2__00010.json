{
  "stem": "4160.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "You know what I did?",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "I went on the front of the-- of the-- on the road and I hold up a German truck.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 25,
      "text": "That was about five, six running.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 26,
      "text": "They get to go by themself.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 27,
      "text": "Five, six trucks they running from [?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 28,
      "text": "Brody ?] to Lwow.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 29,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 30,
      "text": "Brody ?] to Lwow.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 31,
      "text": "I hold them up and I said-- they ask me, who are you?",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 32,
      "text": "I say I'm a Polack from that [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 33,
      "text": "They killed my father, my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 34,
      "text": "They killed all the Polacks--",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because the Ukraini, they killed the Polacks and they used to take blood from the Polacks they put on the Polish, on the doors.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[SPEAKING POLISH] With blood they did.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "With blood.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "With Polish blood.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So they knew what's going on in that area.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So they buy that my story.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And they took me going in the truck.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I went in the truck in the back.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know that I'm Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And they said, we're not going to Lwow.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We'd going to Podhorce.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Podhorce is about 10 kilometer from that place where they took me.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Podhorce.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "A little town.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "In a little town, Podhorce over there used to be-- King Sobieski.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "The Polish King Sobieski, he used to live in a-- in a castle.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And from that castle, they make a [INAUDIBLE]--",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, before this, I talked to the Germans, where I'm going to sleep?",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We're going to Podhorce not to Lwow.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We're not going to Lwow.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We're going Podhorce.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I said, I want to go out from that area.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "So let's meet Podhorce.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "So I went to Podhorce.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "They gave me a saddle-- a riding to the main men from the-- [NON-ENGLISH] from that village to give me where to sleep, because I'm a Polack.",
      "word_count": 27
    }
  ],
