  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "When I came to-- so when I was walking on the road, a wagon came.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "A farmer had a load of hay stacked up real high.",
      "word_count": 11
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "And he was going towards-- towards that town-- towards Ostrog.",
      "word_count": 10
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "I jumped up.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 7,
      "text": "I caught the back of the wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 8,
      "text": "And I pulled myself up on top of the hay.",
      "word_count": 10
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 9,
      "text": "And the man never knew that I was up there, because he was in the front of the hay controlling the horse and didn't see or didn't hear anything about it.",
      "word_count": 31
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 10,
      "text": "As soon as we got on the outskirts of town, I jumped off the wagon.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 11,
      "text": "And I started walking into town.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 12,
      "text": "And he never knew I was there.",
      "word_count": 7
    }
  ],
