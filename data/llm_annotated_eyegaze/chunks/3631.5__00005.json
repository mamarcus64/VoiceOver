{
  "stem": "3631.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, we-- we gradually started venturing out.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "We went for a little walk outside the-- the gates of the camp, and then into the houses.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Then we looked around, and we were not  cut out to-- to do any looting or burn any homes, deserted homes.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And we tried to think what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And the-- the Russians investigated-- no, interrogated us.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And where are you from?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "If you are from-- from Krakow, from Dresden, you go back to Dresden.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "That's-- that's the way they did it.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We did not want to go back to Dresden.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Since we were in Czechoslovakia, we decided to make it to Prague, where my sister-- my sister's fiance had lived before the war.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "We were trying to see if he was still alive.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And we finally made our way to Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And that was not-- it was easy, either, because there really was no-- no transportation available.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "You had to jump on a train somewhere, and hope not to get-- get thrown off.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We finally made it to Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And we stayed in Prague for two weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "My sister's fiance and his-- his family were all wiped out, did not come back.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "But the Prague-- the Czech people were very, very nice to us.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "There is one incident-- we were standing on the railroad-- did I tell you this?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And-- but not in the taping.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We-- we stood on the railroad, my father, my mother, my sister, and I.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And a man, a Czech man-- of course, we didn't speak any Czech-- comes up to my father, grabs him on his arm, and takes him aways.",
      "word_count": 27
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And after 20 minutes, my father came back in a civilian suit.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We still had our uniforms on.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "That man took him in his office, nearby.",
      "word_count": 8
    }
  ],
