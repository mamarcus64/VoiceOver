  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Give me some sort of paper, I should go.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "He said, you don't need any paper.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "You just go and get a lift from the military transport.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I said, but they will not give me a lift just like-- I thought that is a organized-- my foot, they couldn't care less.",
      "word_count": 24
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "He said, just go, don't worry.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Tell them where you want to go, and tell them you are a [RUSSIAN].",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "But sometimes don't say [RUSSIAN], because they are not very friendly, either.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So this is the finito.",
      "word_count": 5
    }
  ],
