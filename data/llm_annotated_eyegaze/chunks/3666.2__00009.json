{
  "stem": "3666.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "We thought we were going to Ponar.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Again, we thought we were going to Ponar.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "My brother jumped out of the window from the train going-- which he thought going to Ponary.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And my-- my mother gave each of us some-- in our clothes-- some gold.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And he somehow went into the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "They were shooting after him, he tells me, he told me.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And he wound up in-- in some kind of hiding that my father knew.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "But these were all temporary things.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "You know, nobody, no Christian, very few Christians were about to risk their life.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "Because you know, they were-- if they caught a Christian hiding a Jew they would shoot them on the spot.",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "But they did maybe let him stay overnight and gave him some food, until he went to a further destination.",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "And then he wound up in a different place.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "My mother and I, and my Aunt Frida.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "She-- the three of us were in--",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "This was my-- it's like my surrogate mother.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she did survive the war.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "So we were in the train for at least a week.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where we were.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "We thought that we are going to Ponary.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Because many times the train just stopped and didn't move and we didn't know where we are.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have toilets.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And the mother, Itele's mother, was sitting there and hallucinating.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "I still remember that scene.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "She was talking to Itele.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Itele, mein kind, Itele, my child, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "She was totally in a state of schizophrenia.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "Reality escaped her.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "This was her only child.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "So [SIGHS] finally we arrived to a place called Riga.",
      "word_count": 10
    }
  ],
