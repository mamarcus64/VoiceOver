{
  "stem": "15082.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, very successful businessman, and had a lot of friends.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, with the-- with the people that were making the shoes, and the boots, whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "But also some would come in, and buy their own, and then take it to the shoemaker to have it made.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "So he dealt with both.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I used to hang around in the store, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish, most of the time.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Polish, we only spoke if we were out of the house.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And among our friends, we'd probably always speak Yiddish.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "School, or if we went over to a gentile family to visit.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Some of my dad's friends used to come up to stay and spend an hour in our house, have a meal in our house.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We did not eat in their houses readily, because of the [NON-ENGLISH SPEECH].",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "If we'd eat there, we'd have some fruit, some just plain bread, that sort of stuff.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "My mother's favorite recipes, she would make the cabbage-- stuffed cabbage.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "She would make [PAUSES FOR 6 SECONDS] stuffed veal [PAUSES FOR 5 SECONDS] and the cabbage soup, which I always used for.",
      "word_count": 22
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And she used to make a lot of [? pierogen. ?] This was her famous-- her baking was very good.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "She used to bake very well.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but my mother worked with my father in the store a lot.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "So I also had a nanny, a Polish lady, which I spent a lot of time.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "My grandfather from the village brought her up to work in our house so she can take care of me.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but in Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I had to speak Polish to her because she couldn't speak Yiddish.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "It's-- my mother's songs?",
      "word_count": 4
    }
  ],
