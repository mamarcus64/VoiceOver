{
  "stem": "2833.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "So I grew up more with-- with these ladies who were taking care of me and going out with me, if I had to do things, you know.",
      "word_count": 28
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And I was a little bit scared of my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "She was very strict.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And I had adored my father and was very hurt when he left.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And, you know, being an 8-year-old-- not quite 18-- 8-year-old child-- I blamed her for leaving me, because that's all I understood at that time-- that I lost him.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "And so my mother and I only got close later on when I was more grown up.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "And then we became friends when I got to know her.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "But then she got to know me better.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And then we moved to Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Vienna was a very fun-loving city and a very beautiful city.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And there were lots of-- [PAUSES FOR 4 SECONDS] --opportunity to go to dancing.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, everybody was very much living it up.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And there was just a lot of-- around the city-- a lot of places which are called the so-called new wine places-- where you go in the evening, and you sit in the garden, and you drink the new wine, and eat some food that you either brought along or got there.",
      "word_count": 52
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And there was music.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And that was the thing that people enjoyed very much.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "The theater was great.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And Vienna is a very, very beautiful city with a lot of parks and-- in the city, in the center, and lots of old palaces of the emperor's time; marvelous food-- much too good-- with a lot of whipped cream.",
      "word_count": 40
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And it was a very fun time.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And it was kind of, you know, it was like all the good times before the end.",
      "word_count": 17
    }
  ],
