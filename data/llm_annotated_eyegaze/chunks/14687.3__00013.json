{
  "stem": "14687.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 0,
      "text": "The-- the-- the people they say, you are Italian.",
      "word_count": 9
    },
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 1,
      "text": "You must go over there in Italy.",
      "word_count": 7
    },
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 2,
      "text": "So they put us in the train.",
      "word_count": 7
    },
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 3,
      "text": "Instead--",
      "word_count": 1
    },
    {
      "segment_idx": 205,
      "sentence_idx_in_seg": 0,
      "text": "These people, the Red Cross.",
      "word_count": 5
    },
    {
      "segment_idx": 206,
      "sentence_idx_in_seg": 0,
      "text": "The Red Cross.",
      "word_count": 3
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 0,
      "text": "So when we went-- we were in Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 1,
      "text": "The-- the-- the Russians came, and we changed the-- the trains.",
      "word_count": 11
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 2,
      "text": "We're-- we take about 12 with us.",
      "word_count": 7
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 3,
      "text": "Other people, we lost them.",
      "word_count": 5
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 4,
      "text": "So they went to Paris and things.",
      "word_count": 7
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 5,
      "text": "We went to Milan after the liberation, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 6,
      "text": "And we arrived in Milan.",
      "word_count": 5
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 7,
      "text": "And the doctors look at after you, see if you've got cough, if you've got TB, all the things they look out-- the Italians.",
      "word_count": 24
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 8,
      "text": "Who-- who received you in Milan?",
      "word_count": 6
    },
    {
      "segment_idx": 208,
      "sentence_idx_in_seg": 0,
      "text": "The doctors there, when we arrived there, the-- the survivors.",
      "word_count": 10
    },
    {
      "segment_idx": 209,
      "sentence_idx_in_seg": 0,
      "text": "So they came there, and the-- yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 210,
      "sentence_idx_in_seg": 0,
      "text": "Red Cross, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 211,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 0,
      "text": "In Milan we stay about 10 days.",
      "word_count": 7
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 1,
      "text": "And I say I want to look to Rome, because I've got a sister there.",
      "word_count": 15
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know there there isn't things.",
      "word_count": 8
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 3,
      "text": "And after--",
      "word_count": 2
    },
    {
      "segment_idx": 213,
      "sentence_idx_in_seg": 0,
      "text": "Si.",
      "word_count": 1
    },
    {
      "segment_idx": 214,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 215,
      "sentence_idx_in_seg": 0,
      "text": "She survived with the four children.",
      "word_count": 6
    },
    {
      "segment_idx": 216,
      "sentence_idx_in_seg": 0,
      "text": "So she was in Rome, and we went there to live with there.",
      "word_count": 13
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 0,
      "text": "From 1945 till 1947.",
      "word_count": 4
    }
  ],
