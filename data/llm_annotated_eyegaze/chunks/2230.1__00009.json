  "sentences_input": [
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "I learned [PAUSES FOR 3 SECONDS] that if you hate, you're in trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "You're very nasty.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "So I learned not to hate.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] But up to a point, I can't forgive.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] And I guess I'll die with it, that I can't forgive certain things that shouldn't have been done to me.",
      "word_count": 24
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] I didn't do anything to them.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 8,
      "text": "I was a little baby.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] How bad could I have been at 9, 10 years old?",
      "word_count": 15
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 6 SECONDS] I guess that's life.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 11,
      "text": "Do you remember what happened when war broke out?",
      "word_count": 9
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "I remember.",
      "word_count": 2
    }
  ],
