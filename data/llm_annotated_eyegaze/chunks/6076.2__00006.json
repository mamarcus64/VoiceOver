{
  "stem": "6076.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "[SPEAKING POLISH] That's all what I heard from her what she was telling my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She came back from school.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "She says, this one, this non-Jewish fellow stopped her.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "This non-Jewish-- my father-- my mother used to say, please, don't tell this to my father-- to your father.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Because your father wouldn't let you go to school.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He would be afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "But try to-- to-- to walk briskly home, to avoid these boys.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And also the same coincident that a fellow came to our city.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And he saw my sister walking.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And he-- he came to visit his aunt.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And he says, who is this girl?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Eh, this is Warszauer daughter, the younger one.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And he went home.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And he sent a [INAUDIBLE] again.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "This fellow, his name was Josef, Nuger second name.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They lived in Suchedniow.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And soon after, they send a [INAUDIBLE] again.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And my mother says, oh, my god, my daughter's leaving me so fast.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I-- I-- I didn't enjoy them growing up, really.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And they're taking them out from the house.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "But my father-- all the neighbors envied her.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Look, Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "Warszauer, you are blessed to have beautiful children.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "That's a blessing.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "You don't need to have money.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "You have good [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "You have good [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE] is, you know, merchandise.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "You sell it fast.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "She was married to him.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And she moved away to Suchedniow.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And the parents had a [INAUDIBLE] store, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And my brother-in-law was with them in the business.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And my sister went in right away to a home, which was good, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Everything was provided for her.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And she had two little boys.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "One, before-- when I met my sister, it was one was two, two years old, a year and a half, you know.",
      "word_count": 22
    }
  ],
