  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "One of our members.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "Could you please address us, and the congregation?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "On a breakfast, some Sunday, when we pick.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "So I says, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "It's my personal story.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "I just wanted to tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "So he walks up to my wife.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "She should persevere.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "So you know, the woman [? does ?], usually.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "So Sally just convinced me I should talk.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "And that's how I thought it over, that it would be good if my children would be there.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 24,
      "text": "So my children will be there, so this will be proper, for-- for me to talk.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 25,
      "text": "And that's the reason I accept it at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 26,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 27,
      "text": "We're going to break here for the next tape.",
      "word_count": 9
    }
  ],
