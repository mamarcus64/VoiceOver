{
  "stem": "8703.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't easy, you know, to, to register again.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "A Jew-- that's what a Jew went through over there, especially.",
      "word_count": 11
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "He didn't  bother the Polish people.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "They didn't bother.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we--",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "We, we-- I wanted to leave very badly, very badly.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "It's a matter of fact, I don't know if I mentioned, no, my sister--",
      "word_count": 14
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "My oldest sister--",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "'Hancha'--",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "--we used to call her Hannah-- 'Hancha.' She, she, she became a pioneer, Halutza.",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "The Halutza, they went to a kibbutz that time, to prepare themselves--",
      "word_count": 12
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "This was in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "A kibbutz in Poland, to work hard at various trades, and various things, the hardest things, and support themselves.",
      "word_count": 19
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "And then, after a year, they could go to, then, Palestine.",
      "word_count": 11
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And my sister was-- she was-- that was in 1933.",
      "word_count": 10
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "She came back from a kibbutz.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "And she went for Aliyah to then Palestine.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] OK.",
      "word_count": 5
    }
  ],
