    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And I remember standing during one action.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "And I said to myself, I have no more problems because there's nobody older than myself that's living anymore in-- in the building where I live.",
      "word_count": 26
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "My mother was dead.",
      "word_count": 4
    },
