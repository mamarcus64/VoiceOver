{
  "stem": "26728.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I was playing tackle football by the time I was in the seventh grade in the schools-- public schools.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Incidentally, I might add that because of my early Catholic education-- if you could call it that-- in the-- in Prescott, at the academy-- when I was in elementary school in Miss Ressor's class, in the first grade, I ended up being double promoted from end of the second-- to the second grade-- regular promotion.",
      "word_count": 55
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Skipped the third grade, because I was too far ahead of the children in that class.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And then I was double promoted again, and I skipped the fourth grade.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I ended up in the fifth grade when, ordinarily, I would have been in the third grade.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So I was actually two years ahead of other kids my age.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "But I was big for my age so it didn't-- that was not a problem, except for the kids that knew that I was younger than they were.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So, tell me about your high school and what happened after high school.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "High school was-- well, junior high school was even more fun, in some ways, than high school for me.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Because I went from the sixth grade to the seventh grade to a school where-- with children who I didn't know.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Kids from all over town went to the junior high school, which was seventh, eighth, and ninth.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "That's when I became interested-- pretty-- I always was interested in pretty girls, even in the first grade.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But by the time I got to Safford Junior High School, I was-- I was very aware of, of, of girls and always had a girlfriend.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "A lot of good memories of those days.",
      "word_count": 8
    }
  ],
