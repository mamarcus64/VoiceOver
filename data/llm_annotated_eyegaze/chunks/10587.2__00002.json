  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And we sang the various songs about Hanukkah and about the destruction of the Temple and the-- [PAUSES FOR 3 SECONDS] and the, also, the [INAUDIBLE] how the Miracle of the Lights, how there's a song that describes it, how the candles were burning for eight days without-- without-- actually, not the candles, the oil was.",
      "word_count": 56
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] But I remember these--",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "[SINGING IN HEBREW] We sang various songs.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "This one I remember the best.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I would say that in my father-- grandfather's building, there mainly was-- there was Jewish people, mainly, living there.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "We had a caretaker which was non-Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And he had his own apartment, because of-- he was the custodian, the caretaker.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And also he used to come around on Shabbat and high holidays, and turn on and off the candles, the lights, [PAUSES FOR 3 SECONDS] and perform some work that was not allowed because of the Shabbat, of the Sabbath.",
      "word_count": 40
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 8 SECONDS] The family was important in Oswiecim because it was a-- an old, established family.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I-- [PAUSES FOR 3 SECONDS] my grandmother [PAUSES FOR 3 SECONDS] came from-- [PAUSES FOR 3 SECONDS] her name was-- maiden name was Van [?",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Plasner. ?] She-- they were old Austrian Jews with a title.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "So she was a contessa, count-- a countess.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "Van [?",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Plasner, ?] that was her maiden name.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And [PAUSES FOR 3 SECONDS] this is the same person that I describe where people-- you should tell me how they-- they say we need more people like this now to help the poor.",
      "word_count": 34
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And your grandmother was such a terrific person that she made sure that the poor people had food and-- and were able to keep warm.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And that was her.",
      "word_count": 4
    }
  ],
