  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "But I know that many people closed their eyes completely.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to know it.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Why should we be bothered with it?",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We have a very wonderful life, they felt.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And why should we be bothered?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And I know that-- I know it from some people in-- from the grocery store, who said, oh, I know about the deportation of Jews.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So what can we do about it?",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They had a-- a nonchalant attitude.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And it was terrible to hear that, because the friends of my parents, so many were already deported.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And the situation became so close and so desperate that we almost didn't dare to go out anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    }
  ],
