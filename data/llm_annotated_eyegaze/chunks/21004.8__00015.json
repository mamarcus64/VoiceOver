{
  "stem": "21004.8",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So she-- so soon they see her, they stopped.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "She picked up her hand in the middle of the road, and she hold-- a whole squadron of tanks.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They all stopped.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And they ask her, in Russian, [SPEAKING RUSSIAN].",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "What kind of people are you?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "She say, we are not partisans.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "We are Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Survivors.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And I got my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And my husband saw this, and this, told them.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Later, they took us all on the tanks, on top of the tanks.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "They'd drag us up, and they took us to Jaworow.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "Where you want to go, they ask?",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "We say, to Jaworow.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "And that's how we came to Jaworow.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "Could you describe what you felt that moment?",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I felt a little easier.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Much easier.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Much easier till [PAUSES FOR 3 SECONDS] I start doing a little work against the Ukrainians, for they were killing Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And my wife know a lot what she heard, saying those Ukrainians, they say, why don't you throw-- oh, yeah.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "One says to the other, why don't you throw in the-- in the well?",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "One girl, a girl friend from my wife.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you throw the girl?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He grabbed her and he throw her.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "He drowned her.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Throwed her in a well.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "So later when he came-- Excuse me.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Who was thrown in the well?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "The-- the Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Ukrainians.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Bandera-- those Bandera.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "They throw her in a well.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "But my wife overheard it in the-- in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And they passed by.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Why don't you throw her in a well?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "They throw her in the well.",
      "word_count": 6
    }
  ],
