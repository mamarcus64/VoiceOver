{
  "stem": "7238.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "A lot of rabbis were killed defending the Torahs.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We heard stories about kicking the rabbis and killing them.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "But Jews prayed privately in a private apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, new restrictions that people have to leave their homes and be assigned to very cramped quarters.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "This we called the-- the big ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The big ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "We were lucky at this time because we remained still in our apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "However, the three rooms were shared with three other-- with two other families.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Moved in from a part where Jews could not go in.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "There was a curfew.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Nobody would dare to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] The same, we didn't dare to wear jewelry or fur coats, because it was an order of the day.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I worked in this-- [PAUSES FOR 3 SECONDS] in the stat commandant.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Cleaning his apartment.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And then, with escort, I was brought back to my place, where the Jews were allowed to stay, because he lived in the best part of the city.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "It happened that my young brother, who was taken to work, did not return home.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We heard only from our friends and neighbors, a lot of young people were sent to a labor camp.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We didn't hear from him for a long, long time.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And one day, a miracle happened.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "He and the other guys ran off from the camp there.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And he returned home.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "He was bewildered.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "He didn't know what to talk about.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "But he was safe because he was with us.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And-- and we helped him to come back.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They-- they were digging some places.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He hardly talked about it, because he said, they hit us.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They wanted to kill us.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "This probably was the main job, to survive the killing.",
      "word_count": 10
    }
  ],
