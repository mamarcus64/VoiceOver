{
  "stem": "8842.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And from there on, I had only my grandmother, because my, my grandparents through my father's side were deceased a long time ago when my father was still a young man.",
      "word_count": 31
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So I don't know that part of that side of my family, but my grandmother was with us much-- many, many, many times she used to come to us and sing to us beautiful Yiddish songs, and being with us for weeks long, and then go to see her other children, and come back to us.",
      "word_count": 56
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "She lived in also in Kovno.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "But she used to travel from one son to a daughter and so on, and always come back to us.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "My mother had [PAUSES FOR 3 SECONDS] a brother here in the United States, a brother in South America in-- oh, God, the name of it-- Uruguay, a sister in Africa, [PAUSES FOR 3 SECONDS] and one brother in Lithuania, which this one I, I knew.",
      "word_count": 46
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "That brother, we knew very well.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He used to come to us very often.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "His name was [PAUSES FOR 3 SECONDS] Uri El, Uri El.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Uri, we can make it-- we can make it a little shorter-- Uri El Zivov.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And his wife, Rachel, and he had two children.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And we knew each other very well.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We used to visit each other very often.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Beautiful, just beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We-- summertime, we used to spend with them the whole summer sometimes.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "That was in Kalvarija, a little city, I would say, probably around 50 miles away from Kovno.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, this is where they lived.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't country.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "It was a small, little town--",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "--little town that they lived there.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And also two of my father's brothers lived there.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So I knew my two uncles from my brother's-- from my father's side.",
      "word_count": 13
    }
  ],
