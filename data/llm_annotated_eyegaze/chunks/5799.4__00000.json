{
  "stem": "5799.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I had a letter back.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My mother wrote in Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My, my father wrote in Yiddish, and I learned Jewish-- Yiddish just now, through my husband.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't know well how to read, so I went to a friend.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "My father wrote that if I met a guy and I'm going to be with him, he is his son.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "My mother wrote to me that she always knew that a Russian woman, you could buy for three pair of silk stockings.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "There is a book by Panteleimon Romanov, But she said that I sold myself, so to call-- in her imagination-- to survive.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "She can understand.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "But I sold my soul and went out of my class because I will never leave him.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I couldn't say to her, mama, you are right, but I am not sad.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I build my life around this man, and it's a good life.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I married to this man five times, each time in a different country, and if I would ever have to get a divorce, forget it.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] The, the Jewish wedding I had while I was pregnant with Anita, with my older daughter, in America.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I went to a rabbi because after the war I met my nanna, who is not Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "She raised me.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Mamma was busy, so I had a nanny.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And she took out the ring-- and she was not Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "She wanted to take me, but the first thing the Nazis would look would be in her place, so she couldn't take my sister and I.",
      "word_count": 26
    }
  ],
