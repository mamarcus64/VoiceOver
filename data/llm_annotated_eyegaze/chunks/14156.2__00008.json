{
  "stem": "14156.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "Did you stay with her?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So I-- I stayed with her till it got dark.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Then I started to go out, walking alongside the river.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I had a pocket knife.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know what I would have done with the pocket knife.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "But I took it.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And I clicked it open.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "It was dark.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "It was November.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I walked along the river home, towards home.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "As I come home, I climbed up to the-- by the railroad and just peeked over.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I wanted to see what's going on at home.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "The neighbor seen me-- Anna again.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "She said, Munford, come on.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Everything is OK.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "You can go home now.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And they took me by the arm.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And they, they, they showed me to the house.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And here's two brown shirts again standing there with the bayonets.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And they see me and said, yeah, Munford.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "It's OK now.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "You can go home.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Go inside.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "There wasn't, there wasn't a, a light in the house-- dark, pitch dark, glass all over the place.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "Nothing was, was kept intact.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "I don't know how we got through that night and waited till the next morning, the daylight.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "And later, I heard from the kids who, who tried to intimidate me and, and, and my mother, who was together with, with her sister at home when it happened, she, she didn't know what to do.",
      "word_count": 37
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "She, she thought they're going to come after her or maybe kill her.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "She screamed, naturally, how women do in, in a situation like that.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "They, they always screamed, you know, in front of me.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "Yeah, your mother, ha ha, ha, in that way, you know, tried to, to make me look-- make her look how she was scared.",
      "word_count": 24
    }
  ],
