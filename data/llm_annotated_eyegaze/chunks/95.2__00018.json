  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I mean, let's face it, some of the pieces of rubber were not all very good, and the leather was not good either.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You look at the whole box, and there are maybe five pieces that are very good.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And he came to me with a lot of heels, and they're not good.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And they were screaming at me.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I said, why you screaming at me?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It's not my fault.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Leave me alone.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And I walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I walked out.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I went-- we had a little barrack downstairs when we had-- when at lunchtime for half and hour, we would get a lukewarm soup.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I went to that barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I was there for half an hour.",
      "word_count": 7
    }
  ],
