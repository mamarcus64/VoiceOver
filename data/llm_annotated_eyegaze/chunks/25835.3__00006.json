{
  "stem": "25835.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "My mother, of course, my aunt, and this lady, they stay up to the end in Ravensbruck.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I mentioned to you before that I knew that underground army is helping Jewish people to, to supply in ammunition, to-- taking some children to, to safe places.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And very, very close to me, it was problem-- not problem, action of this group where my, my and my brother friend lost life-- action of-- on Street Bonifraterska.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It was street very-- this is street close to ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And this action had goal to put dynamite and ruin this wall.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Not too much, but enough to withdraw people from ghetto because everybody knew that ghetto is going to, to be finished by German.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "To--",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Everybody knew what's happened in the-- in the middle of our town.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Everybody knew that German-- and they, they told also, this is last-- we have to finish with Jewish.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They took-- every day, they took big transport to Treblinka, I don't know-- to Majdanek.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I don't know, really.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "In this last transportation, Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Melamed, this beautiful girl, was lost.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Her mother, she took this girl with her.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And they was-- is in gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "After the war-- after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When we return from concentration camp, Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Melamed tried to find us because she was in Jerusalem.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And from her, we know that the daughter lost life and mother.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Probably my, my brother knows better [?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Epstein. ?] I remember Neufeld and Melamed.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Neufeld-- I told you, this man without arm, and Melamed family which were on friend-- friendship with my, my parents.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Barracks was quite big, on three bunks, not wooden floor, only, like, dust floor, one-- each bunk was filled with wooden pieces, not even material, only in paper.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And what's happened?",
      "word_count": 7
    }
  ],
