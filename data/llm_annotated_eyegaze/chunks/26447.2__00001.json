{
  "stem": "26447.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "We will show what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "We didn't understand what happened then.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "Then they come with the horses and with the wagons, we come to the place, to the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 30,
      "text": "We see it's quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 31,
      "text": "Nobody is in ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 32,
      "text": "We understand what happened at that.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 33,
      "text": "They take-- they tell us to take all the stuff, what we will find in the houses.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 34,
      "text": "Everything, everything put in the wagons and take to the warehouse.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 35,
      "text": "When we came in the ghetto, I see it's-- the killed people in the street, everywhere.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 36,
      "text": "I and my father, we came to the-- [SOB] to the-- excuse me, please.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We came-- [PAUSES FOR 6 SECONDS] we came to the house where we was living.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I came in they called the mother, the sister.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Nobody answer.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I went-- and the father-- to the next houses.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Nobody is in the houses.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans, the police came after us and begin to beat us.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Work faster.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Take-- take everything.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I want to tell-- when we came in the ghetto, somebody-- we saw what somebody was taking everything from the houses.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Because everything in the houses, it already was mixed, everything.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "But somebody was coming.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "Maybe they-- they checked each house they would take us.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "As we begin, we take the killed people and we put them on the wagons.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And we take them-- they show us where to take the-- the killed people-- killed people.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And we take it.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And we saw this place, it's terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "You can-- it's-- it's impossible to-- to explain.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "[SOB] [PAUSES FOR 12 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We finished with this, all the job.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We take everything.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Know what to do.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They tell us we will not touch.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "You will stay-- you will [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "No.",
      "word_count": 1
    }
  ],
