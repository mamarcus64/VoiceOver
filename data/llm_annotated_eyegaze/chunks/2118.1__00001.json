{
  "stem": "2118.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Then was my brother Manny, or [NON-ENGLISH], my brother Mendel, and me.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was the youngest-- the baby to the family.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Now we lived in a mostly Jewish neighborhood.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The city was close to a million people. 1/3 of the population, at least 1/3 of the population, was Jewish.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "The other 2/3 were about [NON-ENGLISH], or a little more Poles and Germans, or what they called the volksdeutsche, which means native Germans.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The-- I had a very happy childhood.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I come from a middle class, or what we would call here above middle class family.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We lived in a, I would say, 90% Jewish neighborhood.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "It was not a wealthy neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "It was rather a poor neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "It was called the section of Balut, in the city of Lodz.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "It's was the old town.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And it was a working neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Mine-- my childhood was a very happy one.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I was the baby in the family.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "And I was-- I wasn't spoiled, but I was very good taken care of.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "The earliest I can remember is maybe going back to six years or something like that.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "I don't remember much before that.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "But I remember distinctly the first day going to school, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "I-- I was seven years by then, or pretty near seven years to start school.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And I went to a public school, which was 100% Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "It was run by the government.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "It was a government school, but it still was a Jewish school, because the neighborhood was Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "There were no Christian children in school.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "We went to school six days a week, included Sunday.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "We had off on Saturday-- and also very happy years.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "I finished school.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "I finished school in-- after seven years.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "That was-- after that, either you went-- you continued on privately.",
      "word_count": 11
    }
  ],
