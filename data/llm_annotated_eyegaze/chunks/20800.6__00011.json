  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "I brought him money back, but he wouldn't take it.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "But I will never forget.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "And I said, what do I have to take so that I have something, because I have a-- I didn't pay for a piano.",
      "word_count": 24
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "Because I was a pianist, I have the best piano you can get, [INAUDIBLE], from the government.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "They gave me a concert piano.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "Beautiful piano.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "Here it costs a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "And I wanted to take with him.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "So he said, well, where you will put this piano?",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "So that's my-- that's my hello.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "Why, why do you come, and where you put?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 26,
      "text": "Of course I knew that I go on my own, and I can-- my husband says maybe.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 27,
      "text": "I said, Gershon, I can bet you anything, no maybe, we have to stay on our own two feet.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 28,
      "text": "We come with no money.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 29,
      "text": "We had eight shillings, which we spent straight away to take a few luggage that we brought from Poland, from this, this-- from the ship.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 30,
      "text": "That was that.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if--",
      "word_count": 4
    }
  ],
