{
  "stem": "27747.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And I always-- when I went to the pastures, I always avoided the other Ukrainians that were there.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And there were mainly Ukrainians in the pastures.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So they would not ask me questions, or they would not have any conversations with me.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Only once, I met a schoolmate.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "She was Czech, and she was under way from Miedzyrzecz to her town.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "We had lots of Czech families there, which I am sure Jewish people maybe survived in their homes.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "They were more friendly to the Jewish people, more friendly than the Ukrainians.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "When I met her, she stopped.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "She wanted to talk to me, but I did not-- but I turned around and I did not want to say anything to her.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And she could not-- even if she wanted to call authorities, she couldn't, because she wouldn't know where I lived, where I was residing.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And they wouldn't just go out and look for a girl that was in the pastures.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He did not want anymore to stay in the Miedzyrzecz.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He was much too afraid, and he has decided to move to the town of Rowne, which had no Ukrainians around, had more Poles.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And we packed up and moved.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Her parents did not move, her parents.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He was Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he felt safe in town.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "His wife was Polish, the children are considered were Polish.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So I moved with them to the town of Rowne.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And the-- [INAUDIBLE] and of course the boss and the two little ones, we all moved.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And [INAUDIBLE] also moved to the town of Rowne.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "We had an apartment, and he found a job.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He was working days.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And then we had a census.",
      "word_count": 6
    }
  ],
