  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "When I was a little bit out, I tried to write some poems.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And then, while before I was always fighting, actually, with good Lord, then I finally said, I can't any more.",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "Please help me.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "Please save me.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "I know that, at the end of February or beginning of March, I was in Malchow.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "They transported us there.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Probably February.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Of '45.",
      "word_count": 2
    }
  ],
