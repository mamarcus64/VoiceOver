{
  "stem": "23278.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And their business was, from what we spoke about, mostly manufacture of underwear, heavy underwear, winter underwear, what you would call long-johns, things like that, that was sell at LL Bean's.",
      "word_count": 31
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the father was not very gifted for business.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But that's beside the point.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So they had to move from Nuremberg.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They took whatever they could take, not very much.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But they took their-- those big things of underwear, you know, all this-- the store.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They brought it to [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And after a while, they were pushed out of [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They had to come to Dijon.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And that's where they lived not far from us.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And that's where Rita went to school with my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they were living about three, four houses from us.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And then she went to high school with me.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But she was in a lower grade.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And thinking of that, it just breaks my heart.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "The father would take those clothes, you know, those underwear things in big suitcases in his car.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And he would-- he didn't speak French at all.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And he would stop at houses.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And Rita's mother, [NON-ENGLISH], who was, you know, those kind of Jewish women.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "It's a special type-- very long, very thin with a thin face, the kind of face you see on [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "You know, that kind of physique-- very delicate woman, a good pianist.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "She had to lug those suitcases and do door to door.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "She was the daughter of the Grand Rabbi of Basil, not raised for that at all.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And she had to go from door to door with those suitcases.",
      "word_count": 12
    }
  ],
