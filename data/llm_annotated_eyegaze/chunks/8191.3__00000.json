  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "November 15, 1938, I was married.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My wife was Celine Rosenthal.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She was born a [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And also, by coincidence, I met my wife August 7, 1937.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] In 1937, from January to May, I worked the stall, the pavilion of cinema to the World's Fair in Paris.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] In May my job was finished, and I left for Egypt.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I was [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And then from Egypt, [PAUSES FOR 3 SECONDS] I came back August 7, 1937 to Paris.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And I was coming into my-- I was already in the building, but I was living on third floor.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And my concierge stopped to tell me that there's a lady's coming here every day.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Didn't speak a word of French, but she had a letter with my address.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] And he said he couldn't understand what she wants.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "She said, I'll come tomorrow, [FRENCH].",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And that was-- she was in Paris, August 7 she was in Paris for 14 days, and went every day to same place.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And the concierge said, [FRENCH].",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And I came up from Egypt, and in just Egypt it was very hot.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And I came-- I had shorts, colonial shorts, and all kind of things.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And us-- the concierge takes up my baggage, luggage, and he wants to put the-- put in the key.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And he said, [FRENCH].",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "[LAUGHS] She came the same.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And I said, come in, so she came into the house.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "I said let-- she asked me if I speak Polish.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "I said yes.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "And she gives me a letter of my best friend from Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And he was in that time, was one of first-- he was graduated sports.",
      "word_count": 14
    }
  ],
