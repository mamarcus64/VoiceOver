{
  "stem": "27543.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "She was writing a letter in her hand.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "The pen fall out of her hand.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "She drop down dead.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I was then in Budapest.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And I got a telegram that my mother was-- she died.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I went right away home.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't know what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I bought right away for home, a stone-- and stone that the whole thing was covered.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And on her-- in her name, a stone this way, that's where she's-- but my father, you know, he's buried in Chicago.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And now you saw that I got something that I want to bury in Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I want all three of us be one.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, we're not going to move them, no.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "You don't got to move them.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "It's all set.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "A messenger boy.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "For two years, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "What was the messenger boy?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "This guy called up a letter to this lady.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "This lady called up a letter to the guy.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And then they said that she wants to buy something.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And this and that, there was some boy there, a good looking boy.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "He had the same job I do.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "His name was [HUNGARIAN], a good looking guy.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And once a older lady called that he needs somebody to send, she was fall in love with this guy.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "And always, she always called number six.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "Then the boy, and he bought her all kinds of clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And that's a-- just want to tell you, it's how you had your luck.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And after two years and two months, we had to go in.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "There was a plaque out.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "There was everything out, at every corner, all the Jews this and this age, be ready to go to [NON-ENGLISH], showed the picture there.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And get ready for the winter.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "For how long, we don't know.",
      "word_count": 6
    }
  ],
