    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 22 SECONDS] I would like you to see my children.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "The three girls are here.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "My brother is here and my brother still has problems about this nightmare.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "I have bad dreams once in a while.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "But every so often, [PAUSES FOR 4 SECONDS] you remember.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] Not much you can do.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "But most of all, I'm very happy to be here in this country, among these people and enjoy such nice freedoms.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 6 SECONDS] Freedoms come in various shapes and very generous freedom.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "I hope it stays like this for a long time so other people and our children's children enjoy it too.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
