  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "You-- you was two, three families in one room.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "That was already a luxury, but still.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "You know, it was-- some people with small children they really couldn't-- couldn't do it.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So did register, and my friend, and my husband, and other friend.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So this is now 1948?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, that was 1946, end of 1946. '46 '47-- '48.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "The end of November.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We left Wetzlar November '47.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "We came to Israel in-- in December.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "We came in December.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Because we was hiding in Marseilles for three solid weeks, because illegal-- we must go illegal. 40 people, in a house like that. 40 people was in a-- in a-- in a house, like that, for three solid weeks.",
      "word_count": 39
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Still came there-- the-- the boat from, [? was it, ?] Israel, already-- the [?",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Negbah. ?] The [?",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Negbah ?] could accommodate maybe 200 people or it was maybe 500, 600 people.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "It was lined like herrings in this-- in this boat.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "We waited three solid weeks in Marseilles.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "But the English people didn't let you in.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Oh, they didn't let you in.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't just go.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "It was like water.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "You-- you know, like to America, you have you have to-- they let in so and so many people, not much.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "That was-- the people were--",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Declared-- it was declared.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "But English-- the English people didn't let still in.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Eight, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "When I came-- I will just tell.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "When I came to Israel, when I went out, was still, when we came to--",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, '48. '47?",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "It was still not allowed, immigration.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "We still couldn't illegal.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "We couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "When I came to Israel, and a week later was opened the parliament.",
      "word_count": 13
    }
