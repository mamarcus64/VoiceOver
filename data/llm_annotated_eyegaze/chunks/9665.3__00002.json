{
  "stem": "9665.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "For six packets of cigarettes, I got unlimited sauf-conduit, 800 kilometers.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And I needed to go from Lyon to Marseille.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Why I want to go to Marseille, because I want to see my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So in December, we went to Marseille.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "By the way, again, I wrote a letter to Leizar.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "In arriving in Marseille, my sister in the hotel-- we stayed in the Hotel Select-- got a room for us.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "She was cooking on the sly, because there was nothing to eat in the restaurant.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We were starving.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "In the restaurant, we needed tickets, as we were not residents.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I have to go back to Lyon in a few weeks time.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have any tickets.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So even if we would have tickets, you can't buy anything with it.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "There was already-- how would I say?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "A famine or-- the, the people were already starving.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Already by the end of '41, beginning of '42, they were starving.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We were in that hotel.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We discussed everything.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I was together with my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I said to her, I have to get married the Jewish way, which I did.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They organized it with Isaac's father, who was there in a little room, the old-fashioned way.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "It was a rabbi from somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I had to give him so much money.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "The bride had to walk around me, and I had to walk around there.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And we broke a glass.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And that was we got married the Jewish way.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "That was in December, 1941.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Don't ask me the date, because I really don't know.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I haven't got these papers anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "How would I?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Then I went back to Lyon, because I started to like Jacquet.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I met a man called Sally Noach who just arrived.",
      "word_count": 11
    }
  ],
