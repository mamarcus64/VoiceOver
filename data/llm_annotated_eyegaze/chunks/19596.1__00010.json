{
  "stem": "19596.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "But I was begging my uncle to put up a certain fund, money, to get them out, because you could do it at that time.",
      "word_count": 25
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "It was costing a fortune.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "That was in '39.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "But he didn't-- he was not prepared to put up such a sum.",
      "word_count": 13
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "See, you give it to a guide.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "And that guide guides them to the border and smuggles them over the border.",
      "word_count": 14
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "But he didn't want to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "So that was one resentment.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "And I said, then I get the money.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "And I earn-- I pay you off every cent, plus a profit.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "And he didn't want to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 9,
      "text": "He was not very nice to me on the end.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 10,
      "text": "Not very nice at all.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, it was all right, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "It was all right.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "I was very happy in Belgium.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "Different.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "It was all different, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "I had no pressure.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "And then I-- I continued to school-- schooling, naturally.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "And then my auntie had a baby.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 8,
      "text": "That was my cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 9,
      "text": "She comes from Estonia.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 10,
      "text": "And her name was Marie Louise.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 11,
      "text": "It was a little baby.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 12,
      "text": "And that was already going into the 1940s.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 6 SECONDS] And on the 10th of May, 1940, we saw aeroplanes in the sky in the daytime.",
      "word_count": 20
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 14,
      "text": "And people went on the balcony pointing at those aeroplanes.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 15,
      "text": "They were German fighters.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 16,
      "text": "And they were machine-gunning the streets in the daytime.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 17,
      "text": "I saw people pointing at them.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 18,
      "text": "And that was the invasion of the Germans in 1940 onto Belgium.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And people prepared to leave.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 20,
      "text": "People started packing.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 21,
      "text": "They were fighting on the-- on the lines, on the Maginot Line, and they're fighting on the Albert Line.",
      "word_count": 19
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "General mobilization and so on.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
