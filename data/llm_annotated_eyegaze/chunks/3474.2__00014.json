{
  "stem": "3474.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We're friends-- they were-- you know, acquaintance, you know, from the camps, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And when we got there, we took a train to Buchenwald from over there.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I think it was Leipzig from there.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "I think it was Leipzig.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "I think it was Leipzig.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "That's how we-- we get-- that-- we stayed overnight there.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "They didn't say nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "They seen, but didn't say nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Absolutely nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And-- if-- if you find a piece of grass or something from under the snow, we ate it.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Or something.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "A potato.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "Anything we find, you know, we ate, because you were starved for days.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "You know, no food at all.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "And then from over there, we finally got a train.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "And we got to Buchenwald.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "It was for days we marched.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "For days.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "They finally got us on the train to Buchenwald.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And there also-- in Buchenwald there also, 'arebeit macht frei.' Same thing.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And over there it was murder.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "They put us in that barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And also about 15 in one-- like herrings.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "They used to slept.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And in the mornings, they used to come-- they didn't wake you.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "They come with their sticks, beat you out of the trunk-- out-- out of the bunk.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "Out, out.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "For appel. 5 O'clock in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "And it was cold.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 14,
      "text": "We stood there for hours in the cold.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 15,
      "text": "People were just collapsing and die in the snow there.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 16,
      "text": "And then about three, four, hours later, because we didn't go to work over there too much, in Buchenwald.",
      "word_count": 19
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 17,
      "text": "About five-- three or four hours later, the SS came and they asked if everything was all right.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 18,
      "text": "So we went back in the barracks for a while.",
      "word_count": 10
    }
  ],
