{
  "stem": "6503.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "My mother went to Poland-- one of the few-- one of the latest that went from Vienna away.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "She went with very prominent people because that-- were kept till 1942 in Vienna.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "She went to [INAUDIBLE], near Lublin.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "She wrote me one postal card, and wrote me that she had nothing to eat and nothing to wear, and I should send with-- I went to my brother, who lived with me in Amsterdam.",
      "word_count": 35
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "We sent money, we sent clothing, we sent food.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "We never heard from my mother anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "We got the postal card back from the Jewish [INAUDIBLE], that was the head of the committee there, that the woman, Mrs.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Leiter, Marasch, she is not more present.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "So my mother was taken away, and we heard she was killed there, where they killed them alive.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "They buried them alive.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So I never saw my mother anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I went away.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I was 18 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I went away, and after that, I never saw my parents anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I want to talk about when things started to change for you in Vienna.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "What was the first indications that things were going really wrong?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I remember the day when Hitler came in.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He went to the main street in Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I was coming home from school.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I had-- the school was in the first district, and we lived in the second.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was very scary.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "The people were screaming and hollering.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And when he drove through, the people became hysterical.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "They were very much in favor of the Anschluss-- that means the connection with them.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And as a Jew, it was not very popular at the time to be in the street.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I rushed home as fast as I could to be at my house.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "After that, it changed.",
      "word_count": 4
    }
  ],
