{
  "stem": "7777.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 55,
      "text": "Kulich ?], when the Jewish people-- yeah, the [NON-ENGLISH] said, all the [INAUDIBLE] was the Jewish people was living have be [INAUDIBLE], have to be cleaned up.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 56,
      "text": "Over there was a rich man.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 57,
      "text": "He got a briefcase, with gold-- five ruble gold, 10 ruble gold-- the Russian gold pieces.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 58,
      "text": "The people [INAUDIBLE] took apart, the people where they was.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 59,
      "text": "And the second ghetto worked in this, to take apart-- some people went outside.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 60,
      "text": "Not all the people.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 61,
      "text": "Is where they find gold, or something, that give to this [?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 62,
      "text": "Kulich, ?] to this guy, the president.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 63,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 64,
      "text": "Kulich ?] had the vice president-- [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 65,
      "text": "He lived good with this-- [?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 66,
      "text": "Kulich ?] lived [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 67,
      "text": "And he give him a lot of money.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 68,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 69,
      "text": "Kulich ?] give a lot of money [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 70,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 71,
      "text": "Kulich ?] said, this guy, the vice president, he told him-- the [NON-ENGLISH]-- he told him, if this will get something happen, he will tell him.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 72,
      "text": "And this will be the time to run out from the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 73,
      "text": "Meantime, when [INAUDIBLE], they stand around the ghetto, is the [INAUDIBLE], the [INAUDIBLE] they throw into [?",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 74,
      "text": "Kulich's ?] house.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 75,
      "text": "And me, and my brother, and another five people was hiding in this room.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 76,
      "text": "This was Friday, until Saturday night.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 77,
      "text": "Everybody got a place, a Gentile, to be keep [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 78,
      "text": "Nobody was thinking it will take so long.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 79,
      "text": "Only because the Russian coming so fast-- we was [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 80,
      "text": "Everybody was thinking he will go out, and he will go to the Gentile, and he will-- over there, we hide it, and he will [INAUDIBLE].",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 81,
      "text": "Me and my brother, we have a place.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 82,
      "text": "This was Saturday night.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 83,
      "text": "We walked out.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 84,
      "text": "I walked out.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 85,
      "text": "This was December 15-- December 13, 1943 was the last ghetto liquidated.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 86,
      "text": "This was December 15.",
      "word_count": 4
    }
  ],
