      "sentence_idx_in_seg": 23,
      "text": "Was sand there.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 24,
      "text": "We had mud to go in.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 25,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "But we were OK.",
      "word_count": 4
    },
    {
      "segment_idx": 131,
