      "text": "This side [NON-ENGLISH], and this side goyim.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 20,
      "text": "Didn't go there.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 21,
      "text": "We were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 22,
      "text": "They had a better spot, you know.",
      "word_count": 7
    },
    {
