    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And the war was over seven months later because of Mr. de Gaulle.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "If Mr. de Gaulle hadn't entered the war, the war would have been over not in May, but in February.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "But de Gaulle had to insist that Paris had to be liberated first so the German could catch their breath.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "There was the Battle of the Bulge.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So it-- but there was postponement of the peace.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But all our-- the-- the-- the bulk of our losses, of our murdered people, was in this seven months, when the Germans were losing the war.",
      "word_count": 26
    }
