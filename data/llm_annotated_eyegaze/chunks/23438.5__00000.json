{
  "stem": "23438.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I lived in my aunt's apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The war had ended.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "My mother was not there.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "We had no news whatsoever.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "My aunt had had quite a big nice apartment in the center of Lodz.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "In this time, it was like the Bourke Street Mall.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "There were continuous strangers coming and going.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We slept two or three to a bed.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "There was an incredible amount of people going through.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I found myself in need of some money.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "I had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "I had nothing to wear.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Spring was coming.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I went and offered the Red Cross my blood-- they were paying some money for it then-- so I could buy myself a summer dress.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] That must have been the end of May.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "One day, the bell rings.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "The doorbell rings.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "I open the door.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "There's my mother, looking like a million dollars.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And behind her, the caretaker with a big suitcase.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "What happens was she went to this transit camp.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "She was sent out of Warsaw with the whole population.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "She went through the transit camp in Proszkow.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "She was sent from there as slave labor to a town in Germany called Gorlitz.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "It is now in the Polish part of the recovered parts.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "It's called Zgorzelec.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "Then it what was called Gorlitz.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And she was there employed in a train depot, cleaning the trains.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "Now, Gorlitz had a quantity of fruit orchards around.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "And there were huge stocks of apples.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "And even though she was there throughout winter and spring, there were plenty of apples to bite into, so she was never really hungry.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "And obviously, she looked well from all those apples.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And then, in the street, a Russian army captain bumps into her and hugs her and says, Herr Markson.",
      "word_count": 19
    }
  ],
