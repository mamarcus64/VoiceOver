  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And then the other girl, she married a very prominent doctor now at [INAUDIBLE] in America.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But they lost their Yiddish kind.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They lost their faith, their Jewishness.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You can't lose faith.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Wherever God reigns, you can't lose faith.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "You must have faith, you can't walk across the road without having faith.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "But obviously, those are religious details, the ritualistic observances.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And she got married, and she had two sons.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And they came over here.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And she sent them to St.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Albans which was a very posh American, Anglo-American school, which means they-- they weren't interested in-- in Jewishness.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "[INAUDIBLE] great pity.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And I haven't been able to see her since.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So that's when gradually, gradually, we had services.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And--",
      "word_count": 1
    }
