  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And-- and this time it was-- it was-- the-- it was how to say-- a pact-- a pact there, an understanding between the Hitler and-- and Stalin, So they take Poland to [POLISH].",
      "word_count": 33
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH] means the river, the border.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And the Russians take the parts, and German the this part.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And my-- her uncle decide to go away to-- he liquidate his shop.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he decide to go away.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And he-- he told us he was going.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "He find some people who can smuggle him to Japan and through Japan to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Yes, but then we didn't go.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "My wife was pregnant and-- and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We think it would be better if we stay.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But then we stay and start the-- the war with Russia-- Germany with Russia start the war.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "So we have to go somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We went to Pinsk.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "It's a small city, many Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And from Pinsk, we went to-- I was working there a while, and from Pinsk, we went to Janow Podlaski.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Where is this?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "It's in between Pinsk and-- and-- and-- and [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was Soviet Union, because-- yes.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Is it Belarus?",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Yes, Belarus, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, I couldn't speak the Russian at this time.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But I learned fast, yes, later on, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes, oh yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I find work, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] yes, I find, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I was-- in Pinsk, I was working.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- a-- [INAUDIBLE]-- [PAUSES FOR 6 SECONDS] a nursery, a [INAUDIBLE] nursery, like a-- like a [INAUDIBLE]-- like a [INAUDIBLE] nursery.",
      "word_count": 23
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And it was a Pole yelling.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "His name-- and he run with the German.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So it was a post up here.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
