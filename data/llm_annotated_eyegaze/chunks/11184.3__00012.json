  "sentences_input": [
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "I said, it doesn't matter, I said.",
      "word_count": 7
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "I want to be in the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 3,
      "text": "So I wound up in St.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 4,
      "text": "Louis, Missouri, which I didn't like.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't stand the summers there, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 6,
      "text": "So my mother worked.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 7,
      "text": "And-- and my ex-husband worked.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 8,
      "text": "He was still your husband at the time?",
      "word_count": 8
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "And my-- my mother worked.",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 4,
      "text": "And so we bought some ticket, trains-- tickets and came over to the-- to Los Angeles on our own.",
      "word_count": 19
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Hamburg.",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "From Hamburg, we came over here.",
      "word_count": 6
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "We still-- we still in touch.",
      "word_count": 6
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "And we-- we're very close.",
      "word_count": 5
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "Some are very close.",
      "word_count": 4
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "But I knew they're coming too.",
      "word_count": 6
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "I knew that-- and a lot of them came already.",
      "word_count": 10
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "You know, the people from that city, what we lived, yeah, we were about 100 of us.",
      "word_count": 17
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "And so a lot I met here, and they're still here.",
      "word_count": 11
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 3,
      "text": "Some are here.",
      "word_count": 3
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 4,
      "text": "Some passed away.",
      "word_count": 3
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "I came in to New Orleans.",
      "word_count": 6
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "I think.",
      "word_count": 2
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "My mother was sent to Detroit, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 2,
      "text": "Because she had a different name, they didn't understand that, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 3,
      "text": "So she was sent to Detroit.",
      "word_count": 6
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 4,
      "text": "But they helped me to bring her back, you know, to be together.",
      "word_count": 13
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "Very rough, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "I was so sick.",
      "word_count": 4
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 2,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 3,
      "text": "I-- I couldn't-- I was so nauseous, day and night and day and night, never left me.",
      "word_count": 17
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 4,
      "text": "Very, very ill.",
      "word_count": 3
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "He was all right, but he stopped eating.",
      "word_count": 8
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "He wasn't eating any more.",
      "word_count": 5
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 2,
      "text": "And when we arrived, he got the measles.",
      "word_count": 8
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 3,
      "text": "And after the measles, he got pneumonia.",
      "word_count": 7
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 4,
      "text": "And he had to be taken away from me to the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 6,
      "text": "It was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "I talk a lot.",
      "word_count": 4
    }
  ],
