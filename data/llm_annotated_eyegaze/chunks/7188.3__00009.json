{
  "stem": "7188.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She was very-- what do you say?",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "She was very alert.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "She knew how to-- to deal with this thing, grab things, and making and cooking.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "After the war?",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "In the march, in the death march, when she found a chicken, she cut the chicken.",
      "word_count": 16
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Not in the death march.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "After the liberation.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Death march, you couldn't do anything.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "You ate all what's in the grass.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "You ate grass, but it didn't belong.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "People got diarrhea.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "They made-- excuse me-- and-- wherever they were sitting, they were making from the grass, eating in the street to survive.",
      "word_count": 21
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "There was no water.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "There was no sanitary, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't wash in the march.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "How could you do anything in the march?",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "So when you got out of that hole and there was nobody there, and you saw this woman--",
      "word_count": 18
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "We start marching ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "You were just walking yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "We went on a train.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "We just went on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "We wound up in Leipzig.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Before the camp we left, we wound up there.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And we came to the American side, so they crossed us a bridge.",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "The Americans took us on their [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "We didn't feel anything.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "We fe-- felt numb.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "We felt so numb.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "They crossed us the bridge.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "They led us.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "We had to go down all the way, and they picked us up on the other side, something.",
      "word_count": 18
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "But the bridges was exploded.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 8,
      "text": "They were-- you couldn't cross a bridge there.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 9,
      "text": "So we wound up in Leipzig, in a school.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "The American said, you're free.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "What does it mean, free?",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't.",
      "word_count": 2
    }
  ],
