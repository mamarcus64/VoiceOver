{
  "stem": "2097.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "And-- [PAUSES FOR 4 SECONDS] --because she had such a hard time, that she didn't know what to do, when vacation-- and on the days when I was a 1/2 a day, eventually, off-- she put me to learn with a tailor, to do ladies' garments-- I mean not a tailor-- ladies, custom-made clothes.",
      "word_count": 54
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "So I had no more vacation, and no more free time.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Whenever I had a little time, I had to go there.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The lady liked me a lot, and she taught me.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I learned how to make, by measurements, beautiful dresses-- while I wasn't at school.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "At that time, I was 13 years old, in 1942-- when after my father-- so I was just very busy, all the time.",
      "word_count": 23
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "He-- my little brother went to the-- he-- Jewish-- Jewish kindergarten, with the-- for the children, where they learned how to do-- read [NON-ENGLISH].",
      "word_count": 24
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And he was all right.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "He was going by himself.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "It was in the same school yard where I went to school.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And in 19-- we lived that way about two years.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "1944, in the-- in about January, we had to put the-- the yellow star.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Brother.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "We had no radio.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I don't know here who had a radio--",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "--at that time.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We had no telephone, no radio.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Seldom we communicated, and maybe--",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the post office--",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "--work.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "We communicate.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "We wrote each other letters.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "And this-- now and then, we went for a brief.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "But we didn't go, even, because it was-- Jew was not allowed to travel.",
      "word_count": 14
    }
  ],
