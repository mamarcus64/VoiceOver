  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "They made a floor.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "They made shelves.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "I took in a sewing machine.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "I put in a sewing machine.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And I went to New York, and I shopped.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "Men's, ladies, and children's.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "The children's wear I had in the small store.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "And men's and ladies, and luggage and jewelry, and whatnot.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "Everything, whatnot, I put in the second store.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I had-- I was 15 years in Vineland, New Jersey.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And after that, Ruthie got big, to go to college.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And she wanted to go to art college in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't want her to be alone in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "We sold the business.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "We sold it.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I made money.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Empty store.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And we came to New York.",
      "word_count": 6
    }
  ],
