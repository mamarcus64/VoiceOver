{
  "stem": "11274.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I was the first Jewish girl that was given by the teacher-- as I said, I was sort of the favorite for the lay teacher when I was in fourth grade.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "The first one-- the first, second, and third, I was where the nun was teaching.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But in the fourth grade, when I was-- she gave me the privilege to be the school sales lady for the books, books and, and pencils what children needed, and helping her bring the, the books home.",
      "word_count": 37
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And what was the main thing I wanted to tell you?",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I almost forgot.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And-- [PAUSES FOR 3 SECONDS] oh, yes, and she decided that Jewish children usually spoke Jewish at home.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And our older sister, Zosia, was living with us.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Gertrude was already the first one, that I said, the oldest one alive.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "The first child died, and the two boys.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "The oldest one emigrated to America in the same year that I was born.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The picture in the book shows me about eight or nine months old.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "This was the [INAUDIBLE] picture from her to the family.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And she lived, and she lived in New York City.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And uncle, my mom's brother, took-- sent the papers, the affidavits for her.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And she went to America when she was 17.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "She's 16 years old, and I was almost a year old.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So she went to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So Zosia was at home.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And Zosia decided when we came home from school, every time we spoke, the three of us together-- Zosia the oldest one-- Zosia was 14 years older and Gertrude 16 from me.",
      "word_count": 32
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And so when Danka and I came home from school, we were speaking Polish with her.",
      "word_count": 16
    }
  ],
