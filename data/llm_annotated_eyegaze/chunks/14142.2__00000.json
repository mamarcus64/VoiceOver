  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Toilet.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I was wearing all the time a handkerchief, because the yellow-- the-- the yellow [NON-ENGLISH] what we were wearing.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Star of David.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The star, it was a round [? patch ?].",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I was wearing in the back.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my handkerchief always covered-- the point covered the yellow.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid, because it was times when they-- they could shoot when they saw from far a yellow.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "They shoot right away.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They killed people.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So I was covering.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Maybe they won't recognize me.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "You know, I tried.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So I took my handkerchief, I covered my nose and everything, and I cleaned.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I cleaned.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Then they locked me up when I cleaned the toilet.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They locked me up.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "It went a few hours, and they noticed in there, in the office where I was working, that I'm not there.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "So they started to look for me.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And they came to the police station.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And they looked for me, and they started to demand.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Did she do your-- her work?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "Why do you keep her?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "This and this.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "So then they let me out.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "The people that came looking for you, they were part of the Judenrat?",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "They released me.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "There's no answer for this [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Low.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Very, very low.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Very depressed.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Very-- [PAUSES FOR 3 SECONDS] summertime, imagine to go into-- it's not the toilets like today.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "But they were-- [PAUSES FOR 3 SECONDS] just impossible.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 5 SECONDS] [SIGHS] And then every-- every day, being in this-- in this office, working there.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So every day, we had to give some [PAUSES FOR 3 SECONDS] people to work.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Like 20 people, 30 people, to give a list.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] They demanded.",
      "word_count": 6
    }
