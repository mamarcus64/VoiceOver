    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "So he went to this sergeant over there.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "He told him, I have a good Jew there, hardworking Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "Maybe you can use him.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So he came out and said, from today on, you're going to work here.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "So I said, good.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Give me a paper.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Because they're catching in the streets.",
      "word_count": 6
    }
  ],
