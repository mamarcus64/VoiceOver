{
  "stem": "10162.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother had two cousins, girls, who were about the same ages she was.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And they were also living in Debrecen.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Then they also got married.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So her two cousins were her best friends.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And their husbands were best friends with my father.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And there were also always some friends coming in from-- you know, from other families.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "But this-- the three girls were very close.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And actually, my mother cousin's son, who was also an only child and also about the same age as I am, was my best friend.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "We were brought up together.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And my father had a sister, an older sister, who lived in Debrecen who we were friendly like family.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "But she was older than my mother and not quite-- it wasn't-- it wasn't real friendship, just family.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I only had one grandmother living in Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Because my grandfather, who I remember-- he must have been maybe-- I must have been maybe seven when he died.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I remember him.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So my grandmother lived in Budapest.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And we went very often back and forth.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Your mother's mother?",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "My mother's mother, right.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "My father's parents died when I was maybe a year old or earlier.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So I don't remember them.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Well, I just-- I-- my mother went fairly regularly because she had a younger brother in France.",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And she would go visit him.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And she went once or twice.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I know they went to Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And then she used to go to-- to Italy on a tour to Abbazia, it was called.",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Now I think it's Opatija.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "It's part of whatever that is.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "It's not Yugoslavia anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "I-- I don't know if it's Serbia or Croatia.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And the only time I went with my mother was to Italy, to this Abbazia once.",
      "word_count": 16
    }
  ],
