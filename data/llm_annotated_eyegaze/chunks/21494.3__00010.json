{
  "stem": "21494.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The date-- I-- I think it was the 9th of-- 9th of February, '44.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "'44-- February '44 is for sure.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "But the 9th, or the 11th, I don't remember.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, when I was-- when-- when they come, already-- Russian, I was liberated.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "That I know already then.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know the track, no.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know the time.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know-- they didn't know either, the goyim.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I don't think that they know.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "The day of liberation, we-- from this goy, what he told me, the Ukrainian--",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "--that he cannot-- Homa.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "They started, you know-- he had under the-- a-- a teacher from Radum-- hiding.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "His home.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "He had a-- a-- a Jewish child on the top.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "His wife died on typhus, because the lice-- not me.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "I-- when I was, she was dead already.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And he was hiding-- was afraid, because his brother, and his uncle, and his-- his neighbors was all Bandera.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "So he was afraid-- afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Once I was there, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And they came at night.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "They beat up so his daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "They thought that this is me, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "If-- then the-- the brother, the-- his brother told him-- so, this is-- he say, what you-- you are crazy?",
      "word_count": 20
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "He recognized her.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "They called him.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "He say, no.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "This is my niece.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "Leave her alone.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "So they were looking for you.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He told.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "He told that a Jewish-- he told.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "But then they called her, he should recognize.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "He said, my God.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "This is my-- my-- my niece!",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And then he told, you cannot come anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "But I'll speak, you know, I'll speak with my friends.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And then the-- they'll already start, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "And I came to this [NON-ENGLISH].",
      "word_count": 6
    }
  ],
