{
  "stem": "15900.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I said, look, I'm gonna to answer you.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to go back, and I'm going to give my boss two weeks-- Notice.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Notice.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I'm not going to leave like this.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I'm gonna tell them if it takes more till he breaks in somebody on my place, then I'm leaving.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The people already told my boss I went in to [INAUDIBLE] studio.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And when I come back in the morning from vacation, 8 o'clock I open.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Before 8:00 o'clock the people start. 8 o'clock I'm preparing the work for them.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "He's already in the studio, the boss.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He never comes. 10 o'clock here's there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "He calls me up on the phone, Sol, come into my office.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I hear you went up to [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So what you do?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I said, I ask you a question.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I ask you $10 a raise, you said you cannot afford it.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I lied to [INAUDIBLE], and I told him, I doubled the salary what you give to me, and he agreed.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "So if you were in my-- Shoes, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "--position what you do?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "You leave?",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Sure, I take the job.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I said, I took it.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "He almost passed out.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You leave me in this situation before Christmas?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You know, after Labor Day we start to work hard to finish the schools, the yearbooks, and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "You leave me?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "You cut my hands?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I said, look, just a minute.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "You didn't treat me right.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I worked for you 30 years, day and night.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "So it's like mine. 30 years this was already?",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I worked for him for 30 years, the boss, till I decided to quit.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Because of the other studio.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I said, well, you didn't treat me right.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I was married and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I struggled.",
      "word_count": 2
    }
  ],
