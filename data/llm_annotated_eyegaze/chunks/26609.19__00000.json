{
  "stem": "26609.19",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "She ran with that paper back.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I don't know even if that woman she lived with-- they looked after her-- if they could read him that piece of paper.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "She could read Wanda [?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Grobeminske, ?] my name.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And she said, look, mom is alive.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Mom is alive.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They said, no, it's not your mother.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Who is it?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "A piece of paper.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "No, my mom is alive.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It's mom, mommy's name.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "It's here.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "You read it.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "He came home.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He worked with the police.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "He said to him-- maybe he could read Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "That's my wife.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "She's under-- it's an amazing story-- under different name.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "She doesn't want me at all.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "She want only you.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "That was not your daddy.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "She thought it's her father.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "She has another husband, maybe.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Because she's not looking for me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "She looks only for you.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "In the paper, I wrote [NON-ENGLISH SPEECH].",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "So it's means he went out and asked people, what is that [NON-ENGLISH SPEECH]?",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "What means [NON-ENGLISH SPEECH]?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "They told him.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So he came and said, no.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "If she is like that, she doesn't want me.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I am not her husband.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "She doesn't want me.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She wants only you.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And we don't want her.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "You not-- you will not see your mother.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "You will be with me.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I don't want her, because she has another husband.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He had two friends.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "They were in the Partisans, two big blokes, tall ones.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I put their address.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "Please, if you live, if you are somewhere there, let me know, please.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I had night duty in the ambulance there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I wasn't paid there too, only with food.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "At night duty, for a minute, I went in and sat down.",
      "word_count": 12
    }
  ],
