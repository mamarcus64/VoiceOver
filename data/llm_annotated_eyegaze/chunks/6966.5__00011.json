{
  "stem": "6966.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 22.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I woke up one night, and I had my foot underneath his arm.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't feel the leg anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I said, Yop-- his name was Yop Tabum.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And his son was [?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Yopi ?] Tabum.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "I said, Yop, let go of my leg.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I can't feel my leg.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "He says, stay where you are.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And I was laying upside down like that.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So I said, let my leg go.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You get off of my leg.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So my friend, Barron Dinstof, he says, let Leon's leg go, or I'll give you one.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So he let go.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And I took my boots off, and I couldn't get them on again.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "My foot swelled up all of a sudden.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I had elephant feet-- rotten elephant feet-- rotten feet from the death march.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And he got up, this fellow.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He said, you people make a lot of noise, a lot of trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you what I'll do.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I'm going to jump out of the train.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I'll be home before you people get home.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And he did.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "He walked over us-- over the men-- jumped out of the train, and I never saw him again.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And I never saw his son neither.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "They're all gone.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "All my pals were gone.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, this journey took five days.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "The fifth evening, in between that journey, one night they called out-- one dark night they called out, how many men?",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And somebody said 125 were left in our-- and they threw loaves of bread.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And there was a fighting to get a piece of bread.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I was weak.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I was-- I was half finished.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Because I kept on telling my friend, Barron, when you get to Holland, go to Rotterdam.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Go to that-- that address.",
      "word_count": 5
    }
  ],
