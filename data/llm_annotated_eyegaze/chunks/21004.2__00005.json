{
  "stem": "21004.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I'm not going to say it 'til they'll bring the stuff back.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They don't have to say who it is.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Throw it in.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Put it back.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I don't care what you do.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Then, when they went back from the church, going home, they all coming in on our ground, the front-- the front lawn, coming in, and oh, we see [INAUDIBLE].",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "A couple of hundred people, they all come in.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They all call-- you know.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We came out.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "My mother came out.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "She say, we didn't know.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You didn't even tell us what's happened, what's happened to you.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "But the priest told us he's not going to say the [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So they say, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "You'll get it back.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We'll talk to our children.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And our children, whatever who did it, we don't want to tell nobody.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Forget about it, you know, not to put them in jail for that or whatever they did.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They have to bring it back.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Monday morning, my mother yet didn't believe so much.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So he-- she said to my older brother, David, she said, David, let's go.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We hire the same man what used to go with my mother sometime to our rabbi to [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We had a rabbi special, you know, you know, talk a little bit over her problems sometime, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "My sister didn't feel good.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "She had bad eyes.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And my brother was sick.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "He had arthritis.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "He fell in once to a well, and this was in the winter.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "They went for water with my brother and he fell in.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "It was so heavy, and my brother, my other brother, the younger one, left and he-- it pulled him in in the well, deep in the well.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "So he was there.",
      "word_count": 4
    }
  ],
