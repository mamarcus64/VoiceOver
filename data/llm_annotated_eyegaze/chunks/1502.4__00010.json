  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "So we thought it could be a set up, or it's unimportant.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "But he insisted he wants to go.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "He said maybe there's some certificates, maybe came in.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "Maybe we'll be able to get out of here or something.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "He insisted, and he went.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "At that meeting, which was completely unimportant to us at the time, a man appeared at that meeting.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Neikirk ?].",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "He was a Belgian Jew who had a Belgian name, and he was a Zionist.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He had fake papers as a non-Jew, very courageous man.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I never met him, but my brother did.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "He was a courier.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He came from Switzerland.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "He braved the Gestapo, the borders, and the checks, and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "They didn't recognize him.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And he came up with the news that there are exchange certificates being prepared.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "That there is a number of Germans in Palestine, and these civilian.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And these Germans were interned by the British as enemy subjects.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And the International Red Cross wants to exchange these few thousand Germans from Palestine for British subjects in-- that are stuck in Europe and that were interned by the Germans.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So the Jewish agency-- of course, there was no Israel at that time, there was, you know, [? is ?] no government.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish agency was the Jewish, was the leadership.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish agency insisted [PAUSES FOR 3 SECONDS] so much with the British that Jews, Palestinian Jews, that were stuck in Europe should be added to the exchange list for the Palestinian Germans.",
      "word_count": 33
    }
  ],
