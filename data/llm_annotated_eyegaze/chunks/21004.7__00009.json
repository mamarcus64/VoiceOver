{
  "stem": "21004.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Why should we be involved, it's so bad?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "We want to stay alive too.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Why don't you go someplace else?",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "I say by the first day, I know where I'm going.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "I'm not going to stay here, Marinya.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "I want the best for you and for Stefan.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And they had a daughter and the grandma was there.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I say I don't want you to be doing that you're going to be harmed.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I want you to-- I wanted to tell you what I need.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You have to go to the city.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You have to buy me everything, whatever I need.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I need equipment.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I need a lot of-- and I talk to her husband, to Stefan, I need to make me a-- a special-- a special thing, a board with a handle, because I cannot do this in the wood, that I can make a bunker.",
      "word_count": 43
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And I figured out how the bunker will look.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Just when I go in the bunker, I'll have a little tree, and this will close in.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I'll have a stepladder going into the bunker.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And I need gasoline.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I need candles, and I need parts, and I need pans to cook, and whatever everything.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I forgot-- only one thing I forgot is medication.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I even had bandages but no medication, no nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Little bandages.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "I even figured they were going to get burned or whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So she went to the city in the daytime, because he was a little sick.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He had problem with the heart.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I think scared with us.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So she went to the city.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "She brought me everything-- needles for sewing, cotton, complete everything, whatever, scissors-- to build a bunker, all kind of equipment-- a saw and knives, everything.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So she went, and she brought me this.",
      "word_count": 8
    }
  ],
