{
  "stem": "9486.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "I'm going to tell-- there was a guy, what used to go and look in the houses.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "I-- I'm going to tell him you are a Jew.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "Even with food.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "If the mother gave me two potatoes, and you know, with food-- she used to take the potato from me, away, and to give the-- the pig, only I should have less.",
      "word_count": 32
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "She was not human.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "She was a bloodsucker.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "And the boy was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "He was very kind to me.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 20,
      "text": "He used to tell me don't-- don't take serious, Maria.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 21,
      "text": "I was six months there.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I was seven, eight years.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The boy, he-- she was older from me.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "She was 11 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "He-- he was 14 or 15.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] The father was not too much in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "He was always working.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] When she get-- took me and told me I have to leave, she scared for-- she gave me a bread.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And she gave me cheese.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And she gave me clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And she gave me a blanket.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And the father took me, covered me under that-- that tractor.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And she took me in a-- in a place where I can hide myself.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And he said, I going find a lots of Jewish people there.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "It was-- That was in Tyczyn.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was lots of trees.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They had lots of trees.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "All around, they had water.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And the trees, lots.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And we were hide-- hiding there.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And I was-- I find a gentlemen with-- an older man.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And he had two kids.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And they were not his kids, even.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And he took me in, in a place where we was 12 people, underground, under a tree.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] And we went out.",
      "word_count": 8
    }
  ],
