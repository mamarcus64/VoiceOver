{
  "stem": "21004.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "So I stayed there and I was looking around for a job, but I couldn't get it.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "But then I came back home and I went to Krakow, Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "We-- I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "I had a cousin there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "He had a restaurant.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "This was 19-- it's starting 1933, going, you know, looking for a job.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And then I came 1935, the end of '34, I came to Krakow and I stayed by my cousin.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And he had another room where to sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And also, I had already my sister was already in Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She was working for a wholesale.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They were selling materials for clothes for ladies, special for ladies clothes.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "So she worked there in the office.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My sister Pepka, the second-- the second sister.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "She was there, so then I came there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I was looking for a job.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And after a couple of months, I got a job and I was working for a big firm.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "The firm was [NON-ENGLISH] Export-Import.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "We were just getting coffee, tea, all kind of dry foods and chocolate import from Argentina, like all kind of coffees, [NON-ENGLISH] Santos, Rio, all kind of coffees, and then sending out by mail, by train, all over Poland, sending out.",
      "word_count": 41
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "There were 12 people in that place.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Everybody has his station where to take telephone calls and all kind-- so I was like a salesman.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how to explain it.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "But export-import we had.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "[NON-ENGLISH] and [NON-ENGLISH] was the street from the place in Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My sister Pepka, no, she had her own apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I used to stay with my cousin, 'til my mother came there.",
      "word_count": 13
    }
  ],
