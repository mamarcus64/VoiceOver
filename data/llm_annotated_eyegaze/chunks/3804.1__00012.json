  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "That's why we have so many in Poland because they're being kind of traditional.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And the atmosphere was you have to listen to your rabbi.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "You don't leave your work.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "You don't leave the bread you have.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "You have to try it again.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And with God help, everything will be OK.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "Looks like it was not OK.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "There-- There's no one who was not close to the rabbi.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "You are talking about a small community that everything goes around the synagogue, around the rabbi, and the people knew each other.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "There wasn't such a thing that you didn't know the one brings the candy, the one with the mail.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "If you see, how do you call, the you've seen it.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Tevye and the seven daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "That's-- there's no way you can't-- You know everybody.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "You know who's going to marry.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "You know the girl.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "You know this.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "It was a very familiar with each other.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And also, we knew our enemies.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "They knew whom to talk, whom to give the money to stay alive, to get permits and all this.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "It was a very close, small community.",
      "word_count": 7
    }
  ],
