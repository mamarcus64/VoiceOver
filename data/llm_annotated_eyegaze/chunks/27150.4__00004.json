{
  "stem": "27150.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And he lent me 3,300 rubles.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And I went to the station.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And I went to meet some friends who still stayed there.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And they told me that Romek just boarded the bus back to Suprasl.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "So I boarded the next bus after him.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "Because at that time, at night it already was bad.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "To change the money, you see.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And in Bialystok you can get something.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Because a lot of smugglers were going back to Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So they were buying the Polish money for Russian money.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I changed some to Russian money.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I went on the next bus, and we met a friend there.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And said, look there's no business staying here.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "They're forming kibbutzes, in Vilna, which was given away by the Russians to the Lithuanians.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] I come back, and Romek sits as the King, served with dinner.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He said, I'm staying here.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I told him, look.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Look-- look, you're not staying here.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Everybody you see goes to Vilna.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "You see, not everybody, but you see our friend who was active with the harlots.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "You see, where I was running the books.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And we have to go.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "So Romek and I, we went to town to buy tickets, railway tickets to Vilna.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And I stood up in the queue.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And-- and every so and so minutes, they let in-- let in three people.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And it looked like the queue will never end.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "It will take weeks.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And somehow there was a fight.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "Romek went to have a look.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "How, he said, you're standing in the queue.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "And you keep the place for me.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "And he went to the door of the interest office to see how long it will take me to get the bloody tickets.",
      "word_count": 23
    }
  ],
