  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "So there was a house which was owned by the Jewish community before the war.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "A few hundred people who came back from the-- those-- from this region, settled in this building.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And one day, somebody-- they found a Christian boy killed, a young kid.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And somebody spread the rumor that the Jews killed him because they-- they need blood for matzoh.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "The mob stormed this building.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "This was a year after the war-- after the war ended.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They stormed this building.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "They pulled out 72 people and killed them with rocks, with picks, with knives.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "They killed 72 people.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "This was 50 years ago.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "In Kiecle.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "So this was the attitude.",
      "word_count": 5
    }
  ],
