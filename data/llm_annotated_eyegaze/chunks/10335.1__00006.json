  "sentences_input": [
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 9,
      "text": "And a friend of mine, told him to go on.",
      "word_count": 10
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 10,
      "text": "Go over there.",
      "word_count": 3
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 1,
      "text": "I will go over there.",
      "word_count": 5
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 2,
      "text": "No, nothing I can do.",
      "word_count": 5
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] See, when I wouldn't go to him, they'd be gone by a long time away.",
      "word_count": 19
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 4,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "Ah, a train for the-- for us, a person plane.",
      "word_count": 10
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "Like all the time, the planes.",
      "word_count": 6
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 2,
      "text": "The train-- the trains.",
      "word_count": 4
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 1,
      "text": "After there, we go someplace else.",
      "word_count": 6
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 2,
      "text": "They give us the cattle planes.",
      "word_count": 6
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "From Plaszow to Gross Rosen, I thinks that we go two, two days.",
      "word_count": 13
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 1,
      "text": "I'm not sure.",
      "word_count": 3
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 2,
      "text": "We was in Gross Rosen, we stay all of overnight.",
      "word_count": 10
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "Gross Rosen?",
      "word_count": 2
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 1,
      "text": "Ah.",
      "word_count": 1
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 2,
      "text": "I don't want to tell nothing about what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 3,
      "text": "It was worse over there.",
      "word_count": 5
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "It was bad, very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 0,
      "text": "We sleep on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 1,
      "text": "Overnight, and on the morning, he comes and tell them, come on!",
      "word_count": 12
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 2,
      "text": "Get the people.",
      "word_count": 3
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 3,
      "text": "Come on, come on, come, on.",
      "word_count": 6
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 4,
      "text": "No hold them up.",
      "word_count": 4
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 5,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 6,
      "text": "He took a man and a woman.",
      "word_count": 7
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 7,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 8,
      "text": "We got about, about 3,000 people.",
      "word_count": 6
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 9,
      "text": "He saved 3,000 people, he saved.",
      "word_count": 6
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 1,
      "text": "I talked to him, too.",
      "word_count": 5
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 0,
      "text": "In Brunnlitz.",
      "word_count": 2
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 1,
      "text": "We talked to him.",
      "word_count": 4
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 0,
      "text": "But I mean in Gross Rosen.",
      "word_count": 6
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 1,
      "text": "Not with him, no.",
      "word_count": 4
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 2,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 1,
      "text": "Saw, saw him in, in, in Czechoslovakia.",
      "word_count": 7
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 2,
      "text": "Over there, and I talked to him.",
      "word_count": 7
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 0,
      "text": "No, Gross Rosen, we just sleeping on the floor.",
      "word_count": 9
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] because come middle of the night, or at in the morning, I tell them, come on.",
      "word_count": 17
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 2,
      "text": "Get the people out.",
      "word_count": 4
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 3,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 4,
      "text": "Come the other way, take out the people.",
      "word_count": 8
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 5,
      "text": "He sits over there night time, night.",
      "word_count": 7
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 0,
      "text": "Was bad about Gross Rosen?",
      "word_count": 5
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 1,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 0,
      "text": "You see what's going on.",
      "word_count": 5
    },
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 1,
      "text": "They kill people in the oven, put on the bakery.",
      "word_count": 10
    }
