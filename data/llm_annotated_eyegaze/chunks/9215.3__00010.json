  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I told you, I-- I saw the bones.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I hear them.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We hear them.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "They used to come.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "They used to come schiessen and this, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "But we used-- we used to hiding.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Ah!",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "Only three of us.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "When we came home?",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I knew what nobody was there.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "When I escaped, I knew what nobody was there.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "They verbrennt everything to [? broken. ?] But my grandfather's house-- he was a contractor, I told you.",
      "word_count": 18
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "He built himself a beautiful house, a brick house.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And a Polish family was there when I came home.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "When I came, and I went, right away, to my grandfather's, I saw the house is-- is there.",
      "word_count": 18
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "And I came.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "And there was a Polish family.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "And there was-- I right away, I went to the attic, because I hide-- my sister and I-- we hide a-- a lot of stuff in the attic, there, in my grandfather's house.",
      "word_count": 33
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Next to my mother's house.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The same street where the ghetto was.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And she said to me, oh, now, I know it's your house, because you go right away in the attic looking for things.",
      "word_count": 23
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I said, I hide in there, but you took it out.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "She said, no, I didn't took it.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I said, how do you know, when I went to the attic and to looking for stuff?",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "How do you know I was looking for stuff?",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "How do you know?",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "I hide a lot of stuff there, coats and this and that.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "I said, you took it out.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "She said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "I said, how do you know there was stuff?",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] You know what I mean?",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 9,
      "text": "She went.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 10,
      "text": "Right away, I said, go.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 11,
      "text": "She left, right away.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 12,
      "text": "But this house was empty, nothing.",
      "word_count": 6
    }
  ],
