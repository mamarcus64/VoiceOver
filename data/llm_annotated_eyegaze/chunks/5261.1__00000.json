{
  "stem": "5261.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I can.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My name is Teofil Kosinski.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was born on the 1st of January, 1925, in Torun.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We were together, five children and my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Two brothers-- with me, together, three boys-- and two girls.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "My father was a rail-- railway worker, and my mother worked part [? jobs ?] from time to time because she has to feed and to work for the whole family.",
      "word_count": 31
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Until-- until the begin of the war, I was going to the ordinary school.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I finished my second class of school also in Torun.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I was rather good pupil.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I had very good notes.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And especially in singing, I was very good.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "My teacher said me, oh, you have a very good voice.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "You must improve it.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Maybe later you will be some singer.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "Then my family-- especially my father-- he told-- he said to my mother, we must do something with him.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "He must finish high college.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "He must be a mensch, as we call, somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "He must be somebody.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "All of us are so simple.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "My mother finished only four classes school-- father, also.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And the wish was of my parents that maybe I-- I will be a higher-- somebody-- that I will-- will be somebody.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So I wanted to go to the gymnasium-- or gymnasium.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I don't know-- English-- gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I passed the examination for this gymnasium.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "My mother ordered it by tailor a new uniform for this gymnasium, but I never used this-- I never wore this uniform-- maybe only for a picture once.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And I never begin-- began to go to school because on the 1st September, 1939 began the war.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I never forget this day.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It was rather cool day.",
      "word_count": 5
    }
  ],
