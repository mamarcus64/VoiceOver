  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "The skin, they were processing.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I mean, there were various things.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, definitely.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Not always without clothing.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Without clothing, it was only special occasions.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Normally, we were able to keep a few little rags on us.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Of course, the shoes already were worn.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "A lot of them had paper put around their feet.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "See, because I was working in such a fortunate place, I had shoes and a little more clothes.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And when we used to come back, many times I came in three, four dresses.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And we brought lipsticks to put the red stripe on them and left them for the girls who didn't have clothes.",
      "word_count": 21
    }
  ],
