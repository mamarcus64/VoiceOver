  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And it was a cable from my sister in Belgium, that she's looking for Joseph Greenblatt.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "[SOBBING] He was in a Polish underground, and I hope that he survived.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "But they didn't have anything of--",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "With that name.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I never registered.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I make-- and they brought that telegram.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "In short, not among the living.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I make a-- [INAUDIBLE] said, why should we look for you?",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Who will know that you're Jan Bednarczyk?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Then they cabled my sister to Belgium that I'm alive.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And then, of course, when I escaped Poland, I escaped Poland in a uniform with a military Jeep, went with a false-- this order of traveling.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And I'm going on military business to East Berlin with my secretary, [NON-ENGLISH].",
      "word_count": 13
    }
  ],
