{
  "stem": "17299.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "They told him that he had committed sabotage by ripping up the shirt.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "Of course, the shirt belongs to the Third Reich.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And he got another beating.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "And then he got thrown out of a-- out of the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So the next day, we could not take him back to the-- to the airport, so he had to do work in the barracks.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And it took him few days until he could eat and speak.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And he had even a few teeth knocked out.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Were there other incidents of mistreatment?",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I saw a lot of beatings, but the-- most of the-- the worst things were going on after I had left Kaiserwald.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Maybe four weeks later, after I came in, I went on a volunteer basis to Dondagen.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "But",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "First, we were marched in the barrack and stripped.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Then we were getting rags for clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "All our leather shoes were taken away.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We got wooden clogs with some cloth or leather on top for shoes.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And then we got some other rags for a second set of underwear and a blanket.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No more, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And, uh-- anyone who would have seen us would have known why we were prisoners, because everything was put in pieces together.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I was the first group of the 500 to arrive [INAUDIBLE] shipped by train to Dondagen.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "First 2,00 in boxcars, 52 a boxcar with two guards in it. 25 on each side, and the guards with a rifle were sitting in the middle.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Maybe three or four hours to Talsi.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "From Talsi, we were put on a small [INAUDIBLE] road.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We were put 50 in a boxcar without guards and told to sit down.",
      "word_count": 14
    }
  ],
