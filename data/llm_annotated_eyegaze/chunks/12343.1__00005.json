      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Oh, hold on.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Czechoslovakia.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Before the war.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "I was in [INAUDIBLE], working over there.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "Then my uncle, other uncle, said to me, go home.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "My mother will-- then I left back home.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "They started wars with Poland, others.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
