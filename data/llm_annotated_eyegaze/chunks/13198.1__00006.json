{
  "stem": "13198.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We were all very well-educated and very interested in the arts, and painting, and music, and that angle, but not a bit in the politics or-- [PAUSES FOR 3 SECONDS] but my poor husband-- but he took it all.",
      "word_count": 39
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "He must have had a shock when he first came to our home.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "That freedom probably did attract him.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "He came from this rather stiff, conventional home.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And he was the only boy.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He had two elder sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, I had to behave myself.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I think that was really the-- the first thing I had to learn.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't be sort of-- I had to learn to be married and to be-- I remember sort of have to be the lady of the house, and all that business.",
      "word_count": 31
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "[COUGHING] But thank goodness I'd been to that domestic college, so I knew what was expected of a married woman, who was head of the household.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I had to know what all the maids did, because you had to do it yourself before you-- had anybody else to do it.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Charring, that sort of thing.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I mean, they made you scrub the floors and do everything that your charwoman would do, so you knew what you were talking about when you said she hadn't done it properly, or she had done it properly.",
      "word_count": 38
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, I liked being married.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I was really cut out to be married.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I didn't mind that my husband was the head of the household and bossed me.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I thought it was just as it should be.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I didn't-- I mean, I was at the time when women were sort of-- we're not we're on unequal footing with the man.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But I never felt that.",
      "word_count": 5
    }
  ],
