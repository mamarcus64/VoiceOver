{
  "stem": "11184.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.4,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 16,
      "text": "But she has been-- had been there already for two years.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 17,
      "text": "And everybody cries, where are we?",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 18,
      "text": "What-- she said, don't ask questions.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 19,
      "text": "I said-- she said to us, you are the lucky ones.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 20,
      "text": "The others, you see that-- you see that smoke?",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 21,
      "text": "That's what happened to the others.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 22,
      "text": "You know, you talk about it-- it was at night and it was so dark.",
      "word_count": 15
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 23,
      "text": "When you got to the barracks, were there any lights there at all?",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see any lights.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "I don't-- I don't remember how long we stayed in this one and when-- when they brought us out.",
      "word_count": 19
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "This, I don't remember it through the barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "And so we-- we--",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to the right.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "I mean, it was in such a manner.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "I still see the guy, the Nazi.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "You know, I don't know who he was.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "But he just pushed me down there and pushed my mother down there, you know, in such a hurry, in such a-- they were so nervous themselves.",
      "word_count": 27
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "And so-- and then we were at the barracks, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "And we learned.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "And here you got the little spoon.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "And you got the little dish to hold onto.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "And-- and here I meet my two friends.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "They were in another barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And I said to them like, why don't you join me?",
      "word_count": 11
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "I said, you come move with so we'll be together-- so naive, I mean.",
      "word_count": 14
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] I still think about that, you know-- when I told them.",
      "word_count": 12
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "And we talk about it.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "One is still alive, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "She lives in Sweden.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "And-- [LAUGHS] --come and join us.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 5,
      "text": "We'll be together.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 6,
      "text": "Because we grew up together in Poland, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 7,
      "text": "We're close.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 8,
      "text": "And then-- and then that was-- Birkenau, actually.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 9,
      "text": "They took us to Birkenau.",
      "word_count": 5
    }
  ],
