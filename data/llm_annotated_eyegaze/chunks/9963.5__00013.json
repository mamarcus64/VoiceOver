  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I remember still today, when I ate that bread, that I felt in the teeth, you know, that glass.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "But we were hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "We ate.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "And that bread killed so many people, because it cut the-- you know, the inside, you know, the [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "You know, cut-- the glass.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And people got diarrhea later, and dying in the thousands.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "When the day came, April the 15, early morning, when the first two Jeeps rolled in in the camp, nine soldiers came.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "And they came down and we were crawling to them, you know, and kissing their hand, because we could see already the liberation.",
      "word_count": 23
    }
  ],
