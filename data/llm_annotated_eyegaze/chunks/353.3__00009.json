{
  "stem": "353.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So he send me back to the shop, and he told me, you go to the shop, and I'll be there pretty soon.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Instead of shop, I went to Schindler.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know Schindler.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "He didn't know me.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I went to Schindler, and I said, Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Schindler-- she was by the door.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I said, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Schindler, I'm in trouble now.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "She said, what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "So I told her what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "So she called him.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Oskar, somebody is here to see you.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "He came up to the door and asked me what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "So I told him what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "I did this and this.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "Oh, he said, oh yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "We didn't have no light for a few minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "He said, you go to your shop, and I will come there.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I went to my shop, but knowing that something going to happen with me, not knowing what going to happen to me.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I know that Schindler know about it.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Then I know that nothing wrong going to happen to me-- maybe beating, maybe beating.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Schindler came to the shop, so waiting until the SS man came.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "The SS man came.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Schindler said to him, I need an electrician.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So he say, all right.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I give you electrician.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He looked through.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "There was a group of electrician, 10 people.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He looked through the whole group.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Take this guy.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Then he said, no, I want this guy, and he pointed on me.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I want him.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Oh, he's not an electrician.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He doesn't know what the hell he's doing.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "He said, doesn't matter.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I need-- I need this guy.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "You let me take him.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "He said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "Go ahead take him.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "Take him.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And since this time I didn't go to no work at all to the end of the war.",
      "word_count": 18
    }
  ],
