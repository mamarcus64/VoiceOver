  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 34,
      "text": "And when I went to look for the kid and I saw that it's not Aviva the same-- but I went to her.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 35,
      "text": "And then a couple months later, I don't remember the time exactly, a lady came in, a Jewish lady, to me.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 36,
      "text": "And I used to live in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 37,
      "text": "And I don't want to, because we'll drag it too long, certain details which came to my mind when I talk to you, which is not necessary in the history.",
      "word_count": 30
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 38,
      "text": "And I came to-- and a lady came into my house and told me-- after we were liberated.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 39,
      "text": "She is a Jewish lady.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 40,
      "text": "And she left her kid somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 41,
      "text": "And I looked in here.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 42,
      "text": "And she looked exactly like the kid what I went in the beginning to the lady what she-- the kid, she never got-- And I told her, this is not a make-up story.",
      "word_count": 33
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 43,
      "text": "This is my story from my life.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 44,
      "text": "I said, I know where the kid is.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 45,
      "text": "And I took the lady, the mother, and I went to the lady where she picked up the kid.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 46,
      "text": "Exactly like if God created the features from both of them and this is their kid.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 47,
      "text": "And I'll make shorter the story.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 48,
      "text": "We took out the kid and gave it to the mother.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 49,
      "text": "With help-- I mixed up shorter and longer the story, because I went too deep to tell every detail, to explain every detail.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 50,
      "text": "But it's connected.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, Aviva I find later.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Because Aviva-- at night when I find-- this came to my mind and you just asked me.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Because I already mixed up.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I know they said-- my Ger-- my son sitting there, because I mixed up already.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Because--",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "--this is my mind.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "My mind is not the same.",
      "word_count": 6
    }
  ],
