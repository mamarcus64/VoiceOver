  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And he asked a simple question. of we know a family from-- who is from the city Lodz?",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Then he comes to our wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I and my wife are from Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he asked a simple question, oh, we know maybe in Lodz the family Tenenbaum?",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I look on him.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And  I tell him, if I know the family, then you are Mr.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Zeide. ?] Then he asked me, how you know that?",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I tell him, I was with your sister-in-law, a good friend.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "She has a library, [INAUDIBLE] library.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And your wife, she was in vacation this and this year-- 1937.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- 1937, I was in the army.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "So right away, he comes home.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Here's the situation.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And tomorrow, he took this wife.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And they come.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "We were sitting together.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "He has-- they help us a lot out [? even. ?]",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes, please.",
      "word_count": 2
    }
  ],
