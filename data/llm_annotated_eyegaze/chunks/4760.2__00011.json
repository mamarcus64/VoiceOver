  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Then-- then we were arrested.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So they took us to the closest village where they had a commando post.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And then they started to interrogate us.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "My-- first came two, three guys interrogated-- were interrogated.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Then came my brother was the first one to be interrogated.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So when my brother was there and was asked questions, the first thing they asked him, are you a Jew?",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And they had him drop the pants.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "The first thing they looked was if he was circumcised.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And so my brother said, oh, in Morocco they all get circumcised.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "In-- in these countries, they all-- we all get circumcised.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "But we didn't let them know we understood German, because they have a-- had an interpreter there.",
      "word_count": 17
    }
  ],
