  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "What has happened in-- in recent years, and maybe even not so recent years, is that people who were fortunate to survive the war and are survivors by either being hidden or by having left the-- the countries involved in the war, and come to either Shanghai, or come to Australia, or come to the United States or Israel, cannot be categorized the same way as those such as myself, who have survived the war by witnessing what I have seen.",
      "word_count": 81
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And that is the one difference I would like to make.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I saw it.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And I can't even describe it that well.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "It is totally indescribable.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And that is the Holocaust, the word that Elie Weisel coined, because it-- it had to do with fire.",
      "word_count": 23
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And it has to do with the annihilation and genocide.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 8 SECONDS] Sorry, but I had to put that in.",
      "word_count": 12
    }
  ],
