{
  "stem": "19807.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "That was absolutely something which was not done.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Intermarriage was absolutely to-- to a minimum there.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Very, very few people intermarried.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And they intermarried, they were not shunned by the community.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "They were accepted, but it was very frowned upon.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I'd like to give you the picture of the contrast with the childhood, like I said, the-- the childhood of innocence that we can roam around all over the city.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I remember as children we'd go to the train station to watch the Orient Express pass through.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "You know, we were eight, nine years old.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Try to let my grandmother-- I mean, my grandchild to go now across the street at eight or nine.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Here we go from one side of the city, we walk all the way the side to the train station to watch the Conventional, to watch the Orient Express in its splendor pass through the city.",
      "word_count": 36
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was incredible.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And all of a sudden, you can't do any of this.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We would go all over, roam all over the hills, the beautiful hills in Plovdiv.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We can't go there.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "All of a sudden, I can't be a Boy Scout.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "All of a sudden, my father is out of work.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "All of a sudden, we begin to hear the Jews are being persecuted.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "The Jews are being sent to camps.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "The Jews-- the words-- the words of the Holocaust begin to filter through.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "It was the time of apprehension.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "It was the time of-- of the anticipation of some real, real bad things to happen.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And they did.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "They did.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "All of a sudden, we begin to hear the news that the Jews are going to be assembled.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "They're going to be sent.",
      "word_count": 5
    }
  ],
