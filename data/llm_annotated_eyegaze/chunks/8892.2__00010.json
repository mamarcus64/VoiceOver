{
  "stem": "8892.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And I don't want to take my panties off.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I do not want to take it off.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And I had my, you know, thing on-- what they call it-- the sanitary belt.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And he-- the gendarme, the Hungarian gendarme-- goes, take-- in Hungarian tells me roughly, take your pants off.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "And I says, I can't.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "He says, why.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "And I tell him, I'm sick.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And my mother hears my voice, and I'm already crying and I'm blushing, and I used to be very, very shy and easily blushed.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She somehow hears my voice, turns around as naked as she's standing there, and grabs me and hollers.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Can't you see she's an innocent child?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She's embarrassed to take it off.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And he puts his hand right between my leg, right between my leg to see if I hide jewelry or anything there.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I thought that minute I wanted the floor to open up, and I think I'll just disappear.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "As a 15-year-old girl, naked, seeing my mother naked.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they just-- you know, I don't know if they ever found on anybody anything, but this is what they did.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They were very rough.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "They were as rough as Germans, and that's why I hate them, actually hate them sometimes more than I hate the Germans.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So it was a very, very bad experience.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And from then on, my mother just clinging to me, holding my hand, because I was a child and felt I can't even take care of myself.",
      "word_count": 27
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And my sister-- I think at that point, my mother didn't notice, but she's halfway dressing up, and they let you put-- after a while, they checked you, stripped you, touched you, then they let you put back the clothing.",
      "word_count": 40
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So we put back the clothing, and that's how we go.",
      "word_count": 11
    }
  ],
