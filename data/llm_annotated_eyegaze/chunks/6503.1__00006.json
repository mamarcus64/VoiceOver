{
  "stem": "6503.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "I had my brother at the time living with his wife and her mother in Amsterdam, so I moved in with my family.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "'39.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "'38. '38.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I'm beginning from '39.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "When I got to Amsterdam, I lived with my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He took me up to the committee because we were not allowed to work.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The committee gave me a piece of paper to go to the police, and I had to sign that I never will work because there was too many unemployment.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We were not allowed to work.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And I had to come every week to the police to sign that I didn't work.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "The committee gave us money to live.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We got $6-- guilder and 25 cent, what barely makes [? it ?] go by.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "But everything was cheap, and we were four together, so we made a go of it.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Like I say, my boyfriend never survived.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "He was picked up and he never came back.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I was with his parents together.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Also, they were picked up, and they didn't come back.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What event can I tell you?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I went to a dance, and my husband was sitting there.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And my husband was talking that his parents will come from Vienna, and that he had a smuggler.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And my brother was sitting next to me with my sister-in-law, and we were very much interested in that, because I still had my mother there.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And we wanted to know who brought-- who will bring the parents to Amsterdam, and if we can meet my husband at the-- then so we can have the name of the man that will bring him, because we wanted to bring our mother.",
      "word_count": 44
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "So my husband said, yes, you can come to me, and he gave me the name and address.",
      "word_count": 18
    }
  ],
