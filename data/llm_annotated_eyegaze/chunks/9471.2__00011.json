{
  "stem": "9471.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And I didn't care, concentration camp or not.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "I was very, very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "We were there for, uh, I don't know how many months.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "Then they transferred us in other concentration camp, still in Italian-Yugoslav zone on the RAB, R-A-B.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And we were there till liberation.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Uh, the partisan took over, and then we were liberated from the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Then started our problem.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Where to go?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Some people went to fight with the partisan, and some people tried to escape to Italy or Switzerland.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So we tried for Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "But before we came there, we went only night with a little boat.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We went over the night till we reached Vis-- V-I-S-- where the-- uh-- um-- Allies were there, English, uh, from England.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we were there, I don't know, a couple days.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Then partisan wanted to take my husband to fight.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "All men, they had to go to fight.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And he says, I cannot go.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I cannot leave my-- my-- uh, we were not then married yet, but he said 'my wife.'",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And they took examination, and they told him, he says, oh, look at this man.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Put your hands like that.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They says, Jesus is coming.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Because his beard was, you know-- all of a sudden he was all white.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And he put the beard-- he looked really bad.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And he says, uh, you are, um-- [NON-ENGLISH] how would you say that?",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "You are, uh-- [PAUSES FOR 4 SECONDS] too-- too old-- too quick old, something like that.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And he says, you can go with your wife to Italy.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So then they took us to the ship.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We came to the body, Italy.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "That's how Italy, um-- the British were there.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "They gave us food there.",
      "word_count": 5
    }
  ],
