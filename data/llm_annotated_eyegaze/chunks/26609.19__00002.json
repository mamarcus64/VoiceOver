{
  "stem": "26609.19",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He gave me money.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And he said, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Go as long as you need.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "There was no other nurse.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Later, we had someone.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And go there.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Go [NON-ENGLISH SPEECH].",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "These two men took me.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "It was a long journey to [?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Cassel. ?] It's some way from there over the other side.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "I came in.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "They knew when the train arrives.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And they knew that I am there.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "He waited for his wife.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Who has-- they couldn't-- no telephones.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "They couldn't phone him that I am alone-- his wife who has another husband who came for her child, the wife who I want from him, from my husband, the child.",
      "word_count": 31
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "That what he thought.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "As I came in, it's like in a film.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "I nearly fell faint.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "Like, a stone wall, hundreds and hundreds-- like in a film, I didn't know what they want.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "Came across to me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And I was alone.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "These two men disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "They didn't want to tell the story, because they said it would have a battle, because they knew his wife.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And they saw that I am not his wife.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "These two men who came to me, they were his friends.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "That's why he sent them to me.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And they knew his wife who was killed.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "And they saw that I am entirely different person.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "I am not his wife.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "And he waited for his wife.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "And they thought straight away, maybe they tried-- if she looks like me, it's my daughter, not his.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "And he will not give her to me.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "Because he thinks-- maybe he was stupid, I don't know-- it's his child.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So quickly, he left me. he went over to him and said, she is not your wife.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Why do you want her?",
      "word_count": 5
    }
  ],
