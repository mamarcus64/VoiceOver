{
  "stem": "11641.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 131.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "She came.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "She want to see-- she says, you're all free.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And then the Russian soldiers came in after her.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And then we-- we were free.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That's the-- that's the question.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "What does it mean, you're free?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "You wanna go-- you go anywhere?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "What does it mean anywhere?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Home-- they were think, what are you gonna go home for?",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "You know-- you know, as in-- in my case, I-- I knew that I'm not-- that my family is not alive-- down deep.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I hoped that my brother's alive.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And I hoped that my son is alive.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Because I knew that she was-- she was going to be hidden by a Polish farmer.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So my friend and I-- this Abusz Reich and I-- we decided to stay another week.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And because one of the Czech family adopted us sort of.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "He says, we'll feed you.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Don't worry about it.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Don't go nowhere else.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "We'll feed you gradually.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "You shouldn't get sick.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My brother-in-law, who was-- was married already, he went earlier.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "He says, look.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I have to look whether Tosia is alive-- his wife.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So he and his friend went before us.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "We stood another week and said, we'll decide what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So he had a brother.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "He know that his parents are not alive, so he hoped his brother is alive.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I hoped that my brother is alive and Sally is alive.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "So eventually, we went by train to-- to Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "It took a long time, but eventually, we made it.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I came to Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "So nobody knew about my brother, but they told me that Sally is alive.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They says--",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "There was a committee at that time, a Jewish committee.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And there was somebody who came-- who was from Sally's town.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "So he told me.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He says, look.",
      "word_count": 3
    }
  ],
