{
  "stem": "365.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Primarily bread, potatoes, some margarine, and occasionally a vegetable.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "To the family, we all shared.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We all shared.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Every one that worked received those rations.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the hard rations?",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Hard rations consisted of more than that.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I also received some sugar.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I received some meat, like sausage, and occasionally even fish.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I brought it home.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We still lived as a family.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Brande.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was no camp before Brande.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Brande was the first camp.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this was only for a week before, when they picked me up from my home.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "When I was sick, I did not appear to work.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They picked me up.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They sent me-- that was a holding camp or jail, whatever you want to call it.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was just-- it was called [GERMAN] or holding camps for--",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You did not work.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "You were just sitting around, waiting till they will pick you up and send you to-- to a camp.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "There you only stayed for a few days at most, a holding place.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Unless you tried to escape or something.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "That's when you would get shot.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I went to Brande.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "In Brande, I was there from October '42 until the end of May '43.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "In Brande were selections every few weeks, three to four weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "There used to come a civilian, Nazi, which we nicknamed The Horse Trader.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He was trading human lives.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "He was picking up all the healthy ones and shipping them out to various forced labor camps.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Those that were not healthy or in physical condition, would send them to one of the extermination camps, which was mostly Auschwitz, to be gassed.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And the others, like I mentioned before, were killed right in Brande, that were extremely sick.",
      "word_count": 16
    }
  ],
