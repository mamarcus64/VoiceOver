{
  "stem": "19130.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They were very happy to have us.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We-- they were very happy to have us.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So our children are supposed to take-- we couldn't send the children in that school because they were only two, two white children.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "We sent the children in McCall School-- you know, the McCall School there for immigrants.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "But they have to take two buses, you know, there.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "But in a short time when I start to work, we, we, we moved to Wynnefield.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We rent a apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And we rent apartment for them.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING] [SOBBING] They want to be near us.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "They sold their house for $2,800.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And they-- we lived to-- in Wynnefield, they lived nearby.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "They were very old ladies.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And later, we moved in Northeast.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "We bought a house in Northeast.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "So they moved with us.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "They died already.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] Hardest question.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[CRYING] I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Things what I went through, I don't know how I survived.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] [PAUSES FOR 3 SECONDS] [SOBBING] After everything, the front-- it's miracle.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] All the time.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SOBBING] I have bad dreams.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "The first year-- I-- few years-- many years, I couldn't-- why?",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "For what?",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Children-- [PAUSES FOR 3 SECONDS] for what?",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Would [SOB] [CRYING] How I survived-- I-- it's a miracle.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I can't say I'm smart or what.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "It's just a miracle.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "It's probably got-- to want somebody to tell the story.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't tell.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "[SOBBING] I should start to talk.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I should start.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Only one time-- I was at my daughter's house.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And she said, Dad, try.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Maybe, maybe you'll get--",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So one time, you know, I, I, I told them a lot.",
      "word_count": 12
    }
  ],
