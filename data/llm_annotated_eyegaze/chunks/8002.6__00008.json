{
  "stem": "8002.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And they caught the children on the bayonets.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And they had a lot of dogs, about 12 dogs-- German Shepherds, Dobermans.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And they were feeding the dogs to the babies.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Feeding the babies to the dogs.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the babies to the dogs, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "We were downstairs.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And we were watching when they were taking with the bayonets the children they threw out from the second floor.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And downstairs, they were drinking.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They were holding liquor in one hand and the rifle in the other hand and catching the babies and feeding them to the dogs.",
      "word_count": 24
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In the barrack.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And we-- I started to work again for the German.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And I was with my mother and my three brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "One of my brothers, the oldest one, got sick.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "So they separate-- they put him in a different barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And they ask whoever wants to work to work for the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] So I volunteered.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And my mother went to work.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And we saw a lot of freight trains coming in with clothes.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "We had to take out the, the, the-- [INAUDIBLE] the soldiers' clothes, empty the packets to find if there was wallets or money or papers and separate out.",
      "word_count": 28
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And when a lot of clothes came, there was missing a-- an arm, a leg.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "Fingers we find in the clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "But that only went for about three months.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "And after the three months, they, they stopped.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "And me, me and my mother were separated again from my brothers.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "And we worked for the German.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "And we escaped again.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 16,
      "text": "We escaped again.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 17,
      "text": "And then we were going on a road back to Wiskys again.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 18,
      "text": "A Latvius woman started to scream, you dirty Jew, and picked up stones and started to throw stones.",
      "word_count": 18
    }
  ],
