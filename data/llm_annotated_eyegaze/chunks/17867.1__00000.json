{
  "stem": "17867.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 103.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It was Tama, T-A-M-A.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And Hachman, H-A-C-H-M-A-N.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Mlynow.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And it was Poland, I believe, at the time, May 1, 1937.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Rochel, and my father's name was Leib.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother was born in Riga, Latvia.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And as a very young bride of 16, my father brought her to Mlynow, where he was a little bit older and an officer in the Russian Army.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Madly in love, they sorry each other and that was, that was it.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And they got married, and she lived in Mlynow.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "He was a very skilled carpenter.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He had, my mother always said, hands of gold.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He could make very intricate wonderful things.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And he used to do apprentice work, have children come to him, and they would learn from him.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And this is how he made his living.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And he also built the house that we lived in and he made all the furniture that we had.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I am the youngest of six.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And do you want me to give you the name of--",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My brothers.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I'll put on my glasses, I've reached that age.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother's name was Shaya, then I had a sister.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You'll forgive me.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] It was Shaya, [SOBBING] and Malla, Fega, and Efraim, Mayer, and myself.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I believe my mother said she had every two years.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She had a child every two years.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We all lived in the same house.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we didn't have all these bedrooms that we have now.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And for some reason, the house was happy and warm and Shabbat came along and everybody knew what they had to do.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And being the baby, I was being taken care of by my oldest sister Malla.",
      "word_count": 15
    }
  ],
