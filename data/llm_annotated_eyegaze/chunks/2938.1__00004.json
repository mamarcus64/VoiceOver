{
  "stem": "2938.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Certain-- they used to prepare it.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "We used to feel that a wave, an anti-Semitic wave would come in time to time.",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, we used to feel it.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And we used to struggle.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "We used to fight back.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And it blow over.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Well, used to start off the light way, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "A little attack.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "We used-- used to go to a football game, you know, a soccer game.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "On the way from the soccer game, they used to throw stones at Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "They used to beat up a few Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And we were no chicken.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "We used to fight back, too.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "We used to-- we organized in group.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "That's we want to be prepared to fight back.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "And we used to beat them up, also.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Certainly we have to do.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Betar used to teach us a lot to be defensive, to fight back.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "In what way?",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "To be strong, united, and fight back.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "We used to go in groups.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Five, 10, 20, 30, to be strong and mighty.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Not to get beaten up.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Well, used to be a big fight.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "We fight it out, and after the fight, police came, straighten out everything, and life went back to normal in a few days.",
      "word_count": 23
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Police used to treat Jews fair.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "The police used to follow the order of the government, yeah.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "They didn't stick with the hoodlums.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Usually they were fair.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "They behaved.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I never have any trouble with the police, no, no.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Many times.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Many, many times.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Well, they started it with us.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Mostly going out from a theater, going home from a movie, or going, Saturday and Sunday, to a public park, a state park, on the way home, you know?",
      "word_count": 29
    }
  ],
