{
  "stem": "16922.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 376.3,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But I remember my uncle, I don't know if they want to kill him.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They were very disappointed at the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And they came to-- went to Poland, and they stay in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but they couldn't afford it.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this is a long story and a hard story.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 11 SECONDS] But I have to tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They came, [PAUSES FOR 8 SECONDS] we find out the Gestapo was going to be there in, in this Rabka.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "We were very sad, sad about it.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But we couldn't help it.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They took our children, my sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "They took to Tereska.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "Tereska was a place where they say-- where they-- where they had the headquarters, headquarters.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And all the children, the girls, they have to clean for them.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They sent from the Judenrat.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Because they went to the Judenrat.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They need girls to clean.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And the, the Judenrat sent us.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I was not taken, because I was breadwinner.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I worked for the German girls.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] But later they took everything, everybody.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes, making-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "They used to come to me.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "But I went to-- saw some of [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH], that's a woman who take care of the children.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "She take care of the children.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "So she ask me I should take off the arm band.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I have this.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Because she doesn't want that the children should know.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "I did take off-- in there, it was before the holidays.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "I went there, and I-- she had a friend, Rosenbaum also her friend.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "He came there visiting her.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "And I saw him, he saw me.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "You know, I was without the arm band.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "She said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "He said, [NON-ENGLISH] arm band?",
      "word_count": 5
    }
  ],
