  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "About the German?",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Of course, as I mentioned before, we learned about a German invasion right September 1, because they were preparing.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Preparing.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Because we saw a lot of-- a lot of preparations to-- of the armies, traveling one base to another with their military trucks.",
      "word_count": 23
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "And we knew that something was going to happen unless Poland gives up, gives them the break.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And being that England and France had guaranteed the Polish border, Poland became strong.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "I will remember the first day.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "There was a lot of-- a lot of traffic.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "A lot of people started to run away east, east towards the Russian border.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And I remember it because I-- most of the time, I was working nights.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And there were so, so many people that I haven't seen.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't handle that many people.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "People used to take some food out and to eat outside.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And the-- and the first day of war, there was a plane passed by.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "And there was a-- a line to-- in front of a bakery, and a bomb fell nearby.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "And that was the first time we saw it.",
      "word_count": 9
    }
  ],
