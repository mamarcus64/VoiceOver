{
  "stem": "7160.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So in a way it's good and a way it's--",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Medical treatment?",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Was such a thing in medical treatment over there?",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I got lice running all over me.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They used to eat me alive.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] No, there was no hospitals too.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was sick, it was goodbye Charlie.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "The only one that are on their feet can stand and work, they still want.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "If I wasn't going sticking to Warsaw, I never was going to make it.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I was very young and strong when I got in, and I'd become like a living skeleton, you know?",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "My legs was as thick as my arm here.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It's a much-- we lost the weight.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Everybody become skeletons.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "There's no food, you work hard, you get breathing, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "When you have some meat they hit you, you don't feel it so much when they hit you.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You got bones, that hurts.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It goes straight to the bone.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 8 SECONDS] That's the way it goes.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I was a policeman in the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Close to the camp we had some Ukrainian and Russian soldiers where they threw their arms and they went to the German side.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And they went to the German side, and they were afraid to go back to Russia because they're going to execute them over there, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "It was about two-- about a mile away from our camp.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And they used to come inside in our camp at night and attack older people-- steal their watches, their rings, whatever they can get, and beat them up.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "So we organized about 10 guys of us, the strong guys.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Everybody's going to watch around the camp, you know, to see around.",
      "word_count": 12
    }
  ],
