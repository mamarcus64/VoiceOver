  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But what could we do?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, no.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That's a mistake to think because that's impossible.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't write.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "There was no way of keeping in touch.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Once in a while, through the underground, you would have somebody who could then say a word.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "We were separated for eight years during all that period and hardly knew from each other.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Bratislava.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "There's another person who had to go through the same thing as I.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Her name was Erna, E-R-N-A.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And then we both-- I don't know whether we went at the same time.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I think she went earlier.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But as a happy bride with an Austrian passport, I had to go to Vienna.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it's-- what do you call that?",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In the-- in the city hall.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Somebody in the city hall.",
      "word_count": 5
    }
  ],
