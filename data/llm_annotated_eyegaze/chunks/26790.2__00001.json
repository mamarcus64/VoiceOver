  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "But we know that he is not a friend of Jewish, he's an enemy of Jew.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Very not good.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Not good.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Not good.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Because we know what is-- I tell you before-- we knew about what is-- what is-- what is the future what he wanted to do, what he according to his book, his dirty book, we knew already what he's going to do.",
      "word_count": 42
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But we didn't expect it.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "We didn't expect it to-- to be like that with the concentration camps, with the gas chambers.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We didn't expect it.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "How I can expect it?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And a matter of fact, I'll tell you the Yiddish people used to say like that, Germany was a cultured country and it has three or four newspapers daily.",
      "word_count": 29
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "How it can be expected in Poland?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Who can afford the paper?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "Two-- two or three families used to buy a paper because they can't afford them.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "But over there, in [INAUDIBLE] was three, four newspapers.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Cultured people.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And how you can expect it from them to be [? helped ?] like that, to be killed.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "What condition got killed, that's what [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I'll tell you what, not me family.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Any Jewish person, if you wake him up in the middle from the night, you ask him, you want to go to Australia, to Argentina, to America, to England, he would-- he would left everything, he would go.",
      "word_count": 38
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't have a chance.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You must have a permit, you must have money, you must have this, you must have [? relation. ?] But you-- but-- when they ask you to come.",
      "word_count": 28
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise, any Jewish person if you would ask him, you go.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    }
  ],
