  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "And after we got across to that gypsy compound, she took me by my hand and she says, I have a surprise for you.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "My cousin was there, a man, whom she knew.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "They grew up, more or less, in the same little town there.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And she knew of him and he knew of her.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "And via grapevine, my cousin discovered that I am there.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So she gave us five minutes together.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And a couple weeks later, she came to look for me, and to let me know that he was taken on a transport, where she did not know.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But this is what-- there were some human people in all that too.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Not everybody was ugly.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Not everybody was mean.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And not everybody was nasty.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "There were some humane people.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "We're going to stop for a moment to change the tape.",
      "word_count": 11
    }
  ],
