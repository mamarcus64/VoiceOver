{
  "stem": "11797.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "It was run by the government.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But mostly Jewish people were in that public school.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "It was called [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "After a big Jewish writer it was named.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "It was not a Jewish-- it was-- it was a-- it was a what do you call it?",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "A, a regular public school by, by the state.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Polish, strictly Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Polish, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "We spoke mostly Jewish, mostly Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Occasionally we spoke Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Beg your pardon?",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Mostly Jewish, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Maybe if you-- if you-- if you find a non-Jewish person, we spoke, of course, Polish.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But I spoke good-- I spoke good Polish, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I spoke Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "But in the house, we spoke Jewish, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And that's what I understood.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And that's what my father-- and grandfather, especially, wanted to talk only Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "He was very, very Jewish-minded and Jewish traditional-minded, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "My, my grandpa is a very old-fashioned man.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "My father, every day when he used to get the newspaper, he used to stress the fact-- look over here what happened.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Look over here.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Look at this country.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Look how bad it was here.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Look how they're beating the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Look how they-- they-- you can't go on the train to go from one city to the next city because they would beat you up, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "They will hit you.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "They will-- they will close your stores, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And we noticed something that stores were coming in-- of non-Jewish men-- were coming in the garments industry-- opened up stores, selling clothes.",
      "word_count": 23
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "This never-- we, we never seen it before.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "But the Jews were in charge of that, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "And they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "And they were, like, showering away-- or chasing away the Jewish people who were in Rowne, you know.",
      "word_count": 18
    }
  ],
