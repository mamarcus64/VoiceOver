  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "You're going to wear a babushka, you're going to have to go someplace to the village to maybe they will hide you, something they don't know you.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "I don't know, my husband is driving me crazy.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "I can't Mary, I'm sorry.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "I can't I blah, blah, blah.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And I said, OK, Lucia, I understand.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "I will walk out in the streets and I'm dead.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "It's-- it's 99% dead.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "And then these little boys are playing, both of them, her son was my son's age.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "Merrick his name was.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "OK, we'll leave, we'll leave, we'll leave.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He took it.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They give him a little money, my brother-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "He right away walked out, and we will find a little apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Not a little apartment, in a house, one room with a kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Behind the wall, rented the home-- it was a two-family home, behind the wall you can hear everything",
      "word_count": 18
    }
  ],
