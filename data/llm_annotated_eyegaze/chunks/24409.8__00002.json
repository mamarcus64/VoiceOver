{
  "stem": "24409.8",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 50,
      "text": "And if they would capture the ship, I would be the first one whom they would arrest, and they would shoot me.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 51,
      "text": "And he went with the ship.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 52,
      "text": "And now you know the story which happens on the ship, with the ship.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 53,
      "text": "The ship, the ship-- first of all, we took many more people than we were allowed to.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 54,
      "text": "They had beds for supposedly with flour, and first they loaded some flour, some supplies for the people for the trip.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 55,
      "text": "And then they were filled with people.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 56,
      "text": "And we took many more people.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 57,
      "text": "I don't remember the figure.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 58,
      "text": "But 2,120 or so ended up on the And the went-- had the shortest trip of any of the ships.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 59,
      "text": "It went through the Marmara [INAUDIBLE] into the Sea of Marmara and sailed.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 60,
      "text": "But they got spotted by a British warship.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 61,
      "text": "The British Navy had given orders to-- what inform [INAUDIBLE] ship was unpermitted refugees and arrest it and bring it to the next, the nearest port.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 62,
      "text": "And so their landing party came on board, expecting all kinds of trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 63,
      "text": "We were about five or six men.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 64,
      "text": "And there were 2,000 people on board.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 65,
      "text": "And they said, I'm sorry, we have to confiscate you, and we have to direct you to the nearest British port.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 66,
      "text": "[INAUDIBLE] Haifa.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So the captain was a very smart guy.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The Turks are very smart.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And he was not a Turk.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He was a Russian, I believe.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "A White Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "He said, I don't go to Haifa.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I have orders to go to Alexandretta, which was in Syria.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So Alexandretta, I don't go to Haifa.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "If you want me to go to Haifa, you have to give it to me in writing.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They got in writing that he's ordered by the British navy to go to Haifa.",
      "word_count": 15
    }
  ],
