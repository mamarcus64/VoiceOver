{
  "stem": "24466.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I told you about that watch, yes?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And Ala was with me in that room.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And Fronckiewicz was in that room.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And his wife was in that room too.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Exactly where he was during hiding, because she got documents as an Aryan.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But I don't know in which, by whom she was with Lutka, together.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They were together all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Being by the partisans, [PAUSES FOR 10 SECONDS] not by the partisans.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] Not clear for me.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "It's not clear for me.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "When I was in Valakampiai, she was about two or three kilometers apart from me.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "There are things that you can't forget.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "The Russians took over again the-- the factories, the combine.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Asked me to do the same work for them.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I was a technical manager, working again for the Red Army.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Only a few months.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Definitely was better.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "[CHUCKLES] No comparison.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Not with the time in ghetto, not time in Kielce.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "In time, we are free people.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And that happens once, a Sunday, where factories are not working.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] A captain of the Army was found in Russia, Polish Army, [NON-ENGLISH SPEECH].",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "That was the Army that was founded there.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "A captain, [PAUSES FOR 4 SECONDS] he recognized me.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] He took away some-- he was working before the war for the Department of Supply [PAUSES FOR 3 SECONDS] for the Polish Army, and he took from my father [INAUDIBLE], and he recognized me.",
      "word_count": 38
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "He asked me, what-- how-- how-- and I told him what I-- and he asked me what I am doing.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "I told him that I'm working.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "He said, well, if I took up the Russian citizenship.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "I said no, I've got the Polish citizenship.",
      "word_count": 8
    }
  ],
