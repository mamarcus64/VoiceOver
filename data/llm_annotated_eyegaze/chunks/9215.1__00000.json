{
  "stem": "9215.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Clara Posner.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I'm born in Poland, in the city of Luboml.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I'm born 1916, and November 10.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "City.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Was a nice city, big city.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "There was Jewish people, and Ukrainian, and Polish people.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Before, my mother used to tell me, I don't remember, my mother told me before it was Ukraine.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But after the First World War in 1918 or 1919, the Poland occupied there.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And that's why, since then, was Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "There was all kind of a people.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "There were people, working people, like carpenters, like shoemakers, like, you know, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Tailor, something, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And there was a lot of stores.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "People was, it was a big, a square, I'd say, a-- like a bazaar, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "A big one.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And around and around was stores.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "It was everything was there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Whatever you wanted, it was in the stores.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And the most was Jewish people got stores.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Moshe.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He was a businessman.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Since I remember, he used to, went to the villages.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He got a horse and wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "He used to go to the villages.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And he bought-- you know, on the villages, the Polish people or the Ukrainian people, they used to go for huntings.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "They shot.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And [INAUDIBLE] he used to buy the skins, all the skins, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And this, you know, he was.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Hanna.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She was-- I [? don't know was she-- ?] I-- people used to tell me that my mother was very nice, and was the nicest girl in the city, she tells me.",
      "word_count": 32
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "But she was-- she was young.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "She told me, she used to learn dressmaking.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "But then, she got married when she was only 18 year old.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And my father was 20 year old.",
      "word_count": 7
    }
  ],
