  "elapsed_s": 245.6,
  "sentences_input": [
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "And that was a rather narrow escape because I almost fell for it.",
      "word_count": 13
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "But he had none of the papers that were needed.",
      "word_count": 10
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 4,
      "text": "Or none of the names that were needed.",
      "word_count": 8
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 5,
      "text": "And so with a breaking heart, I let him go.",
      "word_count": 10
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 6,
      "text": "I suffered.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 7,
      "text": "It was-- it was maybe a week later that I then saw him with those Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 8,
      "text": "But that whole week, I felt, it's so terrible that I have refused him.",
      "word_count": 14
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 9,
      "text": "Maybe he's shot.",
      "word_count": 3
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 10,
      "text": "Maybe he's dead.",
      "word_count": 3
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 11,
      "text": "Maybe I could have helped him.",
      "word_count": 6
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 12,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 13,
      "text": "But then later, I knew I had done the right thing.",
      "word_count": 11
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 14,
      "text": "And I cried.",
      "word_count": 3
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 15,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
