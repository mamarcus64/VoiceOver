  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And nobody will spy on me and report me to the authorities that I'm hording coffee.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Of course, I bought all this to make packages with, to send it home to the people that I was supporting.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And this has now diminished to, literally, two people.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Everybody else died.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "But in my own very modest way, I started out helping a little over a dozen people.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And, you know, I was helping them in terms of my resources.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "Initially, I was sending $10, maybe.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "And-- and occasionally, and as time went on and I got a regular job and so on, I was sending what to me were large sums-- $100, $200.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "But I'm telling you all this because your-- your question was, was I worried about my future.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And I was never worried about my future.",
      "word_count": 8
    }
  ],
