  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "I should say before that that my hotel was selected in a different location than the hotel of the contestants that were coming from socialist country, including from my own native country.",
      "word_count": 32
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "There were so-called socialistic hotels-- all the Russians, Czechoslovakian, Polish.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And I was in the capitalistic world--",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Israel-- which-- there were some Americans there.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] By the way, the Americans, a number of them were of Israeli descendents-- France, England, Germany, and some other countries.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So I start to receive these calls during the night.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They didn't stop all the night.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But this-- not, not only the night, but also the following.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "So this obviously attracted attention of the KGB in Romania.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And suddenly, these calls stopped.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I was very glad, between us, that they stopped.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Because the last night, I really needed one good night's sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Because the competition is almost like the Olympics.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "You need to be in, in maximum shape-- biological, physical, and mental shape when you are playing-- performing there are on the highest world level, in front of the top authorities of the world.",
      "word_count": 34
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "This was-- jury very similar to the jury that was-- given to the American very famous now pianist, Van Cliburn, the first prize on the piano competition, with the greatest composers, greatest artists, performers, all over the world.",
      "word_count": 38
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
