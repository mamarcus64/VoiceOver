  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And then my neighbors.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Actually, the-- a good friend of us, and old friend who's niece came, and the baby, and his brother-in-law.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And you know, people who wasn't in the labor camp.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And people who come home, some funeral, and went back maybe a week before or something.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Then-- And I cannot remember how long took this.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "That's the reason after when I talked to you, I called up Martha, my daughter.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And I told last night 11:30, Henry.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "I think before I die I would like to go to Auschwitz, and Stutthof, and Torun, and Magdeburg where I will somehow.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "Till now, I never want to go.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And we arrived there.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "We don't know it.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "This is Auschwitz.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "How can I describe?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It was [PAUSES FOR 4 SECONDS] crying, yelling, people get crazy.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And-- and some people's [INAUDIBLE] is-- is-- cannot describe.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "How could-- how could they do it?",
      "word_count": 7
    }
  ],
