{
  "stem": "7777.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "If not, this was a lot of Jewish organizations.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "This was the Zionist organizations, this was [NON-ENGLISH] organizations, this was the [NON-ENGLISH], [NON-ENGLISH], [NON-ENGLISH]-- this was a lot of young people.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Only, everybody was thinking to go to Israel, only the doors was locked.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "This was a very hard life for the Jewish people in-- in that town-- in that-- in Polish.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "And every town like this.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "Like this was a-- a small town.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "Before the war, they come out with the pogrom.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "They-- they was-- they started to hit all over the Jews in this [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "And they was arrested, some Jews, where they was standing, again.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 28,
      "text": "It was very, very difficult to live over there.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 29,
      "text": "Only there was no place to go.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 30,
      "text": "You have to-- you have to take it, what has come.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 31,
      "text": "The young people, they just was hoping to go to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "It was their only hope.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 33,
      "text": "Only this was not a possibility.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 34,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I just went to cheder.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And-- and when my brother got married, even before I was helping in the store, because my brother got married in '26, '25, I was helping in the store, [INAUDIBLE].",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And the other brother was working.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He was a painter.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And the older brother got married, and he have a lumber business.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "It was not a big success-- only he make a living.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "It was very hard-- only make a living.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And my sister-- it was very hard to give the kids an education.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I have one sister-- Hanna-- she want to be educated.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And my mother have not the possibility to give her the education.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "She finished grammar school-- this is seventh grade.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And she took a job for-- helping bookkeeping.",
      "word_count": 8
    }
  ],
