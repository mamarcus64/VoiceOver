{
  "stem": "23626.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "The Russians are moving, moving closer and closer.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And the liquidation began.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And till one day, there was a doorbell.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And I came to open the door.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And there were two civilians-- German-- asked for Amon Goeth.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I went upstairs, and I said, Herr Kommandeur-- I explain him that somebody's looking for him.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "He came down.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I came down toward the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "But I was standing on the last step and sneaking, looking, you know, seeing what's happening.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "It was kind of different normally that anybody is at two people asking for him, two men.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And I saw them showing some kind of a paper.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And that moment, I saw him reaching for his hat, and his belt, with his gun.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And he walked in the middle, out of the villa, with those two men.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And I ran into the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I said, I said, Helen, you know, two, two, two Germans came, civilian.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They asked for him.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And when he came down, he, he walked in the middle.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "You saying they taking him away?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "She says, [NON-ENGLISH], you're such a child.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Who could take him away?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "He's the, he's the kommandeur.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "He-- who could possibly order him to go out?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "You child.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "You're so childish.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I said, I don't know-- they showed him paper.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And he walked, like, in the middle.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And this is what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We never saw him again.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "We only heard, later, that he asked for some underwear to be sent.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Packed up some underwear and socks and somebody's going to pick it up.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Rumors-- somebody was saying later that he did leave for Vienna, where he actually--",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "That was, like, beginning of October.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "When the civilians took him away.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "That was maybe like five days later.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Not exactly.",
      "word_count": 2
    }
  ],
