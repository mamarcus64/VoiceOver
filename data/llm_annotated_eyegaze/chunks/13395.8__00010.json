{
  "stem": "13395.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 40,
      "text": "And I had the opportunity to sit at a table with seven ministers of Ontario, and to bring to them the concerns of the Jewish community, the anti-Semitism of today, the neo-Nazis that live in our midst, the war criminals that still are being harbored in Canada, and not being punished or deported from this country.",
      "word_count": 56
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 41,
      "text": "I would sit in the court when we charged any neo-Nazi with some neo-Nazi activities.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 42,
      "text": "I would face them.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 43,
      "text": "I would confront them.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 44,
      "text": "I openly said to them, as long as I live, there is no room for you in this community.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 45,
      "text": "And they knew it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 46,
      "text": "They knew who they were dealing with.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 47,
      "text": "And I didn't mind if a detective had to follow me to the garage to pick up my car.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 48,
      "text": "Because they were afraid that the neo-Nazis get me.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 49,
      "text": "I had an unlisted telephone number.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 50,
      "text": "And I never went straight home from the court.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 51,
      "text": "I traveled-- drove around in the city.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 52,
      "text": "And I never parked in front of my children's home at the time that I was fighting the neo-Nazis.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 53,
      "text": "I didn't want them to harm my children.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 54,
      "text": "That was my only worry.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 55,
      "text": "I didn't worry about my life or my safety.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 56,
      "text": "I survived the Nazis.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 57,
      "text": "I'll survive the neo-Nazis.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 58,
      "text": "But I will not make it easy for them to spread the lies, their hatred.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 59,
      "text": "The work has to be done.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 60,
      "text": "There aren't many survivors left.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 61,
      "text": "Every day is less of us.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 62,
      "text": "And one day, there won't be any.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 63,
      "text": "The Spielberg Foundation has make possible that future generations will know our story, hear it in our words, without editing, without making it look good.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 64,
      "text": "This is the story, as it was.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 65,
      "text": "And we survived it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 66,
      "text": "And I thank God for it.",
      "word_count": 6
    }
  ],
