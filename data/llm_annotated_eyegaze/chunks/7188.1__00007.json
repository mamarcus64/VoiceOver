  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Christian.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Just me.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Not far.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Walking distance from their house.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Not so far.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I slept on the floor in a corner.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "A couple days.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "It's nothing there to remember.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "I stayed there in the corner until my mother came.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "She used to deal with them, buy chickens from them, things like that.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "She says, now, you could come home.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "My mother was attacked when German's dogs, German Shepherds.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "My mother was attacked, too, when she picked me up.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "They ripped the clothes off, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "She was hurt.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Sure, the dog threw her down and they ripped the clothes off her.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And she had-- what do you call it?",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "The jackets?",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "It's not a jackets.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "They're for the pelts.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "You know what a pelts is?",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "She had a pelts on, so they ripped it off.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 9,
      "text": "They wanted to see what she's carrying underneath.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The dogs did this work.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "This happened not far from my house.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Not far.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And then I've never been back to this place.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "No more.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "It changing.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Every day, was changing.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I was hiding in the attic.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I was hiding under the bed.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I was hiding there.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't a normal line.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto-- my sister wrote us a letter.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "She was in Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "So she wrote us a letter we should move.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "Maybe times will get better in Russia because she find out it's no food and things like that.",
      "word_count": 18
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "So then we got the letter from my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "She was in an accident.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "The Germans attacked and she's in the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And what happened to her?",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "She came out of the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "She was all right.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Shop [INAUDIBLE] she got attacked.",
      "word_count": 5
    }
