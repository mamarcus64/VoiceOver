  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I-- I consider that the loss of two or possibly three people [PAUSES FOR 3 SECONDS] as great a loss, other than my family, of friends which I lost during the Holocaust, more than those which didn't make it up to that point.",
      "word_count": 47
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, life begins on May 3rd, 1945, approximately 10 o'clock in the morning, [PAUSES FOR 4 SECONDS] life without family, [PAUSES FOR 3 SECONDS] life with-- [PAUSES FOR 3 SECONDS] without a meaning, [PAUSES FOR 3 SECONDS] just life to live.",
      "word_count": 41
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Does it make sense?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] Fortunately, we had some very good counseling.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "There were some Jewish chaplains available from the British army, some social service people who helped us through the first few days.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And a strange thing happened to all of us, to me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I'm going to speak about me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "After two days being in the hospital, I was able to walk and get out.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Never forget this.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And I walked the hospital grounds on the street.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] I hadn't mentioned that, but I'm sure you're aware of the Jews were not allowed to walk on the sidewalk [PAUSES FOR 3 SECONDS] in the late '30s and early '40s.",
      "word_count": 35
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And of course, while we were in ghetto and concentration camps, we always had to walk on the street.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Jews were not allowed to walk on the sidewalks.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And here I'm walking the hospital grounds on the street.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And somebody tapped me on the shoulder and said, Bert, Luds, [PAUSES FOR 3 SECONDS] you're a free man.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "You don't have to walk on the street anymore.",
      "word_count": 9
    }
  ],
