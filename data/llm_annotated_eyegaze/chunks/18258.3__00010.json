  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I took the hint, got dressed, what little money I had, not much, and left home.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And I spent the day riding the trolley and the subway all over Vienna, just not to be home.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "When I got home at night, I found out that a couple of hours later, mid-morning, they had sealed the street on both ends and had brought in some SA or maybe SS troopers with some army-- with some trucks, had pulled Jews out of the apartments and the stores, and forced them to crawl underneath those vehicles and scrub them with pails and brushes and water and scrub the street.",
      "word_count": 71
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And one incident my parents told me--",
      "word_count": 7
    }
  ],
