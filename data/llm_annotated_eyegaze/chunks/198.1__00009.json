{
  "stem": "198.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have telephones in Poland at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But there was no news.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We could not get any letters.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We were cut off from the whole world.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Was absolutely nothing, no news.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We just lived from day to day, and we were hoping that we will survive.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "There was not a thing we could do to survive.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Whenever they want, they caught us and sent us to extermination camps.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Life in the ghetto was terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We had no facilities.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We had no fuel.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Poland was very, very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "It was very, very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We had no communication with each other.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "We were in a ghetto with barbed wires.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "The barbed wires, we had SS every few miles.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "They were patrolling like we could run.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Where could we run?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "We were so weak and so weak there was no place to run.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And we were treated just [SIGHS] like we were animals-- even worse than animals.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "Was no food, we didn't know anything what's happening in the world.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I had a cousin living in the same court with her whole family.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "They were a family of five children, but [SIGHS] they were taking-- we were-- had every few months round-ups in ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And they took people out till it got thinner, and thinner, and thinner.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "My cousin who survived, now she lives in Chicago.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "She's my age so she was hiding all by herself in my-- in my place, and [BACKROUND NOISE] somehow we survive.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And her whole family [BACKROUND NOISE] was taken away at round-- round-up in 1942.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "My cousin survived.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Now she lives in Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And we had no food.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "The little food I had, I shared it with her and we survived.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Every single day I went to the factory--",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "--and I worked.",
      "word_count": 3
    }
  ],
