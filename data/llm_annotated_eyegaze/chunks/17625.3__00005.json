{
  "stem": "17625.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 232.5,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Moniek Fuchsbrunner-- Fuchsbrunner, my name.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "His father was a cousin to my father.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So he was-- he was-- he was before the war, he was a mechanic.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "A [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You know what it means, [NON-ENGLISH]?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "A mechanic.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He good in-- in-- in mechanics.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So I was with him together there.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "All of a sudden, the [NON-ENGLISH] comes.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know what a [NON-ENGLISH] is?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "The [NON-ENGLISH], from the block.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They are looking for hand craft, like carpenters, and-- and-- and-- and, [NON-ENGLISH] and-- and the other things in there, you know, more-- more or less the-- the-- the brick work, they're looking for.",
      "word_count": 34
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So my cousin told me, I'm gonna go.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I'm a [NON-ENGLISH], so I have a chance.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It can't be-- can't be-- can't be worse than here.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Here, I can see every-- every day, every day is-- is nearer-- nearer to the end.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "So he went.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So I said, I'm gonna go too with you.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And this is the way I stuck with him.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And they lined us up.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And they took 25 young people.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] And then, from the whole group there-- 25-- and from there, they took us-- they took us to the bath.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And they gave us the stripes.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And they brought us back.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So everybody was looking at us.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "How did you do it?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "How did you do this?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "You know, the-- they-- they were-- there was the envy.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] It like-- like-- like I would make the-- the-- the-- the lottery, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "That's what it was.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And they brought us a little kettle-- you know, a kettle of-- of-- of soup, which, this was a rarity.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "This was millions.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "You couldn't buy it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "For us, 25, do you know what it means?",
      "word_count": 9
    }
  ],
