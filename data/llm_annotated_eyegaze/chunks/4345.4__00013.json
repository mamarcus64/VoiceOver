{
  "stem": "4345.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And we are the inhumans, they are the humane people.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "We arrived to Bergen-Belsen, and I saw carts waiting for us but there were no horses.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "There were human horses.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Those were skeletons from Bergen-Belsen already.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And we are supposed to go on those carts and they are supposed to take us to the hospitals.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "When I saw this, I knew that these people were going to die-- to their deaths, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I got off the train.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "My feet were like sticks, my legs like two sticks, wobbling like a new-born lamb.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "I hardly held on to my own life.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "I was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "I had a-- a full-blown typhus.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "I had hundred-and-six fever.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "I was emaciated totally.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "Ok?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "And I said to myself, no way am I going on that thing.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "I said to myself, [?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "[SPEAKING YIDDISH]. ?] I spoke Jewish to myself.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "I got off that thing and I walked slowly with whoever else walked with me, and I hoped that I'm not going to be noticed by the Gestapo or the SS or the Wehrmacht, whatever, how I walk because they would easily throw me on the fires there.",
      "word_count": 48
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I made it to the barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] The wall of my barrack was situated over there, for instance.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "This was this direction.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "When I walked in, the floor was full of dead bodies.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Full with dead bodies from dysentery, from typhus, from hair loss.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "You name it, and they had it.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "The lice, first all, caused the biggest problem, because my skin was already yellow with the pus, everything it was.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I had nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I had nothing on me except my heart was going.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Did you ever see a board?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "That's what I was.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "My heart was going.",
      "word_count": 4
    }
  ],
