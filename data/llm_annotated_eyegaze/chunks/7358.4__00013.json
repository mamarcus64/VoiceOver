  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "He went to Israel during the time of the Scud missiles to, to, to live with this people.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And he thought he wanted to feel this on his own, on his own skin.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The burden.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My daughter is a graduate from Oswego College.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And she's a paralegal.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And she works in the legal profession.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "She has a very nice job.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "She's not married as of this moment.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And I'm very proud of both of them.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "We have three-- have three grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Two of them are three years old, and the baby is 10 months old.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And my son married a very nice young lady, very educated.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "She also had a very high position.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "So I'm very proud of our accomplishments.",
      "word_count": 7
    }
  ],
