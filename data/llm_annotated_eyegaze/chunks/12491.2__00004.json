{
  "stem": "12491.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I just had to wear an-- an armband with the Star of David while I was traveling to and from.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "The travel consisted of walking because by that time, Jews were not allowed to use trolley cars anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Sometimes before the ghetto, Jews were allowed to use trolley cars but had to stand in the very back.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "But this was eventually changed, and at that point, Jews were not allowed to drive-- to ride wherever-- to ride trolley cars at all, so I had to walk.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, there was no real pay in money.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Nevertheless, I did get some pocket money from the owner of that place because I did very well for him.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He was making money out of me being there.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And he also was giving me different things, foodstuffs, to bring into ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "At that time, I was wearing boots which were about, like, three-quarter high and were very loose at the top.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And I always had stuffed in there some stuff, and I walked into a-- into ghetto with them in my boots.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And this how we survived, actually, above and beyond the-- the ration cards, which were a starving diet.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother was not working.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My sister was working.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She-- my sister eventually became a dressmaker.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "She after-- she had to interrupt her high school, and she went to a Jewish-run vocational school where she learned dressmaking.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And she became very good at it.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "She was making beautiful wedding gowns and very elegant gowns.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And she got an assignment because of her talent to do these things.",
      "word_count": 13
    }
  ],
