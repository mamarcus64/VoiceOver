{
  "stem": "747.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "On a leaf, we had to put the stones and carry.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "In and out, day in, day out.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Carry these stones.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The SS women.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Occasionally.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I-- I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "They didn't touch me.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "But many, unfortunately, especially if somebody was very pretty.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Not too far.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "That was the outskirt.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That was still in Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "That was still in, in, inside Birkenau.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it was a big compound, but, but the working area was all-- all was around the crematorium and the railway station.",
      "word_count": 23
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "The, the headquarters of the SS Nazis, the offices, Mengele's office, where he did all the-- with the twins.",
      "word_count": 19
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Experiments.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "The [GERMAN], the sewing room.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "There were different sections was all-- was taken-- done by inmates.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Luckily, luckily I was strong.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Luckily, I was well fed, and I was never sick before.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Before the war.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "So I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Nothing, nothing serious really.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Just hungry.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Just hungry.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "But so was everyone else.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No way.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "It was no way.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Food was impossible.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "Occasionally, we were working-- there was an old apple tree and-- with rotten apples in it because nobody tended it.",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And so we gobbled it up, with the worm and all.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "But we couldn't, we couldn't get any food.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "Food was impossible.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "While I was working in Canada we got little bundles where, you know, people were hoping to save some salamis, dried salamis.",
      "word_count": 22
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And then what we find a lot was diamonds and jewelry.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "But it didn't have any meaning.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "It is absolutely-- we couldn't use it.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "With a toothpaste stuck in-- wrapped over with thread.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 12,
      "text": "And we throw it to the toilet because we were scared of it.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 13,
      "text": "We couldn't buy a slice of bread with it.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 14,
      "text": "It had absolutely no meaning.",
      "word_count": 5
    }
  ],
