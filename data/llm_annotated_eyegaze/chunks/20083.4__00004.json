{
  "stem": "20083.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Earlier, I had actually worked in Wiltshire in-- on the farm for-- in a garden and a farm for about a year-- a family called the Griffith family.",
      "word_count": 28
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "He was Welsh.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And she was French.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And they both disliked me intensely, probably because the French has-- have always disliked the Germans, regardless of conditions.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "The fact that I was Jewish made no-- had no impact on her whatsoever.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And of course, at that time, I didn't know that my family had been wiped out or that they were even in concentration camps, because I learned all this later.",
      "word_count": 30
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "But I did not have a very happy experience there.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "Rachel was their daughter who was constantly singing at the piano.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And she was a very heavyset young girl who never seemed to do any work.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And that annoyed me no end, too.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "But after a year, I left that place and went to London.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, in London I worked in a factory and--",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Textile--",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Then I actually went to the Bloomsbury House.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Reuben, he said, you know, we lost one of our-- I don't know how.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "But we lost one of our social workers.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Would you like to be trained as a social worker looking after refugees like yourself?",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I'd love to.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And he said, all right, we will train you.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "You will have your own little office.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And you'll have to discuss the problems with these various boys and girls and see to it that everything is done to their liking and that-- that you can solve their problems, et cetera, et cetera.",
      "word_count": 36
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And I was trained and had my own little office.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And I stayed there until I left in December-- or November 1947.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I started looking for my family almost immediately.",
      "word_count": 9
    }
  ],
