{
  "stem": "19211.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 286.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And they were just not very-- most of them in general, generally speaking, were not very well educated.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And they just, they were anti-Semitic.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "The Polacks were more refined.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I don't have much against the Polacks, really.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Except they were so anti-Semitic too, some of them.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "But they were nice to us.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "The Ukrainians, I can't say the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "They were very bad, anti-Semitic and bad, very few exceptions.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "That day when my friends were killed.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "That was about the worst thing that-- I still have nightmares.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "This will never end, as long as I live when that scream and they shot-- and they shot her, my-- she was going to school with me to [NON-ENGLISH], I told you, [NON-ENGLISH].",
      "word_count": 33
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "She was killed, and her father, and her brother.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Her mother was on the Aryan papers.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And she was somewhere else.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "She didn't know about it till later.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "That's probably one of the-- there were many bad days.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "But this is something that's in my mind until today.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "I don't think I'll ever forget that.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I never did try to do that, never did, no.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "My mom had a chance to be on Aryan papers.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But she didn't want to leave us.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She said if we die, we die together.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And that's why we stayed as a family.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "We stayed together.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "She didn't want to leave us.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "She could have, with my brother she could have left, as that nobleman's relative.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "He wanted to make her a cousin of his and give her papers.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "But she didn't want to leave us.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Because she had to live in freedom.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We had to be in hiding.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She would be free as an Aryan.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We were too Semitic.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We looked Jewish, and no.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "She didn't look too Jewish.",
      "word_count": 5
    }
  ],
