  "sentences_input": [
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 3,
      "text": "My mother started to get very, very ill.",
      "word_count": 8
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 4,
      "text": "She started to feel tired and probably very destroyed from all this.",
      "word_count": 12
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 5,
      "text": "We found somebody on a horse and buggy that-- somebody we knew.",
      "word_count": 12
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 6,
      "text": "So we put her and my little sister-- they tried to help her out.",
      "word_count": 14
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "So we were just walking behind that wagon and trying to hold on.",
      "word_count": 13
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "She shouldn't fall off.",
      "word_count": 4
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "Because everybody that could, that little wagon that could take, put them on on top of them-- Right.",
      "word_count": 18
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "--and she was in terrible, terrible state.",
      "word_count": 7
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
