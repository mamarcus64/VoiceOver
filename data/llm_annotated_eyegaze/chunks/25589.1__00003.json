{
  "stem": "25589.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "One day, I come out of school, [INAUDIBLE] talking about things that you remember.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I was a fighter.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Although I was very small, I was a fighter.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I come out of school, and somebody is beating up on my brother.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "No, well that can't happen.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I go over there.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I beat him up.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But I got beat myself.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I got a cut on my eye.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "My mother said, what'd you do?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Said, well somebody beat up on Johnny.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Said, oh, that's good.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "She said, did you get hurt?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I said, no, not really.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "So while we have supper, the bell rings.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And, and my dad says, hey, you have to come downstairs.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "You beat somebody up?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "No, I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I'm already afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I mean, my father never laid a hand on me.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "He was strong, but he never laid a hand on his-- so we come downstairs.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "There's a policeman, and the guy is about a foot taller than me.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And the policeman says, did you beat him up?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Says, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "I says-- he says to the other fellow, he says, yeah, it'd be a shame, that a little guy like that beat you, beat this guy?",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Get out of here.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And they got out of here.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And it's one of those stories-- I got a few of these stories.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "You told me a story about apples?",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "On Wednesday afternoons-- I had three friends, and we always would go out, have a good time on a Wednesday afternoon.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "This afternoon, we go picking apples.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But they were not ours.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So we had to go to the farm.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "There's a lot of farmland there.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So we arrived there.",
      "word_count": 4
    }
  ],
