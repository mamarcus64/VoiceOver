{
  "stem": "13817.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Fred F.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Roer.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Live in Seattle now for, what is, 46 years.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "At birth my name was Fritz Roer.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in Kerpen, which is a little city near Cologne in Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "On November the 2nd, 1920.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I lived there till [PAUSES FOR 4 SECONDS] I think beginning of 1939, spring of 1939.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And then we were forced out of our-- of the home we were living in and moved to a so-called Juden apartment, which is a Jewish apartment just for Jews which was shared by one other family.",
      "word_count": 37
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In-- that was in Cologne.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "That's in the [INAUDIBLE] 63-- yeah, 63.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And we moved from a, let's see, three-- five bedroom home into a one bedroom apartment where we had to share the kitchen and bathroom with the other family.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Kerpen was a town between 5,000 and 6,000 people.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Everybody knew each other.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "My family on my mother's side grew up in this town as far back as I can go, I would say about 1500, 1600s-- in the 1500s, 1600s.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] My-- my mother's father was a cattle dealer and after he passed away in 1913, his sons took over the business.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "My parents were married in 1914 in Cologne the year-- less than a year before my grandfather passed away.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We lived there like everybody lives here in America.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "There's no-- there was no difference between Jews or non-Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "There-- there was a little Jewish community of about 30 people-- 30 families, approximately 100 people.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And we had a synagogue which was run Orthodox.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Most of the people were between Orthodox and conservative.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And also we had a one-room day school from grades one through eight, and the teacher was also the rabbi and the cantor.",
      "word_count": 23
    }
  ],
