{
  "stem": "6110.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And they took Sam to the wagons already to go to Mauthausen.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "It was a terrible, hot day.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "It was July.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was so hot, and Plaszow was hot.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "The men were dying in the wagons waiting, all ready to go.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Schindler came and he gave an order to spread cold water on the roofs of the wagons to make it cooler, cooler.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "To hear something like that as such a Nazi, he came to help the Jewish people to get a little cold water, you know.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And then my husband left me.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "He went to, to Mauthausen.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And a few days later, they took us to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "But Schindler wasn't already with us.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "He was already in Berlin in prison when they took us to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "You know from the picture what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "One night, he came, and he brought with him jewelry and diamonds and gold, and he bought us out.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Oh, this I never forget.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They took us with the thinking that we are going to Czechoslovakia, to Brinnlitz.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And we all were happy.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We're going to Schindler.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We're going to Schindler to work.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "We're going.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And all of a sudden, in the night, we came over to a camp, and we saw the oven.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "The smoke came out from the ovens, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "They were burning.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "So we knew that we are in Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I was in Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We heard before.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We heard.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And, and they took us there, and we didn't know what happened because we were not supposed to go to Auschwitz.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "What we saw?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Fire coming out from the chimneys.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And we knew this  are the chimneys where they're burning people, the gas chambers.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "It smells-- how can I explain you how it smells?",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was choking.",
      "word_count": 3
    }
  ],
