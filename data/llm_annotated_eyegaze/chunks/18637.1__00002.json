{
  "stem": "18637.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And when she-- when I was 10, my sister was 8, my brother was 6, she-- she-- she got sick.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "She had cancer.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And she died.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "She was sick two years.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And we were-- we were alone.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "But my father had two sisters, who helped a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "They used to come in the morning and cook for us.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And there was a local girl, who cleaned.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And we managed, somehow.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "We tried to cover, eat less.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "I used to come from school.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "I knew that I have to wash the dishes, so I have to do things for my brother and sister, my father.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "He never remarried.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And we were maybe five years until the war started.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah, very difficult.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I used to think-- I used to be envy of my girlfriends that they-- they have parents.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I mean, we had a very good father and aunties, but that doesn't-- doesn't mean that.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I remember her funeral.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And being young children, they didn't take us.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And there were a lot of crying, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And that's how it was.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Everybody had, like you say in Hebrew, [HEBREW] because we were orphans.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "But I-- I-- I didn't like that somebody should have pity with me, with us.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Because I don't know why I kind of-- [PAUSES FOR 6 SECONDS] and being independent probably helped me a lot, through the years to come, not to lean on anybody, rather give advice somebody, how to survive or other things.",
      "word_count": 40
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a Polish school.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And it was a Hebrew school.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "In Polish school, I went just till seven grades, because, in my time, it wasn't a high school.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But Hebrew, after school, I went to Hebrew school.",
      "word_count": 9
    }
  ],
