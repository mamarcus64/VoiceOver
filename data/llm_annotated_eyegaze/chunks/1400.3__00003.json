  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And we arrived, I don't know even how many days we traveled, a couple of days, probably.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Arrived to town, and we heard the, the name.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "It was Landsberg.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And we marched through the town of Landsberg between the SS guards.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And one thing still sticks in my mind that I-- one of the older person said, this is the prison of Landsberg where Hitler wrote At the time, it didn't meant nothing to me because I didn't know nothing about at that age.",
      "word_count": 43
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Maybe I was ignorant, but I didn't know about it.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And it stuck to my-- that Hitler wrote he said that.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And it was in Landsberg where we started working on, on some installation of airplane repair place, steel-reinforced concrete.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It seemed to me we were building a hangar.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "But as I later learned, it was an underground factory.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "But the part I was working on, it was a hangar.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "We were ordered on a mini railroad train, and we were taken to this building site.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "We were working, carrying the, the cement, the material, and, and the, the, the sand and-- in these little railroad tracks.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "We were pushing them.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] And one thing sticks to my mind.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "This one time, as we were pushing this loaded railroad car, one of the fellow fell in between the, the steel reinforcement.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Must've broken some.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "He was screaming and yelling.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "The SS guard never let that man stop the pulling of the cement.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And his screaming is still in my ear today.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 7 SECONDS] These are the things which sticks in my mind, because it was so outrageously brutal and horrifying that I can't forget it.",
      "word_count": 26
    }
  ],
