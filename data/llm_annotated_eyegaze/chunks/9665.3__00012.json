  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "For me, it was a nightmare.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "At the end, I was so tired.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "And they had some lamps, like this lamp there.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "They had a few shining on me.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "And I didn't know what they were doing, but he took a chair, which was a timber chair, and he crashed it over my head.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "Surely, I didn't feel anything.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I didn't, didn't feel anything, because you get to the stage where you are-- nothing can really happen to you.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "All I knew I had this [NON-ENGLISH] from a man in a coffee shop.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And I knew even the coffee shop, the name of the coffee shop, right?",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We're going to change the tape now, Paul.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We'll come back to this story.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    }
  ],
