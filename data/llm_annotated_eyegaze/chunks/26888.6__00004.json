{
  "stem": "26888.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was, you know, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, 3 o'clock in the morning, I was running in that kitchen there, they should send me a doctor.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And they-- 6 o'clock in the morning, they send me a doctor.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I said, yeah-- and he said, listen, your sister is very sick.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "If you're not going to take her right now to the hospital, she has a very bad tuberculosis, and she'll die.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So that second cousin, that I told you, he was also in Munkatch that time.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He also was liberated, and he came to Munkatch.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And he helped me and  my sister, to bring to Budapest.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[COUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "To Budapest.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He said, if you're going to put her in Munkatch, there, it's not going to be good.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They're not going to do for her what she needs, and Budapest, there's a much bigger hospital there.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So I took her there-- meanwhile I was, myself, sick.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I had boils on my whole body.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I had to go myself.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "When I took her to Budapest, I came back to Munkatch.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I had to go into hospital because the boils were terrible.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I had on my feet, and on my body-- everywhere.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "So they put me in a hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "There was venereal diseases, things like that.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And I see this one is talking there, that kind of a man.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I said to the doctor, doctor came in, I said, listen-- this is-- I'm not that kind of a girl, and I'm not going to stay.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "So every day, I had to go for packing-- they put whole packs on my feet, and medication.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Anyway, I got better from that.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Did you ever find any of your family, other than the second cousin back in Munkatch?",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Nope, nobody-- nobody at all.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "With my brother?",
      "word_count": 3
    }
  ],
