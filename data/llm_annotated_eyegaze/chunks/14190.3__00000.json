{
  "stem": "14190.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I heard sounds.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I heard sounds like something popping.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Pah, pah, pah, pah, pah, pah, pah.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I-- so I-- I didn't-- I didn't really-- I didn't really associate with-- this with shooting, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Because it-- it sounds differently, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, I-- I-- I went towards the sound.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And I didn't go very far.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I saw this-- this-- this huge ditch.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And around that, a group of-- I began to hear also voices-- voices.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I-- I saw a group of women.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And they were undressed.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And some of them were holding babies in their arms.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And-- and the-- oh.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "The Germans were shooting randomly, I mean.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And they were falling.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "I was so-- I was so stunned, I-- I couldn't move.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "I couldn't move, I couldn't-- I was just like-- like hypnotised.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "I was-- I was-- I was there.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "And very soon afterwards, I-- somebody-- somebody grabbed me and-- and carried me again from there.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "And that was one of the nuns, older nuns.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And they were telling me, she was telling me, the others were dead.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "You were told not to venture, you were told not to go.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "You have not listened to us, that's very bad.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "And that night, that night our priest was back.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "I don't know how they let-- let him know.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "There was no telephones.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "I don't know how he-- how they let him know.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "But apparently, they had ways.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And he-- and we were again put into a buggy.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "And-- and he drove away with us.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "We were covered with all sorts of things.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "There were like some boxes and stuff on the buggy.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "And he-- and he drove away with us.",
      "word_count": 8
    }
  ],
