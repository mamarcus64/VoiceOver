{
  "stem": "2830.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "So, when I met a friend from Warsaw, she also took me under her wings, and she sewed something for me.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "A skirt-- she made me a skirt and a jacket.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "She made me some clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I get to there.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Uh-huh.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So I wore clothes, nice.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "That she-- she was one of the-- she sew-- she was a seamstress for actors in Warsaw, for, you know, for the theater, you know?",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Very fashionable things.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So they-- things are getting, you know, to be-- people are meeting families they find already, maybe a sister or brother or what.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "I have nobody, and I have no prospect to meet anybody because I knew that everybody was killed.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Didn't know my sister.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know where she was, though she wasn't too far from where I was in Bitterfeld.",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "She was in Mauthausen.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And that wasn't too far.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "It was about 20 kilometers or something.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "But that Kitty Hart-- she was a tomboy.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "She was only 12 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "She took-- went on a bike, and she went there on a bike.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Her mother was furious.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And she saw my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And she came and she said, Kotek, she used to call me because that's what--",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Was my-- Kotek is cat.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "That was my name.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I picked a short, little name that I remember and when I--",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I thought kotek meant aunt in Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Kotek is a kitten.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I wished-- I wished all the time that I was an ant-- that I was a bird, I was anything but not a Jew--",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Not an ant, no.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "An aunt or an uncle, I didn't mean an ant.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a aunt or an uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I didn't expect that-- in the States we had no family.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Nobody ever emigrated.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "That's what you're interested?",
      "word_count": 4
    }
  ],
