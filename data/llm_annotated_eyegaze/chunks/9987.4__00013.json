{
  "stem": "9987.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "I stayed in Los Angeles one day.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "The next day I had a job, and I worked for 30 years without a stop.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "We had another child in Los Angeles.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 25,
      "text": "We established ourself very nicely.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 26,
      "text": "This country was very good to me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 27,
      "text": "Within a year, I had a car.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 28,
      "text": "Within two years, I bought a house.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 29,
      "text": "I educated my children.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 30,
      "text": "My son is-- is-- is a medical doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 31,
      "text": "My daughter is a very educated person.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 32,
      "text": "She is a Psychology major.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 33,
      "text": "And we have beautiful grandchildren.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 34,
      "text": "We have a beautiful life-- something that I could never have in Poland even if I stayed there for 2,000 years.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 35,
      "text": "And that's about the story.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, in my story here, I never mentioned the names of my wife, how she got through the war.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I never mention-- that has nothing-- I never mentioned my children.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "[INTERPOSING VOICES] My wife's name originally was Gusta [?",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Friedmann ?].",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Now, when we came to America my sisters didn't like Gusta, so they named her Gertrude, and she hates that name all the time.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "She would rather change her name back Gusta.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "My children's name, my son's name is Jack, after my father.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "He was born in Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "He's now 49 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "He's a physician in Los Angeles.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "[INTERPOSING VOICES] My daughter is Marlene.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "Each one have two children.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "My son has a daughter named Tara and a-- and a boy, Alex.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "He's going to the University of California.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "My daughter has two sons, Daniel and Jesse.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "They are all happy families.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "They all have their homes.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And we have a very close family together here.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "They all live in Los Angeles.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They all live in Los Angeles.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, I guess it was my luck.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Or maybe it wasn't.",
      "word_count": 4
    }
  ],
