{
  "stem": "27150.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "What we found out later-- [PAUSES FOR 3 SECONDS] that the ship was canceled on account of the elections in Australia.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Chifley was afraid that in one lot, if he takes in 300 jews, and the press will pick up the news, he might lose the election.",
      "word_count": 26
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we got stuck in the two ballrooms.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "How long were you there for?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "A couple months.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Playing around, you see, that means we make a connection with the American-- the English Army.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "There was a fellow foreman, who was running a troop, an English entertaining troop, and he was playing the-- The Bumblebee, and et cetera.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And we went together, and then you see that means he was going with an entertainer for the English Army, but he was doing big black market.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And-- and-- that means we-- there was a strike on the ferry, between Kowloon and the island.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we used to hire boats and go in, in there, and singing and-- and happy.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well an experience, you see, that means like you see we were still young.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "You see, I was 31, but I-- I missed the 5-6 years.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "So I was sort of still young, like we were in a camp, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Now mister-- we found, you see, that means we, being looked after by the Russian Jews, we learned Russian in the peninsula had a manager, a Russian manager.",
      "word_count": 28
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And he gave us a room, and we were making parties, the Polish Group.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "You see, there was a captain, a Jewish nationality, a Jewish captain of the American army who was running our group, the 300 people from Burma.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And he lined up two freighters who were going back to Australia without freight.",
      "word_count": 14
    }
  ],
