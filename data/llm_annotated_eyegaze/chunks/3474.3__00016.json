{
  "stem": "3474.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And then we met the other sister over there.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We find other sister.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We just ran into each other just by blind luck, luck, pot luck.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We were in Budapest for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we went to Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And in Czechoslovakia, the Czech gave us housings.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Because the, the Germans ran away.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "It was also in Sudeten.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "They give us housing there.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "They treated us nice.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "They gave us jobs for awhile.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And we stayed there for awhile.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And then they drafted my brother into the army.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And just a little while after that, they start talking about communism.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And they started talking-- the, the party, join the party, and this and this.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "My brother knew what communism was already.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "He came home.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "He says, we're leaving.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "So he left, [INAUDIBLE] from the army.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "He says, I'm going to [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "So the next-- the same day, he went across the border.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "And then a few days later, we followed him.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "1945, [INAUDIBLE] 19-- beginning of '46 I think it was.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, 1946.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "No, it was in beginning of 1946.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Already, already, it was getting-- started getting warm already.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We came to Munich.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "We got a train into Germany from right across from the Czech border.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "We got a train, because there was the Bricha, Israeli-- the [INAUDIBLE], the Zionist.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "They was-- they wanted to [INAUDIBLE] to go to Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Or anybody who escaped from the countries, from their countries, they helped us.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They-- no, they took us.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They took out-- the Bricha, they took us.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "The-- they special-- they had special people from Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "They helped us go across the border.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The Czech helped us, too.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "You know, the Czech people were nice people.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Then we got to Munich.",
      "word_count": 5
    }
  ],
