{
  "stem": "7777.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "No, well, but there-- Over there, the rumors was coming, a lot of people.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And people wasn't the freedom.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "They was working in the street, but in the stores, was not too much.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "All the restaurants was open, and people was living not bad.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Only, like I did, little bit black market.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "In the meantime-- was over there tow truck, like Maxwell Street.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You hear about that with Chicago?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I went to Vilna.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I went to Brest.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I bought something over there, and I went out in this little truck to sell it.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "One time, the police got me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I have some-- some kind of letter to sell off the tow truck.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "They bring me to the [INAUDIBLE], the Russian.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Was about 11 o'clock in the daytime.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I don't-- nobody asked me nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I was sitting and waiting It was about 1:30 already in the morning, I am-- some man come over there, what called me in.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "He called me, he says, [NON-ENGLISH SPEECH]-- black market, [NON-ENGLISH SPEECH].",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "He asked me.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I told him, I come from the other side of Poland to here, and I don't have what to live.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I have this letter what I have, and what I bring from Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And I was selling this.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "I want to sell it to be able to exist.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "He let me out, and I was-- I was doing again black market.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "I was careful.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "It was-- There was so many people in Wlodzimierz or in Brest, [INAUDIBLE] or on some-- Lwow, was a lot of refugees living.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "Is the Russian government make announcement, all this [NON-ENGLISH SPEECH]-- they call it [NON-ENGLISH SPEECH]-- to take passport, to get to be a Russian citizen.",
      "word_count": 25
    }
  ],
