{
  "stem": "1733.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He went-- he came to the United States for business purposes, to be able to earn a better living, and also for reasons that he had to leave the business in Czechoslovakia at that time.",
      "word_count": 35
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "At that time, we were a family-- my mother, myself, my brother, and my sister Magda.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "That was in 1929.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "A year later-- actually not a year later, about six months after my father left, my youngest sister was born.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So when he came to the United States, we went to Loucky to live with our grandfather.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Our grandfather and grandmother and our family were living together.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "My mother helped them run the business, and all the aspects.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Was that your paternal grandparents or your maternal grandparents?",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Maternal grandparents.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father went with the idea to bring us out.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But my mother was very reluctant at the time, and she was hoping that he would be able to come back, because she was close to the family.",
      "word_count": 28
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She was close to her grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They were not in very good health.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And when the decision was made that we should come out, he should send us paper to come to the United States, it was too late already.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And we got stuck there.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "A little Hungarian my mother spoke sometimes with her sister.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But primarily, we were speaking Yiddish in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had radio already.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We had newspapers.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And primarily the news was generated when we went to minyan every morning, to the shul.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And we sat around the stove, the heated stove, and everybody was talking about the [INAUDIBLE] events, what's going on in the world.",
      "word_count": 23
    }
  ],
