  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "The Polacks, the Ukrainian, the Lithuanian, I don't know but they say, that the-- but the Ukraine and-- and the Polacks I went on my own skin.",
      "word_count": 27
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
