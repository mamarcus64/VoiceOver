{
  "stem": "7093.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "But I got it through my father, through somebody knowing my father, the ambassador in Paris knowing my father.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "But it-- when it expired, it wasn't renewed.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "They told me, you, can't consider yourself Hungarian.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And I couldn't get a passport.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I had no paper to, to get out, to go somewhere else.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I wanted to be nationalized South African to be able to get out, to get a passport and get out.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And because my husband did various things, we just couldn't get it.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And it took nine years to get it.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So finally, '57, 1957, we got it.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But I was decided that eventually, I'm going to leave him, that I don't, don't want to stay.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we came to England.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And here I started-- I found that my qualifications weren't recognized anywhere.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So I started as a writing addresses at advanced [? laundry ?], and doing ledger clerk and doing all kinds of thing, any job that I could get.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he got into the philharmonic orchestra and worked there for quite a long time.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And I, I eventually started working at [INAUDIBLE] Library.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But I found that this was no life.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I just couldn't stay with him.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I mean, we had no life anyway together anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I was just running his house.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "So I didn't want to stay with him.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "My son always had to be in a boarding school, because I-- they couldn't be together.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "They hated each other to such an extend.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "They never could build up a relationship.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "My son was so terrified of him.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "He never touched him, but he was so terrified of him that he couldn't-- so I always, he always have to send away.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "Because I just didn't earn enough to support both of us.",
      "word_count": 11
    }
  ],
