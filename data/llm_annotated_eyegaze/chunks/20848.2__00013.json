{
  "stem": "20848.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "They made the factory Rgrodewa 29 where we lived before.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "And my father was very friendly with the owner of the house.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And because we were going every day there to work, my father and the owner of the house and another man, an engineer, they made a bunker for us in the cellar.",
      "word_count": 32
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And the caretaker was Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "He wasn't Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "And the bunker was prepared with everything.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "There was water and-- and food and clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "And only the caretaker knew about it.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "And we knew that one day they're going to come and get us.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "So we decided to stay the nights over in there and never come back to the ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "But I'm running ahead of myself.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "One day they made what they called-- well, as I said, I was working there.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "My parents were working there.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "What they used to do, the Germans, they used to bring socks from the front.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "And what they-- we did in the factory, we used to cut off used socks from the soldiers.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "We used to cut off the foot pad and used to make new-- we only kept the uppers-- and we used to make the new foot pad.",
      "word_count": 27
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 26,
      "text": "And [LAUGHS] I had this wonder-- I was so fast I used to put it on combs.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 27,
      "text": "I don't know whether you would realize what it is.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 28,
      "text": "You know, when it was cut off, it had little eyes.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 29,
      "text": "And I used to put the little eyes on combs and give it to the machinist.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 30,
      "text": "And the machinist used to put it on the machine and knit.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 31,
      "text": "And I was so fast, I used to work at night shift.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 32,
      "text": "I was so fast that I used to get extra bread, you know.",
      "word_count": 13
    }
  ],
