{
  "stem": "22447.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I know she made the selections at Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But what I don't know is who saw her do it.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "That's why we've had to let her go.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We've had her here three days.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And we've got to leave her go.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "So she said, well, I saw her do it.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] So when she said that, the mug of tea and the tea fell out my hands.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Here, we've been trying three days, frantically trying to find someone that see her.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And here someone comes in at the last minute and says she's seen her do it.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "She's seen her make the selections.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So I said, well, how did you see her make these selections?",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "So she said, I used to play in the orchestra.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "So I looked at her, I said, what orchestra?",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "She said, there was a string orchestra outside the crematorium by the gas chambers.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "To drown the screams of the people, they used to play classical music.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 4 SECONDS] I'm looking at her, and I said to the sister, did you also play in orchestra?",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "She said, no, she had a job in the office.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "She spoke a few-- English, German, French.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "She spoke a few languages, so she used to be an interpreter and run errands for the Germans.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So she used to see through the window in the office when she used to make these selections.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So she said she used to see it.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I said, forget about the tea.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I called over to the fellow she was talking to.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I said, bring her back.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She's going back into the, into the cells in the bunker.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I went downstairs.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I said to the sergeant, get the charge sheet out.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I got two witnesses.",
      "word_count": 4
    }
  ],
