  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And he decided that it's time for Jewish students to go to Israel and see what Israel is.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And he went to Israel, and he made a program of a six and a half week program-- study and travel.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And every summer, 80, 90 students from Gratz and from the synagogues all over the city of Philadelphia-- Cheltenham, Abington, all over-- went with Gratz College to Israel.",
      "word_count": 28
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "But they had to study too.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "It wasn't just travel.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "And there was a certain program.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "And I went for 14 years, every summer, with a professor, because there had to be professorship too-- not enough teacher, because they got credit.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "Even Penn gives them credit.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "And we studied and traveled.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "I went up Masada 100 times.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "[LAUGHING] And that was the program.",
      "word_count": 6
    }
  ],
