{
  "stem": "15610.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "We've been in Be'er Sheva, and the kids went to kibbutz.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Four years.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "And here in this house live my brother-- live my husband brother.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And he wrote us letters that he's very sick and whether I can come and help him.",
      "word_count": 17
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "But family decided that yeah, that I have to go because they-- he was my husband.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "Stop?",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Continue.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "He want my husband here to come, his brother.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "But Paul say, what-- what's father can help?",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "He wasn't-- he didn't know how to cook and to clean and take care of a sick person.",
      "word_count": 18
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "They decided that I will be the-- the person who can-- he can use me.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "So I came here by myself.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "All my family, I leave there.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "And I have [INAUDIBLE]-- you know [INAUDIBLE], what it is, a Zionistic Jewish organization-- I have a job there.",
      "word_count": 19
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 8,
      "text": "So I leave the job, my family behind, and came here.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "'69.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "They came maybe-- I came-- I think in one year, they came.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And all three, they came-- Julius, my son, Paul, and my husband.",
      "word_count": 16
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Sonia, she was married, so she-- she stayed there.",
      "word_count": 9
    }
  ],
