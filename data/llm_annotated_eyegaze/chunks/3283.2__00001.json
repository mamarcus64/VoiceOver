{
  "stem": "3283.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I remember she told the rabbi, if you take more than five minutes I'm going to walk out.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "So we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And then we were both busy with cases.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And we took a short trip to Albany and then back.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And she was in her own office at 51 Chambers Street.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I was at 299 Broadway, just a couple blocks away.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And we got together several times.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I sent-- I went to the bookstore.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I sent her some books that I was reading that I liked, I gave her.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And I sent flowers.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And then eventually, she moved into my office and we were doing law business, Kronhart Kronhart.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And she had some very important cases, too.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "Very important.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And she also was a labor lawyer.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And then we moved to 80 Wall Street in the Wall Street district, right down the street from the Treasury Department and the stock market.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1938.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "No, '37. '38, '39, '40. '40.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "In '42, when the war started, one morning she came into the office and said, Al, there's a war going on.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to Washington.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "So I said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "You go to Washington.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "We had some cases to try, but I tried them.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "She went to Washington.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And Wayne Morse-- he later became a senator-- he was the head of the National War Labor Board.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And he hired her right on the spot.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He became a senator later.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "A very-- I met him--",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I met him too.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We went to lunch, my wife [PAUSES FOR 4 SECONDS] and the-- the one that headed the War Labor Board.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We went to lunch.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And then, when at first I visited, she was sitting with the BOARD every night.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They were so busy.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "John Lewis--",
      "word_count": 2
    }
  ],
