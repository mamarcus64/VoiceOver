  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And one of-- I think-- took him out of the ghetto and brought him to Bochnia.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And he was there maybe three or four months, until something happened in Bochnia.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Then he came back to-- So you-- so there was always a--",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Always action, always action.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "But there was always somebody telling--",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Telling.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Believe it or not, this murderer, this terrible, terrible murderer, through him, I think I have saved my son.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He saved my son.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, no relationship.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He was just the guest in his house-- no relationship.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "No, not yet.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Not-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "That wasn't-- that-- that wasn't so far yet.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "That came-- that was a lot of time yet to give encouragement.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I left Plazsow for Auschwitz in 1944.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "At the end of 1944.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
