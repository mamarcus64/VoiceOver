{
  "stem": "10478.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And it was a surprise, of course, on May the 10th, all of a sudden, we was-- woke up in the morning, and there were hundreds of planes in the air.",
      "word_count": 31
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "And we had-- and, well, it was a shock.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I was in the hospital, at that time, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I had a kidney ailment, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "My family was living in Maastricht, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "All lived in-- at their home-- at their  home in Maastricht, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Not right away.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Not right away.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "The-- we were, at first, scared.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And then later on, they-- everything went back to normal.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And we, more or less, believed that there was nothing going on right away.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "That came on later, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Well, the streets were, of course, filled with German soldiers.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Wherever you went, you know, there was soldiers walking around in uniform.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And also, some pro-Nazi Dutch people went on the street in their uniform.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And they had their own thing, set up their own party, the NSB.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And, and they had, had the same greetings as the Germans did, the Nazis did.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "So that was that.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "That's right, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Not much except, of course, that, that we had to use food stamps for food.",
      "word_count": 15
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "And there was-- less and less food we got, and bread, and meat, and butter, and that kind of stuff.",
      "word_count": 20
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "There were--",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "--rations yeah, right.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yes, later on, they had a curfew.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "You were not allowed to go on the street at-- after 8 o'clock.",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, until early in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "That's right, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "There was-- there was plenty of work.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "It was-- lots and lots of boys, aged 18 and 19 were taken away and brought to Germany for-- to work for the army.",
      "word_count": 24
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "So-- and there were quite a few.",
      "word_count": 7
    }
  ],
