{
  "stem": "26140.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We were-- it was in the evening, about 5 o'clock.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Ground, it was thick frost.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "It was February.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And we were moving, going, and then German-- German had their patrols on, and they stopped us, asking where are we going?",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I try to explain, with my brothers, that we were looking for some-- in order to buy some food in the village, because there was shortage of food.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't accept this and locked us up at the prison.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they-- they were very hostile.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And they-- they tried to tell us by beating, tell us you wanted to join the Polish legionaries, [INAUDIBLE] in Hungary.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Speak the truth.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And I said, we-- but we only went here to look for some food, to bring to Poznan, to where my parents lived, in Krakow.",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Because they were moved to Krakow later on.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't believe us and locked us up in prison.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Well-- well, very poor.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't eat at the beginning.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The food they gave, it was a slice of bread and very watery soup.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "First day, I didn't-- didn't manage to eat anything.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "But the next day, I felt hungry and I tried to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "It was in Sanok, the prison was.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And-- and they brought us three times for interview from the prison, in order to-- to get from us-- to speak the truth what we were trying to do.",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Each three-- three of us went, and each was interviewed separately.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And every time we were beaten in order to get the confession.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We knew that if we confessed that we were trying to join the Polish forces, they would shoot us, because they did so in many other prisons.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "All those who confessed they wanted to join the police forces.",
      "word_count": 11
    }
  ],
