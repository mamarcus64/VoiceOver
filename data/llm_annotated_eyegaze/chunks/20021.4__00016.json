  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And we want to honor this agreement.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "That the total number of Jews in this house will never exceed XYZ.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So you arrive now.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "You have to make space for others to arrive after you.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "So you must leave.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And you leave towards Budapest, see?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And they, again, told us that somebody, again a smuggler, will help us to go.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We get on a train, and we go to Presov, which is quite a distance from that Svaty Liptovsky Mikulas.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And in Presov, there will be somebody who will help us to smuggle the border into Hungary.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Unfortunately, we managed to arrive to Slovakia safely, and we managed to cross practically all of Slovakia on the train to Presov.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But that smuggler, instead of handing-- helping us, almost handed us over to the Hungarian police, and we got arrested and sent to jail in [NON-ENGLISH], which is a big jail, you know, in-- in Budapest, big, giant jail, heavy buildings.",
      "word_count": 41
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    }
  ],
