  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And he said, yes, and we'll go overseas.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And you will live a normal life.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I said, that is very, very nice of you, and very sweet of you.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And I do appreciate it.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I really do.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I'll never forget it-- forget the offer.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "But how can I lead a normal life knowing what the Jewish people, my people, are going through?",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "I belong with them.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "What happens to them will happen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "We'll break for the end of the tape.",
      "word_count": 8
    }
  ],
