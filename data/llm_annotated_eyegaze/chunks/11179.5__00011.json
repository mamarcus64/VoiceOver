{
  "stem": "11179.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I was really never sorry I did.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I was really never sorry I did.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Some people said [SIGHS] if you work with your hands, you'll be regarded as somebody dumb or something like this.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I have-- I was already in the trade.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I was in the union.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I was in sheet metal worker's union.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I had never any real problem.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I had never any real problem.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know if I should mention this, but I'd like to.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "There was a-- there was a 1933 club, which still exists here, for refugees from-- from-- from Germany, [INAUDIBLE] and they had a youth group.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And that-- we had a speaker from the Jewish Community Council at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "That was before they were on 590 North Vermont, even before that.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And they advised people to stay away from the trades.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Jews-- Jews would be mistreated and should stay out of the trades.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I never forget that.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I've-- too bad I forgot the name of the man-- the name of the man who said that nonsense remark.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I met many Jewish people in the trade that were born and raised here.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I did not have any problems.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I have heard remarks, antisemitic remarks, at one time or another.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And I stood up and said, I'm sorry, I'm Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Oh, they apologized.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, what can you do?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You live in this world.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "The way-- people are the way they are.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But when they apologized, and some-- some-- some-- some are kind of sheepishly apologized, I accept it.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "It didn't happen very often.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Really, I must say, it did not happen very often.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I didn't stick my nose out of business-- out of other-- I didn't stick my nose in other people's business.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I mind my own business.",
      "word_count": 5
    }
  ],
