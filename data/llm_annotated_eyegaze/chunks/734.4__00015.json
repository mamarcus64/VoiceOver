  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And they also know that the Germans are not about to let them survive.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "Because as soon as the Germans notice that they lose the war, that they are going to lose the war, he said, they're going to do away with us.",
      "word_count": 29
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "That's a fact.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "That they've done it, he said, before.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And they'll do it again.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So that he said we decided that we are not-- we-- we are-- we are going to fight back.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We are not going to let them kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And then he said to me-- and then he said to me, you are one of us.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "So you can imagine how I felt.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
