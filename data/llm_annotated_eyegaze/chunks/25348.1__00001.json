{
  "stem": "25348.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The Germans, on entering Lwow, they transported-- after entering Lwow, they transported about 15,000 Jews to Bergen-Belsen, who were never heard of after.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And they, [PAUSES FOR 4 SECONDS] they arranged a ghetto in special parts of town and also working camps.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And I was not in Lwow at the time.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And I need to expand on this to explain my case.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I grew up as a child in Lwow.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I had two brothers-- one was-- his name was-- [PAUSES FOR 3 SECONDS] this is where I become emotional.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] His name was Moses Lieb.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he was 14 years older than I.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And I had a younger brother who was only 18 months my junior.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "My older brother studied in Paris, being so much older than I.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And we were-- he was a little bit detached from the family because he spent most of the time in France.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Unfortunately, at the start of the war, he came home.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] My father lived with us in Lwow.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I want to explain this.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "My parents were divorced when I was six.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And this is where I get back to where I was during the war.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "I'll get back to you.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I went to a-- my friends were mostly Jewish, though I had some-- I did have some Gentile friends.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And I went to a Catholic school because Catholic schools were public schools in Lwow.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And strange enough, it was one of the regions in Poland where you could say there was a class ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And I'm talking as a girl of under 14, who from her seventh-- from her time of enrollment-- the enrollment at the primary school in Poland did not start until seven, so-- the age of seven.",
      "word_count": 36
    }
  ],
