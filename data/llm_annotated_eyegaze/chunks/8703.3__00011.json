  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They took about 300, 400 to Werk C, 400 to Werk A, and werk-- to Werk B.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And my brother and me were sent to Werk C.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "My sister, Rochelle, went to Werk A, A, Werk A.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I was standing over with my brother together.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "He just went between my brother and me.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "They divided.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And I went to work to a different place, and he was a transportation.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Transportation.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "But I was assigned to work in a factory which produced and made underwater mines.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "The material was a chemical which was a powdery chemical pressed in squares, in a certain squares.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "It was two by three by five squares, solid squares.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And we had to work a norm, a certain amount to produce.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And in the beginning when we were still healthy, we could do it hardly.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "Because they figured out if you can do five a minute, five one minute, and 60 times, five, 300 per hour, and so on and so 2,500, for instance, a day during the eight-- the eight hours of work.",
      "word_count": 39
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And it was very, very hard for us to produce these things.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "That's what I was assigned.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "I was-- I was-- OK.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "I was assigned to work in [NON-ENGLISH SPEECH].",
      "word_count": 8
    }
  ],
