{
  "stem": "25651.15",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And, [PAUSES FOR 3 SECONDS] we get back to London and I got a job with a company making industrial models of chemical plants.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And Eve was-- became highly pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Her parents came.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We got married in Haifa, actually, because we traveled to Haifa for the wedding and then came back.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We had a honeymoon traveling across Greece, and Italy, and France, back to England.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I finished my apprenticeship.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I resigned my job in-- at Warton Aerodome and came back to London.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And then I started working for this company making tonnage oxygen plants.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And then I started building some very large projects.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I left them and worked for another company.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Jonathan was born about five years later, 1961.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Then we bought a house.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And because of going to college in London and because of my activities in Habonim, I had lots of London friends.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "So Eve suddenly had a sort of young group of people around her.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Other people, you know, old girlfriends were in the same situation-- children.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So we just stayed in England and kept visiting Israel often.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I know Hebrew so-- from this course that I did in 1948.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I had a sort of happy family life, except Eve herself is a survivor.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But she can't talk about it.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She can't bring myself to.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "She's told me some stories, horrendous stories, as well.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They were in hiding for five years.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But she was two when the war started.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And she was eight when the war was over.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And, to her, it's sort of colored by her mother's attitude.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Her mother is also in hysterics about their time in hiding.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Their father-- her father, he, he said he would write it down one day.",
      "word_count": 14
    }
  ],
