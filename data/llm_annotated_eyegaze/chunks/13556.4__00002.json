{
  "stem": "13556.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I used to make-- they used to hang them up on the wall, different kind-- swans and different kind tigers and different-- and I used to sell them.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I make a little bit money.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I dress up myself.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I was ashamed to come to places where people know me not dressed.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And then I would dress up myself.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I came over there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I met people.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I came to Rowne.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I met some friends.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they told me, Leon, it's time to be married already.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Why, you see, to perform, I didn't go anymore after this.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My morale, morale was low.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I figure up maybe they'll not let me in the big cities.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I have a stamp.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I'm stamped already.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "As a bad label, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "When you're in jail in Russia, bad label in society.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And they're not accepting you.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I met a cousin, my wife's.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And he told me, I want you to be in my family.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And he give me her address.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I came.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And she was living with his sister.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And just they came from Siberia, and I saw it.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "My-- I, I didn't overprice myself.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I didn't overestimate myself.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I know my nerves is not the same like used to be.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And I see this is the right person to understand me.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And I decided to marry my wife.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "We fell in love and--",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "--sent letters.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And she sent me a couple of letters.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And we married.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, excuse me, I missed something.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "When I-- before this, when I left, I came to Rowne-- after the jail.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I decided I want to go to, to Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Then I came to committee to give my papers--",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "--to apply to let me to go to Israel.",
      "word_count": 9
    }
  ],
