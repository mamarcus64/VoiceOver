{
  "stem": "5516.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my father-- my mother was going according to--",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "--the whole family had to--",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "--go, you know, a little bit [LAUGHS] in the background.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "All, all holidays-- we observe all the holidays, especially the holidays where we used to be-- Easter and the High Holidays.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Passover and the High Holidays, Yom Kippur and New Year, see?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "This holiday, when we grew up and my brothers and sisters was married with children, that we used to come in all together in one place in Panevezys.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And we used to celebrate the holidays all together.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And all our stores all over the country used to be closed.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And they used to come in all together to be in one place.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I was in this time as not a small kid.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But I liked it, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We used to wait for that, you know, because it's not like today, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "We used to go-- maybe two months before the holidays, my mother used to prepare everything, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[BACKROUND NOISE] You couldn't go in the grocer and just buy the stuff, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They, they used to make the-- everything-- prepared to have everything for that.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Who is that?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Matzah-- we bought matzah.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We used to buy it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But this same-- a long time before holiday, we used to buy all the matzah should be-- for sure we have the matzah--",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "--in case they will run out.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We had-- the house was-- the-- our factory's a rope, rope factory.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We had a lot of land, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And we used to live in the-- in the same place where the factory is.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we had two houses there.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And after this, we build that big house at [NON-ENGLISH], you know.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In the same place.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Same place, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
