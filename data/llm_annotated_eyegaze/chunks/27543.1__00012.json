{
  "stem": "27543.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The Sergeant [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "There was guards, Hungarian guards with bayonets and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't run away, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no Germans there at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, you couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, you couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "We had night time, we were-- the three days we were there, or two days, we were locked up in a barn.",
      "word_count": 22
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "You got to beg to-- you had go out, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "They put us about 50, 60, 80 people in a barn.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And they left you there.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "They were going around.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "There was younger guys with guns and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "So you couldn't escape from there.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I know-- I know a lot of them.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "They-- they had girlfriends.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "Or excuse me, a lot of Jewish boys had girls there, you know, what they call those-- no.",
      "word_count": 18
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Pimps, you know a lot of them, they have girlfriends there.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "They hide them.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "There was a lot of hide them.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "A lot of Jewish guys married Christians.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "You know, I told you.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "They didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "Later on, come in the law that you had a-- you had a white thing.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "We had a yellow, my two cousin's kids.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "A lot of them escaped, you know, who their friends where to go.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "They went to the village.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "Or you went someplace, just with my--",
      "word_count": 7
    }
  ],
