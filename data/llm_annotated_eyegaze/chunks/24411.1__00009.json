    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "And then, when she came down, she was sitting with me and she said to me, just like this-- if I would have the power, I would tell the Germans where all the Jews are.",
      "word_count": 35
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I said, what are you talking about?",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "I'm Jewish too.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "So she said, I don't mean you.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "I said, thank you very much and I went up to my parents' house.",
      "word_count": 14
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "We'll continue on the next tape.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
