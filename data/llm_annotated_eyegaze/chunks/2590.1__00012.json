{
  "stem": "2590.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And it took me a few days to come to her because I had to walk only when it was twilight.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "I was afraid I shouldn't be caught again and recognized.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And when I came to Nadia, she said, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "She said, your parents and your grandparents were good to my parents and to me.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "And I am going to hide you.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "You're going to stay with me.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "You'll be in the attic.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And many times, you know, there was no toilet, and I had to go.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "And she had to take out the pails of it.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "And she came, she started to curse.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "And she got very nervous.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "And she used to pull me from the attic into the house and hit me with an iron stick that she shovelled coal in the oven.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "And she hit me.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 37,
      "text": "She pulled my hair.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 38,
      "text": "And she tore my dress.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 39,
      "text": "And she said in Polish, [POLISH], meaning that you Jewish ghost, just get lost.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 40,
      "text": "And she would chase me out.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 41,
      "text": "But she was afraid that if the Germans will find and they'll torture me so much, so long, that I'll have to reveal where I was until now.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 42,
      "text": "And I was by her for a year sitting in the attic.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 43,
      "text": "And, finally, she really wanted to get rid of me.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 44,
      "text": "So I sent her to the Czech woman where my uncle was hiding.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 45,
      "text": "And my uncle started to send money.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 46,
      "text": "Every second week, he sent money in the letter.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 47,
      "text": "And I used to give that Nadia all the money.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 48,
      "text": "And one day, my aunt asked me in the letter if I saved up some money for an emergency.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 49,
      "text": "And no, I was young and didn't think about it.",
      "word_count": 10
    }
  ],
