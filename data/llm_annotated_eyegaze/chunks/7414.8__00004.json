{
  "stem": "7414.8",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "People were going from one country to another, the soldiers and-- somehow my sister got the news that I am back, and she sent me a message through a soldier, because she was quite a big shot in the army.",
      "word_count": 40
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "She's sent me-- This is your Rushka?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Rushka who lives now in Los Angeles.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She sent me a message, come right as you are to me.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So to make a long story shorter, because my husband got sick in meantime, so we had to stay.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "In it was April, we left for Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I had only--",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes, '45.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I was still crossing the border with my German papers, although I had the certificate from the Jewish community that I'm Jewish.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we crossed to-- we went to Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "My husband was short time with us, but he had to go back to Poland because he had some unfinished business.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Because they, in south of Poland, they were liberated much, much earlier than I was.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And see, I was still nearly to the end, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "It was on the other side.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "But they were liberated much earlier.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "But to illustrate that how the Poles never thought-- one thought that I could be Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I was standing-- I did not know the value of money then.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I did not know how to buy a-- I did not have money for such a long time.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "But anyway, one day I went to the marketplace to buy something to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And there stands a peasant woman with a chicken.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And next to her stands a Jewish girl-- girl-- she was a woman my age, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And she recognized me, and I recognized her all right.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "She was bargaining for this chicken with this peasant woman.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And I approached.",
      "word_count": 3
    }
  ],
