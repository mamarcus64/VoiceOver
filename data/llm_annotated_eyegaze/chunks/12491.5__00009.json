{
  "stem": "12491.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And this is where I lived until January, 1946, at which time my future wife and I and the boy I mentioned before went-- who was hiding in the latrine-- went to Bergen-Belsen, where we lived until we came to the United States.",
      "word_count": 43
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "When I-- on my last trip to Poland, where I took the 16 people back out, he was in the-- in one of them.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He-- at that time, he was operated on his middle ear.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he was sent by whoever the medical profession to a, like, a sanitarium, which would be like a, like a convalescent home out of Warsaw.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I-- when I travelled to Poland, smuggled, I always had an assistant.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I said the assistant-- I paid him an airplane ticket for helping to go there and bring the, the kid back.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He was now, at that time, eight years old.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And he was actually my future wife's cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "This is how he's my cousin, you know, my blood cousin.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And he was one of the 16 people I smuggled back to Austria.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "That was my last trip.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I never came back.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Never went back.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Because my future wife's mother was still there.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "There was a-- a camp, a DP camp-- very large.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "At one time, if I am correct, there were about 40,000 people there.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And we lived from day to day.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "They distributed food, they distributed some clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "But this, of course, wasn't enough for a person as active as I am.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "So I had to do some business.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "I started traveling to Hanover first, because it was closest-- about 35, 40 kilometers.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Then to Hamburg, which was about 100 kilometers.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And then to Cologne, which was about 350 kilometers.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And started doing business.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "You name it, I bought.",
      "word_count": 5
    }
  ],
