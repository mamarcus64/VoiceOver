  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "I know my mother did the best way she could because she had a hard life.",
      "word_count": 16
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "When I work from the beginning, like with that Chaim David Schmidt.",
      "word_count": 12
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And then I went in another town in Eishyshok.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "I worked down there.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "Down there I get better paid.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 5,
      "text": "And I [? settled it ?].",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 6,
      "text": "And then I went-- from then, I went to Radun.",
      "word_count": 10
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 7,
      "text": "From Radun, I used to go every day with a bicycle, from Nacza to Radun, 11 kilometers.",
      "word_count": 17
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 8,
      "text": "And then Friday, he keep me long.",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 9,
      "text": "And then it comes in Shabbos, Friday night.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 10,
      "text": "Then from the [INAUDIBLE] the rabbi, they find out.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 11,
      "text": "They tried to stop my bus to keep me so long to not to go in [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 12,
      "text": "Oh, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 13,
      "text": "They was-- I heard it was stuck, and they did nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "I stayed for a few years.",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "For money.",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "I don't get any paid.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Next, I lost my job.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "And I was for quite a while without work.",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "I was home.",
      "word_count": 3
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "They used to come to Eishyshok I was staying in Eishyshok.",
      "word_count": 11
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "I helped my uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "And then the army, then I went to the army.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was-- I was drafted.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "21.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "May-- February 16, 1938.",
      "word_count": 4
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "In Vilna.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "I was attached to artillery.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "I tell you in Polish or in English?",
      "word_count": 8
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "The First Regiment Artillery-- Light Artillery Legionaries from Joseph [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "The-- what do you mean?",
      "word_count": 5
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "The-- the Colonel?",
      "word_count": 3
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "I don't know the first name.",
      "word_count": 6
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I remember the second name, Lapicki.",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "No, it was a few more.",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "Eight, I think.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Some of them, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "There was one [?",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "Glombotski, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "Schnea ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "Glombotski ?], and was one [?",
      "word_count": 6
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "Ullman ?], from another town.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 6,
      "text": "One was [?",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 7,
      "text": "Rappaport. ?] One was [?",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 8,
      "text": "Kruvski, ?] a good friend of mine, [?",
      "word_count": 8
    }
  ],
