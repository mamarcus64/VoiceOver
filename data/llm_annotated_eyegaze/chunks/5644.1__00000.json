  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "David John Landau, L-A-N-D-A-U.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did have during the resistance-- Jan [INAUDIBLE]",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "1920, the 1st-- the 15th of March.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "75.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Warsaw, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The memories have begun to outweigh the plans, and there is nothing abnormal in that.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "What is out of the norm is the cage of the past in which I am locked in for the rest of my life.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "The cage does not exist outside my mind, but it is as real to me as if it were made of steel rods, cast in concrete, and fenced off with barbed wire.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "If, by some chance in the natural laws, I were to live for 1,000 years, I would still remain caged in that invisible jail for the full 1,000 years.",
      "word_count": 29
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I am not the only one trapped in such a cage.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I belong to a breed of people which I have never-- which have never existed before my generation and will be extinct from the human race within the next 20 to 30 years.",
      "word_count": 33
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "All of our breed suffer from the same apparition.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "The breed is called survivors, because we cheated the huge Nazi killing machine of death camps and ghettos and came out alive from places where we were meant not to survive.",
      "word_count": 31
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "We live in a time warp from which only death will release us, and each of us carries within the mind an imagery cage which dominates our lives.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "Those who have become my friends or who have known me after I passed the age of 25 consider fate that always smiles on me.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "This is not the whole truth.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "They don't know my younger years when fate and I were locked together for years in one cage.",
      "word_count": 18
    }
  ],
