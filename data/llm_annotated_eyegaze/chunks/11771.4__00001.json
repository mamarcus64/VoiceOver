{
  "stem": "11771.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And I find out that is a relative of my father-- not a cousin, a second or a third cousin, but they know each other.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know him.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "He opens me the door, and I say, I'm [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "What is his name?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Livitowsky.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "His name was Livitowsky, Jesl Livitowsky.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So I say, I am [NON-ENGLISH], son of Manny.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I tell them a short-- this story.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I run away from the massacre.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I met Judy.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "They took her to Lida.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "In Lida, gave me an address to a Polack.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I gave the name.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I gave them [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "He say, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "But you cannot go there at night, because it's the other side of the town, and they'll catch you.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Don't go there.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "I'll show you tomorrow, next day.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "When I came in, I told them all the story.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "You know, they gave me whatever, a bite or a drink.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And [PAUSES FOR 4 SECONDS] it came out that his son-- he lives in Israel now-- was on the same list that Judy in Ejszyszki, he was on the list in Voranava.",
      "word_count": 32
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "He was participating with the Russians while they were occupated there.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And he was also in hiding.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "But he was hiding in the house in a double wall.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "But he never came out to me.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "He told me after, when I saw him in Israel a  dozen years later.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "Anyway, they gave me a place to sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "Next day, he told me-- he took me to the-- first of all, to the Judenrat, because the Judenrat there was a, a, a resident from Ejszyszki.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "Incidentally, for the last couple of years before the occupation, he moved over to Voranava and he became a Judenrat of the August in Voranava.",
      "word_count": 25
    }
  ],
