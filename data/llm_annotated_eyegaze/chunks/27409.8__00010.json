{
  "stem": "27409.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I didn't-- from work, would never become a millionaire.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I didn't become it.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I didn't try.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "But I was a free man, you see, respected and all.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I worked, also, in the community.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I lived in Palmer's Green.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "First in Tottenham, then in Palmer's Green.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I was active building bridges with the non-Jewish community, because you have to-- I-- I got friendly with the locals, the British.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I was chairman in the local Church of England school.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "I was a Parents Teacher Association.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "I was in a police committee.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I was in the local residents' association.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "All where I could help build bridges with, to show that a Jew is not only here to exploit.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Intellect is [INAUDIBLE] recognized and they liked me.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes and not.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Not direct.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "It didn't-- if you could call antisemitism, not proper antisemitism.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Not knowing-- many didn't know that I'm a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I had, for instance, last Rosh Hashanah I went to shul, synagogue, and I was dressed up.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "A colleague of mine, which was for years with me on the various committees, English-English, told me, oh, you are going-- it was Sunday morning-- oh you are going to church so early?",
      "word_count": 33
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I said, no, I'm going to synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "We have the new year.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "What, are you Jewish?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "She just could not understand.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I'll give you an example.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I was in uniform, in civil defense, and I was asked to a party.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "If I ask for a dietary food, Jewish dietary, I said, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And when I sat here it was a major general next to me, and the other was the Bishop of Sussex.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And they were surprised seeing me eating different things than them.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Saying, oh, are you Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    }
  ],
