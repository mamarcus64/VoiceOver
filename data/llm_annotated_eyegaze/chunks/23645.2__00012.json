{
  "stem": "23645.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And when she found out, when I got home, that the parcel was delivered safely and she has it, I can still-- you know, the smile on her face was-- of course, I didn't maybe appreciate or understood, you know, the heart of a Yiddische mama.",
      "word_count": 46
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "Her little girl had a, a meal that she made.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] I think it's only in one occasion that, that I did that.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So the only ones that were at home were my mum.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She would-- she refused to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "She wanted to look after the castle.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "You know, if somebody comes home, I'm here for you.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "That's-- that was-- she didn't, she didn't think about-- she could have gone to work there and maybe be safe, in that sense.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "But she had the baby, which was me, at home.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And she had anybody that would come home.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And she was home.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Only-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "There was-- we weren't able to.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The-- the ghetto was soon established.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And they were still able to come and go, although they stayed in the camp.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "So it was still not that drastic, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They were able to come home and then go back.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "But once the ghetto was firmly established, then it changed that.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "You worked at the munitions factory.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "You had barracks-- camps.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "There were camps established.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we were.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And it was verbal, whenever he could come, he would come.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But he would stay at the munitions factory.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
