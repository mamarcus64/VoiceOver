  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] And then I went to see if my other sister-- she was in a different block already-- to see if she survived because she-- while sitting on this [NON-ENGLISH], on this lime, she developed some kind of infection.",
      "word_count": 42
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "So she went to the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "This is the hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "And somehow she-- somebody liked her there, the, the nurse or, or the doctor.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And they cured her.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And they begged her to stay.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "They will let her clean the, the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "She should stay.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "So she says, no.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "She wants to be with her sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And she came out.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "They didn't bring her back to our block.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "She went to another block.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "And then was, was the selection.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "And she didn't make it.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "Right before that, this was the most-- was a selection-- the selections were going on every, every day.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 26,
      "text": "You never knew what.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 27,
      "text": "For entertainment we had a selection.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 28,
      "text": "So Mengele was there.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 29,
      "text": "And there was a selection.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 30,
      "text": "Nobody knew if the right or the left is good.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And I says, what am I going to do?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I have my two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And my two sisters were completely helpless.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "My oldest sister was 20-some years.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She was helpless because she lost the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And she had the milk coming in because she was nursing.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And it was painful.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "So some older woman says to tie her breasts.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "Anyhow, she suffered with this plenty.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "It's like she gave up.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "So I divided my sisters between every third, fourth person in a, in a single line to face Mengele because he was going to the right and to the left and to the right and to the left.",
      "word_count": 38
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And my two sisters went to the right.",
      "word_count": 8
    }
  ],
