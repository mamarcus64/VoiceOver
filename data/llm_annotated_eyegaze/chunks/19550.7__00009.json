  "model": "openai/gpt-oss-120b",
  "elapsed_s": 127.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "I-- I'm always bothered by the notion that the Holocaust is knowable or can be described.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "The Holocaust is going to be the longest untold story.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "There is no way in which the real truth of the Holocaust can be described, conveyed, or communicated to the world, to the outside world-- that is, to those who were not there.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "It is not one story.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "It is the story of every survivor.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "And then there is the six million stories that will never be told, that cannot be told.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "This is quite apart from such prosaic matters, as you know, although surprising-- and we keep being surprised-- at how much written documentation and material can be found about the concentration camp.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "I mean--",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We need to",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "OK, sure.",
      "word_count": 2
    }
  ],
