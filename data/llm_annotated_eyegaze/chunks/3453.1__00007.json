{
  "stem": "3453.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They let us stay for a little while.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "That all the Jews must congregate, must come into Sarny, from the villages, from all the small towns, from the villages in particular, and my grandparents.",
      "word_count": 26
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Through the Jewish Kehilla, through the Jewish council, through the Jewish council.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Somebody came.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And they were in communication with us.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "In 1941--",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "--when the war started, in 1941.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We moved in, in the ghetto, with-- we moved in, in the ghetto with some of our distant family, also Borko was their name.",
      "word_count": 24
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in three small rooms with about 14 people living down there, with a little kitchen that we used-- used to share.",
      "word_count": 24
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Was--?",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Not-- we were-- not in our case.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "It was fenced in by a fence, a-- a wooden fence.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "It was not barbed wire.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But it was a wooden fence.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "But nobody was allowed, of course, to go across the fence except through the gate.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "If somebody would jump through a gate, they would be killed.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Because there was stationed some policemen, Ukrainians, Ukrainians and some Germans, but mostly Ukrainians, the [NON-ENGLISH], I call them.",
      "word_count": 19
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Every family had to come to the-- to the municipality, to the self-govern, to the Kehilla, they called it, you know, to the council.",
      "word_count": 24
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They had to come, they had to produce every family has to produce two-- two or one person, almost twice a week or three times a week.",
      "word_count": 27
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And they used to send them to a manual-- and stupid work, whatever had to be done.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto lasted from 1941 to 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Our ghetto was at one point surrounded.",
      "word_count": 8
    }
  ],
