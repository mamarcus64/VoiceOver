{
  "stem": "20609.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She took the paper, ripped it apart, you know, you will learn English, and she enrolled me right in the school.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And I went to the school and I-- I started meeting people, you know, we went-- and I started learning English.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I also went to movies every day on a Saturday, like the first movies I didn't understand, double features.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "By the time they got around the third time, I could understand English.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So that was my-- my English lessons on the weekend.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "I think movies in those years were like $0.25.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I sat there about nine hours sometimes.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And so I'm glad I-- I-- I learned English, you know, because it has-- it's helpful.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "I walk around here with hardly any accent, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "I mean, my accent is better than Kissinger's and he got here before me.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I went to Florida.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I went to Florida with this guy a real funny story.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "This guy had-- he wouldn't-- he had a new Studebaker, that's-- remember, they looked like from the front and the back was the same thing.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And-- and he-- I didn't even have to put in gas he had so much money, this guy.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I really-- no, I don't remember the name.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And it was one of the Jewish guys I met at a Jewish Community Center-- American, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I went to Florida and for a couple of days, I stayed with him at the-- he was staying at an ocean front hotel that.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I said, what am I, crazy?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "So I-- I said, I gotta move out because I have a couple of dollars but I didn't have much.",
      "word_count": 20
    }
  ],
