{
  "stem": "22889.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So I worked on it from August till [PAUSES FOR 3 SECONDS] probably around April or May, something like that.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I was sent out to Krakow-Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Things were very bad for me in this camp.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It was a small camp.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I was away from home, I was a youngster, I need my family, I missed my family terrible.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "My mother gave me two pair of pants to wear, and I had a hopsack.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I wore these pants-- I remember I had blue corduroy pants I wore underneath.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I wore it so long till the corduroy wore out.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I was afraid to leave it, because somebody else would have maybe take it away from me.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I slept with them, I ate with them, and I work with it.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "It was very hard camp.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "It was the first camp away from home, and I knew I couldn't go back.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "There's nobody to go back to.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "There was no Jewish people anymore in town-- Judenrein they called.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "There was no Jewish people in town.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And some people from my hometown, the Gentile people that work in this lumber yard, they used to travel by train for the Hobag company.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "They got paid, naturally.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And then they were my neighbors, across the street.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "One fellow, his name was Krupa, and I ask him-- could you bring me a piece of bread from home?",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Could you help me out?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I'm starving here, because they don't feed us.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "You know, we were away from home in the-- our ration was very poor.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, we used to get a slice of bread and a coffee.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Then lunchtime we got a little soup.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "In evening again, a little bit soup, and slice of bread, and a black coffee.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "They called coffee.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "This was our diet.",
      "word_count": 4
    }
  ],
