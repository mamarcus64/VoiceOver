{
  "stem": "1413.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But after school, I had to go to Jewish school for an hour a day, or an hour and a half a day.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And I just want to go a little further with Talmud Torah.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Talmud Torah was a Jewish school.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "In winter time, we went home 12:30 on Friday.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "But we worked every-- we went to school every year Sunday on account of Shabbos was no school.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I did occasionally because my teacher was a chazzan in the temple, in the synagogue, Yiddish temple.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And he kept a list.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he asked the people on Sunday morning, did you go Friday night, Saturday morning, or Saturday afternoon to shul?",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And he kept track of it.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And since he was the chazzan there, so he knew everybody was coming into the temple, so I couldn't lie.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I was going to his shul.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't lie.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Yes, I was.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "If he was there himself, so I couldn't to say yes if the answer was no, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't think I as much as I did because like I said, I was in his class.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And he could take me down if I went than they did.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Because I was not the same timings in Talmud Torah when my oldest brother was in because he was older.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I think my oldest brother was born in 1914, if I'm not mistaken.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "So he was nine years older than I am.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My mother was raised in an orthodox family.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And even-- I can see it in front of me that my mother inherited the dishes for Pesach.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We had different-- she was kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "She was kosher.",
      "word_count": 3
    }
  ],
