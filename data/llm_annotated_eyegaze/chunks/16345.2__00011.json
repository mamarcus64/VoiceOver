  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "They had outhouses that really stunk to high heaven.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And I got-- I actually got to see my father's two sisters.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "One-- one looked very much abused.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I was a cocky kid.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "I asked her who was abusing her, and she told me that her blockalteste, who was also a kapoo, a trusty prisoner.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And I asked her to show me which one it was, and she showed me.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And I went over to her, and in my best German, arrogant language, I told her that-- I told her if she abused my aunt, I'll find a way of getting her killed.",
      "word_count": 33
    }
  ],
