  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "They grabbed-- they grabbed people in the street.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Come-- same thing for truck and same thing-- but before they had this Kowalchuk, the Ukraine commandant was known to my mother.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Ask them when I tell you the story that my father told me to go away from him.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He went in-- the policeman, the commandant-- asking for shovels.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "So he asked him, why you need shovels?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He said, we're taking him out to work.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "But with the shovels, the police-- the Ukrainian police-- they buried them.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "They covered them.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "OK.",
      "word_count": 1
    }
  ],
