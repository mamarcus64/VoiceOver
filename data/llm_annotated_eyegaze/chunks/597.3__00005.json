{
  "stem": "597.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "It was pretty hard, but he worked.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And they schlepped him there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "They-- they took him there to work, and he was working every day.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He got had plenty, plenty knocks from the Germans to drag there in the heavy cable on-- on his shoulders-- telephone to the front.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "They build a telephone.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And this was a highway.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And he was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "Any work-- he did all kind of work.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "They took him there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "But, we tried to protect him.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "They called up sometimes and they want him to go to work.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And we used to hide him and attempt-- the same place there.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "He's not home.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "There was Jewish police too in the ghetto-- Jewish police.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "They used to-- they had to have some people to work.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "They used to come in and drag some people out-- men, young girls, young boys.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "But sometimes they came in in the house, and they asked me.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "I said, my father's not home.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "He's working.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "He's not home.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "Yeah, he was hiding under there.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "In fact, this-- there was a time when they was looking for men.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "And they came.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "They came in.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "They was looking.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "They're knocking over the whole house.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "They couldn't find him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "We-- we hided him up-- hide him down the space.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "And he was laying there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "And nobody dragged him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "The only thing, he was killed in this-- on the end, in the ghetto-- you know, the liquidation from the ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "That time, he was killed.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "All the time, we tried to protect him-- not to let him to go out-- sit him in the house and not to let him out to work, unless they grabbed him someplace to go to work.",
      "word_count": 37
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "Because he was very you know, a religious man.",
      "word_count": 9
    }
  ],
