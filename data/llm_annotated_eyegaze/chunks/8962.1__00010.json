  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 54,
      "text": "And he took the money and paid the bank because he had still owed money for the cars before.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 55,
      "text": "He said, no matter what I do, I am paying what I owe.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 56,
      "text": "I am an honorable man.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 57,
      "text": "And he packed up all of the equipment from the factory, put it in a truck.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 58,
      "text": "And he had promised this man he was coming with all the equipment to show him how to set it up and how to use it and how to start the business in Hamburg, which was quite a distance away.",
      "word_count": 40
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 59,
      "text": "In the meantime, my mother and I still lived in the same apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 60,
      "text": "But she took in a boarder who helped pay for the rent.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 61,
      "text": "And I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 62,
      "text": "And I made some money in the dentist's office.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 63,
      "text": "And between that, she and I were able to live in this apartment until-- I forget the date-- '38, 1938.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 64,
      "text": "Yeah, this was in 1938.",
      "word_count": 5
    }
  ],
