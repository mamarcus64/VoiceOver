{
  "stem": "2938.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And this was the end of Proszowski Rubin, a very good friend of mine.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And I was living in the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Went to work.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I was manufacturing spokes for wheels.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "They supposed to use those wheels to march to Russia, to go occupy Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "I worked there, I knew all the people there, I had lots of friends there.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "The people of the camp received me very well-- very well.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "I came home poor, empty, I didn't have one cent.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And I had some guys who knew my father.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "They respected me very well, and they helped me a lot, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "And I lived there in the camp, [PAUSES FOR 4 SECONDS] mostly at the time of the war, till late date in 1944.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] In 1944, it was sometimes early September.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] Oh, no, no, no, no-- no, no, no-- while I was in the camp working in Huta Ludwikow, the uprising, the Warsaw ghetto began.",
      "word_count": 28
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "And we'd been getting reports every day that the Jews are shipped to Treblinka from Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "This is 100 miles outside Warsaw, in the deep forest.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Treblinka-- Treblinka is 100 miles outside Warsaw, in the deep, deep forest.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That's one shipment, the other shipment, third shipment went to Treblinka.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They found out, and they decided-- they decided in Warsaw to rebel.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And they start rebelling.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They didn't obey the German order.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "The German came in one day, asked for 10,000 people.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They say no.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "Came in the next day for 5,000 people, they refuse, and start to go on fighting.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And they start to rebel, day by day.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Poland had lots of underground.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "People-- Jews and non-Jews-- were in the underground.",
      "word_count": 8
    }
  ],
