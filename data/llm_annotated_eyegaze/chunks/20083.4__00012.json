  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And I was trained as a social worker there.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And we met displaced persons at the pier.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And remember, I was not a displaced person because I came from England.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "The displaced persons came from the continent of Europe.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "It's not-- not only Jews, but every kind of nationality and religion.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And we had to find jobs for them, make arrangements with various people all over the country in the factories and on the land, in offices, and arrange for these displaced persons to travel all over the United States.",
      "word_count": 39
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "It's called A Church World Service.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I stayed with them till about 1956--",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "--about eight years.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "After that, I went to Italy.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And in Italy, I-- I had corresponded with the mother of-- of a woman.",
      "word_count": 14
    }
  ],
