{
  "stem": "6503.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "And the-- I said somebody will come from Amsterdam to pick us up.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "While we were in the hotel, the two other ones was picked up and we never heard from them no more.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "They were shipped back to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So I was with him that was the uncle, an older person, older than me, and we two survived.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And somebody came from Amsterdam and picked us both up.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Who came from Amsterdam to pick you up?",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I had a boyfriend who lived in Amsterdam, and he came and picked me up.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He told me how to go.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We went to the city.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "The name was Venlo in Holland.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "We went first to Germany, to Cologne.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Then we took a little train to the border, and in there, we went on foot the whole night.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "It was December 12th.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "It was snow and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "It was very cold, and we walked to foot most of the night.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And we couldn't identify where we were, because on this point comes Belgium and Holland and Germany together.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "It is a three-point.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "But one of the girls who spoke French said, we are not in Holland.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "We are in Belgium.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "So we walked back and forth and back and forth till we came to Venlo.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "The lights was above us, and the [GERMAN] from the German.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And we came to Venlo and we asked them where that restaurant or hotel, whatever it was.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "We went in there to wait.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And the two other ones were outside, but they were picked up and we never heard from them.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "I don't know where they went.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "I went with the uncle to Amsterdam.",
      "word_count": 7
    }
  ],
