  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Did you have any idea what you wanted to do in the long term?",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in the first few months, really, nobody-- from us, at least-- entertained any thoughts as to short terms or long terms.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We lived really fairly from day to day, trying to, [PAUSES FOR 3 SECONDS] to do the best we can and to have everything what we want, to have food, to have clothes, to have cigarettes.",
      "word_count": 36
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] But we did know that this life-- we did not want to stay there.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "We did not want to stay in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "This we knew.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 6 SECONDS] But that was really, at that point, a secondary thought.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "The first thought was something else.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Our first thought at this time-- once we came to ourself-- was to see if we can find members of our family and our friends.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "This was our primary thoughts.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] And [PAUSES FOR 3 SECONDS] this being the case, we started to search for our family.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
