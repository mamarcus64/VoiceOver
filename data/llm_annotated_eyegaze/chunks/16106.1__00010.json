    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "They made us study Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Hebrew was out because it was fascistic and Zionistic.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And we could-- had a choice between Latin-- Latin, French, or English.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And Russian.",
