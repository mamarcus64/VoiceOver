{
  "stem": "20088.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And one day a lot of our things were stolen from our little room.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "You know, things we had-- I mean, it was all stolen goods.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "It was nothing that belonged to us, but things which we had planned to keep was gone again.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "So [PAUSES FOR 3 SECONDS] we tried to make do with what we had.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And we-- I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "We did not really do anything.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "We just walked around.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "Again, just trying to eat and to speak a bit with the people.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And one day a Russian came and asked he need somebody to window clean.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And this person will get special food.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "So my mother volunteered.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "She would clean the window in this office, from his office.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And so she said I have nothing to clean it, so he said, newspaper is the best.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "So he gave her a bucket and newspaper and he said, you wash the windows with newspaper.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "And she did that and she did get some-- I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "Some more cabbage soup or something.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "And then-- and other days they wanted people for translating, for German and Russian.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And my mother helped with German.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "I mean, she couldn't translate Russia, but there was somebody else helping.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "So my mother tried to make herself useful.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So she was still very, very weak.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how she did it.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And she had no hair and a very knobbly head.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And she had to have a blue dress with a high collar and very, very short and no stockings and high, high black boots.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And, you know, she looked quite terrible, really.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "You know, I can see her still in front of me.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember what I had.",
      "word_count": 6
    }
  ],
