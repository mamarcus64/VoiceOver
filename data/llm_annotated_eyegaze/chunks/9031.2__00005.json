{
  "stem": "9031.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And we saw like soldiers, but we don't know what kind of soldiers-- German soldiers, the Russian soldiers.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And this was Russian soldiers came in in this small town where I was.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I was all with this-- my sister, my-- my youngest brother.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And when I go out from ghetto in 1944, I left them in ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Later, in 1944, this was in March 26, I was not in ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "But I know from my Lithuanian family, they tell me about this terrible things, what the Germans to-- do to the kids in ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Three days they grab kids from every single place, from every-- from any apartment.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And they killed the kids and the oldest people.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "In this meantime, they killed my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He was 13.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And my sister's baby, she was 2 years.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Please what you--",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1944 in March 28-- 26 to 28-- two days.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "This was a special-- they do this special to kill kids.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the rest for the people, they took them in Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "My sister, she was-- they-- they took her to the-- to Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "She was-- and stood-- and stood over them-- and stood guard.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I don't know exactly in what place she was.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "This--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this was the-- the beginning when they close the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "But a lot of people stay in ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They have bunkers, and they was there.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans, they know what people, they was--",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Hided.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And there was-- fired the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And it was a big fire in this mountain.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "The ghetto was two weeks--",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Burning.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And everybody was there--",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Died.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The people that died are-- were the one that were hiding in the bunkers.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The other people was in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "They took to Germany.",
      "word_count": 4
    }
  ],
