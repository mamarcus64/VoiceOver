{
  "stem": "10745.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "They were 15, 16.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "If I wouldn't be-- having my mother to look after all the time, probably I would have been wind up in the partisans, but they lost everybody.",
      "word_count": 27
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "I was one or two, who had a mother.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "No fathers.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "If there was a father they didn't keep the child.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "If there was only a mother-- and like my mother was very sick, so they kept me upstairs.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "Because there was no other place to go.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The facilities-- I think there was four rooms, or five rooms in-- there was 25 or 30 people in one room.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And there was some straw-- the toilet was not there, and water was scarcely.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We didn't take showers to say.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They didn't give us no clothes to change.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Nobody had any clothes to wear.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Whatever we-- I had because I was wearing Russian uniforms.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "So I had a few of them, which I saved up in that time.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "So I had something on my clothes, I was hiding it-- nobody should take it away.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And all the time we used to have little children coming in to us.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Which they used to drop off because they were hiding out from Jewish families-- you know, from the-- the Christian.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "They used to bring it in.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And all the time they were screaming and yelling, we are not Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "They wore a cross on them, and they used to pray in Polish.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And all the time-- the atmosphere was very bad.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "The food that-- there was a woman that used to cook-- I don't know if she could cook enough.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "There wasn't-- food.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "I got a slice of bread and get something with it.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "It was not-- nothing there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "We, as the older boys, we used to go out to the city.",
      "word_count": 13
    }
  ],
