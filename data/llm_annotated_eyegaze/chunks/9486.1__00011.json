  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "I got lost.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Tell your name.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "He-- he put every child, he put a name on-- on us.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "If somebody find us, we should know the smaller one, not the bigger one.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "And in Kiev, we got lost.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "And I never saw my parents again.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] And I-- I find a lady there with kids.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "And she asked me.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 13,
      "text": "I went to her.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 14,
      "text": "And she said, I have my own trouble alone.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 15,
      "text": "I can't look for another one.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 16,
      "text": "I have five kids.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I stopped, and I-- I didn't know what to do.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I was really disappointed, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Somebody refused to take me.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I thought, I'm a child.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I have the-- I have the right, somebody to help me.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And at that time, I've-- [PAUSES FOR 3 SECONDS] We'll come back to that in a minute.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
