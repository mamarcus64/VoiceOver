{
  "stem": "2097.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "In the B lager-- [SIGHS] --we had to take off every cloth again.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "We were naked on the-- all day in the yard, at night-- and no food.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "At night, we were-- they told us to go into the barracks.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And when we walked in, everybody got a pajama top.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Somehow, I got a pants.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And because I got a pants, I-- somebody hit me, that I broke my teeth-- one of my front teeth.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "That wasn't a German.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "It was a-- a Polish-Jewish person.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And in the-- we slept on the floor.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "The barrack was pretty clean.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And the next day, we were taken again to disinfection.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And we were given us clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And we were-- we were taken to the wagons, to train.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "When I walked up on the train, I was on the first.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "My cousins, they were cut off.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "So I was then separated of them.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "I thought they are going to be on the next train.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "When we walked out in Fallersleben, I didn't see them.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "We were 500.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "And we were placed in the-- across the street from the factory, like a-- a semi-basement, a big place.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "And because here we had cold and hot water and clean floor, and we got, every day, a big plate of beets to eat.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "In the morning, we had a piece of bread and a certain kind of bitter coffee.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And at night, and again some kind of soup, beet soup.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "It was a big change from Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "And we were selected.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "I mean, we were sent to work.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "I was selected to work between 10 of-- I mean, 10 of us, we were put to work in-- in the painting quarter.",
      "word_count": 23
    }
  ],
