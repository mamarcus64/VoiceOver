{
  "stem": "18932.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I would like to live a little longer.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And my mother says, don't cry, my child.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "She says, we should be the victims for all the people-- [SOBBING] [INAUDIBLE] around here.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "If we should die-- in order the others should live.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And we were staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And everybody was almost gone.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "We were staying, too.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And there was a couple of officers that came over.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And he comes and asked my mother, what are you staying here?",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And my mother says, the other officer told us-- in perfect German, she spoke perfect German.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "She says, the other officer told us to stay on the side.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "So he looks at me and looks at me and looks at my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I guess, you know, it must have been my eyes, they were so blue.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And I, I really-- You were a very beautiful child.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I was-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And he says to me, go in [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And when we came, they-- all the people were so happy to see us because they were sure that we were-- we were already sent to the oven.",
      "word_count": 28
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And sure enough, my, my aunt with my little cousin, Judith, was sent to the oven.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And then they took us.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And they said we go in in [NON-ENGLISH]-- into the bath.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And we had to get undressed.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And my mother still had that little bundle of the jewelry with her.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And she was going to give it away.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And I said, no, Ma, I don't want to give them nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "So I made a little hole in the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And I buried it.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "I wanted-- really, I wanted to take-- she had one big diamond, to hide it.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "My mother says, enough.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "I don't want anything anymore.",
      "word_count": 5
    }
  ],
