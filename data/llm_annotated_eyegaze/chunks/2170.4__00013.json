{
  "stem": "2170.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "But we invite you to come to Moscow.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 36,
      "text": "You'll try to get a Polish passport.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 37,
      "text": "And then when you have the Polish passport, you get the Soviet exit visa.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 38,
      "text": "This made me a little bit feeling better.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 39,
      "text": "I came back to Zhmerinka.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 40,
      "text": "I knew the head of the KGB, railroad KGB, not the regular civilian, and they I went to the chief.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 41,
      "text": "And I told them the story.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 42,
      "text": "But he was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "He said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I'm gonna give you a permit to go to Moscow to buy all kinds of things that we need for the railroad.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Maybe this will help you.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And he gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Also I had the letter from the American Embassy.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I had also a letter from the Polish [? patriots-- ?] [? patriots ?] were the Polish organization in Moscow-- that I am Polish, which helped me too.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And go to Moscow, then you'll have to get a permit to get into a train, which was impossible.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Only Russian generals, officers, and soldiers were right to go to Moscow.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But somehow I knew the [? nanchanik ?] of the station.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And he gave me a ticket to go to Moscow.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He did not know what he was doing.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But he gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And I came to the train at night, and I was wearing a Russian uniform, not a military but the uniform from the railroad, which was instead of green was blue.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I came into the train, my sister took me there and my brother-in-law.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I took food with me because I knew in Moscow there was nothing to eat.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So I had with me bread.",
      "word_count": 6
    }
  ],
