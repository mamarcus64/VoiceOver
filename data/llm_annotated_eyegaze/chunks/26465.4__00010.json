  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "So I come in, come in-- I am coming down on the stairs.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And there-- there-- there's two soldiers coming up the stairs towards me.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And for some reason, one grabs me.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And the other is shouting something, of course, in English.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I didn't understand English at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And he grabs by the hand.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And I, seeing that, I just had this strange moment of escape, the final, you know-- it's just instinctively.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I jumped over the rails, jumped down.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And somehow he let-- somehow I slipped out of his hand.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I hurt a little bit my-- my tushy.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And [LAUGHS] I-- I run out.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "There was a-- there was this wash room outside, the outhouse.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
