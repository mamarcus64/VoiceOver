    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And-- [PAUSES] it was a nice, cozy-- here I go again.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "But it was a cozy, cozy apartment.",
