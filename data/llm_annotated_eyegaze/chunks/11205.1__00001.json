    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] It was a beautiful building, [? one of the ?] really because the owner was very wealthy.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They were very wealthy.",
