{
  "stem": "18670.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 33.5,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I found out later on into France.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "But then I got contact a little later on.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I got contact that they're being in France and my father had been interned at Gurs.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "My mother was in Marseille.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And now they needed new papers, because the papers-- they had gotten affidavits already.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But their affidavits were lost in Belgium.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "The American embassy, we need new papers.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "So we started working on new papers.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Now I had to get new people.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "The-- this guy-- the egg and butter man didn't want to.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Had to go and get people.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Then they got-- finally got affidavits.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And now America is it at war, Pearl Harbor, 1941.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And now my parents became enemy aliens.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Now they're Germans as far as the American government is concerned.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So I wrote a letter.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "A very unique thing happened.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's a small world.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Every Jew is related to another Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The chief rabbi in Venice, Vienna was-- his name was Frankfurter.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Frankfurter married my parents.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "My parents had married during the First World War.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Frankfurter also was the uncle of Frankfurter, Justice Frankfurter in--",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "--on the Supreme Court.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Felix Frankfurter.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "So I wrote to Felix Frankfurter and I got a nice letter back a few weeks later.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I am sorry I can't help you as a justice of Supreme Court, I cannot become involved.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So I wrote to Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Roosevelt.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And it worked.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "Unbelievable.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "Within a week I got an answer that I'm going to be questioned before a commission at the State Department.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "I went, made an appointment about a couple of weeks later.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "I went to the State Department.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "I was questioned.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "All they were interested in, one thing, is my father Communist?",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
