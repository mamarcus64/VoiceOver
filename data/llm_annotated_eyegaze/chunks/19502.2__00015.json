{
  "stem": "19502.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 345.6,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "She said to me, I've got something for you.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "You see, in school we took hand work, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Knitting.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "She knew I was knit-- she used to deliver milk to us.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "She knew I was knitting a sweater.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "She says, everybody was robbing.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And everybody was taking things away.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "So I made a little parcel.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "I figure out maybe sometimes you would come.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "I saved you this, you'd have.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "She gave me that little parcel.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "And she said to me, I've got some-- here's some milk and here's some bread.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "She gave me bread to take.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "She says, but I'm telling, I'm afraid you should come here.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "Because, I mean, her life was also in jeopardy.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "But if you can sneak out once in a while, I'll give you bread and milk.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So she said to me, but one thing I must tell you, you was-- tell you about-- your mother came to my dream.",
      "word_count": 23
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And she said to me she is very happy where she is.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "The only thing, it's wet for her, because you cry a lot.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So I don't know if she wanted to make me feel that way or if it's true.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "She said, don't cry, because you're hurting your mother.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I said, Pascha, I won't cry no more.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And you know what?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I never cried.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I never, I never cried.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I was as hard as a rock.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And I just says, I have to survive.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I have to survive.",
      "word_count": 4
    }
  ],
