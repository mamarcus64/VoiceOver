  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And they find out I have a [NON-ENGLISH SPEECH].",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "That means a ulcer in the stomach.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Then, my mother--",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "A little bit.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "The feel the everything.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But it's not comfortable.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You know, that we feel, sure.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They recognize right away.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I-- then, I went to my mother, did not quiet, he says, listen.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Something is there.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You not feel comfortable, you this-- you go to Lemberg-- Lwow.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "The biggest doctor.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Which at that-- I meet a doctor over here, which was that-- the student.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Came to Lemberg.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Dr.-- a Ukrainish doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Ukrainish doctor.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I've-- I spoke to him yesterday.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "[NON-ENGLISH] Cherenesky in Lwow.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "The biggest doctors.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "And they are x-ray me.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "And he says, you've got a couple figures down the stomach.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "They are-- [NON-ENGLISH SPEECH].",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "And my mother start to give me food.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "They said, the only thing give, food.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "And I went to the other doctor, and I meet this doctor over here, over here, which I speak to him every day, play with him in chess.",
      "word_count": 28
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "He was a student.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "My doctor, my friend, went to-- Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "Erlich, which his name is [NON-ENGLISH] Erlich, from Horochow.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "He says to her, I'll give you $10 to give my son down there.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "And I come there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "It's very-- I had to walk up to university.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 29,
      "text": "And he says-- and he says [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 30,
      "text": "And I meet this Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 31,
      "text": "Erlich.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 32,
      "text": "I meet him over here.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 33,
      "text": "Which I could speak to him if you want me to.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 34,
      "text": "I'll speak to the telephone.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 35,
      "text": "And I spoke to him.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 36,
      "text": "He doesn't remember exactly, and I don't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 37,
      "text": "But the other doctor gave me the $10.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 38,
      "text": "And he show me all the doctor hospital with them.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 39,
      "text": "And I went home.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 40,
      "text": "And I feel OK.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 41,
      "text": "I've nothing-- healthy.",
      "word_count": 3
    }
