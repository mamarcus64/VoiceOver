{
  "stem": "22889.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He came in where the people live.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So he walk around with them, show where the Jewish people lived.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Right away they took Jewish hostages and some of the prominent people, whoever it was.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "There were Jewish names, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They came to our house.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "They were looking for my father because my father wasn't home.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "This was a few hours after the occupation, maybe the next day I believe, yeah.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My father wasn't home.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "My mother say, he's not home.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Where is he?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Where is he hiding?",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "My mother said he's not hiding.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "He went with-- he ran away with the other people.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "She doesn't know herself where he is which because we didn't know where he was either till we find out, till we got later on message.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "People-- some people came back from the Russian zone, you know, and they tell us that my father survive.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He's in Lvov-- Limberg, they call it.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But after awhile, few months later when things quiet down so my father return, he came back.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He came back [PAUSES FOR 4 SECONDS] about two months later.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, about two months later.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "What changed right away, you know, I remember they start to right away after the Jewish people.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We weren't allowed to go to school.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "This was the first thing.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Jewish kids weren't allowed to go to school with a proper education.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We had to go to work.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "The first job is to sweep up the streets, the sidewalks.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Women used to-- like my mother, they took her to work.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "She used to clean the offices, scrub the floors, windows, sidewalks with a brush.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "You know, they were taking all kind of pictures.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "They were cutting the beards from the Jew because we had a lot of Hasidim in our town.",
      "word_count": 18
    }
  ],
