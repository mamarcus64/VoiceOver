{
  "stem": "20684.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "You could buy something over the fence for clothing.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And you know, my parents got rid of all their clothing very quickly, get a bit of bread from the Poles, you know, over the fence.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "So when someone dies, you take off the clothes, and so on.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "There's no-- no traditional funeral.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "They were just-- carts were coming in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And I looked through the window, and I was also given a whack by my father.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "I was getting up too early.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "I wasn't allowed to get up, because I could see-- hear the carts, so I would come out.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "I had to wait till the cart went by, because they're just picking up bodies, and it wasn't good for my-- for my well-being to look at all those corpses being picked up in the mornings.",
      "word_count": 36
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In a house with hundreds of people in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Just strange people.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "My parents went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I was told to-- to-- to always stay inside and hide in the cupboard again.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "But not a cupboard like that, but a normal cupboard, just to stay out of sight.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "But I sneaked out and the dogs got onto me.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "The-- the guards sent dogs to chase me, but lucky enough I was quick enough to get away, and I ducked into-- into a-- a house and-- and I hid.",
      "word_count": 30
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Run up, and I hid under the stairs.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And the dogs went away, went by.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And then I quietly crawled back into my house, only when it was dark, in the evening, which was a few doors away.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "My parents were very worried.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "They thought it got me.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "--I wasn't so easy to catch, at least.",
      "word_count": 8
    }
  ],
