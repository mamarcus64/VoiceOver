{
  "stem": "14810.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And they told me to put back the body, and I had to burn the whole, it was a whole 50 people.",
      "word_count": 22
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We burned them.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "But after the SS man left, I picked up a can, a metal can, and I took a bunch of ashes and I put them in the can.",
      "word_count": 28
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And I remember, I buried it right next-- there was a fence there, and I buried it.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I figured if I survive maybe I'll be able to come back and bury, give her a burial.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I was there eight years ago.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And we went to the place, but unfortunately, everything looks so different.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "First-- it's overgrown with weeds, about 10 feet tall.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "The fence is gone.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "And I-- I spent there a couple hours.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "I couldn't locate that place.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "But I really had hoped that maybe I'll find that metal, with the ashes.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "But I'd have to spend probably days to find it if it's still there.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "So that was, and so my father and my brother were the only survivors.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We were in the ghetto another two, two months.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We had to liquidate, liquidate everything.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "The furniture-- we had-- the Germans came with trucks, and we had to unload all the furniture, all the belongings from the houses, and they sent it away to Germany.",
      "word_count": 30
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "So I was there another two months from September to middle of November.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And then middle of November they came and picked.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "We were 150 people, and just picked 100 people at random.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "They put us on trains and sent us to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And like I said, my brother and myself in Auschwitz all this time.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And my-- yeah, and my father was left in the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
