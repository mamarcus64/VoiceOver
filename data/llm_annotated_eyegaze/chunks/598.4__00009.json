{
  "stem": "598.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "One time I went away, they had a hold-up, too.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "So the-- when I- when you're in the back, they are afraid of him.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "And I know the people.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "So they never had hold-ups.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So they kept me there for 22 years.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "When I was 57, I sold it to another guy.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And what I'm going to do now?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I'm 57 years old?",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Went to school to teach-- to learn myself to be a real estate man.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It took me a couple months.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I learned it.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "One time I fall through.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "By the third time I made it.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And I get my real estate license.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And I was been in a real estate license.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "One time I bought a building full of apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And I convert it to condos.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And I fix it up myself, and I sold it.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And that's the way I made a living.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Then I came here-- yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "No, not-- I came to California in-- about seven years ago.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I was there in Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I was trying to make good for people-- the Russian people came here.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "So I was a president of their club, and I try to give them jobs, try to make entertainment.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Here, [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "See the [NON-ENGLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They give me a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "That says I donated.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I had been there-- I was 62.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They gave me-- make a party.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "So it was a committee.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And the American government gave us $10,000 for entertainment.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "So I was the president.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I was sign it, and it's another guy sign it.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And we used to bring in concert-- all kind of concert.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Every concert, we didn't make enough, the rest of them fighting with me, we should give them all the money what we collect for the concerts.",
      "word_count": 26
    }
  ],
