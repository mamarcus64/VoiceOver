{
  "stem": "210.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "So I don't know how long it took, but it took for-- it wasn't really that far.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "And they took us to work there.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "And over there was already a little better.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "And we had to go.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "And they gave us clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "They gave us just asleep two in a bed.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "And over there was one German Jewish woman that she was like the head of that-- of the barrack that I was in.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "And she was really very nice to me.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "And we went to work every morning, and we came home at night.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "And we worked on this, this highway that was supposed to go from Berlin to Moscow.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 40,
      "text": "So we worked at a certain portion of this highway with picks, iron picks and shovels.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 41,
      "text": "And if somebody couldn't-- if you didn't work fast enough, they were standing over you and hitting you.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 42,
      "text": "And if you couldn't work fast enough, they shot you right then and there.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 43,
      "text": "So every day we came out, we came back less.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 44,
      "text": "Every time, we came back less.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 45,
      "text": "And it came to the point where you didn't even look who it was that they shot.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 46,
      "text": "You just wanted to walk by and get back to your barrack.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 47,
      "text": "And we got back to the barracks, over there was already a little better.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 48,
      "text": "This woman, she gave us pieces of material.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 49,
      "text": "And I remember I made myself a skirt.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 50,
      "text": "I make myself a brassiere.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 51,
      "text": "I made-- you know, little things that she showed us how, this woman.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 52,
      "text": "And it was already-- it was-- this was-- you know, and we got much better-- I mean, food to sustain us.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 53,
      "text": "And I was there maybe four months.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 54,
      "text": "And while I was there, there was one woman there that she was the only person that I knew.",
      "word_count": 19
    }
  ],
