{
  "stem": "25598.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was involved in Hashomer Hatzair, which was a more leftist Zionist organization, which later fed into her and my inclinations towards communism, before we knew what it was all about.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I always liked to organize things with or for other kids-- be it a funeral for a bird, where the whole city of kids came and we put the bird in a shoebox, or what have you, and there was a whole procession through the streets of the city.",
      "word_count": 49
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I used to like mountain climbing.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I built a factory of some sort in our wood shed, and I had a lot of kids involved in that.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I was always organizing something.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I was always a very active child.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And it was also an activity which kept me away from my mother, because I was afraid of her.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I was afraid that if I don't finish my food, I'm going to get it.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And I got it, every day.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And often I was black and blue.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I attended public school.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But I had a private teacher for Hebrew and Jewish history.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Yes, there was-- the town was too small to have a Jewish school just for Jewish kids.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So most of the Jewish kids had private tutoring after school, on a one-to-one basis, actually.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "It was not an organized school.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It was-- there were a few Hebrew teachers and history teachers in town.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And they used to come to the house, and they used to give us lessons.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "In school, I encountered-- I-- I became aware of anti-Semitism for the first time when, when my teacher called me out in front of the class and took the, the attendance book-- which was a big book with black covers-- and she hit me with it on the head.",
      "word_count": 49
    }
  ],
