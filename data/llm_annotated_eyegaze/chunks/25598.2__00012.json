  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I was wondering if my face changes like that when I'm asleep too.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] I forgot one incident, which I think is important for both historic and personal reasons, which is before we were deported, my father was very well known in town.",
      "word_count": 33
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And he has a lot of friends, Jewish friends and not Jewish friends.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And a lot of the people who bought in his store were very grateful to him, because he loaned them money, or he gave them on credit, or what have you.",
      "word_count": 31
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And one of the people who was a Legionnaire, a member of the Iron Guard, which was-- who were ferocious antisemites, came to my father's store one day and told him to pack the family and leave to Bucharest as soon as possible, because we're going to be deported.",
      "word_count": 49
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "He was drunk when he came into the store.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Maybe that's why he told my father, because that was supposed to be a secret.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "He was drunk, and he had a beer bottle in his, in his hands when he came into the store.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And he told my father that, and my father started laughing.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And he said no, that will never happen to us.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And the guy got so angry that he punched my father with the beer bottle, hit him in the face.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And my father came home with a split lip.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And my mother-- they had to call the doctor to-- to stitch it together or what have you.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "Because he was furious that my father doesn't listen to him.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "That's how non-believing we were about what is expecting us.",
      "word_count": 10
    }
  ],
