  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I myself made a list in Israel for Yad Vashem of 137 people on one side of the family.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "[SOBBING] My uncles had children.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "There were young people who never got a chance to marry.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "There were-- my little schoolmates, whom I don't know any of them are alive.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "People should know.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "People should be aware that humanity is capable of things that are horrible if the rest of the world pretends it isn't happening.",
      "word_count": 23
    }
  ],
