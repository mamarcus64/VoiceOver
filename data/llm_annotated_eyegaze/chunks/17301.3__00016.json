  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And as we were digging trenches, I saw a little girl in a not too distant, like around fence.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "She was not too far from me.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "She must have been maybe five or six years old.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And I went over to her to talk to her where-- I mean, I wasn't supposed to, but I was so hungry.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "She was eating carrots.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And I went over.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I said to her, would you like to give me a piece of carrot?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She says to me, [SPEAKING GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And she ran away from me.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "She would not share a carrot.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "This is how I knew that all, even the children in Germany knew that we were Jews.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "OK, we're going to pause here.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "This is the end of tape three.",
      "word_count": 7
    }
  ],
