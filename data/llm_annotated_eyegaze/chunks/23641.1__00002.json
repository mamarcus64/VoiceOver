{
  "stem": "23641.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Right-- not before-- not way before the war, but right-- let's say, 1937, I remember, the Polacks used to went to, to the Jewish stores, and they used to scream, don't buy from a Jew.",
      "word_count": 35
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Buy from a Polack.' That was in 1937.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I guess at that time, then already Hitler Germany, started to have trouble with the Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So I remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So that, that I still remember today, the anti-Semitism, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "That was before the war.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I went to school, but only I finished two grades.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Something happened at the public school.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I went two grades because the Jewish population started to make a school on their own-- like here, like private schools.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And then they took me out from the public school, and they put me in those private schools.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "But that private school didn't last too long, maybe two years.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And then I were out, and I didn't went back to school anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "So that's why I just finished two grades in the public, and maybe had two grades in the private school.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "That was all my education.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Work?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "After that, I-- my mother gave me-- my uncle was a tailor.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And she said to me, 'You go in over there-- go in to your uncle, and you'll learn the trade as a tailor.' And that's what I did, you know.",
      "word_count": 30
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Alta.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Alta.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "He was a nice orthodox Jew, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And he was my own-- my, my mother's sister's husband.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And he was nice, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I-- I learned a trade.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "That's what I did there.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He worked for himself.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Didn't have a store.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Back then in Poland, was no stores like here.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He worked from the house.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Everybody worked from their own house.",
      "word_count": 6
    }
  ],
