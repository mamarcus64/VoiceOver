{
  "stem": "2684.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And all I seen, about a few hundred people in front of my mother's stall screaming that the bloody Jews-- she pinched the goose from the people of the communist republic, and so forth.",
      "word_count": 34
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And again, the same day or maybe the next day, I see again people armed from bottom to top-- bazooka, hand grenade, machine guns, you name it-- in front of my mother.",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And I couldn't go into-- into the back of the shop, because I saw my mother white like a sheet between two armed guys.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I asked the guy, what happened to my mother?",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He said, the bloody Jew was selling goods which was sent from the country to the capital city as a present for money.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I said, this Jewing start all over again.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And one of the leaders of this mob said he'd take the woman into the school, nearby school, to interrogate her.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And my mother-- when she came out, I said, Mommy, what happened?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "She said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I'm a member of a-- of a-- how you call when a lot of people organizing?",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Commune, like a commune, but a business commune.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "She said, I got the goods from the distributor.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I have to pay for it to the distributor.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And I'm selling it.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I'm not my own.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "This is not my business.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "That business belongs to the combine.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "But the people wouldn't listen.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "They said, where is your papers?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "She said, the distributor has it.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And one of them was decent enough.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "We don't hurt her, he said, until we find the distributor.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "So my mother was, for two days, in the school.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And in those days, to find somebody-- with no transportation, everybody in the move, revolution is on-- to find somebody's a miracle.",
      "word_count": 22
    }
  ],
