{
  "stem": "27335.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Durovecz.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good morning.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm glad that you selected me for this-- for the purpose that you inter-- interviewing for.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name is Andrew Durovecz-- and uh, it has been changed, the name from Gyurovecz.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It has been-- it has been modernized so- so to say to make it more like, sound like Hungarian, because originally Durovecz-- is, uh, or Dur-- that is the first part of my name, D-U-R, is French.",
      "word_count": 37
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My grandfather was a Paris [? communat. ?] And when the uprising was suppressed by the Prussians, uh, there were a section in the Prussian army which collaborated with the revolutionaries, and they opened up-- opened up a-- a gap.",
      "word_count": 40
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So, and several dozens of revolutionaries escaped.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And they heard about revolutions in Poland and Ukraine and Russia, and so on-- and they just took off to the east.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And landed up in a [INAUDIBLE] in the Austro-Hungarian empire.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And then they settled down there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They didn't go any further into Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They found enough comfort in [INAUDIBLE], and they became charcoal burners, and wood cutters, et cetera, et cetera.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And uh, my father was born there.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "Where was your father born?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In [?",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Trenchin ?] province-- I-- I forgot the name of the-- of the village.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I might remember later, but-- [LAUGHS] but then when he was-- he was at age of 13 to be ripe enough and strong enough to be an apprentice.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "He had an uncle in Vienna, in the outskirts of Vienna, and he had a harness making a postal shop.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "So my grandfather sent-- sent my father down as a young boy to be an apprentice with his-- with his uncle.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, unfortunately not.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Because I never-- never saw any relatives on my father's side-- never.",
      "word_count": 12
    }
  ],
