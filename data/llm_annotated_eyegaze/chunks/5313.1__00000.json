{
  "stem": "5313.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Ernest Braunstein.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Germany [PAUSES FOR 3 SECONDS] on February 12th, 1924.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "When I was a young boy, like one-year-old, we moved to Romania and my father-- actually in Romania, which was changed back to Hungary, Romania in a matter of 15 years or so.",
      "word_count": 33
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But I'd been raised mostly in Romanian.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, my family, my father was in the wholesale fruit business.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Was Aladar Braunstein.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was Aranka Braunstein, which her maiden name was [?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Farency ?].",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Called in Romanian called Oradea Mare, in Hungarian is Nagyvarad.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And a little from there was 24 kilometers was a little town which called Mezotelegd.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "That's what-- where I was raised by and went to school, in Oradea Mare.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, in the town was a small town when I was raised.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "But Nagyvarad was a big town already.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And I went to school there, and both in Hungarian and then in Romanian when it was changed.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I had a very good young life, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "My father was in the business, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I remember that, you know, I get a bicycle on mine 13th birthday, so I become a rich person.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Everybody was look at me that I had a bicycle.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had a brother which I never remembered, you know, passed away before I was born.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Then but I have a brother about three years younger than I am, which is still alive.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He lives here in Palm Spring.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "It was very conservative far as Jews concerned.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Was a lot of Jews there.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I could say that I remember in my young life, the Jews was very well treated at that time.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "In Romania, the Jews had right to do a lot of thing.",
      "word_count": 12
    }
  ],
