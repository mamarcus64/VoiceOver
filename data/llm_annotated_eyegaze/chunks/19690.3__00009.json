{
  "stem": "19690.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And he was very happy there because he could do some manual labor other than barbering, which he had been doing in the camps, and which had gotten us some extra income for incidentals that we needed.",
      "word_count": 37
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My father went back to Miramar, we went back to Hotel Terminus, and on the 3rd of August, we woke up and the whole hotel, the whole block, was surrounded by French militia.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And we knew we were in big trouble.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was another time of we should have.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "We were told to pack, then we were told not to pack.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We were given food, but we couldn't eat.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "My mother had been buying food from the black market periodically, and she had all this food and she was packing it.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We didn't know what was happening.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And late that night, we were told to pack, that we were leaving the following morning and that we were going to Camp Les Milles.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Our luggage was put into one truck, we were put into another truck early in the morning, oh, probably around seven o'clock, and we were driven to Les Milles.",
      "word_count": 29
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "Les Milles is a camp that was a brick factory.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "I've been back there since and it is again a brick factory.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "It has never changed.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "It was directly on a railroad line and trains would come in and out of there to deliver prisoners.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "They didn't even have to go to the railroad station.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "It was a very primitive place, furiously hot in the summer because there was nowhere to hide.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "The barracks building itself had some windows in it, not very many.",
      "word_count": 12
    }
  ],
