{
  "stem": "18294.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "And this-- they tried to get to provide the life like a normal life-- the people not to feel that they are so been hurt, you know, to go on with your life.",
      "word_count": 33
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "But in other way, some of you was worse hurt.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "Like I was hurt from my sister's side.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "Then other people lost already half of the family because there-- there was two ghettos.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "There was ghetto number one, and there was ghetto number two.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "Ghetto-- who come into ghetto number one, they all went to Ponary to shot.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "And the-- I was in ghetto number two so I was lucky to stay alive.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "And the life in ghetto, we had something too because my-- my father was working for Gebietskommissar Murer.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "People know exactly, you know, been over there.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "And he was working there like-- like a shoemaker.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "And he used to bring some leather, what was left over-- he'd pinch from there-- and bring them to the ghetto, and he sold them.",
      "word_count": 25
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "So we had the money to-- to live.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So compared to other ones, we had in-- in food we was very, very good.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Even I helped-- helped my-- my husband's family there because they didn't have so much, not so good in the ghettos.",
      "word_count": 21
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And how did-- what happened when you had to move from your house to the ghetto?",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "From-- from my house in the ghetto?",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Into the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Into the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Whatever somebody could carry in your hand.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And you left everything.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "How much you can take it in you hand?",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "So we left everything there.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "All right, my mother took a pot and a kettle.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "You know how it is.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "She said, we're always the smartest there was.",
      "word_count": 8
    }
  ],
