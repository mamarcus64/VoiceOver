{
  "stem": "23131.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 3 SECONDS] My-- the only thing is that I wasn't too much home in the beginning because I still was in Bialystok in school.",
      "word_count": 26
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 28,
      "text": "It was in '39 when I came home, [PAUSES FOR 3 SECONDS] and they were already married.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 29,
      "text": "She was the-- the boss of the house, the [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 30,
      "text": "After every-- Mommy left everything in gold and in silver and everything, my heart busted.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Daddy didn't tell nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "That was the reason that my brother came to pick me up.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I shouldn't get a shock coming into the house.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if they were married, to be honest with you.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "But I know-- they married later on, but I know they were together.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "I know that my-- the-- the bedroom of my father and mother wasn't anymore my father's.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "It was a mutual bed room.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And it was very hard for me.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "You know, I don't know what she wanted to prove, but my father suffered terribly.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "He was between the hammer-- his daughter and his wife.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "I guess he liked her.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "She was extremely intelligent person.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "Any book, any-- any film, any-- any movie-- everything, you could talk with her.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "And she had-- and then, you know, [PAUSES FOR 4 SECONDS] when-- in '39, when they started-- already when the Russian came in and the Poles had to leave-- and my father was a capitalist and a very, very rich man.",
      "word_count": 41
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And they wanted him.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "They want everything, and they wanted a [INAUDIBLE]-- they took away everything from him.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "And, you know, like the business-- he wasn't any boss anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "But him, personally, and his family, they wanted to ship to Siberia.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Already?",
      "word_count": 1
    }
  ],
