{
  "stem": "7860.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And I followed them to the outside of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And they got into a field where everybody was stealing potatoes and the field, and the farmer wasn't protesting.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "And I did the same thing, too-- brought some potatoes home to have what to eat.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was the city-- Otwock.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "O-T-W-O-C-K-- 25 kilometer near Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they had to relocate from outside a little shack we lived in to another shack in the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "With other people, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "There was a fence around it, barbed wire.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Anybody leaving or coming, regardless who the person was, would be shot on sight, guarded by Polish, Jewish, and German police.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And anybody going in-- regardless of your age.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I managed always to sneak in the ghetto and sneak out and come and go.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Very often-- I used to leave in the-- instead, I see children lying dead on the streets, grown people lying dead on the streets, naked because somebody took their clothes off already and the horse-drawn wagons that pass by and pick up the bodies and pile them on a wagon, horse-drawn wagon.",
      "word_count": 52
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Two men would pick them up like you pick up garbage over here and then bury them in a common grave outside a ghetto in a cemetery, over [INAUDIBLE].",
      "word_count": 29
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I start sneaking out the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Underneath the barbed wire, I dug a whole.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And I camouflaged the hole.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I used to come and go.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "That was my own private gate, entrance, and coming, going.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I used to walk straight ahead of me, go to various villages.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I would see a village and stop and go, ask for handouts.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "First experiences were very bad for me.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "I was inexperienced back then.",
      "word_count": 5
    }
  ],
