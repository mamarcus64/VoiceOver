  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 9 SECONDS] I guess I would like to forget misdirected anger.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I would like to-- I wish I had been appropriately angry at times and less inappropriately angry.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents were courageous people.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They were decent people.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They-- they made a huge sacrifice.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They had enormous-- I survived because of the courage of my parents and the vision of my parents.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I survived because there were people in England who took it upon themselves to help perfectly strange people to whom they had no family connection to.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I survived because there were some people along the way who [PAUSES FOR 3 SECONDS] put their arms around me.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I mentioned three women, my mother, Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE], and Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Cartwell-- more than one, more than three, four-- who were not-- except for my mother, who were not related to me, who went out of their way to help me in a way a human being helps another human being, not because of anything particular in me, but because they were human beings who showed me what it is to be a human being.",
      "word_count": 64
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "So I survived because there are good people in the world and people of character who live up to what it is to be a human being.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well, let me start out with to my child, my daughter, that I tried the best I could and I-- I know I've screwed things up along the way in some ways, that I hope she can find joy [PAUSES FOR 4 SECONDS] amid the bumblings of a life that had not the kind of support that many other people have, but also that I've had privileges that I feel good about.",
      "word_count": 72
    }
  ],
