{
  "stem": "2118.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--and a real game.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Who-- who are you guys playing?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We play like the E channel, Amblin-- we're gonna play Amblin this year.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "So we play all different-- any kind of studios we play.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So it's fun, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And when Michael told me that yesterday, you know, I talked to this guy Friday.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I'm kind of hung up right now.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I don't know what to-- I mean, I want to stay with Shoah if I can, but if I go-- you know, I've got to go with-- I've got to do something.",
      "word_count": 32
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I would love to stay with Shoah and work, because I enjoy this.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "But there's not enough-- or, what's the-- what's preventing it?",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "The-- see, this one guy, the Stan guy got married.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And he's on his honeymoon.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And they want me to fill in for him for three weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "Oh, I see.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And he said I fill in for him for three weeks, and then in June, when they hire more people, they'll hire me, right?",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And-- Go ahead.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "Today's date is 24, April 1995.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "The survivor's name is Leon Wendel.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "The interviewer is Ellen Baskin.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "The city is Los Angeles, California.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "We're in America.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "Today's language will be in English.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "OK, go ahead.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Leon Wendel.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "E-L-O-N W-E-N-D-E-L.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "L-E-O-N.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born Lajwa Wendel, which is L-A-J-W-A.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In--",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in April 4, 19-- April 7-- my correction-- April 4-- April 7, 1924.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I'm a little nervous.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In Lodz, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We were five brothers and one sister.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father was Kalman Wendel.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was Esther Hannah Wendel.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My oldest brother was Leibel.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The next brother was Hershel.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Next was my sister Alta or Adela in Polish, or-- I don't know how it would be in English.",
      "word_count": 19
    }
  ],
