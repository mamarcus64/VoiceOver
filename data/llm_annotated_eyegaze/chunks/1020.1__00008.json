{
  "stem": "1020.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But the reason a lot of people told the Russians that they were communist, they were the ones were sent to Siberia immediately.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Because Russia had the politics not to trust anybody from outside Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They say, if you were a communist, fight where you are.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Don't come to us.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "We don't need you.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "They didn't trust.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Well, they let us out.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And a few times, I was sent.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I went to Lvov, another city from Pshemish.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In 1940 already.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I escaped from the coal mine, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Russian side.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I was on the Russian side.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I went to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And then, they organized us and they sent us again to coal mines in Donbas.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And in there, they let me go down to a shift.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And they gave me go punch a hole in the wall and the coal.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I remember when I start to slide in in that foxhole, I lost my galoshes.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And I walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I says, kill me.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I'm not going back.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So they send me up, and I walked up, up on top on the grounds.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And didn't last long.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And I ran away again.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I run.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "But I couldn't help it.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I was arrested by the Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And I was sent to Siberia to a concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Why were you arrested?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I got ten years for being a counter-revolutionary.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Because my father had a little business on a market.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So I was a capitalist.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "With them, you don't play.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They did what they had to do, what they want to do.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So I didn't last long.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I was in Siberia into the 19-- when the war started, 1941, with Russia-- German-Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "In 1942, at the end, I escaped.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "From Siberia?",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In the middle, in '38, I escaped from Siberia.",
      "word_count": 9
    }
  ],
