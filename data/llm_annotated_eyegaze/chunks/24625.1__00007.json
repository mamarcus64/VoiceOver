{
  "stem": "24625.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "What did your parents tell you when they first-- you know, when you were first going to be taken to the homes?",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They told us that they deport us if we stay.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "If they're going to catch us, to go away.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "At least, us, we will survive.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "That somebody should remain from the family.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "That's why they did the sacrifice, and gave away the children.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "They didn't have them in mind.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They had the safety of us.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And as a matter of fact, in account of this, most of the children in Belgium survived.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "The parents deported and killed but not the children.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "They did a big job for the children.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "A lot of them remained orphans.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I was lucky my parents survived.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "But not all of them were like this.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Most of it if you want to think back, it's like normal children do.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We didn't do any-- we didn't do any robbery or killing or anything, but we were not disciplined the way it should be.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Those guys-- the chiefs of the scout-- if they say stand up, we should stand up.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Sit down, sit down.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We had to do so many chores.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Every time we did something wrong, we had to go-- I remember I had to peel a mountain of potatoes.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I was-- I didn't see the sun in front of my eyes.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I was peeling potatoes all day long.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "They came in with shovel coal.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "We had to do.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Always the same group, the same bunch of guys.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "But we were the bigger ones.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "See, I was already-- I was pretty big for my age.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "When I was 12 years old, I was the size that I'm now-- I mean, no.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Maybe not-- but when I was about 14 years old.",
      "word_count": 10
    }
  ],
