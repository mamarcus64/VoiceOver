{
  "stem": "1354.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "It was maybe a half a hour with the-- with the train.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "That was-- well, the war broke out in '39.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And that was in '40, '41, something like that.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And my parents--",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my father, he went to Kocmyrzow, and they rented a-- it was a-- a room with a tiny kitchen.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And we took our stuff, and whatever we had, and we went there.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "My brother went to ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Oh, at that time, both of my sisters got married.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "My Erna, the-- the third one in the row, she got married in '40.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Then, later on, my oldest sister got married too.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "She married a fellow, what he came from-- like, they were-- first, they sent the-- all the German people from Germany, they sent to Krakow.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And we all-- my older sister did not go to first to ghetto-- to-- to ghetto either, just with us.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "But then later on she went back to-- to ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My mother, my father, and-- and the three of us that's left at home.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I mean, because my brother stayed in-- in ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And over there, we-- we had some savings, so that's what we lived on.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And besides that, my father used to travel on a train to ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He-- at that time, we had to wear the armbands.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "So he put like a-- like a scarf, a plaid, over the armband, and he was traveling.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "At that time, Jewish people, we-- we couldn't anymore, you know, travel on the train, or-- so he put this scarf over-- over his band, and he traveled to ghetto.",
      "word_count": 30
    }
  ],
