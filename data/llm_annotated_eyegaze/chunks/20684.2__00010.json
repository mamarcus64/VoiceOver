{
  "stem": "20684.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "I mean, they were already in hospital being stitched up, the ones that were still alive.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "I got a dead fellow's leg.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "And so he took that leg.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "He had a look at the leg and he put it against the post.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "And I was trying to explain to him it was the best there was.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "And he tapped me on my head and he was saying something like, gee, that's terrible.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "Well, there's something-- I can't remember exactly what he was saying.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "But anyway, he started crying.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 42,
      "text": "And I-- I was surprised.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 43,
      "text": "I hadn't seen anyone crying for-- for a long time.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 44,
      "text": "I mean, you know, partisans don't cry, big boys don't cry.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 45,
      "text": "Crying is always [INAUDIBLE] allowed to cry, I told myself.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 46,
      "text": "I figured [INAUDIBLE] a partisan, not like us.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 47,
      "text": "I mean, we partisans don't cry.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 48,
      "text": "We-- we live or we die.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 49,
      "text": "We kill or we die, but we don't cry.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So he was crying and crying.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And anyhow, he said he's got to go back to-- to work because he's in the middle of-- of looking after sick people, trying to make them not sick people.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Sick people.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "People with legs and arms missing were sick people.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "That's why I brought the leg and he wasn't fooling me.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And they weren't just sick people.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So I said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And I walked away.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And-- no, my father walked away and then I walked away and he waved to me.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And then I came back.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I was all upset because e went away and left the leg standing against the pole.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I came back and I told my father, look, it took me three hours to bring that leg.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Oh, and he felt sorry. he took the leg and he was still crying.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I went away.",
      "word_count": 4
    }
  ],
