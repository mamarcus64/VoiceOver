{
  "stem": "12768.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Bent Lerno, B-E-N-T L-E-R-N-O.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Sally Levitin, L-E-V-I-T-I-N.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I got the name Shlomo, S-L-O-M-O.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "January 22, 1927.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I am 69 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a place called Charlottenlund, Copenhagen, Denmark.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was, like I said, lived in a suburb called Charlottenlund.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We lived in a, I guess, a fairly nice home.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "But my father wanted to build a basement under it.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "In those days, also, there was no basement.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And the house started falling down into the basement.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So the engineers came out and said that, unfortunately, they couldn't do anything.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And the house should be torn down.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So my father instead built the first high rise outside Copenhagen, which was a five-story apartment house.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And it was finished in 1928.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And it is still standing there today.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I had [PAUSES FOR 3 SECONDS] three brothers and a sister.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My oldest brother-- I had two that had passed away before I was born.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So I thought that there was no sense of naming them.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But my oldest brother, Richard, [PAUSES FOR 3 SECONDS] was born in 1910 and-- no, I'm sorry. 1911.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "This year he would be 85 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "My second brother which passed on was Harry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And I have a sister, Ida, I-D-A, Ida.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Her married name was Goldine.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And she was married to a  doctor, which later became my doctor until he passed away.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And then my brother Paul, which is about two years older than I am.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Paul and I have been, I would say, real good friends all those years and have enjoyed each other's company.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "Like, I was just in Denmark visiting him.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "But we'll come to that later.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "We lived in Charlottenlund till about 1930.",
      "word_count": 7
    }
  ],
