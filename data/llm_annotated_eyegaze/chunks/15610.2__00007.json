{
  "stem": "15610.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 421.1,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "And then went to Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "He bribed them, probably he bribed them.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know all the details, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have newspaper.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have radio.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know nothing, just what you could hear from people.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "One month.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and it was terrible feeling.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "My sister, I met there.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I heard that this Madrit group is there.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "So I was asking.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Madrit, where she was working.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "M-A-D-R-I-T, Madrit.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Like the in Spain, this capital.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Like in Spain, Madrid.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "His name was this, where she was working.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "But he didn't have this power like Oskar Schindler to save them, so they went to Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And from Auschwitz, they killed them.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I saw my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I saw my father in Auschwitz too.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Where the man been.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "So I been asking, do you see [?",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Lukower? ?] And they say, no, go there, go there.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And I found him.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "And I found my sister too.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, just sitting.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] We were happy to see each other, but we didn't know the future.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "He was good looking.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "He was not skinny, like starving or something.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "And I say, oh, you look good.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "I was happy how he looked.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "This was not work to do there.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "We didn't do nothing, just waiting.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Also nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No work.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "This is worse than to work, you know that?",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "The day is so long and so boring.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "This was another punishment, not to work.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "And the uppers were there also in morning, early in morning get up.",
      "word_count": 13
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz also.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "The upper, what I say, they wake us up 5:00.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And we have to go out, everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And they start to count us.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "What we could say, we didn't know what will be.",
      "word_count": 10
    }
  ],
