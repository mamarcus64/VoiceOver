  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And that's what it's about.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And yes, it-- it-- it stays as a special interest.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It, it is not-- it is, the subject of the Holocaust, and even of Germany as-- as such and of Mainz is a-- is one that is, that remains very special.",
      "word_count": 31
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "It, it's part of me.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And in fact, it's special to the children, too.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And I think, I hope it will be to the grandchildren.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "It's something they have to know about.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "They have to know what it was like before and what it was like during.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And you know, they read about Anne Frank.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "Well, it could have been me.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And I want them to know that.",
      "word_count": 7
    }
  ],
