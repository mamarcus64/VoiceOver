  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] It was a general on the train, and he himself shot three Russian soldiers for raping the girls.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] He didn't want to have no court, no nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "He just plain took out the Browning and shot them.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "When I arrived to-- in Kielce, first thing, I didn't go to my house.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "First thing, I went to my uncle's.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I knew-- when I came in, I was told that my uncle lives there and there.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So I went to him, and he told me what, what-- he was liberated in January.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "He's dead now-- Joe [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My-- he was my, my mother's brother.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] And he said, [PAUSES FOR 3 SECONDS] you need a doctor.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He took me to a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "He told me the story that my younger brother was hid there and was waiting I should come.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "But he couldn't wait any longer.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "He wanted to get-- to go out of Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So him and some friends of his, they went to Italy, because in Italy, the Catholics, the Catholic Church-- if you went in and you said you want to convert, you used to get paid money.",
      "word_count": 36
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We'll go to break now.",
      "word_count": 5
    }
  ],
