  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And my mother inquired between the customers of ours-- such trusted customers and trusted maids-- that if anything should happen again, would they-- would they take us in?",
      "word_count": 28
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Would they shelter us?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We really never had a definite answer from them.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "My cousin, the pharmacist, made out Aryan papers.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And-- How did she get them?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "She had the connection because of-- because of the pharmacy.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Because the-- the-- even the SS, even the Germans, needed some assistance with pharmacology.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And they helped them, you know, with medicine.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And the Ukrainians, the one that was not in the Judenrat but they were in the-- in the-- in their committees, they also were very much helped.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Herself and her husband.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in the pharmacy--",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Until the fall.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Until the fall when the new action started.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Right, when the-- when the rumors of the second action is going to be.",
      "word_count": 14
    }
  ],
