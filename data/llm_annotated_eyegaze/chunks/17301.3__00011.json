{
  "stem": "17301.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And she says to me, if you're going to say anything to the kapo, she says, you're not going-- they're not going to find you tomorrow morning alive.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "So I was afraid to say anything.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Nobody said anything until-- we were there not-- not too long, thank God.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "We were there maybe four days.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And after four days, again, they lined us up.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "But we are taking you someplace else.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "So, again, we started to walk out of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And I said to my mother, nothing can be worse than this.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I said, wherever we'll go, maybe it's going to be a little bit better.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "I say, each time it's better.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "It's-- maybe this was better than Auschwitz, maybe not.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "But maybe they're going to take us out of Ravensbruck.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Maybe it's going to be a little bit better.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "They took us out of Ravensbruck.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "We start to walk.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "Again, we went to the train station.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "And we were walking.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "We didn't know we were walking pretty good distance.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "They put on train station.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And we ended up in Neustadt-Glewe.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "And that was the camp that we were liberated from.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "And when we-- when we arrived to Neustadt-Glewe, they, again, they put us into a building.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "There was not barrack, like a barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "It was a-- a wood-structured building.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "And they put us in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "There were no bunk beds.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "It was just one huge room, huge.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "It wasn't huge.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 36,
      "text": "We thought it was big, but it wasn't big because we were like 60 of us in one room.",
      "word_count": 19
    }
  ],
