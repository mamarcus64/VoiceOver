{
  "stem": "753.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But I couldn't, just emotionally couldn't.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I wasn't right for it.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I went back to that first village, Possagno, which was a very emotional experience.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And I knew I can't take more of that.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So yes, I, I met a few people that I was friends with in those days.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "They were old already.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But yes, I did go back.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And how long did you go-- did you live in Yugoslavia after the war?",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I lived five years.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And then I went to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I married.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I had children.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I worked.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I did not have the opportunity to go to school anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "But it was a pioneering life, and nice and free, and very good to be young in Israel.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I married a few-- a year after I arrived to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "My husband was a survivor from the Holocaust, like I was.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I met him the first time right after the war, when I was 15.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And then we didn't see each other until we-- we were not connected at all.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And we came to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We fell in love.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We married.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "We had our children.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Mirko.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "My daughter was born in 1954.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Her name is Liora.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And my son was born in 1962.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "His name is Amir.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "We lived 16 years in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] And I would like to, [SIGHS] I think, conclude [SIGHS] this meeting.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] I would like that post-Holocaust generation [PAUSES FOR 3 SECONDS] to know that there was decency and goodness in those days, that not everything was negative.",
      "word_count": 30
    }
  ],
