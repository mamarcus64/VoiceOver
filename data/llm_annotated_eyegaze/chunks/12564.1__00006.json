{
  "stem": "12564.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "It was the first the firemen in the city, in the town, they called them in Polish, the [POLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But this was the volunteer fire department.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "They were catching.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "For each Jew what they caught, they got 5 kilo sugar.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The Germans.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And there were other ones, didn't care for the sugar.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They were just catching and killing.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, this family, Matisek, where we were hiding in the bunker, their grandson was one of the biggest killers in town.",
      "word_count": 25
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Every couple night, he came in the evening sitting, and talking, and explaining how many he killed, and how he killed, with a hatchet, with a shovel.",
      "word_count": 27
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And we were hearing everything.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "But we know everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We found out from the family where we were.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "But then, who is the killers and who is not?",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And we know the people who used to live over there.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "So we know who to go.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And by the end of the six months being the bunker, the fact that we had to leave this place-- let me retract that.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "One night, my sister, Regina, left in the morning for food.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "And that time was really quiet in town, so Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "Matisek ask us that we can already sit a little bit in the kitchen the night to straighten out.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "There was no light, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "And about 10, 11 o'clock in the night, we hear a big noise.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "Four of, I think it was four of them, from the bandits, they caught my sister, Regina.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "And they were beating her.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "They followed her, actually, they burst into the house together with her.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 15,
      "text": "And they find mother, sister, my brother, sitting in the kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 16,
      "text": "I, at that time, jumped under the bed, slide over.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 17,
      "text": "They did not see me.",
      "word_count": 5
    }
  ],
