{
  "stem": "9031.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "This was about-- they never-- they never took in buses that are in some places.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "We was walking, the people.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "This was one hour and a half to walk to the-- to the other place, to work.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I was some-- sometimes I was work.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But I work for somebody else-- and for my sister, for my sister's friends.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And they-- they give-- my-- my sister's friends, they give me something to eat for this day-- a piece of bread, a piece of brother-- of butter, sometimes water, sometimes tea-- like that.",
      "word_count": 33
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "We-- kids came, when the Germans saw us, it's small kids.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And they can't do hard works.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They tell us, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "This is-- this is 40 people.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "You must do-- care for them, to bring to them water.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And when we was have nothing to do, we helped them.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "We took the-- the hard [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And we helped them to-- we slept, everything together, with the people.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean the walls?",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "They-- we have the yellow sign, five-- this is the Jewish--",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish star.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And we must to be-- everybody must to have, in the front and in the back-- in the back-- two stars.",
      "word_count": 21
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Because they must to know, and they see you in the face, and when they see you in the back, what this is a Jewish person.",
      "word_count": 26
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean guarded?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "There was Jewish [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "We have a committed, special, nice people, what they explain to us what to do.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Today, we must go-- the Germans today need thousand people to work.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Today, the Germans need money.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Today, the Germans need jewelry.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And we must to give to them five, six pounds jewelry.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And if we do not do this, they will kill them, the Jewish people.",
      "word_count": 14
    }
  ],
