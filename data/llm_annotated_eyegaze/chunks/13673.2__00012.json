  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Very late, not-- I really-- and the day after they left Stuttgart, the American consulate closed down.",
      "word_count": 17
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So they literally escaped by one day.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't aware of it, no.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I would-- well, depending on if it was wintertime, I would have to get up and sort of quick wash myself in the-- from a bowl that had probably a layer of ice on top, and then get dressed.",
      "word_count": 40
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And very often, I would get dressed in bed because it was so cold.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And-- well, and I went to school, and we had air raid drills, though.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "We had to be ready to jump out of bed in the middle of the night.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] But other than that, just a regular kid's day, I think.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "Going to school, doing homework.",
      "word_count": 5
    }
  ],
