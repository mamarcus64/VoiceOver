{
  "stem": "6526.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "But they were most of the time already people that my father knew.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They needed to sleep overnight or-- or have a meal.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "There was always an open door.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "All Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And we had-- a matter of fact, we had also Polish neighbors because the mi-- the town was 70% Jewish.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "The outskirts of the town was occupied mostly by Gentile, by Poles.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Our house was almost the last house in town on the way to Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And the next neighbor had another restaurant, but it had like a meat place they used to sell non-kosher food.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "So that was the last house.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And then there was an-- an orchard.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "A man-- but this was not occupied on the side, not on the main street.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "At the beginning, I was three, four years old, I went to Cheder.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "At six or six and something-- it depends the time.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I think I was six.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I went to public school, which was school for all children, Polish, teaching us Polish and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "When later on I went to three schools.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "In the morning, from let's say from 9:00 to 11:00, or 9:00 to 12:00, I went to Hebrew school teaching me just Hebrew.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Then I went to public school for the-- to teach everything else.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And in the evening, a rabbi used to come to the house to teach me for bar mitzvah and so on and so forth.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "So it was a day of school in--",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "At home.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Well, there were two types of schools.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "See, mostly the pe-- the Jews in our town spoke Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "So for them to speak Polish, they had a very bad accent.",
      "word_count": 12
    }
  ],
