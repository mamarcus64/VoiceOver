  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "There was no resentment.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "There was no resentment.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "At least not when-- when I-- among those-- those which I was there.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I saw them taking off the clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't [PAUSES FOR 3 SECONDS] on top of them.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "But I-- I-- I heard the-- the-- the-- the dogs barking, and they chased them.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "First of all, they went there.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And then it was full, and they could-- with no place to go.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "Then start the-- the-- the-- the dogs, the-- the rest of it, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "Until it was full, full.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "Close the door.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "It could be heard.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Could be heard.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "After-- after the gassing, there was a commander which was the [? schleppers. ?] You know?",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They pulled by the hand or by the legs.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And they put on masks, and they ventilated.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Because it was impossible to be there.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And they cleaned it, because everybody-- everybody was soiled.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "This is-- this is-- this is a terrible death.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "It's a terrible death.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "One steps on the other.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "One-- one just-- the place inside looked-- there was no place to-- to sit down.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "Everybody was one on top of the other.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And some of them held themselves other.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "You had to force it to separate.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] That's what it was.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I'm not calm.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I'm not calm.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "But I try my best.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Reading.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "What kind of thing?",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "History.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "Jewish reading.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And I love Jewish reading in-- in Tanach.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 4 SECONDS] I read.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Hm.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "As I told you before, I made already a tape, and I made another tape.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "But I overheard in this neighborhood somebody made a tape.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "So I said, why not me?",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "I have a story like anybody else.",
      "word_count": 7
