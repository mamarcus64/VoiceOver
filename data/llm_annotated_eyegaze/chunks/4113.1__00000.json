{
  "stem": "4113.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Alexander B.-- which stands for Bialywlos, my old name, B-I-A-L-Y-W-L-O-S-- White, which is my present name, W-H-I-T-E.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is June 4, 1923.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I didn't hear that.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "72.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a small town called Krosno, which is right near the Dukla Pass of the Carpathian Mountains in southern Poland.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a small town.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It had approximately 15,000 to 16,000 population.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "There were a few thousand Jews living in that town.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And it was very much like any shtetl in the old country-- a picture of which I believe you have, if you want to show it later on.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And the Jews did very much what they used to do in the shtetls.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Many were tradespeople, carpenters, bakers, glaziers, blacksmiths, et cetera.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And some had stores.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And they lived amongst the non-Jewish population quite peacefully, and went on to live their lives the way they had for years and years prior to that.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The members of my family, of course, my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was a Mendel.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Leah.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My mother's maiden name was Platnar.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And of course, I had my grandfather, my grandmother, on my mother's side.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We lived together in the same little apartment, which consisted really of two rooms and a storefront in front of it.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And of course, I had two brothers-- one, one year younger than myself, and one was born the 1929, and one sister who was one year older than myself.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My sister's name was Miriam.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We call her [?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Manya. ?] My brother's name Schlomo.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We called him [?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Shlomeck. ?] And my little brother's name was the Henek, which actually his Hebrew name was Chaim Hirsch, because that was my grandfather's name, after whom he was named.",
      "word_count": 29
    }
  ],
