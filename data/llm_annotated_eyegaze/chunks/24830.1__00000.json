  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Micheline Marmor.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "M-A-R-M-O-R.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And the first, too?",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My first name is M-I-C-H-E-L-I-N-E.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Micheline Kaplan, K-A-P-L-A-N.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Beaumont.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "B-E-A-U-M-O-N-T.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Same, Micheline.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "August, 20, '23.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Paris, France.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Now, I'm 73.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father is Charles Kaplan, same spelling.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Charles.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Estelle Kaplan.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, before the war?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "OK, well, my brother is-- well, you want the name before the war?",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Sammy, [FRENCH].",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "OK, [FRENCH].",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Kaplan.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And my sister, Ellen-- Ellen Kaplan.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we lived in a very nice part of Paris, which is [FRENCH], [?",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Cannes ?] [FRENCH], which is, if you know Paris, it's-- a street between-- it's between actually [?",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Opera ?] and Madeleine.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "L'Opera ?] and L'Madeleine.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Well, it's known, you know, known monument.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And we were born there.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "My parents lived-- as long as they were in France, they live all their life in this apartment.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And-- and we have to move during the war, during the German occupation.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, we have two.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The third floor was the business.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "My parents designed clothes-- high class, haute couture, we'll say-- clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And this was in the third floor.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And then we live in the fifth floor.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We have, you know, the-- the bedroom and the kitchen and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "We-- we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, I share my room with my brother and my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "To me, it was very large.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But when I went back to France and look at it, it didn't look that large.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Like the street-- I thought the street was a big street.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And when I went back, it didn't look so big.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I thought I closed it.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Well, my-- my mother and my father and-- and the three of us.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I went to school, you know, I had my school friend.",
      "word_count": 13
    }
  ],
