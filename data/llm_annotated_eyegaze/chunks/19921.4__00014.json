{
  "stem": "19921.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 326.1,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "In other words, if you were Jewish, you said you're [NON-ENGLISH] and if you were Uzbek, you said 'Uzbek.' It was on your documents.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "There was no cheating there.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Some of the Russian Jews, you know, down to the commoners, they didn't have the circumcision, so they could not be recognized.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "But in any event, they had it in the document that they were Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "There were still Russian people alive.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "You didn't see any men.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You saw men are only with guns, partisans.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "You only saw women or children.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I did not see men free except when the guy was 75 or 80 years old, you saw other men.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "But that's about all we saw of men.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "But people were there.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "People were there.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "We stayed-- there was a time that we stayed in-- near [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "The front advanced towards, towards our line to the Polish border.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And when there was a long stay, we stayed in the farmer's place.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "You know, like, we got in like 10 soldiers, 12 soldiers, 15 soldiers, whatever it is, we stayed in the farmer's place overnight.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "During the day, we moved out from there, went to the guns.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "The following day, the same thing.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "They would tell us everything.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They would tell us the stories.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They would tell us what was going on there.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And you could see because there was a lot of destruction-- houses burnt, people hanging, so you really could, visually you could see.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And all those graves.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
