{
  "stem": "18397.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 176.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Because how-- how long can you eat over there, from-- from the pig?",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] And then it was night, and we came to a highway.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And then I see-- they're going after-- I figure they're going after me, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Who is escaping?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Me, I was an escapee.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "But no, they were going into Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I see the people are black, dirty like me.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Everybody the same thing, and all the people, I figure this is-- they go to Poland, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I stand up, and I mix through the people.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And they didn't even look at me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I tear off my-- my things, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "What did you tear off?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My-- my not medals, but it was a-- like-- [NON-ENGLISH], what do you say-- what do you say, in the-- in the sky, you know the one that flies and catches?",
      "word_count": 31
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The Polish emblem.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We have-- you know, like an--",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Insignia, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] is what is it?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You're not allowed to hunt him now?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Eagles, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "This was an eagle, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And we took off all the buttons.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I was laying there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I figure, that's it.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I stand up, with the-- with the guys.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "They didn't even look at me.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "They didn't have the strength.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They're soldiers.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "They're Russian soldiers.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And we came to a place, and we sit down.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And they start eating.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And a guy asked me, did you eat?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I say, something.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He took off a piece of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "He gave me a piece of-- of pork.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And I ate.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "All of a sudden, I became alive.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] And we start going, you know, and it was pouring.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "It was raining.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "It was anything that you wanted.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And we came to a place.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "All of sudden, we see lights.",
      "word_count": 6
    }
  ],
