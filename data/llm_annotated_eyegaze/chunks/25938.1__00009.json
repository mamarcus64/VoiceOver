  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "Like ulpan, and the method of teaching was excellent, I must say this, in-- in-- in-- in that-- in that school we learned Russian, Russian geography and biology and-- and-- we learned a lot.",
      "word_count": 34
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "Took me six months.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "So then I chose to be a teacher in-- in-- in-- near Sokolka, in a little village.",
      "word_count": 17
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to be far from-- they offered me a job in my little town.",
      "word_count": 15
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "But I-- I begged them not to send me there because I didn't-- I wanted to be near my Bashe.",
      "word_count": 20
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "And they showed me the maps, the little-- little villages where I went to work.",
      "word_count": 15
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "So I-- I appointed to that place near her.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "I was there.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 6,
      "text": "I was teaching the whole year.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 7,
      "text": "And every Sunday-- we got Sundays to come for the weekend to my-- to-- to her in Sokolka.",
      "word_count": 18
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 8,
      "text": "Cult",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "In 1941-- in 1941, I-- I-- I left for vacation to my little town.",
      "word_count": 14
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "So when I left that-- that house, I have Bashe there.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "She insisted I stay her-- with her.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And I insisted that she comes with me.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "So we were about discussing that what to do.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "And then she accompanied me to the train, and the train, she said to me, and OK, come-- come to me, or come-- come with me.",
      "word_count": 26
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "I said, no, come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "And then the-- the-- that the men said, OK, we are moving.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 8,
      "text": "And the train moved, and I went to my little town.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 9,
      "text": "And then at-- at night, I had a dream that war broke out.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 10,
      "text": "I had a dream that war broke out.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 11,
      "text": "And I woke up about-- in the morning, I woke up and Mother came to my bed and said, says, Leybl, [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 12,
      "text": "She said, [NON-ENGLISH] It's a word.",
      "word_count": 6
    }
  ],
