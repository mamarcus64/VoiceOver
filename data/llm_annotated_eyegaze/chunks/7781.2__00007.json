{
  "stem": "7781.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "This-- the German administration, they were the sole suppliers.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "They decided what to supply and how much and so forth and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Only the food that came into the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Then they knew how much food the Germans shipped in.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And that was allotted so much-- let's say, two pounds of potatoes, or five pounds for two weeks, sometimes a can of little sugar or oil.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And that was divided.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "You had those coupons.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And they would say for this coupon, you get this and this and this and this or whatever.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "You used to go to the store, and they used to give it to you.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Not to buy.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Only was-- they were given to you what they decided that everybody else should get.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And now they decide five pound potatoes, you got five pound potatoes or beets.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "A food warehouse, a distribution.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was not a store you can go.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "We would get coupons.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Coupon number two was [? whether ?] you get two potatoes, two pounds of potatoes, a half a pound of bread, and so on.",
      "word_count": 24
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "This should have to last you for two weeks or a week, you know, something like that.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And the administration tried to divide the food among the Jewish people living in the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You didn't get any more food.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Everybody got his card.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] They didn't give food for family.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "They gave food per person.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And everybody had to manage his own food.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was pretty grown up.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I had my own card, my own identification card.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I was getting so much.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But before the war-- before the war, we used to eat collectively.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And-- and after-- during the war, we couldn't eat collectively anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't put the bread on the table.",
      "word_count": 8
    }
  ],
