  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "If there was a little bit of not even freedom, but a little bit of not so much oppression, that if you didn't work 28 hours, 24 hours, and they didn't grind you to the point of destruction, [BACKGROUND NOISE] there was always this development of some songs and so on.",
      "word_count": 51
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And that's all that I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know, I went through-- I was in Slonim, Grodno, in Vilna, and then-- in Estonia.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I learned songs in every one of them.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Not so much perhaps from Slonim.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "But-- but there must have been there some, too, that I knew.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I think that the Russian one I told you came from there.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "A thought about the policeman was hilarious, about the cemetery stuff.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I always used to laugh about it.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And so people who I used to sing used to laugh about it.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Because obviously, it's humorous.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
