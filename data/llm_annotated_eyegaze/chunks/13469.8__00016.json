  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] You can say all these sort of thing.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And as I said to your colleague earlier on, if I went to a therapist, they could say all sorts of things, that I'm shut it away on purpose for 45 years, because I did nothing about the Holocaust for 45 years.",
      "word_count": 42
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "But it wasn't on purpose.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Nobody was interested.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "If somebody would have wanted to talk about it, I was quite prepared to talk about it.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I was very busy in those years trying to catch up on studying and working and making a living and leading a normal life.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And I don't think I shut it away on purpose.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "I just didn't find it interesting and I didn't think anybody else was very interested in the Holocaust.",
      "word_count": 18
    }
  ],
