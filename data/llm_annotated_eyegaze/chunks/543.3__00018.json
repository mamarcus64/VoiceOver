  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "The station-- the army station.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "The station where they are.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "So they wanted to give me coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "They want to give me chocolate.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "But I had to make them understand that I had to go back for Lillian.",
      "word_count": 15
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "And I speak very poorly English.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "Not that I speak it so good now, but then-- you know, I said, you know, I have to go back.",
      "word_count": 21
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "I have to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "And slowly they started to understand me.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 9,
      "text": "And we looked for her.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 10,
      "text": "I forgot where it was.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 11,
      "text": "It took an hour.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 12,
      "text": "And I find her.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 13,
      "text": "And she was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 14,
      "text": "And so was I.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 15,
      "text": "And then we-- and then, the guys also didn't want to pick her up-- went back for a-- for a stretcher and picked her up in a Jeep, and took us to the-- to their place.",
      "word_count": 36
    }
  ],
