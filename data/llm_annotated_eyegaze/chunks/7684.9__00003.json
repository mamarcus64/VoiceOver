{
  "stem": "7684.9",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "And we stole sometimes carrots from the field, And at night sometimes, we walked at night.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "And then dog come in back of us, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "It was very scary.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "You know, every minute you thought, that's the end.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "So after 10, 12 days walking-- we don't know exactly how many days and how many nights.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "We came by a farmer.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "And Chaim say to him, can you hide us?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "And the man say, no.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "You could stay overnight in the farm, and I will bring you tomorrow morning to my brother.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "He lives isolated somewhere.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And I will bring you to my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And we trusted this man.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And Chaim was on the wagon, a very old fashioned wagon, which you see in pictures sometimes, from 100 years ago.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he put branches over Chaim.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And he dressed me up like a Polish woman.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Chaim always say like an old lady, like I am now.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But I was more like a Polish woman.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And he brought us to his brother.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And we came there, in the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "He let us wash.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And he saw how we had scabies over our whole body, and legs, and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And he say, you can stay in my-- and he saw also the money that Chaim had.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "But, anyway, he say, you can stay in the barn.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And he put us-- the cows were under, and top were pieces of wood.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And there was straw laying.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And we were allowed to sleep on the straw.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And we gave him all the money what we had.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And he really-- he saved our life.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "They-- I have a little diary.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "I can almost not read it anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And I read about it.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "I complain constantly about it.",
      "word_count": 5
    }
  ],
