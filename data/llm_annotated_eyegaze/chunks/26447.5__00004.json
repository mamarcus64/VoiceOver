  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I say, I didn't got the time, but I can-- I can have a wife.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And that she came-- Mina came back, and we begin to talk with her [? dad and ?] [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And we went-- and we-- you know, in the office in Russia, you-- you don't go to-- to-- to the [? rabbi ?] or what.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We didn't [INAUDIBLE], and we make the papers.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I begin to live in Kiev.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And Kiev, it was a terrible time.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "In awhile, it's past a year, it was born, my older son, in 1946, Michael.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "The time is very bad-- we don't have what to eat, they-- they give us where-- who works-- the government give very little bread [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No, I was talking with the wife and telling her, what to do?",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We cannot stay in Kiev, why we stay in Kiev?",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Let me go in my place, where I was-- I was in ghetto, where I was before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We will see-- I went one time and I saw it's more food in these places, in the smaller villages.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I decided to go in the same city where I was in ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And it was 1947.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I came to my city, Kolki, and begin to work.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I was working in beginning, director, a restaurant, then the director a warehouse.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I was working with all my heart, and I was working it, and they give me all-- all the time, how it's called, better-- better jobs.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "In the time, they send me to study a special school for [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "It was the headquarters from-- from government business.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I was-- and I was study-- it's in [?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Livov. ?] Then I came and they give me a nice post.",
      "word_count": 12
    }
  ],
