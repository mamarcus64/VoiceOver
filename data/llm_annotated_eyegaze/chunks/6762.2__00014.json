    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't estimate those days, not like now, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "[COUGHS] How can you feel?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "I mean, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "A lot of time, my kids can not understand me, either.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "I have a little bit, how should I tell you?",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "Backfire, back  memory-- a lot of time I get aggravated.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "I get nervous.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "They don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And I don't know why, either.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Upsetting, you know, and all that.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "My kids are mostly-- their two Americans.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "One was born in Israel, but he came here, he was 3 or 4 years old.",
      "word_count": 16
    },
    {
