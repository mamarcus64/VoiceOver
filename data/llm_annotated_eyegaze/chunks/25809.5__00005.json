{
  "stem": "25809.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And then meanwhile, they had found a place to live in the Dintelstraat [INAUDIBLE], and-- which was a place of the NSB people that had left when the crazy Thursday came about, and everybody got scared that they better get out of the country.",
      "word_count": 44
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Whatever happened to those people, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I don't even know their name.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But we moved into an apartment, and from there, life started in reasonable, normal fashion.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Or I started going back to school.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we picked up the pieces of where we had left off.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The Apollolaan, we couldn't get it back.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Other people had moved in.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Later off on the Dintelstraat, we moved to the Churchilllaan, right near the-- where the sun-- sundial-- sundial used to be.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Isn't there anymore, the sundial.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But very close to the Apollo [? hall, ?] Almost at the end of the Churchilllaan, Churchilllaan 213.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And we had a downstairs apartment there with a yard in the back.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And I had a little room there, front of the house.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And we lived there, and I went to school.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I went to H-- H-- HBO, [DUTCH], higher so  and so [? otherwise, ?] a teaching-- or school.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And things started to go back to a reasonable, normal life.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "There were still troubles.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I had troubles at school in learning, great difficulties in learning.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "My-- my parents were continuously fighting.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "They had big arguments.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And I think one of the things was that my father was still very troubled and may have taken this out on my mother.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "So there were big fights and big arguments always.",
      "word_count": 9
    }
  ],
