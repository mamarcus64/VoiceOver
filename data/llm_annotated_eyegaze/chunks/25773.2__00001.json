{
  "stem": "25773.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I came to-- and the nurses told me already.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And we spoke the whole night.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And he was very cheerful and he said, do I hurt?",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "There is a, a sunny, a sunny cemetery in Otwock.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Do bury me there on the sunny side.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And it was very traumatic, of course.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And he died the same night.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And I had the task to, to see to, to for burial.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I enlisted the, the, the nurses, the kindly nurse.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Enlisted the carpenter, carpenter who made a coffin, a wooden coffin.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And we put the coffin on a cart, with a horse.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And I was the only one, so the, the, the, the coffin was on the one-horse cart.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And the carpenter was sitting on that or standing.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "I was walking behind the coffin.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And it was a very nice, sunny day, very sunny day, May.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And the lane-- we made the same journey with my daughter and my son-in-law, which we found by a miracle.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And we went to a little Jewish cemetery.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And the little-- the carpenter helped me to dig the grave.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "And we put the coffin to--",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "There was nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "My parents were with the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "My parents were in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I left the ghetto, taking off my [INAUDIBLE] and went to-- so I was the only one.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And then we made, we buried the coffin.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And we put a lot of furs with the hands and he had the shovel-- he had a spade.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And then I gathered a lot of summer flowers from the vicinity and covered the whole grave with the flowers.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And put a name on it, which there was no--",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "A piece of wood.",
      "word_count": 4
    }
  ],
