{
  "stem": "19807.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It's like-- my favorite, it's-- it's like ratatouille but it's got beef in it and it-- that's what gives the flavor.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And they-- after that-- after you cook it, the best thing is to let it go for one day and let it go simmer and after that, like it forms a little bit of a crust and is crisp.",
      "word_count": 39
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "That's my favorite dish.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "It's called ghivetch.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Then it have pastel, which is like-- oh, it's-- it's like a turnover.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "But I mean, it's a large one with phyllo dough and inside filled with-- with like a hamburger meat.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "But very, very tasty with all kinds of spices in it.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And the third one is the-- it's called [INAUDIBLE], which were stuffed bell peppers with rice and meat.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And on and on and on and on.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "I can go there.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "So when I go to Israel, I always gain too much weight.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "But my sister-in-law that learned from my saintly mother how to cook, she's a marvelous cook and she does that.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "But they-- they do keep the tradition.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "My brother, they eat all the time the same thing.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "So I'm very happy--",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I had not seen my parents in five years.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And it was just a year after the war.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I remember going by bus and the bus was so full because everybody was going there that a few of us got on top of the bus and I got soaked wet because it rained.",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And the-- their-- their boat was docked in Haifa and I'm just waiting to see, and finally they-- I spot my father and then I saw but my mother, God rest her soul.",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And I said, where is my brother?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And all of a sudden, there comes my brother, pops up.",
      "word_count": 11
    }
  ],
