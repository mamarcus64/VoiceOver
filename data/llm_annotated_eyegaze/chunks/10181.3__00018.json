  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "There was no selection like in Auschwitz, there was just-- this was just a death camp, and-- and a majority of people were taken straight to the gas chamber.",
      "word_count": 29
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "And-- and there were no known survivors of this particular transport.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "So if I wouldn't have screamed, I wouldn't be sitting here today.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "That's-- I always tell this to people, and that's the strange quirks of life sometimes.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "You know, the little things make, you know, make big differences in your life, and this was one of the little things, to scream, and it made all the difference.",
      "word_count": 30
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "You know.",
      "word_count": 2
    }
  ],
