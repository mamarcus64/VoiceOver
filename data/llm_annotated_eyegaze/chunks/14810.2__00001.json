{
  "stem": "14810.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "He looked very-- he looked like a Gentile.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "He was blonde and for somehow-- anyway, he escaped.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "This is the only case we know.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And he came to the ghetto, to the Judenrat, to the Jewish council, and told the people, don't let yourself deceive.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "The people-- nobody comes back from Treblinka.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And he said people actually are being gassed and cremated and killed.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "You know, the Judenrat did not believe it.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And they even told him to be quiet because he might create panic in people and so they didn't want him to tell anybody.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They didn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We didn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We always were told-- can you conceive something like that?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They're taking women and children in the tens of thousands and gas them and kill them?",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Nobody believed it.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I believed it when I arrived to Auschwitz, when I saw the crematoriums and I could smell the flesh and the smoke.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I realized it that it was fact.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was the truth.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Because he came into our-- to our house, and we had a gathering there, in our house.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The Judenrat came and he told us.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He had to be very secretly because they didn't want people to know it, and it was in our house.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Rothblatt, Rothblatt.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Shepsl Rothblatt.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "R-O-T-H-B-L-A-T-T.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I remember it very well.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "What happened, they took us from the ghetto and not direct to Auschwitz then.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They moved us to another camp, which was-- the name was Szebna, S-Z-E-B-N-A.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And we were there about a week, and then they took the whole camp, and then they sent us to Auschwitz.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Just like they grabbed us.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't take nothing, just what you had on.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "1943.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "October.",
      "word_count": 1
    }
  ],
