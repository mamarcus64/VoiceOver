{
  "stem": "4345.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We got together.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We were 900 girls our camp. 900.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Some of them had already died or were sent away.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And we started out on our journey.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "We called-- they called it the Todesmarsch, the death march.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I had my coat from my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I had the-- I had the clogs that we wore, you know, the backless shoes.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "That-- that-- like the clogs, you know that one style.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And it was January and the snow was high.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "The winter was very bitter.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "We could not take anything with us.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "We had actually nothing to take from-- from the camp, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "We had no food.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "We had no water.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And we started out just what we had on us.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "We walked for about January, February-- January, February, March, about two and a half months.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "About two and a half months this death march took.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "We walked day, and we walked night in hunger, in pain, in death.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "And just you name it, we had it.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "We slept, during that time, if there was a Bauer, a farmer that would have a little heart, with the permission of the Gestapo, if he would say it's OK to let them in for a night, they would let us in.",
      "word_count": 42
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And they would also boil-- they had those big things for potatoes, those big pots.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They would boil some potatoes for us.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Otherwise, we had no food, we had no water, we had no toilet facilities, we had no baths.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Did you ever go for two and a half months without a bath?",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Can you imagine what's going on in Bosnia and in all these places, in-- in-- in Africa, how people live?",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "This is how it was with us.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And, of course, people got sick.",
      "word_count": 6
    }
  ],
