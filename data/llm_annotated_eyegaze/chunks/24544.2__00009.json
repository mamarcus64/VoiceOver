{
  "stem": "24544.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "We said, it's not a bad place.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Still the morning, and they're walking in pajamas.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "What's wrong?",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Then the doors was opening.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And the [SIGHS] Polish guys, I don't blame them.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "It's not their fault.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "It came like hell to us.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Get out!",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Get out from the wagon!",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "They pull everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Jewish-- Jewish Polish guys.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Prisoners.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "All over.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Prisoners.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "Always prisoners.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "The German with dogs was just watching them.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "But we didn't know who they are.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "They don't introduce themselves, right?",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "They were pulling people-- they were hitting, get out!",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Get out!",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Leave the packages.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "You will get it later.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Don't worry, you will get it later.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Men here, women here.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Crying.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "People was separated.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "The whole thing was terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I tried to save my-- my skin and get out quickly, holding my mother's hand.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "My little brother was separated at this time.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And it was terrible heat, that day in Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "But we pulled on him a heavy sweater-- maybe you will need.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "And he was shvitzing, sweating.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "And we, whatever we could-- underwear, dress, sweaters-- we pulled on because maybe we need.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "Because we have to leave the-- the packages, the backpack or whatever it was.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So in the mean time, on the road, the German came and collected the jewelry.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "You are going to get out one by one.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And we are going to search you.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "If we are going to find money or jewelry, right away, the same spot, we kill you.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "So whoever has a little things, they give it.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "They went around with a hat or whatever, and they collected everything.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And some people doesn't dare to take out from the lining.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And no time for it.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And they didn't know, did I do good, or I didn't?",
      "word_count": 11
    }
  ],
