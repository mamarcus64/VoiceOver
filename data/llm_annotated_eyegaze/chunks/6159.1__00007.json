{
  "stem": "6159.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But my mother was very much against it.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Because-- I can't call a lady, but a girl from a good family hasn't had-- she thought hasn't had much chance to find a nice husband, if she's in the modeling business.",
      "word_count": 32
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Because they have do a lot of things, which she didn't agree.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So I had to leave it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And I went to-- after high school, I went two years to an academy, where I learned [PAUSES FOR 6 SECONDS] shorthand and typing.",
      "word_count": 24
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And then I got an official.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And that office job, in an advertising agency, I kept until the war, when I had to go.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And they collected me, the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "He was a thorough gentleman, without children.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And he was a cello player, a very gentle soul.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And the wife was also a piano teacher.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And they took me aside with their daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Because my circumstances were like that.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They knew that I am practically by myself in the world, beside my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And they were the ones who lifted me to higher level education in music and opera.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And they took me places where I learned a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "So I owed them a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And I always called them a second parent.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "He was Arnold Kisch.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And the wife was Caroline.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And the wife wasn't Jewish, he was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And he's had five brothers, six boys all together.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And when the war came, the wife was hiding whoever was left, including her husband.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "But when I went to the working camp, she was the one who looked me up and went through a lot of people, until he found me.",
      "word_count": 27
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Because I was sort of lost in the wilderness.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she was.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "She notified my husband, who wasn't my husband then.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He survived the war, yes.",
      "word_count": 5
    }
  ],
