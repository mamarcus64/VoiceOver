  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "So there was a train.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "And only the men were allowed to go on the train.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And we stood-- I remember that a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "We stood in front of this platform, and my father decided, no, he wasn't going to leave his family.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "But Lolac said he was going.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And I don't know what happened to the grandparents-- the old people.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "They must have just perished.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "But, of course, the train there was caught and the men were exterminated.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 20,
      "text": "And the women would have, as we know now too.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we basically saved ourselves because my father was such a-- he was brave.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And he was very committed.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He was very-- what's the word-- you know, his family was everything-- very Jewish, I think.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Not only Jewish, but also Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Now I don't know what you asked me.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Now finish-- we'll finish the tape.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Ah, OK.",
      "word_count": 2
    }
  ],
