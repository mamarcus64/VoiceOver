  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "But the fact is that everybody who walked in in that camp walked out, except one girl who died on tuberculosis.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And he bought from-- for her a grave.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And we made a Jewish burial during the time-- I think it was in January or February.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "This is unheard or by the Germans and in a camp.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Not in Brunnlitz.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Out of the camp.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Out of the factory.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was a villa.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He lived in the villa.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Over 1,100.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Not too many.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "But older people were a lot.",
      "word_count": 6
    }
  ],
