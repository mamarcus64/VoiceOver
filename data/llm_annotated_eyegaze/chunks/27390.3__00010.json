{
  "stem": "27390.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "We looked out.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And as I told my father what's going on outside, so he said, put on-- it was in the winter, March.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "It was still very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "So he told us to put on our coats and our rucksacks.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And as he was talking to us, we heard shots coming from the yard, from the staircase, and a bang on the door.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Two soldiers came in.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And they said, we'll give you 15 minutes time to be outside in the yard.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we were already in our coats, and we started walking into the yard.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We got into the staircase.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And as we came into the staircase, they got hold of my father.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They dragged him back into the apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And us they pushed out into the yard.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And we had shots all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And we couldn't believe that they're shooting people.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We thought they just wanted to frighten us to get us out into the yard quick.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And as I came into the yard, there was snow all over the place.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And I saw a woman laying in a pool of blood.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And they pushed us into the gate.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "On the continent, they have got such gates.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "In the building is a gate.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "So the women and the children, they pushed us into the gate.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And the soldiers went back into the apartment, and we heard shots all the time for about a half an hour.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And then they came down.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I noticed they had the swastikas, the scout-- what's it called?",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "The skeleton, the skulls, you know, on their helmets, and we realized that they are the SS.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And they pushed us out into the street.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It was already getting dark.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It was about 5 o'clock in the afternoon.",
      "word_count": 8
    }
  ],
