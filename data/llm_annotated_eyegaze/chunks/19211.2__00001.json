{
  "stem": "19211.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 300.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He was helping us.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And he told us, you cannot stay in this village anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And he gave us a contact, and we was about like five miles from Ponikwa was another little village.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And it used to be called Wlochy, W-L-O-C-H-Y.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And there was-- there were large forests there.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And they-- he sent us one Jewish guy, he was a local man.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "He knew all the-- every angle of the forest, everything.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And he led us into the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And then he got us acquainted with some Ukrainian Polacks.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "They were very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "In that village, they were all very nice to us.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "I think 90% of them were with us.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "It's just amazing that we were just so lucky.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And they were sympathetic to us.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And they even brought us food to the forest.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "We used to go for food to get food usually.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "But sometimes they used to bring it with the horse and buggy.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And they used to unload it into the bunkers.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "They helped us build bunkers in the forest.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "OK, bunker, they dug a hole in the ground by hand.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They used to come.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We used to work on it, maybe five people, for six people.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "A large hole, probably the size of this living room, which is probably 18 by-- what would you say, 20?",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Something like that.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And they dug a hole.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "They put beams across the top.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "They put from the forest, they cut-- it was in the deep forest.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "They cut the wood.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They made wood walls, paneled-- like paneled the walls.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And then they on top of it, they put earth and seeded like we call grass.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "It was wild stuff there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "So that it was masked.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "It was camouflaged.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "On top, they put a camouflage.",
      "word_count": 6
    }
  ],
