  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "I was-- I went-- I had a store in Miami, a Jewish bookstore in Miami, who a friend of mine who was working for a Hebrew publishing company here.",
      "word_count": 29
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And this was all over the country used to buy there.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "He found out that there was a shortage in [INAUDIBLE] there and other things.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "So he decided he had the money that he'd open a store.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "He sent me to open a store in Miami Beach.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "I was there a few months.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And then he sent somebody else.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't stay.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "It was back to New York, and I did different things all the time.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "And then when I got-- I went in-- after I got married-- no, no, as a single man, I was for years managing a nursing home.",
      "word_count": 26
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "This was quite a number of years from one to the other.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "It was with that family-- with that Frankel family.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "I was quite a number of years there, even when I got married for a few years I got-- I was in managing homes.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "And I made a living, and my wife was teaching-- a Hebrew teacher.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 24,
      "text": "Then-- then she went into the public school system for quite a number of years later.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "And then I bought a small nursing home in [?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "Pecha, ?] Long Island.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "And it was-- turned out bad because of some local things with Welfare Department, with stealing.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 28,
      "text": "It was bad for the-- for the homes.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 29,
      "text": "It wasn't enough.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 30,
      "text": "So I didn't have enough money to make it [INAUDIBLE] and this little time.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 31,
      "text": "I was out of debt-- little things back and forth, back and forth.",
      "word_count": 13
    }
  ],
