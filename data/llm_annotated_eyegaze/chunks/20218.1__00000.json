{
  "stem": "20218.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Actually-- excuse me.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I didn't-- I didn't tell you that I was Hannah Wolhendler, but I was Estella Hannah.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "So you didn't marked it, but I-- I should say it.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born December 25, 1926.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Lodz, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Pinchas Wolhendler, W-O-L-H-E-N-D-L-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother's, Karola Wolhendler.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Karola Szczupak, C-Z-- C-- C-Z-- S-Z-C-Z-U-P-A-K.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father was like collecting money from the-- from the-- for the firm over-- all over Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He was sent all over Poland to collect money for the firm he worked for.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She was a housewife.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I had a brother three years older than me.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "His name was Moishe [?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Wolf ?] and Wolhendler.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My only grandmother was alive when I was-- when I remember.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Minka, M-I-N-K-A, Hammer, H-A-M-M-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "The rest, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I never met them.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They were not-- they were deceased.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a-- in a middle class family in a nice, nice section of the town in Lodz.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I was very protected by my mother as a child.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I had a happy childhood.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "My father was a very delicate man and a very loving man.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And as, as I could remember, it always was fights with the siblings, siblings.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "My brother and me always fought, but that was in fun.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "It was not in tragic.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And we went every year to, to the country for the summer, for vacation.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We came back.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Food was plenty.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "We even had a maid.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "Vladia, ?] her name was.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "She was a country girl, and she lived with us.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "My mother was so protective of me that she sent her to take me to school and to pick me up from school.",
      "word_count": 23
    }
  ],
