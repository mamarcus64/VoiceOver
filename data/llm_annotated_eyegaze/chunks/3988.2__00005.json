{
  "stem": "3988.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "You know, that was for Germany, in the field.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "Because they were short of manpower.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "You know, they didn't have people to work on their field.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "They got us from the camps.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And we worked in the fields.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And for that, they finally gave us bags of potatoes.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "You know, I remember load up the wagons.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "You know, we should take this, take it to the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "So the soup wasn't too bad, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "We found a few pieces of potatoes in that camp.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "In there I worked-- the same thing.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "I don't remember how long.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And then I was shipped to Auschwitz from there.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We went by trucks, you know, open trucks, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We're going to Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We just said-- they said we are going to another different camp, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't know nothing in the camps.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know nothing about it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And-- and when we came to Auschwitz, you know, before they let us in, into Auschwitz, they dropped us off.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And then we had to walk up to a German officer-- you know, dressed up in uniform.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And he looked at you, you know, and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Or he told you, left, right, right or left, you know, and walk up.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And he looked at me.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And then, you know, he told me to go right, I guess, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I went into-- into Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And the one who went in the other side-- they went into the gas chamber, you know, to--",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They didn't ask.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, that time, [INAUDIBLE] maybe three or four years later-- maybe 18, you know. 17, something like that, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I was-- and I was lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I guess I was lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I went into Auschwitz.",
      "word_count": 4
    }
  ],
