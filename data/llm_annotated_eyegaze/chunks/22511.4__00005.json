{
  "stem": "22511.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "There was a lot of children, very sick, diabetic.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "They had a lot of bad sickness, like syphilis.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "A lot of sickness, which we was very frightened.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I didn't know what it is even.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Although I was in a different-- in a healthy group.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "I was healthy.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And my sister was with me, and we-- we didn't work that time.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "We just eat, and drink, and dance, and a bit of study-- not much.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And we-- our aim was to be in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "We come one day.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "We went to Marseilles.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "We had to travel with everything hidden, with buses.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "We were like-- not human.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "All the time hidden, hidden, hidden.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "I don't know how it comes that we are still brainy with-- we're working with our brains and we're thinking.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "We was traveling in a-- in a big bus.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "The bus was locked.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "Nobody knew that we are people.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "They thought we are some things they're carrying.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "We came to friends.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "They put us in a home, like a prostitution home, because they had to hide us.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "And I looked at the pictures.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "I thought, this is angels.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "Because I know only angels and devils.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "I didn't know prostitution at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And I said, look!",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "How beautiful, angels!",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "And this was absolutely naughty pictures.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "Any my friends were older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "They said, [INAUDIBLE], don't say that!",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "This is not angels.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "This is very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "Then I opened my eyes.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "I looked again, only I was ashamed to look at it.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "It was something terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 46,
      "text": "And all the houses, the rotten places we were put in.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 47,
      "text": "After the war, even, because we was not allowed to travel to-- on land.",
      "word_count": 14
    }
  ],
