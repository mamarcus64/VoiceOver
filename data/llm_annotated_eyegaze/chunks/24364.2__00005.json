{
  "stem": "24364.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And it happened after I had helped a friend of mine, or a lady actually who was very nice to me usually.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I had helped her wash the underwear from her husband who was sick.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And next day, I got sick.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And so they said, oh my god, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Better go to the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "So they had a little hospital on the boat, so they shipped me to the hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And that hospital was about the worst thing I have ever seen in my life.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "There were bunkbeds, three.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And I-- they put me on the middle bunkbed, and you couldn't sit up.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "You could barely turn over.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And there was some nursing care, but the nurses were busy.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "There were quite a few really sick people there, so I felt I wasn't really sick enough to stay there, so I ran away.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "That was-- and fortunately I-- I was OK the next day or a few days later.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "The-- the condition on the ship were terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 3 SECONDS] The washing facilities were impossible.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "You had to-- what you did all day, you were standing in line for something.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "You were standing in line for food.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "You were standing in line for water.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "You were standing in line to wash up.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "You were standing in line for the latrines.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "And when you were finished with one line, so you had to start another one.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And sometimes you just gave up and you didn't eat or you didn't wash.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "And sometimes you went for days without washing.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "I remember I-- once I had a sweater, which had a white collar.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "And I was walking on the boat somewhere and somebody was walking behind and told me, hey, I think you better wash your neck.",
      "word_count": 24
    }
  ],
