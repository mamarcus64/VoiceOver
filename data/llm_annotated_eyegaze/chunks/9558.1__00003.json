{
  "stem": "9558.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "So he picked up the chazan for my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, with my mother, with the family.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents died when I was-- when I was young.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I remember them, but I remember they lived, you know, just across from us.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And we celebrate Shabbos and yontiff and all the holidays, the family together.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And then my oldest sister-- You were close to this sister?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We were a very close family.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "To all of them.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "To all of them.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We were-- [PAUSES FOR 5 SECONDS] --like, one child, you listen to an older sister.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "You listen to an older brother.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "You listen to your mother.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "It's-- [PAUSES FOR 3 SECONDS] --then when I was 12 years old, I started to be on my own already.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I went to work.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Got up 6:00. 7:00 you had to be at work.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Then I had to go-- the law was I had to go to night school, so I left from 5:00 till 8:00.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It was in Wisnicz.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't high school, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was similar to high school, like a training school.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And-- but the bad part was, 8:00, I had to go back and make up the three hours.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And i worked till 11:00.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] Went home hungry to sleep.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] That was the life.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was very good in school.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I was very good in elementary school.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "School was the best thing for me, because I had a lot of Polish friends, which actually they didn't know how to read and how to write.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I used to help them with their homework and with everything.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And so one used to bring me bread.",
      "word_count": 8
    }
  ],
