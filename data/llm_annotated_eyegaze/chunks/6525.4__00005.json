{
  "stem": "6525.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And the man was the husband for all the wives and one kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "When they were chased away-- and they had very big houses, beautiful houses-- the Sochnut put a, every family in a room.",
      "word_count": 22
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "If it was four bedrooms, it's four families.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And if it's three bedrooms, three families.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "And all three families had to use the one kitchen and the one bathroom and the one toilet.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "So you were standing in line to go to the toilet.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "And when the kids had to go to school in the morning, you had 20 kids to go to the toilet.",
      "word_count": 21
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And it was hard times-- again, no food.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Everything was rationed.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The men went away to the army.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "My husband was in the army for two years.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And every year, they called the men for retraining.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And it was a hard life, a hard life in Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "Your-- what happened to your, your child, your husband and child?",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "You said you were divorced.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And I divorced in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And then I married the recent husband two and a half years later.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "It was with me.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "But she-- this is Eva.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "She married at age 20 here in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "She took an American guy from Kew Gardens.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And she went back to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "She doesn't want to live here.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "She likes it there.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And she lives in Jerusalem.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And she has four kids.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And she has a happy marriage and a happy family.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And they make very well.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "I have--",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In Israel.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "When I lived in this one room with three children, then I made the decision that I can't take it anymore.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I had a 15-year-old girl.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And I had no way of getting an apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I was a waitress.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't work much.",
      "word_count": 4
    }
  ],
