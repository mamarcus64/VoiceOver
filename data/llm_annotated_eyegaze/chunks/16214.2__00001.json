{
  "stem": "16214.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "However, I remember standing on a balcony that was after my mother started kissing me and hugging me, the first time I met her.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "She just was coming to try-- and to try to visit me.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And the apartment was closed.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I would be standing on the balcony.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "My other mother was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And she closed me in the apartment, and I could get out to the balcony.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And I would watch my real mother downstairs.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And she would bring me food or something, and she would like to feed me and give me some toys or whatever.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "And she couldn't, because she couldn't get to me.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "I was on the balcony.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "I-- I remember these moments.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And I sort of started liking her.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "Because she was a nice lady.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "She was bringing me food, and gifts, et cetera.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "But I still didn't want to go to her.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "And finally when the court case came about, and I remember holding on to the skirt of my other mother.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "I didn't want to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "I was screaming, crying.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "And [DRINKS] I had to be separated from her.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And I certainly didn't want to go.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "My mother tells me.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "I don't recall that at all.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "But my mother keeps on telling me that during the case court, my other mother mentioned if I knew that I had a Jewish child, I would have killed her myself.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Now, I don't remember hearing this.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "But this is what my mother tells me.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "And I guess she was extremely jealous.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "And I don't know whether it is true, whether it is not true.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "But I don't recall any such thing.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "And I only remember that I was very upset, getting back with my real mother to Krosniewice to that little town.",
      "word_count": 21
    }
  ],
