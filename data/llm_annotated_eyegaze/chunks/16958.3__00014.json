  "elapsed_s": 75.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 50,
      "text": "And more, we took away.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 51,
      "text": "More came.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 52,
      "text": "We couldn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 53,
      "text": "Now, [PAUSES FOR 3 SECONDS] one day we came and this hole is filled up.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 54,
      "text": "The second exit.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 55,
      "text": "Again, they fill it up.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But we have to go out. 38 people have to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Shall I stop?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "So what can we do?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "What I think, we have to try the first one.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "To open the first one.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Because they filled it up.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "The ground settled already.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "It was about three, four months.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So we opened the first one.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And we say like that.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "Now there is potatoes on the field.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And the farmers, when they take out the potatoes, they-- first they put them in big piles.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And then they take them home.",
      "word_count": 6
    }
  ],
