{
  "stem": "18575.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "Also we had nuns that taught us, or taught, anyway, the-- the Christian children, rigorously, that you should not look at yourself in the mirror ever-- ever look at yourself naked in the mirror.",
      "word_count": 34
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "When you get dressed, get dressed that you don't see yourself.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "It's sinful to look at yourself.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "I mean, it's such a continuous, rigorous thing, but we only have to sit.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "We didn't have to-- the Jewish children did not have to participate in it--",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Except to listen to the-- to the anti-Semitic remarks, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I think at least twice or three times a week we had religious class.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I attended, till the war, I think, five grades.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We started-- well, school started at 8 o'clock in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The classes were 45 minutes.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Then was a [? pose ?].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We sat always in the same class, and teachers came to us, not like in the United States where the student go to the teacher class.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "We sat in the same-- we were assigned a class and always sat there.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "There were-- the benches were for two students.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "We sat in a bench, each one.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] The bench opened up so you can keep your books inside the bench.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "The-- we had a-- each class had a patron teacher who was responsible for the class.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We had to a-- a woman who-- who was teaching us Polish literature, Polish drama.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I don't recall her name.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "No, no, I do.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "What am I talking?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I'm not-- I remember her name, yeah-- Eliza Poliker.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Would you spell her name for  us?",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Eliza, it's E-L-I-Z-A.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Poliker is P, as Peter-- O-L-I-K-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Now--",
      "word_count": 5
    }
  ],
