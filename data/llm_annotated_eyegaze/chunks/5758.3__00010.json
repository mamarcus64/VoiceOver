{
  "stem": "5758.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 6 SECONDS] We were put into-- taken to the railway station in the buses, on the railway station, where loads and loads of SS soldiers, [PAUSES FOR 3 SECONDS] some with dogs and with whips in their hands.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And each bus in front of the, in front of the wagon, we saw these cattle wagons.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "Funnily enough, on the cattle wagons were written, in French, [SPEAKING FRENCH]. 40 men or eight horses.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "In each wagon was 100, 100 people, squeezed in.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And when there would seem to be no more room, the SS with whips squeezed us in in order to make space for the remainder.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "There were men, women, and children, and old people, young people, all together.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "We were able to take one hand luggage with us.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "And we were just-- impossible for everybody to sit on the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "It was absolutely impossible.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "There were two water buckets and one sanitary bucket in that-- in each wagon.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] We organized ourselves.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We let the older people and the mothers with their children sit on the floor.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "We youngsters, we stood.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And we tried to organize ourselves with regards to the sanitary bucket, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And, and, and we each-- before we left, actually, we each had a piece of bread.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And we had some-- a piece of salami.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And before we left, we also had some soup.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And they closed the wagons.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] We went on this train for three days and three nights.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I don't know whether you can imagine the stench from the overflowed sanitary bucket, the moaning, the crying of the children, the fights between each other for more room.",
      "word_count": 29
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "It was really one of the worst thing that I experienced.",
      "word_count": 11
    }
  ],
