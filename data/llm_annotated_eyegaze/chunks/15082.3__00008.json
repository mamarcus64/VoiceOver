{
  "stem": "15082.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "He had stacked it up so much with hay, that no matter how much jumping they were going to-- there would be no inkling that it was there.",
      "word_count": 28
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "We never left there.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We were-- the only time-- but we left his place already was when the Russians came back when we were freed.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Liberated from there.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It was a twofold thing.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But in between, a cousin of mine Junior Olaska, which also survived, she's in Israel, lost-- all these relatives of mine were killed in February, the rest of them.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Whoever was around the forest were all wiped out, and a village by the name of [POLISH], almost that village where my grandfather lived in.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "She ran.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "She was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "She ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And she ran in to a Polish house.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And the woman took her in.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "The woman's name is Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Madinska.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "She was given the righteous award from [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "She lives in Connecticut.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "We got a message to us that they wiped everybody you.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "The only one that is left is her.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "Two of my father's brothers were still alive, Pinchas Chartan and Shmuel Chartan.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "But we didn't know where they both are.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "What my father did is for Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "Marczeniek, we had sent-- we entrusted another Polish young man.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "He must have been in his twenties.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "And he swore to secrecy that he was not going to do any harm or tell anybody.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "He went and got her, and brought her to us.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "That was in either late January or early February, to our bunker.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "We took her in.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "And that's the way she survived.",
      "word_count": 6
    }
  ],
