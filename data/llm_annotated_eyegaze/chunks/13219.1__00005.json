{
  "stem": "13219.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Well, lately, you hear that, that they, they were causing a lot of, a lot of bad things for the Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Well, they used to cut beads from the old Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "They used to make fun of them in, in the middle of the street used to beat them.",
      "word_count": 18
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Heard, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Not, no, not at that time, no.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Polish people were anti-Semites, Polish people.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "In the big cities, you can hear that happens a lot between the Polish people and the Jews, anti-Semitic wise.",
      "word_count": 20
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "In our city, small city, most of it was-- very few Polish people there.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "Most of them were Ukrainian.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "The only one who was Polish is the guy who owned the whole city.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "And all the property was his.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was-- he was left with-- his grandfather and grandfather, they used to own hundreds of acres of land in the cities.",
      "word_count": 23
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "They build the churches and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "They used to own it.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And then the people used to work for them.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "And they gave him so much back.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "My father bought the, the--",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the, the land-- he had to go to that man and to, [PAUSES FOR 3 SECONDS] to agree on a price.",
      "word_count": 22
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And then he pay him, buy the land.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Noble families, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Well, most of the time, we spoke Yiddish.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Polish, they made us-- all the teachers made us speak Polish while we were in the Polish school.",
      "word_count": 18
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "We used to have to put out the hand.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "And she, she took a piece of wood and-- because we spoke Yiddish to, to-- between us instead of Polish.",
      "word_count": 20
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "We-- the only thing we hear that Germany is starting to take over a lot of countries.",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "And that's all we heard.",
      "word_count": 5
    }
  ],
