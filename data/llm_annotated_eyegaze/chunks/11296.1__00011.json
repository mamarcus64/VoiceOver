{
  "stem": "11296.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "There was, you know, so many people.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it filled up the whole little house.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "It was filled up with people.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So when we came out, you know, we came out.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And we came back, you know, to our shack.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "So when the winter start, the winter, so how could we stay there?",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "So my father had a brother.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And they had their-- their house.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They was staying in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "So he said-- he had-- his house consisted of two rooms.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "So like this, we was just four people.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "He took us in.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "So the kitchen, we put our bed here.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "We didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "We took our-- his bed.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And he had another bed.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "And he had a family of three-- two son-- had two daughters and a son.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "He took us in.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "So we was happy we had a place where-- we didn't have where to sleep.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "Me and Hanka slept on a table-- a table-- a regular table.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "And on the side by the table, we put a barrel, because the table was not long enough for us.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "So we put the barrels up.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "It could hold our feet.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "I have to remind Hanka about this.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] So-- and, you know, and you know, we got the food.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We got rations-- something they gave us to eat-- just rations-- a piece of bread, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "No coals, nothing, so we was burning our furnitures-- this is what we took out from the house.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Slowly, we-- we burned the beds.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "We burned the closets.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "We burned anything what we could put our hands on.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "We burned.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "We was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "On the yard, where we was living, was a bakery.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And this bakery was baking bread for the people-- for the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "So we always run in.",
      "word_count": 5
    }
  ],
