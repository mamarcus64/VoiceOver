{
  "stem": "598.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And I was building up.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I was building up the business.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I was making $800 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "That store, what was asking $5,000 a month, they were making $800.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Later on, they're making $400 a week.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "They were taking in, not making-- taking in $400 a week.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "My landlord tell me, you can stay as much as you want.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "All of a sudden, he throws me out.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "He wants-- go out from here.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I say, where I'm going to go?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I'm making a living already.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "For one year, I make $5,000.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Where I will go?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I'm looking for another business.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I'm going a couple blocks, my competition.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He doesn't even know me.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He says to me, are you Jewish?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I says, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Talk to the other guy.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He-- he means me.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he says, and you come together with him, and you could make a living.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But he's a big competition.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Any time I'm putting in $0.39 hens, he puts in $0.29.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "When I put in $0.29, he puts in $0.19.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So I bought the other store by him.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I went out a couple blocks.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I stay at the other store for four years, till 1958.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Meantime, my son has allergy.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Allergy-- but we went to California, he lose allergy.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So I'm going to California.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I'm so-- sold my business to another Jewish guy.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Sold the business, and I'm going to go out to California, maybe look for a business.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So in '58, I came in here to California.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Looking for a-- right away, I bought a live-chicken store-- a small one.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And just making a living.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "It comes in New Year's-- Jewish New Year's, and Yom Kippur, I'm closing up the two days.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know that's a-- I was taking in the Saturday, like, $350, $400.",
      "word_count": 14
    }
  ],
