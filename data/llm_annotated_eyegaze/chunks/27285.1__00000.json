{
  "stem": "27285.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Hello, my name is Greta Klingsberg, formerly Hofmeister.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Vienna, 11 September, '29.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And I had, what I suppose you might call, a normal childhood.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We were poor but very clean, and very proper, and very interested in children should learn and go to school, et cetera, et cetera.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I had a sister, her name was [NON-ENGLISH] Hofmeister, unfortunately she did not survive.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And my parents, my mother was Paula, formerly [?",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Steiner, ?] my father, Alfred Hofmeister.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "We were, of course, Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was-- different jobs.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The last that I remember, he was working at some newspaper.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I don't know in what capacity, but I know that he sort-- as a socialist, or something.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "That's one of the reasons which we come into later, why we went separately across the border.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother was at home.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She-- before she married she was working as the first and only Jewess that-- what you might call a drugstore, or something, that sold newspapers, and cigars, and cigarettes.",
      "word_count": 29
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I have even a picture with-- she was the only Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Because her parents died very young, and she had to support her younger brother.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But since her marriage she stayed at home.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] It's very hard to reconstruct it be-- yes, basically, my mother had a younger brother and two sisters.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes, her brother is Leo [?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Steiner, ?] her sisters were, Sophie and Anna, and-- that's it.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The brother survived because he was married to a Christian lady, who is still alive, by the way, at the age of 89.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Katya-- [INAUDIBLE] [?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Steiner. ?] I don't know her first na-- I mean, former name.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And the sister-- another sister survived, Sophie, survived because she went to Italy, and later to America.",
      "word_count": 18
    }
  ],
