  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But Hitler was having his portrait painted.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And he came with this entire entourage.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And we were going down with the baby nurse, who was German, and my brother, who was a, you know, little kid.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And he had seen that you click your heels.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "You know, that was the German style.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] And he clicked his heels and Hitler came.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And he saw this blonde-- you saw the pictures-- blonde and blue-eyed child.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And he picked me out of the stroller.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And he said, this is the example of the Aryan race that we want to develop.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] Ironic.",
      "word_count": 2
    }
  ],
