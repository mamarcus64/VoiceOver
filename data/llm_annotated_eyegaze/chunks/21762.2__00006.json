{
  "stem": "21762.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I started working on a truck.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, the government's truck not my truck.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I had to make the truck.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I had to make the motor.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I had to make the chassis.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "It took about two months until I made it.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And then I make a living.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I was transferring wheat.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "All that I did is transfer wheat.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "My wife didn't work never.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The kids were in school.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "1941, '42, '43, '44.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "When I came back, I think, in '45, I came back to Germany",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "In Tashkent.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Exactly, I was in Tashkent.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "We lived in Shymkent but I was in Tashkent May 9, and they announced the war is over.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Oh, there was the people dancing on the roof and whiskey all over.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "To go home, to Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "But we didn't go to Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We went to Germany, Liegnitz.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And then from Liegnitz, we stayed not long, two months, I think.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And then we went to Czechoslovakia to Austria and to Germany, Stuttgart.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "In Stuttgart, I was living until I went to the States 1945, 1950.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No, I wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't going any more to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, I was once, with my wife, one day and that's it.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We just passed Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "We didn't stay, we passed.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "To Germany.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Through [NON-ENGLISH], no, not to [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Salzburg.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, then I started picking up the family from here.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Well, Dave and Maria are supposed to go to Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "So they went to our camp and wait now to go to Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And we was, then when we left--",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "In [PAUSES FOR 4 SECONDS] Stuttgart?",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "No, Liegnitz?",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Liegnitz.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Liegnitz.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And when we left and the kids was in a camp.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "Then when I left, we go to Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "We went in Salzburg.",
      "word_count": 4
    }
  ],
