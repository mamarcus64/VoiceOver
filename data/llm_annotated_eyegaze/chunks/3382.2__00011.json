    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And when I ran, ran on the other side, suddenly from the gate comes out a Lithuanian guy with a revolver.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Stop, you kike!",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I started, you know-- but he kept, you know-- he kept himself at a distance from me.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Either he knew what can happen to him with my physical, you know, because I was a very strong guy.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Rachela can testify that on the farm already, after the war, I could pick up with one hand two bushels of wheat and throw this way on the--",
      "word_count": 28
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
