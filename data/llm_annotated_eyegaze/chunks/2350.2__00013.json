{
  "stem": "2350.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "But you put on the dirty clothes back on.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "But the lice didn't disappear.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "This was eating us alive for three months.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "So the last selection was everybody had a very unclean body from the scratching, from all the dirt.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "So my sister, my older sister did not get through the selection.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "I went through, somehow, the selection with, with the scratches.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And she didn't go through.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "She went to a different block.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I remained here and some of my friends.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And maybe two days later, I went to see if she is there.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She wasn't there, my oldest sister.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Hela.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "My older sister from me, Menya, was on a different block when she came back from the [NON-ENGLISH], from the sickness.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS] Gosh.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And there was a selection.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And they asked, who wants to go to work?",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "That's what she told me.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And she was-- she says, I was so weak.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I didn't know what kind of work.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "So she went to the selection.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And there is a Block 10 that everybody was waiting to go to the oven.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "[SIGHS] I have no way to put this.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] It was winter.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "It was snow.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "And I went to, to the Block 10 to the  window to call her name, to see her.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "And she came to the window.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "This was the only block that had bars in the window.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "And she says, give me some water or snow.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "So I gave her a pack of snow through the window.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "And she said to me-- I have to say it in Polish because it sounds so good.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "And then I'll translate it to you in English.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "[SPEAKING POLISH]",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING POLISH] This means, with my clear mind, I'm going to die.",
      "word_count": 12
    }
  ],
