  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So they didn't think about just to leave the Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It was like transport.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "My father was in transport trade.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Transport trade?",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Dortheimer.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Hermann.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Franciska Freudel.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "A housewife.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "This time, the women didn't work.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We been-- my father was very conservative-- how would you-- liberal conservative.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So we just-- he went Saturday to the synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Otherwise nothing else.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Tradition.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "We've been tradition.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I remember, it was-- I don't know how to-- to say in English.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But in Hebrew, it's [HEBREW].",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "But I didn't like-- I didn't like to go there.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Because the younger-- the young generation, it was modern.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they start to go to dancing, and with girls, and smoking cigarettes.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Until today.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "It was-- the Jewish-English say a shul.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "You notice differences, are very small, though [NON-ENGLISH] people.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "It was big community.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "But there were-- for me, it was too many-- too many synagogues.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In Cracow.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I don't know, but too many for me.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I remember my bar mitzvah.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And tradition like Yom Kippur and [NON-ENGLISH] were they keeping.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "That I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Until today, I know exactly the [NON-ENGLISH] what I made.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But how many people, I don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "The celebration was kiddush.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "As you know what is it-- kiddush.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Like with my mother, I was like friend.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And my father was a little bit [PAUSES FOR 3 SECONDS] distance.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I saw him a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "But I haven't got to be contact to him.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Because this time-- this time the people, as father and son, it was something too many, they wanted too many respect.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "They were like-- like brothers, oh We always have been like brothers.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Very.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Very.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The same, the same.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "The same, like me.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "This is liberal, everything liberal.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Now?",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Then?",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Just to go to Palestine.",
      "word_count": 5
    }
