  "sentences_input": [
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 2,
      "text": "I-- I don't-- I don't see my mom.",
      "word_count": 8
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 3,
      "text": "My-- my mom moved to a different town.",
      "word_count": 8
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "So I see the Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 1,
      "text": "It scare me to death.",
      "word_count": 5
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 2,
      "text": "I want to move back, what they come from.",
      "word_count": 9
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 3,
      "text": "So I went back to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "I had been caught by-- in [GERMAN]-- in [GERMAN], beautiful city in Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the KBG, they asked me where I'm going.",
      "word_count": 10
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 2,
      "text": "I say, I'll go to Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 3,
      "text": "But I'm going back from Poland to Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 4,
      "text": "So [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 5,
      "text": "So they brought us to the radio station.",
      "word_count": 8
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 6,
      "text": "So some kind of hotel.",
      "word_count": 5
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 7,
      "text": "There was plenty German women who lived there.",
      "word_count": 8
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 8,
      "text": "The-- the KBG throw-- throw out those women, on the station, keep house in the hotel.",
      "word_count": 16
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 9,
      "text": "But I notice-- I smell something wrong, something fishy.",
      "word_count": 9
    }
  ],
