  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I lived in Bratislava because I-- a friend of mine got, got me a job in a leather coat factory.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was, I was doing whatever had to be done in a leather factory.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I told them that I knew how to sew.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But I did not know how to sew.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I told them I only thing I knew how to sew was pants.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And they only did leather coats for, for the Slovakian armored vehicle corps, those small jackets and also long coats for the officers made out of leather.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I was going to do all kinds-- they were teaching me how to sew on an electric machine and also whatever had to be done.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I cut patterns after someone draw the pattern on the leather.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And we just had to, had to cut it out, you know, just to be sure that I set the pattern in such a way that-- where there are no leather deforms or, or something like that.",
      "word_count": 37
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So it was a good-paying job, and the, the owner happened to be a Jew who was on false identities.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And he had, he also had a, a, a, a rank in the Slovakian army.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He was sort of a non-commissioned sergeant, I believe, a master sergeant in the army.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "In fact, he yelled at me even though he knew I was Jewish because I didn't do something exactly the way it should have been done.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I don't know whether on purpose or whether he just wanted to show the other people that he was strict with me.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "That's why I lived in Bratislava, and my brother lived with my, with my uncle.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Later on, it was-- [PAUSES FOR 3 SECONDS] I was, I was very worried.",
      "word_count": 14
    }
  ],
