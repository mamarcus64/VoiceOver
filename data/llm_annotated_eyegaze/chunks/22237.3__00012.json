{
  "stem": "22237.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what for, but I, I was thinking-- I had so many things in my mind.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I was thinking, maybe I would pack and go to Poland, and find my parents.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And so we had a crate in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "We always had a crate, because we were always ready to leave.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I packed as much as I could into that crate, and I had it picked up by some kind of a-- some kind of a company that was very close.",
      "word_count": 31
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And they picked it up.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I said, leave it there until I tell you what to do with it.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "But there wasn't much.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "I packed just a few things.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And, and from then on, then you heard people being picked up, and taken into prison, and being deported.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And there was all kinds of things.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And I was just hiding, hiding wherever ever I could.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I remembered my mother had a friend that I would go to her house one night.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Sometimes I would sit up on the attic on the last floor, because I was always afraid.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "I could have-- I could go to the house just a little while longer.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Because one day, a policeman came to the house.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "I was just in there, and I thought, this is the end.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And he said that I have to come to the police.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "But he didn't take me with him, he said I have to come to the police.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "And I thought-- I didn't think that-- you know, that-- I really thought this is it.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "But when I came to police, he said, you have to sign.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You have to sign your apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You have to sign that you're giving away your apartment to the-- to the [NON-ENGLISH] and to the-- to the parties.",
      "word_count": 21
    }
  ],
