{
  "stem": "3638.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And from Wieliczka, we went to the-- we had to go to the ghetto in Krakow.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But my father and my mother was never in the concentration camp, never in the work-- they were straight taken away to the gas chambers from ghetto.",
      "word_count": 27
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Well, my father was 56 and my mother was a little bit younger then, that particular time.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Nine, number nine, Rynek Podguorski, Podgorze.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Rynek, R-Y-N-E-K, Podguorski, P-O-D-G-U-O-R-S-K-I.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Podgorze.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "P-O-D-G-O-R-Z-E.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "It was just-- opposite was the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Opposite ghetto.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, that was outside the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "It always remained outside the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "It always remained outside the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "That's what helped me, because I had the neighbors and I could get some food from there and smuggle into the ghetto during the war.",
      "word_count": 25
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No, not very much.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "It was just a normal routine where we went to school, we went to the Cheder, and we-- we celebrated all the Jewish holidays like Pesach, Shvuot, and-- and what you call it-- Simchat Torah, and all the other things.",
      "word_count": 40
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "But it was not-- not-- and every summer, I used to go for a month or six weeks, to the-- to the country.",
      "word_count": 23
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I used to go to the parents of-- of-- of Maria, because they had a farm outside.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "That was the whole-- we used to go every year there.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "We used to go there with her, and we came back after the summer.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Not-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "She didn't take all of-- take me and my younger bro-- my older brother.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And we had a-- we had a good time on the farm with the cows and the horses.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "You know, that sort of thing.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "That was before the war, now.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "My class, there were only three.",
      "word_count": 6
    }
  ],
