{
  "stem": "21731.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "She had friends in Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "She gave me their address.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "Today I have no idea where I was, what these people were.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "I just wanted to get to England.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "I sent a telegram from Paris, to my husband, arriving in-- in Dover, I think.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "This and this, with this and this ship.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "Well, I boarded to ship, we went to Dover-- my husband wasn't there.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "I had to take the train who was connected, so to say, with this ship.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "And went to Victoria.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "No husband of mine there.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "I was really desperate.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "I didn't know anybody in London.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "But then I found a card, which I got from a friend of my husband, to-- in Italy.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "His nephew was in Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "And I had his address, 66 Boiler Road.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "That's in Ealing.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "I had his address.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And I showed it to a taxi.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "There were queues-- taxi.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I don't know, where you were born, when this time was?",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So anyway, you didn't see the taxis there.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "It was night.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And no taxi driver wanted to take me to this address from Victoria to Ealing.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "This woman standing-- I was in uniform.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And Yan was in uniform.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I was a leftenant.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "So they didn't want me.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "But a policeman took-- policeman kept [INAUDIBLE], took pity on me, and told one of these taxis, you have to take this woman there.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And asked how much will it cost?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And he said, a pound.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, he could have said 10 pounds, I didn't care what it was.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what 10 pounds is, and what 1 pound is.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So he took me there.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was a long journey.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It was night.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I was frightened.",
      "word_count": 3
    }
  ],
