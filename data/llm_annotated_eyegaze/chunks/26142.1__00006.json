  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Started celebrating-- the preparation was more than-- more than a month.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "You know, Purim is a month before Pesach.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And that's exactly when they-- they-- they-- they used to start cleaning out.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "The [NON-ENGLISH], the houses-- it-- it-- this was preparing-- now-- now, you go into the store and you buy Manischewitz matzohs for Pesach.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Now, this-- this wasn't-- this-- people would-- would get together and-- and bake their own.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And this was a very jolly for Rachel.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Usually the youth-- young people would help in the baking and the kneading, and it was very strictly supervised.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "They would-- in the villages, every house had its own oven.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "There was nobody-- nobody-- very few people bought-- bought-- go went to the store to buy baked bread.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They baked their own.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They kneaded their own-- their own dough, and they made-- and of course, for Passover, they would prepare the ovens.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Everything had to be according to the strictest-- strictest religious-- but it was a joyful thing.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And it lasted.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "It lasted-- it started up between Purim and Pesach.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Oh, it lasted a month.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, let me think.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Let me think.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I think we'd better finish this tape, and let me think.",
      "word_count": 11
    }
  ],
