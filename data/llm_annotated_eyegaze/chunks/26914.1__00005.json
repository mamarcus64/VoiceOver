{
  "stem": "26914.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "The school was changed to another school, closer to the neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Also-- it was also a Jewish neighborhood, [?",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Krochmaina ?] was in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "The same thing, I didn't feel any different about anti-Semitism.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "But when I was up at Mila, very often children were running after us.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise, I didn't feel it.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "We had a big bedroom for 56 girls, a giant bedroom.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "In the middle there were two rooms.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "One side was for boys.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "The other side, for girls.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "In the middle was a room for somebody which watched the children at night.",
      "word_count": 14
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "Every child had a responsibility to make their own bed, to clean the [BACKGROUND NOISE] place where they sleep.",
      "word_count": 19
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "In the morning we had to shower.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "Then we go down.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 8,
      "text": "The bedrooms were on the third floor.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 9,
      "text": "So we have to go down to the second floor, where they gave all the children-- we used to drink [NON-ENGLISH], fish--",
      "word_count": 22
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Cod liver oil.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Korczak was standing there, watching.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "Every child should drink, and a little dry bread to eat after the drinking this.",
      "word_count": 15
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "But very often the children didn't want to drink.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "But he was standing there and he made everybody to drink it.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "From there we went down to dining room.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "Every child has a number, the table where to sit.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "We sit at the table and we were served breakfast.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 9,
      "text": "And from there we used to go out to school.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "After school we came back.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "We have to make homework.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "There was always somebody to help if you needed help.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And after the homework, we went out to bicycling, or play uh, ball.",
      "word_count": 13
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And then lunch.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Dinner, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Supper.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Again, every child sit at the same table, at the same place.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "Every child knew where to sit.",
      "word_count": 6
    }
  ],
