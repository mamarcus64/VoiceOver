  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "But I had this movie that was given to me by the television there as a present in which you're able to see these young mothers seeing their little three, four years children, not believing how they are able to perform like a finished artist, are able to see the crying faces of these mothers after that, throwing these flowers and the enormous success of this program.",
      "word_count": 67
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "After that, I tried to arrange something like that here in Staten Island.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We succeed to make one concert at Wagner College.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But this is where the things end.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We will try eventually in the future to develop similar orchestra here.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "It stayed in maybe New York or in New Jersey, who knows?",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] But this is so far as the educational activity of mine.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Of course, when I was in university in Midwest, I was then professor.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I coached there for a few years students in the university that-- we prepared them for the international competition in Colmar, France, north of Paris, where they win also golden medal and first prize as a piano quintet, string quartet plus, plus piano.",
      "word_count": 43
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And this left also my name there in the, in the golden pages of the university in Midwest.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Because never before that students win the national prize there from the music department.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] If we turn here to my last activity, this is exactly my effort now to build recordings with this works that I'm calling Lost Voices Collection that already some of this was performed in the concert because of the 50th anniversary of the end of the Second World War and the, the liberation of the concentration campuses in Auschwitz, Buchenwald, Theresienstadt, in the United Nations.",
      "word_count": 69
    }
  ],
