{
  "stem": "3277.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And they just, with salt, covered the fish.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And we-- they used to throw out those-- those-- and we used to mix it, the flour with those insides from the-- from the fish, and with water, without any-- even no salt.",
      "word_count": 33
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And that was our food for a-- for a while, being-- as soon the Soviet Union used to go more to the-- to the west.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They used to take us, again, and-- and to the little-- also to the north.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And then I found out-- I came, they got me into a little town of-- close to the-- the river.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And meantime, I learned a little-- when you young, you learn fast-- and I learned a little bit Russian.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And they saw that I knew better than others.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "They took me to an office.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "Office.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And I became a bookkeeper at that office.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "They gave me a little bit more clothings, better clothings.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "But-- and-- and we used to live about 40 people in one room.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "This was the Soviet-- the Soviet-- the Soviet government--",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "--who used to organize this.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, I remember they-- they formed in the Soviet Union Organization of Polish Patriots.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And the-- the top lady was a writer, Polish writer, Wanda Wasilewska.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The-- the first name is W-A-N-D-A.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And the last name is W-A-S-I-L-E-W-S-K-A, Wasilewska.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And at that time, you know, they used to-- in those-- used to get some products from the-- the United States to support us.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And I remember I used to get some shoes, military shoes, and it was a big deal for me.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I got military shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I got some blankets.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And from a blanket, I made a-- a suit.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "From two blankets, I believe.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Yeah, I believe.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "From two blankets.",
      "word_count": 3
    }
  ],
