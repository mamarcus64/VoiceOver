{
  "stem": "19111.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And it was a very jovial and a very happy time.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "My father was very loved by his employee-- employees.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And well, I recall the time, at one time, when there was a strike, all the furriers were striking against the owners.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "My father's employees, they felt so dedicated to him, that instead of striking, they slept in the shop.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "They didn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "They locked everything up and they continued with their work.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "They just could not see hurting him that much.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] My mother had a-- was a-- also a wonderful craftsperson.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "She was a very talented dressmaker.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Suits and coats as well.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And she had a very-- she had a shop.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "One of the rooms in our apartment was the-- her shop at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But she only dealt with a-- with only a clientele, and the high echelons of the city, the-- the-- the elite of the city were part of her customers at the time.",
      "word_count": 32
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "She was very selective who she did the work for.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And she had people working for him-- for her.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And she had quite a successful business of her own at the time.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "She was very much sought after.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In-- due to the fact that she ran her own business and my father was quite busy, we had a live-in maid, by the name of Josefina.",
      "word_count": 27
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And we had, actually, at different times, we had a few others.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But Josefina was the main one.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "She was there the longest.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "As a matter of fact, almost up to the beginning of the World War II.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And she also employed a governess that took care of my sister and myself.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And they were both Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And they were very dedicated, very loving.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And we loved them very dearly.",
      "word_count": 6
    }
  ],
