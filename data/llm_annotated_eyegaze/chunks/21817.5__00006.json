{
  "stem": "21817.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I went home to find out what's happening to my family.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I know my father is dead.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I hoped my mother and my little sisters will be alive.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I didn't worry so much about the uncles and grandfather, because I know they were grown up people.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "But my little sisters and my mother-- [CRYING] Unfortunately, I came into the city.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And I was one, I was one of the first Jews who came back after the war to Mlawa.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I, I looked around.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "There were no Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "The, the Poles were surprised to see that I am in a Russian uniform, even though I have no insignias.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "Just, I didn't have anything else to wear.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I have no civilian clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "They didn't give us any civilian clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Whatever you had in the service, you could go home and, and, it and worked.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "In meantime, there were already Russian headquarters.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "I went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "I registered myself.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "And then, I registered myself in the Polish army, in the, in the, like, draftboard.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And I told them, I need some help.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "I'm, I'm a injured person.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "And I wanted to find out.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "And then I got horrible stories.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "People were still coming back from Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "I had people coming back.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "And I start finding out what happens from '39 til the war ended for me.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "The war was still going on.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "It was going west.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "But in the spring-- I mean, pardon me, in the winter, early winter of '45, Poland was liberated.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "The Russian army were already in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "And we start finding out the tragedy of what happens.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "I got some reports that in 1942, there was a ghetto Mlawa.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "They separated the young women with the children first at Treblinka.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 36,
      "text": "The men went to Auschwitz.",
      "word_count": 5
    }
  ],
