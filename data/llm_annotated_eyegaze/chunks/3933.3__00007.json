  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 50,
      "text": "She has two sons, one with him and one with him.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Now, after they-- we survived, all three of us.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We expected any minute they'll come back to confiscate the apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We were told they confiscate the apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Then I didn't know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I just didn't know what to do!",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I said, I'm going to be killed, and I don't care, and they're going to take me out of the house, and-- he said, no, you're not!",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You-- this is going to be my debt also.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I want you to live.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And maybe you'll find something.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "You can-- Now listen, listen, listen, listen.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "Once-- OK, this is another episode.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "He walked in, [?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "Kola, ?] and said, Mary, these are a couple, a Jewish couple, without children.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "Elderly.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "They have money.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "They are going to pay me, and I have to take them in.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Because we had no money to live on.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "They will find you, they will find them, too.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And the name was [?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "Fischel. ?] He name was [?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "Gooz, ?] their last name [?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "Gooz. ?] And they survived.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "The wife was kind of half-blind in one eye.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "She was wearing big glasses.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "They never got any children.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "They walked in, and we were sitting, all-- all of us.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "We were already two, and two-- four of us.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "Later, again, like I said, they're going to confiscate.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "Then they were a big part, and I don't know how much money they gave him.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "And we are starting out to having a little more food.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "And-- they were-- Before the war, they were wealthy people, these [?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "Fischel ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "Gooz. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "Fischel. ?] We called them [?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "Fischel Gooz ?] with his wife.",
      "word_count": 6
    }
  ],
