{
  "stem": "5799.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "There was no machoism in our house, because my father was a very secure man.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "He didn't mind at all that he-- I think he would be very unhappy with a submissive wife.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "He like her independence.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "The only the time I saw my father cry is when my mother went-- she never cut her hair.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "Her hair was long.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "And she had braids.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "When she let them down, they reached the, the heels.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "And at that time, just like we had here, Vidal Sasoon, at that time was in style La Garconne.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "And she went and cut off her braids.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And she came back.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And Papa said to her, what did you do with your hair?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And she said, well, between my bust and my hair, I was always afraid I'll fall in into a patient's mouth.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So I cut it off.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And he cried.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "This is the first time I saw my father cry.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "But the braids were with us for the longest time, because my sister and I used to play with them.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It was a happy childhood, happy.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My mother rebelled because my grandfather was an extremely religious man.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And my grandma was from a small town.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And like there was a matchmaker.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She was a pretty girl.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And she married my grandfather.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "She had with him six children.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "But there was no love in the sense of American way.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And she helped her daughters to run through the window to avoid her, her faith.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And [PAUSES FOR 3 SECONDS] my mother adored her grandmother-- her mother, my grandmother.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "My grandfather, she said he was limited because he was so religious.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "My father rebelled altogether.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "We have on the Lower East Side here, the [INAUDIBLE] [?",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Wolosian ?] rabbis.",
      "word_count": 3
    }
  ],
