{
  "stem": "7017.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, in Katowice.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In Sosnowiec.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Also, they took me once-- for three months-- they took me to Breslau.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Because the Jewish people, that they send them out to Auschwitz, they have to take out all the furniture, all the food and everything.",
      "word_count": 24
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "We worked maybe three months over there.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "Later, we came back to Sosnowiec.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Well, the people-- they sent them away to Auschwitz, the Jewish people, in Breslau.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "So they left everything in the house-- the food and the furniture, the clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "So we have to move it out, everything, in trucks.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh, at this time, I knew of it.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, we didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Later we know.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Maybe for three months.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Back home to Sosnowiec, to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "It was already a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "The ghetto was Srodula.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And I went back, and I went, every day, to work, again, back to Katowice.",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Srodula.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Two families, three families in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Very bad, couldn't be worse.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Very hard to get food.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "So if I worked, I helped something.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I brought home something, so I helped.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "With permission, I think.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You have to have something, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "You don't want to go-- you don't want to go out, even.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "You always worry.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "You have to wear a Jude arm band when you're Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The name was Merin, Jewish, I think, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "There was police-- Jewish police, too, over there.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "To the camp?",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, they took out to the camp, to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "When the people went in this ghetto, they didn't take as many more to Auschwitz.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "Before, they took plenty of people.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Not long, maybe two months, something.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Later, when I was in Katowice like I told you, I went every day.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And they took all the boys that worked over there.",
      "word_count": 10
    }
  ],
