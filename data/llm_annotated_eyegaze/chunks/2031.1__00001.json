  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "So they kept longer, like a day.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They tried to give up a lot of Jewish families.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The Ukrainians.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "The most was the Ukrainians.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And some people, they wanted to survive, so the Ukrainians [INAUDIBLE], they said they will help.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They took away everything that we gave them, they should help us.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "But as soon as we gave them away everything, they gave us out.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "First, they made a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Later, they made a ghetto from [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "People where they have a [INAUDIBLE], like carpenters, painters, carpenters, sewing people.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So the people that they got the [INAUDIBLE], they put in a different side, in the live side.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And people that they didn't get the [INAUDIBLE], they was a business, they took another place straight to kill the people.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And we was in the ghetto till they said, [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So my oldest brother, he was living 8 miles from Dubno.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "He was married.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "He had a wife and family, and he was living in a [?",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Cesky ?] [? colony. ?] In this place was the name [?",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Mirohoszcza. ?] In [?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "Mirohoszcza ?], he lived there, and he helped to build an [INAUDIBLE], like a theater.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] So he know how this was built.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And then my brother was working in-- how they call a meal-- where they making flour and farina?",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So my brother was working there, and the wife got a little store, and they make a very nice living.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But when they said, the Jews has to go in the ghettos, they took away everything, and they send the Jews in the ghettos.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "When they made the ghettos free, my brother, was he was living in [?",
      "word_count": 14
    }
  ],
