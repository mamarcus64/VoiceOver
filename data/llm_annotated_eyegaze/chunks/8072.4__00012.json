{
  "stem": "8072.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "From there, when we-- when we landed there, somebody came over and they said, instead of going to Stockton, we don't have any place for you in Stockton.",
      "word_count": 28
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We're going to send you to Nashville, Tennessee.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "But I didn't know any difference between Stockton or Nashville, I didn't know anything.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "So I said, fine with me.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed in New Orleans for-- we-- OK.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't get off the boat because it was Labor Day.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "We stayed there overnight.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And the next day, we got off the boat and we stayed in New Orleans till about towards 9, 10 o'clock at night.",
      "word_count": 23
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "And that's when I took a train and went to Nashville.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I think the train ride took about 18 or 24 hours, because we didn't get to Nashville till the following evening.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "In Nashville, I was met by somebody from the-- Nashville had a large Jewish community center, and I was met by somebody.",
      "word_count": 22
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And they were-- after-- they got me a room in a boarding house, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "It was a Jewish lady.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "She had about two boarders.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "I was the third one.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "They give-- they asked me if I have any money.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "I had a few dollars, maybe $200, something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "And they paid my room, paid my room.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "And she introduced me to-- it took me-- from the boarding house, there was a restaurant not too far.",
      "word_count": 19
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "And she took me to the restaurant, ordered me some, I don't know, some food.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "And I went to this restaurant for about two weeks until I found a job.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "And I don't remember whether it was ham and eggs, or bacon, and I ate this twice a day.",
      "word_count": 19
    }
  ],
