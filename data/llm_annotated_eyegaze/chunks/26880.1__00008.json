  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "I came to America, and I had-- in Cleveland-- [INAUDIBLE] family-- Dr.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "Abrams, he was.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And my uncle was known [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "He said, Mendel, for the whole thing, and not-- and nothing left you.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "Then I started to told him what's happened.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "And I told him, he-- very pieces, what you say.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "I said, oh yeah, but uncle, I say, it's nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "No, he had a lawyer, Dr.--a lawyer libre-- he have a brother, a doctor.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "And he was-- him's lawyer-- my uncle's lawyer.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "He told him everything.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "And he wrote a letter to Washington.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "And he told them to send everything to Washington.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 26,
      "text": "The lawyer did this, and he said, in fact, then came a letter.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 27,
      "text": "And you-- some $270 he find numbers.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 28,
      "text": "He sent me a letter-- $370-- and he sent me a letter after I got home.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 29,
      "text": "He [INAUDIBLE], and he send me the money.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 30,
      "text": "That's what I left me, from all of fortune.",
      "word_count": 9
    }
  ],
