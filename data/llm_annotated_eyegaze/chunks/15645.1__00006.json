{
  "stem": "15645.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "This I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "But for a time, until the-- the '39, when the war started.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I suppose so, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "I mean up here one, a local, who run from Poland before the-- the occupation.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "But he-- he passed away last year, Diamond Hirsch.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "He told me he-- he went to France before.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "And he told me, I was [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "He run away earlier though.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Moshe was from 1933 in Israel, so he was not up here.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "He was in the English army.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And in the English army, takes some-- take the Jewish boys to the army.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "Because it was under occupation, English occupation.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And he was in the English army.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "He was in Rome.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "He was in Egypt in the English army.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "And later he was in Tel Aviv and married in Tel Aviv, and stayed in Tel Aviv for all that time.",
      "word_count": 21
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Andrew stayed in Poland, because he was in the army, in the same time that I was in the army.",
      "word_count": 20
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "He was in the front.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And when the Polish army was destroyed and they give up the-- the-- the-- their arms, they give up everything.",
      "word_count": 20
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "So he went to-- to Lvov.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "He went to Lvov.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "And when the-- when the German take the-- when start the-- the-- the German-Russian war start in '40-- during '42 I suppose, '42, he run further to further deep in Russia.",
      "word_count": 31
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "And he was there alone in Cheliabinsk where we are meeting later on.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, not much.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Because it was very dear, and if you call it.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "No, I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Not especially, no.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Before they war, I was working for a Jewish-- sanatorium.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "We call this a sanatorium.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "This was for children, a sanatorium.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "This was run by the Bundist organization.",
      "word_count": 7
    }
  ],
