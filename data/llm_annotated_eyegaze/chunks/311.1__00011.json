{
  "stem": "311.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "And you know, the Jewish merchants, some of them open up after the-- you know, after the-- after Shabbos, they'd open up for a few hours, and then they want to open up on Sunday.",
      "word_count": 35
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't-- it was forbidden.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "They used to bring them through the back, you know, and try to sell everything.",
      "word_count": 15
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "It was a big fine and so far.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Oh, boy, my-- my-- my-- my father, you know, there wasn't a Pesach, there shouldn't be a fight.",
      "word_count": 18
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "He said, how much?",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "You know, when he started [INAUDIBLE] it was an hour and a half, and it was only 12 words, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, sure, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "They were younger.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "They were behaving themselves a little better than me.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "And you have to have the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 6,
      "text": "When you picked up something you didn't want to eat before, you know, you had the salt shaker in your hand.",
      "word_count": 21
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 7,
      "text": "It was very strict.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the bracha, and the Kiddush and the-- and the-- Havdalah, you know, this-- this-- this had to be in every house. as far as the houses I used to come in.",
      "word_count": 32
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] Matter of fact, I saw a Jewish theater on Second Avenue about 20 years ago, maybe more.",
      "word_count": 18
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "And they had the Havdalah, and already I had tears in my eyes.",
      "word_count": 13
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "I didn't hear so many years, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] This was a signal.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
