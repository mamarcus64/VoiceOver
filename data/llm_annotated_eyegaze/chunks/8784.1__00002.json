{
  "stem": "8784.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "To the best of my knowledge, what happened is that the Jewish community outside of the jail, the Jewish community living in the Stanislavov Poland area, discovered that there is a Jewish family with so many children in jail.",
      "word_count": 39
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "And they went to work and bailed us out of that jail.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So we probably didn't spend more than a night or two at most in jail, and the Jewish community was instrumental in getting us out of that jail.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And where did you go when you got out of jail?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "When we got out of jail, we-- evidently my family traveled on a shoestring.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And they wound up in Lviv, which I remember being there for a number of days.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And eventually, when he-- when they gathered up enough money, they got enough money to get on a train and go from Lviv to Krakow.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And in 1933, we arrived in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And from there, we settled in Borek Falecki, which is an outskirt of the city of Krakow.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My father was a tailor, and that's how he made his living for the family.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We lived in a, in a house with two rooms was all we had for the whole family of eight.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And I went to school, because I just-- because the children rather, just arrived from Romania, did not speak Polish, we could not just go to any public school in the area, because with the anti-Semitism as it existed in Poland at that time, and with me-- with the children not speaking the language, Polish, it would have been very difficult to go to a-- any public school, which was located across the street from us.",
      "word_count": 76
    }
  ],
