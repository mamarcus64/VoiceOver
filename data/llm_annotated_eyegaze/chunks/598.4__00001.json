{
  "stem": "598.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Me and her and my wife that time, we have to wait our turn.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed there another, maybe, a couple weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And then we went on [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We took a train to go on the horn on the west-- on the west side.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "So we have pass the Russian zone.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They look for documents.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We don't have anything.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "But somehow, we came back.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And that town was Eschwege.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "We came back to the little town, Eschwege.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It was a camp-- DP camp.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "There was 4,000 people there.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And the mother was there already in her room.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And she gave us a place.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And we stay there.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "We stay in Eschwege four years, waiting for papers to go to United States.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And over there was born my first son, Harry.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We-- we were on the-- when we came-- like I told you, we came into Lodz.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I was getting food and changing for clothing.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And I'm making some kind of living.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Then we are talking, we have to run away.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I says, I'm not-- I don't want to run away by myself-- I'm by myself.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I says to my wife, we have to get married.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Then we run away, we are couple.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So I made a wedding in Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I invite 30 guests.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I invite 30 guests, I invite a rabbi to make the [NON-ENGLISH] and made-- and make the wedding there.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Was a Saturday night.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] there, and everything else.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And then next day, Sunday, I says, now we can go away.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And then we went to [NON-ENGLISH], like a told you.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "From [NON-ENGLISH] went to Berlin.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "That was my honeymoon-- on the third bed.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We were staying there for couple weeks, till we're on the way on the French zone.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was--",
      "word_count": 2
    }
  ],
