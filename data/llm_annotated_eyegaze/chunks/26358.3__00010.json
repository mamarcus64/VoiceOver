  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "He was a afraid to get up.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Was too-- too fast.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "The Gestapo not to see him, shoot him.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And it was quick.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "That happened like half an hour, the whole story.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And when we came back, we come together.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] He took off his long underwear, give me to put it on.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "Well I was soaking wet, freezing.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And he put on his slacks.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "My shoes came apart of the [INAUDIBLE] from wetness.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "And I came in the hiding wood back.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "But I brought the fruit.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I not drop that, or we no have nothing to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "That was important.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "I brought beans.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "I got flour.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "And I got a loaf of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "He no got nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "And we came back and I catched a very bad cold.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "And I was coughing.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "I thought, I'll never make it.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "I was bad off.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "With hot water and with hot towels wrapping the neck that time, I pulled through.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Under the ground, we digged, called-- called bunkers.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That's where we stayed.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We was eight.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "When one person turned, we turned.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "All, we need to turn all.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was like eight feet long and eight feet wide.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We was cooking outside of a branch.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] pulled the branch, and we was cooking.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "We needed to build the fire very hot, not smoke to show.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "You're looking.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you, believe me.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I can't believe it what I'm telling you that everything now.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And I remember everything.",
      "word_count": 4
    }
