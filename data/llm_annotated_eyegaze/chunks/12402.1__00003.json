{
  "stem": "12402.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And I went for another season.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And that summer, I remember that summer, after Pesach, I had my younger brother-- oh, I didn't tell you the rest of the family.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So we have a sister, we had a sister, my older sister was--",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "What's her name?",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Matla.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She was-- she was-- she was born 1917.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "That was my next sister.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And after that, we had another-- after-- after-- then, I was next.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I was born next.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And next was my other sister, Bayla.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "She was born in 1923, something like that.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "After her was my younger brother, which he survived the war, Martin.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "He was born in 1925.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And then we had a-- a younger sister was born in 1929.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "1929.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Her name, Toba.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "She was the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So we were-- that was the-- that was the left of the family, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We were-- we remained at home, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And we had a wonderful life and everything was going nicely.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And we-- and we weren't-- we weren't lacking anything.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "My father made a good living.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And unfortunately, so--",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My mother-- my mother was a-- was a business lady.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "She was-- she never stayed home.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Like the older-- the older sisters took care of the domestic problems.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And the business and the home all was together, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Like in the back we had a home and the business, the store, was in the front.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "So she was the business lady.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My father worked in the manufacturing, which we used-- used to produce 150 pair of shoes a week outside, like home workers.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They were all made by hand, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They were very popular.",
      "word_count": 4
    }
  ],
