  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And then, [PAUSES FOR 3 SECONDS] we came back to Warsaw after 10 weeks.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "Of course, and this hotel was taken by the Russian general staff, military staff.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And I had to make acquainted with a Jewish-- [PAUSES FOR 5 SECONDS] It was not a general.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "It was a-- I don't know his rank, and he told me I shouldn't go to Warsaw because we are going to Warsaw, anyway, so you come with the army.",
      "word_count": 30
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "But I didn't listen to him, and I went to Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We have a very nice family life.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I was working and have a good business.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we were young people, and all we do is stay with the family.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We live together with her parents in the same apartment that time.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "As a matter of fact, the printing was in the same place.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "As on the front it was a store, a front store on the street-- from the street.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And in the back we had the big apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "My pre-war address?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I mean--",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "--the printing?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, [?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Pawia 31. ?]",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, not really.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Rather traditional because my father and his brother had to work Saturdays.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He worked in a big factory, which and mostly Polish people worked there.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He was a carpenter, and has to work Saturdays there.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] Later on, he was on his own, and he built furniture.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was playing soccer, was my hobby.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "There is another thing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I was later on, when I was 13 years old, I finished school.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And they work was I became an apprentice in the printing.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And this where I learned my trade.",
      "word_count": 7
    }
  ],
