{
  "stem": "5644.6",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 2,
      "text": "But then we'll start to gain profits.",
      "word_count": 7
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 3,
      "text": "So I said to my partner, which was at that time, I said look, my dear friend, I am not going to stay in a place where we're losing 10,000 pounds.",
      "word_count": 31
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 4,
      "text": "I have got 10,000 shillings.",
      "word_count": 5
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 5,
      "text": "So you're talking about 10,000 pounds.",
      "word_count": 6
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 6,
      "text": "And we ran out of the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 7,
      "text": "That was Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 9,
      "text": "Rubinstein ?] run the factory there.",
      "word_count": 6
    },
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 0,
      "text": "The one which run at that time Jewish news.",
      "word_count": 9
    },
    {
      "segment_idx": 205,
      "sentence_idx_in_seg": 0,
      "text": "I give you-- here, I can give you names.",
      "word_count": 9
    },
    {
      "segment_idx": 206,
      "sentence_idx_in_seg": 0,
      "text": "In Poland, I won't.",
      "word_count": 4
    },
    {
      "segment_idx": 207,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 208,
      "sentence_idx_in_seg": 0,
      "text": "All the time.",
      "word_count": 3
    },
    {
      "segment_idx": 209,
      "sentence_idx_in_seg": 0,
      "text": "'47.",
      "word_count": 1
    },
    {
      "segment_idx": 210,
      "sentence_idx_in_seg": 0,
      "text": "'47 Or '49.",
      "word_count": 3
    },
    {
      "segment_idx": 210,
      "sentence_idx_in_seg": 1,
      "text": "Miriam.",
      "word_count": 1
    },
    {
      "segment_idx": 211,
      "sentence_idx_in_seg": 0,
      "text": "After my mother.",
      "word_count": 3
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 0,
      "text": "Miriam Alexandra after her father.",
      "word_count": 5
    },
    {
      "segment_idx": 213,
      "sentence_idx_in_seg": 0,
      "text": "If she wouldn't wait for me-- no, yes, one child.",
      "word_count": 10
    },
    {
      "segment_idx": 214,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 215,
      "sentence_idx_in_seg": 0,
      "text": "Yes, one grandchild.",
      "word_count": 3
    },
    {
      "segment_idx": 216,
      "sentence_idx_in_seg": 0,
      "text": "Michael.",
      "word_count": 1
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 0,
      "text": "Michael Mahemoff.",
      "word_count": 2
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 0,
      "text": "No, but before we finish, we-- only one word.",
      "word_count": 9
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 1,
      "text": "The whole story I told you-- it's-- you won't offend me at all, if listening to the story, you won't believe in it.",
      "word_count": 23
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 2,
      "text": "Because I don't believe myself.",
      "word_count": 5
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 3,
      "text": "With that, I like to finish it.",
      "word_count": 7
    },
    {
      "segment_idx": 219,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 220,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
