{
  "stem": "27759.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "My vision was 70 over 16 in one eye and 60 over 40 in the other eye, because when I went into the military, I wanted to get in the Marine Corps.",
      "word_count": 32
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And my vision-- the Marines turned me down and said my vision was too poor for a Marine.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Let's see.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "That would have been two weeks after we arrived at Camp Shanks, New York.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Then [PAUSES FOR 5 SECONDS] at first we were scheduled to go on the Queen Mary.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS] Then they changed the orders, and we went off on the Liberty Ship.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "SS McAndrew.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "McAndrew.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Liberty Ship.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We went over on a Liberty Ship and returned on a Liberty Ship.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "To Liverpool, England.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it took us 12 days. 12 days to go over, and 14 days coming back.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, they boarded us on trains and took us to a town [INAUDIBLE] called Upton Scudamore.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Upton Scudamore.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "It was a town in England.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And we continued in basic training there.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Then they took us to Frome.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "In England, it was different.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, the people were much nicer.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They knew that we had come over to assist in defeating the Nazis.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, when we would get passes and go into town, the different towns, it was-- we were received very warmly.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "The different pubs, you'd go into town and go to the pub.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And you had fish and chips.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They have fish and chips and a cup of tea for meals.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You know, new meals.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "They are big fish and chip eaters over there.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "When you get them.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was in England [PAUSES FOR 5 SECONDS] about three or four weeks before I crossed the English Channel.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
