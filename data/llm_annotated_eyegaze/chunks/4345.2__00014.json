{
  "stem": "4345.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "The pictures that I showed you have the little photo ID?",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "This was the purpose of those IDs.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "We belonged to the [SPEAKING GERMAN], German government sort of, to speak.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I was under their jurisdiction.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I had this ID and with this ID, with many other girls, young girls, we worked in [INAUDIBLE] and we made raincoats for the German army.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "You know, they shouldn't catch a cold, god forbid, you know, the front up there.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "So I remember going to-- oh, my sister was gone already at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "My sister Malka was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "Let me tell you what happened with her.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Then-- then there was a-- before this happened with me-- anyway, I worked in this factory.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "This-- I had a job, no pay, just work, day shifts and night shifts.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "But then came a-- [PAUSES FOR 3 SECONDS] we hear again that that's going to be a roundup on young mothers with their babies.",
      "word_count": 24
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And my sister Malka already had this baby.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He was eight months old, my little Avrom [INAUDIBLE], such a beautiful little thing.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And-- and-- and there were beautiful mothers.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "There were the young mothers at home with their babies, little-- little-- little children a year old, [INAUDIBLE] on the arms, newborn.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "My sister-- I slept-- that night, I slept in my sister's house.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And I had no place to go, anyway, you know, so I slept in her apartment.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "We had to round up outside.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "We could not take anything from the apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Everything was to-- to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "It was confiscated by the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "The only thing that I took is my sister's coat.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, he's--",
      "word_count": 2
    }
  ],
