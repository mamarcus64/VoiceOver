{
  "stem": "21494.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And you know, and he came out and he told-- I know that I said, but I said, don't tell nobody because you'll go and they'll burn all the family.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "There was a family about 12 people.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Then he-- he-- they say, no, no, no.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He say, I still need to-- some questions to ask.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And then-- and then they took him-- the Goy-- to-- to burn the-- the-- the-- the-- the dead people.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And then he saw our Jewish-- he didn't know what to do with us.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "The-- the-- the--",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, they were guarding almost.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They were guarding.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And he knew he was afraid they'll kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Then, he-- he-- he went to-- to the-- to work, and there, he saw this officer-- a Jewish-- a Jewish nose.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "He said, you are Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "You were crying to so-and-so.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "You want maybe to kill me too?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "He say, no, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I have two girls which I hided.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And on that morning, somebody saw us.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I say, Sanja, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "I-- I shouldn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "I shouldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "We should be here.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I don't know why we should be here.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And he said, look, I'll go with you but in case, if they are not there, I'll kill you.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "He took two soldiers with him.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "I'll kill you with whole family, because you are liar.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "He came, you know, and it was good that we didn't go.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "If we would go, he would kill the whole family.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And he say-- he say, go out, people.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "Go out.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "And he start to-- he was from Kiev.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "He start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "And he told [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And he gave him the two good horses, and he took the bad for the soldiers.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "And he said, no more.",
      "word_count": 5
    }
  ],
