  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] So-- and she was telling him all these stories, you know, these [? hand. ?] Do you remember any of that?",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I couldn't concentrate, you know, because I was listening more.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But I heard a couple of sentences.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I knew that's the family.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was press from all over the world.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "The matter of fact, on the third day of the trial, a French [PAUSES FOR 5 SECONDS] journalist had the permission to come into my room where I was sleeping.",
      "word_count": 30
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And he had a little bag.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And he opened up the bag, and he had a suit.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And he said, Moses, I want to give you this suit for a gift.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Because I want something to do.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And I don't have-- that's the only thing.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I have four or five suits.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And it was almost my height.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And he says, I know it's going to fit you.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And he gave me the suit.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "I said, thank you, thank you.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And then he wanted to interview me, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I said, maybe another day.",
      "word_count": 5
    }
  ],
