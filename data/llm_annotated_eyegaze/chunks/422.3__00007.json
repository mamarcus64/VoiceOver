{
  "stem": "422.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Mr.-- Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Wiernik.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Wiernik-- not Reznick, my mistake.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "So he warn us.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "But there was nobody left to fight them.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "No one.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "The fighters, the real fighters fought.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They fought for more than four weeks, and they killed some Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "They had their satisfaction, but they all perished.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They were jumping.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to fall in-- a life to their hands.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They are jumping from burning buildings.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "The ghetto was burned.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "They-- they decided to burn house by house.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "They sent-- they threw down bombs from airplanes-- airplanes, incendiary bombs.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And then, the people-- there is only a few survivors from that fight, that I know.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "That one is Vladka Meed, that she smuggled in ammunition from the-- from the Polish side to the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And the-- there was a few I know from that fight.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "I was very unhappy that I couldn't be that time in that fight, because my father took me to the small ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Their names-- he was, my husband's name was Schmuel Blu.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The child's name was Nina.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She was only nine months old when she perished.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "They were taken to die, to the gas chamber.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "At work.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "In the shop, doing my work.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Coming home and not finding them at home.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It was that time-- I got, in my article, this write-up, this was a time when you came home from slave work, forced work, and you didn't find your relatives.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "One day a sister was missing, the other day a brother was missing, one day a-- a-- grandparents were missing, a child was missing.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "This was those-- those days.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And you had to live like this, and struggle for your survival.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Every day was a struggle for survival.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "The hunger was so terrible there.",
      "word_count": 6
    }
  ],
