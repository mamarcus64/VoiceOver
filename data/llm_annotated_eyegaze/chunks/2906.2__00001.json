{
  "stem": "2906.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "They didn't have anything to spray and it was-- I was there a couple days, and they-- they ate me up.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I was swollen, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "My hand, my feet, because--",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In the fields.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And they decided they have to take me back to-- to this little town.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "So I came back, and my brother told this-- he became his friend.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He said, my-- my sister came back from there.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "She can't work.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "She was all sick.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "He said, OK, so she work in the fish factory.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "There was a lot of Russian woman working.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And it was already so cold that my-- my hand was swollen.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "It was so swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Like--",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The water from the fish was-- have to be cold.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We have to-- the-- this fish goes here.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "This is fish goes there.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I don't know, the Russian woman were working there for years, it didn't affect them.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "At night when you have to-- when you went home, they-- they checked you.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "If you didn't steal anything, if you didn't steal any fish.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "They was watching you because, you know, hunger, there wasn't a-- a lot of food to eat.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Even the Russians didn't have a lot of food to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "It was a war.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "What they give us to eat?",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They give us a piece of bread.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Not enough.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Give us the bread and we split it two times, or three times.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Water.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "There was water to drink.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And we stayed there a couple days, and then we decided, my brother and there was a cousin, the others, that we have to get away from there because this was in a corner from the Caspian-- yeah.",
      "word_count": 38
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "When Hitler will come, we'll come-- he'll catch us in the site.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
