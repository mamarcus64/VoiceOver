{
  "stem": "3150.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "They knew, if anybody's going to-- if anybody was going to hide anybody it was going to be them.",
      "word_count": 19
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Again, they didn't look for us.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was-- I mean, I know they-- they kill eight people.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "But if they would-- if they wouldn't think that we were alive, they would have dug us up.",
      "word_count": 18
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "They would have find us somehow.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No, because they obviously didn't care.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "They-- they-- probably-- somehow, they thought-- because when I came out in 1944, and I met one of my cousins that survived on her own, she was shocked.",
      "word_count": 28
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "She says, you can't be alive.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Because I know where you die-- I know-- I know where you're buried.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "She thought-- because she couldn't believe it.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "Because they-- everybody knew you guys died, you know, when we died and where we were buried.",
      "word_count": 17
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "And it was him.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "It was the Shamas with his-- with his family.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I would say probably, you know, they-- because they stopped looking for us.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "They really accounted for everybody in the shtetl that was missing.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "She was also in hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "She was also in hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, she was in hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "I didn't even-- we didn't know she was alive till we came back.",
      "word_count": 13
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "We did not know she was alive.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "He was 40.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "It was 1902.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "He died at the end of 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "He was 40.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "They're about the same age, months apart.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "My-- my-- my mother's birthday is June-- June 5th, let's say.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "My mother did survive.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And she lived to a ripe age.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "She died when she was 90 and a 1/2.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "So she lived a long life.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
