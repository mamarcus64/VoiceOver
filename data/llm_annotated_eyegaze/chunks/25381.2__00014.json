    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "So I don't know how many killed, or how many what.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "I was the only one.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So I sat on the tree day time.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I went down and I ate the mushrooms.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I ate it like [NON-ENGLISH]-- like spinach during the day.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "My teeth were so black like-- like this-- from-- that I didn't have anything.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I think we're going to pause here, OK?",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "This is the end of tape two in an interview with Edith Cimmer.",
      "word_count": 13
    }
