{
  "stem": "9601.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "This was my first encounter.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "So I used to go to the fence and look at, them you know, to see what they're like, the same way people looked at me in Michigan, Traverse City area.",
      "word_count": 31
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I was in the United States Army Reserves.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I was actually attached to the National Guard during the Korean War because I knew Russian, so I was put into an intelligence unit.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "We were just interpreters.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And we used to go to Grayling for two weeks summer training, but in the evening, we would go.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "So we went to Traverse City to the bars looking for adventures like any red-blooded American does, and we met up with some girls there.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And I was one of the Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And there were three other-- no, two others.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And there were seven of us total, the three Jews and the four Christians.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "We were all in the same unit, same one unit intelligence.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And we said, naturally, we haven't got time.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We're trying to make count.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "You know how things go.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And one of the girls said, oh, you're from Detroit.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "She tells me.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "She says, I heard that there's a lot of Jews in Detroit.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Aren't you afraid?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Oh, she says, I wouldn't live there.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They're terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "What do you mean terrible?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Come on, they're just like any other people.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Oh, she said, they come here and all kinds of funny stories, scary stories about Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "So, you know, I finally got up and I go, well, it's a lost evening.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "So I said to her, how did you like dancing with Steve?",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "Steve Radoff.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "He's a good dancer.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And his cousin-- I don't remember what his cousin's name was.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "How was he?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "He's nice.",
      "word_count": 2
    }
  ],
