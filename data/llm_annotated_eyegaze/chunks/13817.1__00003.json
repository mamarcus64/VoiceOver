{
  "stem": "13817.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "Like I said, I played on it was when I was seven until '33 when I was all of a sudden kicked out of the game-- out of the soccer team.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Schooling.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "I went to-- for four years first with this Jewish day school that I mentioned before.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "From there I went to the so-called gymnasium.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "If you wanted to go to college, you had to have gymnasium education.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And the gymnasium was all-- not like here, the high school.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "The gymnasium was private and it was actually a preparation for-- for college.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And I went there for four years, and that was in '33, '34.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "Then I was kicked out of that school because I was Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "Like I said before, we lived a normal life.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "There was no different between the kids or between religions.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "In fact, an example how we were treated in the town-- it's the best example is that there was a-- a parade in the town, and I had a-- a very bad-- I was sick for over a month in a hospital.",
      "word_count": 42
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "And after I came out, they rerouted the parade by our house so I could watch the parade.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So you can see how-- how well we were liked there.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I come back later on-- when I come to the Kristallnacht, I will show a other example how-- how close everybody was and how close we were liked.",
      "word_count": 28
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The business was very good, what you would call very good.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We had a maid but which was at that time in Germany no big deal-- a lot of people did.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "The maid got a very minimal salary.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "She lived in with us, and she was treated like one of the family.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "She never would be eating in the kitchen or something.",
      "word_count": 10
    }
  ],
