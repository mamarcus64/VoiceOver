{
  "stem": "24242.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Aron Bell.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] A-R-O-N B-E-L-L.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "First is the same, Aron.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The second was Bielsky, B-I-E-L-S-K-Y.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 9 SECONDS] I see this is gonna be pretty hard on me.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I can see it right now.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] I was born near a village which had called Stankiewicze.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "The closest town was [PAUSES FOR 3 SECONDS] 15 kilometers away, which the name was Nowogrodek.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "State of White Russia, [PAUSES FOR 3 SECONDS] which-- which it is now-- they call it Belarus.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] In their language, the White Russian language, they call it Belarusia.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] January, 1930.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "How old does it make me now?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "What are we now, in '96?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] 67.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "David.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] Same place where we were all born-- four generations.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] According to my older brothers, [PAUSES FOR 3 SECONDS] three or four generations in Stankiewicze.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "He had a mill [PAUSES FOR 3 SECONDS] that the villagers would come with grain and you make all kind of cereals and flour.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And we had a farm.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Whatever a farm has, that's what we had, whether it's a turkey or chicken or duck or a goose, horses, cows-- regular farm.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Some for our own consumption, and some they used to sell.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Bella.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 14 SECONDS] [SOBS] Her maiden name was Mendelewicz.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "A village-- [PAUSES FOR 13 SECONDS] [CRYING] a village called Stankiewicze.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I mean, [?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Petrovich, ?] forgive me, [PAUSES FOR 5 SECONDS] like 10 kilometers away.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "There were 10 brothers and two sisters-- 12.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm not going to go through all of them.",
      "word_count": 10
    }
  ],
