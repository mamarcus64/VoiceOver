{
  "stem": "4078.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And of course years later, I realize now, she really wasn't.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "She was just petrified.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "She changed-- her name was Helen Levy, and she would never use the name Levy.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "She insisted her name was Levee.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And I think her name actually was Helenka, but she called herself Helen.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And she would never say she was from Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "She spoke very good English.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "Of course, her mother had a very thick, Polish-Jewish accent.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "But she-- I used to see her sometimes with her mother, and she always ignored people when she was with her mother.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "She was fairly friendly when she was in school, but she was a little bit strange.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And I think now I-- I realize why.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "This was before the-- before the-- before the war, yes, yes.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "What about it?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh no, that was-- that's right.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Oh, you mean during the war, when I-- yes.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "No, this was during the war.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I became sick.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I had an earache-- started with an earache, and this was already 1941.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "We were bombed in 1940.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "November, 1940, we were bombed, and I became sick during the Easter holidays in 1941.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And I got an earache, and the earache became very, very intense, so intense it was excruciating.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And then my ears started to bleed.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And my mother called the doctor, and the doctor came over.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And I heard her whispering to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And then the next thing I knew was that I was sent to the hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And my hand started to swell, and I got a very swollen hand.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And I was put into a room, and I think I was delirious, because I remember being surrounded by lots of people in white.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And I really don't remember too much.",
      "word_count": 7
    }
  ],
