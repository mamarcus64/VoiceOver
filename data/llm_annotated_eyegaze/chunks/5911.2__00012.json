  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Because this was my-- my possession, my beautiful-- nobody had one.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember anybody having.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I remember taking the doll and break into smithereens.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember them saying anything to me.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And then, for a certain time, we were still in labor camp.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And then we were brought back into the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And we were in the ghetto till July of 1944.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And again, people were dying.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Maybe my nature that I had, my father wasn't depressed then because he had me and my mother.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "My mother worked at the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "How terrible things were, I had it better than a lot of people.",
      "word_count": 13
    }
  ],
