{
  "stem": "894.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And-- and I remember one of these handsome soldiers said to my sister-- I look like a kid, so-- But she said to her, I want to take her out.",
      "word_count": 30
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And I didn't let.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I didn't let.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "I said, no, you're not going with a soldier.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "[LAUGH] I was a-- you know, so it was really very funny.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And I remember, he came for tea.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And then my sister went out to get the tea, and he said to me, you know, I really would rather take you, if you weren't so young.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "[LAUGH] I felt so good, very proud of myself.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "And so that was the experience then.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And then we went on to Prague-- capital of Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "And there we went, and it was-- we found out they were communist-- young people, very nice young man.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And we told them the story.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "We told them, this is-- you know, we-- trying to get home.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "And they said, well, first thing, come home to our family.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "We live at home with our parents.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "They took us home-- in the suburbs, somewhere-- suburbs of Prague.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "And right away, the mother made the girls give up their beds and took care of us.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "The Czechoslovak people were always very nice people.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The Czech people-- the Slovaks, not so much.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "The Czech people were very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And we stayed with them a few weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And these boys tried to take us around and show us things.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And [PAUSES FOR 4 SECONDS] we felt it just wasn't-- it wasn't going in the right direction, that we have to get away, and we have to get home.",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I remember they took us to the train station.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And we said goodbye.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "We-- unfortunately-- unfortunately-- they gave us pictures of themselves.",
      "word_count": 9
    }
  ],
