{
  "stem": "8962.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Then came the decree that you had to turn in all your jewelry, all your silver, any gold.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "They had stations where you had to bring it.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "They didn't come pick it up.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "You had to bring it to them.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "And my mother, who was a very feisty lady, said I'm not going to give all of it away.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "I'm  not just going to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "I'm going to give some of it as a token, and she took her silver service for 12, and she sold it to somebody on a pittance, just a pittance.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And then, we got a notice that we had to leave our apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "They had lived there since 1914, and from one day to the next, we had to give up the apartment.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "And she found somebody who bought the piano, my father's piano.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "And when that was carried out of the apartment, it was like a casket was being carried out.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "I mean, these were material things, but still, it showed the disruption of the family.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "It showed a disruption of our life.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "It showed the disruption of something we had taken for granted.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "It was just no more.",
      "word_count": 5
    }
  ],
