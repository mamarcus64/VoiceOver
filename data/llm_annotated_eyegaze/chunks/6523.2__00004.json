  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He say a-- a big percentage for the Jewish population, like I said before, went to other countries, like special of the anti-Semitism education for the children.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "They went to Germany before '33.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And Hitler come in '33 to power.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They took the all of them.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "They called them [NON-ENGLISH] and sent back to Poland-- took them-- and send them back to Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "From them-- from them, we learn what is going on.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They still-- [LAUGHS] --haven't been happy with the Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They've been ridiculous.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Some of them even-- German Jews say to me, if-- [NON-ENGLISH], German that we could die from the Poles.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "The Poles was-- the first thing that they done to-- to-- to look us-- for Jews, they get a five pound sugar, or five pound salt, to show this is a [NON-ENGLISH].",
      "word_count": 32
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Some Jews took off.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And they went outside to try to organize some food or get in contact with some--",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "This is the start of the war.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "This was the start when the Pole-- when the German come.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Maybe three months, four months later, they-- after a few months later, they put them in ghettos.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, like, I try to remember.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "You say, if you learn when the [NON-ENGLISH] where the-- Hitler send them back to Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "What is going on?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We tried to run away.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I took the bicycle.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I ran away to the thousands-- hundreds.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I ran away to the Russian-- to the Russian.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "This-- when the German came to Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Before that even, in the 1939.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] This must be the 9th or 10th month, I believe.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No, before.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] must be the October-- September-- October-- I don't remember.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I have to figure out.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they ran away.",
      "word_count": 4
    }
