{
  "stem": "54.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 48,
      "text": "The ship was standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 49,
      "text": "The one we came with, the ship, was still standing in port there.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 50,
      "text": "He thought that we are on the ship, but we were already in Atlit.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 51,
      "text": "He came with a little boat.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 52,
      "text": "And he was screaming, hello, hello, hello, everybody!",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 53,
      "text": "Somebody was standing outside.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 54,
      "text": "He says, she is not here.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 55,
      "text": "She's the next-- she's in the next barrack there.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So he came.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And he got up on the ship.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He got off the-- the boat.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And he came to me.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he says-- he brought me some food at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And he says, well, you're here.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "That's the main thing.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Now I'm going to see what I can do for you.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He came back.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "The next day, he came back to Haifa-- I mean, to Jerusalem, where we were-- he was in school.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And he said to his [NON-ENGLISH], you know I just came down from Haifa.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "She says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I don't believe you.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He says, yes, here.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I have a picture of my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "He brought the-- I gave him a picture of mine, so.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And she said to him, well, what are you going to do?",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "He worked over there with the men and lived in Jerusalem.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "He was a builder.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "He was building the kibbutz.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And every Friday night for Shabbat, he took one of those three guys home, make him feel home, like he used to be home, like by us.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Every Friday, he brought somebody else home.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So my brother was once there, and he said to him, look.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My sister is in Atlit.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She came from camp.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Where is she going to be here?",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "We don't have family in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have nobody there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "What am I going to do?",
      "word_count": 6
    }
  ],
