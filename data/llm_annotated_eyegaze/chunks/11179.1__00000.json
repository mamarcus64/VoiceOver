{
  "stem": "11179.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It's Henry E.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Moser.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "H-E-N-R-Y E for Ernst, E-R-N-S-T, M-O-S-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Heinz Ernst Moser.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "H-E-I-N-Z E-R-N-S-T M-O-S-E-R.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Frankfurt-am-- on Main, Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "F-- F-R-A-N-K-F-U-R-T O-M, [PAUSES FOR 4 SECONDS] Germany, G-E-R-M-A-N-Y.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm 72.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "May 12th, 1923.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Frankfurt, and when we were-- I was what?",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Four and a half years old, we moved to Berlin.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I grew up in Berlin until I was 16.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Alfred Moser and Lily Moser.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father was an advertising salesman.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He worked for a-- I guess you would call it a trade paper, which was an elec-- electrical-- all-electrical company, including the-- it would go to the appliance dealer, to the contractors, to the wholesalers.",
      "word_count": 35
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "It covered the industry, which included which from-- from radio-- not yet television-- to all the major appliances, minor appliances, to cables, for instance.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Anything to do with-- with electric contracting.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "He had some customers which are now world known, like Siemens AG, OSRAM, Telefunken, Philips, [PAUSES FOR 3 SECONDS] and Beckman Electric, and a few other names-- maybe lesser known names.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "But he-- he made very good contract before the Nazis.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother was accepted-- she was helping him a little bit with letter writing and so on, but basically she was a housewife.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Before she got ma-- before she was married, she worked at a bank, for-- as a clerk in the office, and later on in a photo studio.",
      "word_count": 27
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Lilly.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We were a close family in that way.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We were a close family when I grew up in Frankfurt, with the grandparents.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, we lived in my grandparents' apartment house.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We had an apartment in my grandparents' house.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I was even born, I understand, in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "A doctor came to the house.",
      "word_count": 6
    }
  ],
