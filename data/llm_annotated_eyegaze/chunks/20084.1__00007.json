{
  "stem": "20084.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Miriam was also in school.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, to the German invasion, it started before when Germany invaded Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It was-- they form a civil defense.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And every building was in charge of their own-- of their own-- had to have guards outside.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And we had to schedule.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "People had to schedule sitting guard outside the house, see-- looking that there's no strangers coming.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "The lights had to be turned off.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "There was no lights.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And-- and I recall on one of those nights, I was 1 o'clock or 2 o'clock in the morning.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "It was a dark night, and some stranger came over.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I was sitting in front of the building.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "I was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I was holding like civil defense guard.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And he was starting-- asking me question about this and that.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And he was asking me about a-- a particular place where-- where the army was, this was.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And-- and he was holding his hands in his pocket.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And I was pretty scared.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "I was pretty scared.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "I don't know who he was.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "Maybe he was a spy or what.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "And that was pretty scary experience.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "Then the following morning, they were running, people.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "You heard from the distance artillery-- artillery.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "And you knew the Germans were coming.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "And then a lot of refugees was coming from-- from Silesia, from all that from the German borders.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "And one particular family came in.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "This was an air raid.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "And they came to a shelter in our building.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "Was an air air raid, and-- and I helped them to fix an axle on the-- on the what you call it-- on the carriage, on the horse-- horse-drawn carriage.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "And I help him.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "And he gave me a handful of money.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "It was thousands of thousands.",
      "word_count": 5
    }
  ],
