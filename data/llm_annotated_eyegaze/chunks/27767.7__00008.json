{
  "stem": "27767.7",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And then we-- my cousin, who was that director Jewish committee's wife, she found out in Astoria, in my wife's [INAUDIBLE], they find us an apartment, a small apartment, a rent-stabilized apartment, which we paid very little, $75 at that time a month, which was a lot of money for us at that time.",
      "word_count": 54
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "And I was trying-- they were-- they were ready to send me-- because I had a degree in industrial engineering, they were trying to send me to Milwaukee, to a forest company.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "But, finally, I didn't want to go away from here, New York.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "So I-- finally, I found a place where my cousin's husband just opened up a small place.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "He was alone on 110th Street in Manhattan, a supply, [INAUDIBLE] supply place.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "And I got the job there.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "And first job, I had $100 a week.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And that was pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "And then I got 150, I got 200.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "So I got-- and we were working together.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "And we established this business.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And I'm still in this business.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I said to my wife, I want to go back-- number one, I want to go back to Dachau, and say a Kaddish there for my father.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] So we went to-- I but I didn't want to sleep over in Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't sleep over there.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So we went to Zurich.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And from Zurich, we flew into Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And from there, we took the train.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we went to Dachau-- which is actually, the concentration camp is in a little town, Dachau.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] Munich, Allach, Dachau, and then Dachau.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "So we went with the train.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It's about half an hour ride from Munich to Dachau.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And we went to the camp.",
      "word_count": 6
    }
  ],
