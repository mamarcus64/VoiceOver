{
  "stem": "1677.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And they say, oh, you have come back?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "We heard that they murdered you all.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And so we decided we will emigrate totally.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I spoke good English by that time.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I studied it at the University in Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I had a scholarship.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "My sister studied kindergarten teacher, had a scholarship.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We had a room.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "We share the room.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We managed.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "The Joint Distribution Committee helped us to get our landing permits and our tickets.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And and, we came-- on the 28th of May, '49.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "I left Czechoslovakia totally unprepared for immigration.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I didn't have a trade.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "I didn't have a profession.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I was expelled, as per usual, because I was not in the party.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So we were-- 40,000 were dis-- expelled.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I could now go back.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "There is a big amnesty.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And all these people could go back and graduate and do their doctorates.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "But anti-Semitism now is worse, I think, than before the war.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Because people are claiming restitution.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "So did I.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "So did everybody else.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And that caused enormous anti-Semitism, because they don't want to back-- give back the plunder.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And then we went to Genoa in Italy and waited there.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I met people who had money, people who did black business, people who had gold, people who had paid for their fare, people who put their act together after the war.",
      "word_count": 31
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "Couples-- there were no single girls, only very few, a few boys.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "Everybody tried to marry before you went.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "Everybody was too frightened to go alone, just like this, to Australia.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "My sister was very popular.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "I had a boyfriend in Prague, Otto Ruzdichka.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "He's in Papua, New Guinea.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I helped him to immigrate many, many years ago.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "He's a very wealthy man.",
      "word_count": 5
    }
  ],
