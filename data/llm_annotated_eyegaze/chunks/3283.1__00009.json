{
  "stem": "3283.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "It's the same as an MA, Master of Administration.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So I got that degree first.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And then in 1926, I graduated law school.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And that year, I took the bar examination.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "I passed.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And I got my admission to the bar in 1927.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Then I went into private practice of law.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I happen to have a friend who was a bail bondsman.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And he recommended cases to me.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "That was during prohibition already.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And by the way, that shows.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And there, the assistant district attorney in charge of the cases was Mickey Marcus.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Does that ring a bell?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Dave Marcus.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And in the war, he was Colonel Dave Marcus.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He went to West Point.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And he was a wrestler.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Good wrestler.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And I was a boxer.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "So we became good friends.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And when I went to Washington, I met Mickey Marcus.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And he's the one that introduced me to General Clay.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "You see this whole thing was like a dream to me.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "A panorama.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Panorama.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And then of course, another thing that I consider as fate.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "There was a hotel in Strasburg, Pennsylvania.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And one summer, a weekend in July-- that would be like 1932-- I went with three or four friends of mine for a weekend, a July 4th weekend.",
      "word_count": 28
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And I went to the-- this hotel.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And then after the weekend, my friends and I came back.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was the Lackawanna Railroad that went from Strasburg to New York.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And on this train, I was sitting with my friends, and all of a sudden, I see-- hold it?",
      "word_count": 19
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Go on.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Hold it?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I see a woman walking up the aisle.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "She had a white headband, a white dress, and a gold belt.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And she was handing out sandwiches.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "She had gotten her lunch, and she offered.",
      "word_count": 8
    }
  ],
