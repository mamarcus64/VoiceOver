{
  "stem": "13655.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I was doing a lot for my family, and another family and another family.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "We start to run away from that town, because otherwise-- this was on a Sunday.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Till Friday, we had to be there in Biala Podlaska.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "There is going to be the Judenstaat.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "To [?",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Lowicz, ?] Sarnaki, and in the woods, in the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "We organized.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We took farmers with the horse and wagon this way.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "We tell them to go not in the main roads, only from the side streets, from the side roads.",
      "word_count": 19
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "We paid them in cash for the trip.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "They picked up the best people, the best people-- we could trust them.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "The farmers, we picked up the best one, but we had [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "They didn't took away.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "They took them there.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they took something with them.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "But what happened, that particular day, they didn't arrive to Biala.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "They took 3,000 people, Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "They sent them to Sobibor.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "How did they know?",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "They sent a Polish man to track where they're going.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "And he came, and with the answer, and they went to Sobibor.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "And there was already a crematorium and gas chambers, and they finished them up.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, he direct didn't give me.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "He gave it to the Biala.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "It was 18 kilometers, but we find it out a day or two later.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "If we would go there, we would be finished on June the 6th, 1942, after Shavuot.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "Was a couple days.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "We escaped.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We escaped.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And we tried--",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "My family was there.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "It was spreaded, one in [?",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Lowicz, ?] one in Sarnaki, one in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I was the only one near the town to know the news, what's going on.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "In that particular [? week ?] was the older people.",
      "word_count": 10
    }
  ],
