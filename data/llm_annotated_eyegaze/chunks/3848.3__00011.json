  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 59,
      "text": "And water developed on my knee.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 60,
      "text": "And my whole leg stiffened up.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 61,
      "text": "And I was injured.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 62,
      "text": "I had to go to see this particular person in Munich.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 63,
      "text": "And near Munich, there was a camp-- a DP camp-- Feldafing.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 64,
      "text": "And the director was [?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 65,
      "text": "Gourevic. ?] And he knew about me because he wrote to him.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So with my broken leg-- sort of not broken, full of water-- I had to go into a hospital in this particular DP camp.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They couldn't take me into the hospital, because I wasn't registered in Feldafing.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So I had to get another name.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And the name they gave me from the camp was Leon Swerling.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Now we've finished tape number four?",
      "word_count": 6
    }
  ],
