{
  "stem": "3331.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And in the woods, he survived.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He had a wife and three children.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They were taken to Belzec in the same day and were killed.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "After the war, he remarried.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And he has one-- he had one son.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "His son, his name is Edwin Salsitz.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "He's a doctor in New York.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "He works in Beth Israel Hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Leibush died 20 years ago, and a natural death in the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "After Leibush was a sister, her name was Malcha.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We called her Malcha, but her name was Alta Malka.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "The reason-- well, I don't think so, this is important why her name was Alta Malka, because she was named after an aunt who died very young.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And by Jews, if somebody died young, so you gave an additional name or Alta, which means old or Haya, which means life.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So her name was Alta Malka, but we called her Malcha.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Malcha was married to [?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Shi ?] David Leischer And they had two little girls.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "A girl, Dubcha, Blimcha and Dubcha.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And they were also killed in Belzec in the same day, which Dubcha-- Blimcha was three and a half years and Dubcha was two years when they were killed.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "After Malcha came Liba.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Liba was my third sister and she married a man.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "His name was Moses Kornfeld And they had two small boys, also a three and a half year old boy and a two year old boy.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And the boy's names were-- the oldest was Heneh, And the second was Yosel.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "They also were taken to Belzec in the same day, where they were killed.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Then I had a, a sister.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And her name was Matla.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Martle, we called her.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "She was not married.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And she also perished the same day in Belzec.",
      "word_count": 9
    }
  ],
