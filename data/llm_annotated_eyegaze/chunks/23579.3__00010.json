{
  "stem": "23579.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "We are going always to him.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "He was five years when the war was finished.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Druck-- D-R-U-C-K-- Druck.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "We have another one, what he's in the head of Maimonodes.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "He was only 14 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "A gynecologist.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "We had a couple of these--",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] Jewelewicz.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Jewelewicz, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The leadership began already.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "You see, the three of them, there couldn't be three commanders.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "One has to be the commander.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So they decided-- in the villages like that, it's always like that.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The oldest brother, he is the head of the [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] was the head of the partisan from  the whole [NON-ENGLISH], from all over.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He was sent out from Moscow.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And he was the commander from all the partisan platoon.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "With Zus?",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I was with Zus as soon as I came to the forest.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "He told me that he likes me-- not he loves me, he likes me.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And he would like-- he would like I should stay with him.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "I said, I was thinking about it, for a minute.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I didn't think too, too much.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "I said yes, I will stay with you.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "But you have to promise me to take it out from the ghetto my father and mother.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "He said, then, then I will be with you.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And this took about three, four days.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "And I saw my father and mother in the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "After the six, seven days, the whole ghetto was-- liquidation of the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "Nobody went out already.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "And I decided to stay with Zus, because I promise him.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "But I didn't have the smallest-- I didn't-- I was not thinking that to stay with him, that's mean that I have to go with him to bed.",
      "word_count": 28
    }
  ],
