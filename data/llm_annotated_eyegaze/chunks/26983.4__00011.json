  "elapsed_s": 45.3,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And I took a special another pair of gloves because I thought about with my mother when she will need to go to work.",
      "word_count": 24
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And I managed to smuggle out another pair of gloves, next day, to give it to her.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "But I also remember that one elderly man went to SS man.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Now I have to tell you that nobody dared to speak or go near to SS man.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "It was even forbidden.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "You are not allowed, in Auschwitz, to go near to SS man.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "But he went to him and said, like, mister, can I have aspirin?",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I have headache.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "SS said, of course, my dear.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And he went and brought him aspirin.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "So it was a completely abnormal behavior of the SS towards us.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "Now we shall stop for a second.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "It's the end of the tape.",
      "word_count": 6
    }
  ],
