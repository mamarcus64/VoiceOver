{
  "stem": "10358.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "All the executions were in front of the synagogue, because we were told that this one was shot and all our other friends were shot in front of the synagogue, this big [NON-ENGLISH].",
      "word_count": 33
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And there was no food.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "And it was despair.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And it was hunger, was-- was horrendous.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "It was-- it's impossible to describe.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And we lived-- it was a day to day, an hour from hour, a day to day existence, [PAUSES FOR 3 SECONDS] and-- until started the third execution, the Final Solution.",
      "word_count": 31
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody worked.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Nobody worked.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "It was a different ghetto than other ghettos.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "We had-- we had rations.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "We were on line for just little, little food.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "But we were able to get-- my mother had friends, Ukrainian friends.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And somehow they were able to smuggle some food to my mother, but very little.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "They did it near a gate, because we were-- the ghetto had barbed wires.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "There was a gate.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "They came-- they came to the gate and they were able to [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I-- my husband will give you the information.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I just don't recall right now.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes, however long.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And then my husband-- at that time, he was my friend from school.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "We were friends.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And he was able to, at the last execution-- [PAUSES FOR 3 SECONDS] at the last execution, [PAUSES FOR 3 SECONDS] we heard shots.",
      "word_count": 24
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And then we knew that this is the Final Solution.",
      "word_count": 10
    }
  ],
