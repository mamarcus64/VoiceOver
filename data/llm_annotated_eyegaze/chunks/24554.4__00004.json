  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So I finished the war, what I say, in--",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In the brigade was Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And what I forgot in between, you know, to Czechoslovakia belonged the so-called Carpatho-Rusland.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "This was a part of Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And in this war time before, when the Russian did, they took away this Carpatho-Rus, you know, and took it in the forced labor camps.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And in '42-- no, [INAUDIBLE]-- yes, '42, they liberated them and they come in the Czechoslovak army.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "So there was a lot of, uh, Czechoslovak Ukraine, yes?",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Zakarpatska Ukraine they call it.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "So there was Czechs, Slovaks, and this.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And after-- I don't remember a bit.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "In Slovakia have the Slovak army.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And there was, uh, fight against the Russian.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "No, the same-- they run away and come to us, to the Czechoslovak army.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "So there was a lot of Slovaks too.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In Czech, everything in Czech.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Not in Slovak, all in Czech.",
      "word_count": 6
    }
  ],
