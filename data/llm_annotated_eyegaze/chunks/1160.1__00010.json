  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "They were put through an awful lot, and it was very terrible.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "But he did not want to talk more about it.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "He said it was just terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "I guess he couldn't talk.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I was just a teenager.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I don't know which year this was.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "I don't know which year this was.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "But I remember, in the synagogue, it was so empty.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "It was a very beautiful synagogue, beautiful, big.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And it really was a terrible, empty place on the high holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "Nothing, just a few rows on the front.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "Maybe two rows on the ladies' side.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "Upstairs were the ladies.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And downstairs maybe three rows of men.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "And the rest of it was empty, empty, empty.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "And hundreds of people were able to go in there before.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
