{
  "stem": "22889.7",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "I know where he-- I knew he lived in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "Because the last correspond we got from him was 1940.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "I have a letter from him, too, as a matter of fact, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "My mother wrote to him.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And my uncle kept the letter.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I have with the open up and the seal, the swastika, as far like that, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "So I knew I had an uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I want to find out how to get in touch with him.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "So I went to the book-- went to Muenchen.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "On the Siberstrasse was a Jewish Gemeinde down there, a Jewish congregation, on the Siberstrasse, in Germany, in Munich.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "So I looked at the book.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And I look, look for Mendler, Mendler.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And find-- and I see his name, Emil Mendler.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "I knew he live in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And I had another uncle of mine, too, my mother's cousin, Mendler, also.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "So I-- whoever I seen, I wrote them a letter.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Took the address, and I wrote to them.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Meantime, my uncle, from New York, he moved to Uniontown.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "He made money from Uniontown.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "He moved to Latrobe.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "But my other uncle, my mother's cousin-- I call him uncle-- he received a letter from me, too.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I wrote to everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "Even to my father's uncle, too, Reibeisen, too.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "He live in New York, I wrote to them, too.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "Because I took the addresses.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Whoever I could find, I wrote letters.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I told them who I was.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I survived.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I'm the only one so far.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I don't know, I'm searching for the rest of the family, whatever, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And I needed help from them.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I'd like to-- I didn't need financially help, but I needed help mentally and everything.",
      "word_count": 15
    }
  ],
