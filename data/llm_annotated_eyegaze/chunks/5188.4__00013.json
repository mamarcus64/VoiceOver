  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And I started to work at the Fashion Institute of Technology, where, eventually, I became a professor.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And then, I was in charge of the fashion design department.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Then I was a dean, until 1987.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "In '92-- between '87 and '92, I went back to teaching, but then I resigned and-- retired, actually, in 1992.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I went to college after my second child was born, when I decided that I wanted to be a teacher.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "So I went to Queens College in my 30s as a part-time student.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "It took me 10 years, but I got my B.A, before my children actually were ready for college.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And that was always my goal.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "I said, I must be out of school before they get into college.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "So I did that.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "Later on, I wrote two textbooks that are still being used.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "And I'm happy about that.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "And so I've made my contribution in fashion education.",
      "word_count": 9
    }
  ],
