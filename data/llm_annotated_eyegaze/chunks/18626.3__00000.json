{
  "stem": "18626.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It was giving out orders, everybody, every Jew from old to young, must enter the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "If they don't enter the ghetto by August 15, everybody is going to be shot.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It was-- [PAUSES FOR 3 SECONDS] microphones, loudspeakers, and a lot of paper was glued down all over on the telephone poles and houses.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It was all printed, you know, forms, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And every house glued on.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Every person's door.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And all the time constantly on the radios and they drove around with trucks, and big, you know, loudspeakers in every street.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "All Jews must-- must come by the 15, and report themselves, and enter the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And it was a lot of shootings, a lot of people were shot right away in different streets.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And right away the fear became big, and there was no way out.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't hide yourself, and you couldn't stay in your house.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "If you stayed in your house, a gentile neighbor would come in, right away and say, why don't you go to ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I'm calling the Germans, Lithuanians.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "The Lithuanians, if one wanted to hide himself in Kovno, on a side street, not to go in the ghetto, a Lithuanian neighbor would say right away, are you still here?",
      "word_count": 31
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It's already the 14th.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Tomorrow you've got to go.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Because he was waiting already the Jew to leave all the furniture.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Not everybody could take everything with them.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "There was no transportation to move, or to take things.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "So you took your valuables, clothes, soft things.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "But furniture, you hardly could drag it.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "Jewish people didn't have, you know, trucks or things like that.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "You had to hire, or you had to hire people with horses.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "So everybody left their homes, and they all entered, by the 15th, the ghetto.",
      "word_count": 14
    }
  ],
