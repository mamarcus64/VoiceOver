{
  "stem": "10446.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I had a feeling of not belonging in there.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I didn't want to see anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I had no desire to see any of my former classmates.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So we did not call anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "We stayed at a hotel for, for one night and went to the two cemeteries in, in Nuremberg and got out again and did the same thing several years later.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "There we went to-- first to several country cemeteries where our family had been buried in former years, going back to 1700.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And sadly, some of tombstones cannot be located anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "The inscription has been completely washed away and weathered.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And I'm still trying to identify some of them, get somebody to do it.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And we stayed-- again, we stayed for one night.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And, well one thing I must say, that one night was quite interesting.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Did Hella tell you about that?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "We-- the city of Nuremberg, like so many other German cities, invites its former Jewish citizens for a stay of 10 days to two weeks, whatever it may be.",
      "word_count": 29
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Most cities pay for the entire trip.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The city of Nuremberg just pays for the stay there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "The, the transportation is your own responsibility.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "You pay for the trip.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "But then they house you, feed you, even give you pocket money for 10 days and take you all over town.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "You get a reception by the mayor of Nuremberg, and they show you all the sights and are extremely friendly and try-- there's one woman in charge of these affairs.",
      "word_count": 30
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And she is a fabulous person.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And it so happened that our scheduled visit for the cemetery was-- coincided with the visit of the invitees.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] And we knew the program.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Hella would.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I, I don't.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I'm not sure when it was.",
      "word_count": 6
    }
  ],
