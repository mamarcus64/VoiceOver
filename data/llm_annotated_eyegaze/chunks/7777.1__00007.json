{
  "stem": "7777.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And they bombed the towns.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And a lot of people was running out from the towns.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "They went to the Russian border.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "There was a lot of people from all over, because it was the closest place to go to the border-- in the Russian.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "They have a big border with Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Well, the-- the-- till the 15th of the-- of September, the-- the German come in in our town.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "Just like the German come in into our town the first day, they took out seven Jews that was hiding in a basement, and they shot them.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "They said, they killed a German officer-- the Jews killed a German.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "It was not the truth, only-- In the 17th of September, the Russian come out and defend to Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "They said they want to help Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "While the meantime, they have an agreement with the German. when Molotov went with Ribbentrop, they make, in 1939, an agreement.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "The Russian, if they will go out in the-- against Poland, they will go to the Wisla-- to the Wisla.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "They will have Ukraine and Poland to the Wisla.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And the other part, but the Wisla will belong to the German.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "It's not too long-- a couple days-- the German was in our town.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Later, the German let the Russian come in.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "The Russian come in.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "Was the-- the town was already happy.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "The Russian come in.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "This was the-- [PAUSES FOR 4 SECONDS] this was the-- the 24th of September.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "The Russian come in in our town.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "Well, the people was happy.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "They was-- when the German was, everybody was afraid to go out.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "Only when the Russian come in, happy.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "They got-- we have freedom.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "We back to life for the-- for the people.",
      "word_count": 9
    }
  ],
