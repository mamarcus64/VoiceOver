  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And then I-- they threw a couple other pieces of cases at me, Plieger who was-- Hermann Goring Steelworks, which was a government-owned, biggest steel work in Germany.",
      "word_count": 28
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And I had a small participation, very small, not even official, in the Flick case.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Flick, if you bought a Mercedes Benz in the period 1950, 1960, you were buying one of Flick's products.",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Flick was a steel magnet and a Nazi before the war and was convicted separately in a different case.",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "There was a Flick case, but I had friends who were working on that and periodically I'd give them a hand on some aspect.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Adjourned.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Bathroom time.",
      "word_count": 2
    }
  ],
