{
  "stem": "428.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And from-- and we was there-- what was it?",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And we was there another two weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we went from Czechoslovakia with a-- with a train to-- from that place-- from that place, this was Slovakia, to Prague.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Prague-- Prague is a big city in Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And in Prague we-- we was there how long?",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Maybe two weeks.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And we smuggled into Bavaria, to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Also, everybody smuggled the borders.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And we came to Bavaria in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And in Germany, in that place, [PAUSES FOR 4 SECONDS] it was Jewish people came back and was formed a Jewish committee.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And the American people helped a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They sent-- oh, it was there UNRRA-- UNRRA, the Jewish organization UNRRA.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I lived in that place from 1942 till 1948-- no, 1940-- yeah, from 1943 already.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I was for five years in that place.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I-- I-- I remember the address.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I have a cousin in the United States by the name of [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "His mother and my mother, they were sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And right-- somehow I find out his address from the United States and I wrote to him a letter.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And he's-- and in between, I got-- in 1948-- 1948 or 1949-- 1948 I married my wife in Germany and he sent us papers.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "In 1949 I came to the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "From the time they took me out from the little town, Biecz, they didn't-- I didn't know what was going on with them and they didn't know what's going on with me.",
      "word_count": 32
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I know only when I run away from-- from that lumber, from that run away-- run away when they took me to push the bus.",
      "word_count": 25
    }
  ],
