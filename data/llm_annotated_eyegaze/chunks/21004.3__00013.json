{
  "stem": "21004.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "So they gave him five years.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I say, he in jail?",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "No, somehow he ran away.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "He ran away and he's not there.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But he got-- they gave him five years jail.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So I say, you want to give me a job like this?",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I should be responsible, because I know about the Russians.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "You have to be responsible.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "When they come, they check you out.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "They give you so much and so much.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "If you have too much, you didn't have time to steal to take it away.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "If you don't have enough-- if you have too much, you steal too much.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "You didn't have time to sell it or you have less, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "You-- so anyway, I say, I cannot work in a my job like this.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, later, we had-- we were going around to Lemberg.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We were going visiting, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And we gave some-- the family in the city, they needed money, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And later on, the money didn't got so much worth, because they make the rubles.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "The ruble-- they changed to the rubles.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "So-- but meanwhile, we had enough money to keep us-- to keep us busy with the money.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And so it happens, I say, I didn't want a job like this, I have to control.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "He said, let me tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "The other guy, he was a crook.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "He didn't help us.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "I'm-- I have a big job in the city.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "But I need also to live.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "From the government, what the government pays us, we cannot live with a family.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "You have a family, a wife and children, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "You cannot live with that.",
      "word_count": 5
    }
  ],
