    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And they was in Austria, in Lviv, Lviv, Lemberg.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "They was-- you know, I find when I was coming back, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And From Paris, where did you go?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "From Paris-- from Paris I was there, and I went to Italian from Paris, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
