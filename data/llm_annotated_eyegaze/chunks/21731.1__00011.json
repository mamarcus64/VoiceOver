{
  "stem": "21731.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And-- but I don't think it was more than 15, or perhaps 20 people.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It was really only family and friends-- the nearest friends.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And that was my wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "But before the wedding, I had a-- I got is-- an engagement-- engagement gift, or just as a gift, because money was no object there-- a wonderful pearl-- what do you call it?",
      "word_count": 33
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Necklace?",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "A necklace, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And I had that.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And somebody from the guests at the wedding, in the temple, came to me and took it off, because pearls are [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "You don't have it.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And my mother had a wonderful brooch.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I think it was the only jewelry she had.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "It was a butterfly, and the wings were made out of opals, or moonstones.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And again, the same person took that off my mother's dress and said opals are unlucky.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I still wear an opal ring.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And I have a very beautiful opal-- I don't know what you call it.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Not a brooch--",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "--but a-- no a--",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "A-- a pedant-- a very beautiful-- which I bought myself when-- while-- while I was in Australia.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And I think that is now-- my honeymoon began.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So.",
      "word_count": 1
    }
  ],
