  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And he told my father-- that was in July 1939-- that he is going with a contingent of 10 boys from Warsaw-- they're going to Warsaw, from Warsaw, they will go to Romania.",
      "word_count": 33
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And in Romania, they will get a ship which will take them to Palestine.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And of course my mother and my father was very disturbed.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My mother said, you are my only-- oldest son, you know, and without you, how will we manage?",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "My father was a little bit more far sighted, and he said, yes, I think this is the best thing to do, to leave.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So my brother left.",
      "word_count": 4
    }
  ],
