{
  "stem": "21817.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "And told him, you stay over here and tomorrow, you going to go home.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "Unfortunately, the next day we never went home, of course.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "One of his, brother or somebody who went over there to our house, and they they told him that the Gestapo came at night to look for, for, for my father.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "Since I was the oldest one, naturally my dad told him, you coming with me.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "And we stayed over night over there.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And the following day or two, we start walking away from Mlawa.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "And we walked for almost two weeks, mostly at daytime because at night it was against the law to, to, to see civilian on the streets.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "And once in a while, we used to get a ride from farmers who used go to the market.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "And the end of October or beginning of November, we got way east, close to the, to the Russian border.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "It was Poland, but it's the part which the Russian-- the Russian army took over.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "And we came over there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "And at night, at that time, we knew already that there's only one way you can go through the border illegally, it's at night.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "And I was already knocked out from walking so much, but I was a husky fellow.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "And we met the first Russian patrol.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "Nobody speaks Russians.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "I spoke to them Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "And somehow they understood me.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "And I tried to be the interpreter.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "And they spoke Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "But somehow we communicated with our hands.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "And we told him that we are Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "And they told them, go down over there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "So they kept us over there near the border, on the Russian side already.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "There were no German patrols close to the border.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "We saw them before but not at the border.",
      "word_count": 9
    }
  ],
