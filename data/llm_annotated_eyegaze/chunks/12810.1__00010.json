  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And they said in two weeks time you have to leave your home, your house, and you have to go to the-- that and that address.",
      "word_count": 26
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "You have one room with my-- with your family.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "So we went with my-- my mother's brother and his family.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "We went together in one little flat.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "After the March 19, when the Germans are coming.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Which shop?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was working there.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Nobody knows I am Jewish or not Jewish, nobody is asking me, Only when the Germans are coming.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Of course, we were listening to the radio, even if they take that radio away.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "But we have another radio and we're listening in night time.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Yes, you know.",
      "word_count": 3
    }
  ],
