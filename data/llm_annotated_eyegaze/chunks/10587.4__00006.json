  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I finally got to a place where they gave you a-- like it looked like a, a military canteen, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And they give you some soup, which [PAUSES FOR 5 SECONDS] something looked like [PAUSES FOR 4 SECONDS] used dishwater.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And and I sat down, finally.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I said, oh, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And I can sit down, at least.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So I sit down.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I started to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "This was in the evening-- soup.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And the guy next to me, he says, you know what they're serving tonight?",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "What kind of food it is?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I said no, but I'm very hungry.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He says, it's dog, dog meat.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "So that's lesson number one of survival.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "So I pushed it away.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And as soon as I pushed it away, he poured it in, in his dish.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "This is number one lesson of [PAUSES FOR 3 SECONDS] the survival of the fittest.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And so I was hungry again.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And I never got to eat at-- I don't know for how many days.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And whatever my father and I had, we sort of shared together.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And, and we-- my father always said, eat whatever you can.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "Because they may steal it from you, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "His experienced, probably, in, in, in Siberia taught him quite a few things that I was not cognizant of.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And so [PAUSES FOR 9 SECONDS] we went.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We-- next morning, we got up.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We got a piece of bread, and-- just a piece of bread.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I don't know if they gave us anything else.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And then they took us to work, so--",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "It looked like it's a-- it was a quarry we marched to.",
      "word_count": 12
    }
  ],
