  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And meanwhile, I-- you know, I tried to get out, and I--",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "There was a Jewish agency called [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And many of those people in the [NON-ENGLISH], the Jewish people, had left already.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And there were few people left who would help others if they needed help.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A cultural-- a cultural organization.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "In earlier years, they were something similar to, to, to a Jewish Y in America.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They had all kinds-- they had performances, and they had exhibitions.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "But then, in time, they couldn't have that anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So they just were there to help others, to help them in every way they could, to help them get out, and find them a country to go to.",
      "word_count": 29
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
