{
  "stem": "198.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "She got-- she was bleeding from her lungs.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "So I sort of got a hold of some medication, and I shared the food with her.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "We got a very small ration.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Like a little bit of black oil and a piece of bread.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "Whatever I could share I gave her.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "She should recover.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- [SIGHS] we got it some kind underground in the factory, the medication.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was everything underground.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I think the Italians helped us.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "My sister was about 15 at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When did it come to an end?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We were in this-- we were in concentration camp in Bad Kudowa in Saxon for nine months.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "After nine months, planes were flying over the camp dropping leaflets.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And they said, the war is over.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And we sort of saw that it's a panic.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "That the SS is running away.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So the Czechs partisans, and the Russian which worked with us in the concentration camp, they were war prisoners.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "They opened the camps, and they said, you are free now.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We were so confused.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we say, what's free?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Where do we go?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Where do we belong?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So everybody in Czechoslovakia, the people from the border towns took-- each family took in one or two people until we got on our feet.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Back to when the leaflets dropped.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, when the leaflets dropped, they said that the war is over.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They run away.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "It was overnight.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They-- they were guarding the camps, and we saw them running away.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "This was in Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "This was in Bad Kudowa.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And then the Czech partisan and the Russian partisan came, and they opened the camps.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And they said, you don't have to worry now.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "You are free.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And we saw the Germans.",
      "word_count": 5
    }
  ],
