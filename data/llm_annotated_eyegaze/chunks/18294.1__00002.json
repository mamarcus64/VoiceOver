{
  "stem": "18294.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the-- and her daughter was brought up mostly from my parents.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She was living all the time with us together.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My mother's sister.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Merle.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And she had, like, the cousin, which one she's not anymore alive.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She passed away.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And we was living all the time with her together.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And then I had-- my mother had another sister she called Malka, what she lived in Vilna too.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And she had a very big business-- [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "There's what they called.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And-- and she had two children.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And one from there was survivor with me together in all the concentration camp.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "We survived together.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "She's now in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "What I can tell from my home life-- we had a-- in compare from the time from Vilna and the poor-- there was so much poor people-- we had a very good home life because it doesn't matter how bad it could be at home.",
      "word_count": 45
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We children never felt.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "For us was everything.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Maybe my parents didn't have for themselves so much.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Just for us was always everything.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my mother kept a very kosher home.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "She was not religious, but she was very, very kosher.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And all the yontifs, she keep them, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And she was very particular in this part from tradition.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "yontif and Shabbat.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Only yontif.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Only yontif like Rosh Hashanah.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Not always.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Some things we had-- we invited them.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Not my mother didn't go to them because they wasn't kosher enough for her.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "She couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Pesach Seder-- we had-- we was with the family together.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Like she had two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She was the one which was a very good cook, my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So she invited them, and we had the yontif together.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] what she makes for Pesach.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This was very good.",
      "word_count": 4
    }
  ],
