{
  "stem": "21731.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Eva Schutz.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I spell Schutz, S-C-H-U-T-Z.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Bernstein.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "B-E-R-N-S-T-E-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name is Eva Schutz, S-C-H-U-T-Z.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Bernstein-- B-E-R-N-S-T-E-I-N.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had a pet name, Lala, which is, in Polish, Dolly-- in English-- Dolly-- sorry.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The 7th of April, 1909.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "87 and 1/2.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "It's-- I was born in Allach, near Munich, which is Bavaria, Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, now you know my name and my birth date.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I just want to apologize if I start stuttering or forget things and have to come back to it.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But my doctor would say it's old age related.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "My parents' name were Salomon and Rachel.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They came from the same family.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "My father was the youngest of 13 children.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS] My mother married her uncle, which made the relationships annoying-- how I am relating to various people very difficult-- because my grandmother is my aunt, and my father is my uncle.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "But never mind that.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "My family tree goes back, as far as I know, to 1640.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And they were all very famous rabbis.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "But the most famous was the Gaon of Vilna.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "The generation which I remember has three very famous people.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "One was the brother of my mother, Professor Jacob Parnus, a biochemist.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "The second, my cousin, Lewis Namier, later Sir Lewis Namier, an historian.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And the third was Ludwig Ehrlich, a international lawyer.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "So that is-- that was my family.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "My parents lived, for a very short time after my birth, in Allach.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "Then they moved to Vienna where my grandparents had two houses, after they sold their estate in Poland, which was then Austria, as a matter of fact.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "It was an estate near Lvov, called [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "I could not spell this, even now.",
      "word_count": 7
    }
  ],
