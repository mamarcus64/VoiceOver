{
  "stem": "21013.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And they said, would you like to come to England and wait for your visa to come through in England?",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I said yes, but I can't go to England.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He says, we'll arrange that.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And miraculously, they arranged overnight to get a visa to go to England and I flew in a Czech plane with Mr.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Jaretzki to London two days later.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My parents didn't want to let me go, because they thought he might be a white slaver.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And-- but they made inquiries at the Jewish [NON-ENGLISH], which is the cultural organization, a Jewish organization in Vienna.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they said, it's perfectly all right.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He is with the Joint Distribution Committee and your daughter is safe and very lucky to be able to go with him.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My parents donated money to him for the cause of helping other people in my plight or their plight.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And we didn't have to pay.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "This was a voluntary action on my parents' part, because at that time they had all the money that you would need.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And they bought me a ticket on the with an open departure, first class ticket on the from London to New York, with departure open.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So he took me to England.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We arrived in London.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And there was Miss Fellner who took me to Woburn House and made arrangements for me to live in a boarding house in London.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I'd like to stop right there and go back to that.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I wanted to find out a couple things.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "When you were in Austria, did you ever see any book burnings, anything like that?",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "That was very common.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "There were mountains of book piled in the courtyard right where I lived and they burnt books at major public places.",
      "word_count": 21
    }
  ],
