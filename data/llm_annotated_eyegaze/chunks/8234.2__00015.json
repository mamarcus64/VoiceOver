  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I was a happy go lucky young man.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I loved music, loved-- loved books, and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And they made an angry man of me full of vengeance.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I am still angry.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I am still bitter.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "It's hard to forget.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "Or some episodes just went out from my mind.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "That's what they changed me.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "From mine experience.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Be a mensch.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Have an education.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Try to be somebody.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Don't be a [YIDDISH].",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Be honest.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Truthful.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And then you'll survive happy.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "We finished, didn't we?",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "So how long was I?",
      "word_count": 5
    }
  ],
