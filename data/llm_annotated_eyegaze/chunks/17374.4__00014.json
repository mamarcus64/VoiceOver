  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "And he cames here, and I didn't, again, want to talk to him.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "He come to the kitchen, but he was so nice.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "He come with me to the kitchen, and he talk-- ask me a few question.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 24,
      "text": "It was documentary, [? made ?] [? him. ?] Well, [INAUDIBLE] start to talk, and I start to talk.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And my children was, why didn't you tell us?",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Why didn't you tell us?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Especially my grandchildren, [INAUDIBLE], [? and ?] some things I-- I want to just say finish, no more.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But it [? comes back. ?] And I'm talking too much now, am I?",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And so many things come to my mind.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what a message is.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "No, I really don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I-- I wish the world-- it won't be any more war.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "It won't be any more killing, that people will be good, because love is the main thing.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I attend yoga classes for 30 years.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And we are discussing, and we're talking, and live now, in that moment, and don't think about past, or present, or future.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Just live now.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I know all these things, but it didn't-- I cannot lie to myself, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Relaxation, meditation, no, I'm reading a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And I [INAUDIBLE] the tapes and with all this thing.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "I know so much.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I can advise people what to do, but if it comes to me, I-- I'm hopeless.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "I'm still nervous, and I'm still upset.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "I'm sad very much and get scared.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "It stays with me, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I really didn't talk to anybody so much as I talked to you.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
