{
  "stem": "1677.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 405.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And then I got married to Kurt Fischer, who was driving taxis who was a very brilliant painter and interior decorator from Shanghai.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "In Shanghai, he survived.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I met him here.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It was the love of my life.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And in 1954, we married.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "In 1956, my son was born.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And in 1958, my husband left me.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "The baby was two years old.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And I had a little children's wear shop in Kogarah.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And that was burgled on Cup Day, 1965.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And I couldn't carry on anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I got a very severe nervous breakdown.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Because that was then that I started to feel a failure.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "I never had that feeling before.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "I just thought it was part of emigration that you do many menial jobs and that you have no social connections.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I didn't need them.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "I got matriculation in one year at the Sydney University and went to the bloody Jewish Welfare Society, who helped me to come out and who were very kind to me.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Walter Brand-- Walter Brand was the president then.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And I said, Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "Brand, please let me study.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Help me with a scholarship.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And I pay it all back.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "I want to be a famous divorce lawyer.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "And I have one year recognized.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "Professor Anderson gave me credit of one year.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "That was a big thing.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And he said, you speak English, Kitty.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "You're going to work.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "We have to look after people who don't speak the language.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "And [PAUSES FOR 3 SECONDS] so I had recovered from the break down.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "Then, a lady offered to me-- I didn't, couldn't go back to the flat.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "It was too troublesome.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "Paulie was in boarding school because he couldn't be trusted to me anymore, according to my husband.",
      "word_count": 17
    }
  ],
