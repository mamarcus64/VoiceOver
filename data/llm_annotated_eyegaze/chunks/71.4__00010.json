{
  "stem": "71.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 40,
      "text": "And we did.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 41,
      "text": "We took a picture at the Kotel, and we-- we stayed in a nice hotel with them, and we visited every place we had to go.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 42,
      "text": "And we-- we went with them, the Masada, to Jerusalem, and then we went to the [?",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 43,
      "text": "Galileas. ?] We took a boat trip along the Jordan River.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 44,
      "text": "We went to--",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "This was-- Noah was 14.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "About-- I think '71. '71-- the time we went through was fairly strict, because in Italy at that time I think was the same year when-- when they bombarded-- something happened on the the-- on the airport in Italy.",
      "word_count": 39
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And it was this very, very-- they were very strict about it.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They had-- we had to open all the suitcases.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And-- so-- and Estelle went back quite a few times.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "She was in Israel maybe four or five times.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And Noah was back.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "When Noah graduated medical school, his wish, as Ben said-- Ben had a diamond ring, and he wanted that ring.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "He asked for that ring.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And Ben told him that when he will graduate.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And we asked him what kind of gift he would like to have for his graduation besides that.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And he said a trip to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And we did go to Israel that time.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "We stayed in the Dead Sea.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And he-- we-- and he even went-- he even went scuba diving in the-- in [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "He's in internal medicine.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But he specializes also in diabetes and-- and pulmonary.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He's very, very knowledgeable in pulmonary.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He's a very-- he's a very honest-- he's a good, honest human being.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So is Estelle.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Estelle you don't have to ask Estelle.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Estelle offers.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Estelle is now very active in the Sinai Temple.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "With three little children, it's not easy.",
      "word_count": 7
    }
  ],
