  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And 1947, [PAUSES FOR 5 SECONDS] from the union [? funded, ?] [? albeit ?] the union [? funded, ?] Jewish union started to come to select from the Bund.",
      "word_count": 30
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "That's a left-- left-- left organization.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Working people wasn't existent before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And then the-- the-- the chairman of the-- of the needle-- needle trade in New York.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I-- I know-- I know-- I know two brothers and a sister.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They used to live in Feldafing.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "Also, this was a-- after the liberation, this was a big, big camp.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And Jewish-- he went over there, and they-- they selected.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "They selected their people.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I met him.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I met the-- the-- the two brothers and-- and-- and a sister in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "What was his name?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "What is his name?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "What was his name?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And also the-- the Orthodox, the Orthodox rabbis started to come [? outside ?] the camps.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Bergen-Belsen.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Camps.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "A lot of camps.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And they-- they also started to-- to look for Jews that wanted to go back to-- to Judaism.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And that was-- that time, this house started the-- the-- the Orthodox movement.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The young-- they-- they brought out mostly Hungarian, mostly Hungarian Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know nothing about Jewishness.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "In Germany-- I came to the United States in 1949.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Truman brought me over here.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "You know, the-- there was an affidavit for-- I had-- my affidavit was for Atlanta, Georgia.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But somehow-- you see, I remind myself about my brother, what kind of profession he had.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "A [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We came to Atlanta, Georgia.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "It was hot, and I-- I-- I went-- went to work in a-- in a factory.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Outside, must have been in the 80s like in Atlanta, Georgia.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Inside no air condition.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "They put me to a steam machine.",
      "word_count": 7
    }
  ],
