{
  "stem": "23131.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Already what my brother did.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Because my father supported the Tarbut.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "He was the one on the committee.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "He was the one that-- kids that could not afford, or didn't have any, let's say, any book, or any notes to-- notebook to buy-- it was everything from my father's hands.",
      "word_count": 32
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Whoever had to be married, whoever died and didn't have for the funeral, [INAUDIBLE] whoever had to get married and didn't have a penny for a wedding.",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "My mother used to buy all-- all the colors, the trousseaus, and then when a child was born, she had to make the bris.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "You know, she was-- we-- anybody that lived in that shtetl knew that, if they needed something, he was like the father of the-- of the shtetl.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "He was always a-- a Kehillah.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He was always in-- in all the committees, you know, took part.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He was a member of the shul.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The holidays, were always-- we always had company.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We always had people coming to us.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Friday especially, was a very hard day, because, you know, usually he paid them always matzah shabbas-- the-- the-- whatever the pay belonged to them.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "But people, they did not have money to make shabbas.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "He-- they used to come and he paid them Friday, to buy a piece of challah, to buy this, or to buy chicken.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish traditional house.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't very, extremely, extremely Hasidic, but it was a traditional household.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The-- I didn't like the holidays, because I-- I didn't like the food of the holidays.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was a very poor eater.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So-- but the holidays, my mother forced me for the chicken soup, with the [INAUDIBLE], with all that.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "This was the biggest tragedy.",
      "word_count": 5
    }
  ],
