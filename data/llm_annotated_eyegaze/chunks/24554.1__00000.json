{
  "stem": "24554.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Albert Tausinger.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My parents--",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Spell?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "T-A-U-S-I-N-G-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "29 July, 1912.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Now I am nearly 85.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in-- now it called is [?",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Lodno-- ?] in Transylvania.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "It was the Austro-Hungarian monarchy.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I am the youngest from seven.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I have two-- four brothers and two sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Now I am the last one alive.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father works in timber-- the timber industry.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So he ran around all the Austro-Hungarian monarchy.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It happens that from the seven children after 1918, the war-- end of the first war, we are born in five different countries.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Now, my parents never have been abroad-- always in Austro-Hungarian monarchy.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In 1918, the Austro-Hungarian monarchy split, and it was five independent countries.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was the Czechoslovakia, Austria, Hungarian, Rumania, Poland, and Prussia.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So we are all born around-- around-- only in Austro-Hungarian monarchy.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My parents never ever was abroad.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "They never had a passport.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Went together.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Went together up-- up to 1914.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "In 1914, when broke out the war, we evacuated back inland to Hungary-- to the north Hungary.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "After [? 18th, ?] it was Czechoslovakia.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We brought [? up ?] back except two brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The one brother was in-- Walter was in the army, in the First World War.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And in 1918, we have been in Czechoslovak.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "The border was Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Now, origin, my father-- what I heard.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I don't have documents.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They come from Spain.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "They are Sephardins.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "My mother, she comes from Galicia.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "She was a ultra Orthodox Jewish-- a kohanim.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "So in the family about the religion was a little bit difficult.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "The mother was strong religious.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "The father and the boys wasn't.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "I had my bar mitzvah [? though ?] I wasn't religious.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They met when my father works in Galicia by the timber.",
      "word_count": 11
    }
  ],
