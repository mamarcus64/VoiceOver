{
  "stem": "4513.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And then, when he closed his little tailor shop, he was a chauffeur for a very wealthy family, the Lilly family, which is still around-- Lilly Pharmaceuticals.",
      "word_count": 27
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And he was also a banker, someone who's pressing one of the banks in Boston-- he was-- I mean, Indianapolis.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "He was a chauffeur for them.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And so he used to take me with him when I was old enough, and we'd cut-- and I would cut the grass and I would help him cut the grass at these various places.",
      "word_count": 35
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My mother, at that time, was just beginning her work as a social worker when I was little.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And she was working at the welfare office where-- you know, the welfare office in those days was different than it is now.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "What they did mostly was they provided the clothing for people who couldn't afford the clothing during the Depression.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So she was working at the place where they gave out the clothing for people to-- for the people who couldn't afford to buy clothing.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "My family-- there was one person across the street from us, a woman who was a teacher in the public school, Mrs.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Washington, who my mother talked to periodically.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But we had very few people who came to our house to visit and things of that sort.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "We were sort of the outside group, so there were very few-- there were very few relationships on a personal basis between my-- my uncles, my-- my mother's brothers-- two brothers-- and her sister all moved to Indianapolis.",
      "word_count": 38
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And my father's brothers and sisters, several of his brothers and sisters, moved to Indianapolis.",
      "word_count": 15
    }
  ],
