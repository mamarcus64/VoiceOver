{
  "stem": "25651.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "And there were two little girls playing on a swing.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So I go and knock on the-- I asked the gardener, is this the house of Dr. so-and-so?",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I forgot the name throughout the time.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I'll tell you how I discovered the name.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, I asked, is Dr.-- now I know it's Dr.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Heller.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Is Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Heller at home?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Obviously, I knew it then.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So she says, no, I'm Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Heller.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "You can give it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I have to give it to Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Heller personally.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "So she smiled.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And she actually had it-- as she came to open the door, she had a tray with Ribena.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You know that sort of-- Blackcurrant.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Blackcurrant juice, you know, for the girls in the garden.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And it was so hot.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I had ran up, up this hill to where the villa was.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "The villa isn't there anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "The Czechs destroyed it.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So she says, would you like something to drink?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "You know, I must have looked at the-- [LAUGHS] at the drink.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "So she gets a third glass.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "There was enough there.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "She said, take it in the garden.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "You can have a drink with them.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So I took it to these-- these little girls.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And we all had this Ribena juice, blackcurrant juice.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And then, we swung on the swing.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And I swung a bit.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And these little girls were too little to swing.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "You know, a child has-- you know how you have to learn to swing?",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "You have to tuck in under.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And you couldn't even teach them.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "I mean, they were little squirts of kids.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "One was two or something.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And the other one was-- one was just a baby.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "She hardly walked.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "So you had to swing them.",
      "word_count": 6
    }
  ],
