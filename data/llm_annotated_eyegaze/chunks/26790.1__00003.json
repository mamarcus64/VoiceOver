{
  "stem": "26790.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Because it's not a special place where you can-- you can afford to play, on the road, on the road.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "It was very bad condition.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My older brother, when he was-- when my father died, he was 13 years or 14 years old.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And after a year or so, he become a-- a tailor.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The same thing was happened with my younger brother.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "The same thing happened with me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "The same thing happened with my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "The same thing happened with my youngest brother, the youngest one-- he-- he was only a few months old when my father died.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "For sure, for sure we were close.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We were sleeping in one bed.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Four children- three children were sleeping in one bed.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No, not much.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I have an uncle only in Australia, and one uncle who used to be in Russia, and one uncle who used to live in Warsaw, the capital city of Poland.",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "This is my mother's brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "My mother's brothers-- my mother-- my mother's sister was living in Australia.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "My mother's brother was living in Russia, because he was-- he was in [NON-ENGLISH] in the Russian army.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And he was shot, he was wounded.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "He was stopped in Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "He was living in Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "He didn't come back to Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And both brothers were living in Poland, [? in Warsaw ?].",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We never get in touch with Polish people, because we never get in touch.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You see, we always get in touch, one Yiddish people altogether.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "If we have Yiddish shops, Yiddish tailors, Yiddish shoemakers.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We never have, we never have to deal, like with the Polish people, not much, not much.",
      "word_count": 17
    }
  ],
