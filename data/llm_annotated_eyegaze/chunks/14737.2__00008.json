{
  "stem": "14737.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Many students took the train and went back home and packed up themselves, were going to study in Hungary.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "If something will happen there-- I mean, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "But now, we still are in the studenteneheim, in the dormitory.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Most of the students are there.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And the [INAUDIBLE] still exist, bigger and bigger lines every day.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Come the second day, everyone starts to think what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "So in my case, I said to myself the following, I want to emigrate.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I want to get out from here somewhere, but I'm not going to go to back to Hungary.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Because I want to go either to Palestine, either to United States, or anyplace else where I can go.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I had with me already some sort of a passport.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And this passport I received before, about two months ago, that I want to go for a summer, for vacation to France, to study French language.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "This was during the transit between the protectorate and still was Czechoslovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Now, a Czech passport, but it said only to go to France, not to other states.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "But at least it was a passport.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And I was trying to work out was immigration, starting to go to offices.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I went to Prague.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "In the meantime, I received also an affidavit from America, from the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "I had some family.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "I was tutoring their children when I still was going to the gymnasium in [INAUDIBLE] by the name Neufeld.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "And they lived here.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "I wrote to them, begged them already, [? going come ?] for a year or two.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "I didn't realize they were not citizens, so they couldn't send me an affidavit.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "But somehow, they did manage.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "They asked an insurance man by the name of Shubert.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "And he did send me an affidavit.",
      "word_count": 7
    }
  ],
