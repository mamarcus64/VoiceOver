  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "The same story again.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "Salida was exit permit to leave Spain.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "The consul couldn't do anything for me.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "The ambassador couldn't do anything.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "No, these people were all stuck in Madrid.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "Thousands of them.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Salgado took me to the perfecteur.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Over there it's a different name.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And we all, the whole family, and all my friends, hundreds of them, they all got salidas.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He never took one cent.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I met him after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He never took one cent.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We all got a salida.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So when we left for Vigo, first my brother-in-law and Berta and the two boys with my mother left for Portugal to go on a boat called [?",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Niessa ?].",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And they went to Suriname.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "That boat went to Brazil, but they were transferred on the water to go to [PAUSES FOR 3 SECONDS] Suriname.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "We left with my father.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We left for Vigo, which is Spain, for a boat called We left for Jamaica because with a salida means that we're going to a neutral country.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Jamaica wasn't neutral.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Was English.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "The one that was left there-- oh yes, Anna and Issac and Paulette went to Portugal with a Canadian visa, which they got in Madrid or in Portugal, I'm not sure about it.",
      "word_count": 33
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "So we were spread all over the world.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "My brother, after we were on our way to Jamaica, he left for Portugal.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And from Portugal to Israel, because he couldn't serve in the army.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "He really had one leg shorter than the other.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "We arrived in Jamaica, and my father was in Jamaica.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "He wanted to go to Curacao.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "My mother was in Suriname.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "So I immediately start working towards this.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "The first thing I did, I volunteered for the army.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "The Dutch doctor's name was Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "[INAUDIBLE], a Jewish man.",
      "word_count": 4
    }
  ],
