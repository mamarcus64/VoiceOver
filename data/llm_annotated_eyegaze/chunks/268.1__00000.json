{
  "stem": "268.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Henry Rosmarin.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "R-O-S-M-A-R-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "At birth it was Henryk, H-E-N-R-Y-K Rozmaryn, R-O-S-M-A-R-Y-- I'm sorry, English spelling.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Polish spelling, R-O-Z-M-A-R-Y-N, Rozmaryn.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "October 7th, 1925.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My present age is 73.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a little town called Czeladz, in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It's southwestern corner of Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I spell it for you, C-- capital C-Z-E-L-A-D-Z.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The nearest town was Bedzin, Sosnowiec.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And towards the German border was Katowice and Siemianowice.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Incidentally, it was in Siemianowice that I lived.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Actually, I was an infant.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mom told me she went to Czeladz because my father-- my-- my fraternal grandparents lived in Czeladz.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And so this was before hospital births, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "This was birth by a midwife, of course.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So she went to Czeladz, which was, like, three kilometers, and gave birth-- birth [INAUDIBLE] to yours truly.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And then she went back when I was probably two weeks old, back to Siemianowice, where I lived until-- for the next few years, of course.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Abraham.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Abraham in Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Helena, Helen.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I had one brother, an older brother.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "His name was Max, Maximilian.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Later on, shortly before the outbreak of World War II, my father's uncle lived with us for a short while.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "His name was-- he was the youngest of my father's brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "His name is Benjamin, which was a proper name for the youngest-- for the youngest son, even in biblical times.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Earliest memories?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Childhood, of course-- a happy childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I guess this-- this is true with most of us.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "One would say, oh, I had a happy childhood, you know and-- but a carefree childhood, a loving environment, comfortable home.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Parents who cared and showered me with attention-- not only me, both of us, my brother and I.",
      "word_count": 18
    }
  ],
