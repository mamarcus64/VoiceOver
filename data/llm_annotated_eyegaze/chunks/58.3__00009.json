{
  "stem": "58.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "This were all-- a lot of people for my city, you know, they were in the bakery business.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And they survived for a while, they worked with the Germans, and-- and-- the minute we came to the first station, we knew we were going Treblinka.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Because we knew the roads.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "If you go east, you were going to Auschwitz, or to that other camp.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "If you went west, you went to Treblinka.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And we recognized the station, that we're going, the way to Treblinka.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Now, everybody start panicking.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was in panic, and the-- the-- we were traveling, it was a hot day in April.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And we used to-- some people had some money, so they give a bottle to the Polish people at the station to give them some water, and they threw away the bottle.",
      "word_count": 32
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They said, you don't need any water, you're going to your death, anyway.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "They used to make this was-- used to be the sign, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we traveled the whole day.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "People were getting off their mind.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "My cousin, Madeline, she's right in the picture there, cried to her father, I want to live.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And her father called out, [NON-ENGLISH], you know?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He was out of his mind.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "One person stuck his head out the window, he was shot through the throat.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He was lying and moaning on the-- on the floor.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "People didn't even notice, they didn't pay attention even, to it.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Well we stayed, we came into-- we travelled the whole day, we came in like at dusk, we cam in to-- to Treblinka.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "We came into Treblinka.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] The whole train couldn't go in, they had-- had two rails.",
      "word_count": 15
    }
  ],
