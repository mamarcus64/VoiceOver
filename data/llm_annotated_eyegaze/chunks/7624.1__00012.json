  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "Well, he was arrested and sent to the [? hole. ?] In about eight or 10 months later, an SS officer came to my aunt's house with a little box and said, here's your husband.",
      "word_count": 35
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "So it was already 1938, we know what they're doing in the, in the concentration camps.",
      "word_count": 16
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "So we were worried about--",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "So we-- we were worried about it.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "So meantime, the telegrams-- no answers.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "The-- our hopes start to go way down, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "So the-- our captain said, I will cruise around the Strait of Florida.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Maybe somebody will hear us and will let us out.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "So we flew-- we flew-- the boat went close to the Florida Strait.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And I found out afterward the captain wanted us to come down here to Miami.",
      "word_count": 15
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "Let's stop at that point.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "OK?",
      "word_count": 1
    }
  ],
