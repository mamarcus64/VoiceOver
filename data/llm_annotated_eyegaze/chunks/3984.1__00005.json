    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But he was young, and he was little one, short one, and very little one.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So he looked like-- like a child.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And Hannah was with us.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And Hannah-- my mother was spoking only with Hannah, because she was the biggest.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And she thought, she don't know what to do with the children.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "She's afraid that something is a very bad situation is going.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So what I want to tell you what happens, that we have a very nice family-- an old family.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "A-- a old woman and man is across on the street, says they love us very much.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
