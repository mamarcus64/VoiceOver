    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "In-- yeah-- yeah-- I-- I-- jump, because in '43-- I don't remember exactly when.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "They took my-- my brother, Yeshi.",
