      "text": "They took away.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "David stay us-- with us, because he was-- he was look like very young.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "He was very young.",
