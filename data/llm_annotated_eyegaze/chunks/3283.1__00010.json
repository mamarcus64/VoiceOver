  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "She said, anybody want a sandwich?",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And it so happened that my friends and I, we had lunch.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "But they gave her this lunch [INAUDIBLE], and she was handing it out.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "She looked like an angel to me.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And [PAUSES FOR 3 SECONDS] then nothing happened.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "We got to New York.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "I went back home.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "My friends went home.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And this lady I thought I'd never see again.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "But it so happened-- and this, again, is fate-- a month or two later, I decided to move my family.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "See, I was supporting my family by that time.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "My father was retired.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "My mother was retired.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "My sister, well, she was sort of semi-retired.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 20,
      "text": "My brother, he was traveling all away to California, and so on.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So I had a cousin who was a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Smith, my mother's nephew.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And he had an office on Eastern Parkway and Franklin Avenue.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "So I decided to move my family in that area.",
      "word_count": 10
    }
  ],
