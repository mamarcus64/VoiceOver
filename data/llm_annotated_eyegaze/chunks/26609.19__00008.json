{
  "stem": "26609.19",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "It wasn't another name not like mine, not Frida, not [?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "Junia. ?] So why do you say it's your daughter?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "Oh, he acted like this.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "Or he did it because he wanted the child or he didn't remember.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "So they said, it's not your child.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "Then they asked me, what was the name of a woman and her children that your child stayed with during the Germans' occupation?",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "I said, eh, [?",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "Glenbotske. ?] And the children, she played with their children-- [?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "Christina ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "Vladik ?] or what it was their name.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They ask her.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And she said, yes, [?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Glenbotske. ?] Yes, [?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Christina. ?] Because she lived for a few years with them until the liberation.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So they said, it's not your child.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "It's not your wife.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "You can't do anything about a marriage.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Because if you say it again, they say that you're stupid.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She didn't come to marry here.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And she doesn't look for a husband.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "She want only her child.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The child is not yours.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And you won't get her.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So he said, but I know it's my child.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They said, you can say as many times as you want.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The child recognize the mother.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And the mother recognize the child.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They said, what we can do, we can give you how much do you want-- money?",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You want to go to United States, or to Israel?",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We know you want to.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "He said, I don't want money.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "I want my child.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "They didn't listen to him, gave him I don't know how much then.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But he didn't take the money.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Next day, he jumped from second floor-- want to commit suicide.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But he was alive.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Nothing happened to him.",
      "word_count": 4
    }
  ],
