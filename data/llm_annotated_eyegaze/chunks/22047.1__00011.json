  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And so I'm a-- a member of the board of trustees of that church, and we got to talking about how we should-- should fix those doors, because they're-- they're very valuable and very beautiful.",
      "word_count": 35
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "They have tile insets, little pieces of tile that tell a story, on these doors.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They're gorgeous.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And so I volunteered to figure out how to-- what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So I went to one of our local paint stores, and they turned one of their consultants over to me, and he came and looked at the door, and he said, well, this is what you need to do.",
      "word_count": 39
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Clean the doors, prime them, use some elastomeric paint on them that-- that will fill the cracks, and they won't-- they'll give with the weather, the heat and the-- the cold, and they won't re-crack.",
      "word_count": 35
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
