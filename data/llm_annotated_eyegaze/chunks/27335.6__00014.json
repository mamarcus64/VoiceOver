  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "He was-- he was about my-- about my height, but he was thinner.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And he was-- he was dressed in-- in a partisan uniform, the same kind of uniform that I saw on those boys that I-- I met in the-- in the [NON-ENGLISH] prison.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So he pretended that he-- he's a-- he's a partisan prisoner.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "But after the third question, the penny dropped.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Because finally, he asked me that-- if I could give him-- that he was also-- was also captured so and so as a-- as a partisan coming back from-- from the Soviet Union.",
      "word_count": 33
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And then, his time is over now.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "He said, they didn't strike me right away.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They-- they don't let the all kind of people to go.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But anyway-- anyway, I-- I didn't catch on right away.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But that-- that was-- that was another question.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And the third question is he's-- he's released.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "He-- he-- he's going to be free in two-- two days from now.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And he-- he is from-- from Transylvania.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but don't--",
      "word_count": 3
    }
  ],
