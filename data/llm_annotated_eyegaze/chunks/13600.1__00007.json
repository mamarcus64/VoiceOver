{
  "stem": "13600.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 2,
      "text": "Insecure, can I say so?",
      "word_count": 5
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] To meet a payment was always a problem.",
      "word_count": 12
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, of course I was aware, of course.",
      "word_count": 8
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't afford anything.",
      "word_count": 4
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 2,
      "text": "An item of new clothes was always an event.",
      "word_count": 9
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "Not particularly, no.",
      "word_count": 3
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 1,
      "text": "My mother had a brother who lived in Opoczno, as I said.",
      "word_count": 12
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 2,
      "text": "And he was very well-off.",
      "word_count": 5
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 3,
      "text": "And he used, from time to time, Opoczno to help us.",
      "word_count": 11
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Occasionally, yes, would send money.",
      "word_count": 5
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Not every-- that's not every day.",
      "word_count": 6
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Till the age of 12.",
      "word_count": 5
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "I was sent to Warsaw to-- for exam.",
      "word_count": 8
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "Different to what you see today-- the exam was that the principal called you in.",
      "word_count": 15
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 1,
      "text": "And he said, well, what do you know about this item or that item, he asked.",
      "word_count": 16
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 2,
      "text": "And if he liked, if you answered very satisfactory, it means [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 3,
      "text": "And I was at the 12-year-- I was then 12 years old.",
      "word_count": 12
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 4,
      "text": "That was in 1935.",
      "word_count": 4
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 5,
      "text": "And I won't-- it sounds a bit boasting, but was a very gifted.",
      "word_count": 13
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "They decided I was--",
      "word_count": 4
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and I went to yeshiva in Warsaw then.",
      "word_count": 9
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 0,
      "text": "Yes, mesivta.",
      "word_count": 2
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 0,
      "text": "No, mesivta, just mesivta.",
      "word_count": 4
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "Mesivta is Aramiac for yeshiva.",
      "word_count": 5
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in Warsaw, yes, very much so-- even in Poland, not just in Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "I would say in the, in the hundreds.",
      "word_count": 8
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 1,
      "text": "This was, by the way, located in a place where the Warsaw Uprising, the last, in 1943, was in this street.",
      "word_count": 21
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto uprising-- the ghetto was much larger, because there were half a million Jews at that time in the ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 1,
      "text": "But this was the last stand.",
      "word_count": 6
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "At the place-- not-- the street.",
      "word_count": 6
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "That place was-- the Germans employed there-- I think brush, they manufactured brushes there, I think.",
      "word_count": 16
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 1,
      "text": "I'm not sure.",
      "word_count": 3
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, this was the place where the Jewish proletariat, can I say so?",
      "word_count": 13
    }
  ],
