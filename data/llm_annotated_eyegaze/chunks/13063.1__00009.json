{
  "stem": "13063.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "When I was nine years old, I joined a-- an organization in Cracow, a Zionist organization.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It was called Akiba, A-K-I-B-A.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Yes, Akiba.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "This was a secular organization.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "It was not a-- not left and not right.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "It was a center-mind-- center-oriented org-- Zionist organization.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And there I was exposed to the [PAUSES FOR 3 SECONDS] atmosphere, the knowledge, and the history of Zionism.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No, but there were-- there were-- listen, there were very few non-religious Jews in Cracow.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It was definitely a minority of non-religious Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So whoever belonged there must have been at least traditional.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they encouraged it.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They encouraged it.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "It was-- it was-- for them, it was educational.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Educational, not political.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Educational.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "They wanted me to be exposed to the aspects of Zionist life and of Eretz Yisrael life.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "To Eretz Yisrael?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "There was no role model in Cracow of going to Eretz Yisrael.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "You see, there was nobody who urged someone to go or who served as a role model by going himself or herself to Israel-- to Eretz Yisrael, at that time.",
      "word_count": 30
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So it was a-- like a-- a dream, an aspiration, perhaps, a feature of life, but not something practical to-- for one to work or to strive to be-- to emigrate and go to Eretz Yisrael.",
      "word_count": 36
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "This-- this was not on the agenda at that time.",
      "word_count": 10
    }
  ],
