{
  "stem": "17301.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "And this went on for a long, long time, I mean, many days.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Very, very closely, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "There was a guard in front of each door, every single time.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "When we were in-- in Brzezinka, we saw people, transports coming in, and they were walking.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Because they were walking toward the-- toward the gas chamber.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We were seeing people going in, never coming out.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The stench was absolutely horrible.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Because you smelled the burning flesh day and night, all the time.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "There was one transport that was-- it stands out in my mind that hurts me very much.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "There were old people walking toward the gas chamber.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And I happened to go at that time, I happened to go for water.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They-- I was selected to go for water.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And I went for water.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And this old lady was crying, water, water.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And I was about to turn around and give her some water, when the SS man came over to me and he slapped my face so hard.",
      "word_count": 27
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Then I thought I wasn't gonna have a tooth left in my mouth.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "And I-- I did not grant her last wish.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "That was very hurtful for me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "I-- I-- it was hurting me very much.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "There were a lot of things happened.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "I was very sick at one time.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "I had a very high temperature.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And they had an infirmary-- infirmary in the building, within our building.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "And they took me there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "And I know my temperature was very, very high.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "And I know a lot of girls that went into that infirmary before, and I never saw them again.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "They took 'em away, and I never, ever saw them again.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So what I did one day, and I was there like for three days, they gave me the thermometer.",
      "word_count": 19
    }
  ],
