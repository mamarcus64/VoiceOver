  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "My daughter, my oldest daughter, 35, is married and has been married for 11 years to a wonderful young man.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And they are both very intelligent, and very productive people, and I'm very, very proud of them.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "My Cynthia, my 33-year-old, is also a career woman, and very successful, and just got engaged, and is going to be married next summer.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And my baby, my son, who is 29, was just married, god, a week and a half ago.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Almost-- it'll be two weeks on Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "They are all going to be here today.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    }
  ],
