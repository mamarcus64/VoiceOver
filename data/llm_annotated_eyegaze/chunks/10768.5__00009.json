{
  "stem": "10768.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "So he saw her, and he asked her does she want to come to us, to Bad Gastein?",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "Does she want that we are already in contact with some relatives that we found.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I knew the address, and we, we wrote to our relatives, to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "They send us papers.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "So she said, I don't care to go to the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I will remain here, and from here, I'm going to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And she is still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "This is Rachel, who was with me in Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Thanks to her-- she was feeding me with a little bit of milk, with a little bit of water.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Otherwise I would have died there without medication, in that [NON-ENGLISH] in the Muslim-- I told you.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "So anyhow, she's alive.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And she has a beautiful family.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And they're very active, and they are patriots of Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "So Rachel didn't want to, to go with us.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We received the papers through, through-- my uncle wrote to an American soldier.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The soldier gave it to us, because the post office was not even established.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Leo also, with his family that was in the United States-- his father's two sisters were in the United States.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my mother's two, two, two brothers and a sister were in United States from 1914, from before the first, during the First World War.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "So they immediately wrote to the soldiers-- soldiers, this is how we-- they send us papers.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I registered for the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And Leo-- and then we got married, so he had papers to his relative.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I and my brothers had papers to my relatives.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And this was 1946.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We went through all the preliminary interrogations, through FBI, through CIA.",
      "word_count": 11
    }
  ],
