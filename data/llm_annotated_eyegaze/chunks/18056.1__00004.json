{
  "stem": "18056.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, my-- my grandparents, of course, were religious.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Their children, lets say like my father, was not very religious.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "The reason he went to Palestine was not because he-- he did it for religious reasons.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He did it because he wanted to see a-- a future.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He saw a future.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He saw a different life and-- and more freedom than what we could see that's going to happen in Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I went to synagogue maybe once every three-- two weeks, three weeks just to carry the tallit for my grandfather.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "That I can remember.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I would go there and stay maybe an hour.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And then I would skip-- skip out of there and run home.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Not so much that you would say it was a real religious dietary that we would be very, very strict about it.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My mother was not so strict about it, and my father certainly not so.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But we had to do it, because we had to-- our grandparents would always come to eat.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And they wanted to make sure that we have sort of a kosher house, so we had half and half.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The bar mitzvahs in Poland were different than here.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Here, you make a big party and all this, and you invite guests.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Over there, it was just-- it's called a Kiddush.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was on the Saturday, after the-- the prayers.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They had a drink of vodka or whatever, and a piece of cake, and that was it.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "This was what they called the bar mitzvah at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I'm sure that maybe some people made a little bigger party than I had.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "But this is all I can say happened on my bar mitzvah day.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "13.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "As a child?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
