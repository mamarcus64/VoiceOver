{
  "stem": "22004.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We used to go-- we got workers.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "We used to work and make a lot of shoes for-- for stores.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And this-- the salesmen used to send us the orders.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And-- this was before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And then-- and we got-- we-- the businesses started getting bigger.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And we used to send for the shoes-- when the-- other towns, and the other cities.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And then when the war broke out, we-- we-- the-- the last day when the war broke out, this was in-- in September the 1st.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "It was broke out the war.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And the same day, we sent away a lot of shoes-- about-- about 1,000 pair of shoes in the-- in different areas.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My mother was with-- they-- we-- we didn't have in that time before the war, we didn't have refrigerators.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have-- we didn't have toilets in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have water in the house.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I had to go far away to-- to bring water.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And they had to make fire.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And, you know, it was not stoves to build up the ovens with bricks.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "If they built up a stove, they have to make fire from wood.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And so it was a hard life with cooking-- with-- with running the house for the children-- for the household.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And-- [PAUSES FOR 3 SECONDS] the-- [PAUSES FOR 3 SECONDS] And the-- the-- my father used to go-- he was a little bit religious.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "He used to go every morning in the temple to pray.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And then-- and then this was the life.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "It was a hard life.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Avrum-- Abraham.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Fejga.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name is Feja is F-E-J-G-A.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Fejga.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And Avrum was A-V-R-U-M.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Brothers?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "My older brother was Berl.",
      "word_count": 5
    }
  ],
