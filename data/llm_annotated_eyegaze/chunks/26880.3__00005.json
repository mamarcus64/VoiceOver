    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] And he brought back a Sefer Torah.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "[INAUDIBLE] [SOBBING] The same Sefer Torah that I had in [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And the Sefer Torah, I will save him until I brought to Cleveland Ohio.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And it was there this was right to buy me a house for the Sefer Torah.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My uncle came, and he said Mendel, Rabbi Cohen wants to buy the Sefer Torah.",
