      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I went to get my drink.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Came one man, and he saw me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he asked me, are you a Jew?",
