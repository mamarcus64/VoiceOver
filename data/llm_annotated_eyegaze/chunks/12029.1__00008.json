  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And as it was a large flat, they all moved in to us.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "It was very happy, because the whole family was together.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my two grand-- my grandmother was with us.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "But at that time-- [PAUSES FOR 7 SECONDS] at that time, when everybody moved into that place, the compound, the Germans closed the ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And nobody could get out.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And then you felt like closed in, in a--",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "--Box, prison.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And the trouble started.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And people didn't have enough food.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They were dying from starvation.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] But when it started, actually, my father's business was outside the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And all the merchandise was there.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And my father was very depressed.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And he knew a Polish policeman.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And this policeman said, I will take you out from the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And you'll [PAUSES FOR 3 SECONDS] bring it in, this stuff, to the ghetto.",
      "word_count": 14
    }
  ],
