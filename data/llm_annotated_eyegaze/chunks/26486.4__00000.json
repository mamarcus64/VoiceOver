{
  "stem": "26486.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Brussels",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well we traveled to about three days before we got to, to Berlin, Alexanderplatz.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And when we got to-- we didn't have anything to eat or anything, nothing to drink or eat.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They just left us there in the train.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And when we got-- now about two and half days, it took.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "When we got there, then they-- we got off the train, and they put handcuffs on us.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "We were handcuffed to go from-- you know, from the train to prison.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Got to the prison.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "They put us all in a big room at this-- in this prison.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And we stayed there for hours and hours-- I think the whole day.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they came and got Simone.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And they said, come with us because you're going to the washroom to get washed.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, I saw her in the train.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I told you one of the Gestapo came, knocked on the door.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And he said, [SPEAKING GERMAN], what is your name?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I told my name.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "He said, well come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I went with him, and here was Simone.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "He brought me to Simone.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "She would-- Like this was an old, old wooden train with-- you had them here in America too, probably-- with a door that you opened up like that and wooden seat-- you know, big two wooden seat.",
      "word_count": 37
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And she was there with other people that I didn't know that had worked probably with us, but we didn't know them.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "We didn't know everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So she cried and I cried.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I asked her about my family.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And she said that they were OK, that her sister had seen, I think, my sister or my mother.",
      "word_count": 19
    }
  ],
