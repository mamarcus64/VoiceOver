  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "He was very, very, very well known.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "So we went to this big ghetto, and it was terrible, as you can imagine.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "The crying and the filth, and we were hungry.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And we didn't know what was happening.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And the nastiness from the people that were looking after it.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "Like the Hungarians were there, mainly, and there were very, very nasty beatings and things like that.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And I remember that's-- sorry.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I think we'll finish that tape.",
      "word_count": 6
    }
  ],
