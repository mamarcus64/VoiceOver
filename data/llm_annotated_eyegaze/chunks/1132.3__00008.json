{
  "stem": "1132.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "I also have recollections of family Seders, so that my parents upheld the tradition and upheld the idea that we were Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And if we survived [PAUSES FOR 3 SECONDS] everything that we did, the Holocaust, and we survived the war, then we certainly will continue as much as we possibly can, the Jewish tradition.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "But you are looking at someone who is a Jew, very much of a Jew, without a Jewish education.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And this is also one of the reasons why it was so important to me that my children got a Jewish education.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "Another thing that came out of that is that I wanted my children to get a Jewish education where the fact that they were women had no problem with it.",
      "word_count": 30
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "So this is why we were members and are members of a reform congregation, because as women within the reform congregation, they did everything the same thing as the boys did.",
      "word_count": 31
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "And that was something that became extremely important to both of us, my husband and I.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Going back.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Let's go back.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I graduated from elementary school.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Elementary school was eight years.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "That was the communist system was that you went to the same school for eight years.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to high school, which was, which was called the gymnasium.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I went to gymnasium.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I graduated.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Went through it.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And I have a couple of interesting stories from there.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Graduated in June of '56.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "That's when I graduated from high school.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Couple of the interesting stories have to do with the high school where I went to and the system under which I grew up.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "Remember, I grew up during the worst of the Stalin era.",
      "word_count": 11
    }
  ],
