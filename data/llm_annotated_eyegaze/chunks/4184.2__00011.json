  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "There was one young woman, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "She was a little bit older than me.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "She was also in the convent.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I don't really know her name.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "See, a lot of times you don't really want to know everybody's history.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You don't want to know because somebody could talk or something.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "So you just almost say hello and goodbye, and that's it.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Except Mother Superior and the priest.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Because I had to go to confession-- pretend to go to confession.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "It was horrible because the priest kept telling me stories all about how the Jews killed Jesus Christ.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Until one day I told Mother Superior-- I said, you know, I'm not going to confession anymore because I don't believe that I killed Jesus Christ.",
      "word_count": 26
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "She said, no, you don't have to go.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I think she had a talk with him.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I got so dry there.",
      "word_count": 5
    }
  ],
