  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is James Henry Hayes.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in September the 14th, 1916, in Constantinople during World War I.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My father was an American sailor and my mother was Greek.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was educated in Philadelphia.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I attended the military academy-- the United States Military Academy from 1938 till 1942.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And in May of 1942, I was commissioned as a second lieutenant in the regular Army.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I immediately proceeded to Fort Benning, Georgia, where I took a three-month course in infantry basics.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And then I was assigned in September of 1944 to the 80th Division located in Tullahoma, Tennessee.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "When I arrived at the division, I was assigned to the 317th Infantry and became a platoon leader in Company G of the 317th Infantry.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "In December of 1942, I became company commander of Company G.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And this was my introduction, so to speak, as well to the existence of the Holocaust.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "At the time, we were still in Tullahoma, Tennessee.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And in December of 1942, one of my soldiers came to me-- I will not tell you his name for reasons which will become obvious later-- and he said that he had to speak to somebody.",
      "word_count": 36
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Now, it turned out that this soldier, who was an enlistee, rather than being inducted into the service, was a German Jew.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And he told me that he had to tell somebody about the experience he had had prior to coming to the United States.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "At that time, he described to me a concentration camp in which he had been located.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "He described to me the mass killings that were going on.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Such things as masturbation squads, [PAUSES FOR 3 SECONDS] forced intercourse with women, all sorts of bestial kinds of things.",
      "word_count": 20
    }
  ],
