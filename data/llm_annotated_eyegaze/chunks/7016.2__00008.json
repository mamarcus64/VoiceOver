{
  "stem": "7016.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "When I came to Bergen-Belsen, that girlfriend what she saw me in the [NON-ENGLISH] when I was in that hospital, when she-- what she told me, I have to go out.",
      "word_count": 31
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "She came to me.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "She said, you know what here is.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "Here you don't have a gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "Here they don't use gas.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "Here they put poison in the food.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "If you're going to eat that-- that food, you not gonna-- you'll live a few days, and you're going to die.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "And I said, what we can do different?",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "She said to me, you know, I try to help you as much I can.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "You should not eat that soup.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Because I know what they're doing here.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "She was like, um-- she's alive.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She's-- she's in Florida.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And she's-- she said, I going to try to-- to bring you something, a potato or the-- a bread, the something.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "You should not eat the soup.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And that-- Bergen-Belsen-- was so bad.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Auschwitz was bad.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Bergen-Belsen was ju-- they-- they didn't get the crematorium, that's true.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "They didn't make no selections, that is true.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "Just people died like flies.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "They ate the soup.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "I remember, it came transport from French, from Paris, just beautiful girls.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "They even make shows for us.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And day to day, they was laying dead.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And she was very good to me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And I didn't eat that soup.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "And, uh, she brought me some-- what she could do.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "I probably was not the only one.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "She got probably other friends, too, which she helped us.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And this-- she helped me in-- and I didn't eat.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "Just my job was-- not just mine-- a lot, but we have to pick up all of the dead people and put them in wagons.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "And we have to take them away.",
      "word_count": 7
    }
  ],
