  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "From time to time he would practice with me multiplication and division, as though to give me courage that I still need to know those things, that there is still hope, that there is still a future for me.",
      "word_count": 39
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Or from time to time, he would make me recite Polish poetry, which was also a vital part of school.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I shall never, never forget those nights because this was the first time I had my father all to myself.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] I remember those nights because I want, because I choose to remember, because this was really a time for me and my father alone.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
