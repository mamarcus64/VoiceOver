  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "So from about 28,000 people, they left about 1,500 in the-- in the city, out of, that would be 28,000 Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "On the 20th, 22nd, 24th.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The 23rd, there was no action, OK?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they wanted to take a lot of the unnecessary stuff.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I knew it-- that it would be only a burden for them.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "You know, like suitcase, or something like that, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes, his parents.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "His parents and his sister-- two sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Yes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And Minsberg, too-- the third one, also.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And Wasser.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We all left.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We always survived.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "You see, Wasser worked with me.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Minsberg worked with me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Mosberg worked with me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "All four of us worked in the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "In Henrykow and [?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Ludvikow. ?] Both, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Originally, we worked in [?",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Ludvikow, ?] but they transferred me.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Like-- Minsberg was left in [?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Ludvikow, ?] Mosberg was left in [?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Ludvikow, ?] but Wasser and me went to Henrykow.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "That's what happened, you see, there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I'm on my own.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Except I have uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I have uncle and an aunt, and a cousin, and-- a girl cousin, you know, OK?",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "My uncle was a [INAUDIBLE] it was not chief of police, but he was in charge of an area of police, you know?",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Because, you know, he-- that's my father's brother.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And he had a-- a place to live in a-- it was a store front, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And he got this place there.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And that was an arbeitslager, I'm talking.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "That's this work camp.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I was assigned with all the kids to live someplace there, you know, in a group.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I was in contact with a lot of those girls who were also nurses, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "With Natka Koper, who is in Israel, and [?",
      "word_count": 9
    }
  ],
