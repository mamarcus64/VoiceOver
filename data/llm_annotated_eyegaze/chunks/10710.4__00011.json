{
  "stem": "10710.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And I had a bad experience.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I came into my hometown, and a boy was there from school.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He says, you're still alive?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Instead of telling me, oh, I'm glad to see you.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He says, you're still alive?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They didn't kill you?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "So I had no feeling to stay in the town.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "First of all, I was afraid to sleep there by myself.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "One Jew in the town.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "The Pollacks were very bad at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "So I went to [NON-ENGLISH SPEECH] and we stayed there.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And then we saw there is no future.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So we like burned all the bridges and went back to Krakow.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And in Krakow we stayed for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And then we joined a group who was going to Israel, like a kibbutz.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And we went back to Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "We smuggled the border.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And we had some-- my friend found something from his hometown, some bracelets from his mother.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "So we had to-- on the border they were checking us.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "We smuggled the border but sometimes we were caught.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "So we went to Czechoslovakia, went to Bratislava.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "There was a whole group about 20 people.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Some of them we're still in touch with.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And one lives in Brazil, one lives in New Jersey, one lives in-- but we're still in touch with them.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Sometimes we meet in Florida.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "We kept very close.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "It was like a whole family.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "There were like eight people.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "But we were kept very close with each other.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And from Bratislava we went to Hungary, Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "And we stayed there in a school.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And the HIAS, the Jewish committee used to help us.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "So we were going to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "So we had to go somewhere where there is and ocean to board a boat.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "So we had to go to Italy.",
      "word_count": 7
    }
  ],
