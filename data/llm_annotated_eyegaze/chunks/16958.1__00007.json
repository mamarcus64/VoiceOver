{
  "stem": "16958.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They came to the city, and they grab the people and they take them away like to Belzec or somewhere.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "So a day before Sukkot-- this was a Friday.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Saturday was the first day of Sukkot in 1942.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I thought, this is yom tov, and I know my mother still have something to-- she-- I'm sure she bake something, she cook something nice.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "I want to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I know it's-- it's danger to go home.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "So I borrow a burly bag by a guy who worked with me, and I put in small pieces of wood.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "Because I knew they-- they need wood to cook.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "A big bag of wood.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And I was carrying this on my back.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "It was pressing.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "But I have to bring home for my mother some wood.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Nine kilometers.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I was carrying this.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And I come in Friday like-- and my father sees me.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He says, why do you come home?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Any day it's going to be a-- a pogrom here.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They going to-- they going to take you-- it's terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "You have a good place.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Why don't you stay there?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "Go back.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "My mother said, let's-- he came home already.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Let him stay overnight.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "In the morning, he's going to go back.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "She gave me some challah and-- and-- and nice-- nice stuff.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "But nobody slept in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Everybody was sleeping in the bunkers.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "And we had a house like in the-- to the market.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "And my mother was standing there almost all night listening, if she doesn't hear any noise.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "But I had to go back early in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "So early in the morning, I woke up.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "Maybe 4 o'clock.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "Because I have to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "And my mother was working.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "Our town was like kind on a little hill.",
      "word_count": 9
    }
  ],
