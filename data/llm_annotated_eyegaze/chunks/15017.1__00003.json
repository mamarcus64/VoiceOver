{
  "stem": "15017.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "You see, the workers that used to work for my father-- I used to go to the bank to get the money to pay wages, and stamps, the unemployment and health insurance stamps.",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And when I used to pay the people-- and what was left was the profit for my father, and I used to give it to him.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Then after they'd gone-- they used to-- Monday through to Saturday half day.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And on that Saturday, after Shabbat, the table was laid for the Shabbos [NON-ENGLISH] lunch.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And my father used to say, Miriam, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "So I used-- I said to my mother once, Mother, you hit me when I whistle because you say [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "You don't whistle on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But Dad gave you money.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "What are you taking money on Saturday, if you're so frum?",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And my mother answered me, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Translate-- what is to [INTERPOSING VOICES] God is to God.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And what is to the people is to the people.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Excellent.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Very Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We know when there was a Yom Tov.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We used to polish up everything.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "All my sisters, everyone worked scrubbing.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And especially when it came Pesach.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "The [NON-ENGLISH] was-- the [NON-ENGLISH] is the-- the cups and saucers-- change them, everything.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And [NON-ENGLISH] for the guy to come around that used-- two boys used to be swinging a fire, you know, and say, [NON-ENGLISH] and you gave them a penny.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And you put the [YIDDISH] and the [YIDDISH] in, and little things like that.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "It was very, very Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And there was a Yiddish theater there and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And then, after I came out of school, I won a scholarship.",
      "word_count": 12
    }
  ],
