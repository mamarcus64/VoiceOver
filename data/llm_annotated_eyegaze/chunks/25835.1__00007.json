      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "They like each other, and my father because of business, and children because of age.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "They have two boys in age-- my age-- and one beautiful daughter a little younger.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I think before the war, bef-- sure, before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I remember when my mother was thinking [NON-ENGLISH] where they had wholesale of some, some articles which my mother needed to the store.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we went together.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Melamed, always ask me, [?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Paulinka-- ?] my middle name, my middle name.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And even after 50 years, she's asking about me.",
      "word_count": 9
    }
