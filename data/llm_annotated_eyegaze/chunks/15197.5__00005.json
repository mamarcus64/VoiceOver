{
  "stem": "15197.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "He's also the one who is organizing the commemoration lately in the rotunda.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "And he is one of the first builders of the Holocaust Memorial Museum in Washington.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "Our life is very much connected with the Holocaust.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "It's an inner dedication to a life which is no more, and which very often might think it's not recognized.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "Lately, you know, I think that we are talking so much about the number of 6 million.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "About the people who were killing, the perpetrators.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "And we see the numbers, we see a statistic, but we don't see the life-- very little about the life, the life in the ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "The life before the outbreak of the war, the life after.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "The continuation of life, and what life the survivors built later on.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "Two children were born in the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "Both are part of our life.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 44,
      "text": "We spoke with the children in Yiddish till they started school.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 45,
      "text": "Not because we were not able to speak English.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 46,
      "text": "We want to preserve something from the past in a direct way.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 47,
      "text": "We send them to a Yiddish school, and it did not disturb them to become physicians, doctors, both of them.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 48,
      "text": "They speak, they write Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 49,
      "text": "My daughter sings Yiddish, even-- songs.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 50,
      "text": "And my son taught Jewish history while going to medical school.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 51,
      "text": "They both are physicians.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 52,
      "text": "In it, I have a feeling it's a continuation.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Of course it has to do.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Jewish history is constantly connected in part of religion.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It has to do with religion.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "It has to do with tradition.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "It has to do with moral, with ethic.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "It has to do with a philosophy of life, which has to be understood by non-Jews too.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I didn't tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was really a historical time.",
      "word_count": 6
    }
  ],
