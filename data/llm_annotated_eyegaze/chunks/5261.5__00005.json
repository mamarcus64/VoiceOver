  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 90,
      "text": "It was-- if the war were longer, they cut it-- my leg should be maybe spoiled.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 91,
      "text": "And my leg would be cutted.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "But the American [? fixed ?] it.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In three weeks, I was fit, healthy.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was so glad that I was alive and I could be-- but what have to do?",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They send me to a camp for displaced person.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "It is separate of Munich.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was living there without nothing to do.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But I wanted to see the city, the Munich.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "As a young boy I wanted to see.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And once I met in the Polish community, because immediately all Polish people they [? granted ?] some organization that worked against this communist government Poland.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "They said, stay better here.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We wait.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Maybe the situation will be clear.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They printed also with English for self-learning.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I received also because I wanted to go to America.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I learned from this book, by myself, English.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And then in this community I met one gay.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "At the moment, I didn't know that.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He said, you're living from?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I live in Munich, in center.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "You can move to me.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Yurick, his name.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He is still alive.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "He is older than me.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I have seen him even this year.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "We meet us in the park for exchange the bad experience, et cetera.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And when I moved to him, I met many German soldiers.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They wanted the girls.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I'll never forget one day on the door was written, off limit.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I never understood what this mean.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "But later I knew.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "It's forbidden to come here, probably because too many girls, German girls.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "They wanted to make love for some cigarettes, for some food.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Because in the shop was nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "They had plenty of mark, reichsmark.",
      "word_count": 6
    }
