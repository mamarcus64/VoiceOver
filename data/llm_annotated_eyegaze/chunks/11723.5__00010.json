{
  "stem": "11723.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And I think that I'm going to carry the guilt with me to my grave that, uh, I forced them to come.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And maybe he wouldn't have gotten that if they didn't come.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And, uh, I had two uncles here in this country.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "One, my mother's brother, younger brother, the one who had the typhoid fever, who, after he recovered, he went to, uh, Germany and was in a DP and then came to this country.",
      "word_count": 33
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And my father's brother, who was the chemical engineer who became a busboy in California, he was here.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So we had, uh, priority.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And, uh, as soon as my brother was better, we came, and we were, uh, taken to-- excuse me-- to Camp Kilmer, where, um, my uncle took us from.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He lived in the Bronx at the time in a three-room apartment with his wife and his son.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And we descended upon him-- five more people in a three-room apartment-- eight people.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But they-- they were very happy to see us.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And we lived with them for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And then, uh, we got an apartment near them.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And, uh, my mother and father had a very rough time in this country because my brother was sick almost until the day he died.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And, uh, my parents were heartbroken.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And besides, they just couldn't make a decent living here.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Because, uh, my father was a businessman, and he didn't have enough money to start his own business.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "He was too old to start anything.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "He was, uh, in 1957-- got here February 23, 1957.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Uh, he was at that time 48 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And he couldn't really start over.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And, uh, my mother worked in the, uh-- at Lillie Rubin.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I don't know if you   know the store.",
      "word_count": 8
    }
  ],
