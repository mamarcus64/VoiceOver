{
  "stem": "21648.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it's-- you can't explain.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was a wild girl.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was enjoying life.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I was carrying on like a lunatic.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Because in school, it was very-- I was a good student.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Let's put this way.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "But really and truly, it's a different life in Europe than in America.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We used to dance in the street, jumping, [NON-ENGLISH], walking, and-- and enjoying life.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what-- I mean, killing?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Or, are you a Jew?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Are you not a Jew, or what?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "We know when you work, you have to pay your taxes.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So who knew when I was 17, 18, 20, who knew-- I was married when I was 20.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Who knew what goes on?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Life goes on wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And we had stores, we had nice clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "We were living a nice life.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I-- I love America very, very much.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "From the day we came to America, I always explain to the people, you should hug and kiss the rocks on the streets and the stones on the streets.",
      "word_count": 29
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But we had a different social life in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We was a-- my mother was walking out.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And she didn't see the neighbor, she ran into the neighbor.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Maybe she's sick.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Or, we was close.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was like one family.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know there's 5 or 10 or 15 people, these are friends.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "The whole world is your friend.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I was a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I was gone with the cans collecting money and-- and talking and dancing.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And I don't know how to explain how life was just luxury.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "We was poor.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "My family, my home-- I mean, my father and mother, we hardly have enough to eat and dress.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "But we was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "We was very happy.",
      "word_count": 4
    }
  ],
