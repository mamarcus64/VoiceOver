{
  "stem": "676.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "We didn't work there.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "They just-- they were just-- I don't know why they were sending us from one place to the other.",
      "word_count": 19
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "They just didn't want the Russians to get us.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 10,
      "text": "They were just sending us.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Well, men.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "Men.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "The SS guard.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "They were always different kinds.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "They were just the SS people.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "They were the guards.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "They were on the trains, and they were with us all the time.",
      "word_count": 13
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Always different ones, but always there, you know, the SS guards.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Maybe three, four weeks.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And then we were on again.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "What we did, we were talking about how it was at home.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "We were always hungry, so we were always cooking and reminiscing what delicious foods we had at home.",
      "word_count": 18
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And mostly we were talking about food.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "We were always hungry and cold.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "One of these days, we're going to eat all these delicious things.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And we were swapping recipes and talking about all the delicious food that one of these days, maybe we will still eat.",
      "word_count": 22
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Most of them were Hungarian girls.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "Some of them were Slovakian.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "And I never told anybody that I came from Poland, that I was originally from Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Somehow, they-- the Hungarians hated the Poles.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "The Poles hated the Hungarians.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "It's not nice to say that, but it's how it was.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "So I never told anybody that I came from Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "I always said I came from Slovakia because my mother came from Slovakia and that's where I was, so I was among the Hungarian girls.",
      "word_count": 25
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "I guess it's prejudice, you know, like any other prejudice.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "We would lie in the barracks.",
      "word_count": 6
    }
  ],
