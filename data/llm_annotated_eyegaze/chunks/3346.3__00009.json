  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And your daughter has since immigrated to the United States-- has moved here?",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she decided 2 and 1/2 years ago that she was American, and that she didn't care very much for living in Argentina.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Well, she never did.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "She always-- she's lived for two years-- two years in Spain, and she's been in Japan, and-- she's as much of a wanderer as I am.",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I've always worked as a translator.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I've worked as a freelance.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And for the past four years, I've been looking at the Ministry of Justice as a translator.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "My father died in '71, my mother in '73.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They were very-- they were quite young.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] Well, that's very difficult-- my message to the world.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] I think, really, that if grownups want to fight wars, they're welcome to it.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They're grown up.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "But they should really leave-- leave the children out of it-- just to give them a chance to have some kind of a normal life afterwards, which I don't think any of us have ever-- could ever manage to have after that.",
      "word_count": 42
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "We-- we tried.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "But there's been-- well, a lot of feelings which have been sort of castrated-- when we're too small-- and which we could never recuperate.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "No, I thought it would be much too upsetting.",
      "word_count": 9
    }
  ],
