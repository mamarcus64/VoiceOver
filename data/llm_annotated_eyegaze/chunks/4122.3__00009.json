  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I was the first one in the ladder-- on the wagon And then they put all the others on top of me.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] They brought us then to this grave.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They were pulling us with the wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING] I don't know how far it was, but they pulled the wagon.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "They brought us there, this place.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "[CRYING] And then they start throwing in the people into the grave.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I was full of blood from the other people.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "[SOBBING] And then I was at last-- the last one.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "So they still-- like they were playing with me.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "One catched me by my legs, and one by my arms.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "[CRYING] And they just throwed me like this, and I fell into the grave.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "[CRYING] They just throw in a few shovels of dirt.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And they left like this-- because it was soon dawn.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "[CRYING]",
      "word_count": 1
    }
  ],
