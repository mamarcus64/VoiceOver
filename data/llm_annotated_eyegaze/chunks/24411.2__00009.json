  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "Some of them said don't bother me, I have my own problems, and let me think.",
      "word_count": 16
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "And this was the whole conversation.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "We stopped in a lot of cities, but I don't know the cities.",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Villages, most of the time villages.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "A lot of Russians came to the trains.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "They were thinking, maybe we have something.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "They were looking for something.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "But we didn't have anything.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "A little while.",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "But afterwards, some people were speaking Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And the soldiers told them, you're not going back.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "We don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "They tell us all the time that we're going in the day or night, then they tell us where to go.",
      "word_count": 21
    }
  ],
