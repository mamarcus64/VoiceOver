  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I survived.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And I was a soccer player, very famous and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I didn't graduate.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I went to school there.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "After about 14, 15 years old I went to school.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't graduate.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "I quit.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And I help my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I was going at nighttime.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes, nighttime, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Not the same school, the same school.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "A couple years.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "And then I could not afford to go there, I help my brother.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And I went at nighttime to school.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not-- not-- not, I didn't have the diploma.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "The war came, and I went to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, 18.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And later when I went to the army, I came out for the army.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "I worked with my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And when the war came--",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "Before the war, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "In 1933, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in Poland you have to go draft.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "18 you have to register.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] 18, you have to register.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And 21 you go for a physical.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "And after the physical, then you go in the army.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And I had it good in the army.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "I was never religious.",
      "word_count": 4
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "My father was religious.",
      "word_count": 4
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "He wants to make me a rabbi.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "And I want to play soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "I could not stay.",
      "word_count": 4
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "I was religious.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "I went to cheder and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "But I was not an orthodox religious.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother-- oh, in the middle of the week, it was fine.",
      "word_count": 13
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "But the-- the games was always on a Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And I come back.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "My father come back.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "And my mother give me the meat, and the lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 5,
      "text": "But he went to shul.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Oh, he slapped me and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "But he was a good father.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Oh, about-- before-- before I went to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 121,
