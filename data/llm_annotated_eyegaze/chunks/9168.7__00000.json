{
  "stem": "9168.7",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "'55.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "In August of '55.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In 19-- my husband was on military duty here, so I went back into the court system.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "In order to do that, I had to pass the Colorado State statutory examination for a court reporter at 200 words a minute.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I received an officialship in 1956 in the Denver Superior Court, which is an inferior court to the Denver District Court-- in other states, the equivalent of superior courts, as in New York.",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I worked in the court system and went to the Denver District Court in 1960, until 1972.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "At that time-- in 1969-- 1968, I had passed a National Court Reporter's Association examination, high-speed shorthand at 260 words a minute.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And there were only four of us in the United States writing manual, or pen, shorthand who had passed this examination.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "So for that reason, I came to the attention of the United States Senate reporters.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "They needed to start training a new reporter-- [BACKGROUND NOISE] a new reporter, and [LAUGHS] they contacted me.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I was teaching seminars, reporting seminars, all over the country at that time, partially for the National Court Reporters Association at conventions.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I was at a convention in Boston in-- in 1967, I think it was.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I know it was '69-- 1969.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And through one of their reporters, whom I did not know, I received an invitation asking me if I would be interested in being the first woman reporter in the United States Senate.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And to leave my Denver court and go back there to start training.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I had never been to Washington, DC, and I didn't know anything about Washington.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "My two sons here and I were skiers and did not really want to leave the mountains in--.",
      "word_count": 18
    }
  ],
