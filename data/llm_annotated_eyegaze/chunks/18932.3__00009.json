{
  "stem": "18932.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] is a place that they work together, and they pool-- like in Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They pool their earnings, and they live together.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Some people cook, and some people go to work.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And he stayed with them because he-- he wanted to go to Israel with the rest of the-- the people.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But then he met me, and he change his mind.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Right, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, we send him-- after we were in America?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We got married in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "My uncle send him papers.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "First he send us the papers.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "But in Sweden, we had one of the happiest times of our life.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We were really, really free of any worries and-- and was-- the people were great, were very nice.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Swedish people were wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And I was in school, and on vacation they used to send us to visit our parents.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And once I got a-- a-- a letter from my mother, and she-- it was addressed [?",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Congo. ?] So I said, oh, my-- my-- my god, they send it to Africa?",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But this was [?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Congo ?] in Sweden.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I went to visit her, and she was doing quite well.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And after being there in-- in school, I was about a year and a half, we went to work.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So we went to-- oh, no.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "The place that we stayed after Malmo was [?",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Mela. ?] This was a resort.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And from [?",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "Mela ?] we went to Boras-- from-- we went to school.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "To school, I was in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I think so.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "I'm not sure now.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "Yeah, I think so.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "And then we stayed in school.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And we went skiing, and we had fun.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And we were singing, and we were-- it was great.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "It was really nice.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "We had a great time.",
      "word_count": 5
    }
  ],
