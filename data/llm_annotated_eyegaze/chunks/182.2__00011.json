{
  "stem": "182.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And she said, pretend like you are working here.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And then the Germans will open the front door, and say, 'Raus'.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Then you go out the back door.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And that's what I did.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I came back to my mother, and she was sitting on the top bunk, just in a position like this, you know, like her whole life has ended.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] [CRYING] And then she saw me, so we hugged and we were together again.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So when--",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So when-- when it was the selections and they didn't want to take my mother, I always stayed behind, and my cousins also.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And one day, two Germans came and [INAUDIBLE] civilians.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And they said to the group that they are going to take 500 women to a place where there was never bombed.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They will work in a factory.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And everybody will have their own bed, and everybody will have their own blanket, and everybody will have their own cup.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we thought, th-- this is heaven.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we lined up, and then my mother was in the-- and-- and so the Germ-- the-- the civilians were standing here, and we were lined up here on one side of this whatever we call it, you know.",
      "word_count": 39
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "The middle of the-- what did you say you called it?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was like a brazier?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Like a brazier.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We were on this side, and we had to go around and come in front of the two civilians who will select.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And an SS was standing here to direct traffic.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And each time my mother approached, he pushed her away.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And he says, du bist schon zu alt.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "You are too old.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And all my cousins were taken.",
      "word_count": 6
    }
  ],
