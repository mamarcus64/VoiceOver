{
  "stem": "24090.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But they made these rounds, and came back to tell my mother the horrifying tales-- that two old ladies that were widows that lived together in a small little farm town, who had just finished putting up all their preserves for the winter, their food, the Nazis came into their house, smashed all the food, destroyed it, and poured gasoline over it.",
      "word_count": 62
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They did not set it on fire.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "But they destroyed all their food.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And then they came to another place where an uncle-- whose antiques that I have with me today that my mother took to this country, some of the antique little pieces that he had in his ancient little home-- he lived by himself.",
      "word_count": 43
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "They took him outside, took him from bed and beat him to death outside of his home.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And these were the horror stories that the adults were talking about.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They didn't want me to know these things.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "But I would listen.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I was curious.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And I would hear those things.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "It was very terrifying.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I found out our synagogue, all the synagogues, were attacked that night.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The one in Opladen was burned.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "People saw it burning.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And they wanted to put it out.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But they were told they couldn't.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And the Nazis made it burn to the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "It was totally destroyed.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Nobody could understand it, except that it was Hitler and his gung ho seizure of the people and the country and the wild speeches he made that you heard on the radio.",
      "word_count": 32
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "There was no freedom of speech, which we, in this country, don't understand.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It's something that you can't explain very easily.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It's just-- you know, the rights weren't there.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "People didn't have the same rights that we have here.",
      "word_count": 10
    }
  ],
