  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] I remember that there was one bed.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "What my parents did was they took the mattress off the bed at night so that I could sleep-- so that I would have a place to sleep, and they slept on-- on the-- the mattress underneath or whatever you call that.",
      "word_count": 42
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I remember my father starting to teach me Hebrew.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And he taught me the Shema, the-- one of the basic prayers.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And-- but I was pretty miserable, because I didn't have friends.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I didn't speak the language.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I was still pretty scared about-- from all of the stuff that was happening to me and my parents.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
