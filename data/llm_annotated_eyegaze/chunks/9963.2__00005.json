{
  "stem": "9963.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Because that camp was already very dirty.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "It was bugs, you know, biting and thing like this.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "But we had to keep ourselves clean.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And I couldn't stand that to be in that camp and not to go home at least once a week.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So came Saturday, I did the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I came home, I took my bath, changed clothes, and-- and I know I come back, I will get 25 lashes.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I didn't care.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Later, I got tired.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was-- so I didn't went every week.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I went every second week.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But I still went home.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So long we were in that camp-- this was 1940-- I did not listen to them.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I didn't care what they say.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I went home every second week or every week-- depends, you know, I felt-- in order to take the bath on there.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And mine mother, she already waited for me.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "You know, she had prepared a hot bath, she had prepared everything.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "When I came home, you know, I got it everything ready.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Because I couldn't take off the clothes in the house, because it was soaked with the lice and all kind of bugs from the camp.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "What I had to take off the clothes outside and right away to put the clothes in the hot water, you know, to wash it.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And-- and for me to take a bath and to change clothes was, you know, it was a very, very humiliating-- it was very, you know, disgusting, what-- that kind of conditions what they put us through.",
      "word_count": 37
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The barracks were the big barracks with-- with the bunk beds, you know, three, the-- three stories bunk beds.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "On the-- only straw was on the beds-- no-- nothing, you know, fancy.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It was long.",
      "word_count": 3
    }
  ],
