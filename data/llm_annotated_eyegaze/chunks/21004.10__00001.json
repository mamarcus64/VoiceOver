{
  "stem": "21004.10",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So when we came to [INAUDIBLE]-- oh, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "That officer, well, he said is going to pick up our baggage and take us right on the train.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So he told me, now, you have a uniform, a Russian uniform, a Secret Serviceman.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Nobody will bother you.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "Soon you come on the train, nobody will check you.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "You come with me and with the baggage.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And we put it right in the same wagon where you-- where you have on your-- on your passport.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And when you come there, soon the train starts moving-- we had prepared a civilian uniform.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Take out your military uniform, wrap it up in a bag, throw it out through the window, and change your clothes.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "You are complete difference person.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "You are not a soldier.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "You're never been a soldier.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Nobody would know what's happened.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He gave me the good idea, and that's the way we came to [INAUDIBLE] where we find her brother.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And her brother-- her brother's first wife also got killed.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "He had two sons.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "They all got killed.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So he found himself a lady from another city, and he's supposed to get married.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Now, to get married again, he's supposed to get married now by a real rabbi.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "When we married in the ghetto, there was a religious Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "There was no more rabbis.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "So we really weren't--",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "There was another couple what we were going together.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They were not married yet either.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "So all three couples, you're supposed to get married.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The meanwhile, you can't get married if you are not divorced.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "So she has to go to Krakow with her husband, with her first husband, and get a divorce.",
      "word_count": 18
    }
  ],
