  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "And at dinnertime, we all sat around the table and the conversation always was about jobs, the looking for jobs.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "There was somebody who became a butcher and he had no idea about being a butcher.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "He applied at six different butchers and he was-- after one day, he said he was experienced, he was thrown out.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "And after the six ones, he knew enough to remain hired.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "And later on, I had a very similar experience myself when I first became a photographer.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "[LAUGHS] But that's-- and one former I think he was an accountant, a bookkeeper over there, he became an auto mechanic.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "And somebody else-- they all took really menial jobs, whatever they could find.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He looked for a job and it took a long time.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He couldn't find anything, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But finally, he took whatever he could find and it was-- the first job that he got was selling razor blades to candy stores.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he went to a wholesaler, he got one of those cardboard racks and-- where the razor blades were stapled on there.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And he went from razor-- from store to store peddling razor blades.",
      "word_count": 12
    }
  ],
