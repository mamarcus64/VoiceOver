{
  "stem": "18061.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "We were over there about two weeks at that place.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "And it was really nice, the people were very nice.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "And according my heart, I suspected that she must be Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "They had two kids, a son 9-year-old, a daughter 7 years old.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] When we left, she said, please.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "Somebody if you survive, let me know what happened to you.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "At night, we left the place over there.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "Two of them, her husband and her husband's brother, went with us to the railroad station.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "On the way to the rail station, all of sudden behind us, two Germans with guns.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "And we were shocked.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 26,
      "text": "I really didn't know what to say.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 27,
      "text": "But my cousin, [INAUDIBLE] me and I think nothing to say.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "But we find out that people from that place they had no documents, because they changed the documents to other one.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "When they got us document, well, we have no documents.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Because they took away the documents.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We're going to get new.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Where are you going to go today?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And they looked at us.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "OK, let's just go.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We got to the railroad.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We were waiting outside, and they went in to buy tickets for us.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They bought tickets.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Those two men.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The man who took us into his house and his brother.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] We went into the railroad.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Then the train came.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "We went from there to Warsaw, which is about-- I would say about 80 miles.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Nobody did.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Went with people, a lot of people was in the train.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We got there to Warsaw at the main railroad station.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Now as you know, not, not Jews, or even Polacks were not allowed after 8 o'clock to run around.",
      "word_count": 19
    }
  ],
