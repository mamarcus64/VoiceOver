  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I come with him.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He took me up in the house.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "They give me water, with a [NON-ENGLISH] they call.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how this is-- a big place you can wash.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I wash up, and take me down in this room.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "In this room over there was already four grown ups, and three children, and I was already eight people.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "OK, I have, in this time, I have the gold pieces.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I paid to this guy [?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "Gochinski ?] 10 [NON-ENGLISH]-- a $10 gold piece for [INAUDIBLE] to keep.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "All right, he give me.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Later-- and we have over there, digged out, in this hole, where we was hiding.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "In one side was a wash room.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "You used the wash room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And in the other side was a little hole, to get out little bit water.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "We was all digging.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "They was digging.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "This guy, the doctor, he was in love with this [?",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "Gochinski's ?] wife.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "He went, every night.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "About 10 o'clock, we went up over there.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "I don't know what he did, but [INAUDIBLE] he come back.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "One day, in the morning, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "Gochinski ?] come down.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And he said to the doctor, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "The wife was called [?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "Zosha. ?] And he tell him, you will not have-- you will not get nothing.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "And I will not have nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "If she passed away, you will not have nothing from her.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "And I will not have nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The doctor start to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "There was over there a woman what she was hiding.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Ruhala ?] was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She asked him, doctor, why are you crying?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "She said, [?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Zosha ?] was to me better like my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We were sitting-- this first in January.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "This guy [?",
