{
  "stem": "22959.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They would prepare food orders, and we would stop their places and pick up the prepared food orders and leave receipts.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "The partisans were here, and they picked up the food.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Our goal, we were not interested in getting involved in open battle fights, because we were not equipped or trained for it.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "But we were interested in getting involved in sabotage acts to interrupt and disrupt the transportation and the communication at the front.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Often [BACKROUND NOISE] we would lose our own comrades due to our mistakes.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I remember once my husband left on a mission to blow up a train.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And they had everything in order, the little hill was camouflaged.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And one of the partisans disliked the looks of the little hill, and he tried to smooth it down and it blew up.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "And we lost three of our best comrades.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "I'll never forget when they brought the bodies back to our camp.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "That you never forget.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "You always-- you always think about it.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "You picture it in your mind.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "They brought-- they brought back-- my husband was on the mission.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And they came back to the-- to the-- to the camp with parts of the bodies.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It was completely, you know, dismembered.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They brought it to the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And it was-- it was a horrible, horrible tragedy, because we did it ourselves.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] And that-- that was terrible.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "That was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I'll tell you about my husband.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I think I owe it to him to tell you briefly about my husband.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "My husband was born in Novogrudok.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He had a beautiful family.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "They lived a normal, decent life.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "He attended the gymnasium in Novogrudok, where all the subjects were taught in Polish.",
      "word_count": 14
    }
  ],
