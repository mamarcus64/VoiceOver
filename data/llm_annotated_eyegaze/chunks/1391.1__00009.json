  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "Is common.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "I remember the mothers say, OK.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "She have a golden chain, you know, when she married.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "And was a oven, was over there we, we lived.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 19,
      "text": "And another Jew give us the apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 20,
      "text": "And she say, you see, I put the-- how do you say the--",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The chain over here.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Who goes surviving can come back and pick it.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Not just this-- she took the rings over there and put it in.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I say to myself, OK.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Where they put in.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "This was one day.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "The second and third day, I come in front, you see, because I know how to run upstairs to live.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And they come in, because the number have to be revealed.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "When they say 300 Juden, that's it.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Now, I come close.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "What I do when I run away?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Where I go run?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And I'll never forget in my whole life.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "The third day, I see they put [SPEAKING NON-ENGLISH] You know what mean [SPEAKING NON-ENGLISH]?",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "What to hang people, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And they took out [SPEAKING NON-ENGLISH] 10 young guys like this.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And we all have to see it, how they hang them in Belchatow.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They hanged it up.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "When the Gestapo put off the tube, everybody can go back at the house.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "The next day, come again, maybe three or the four wagons.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And they put all of them after.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And we come to Lodz, a ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "This was one [? tablet. ?] We come to Lodz, was the [?",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "Rimner ?] Street, the [?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Rimner ?] Street, and next, it is Ga-- anyway, you don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And we come down from the wagons.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And Mother was right away [SPEAKING NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "In the beginning, I didn't know what this means, [SPEAKING NON-ENGLISH].",
      "word_count": 11
    }
