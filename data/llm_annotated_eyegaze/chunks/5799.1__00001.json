{
  "stem": "5799.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "My mother was a fighter and a suffragette for freedom of women.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And she was against the czar and against the pogroms.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "I'm the first generation grandmother to no grandchildren.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I have never known mine.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "They were killed by the Cossacks.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "My mom was a dentist.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "My father comes from a long line of rabbis.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "Became quite nationalistic and atheistic.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "He became a Zionist, an ardent, ardent Zionist.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "He started as a rabbi, as a teacher, as a physician, laryngologist, and ended up as a periodontist to help my mother.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "My sister never knew my father.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "She was born while he was in Kiev, going to school.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "By the time he came back, she was four years old.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And I was his daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "He delivered me.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "So I had a, a very strong attachment to my father.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "I always respected and adored my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "But by the time I became to understand her, it was too late.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "I almost lost her.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And then it was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "It was a unusual relationship between my sister and myself, too.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "She was five years older.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "And yet, we were like Siamese twins.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "We adored each other.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "When I was nine, I realized that I could never match her beauty.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "Because she won every beauty contest under the sun.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And I decided that I might as well use my brain.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "So I decided I'll be the smart ones-- smart one.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "And anyway, it was easy at that time to be a smart.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "One because anybody who wasn't so pretty was smart.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "And the one who was pretty was usually considered, she isn't so smart.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "But my sister belied all of that norm.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "She was clever.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "She was good in school.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "She played the piano.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "She sang.",
      "word_count": 2
    }
  ],
