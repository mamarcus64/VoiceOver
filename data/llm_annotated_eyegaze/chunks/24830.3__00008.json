{
  "stem": "24830.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "They got scared now.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "You know, the-- the-- when they saw this, you know, what happened to them.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They-- now they were not so happy to denounce people.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They were my friend, yeah-- Ernest-- Ernest, Zizi, and Mark.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, Ernest [NON-ENGLISH], Mark Levi, and Ziggy Porilez.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, I remember them.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Because I forget some of the name.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "That was dangerous.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "You have to be very careful.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Well, I told you, we meet in-- first, for dinner, we meet.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "But sometime we stop it.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And everybody was living on their own.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I was living first with a-- a-- a friend of mine who live in Washington now.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And we lived together.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "But it became too dangerous, so we separated.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "You know, if one was caught-- like for example, if one day we live, most of us there.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And then Ernest was caught.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And then we had to move, because I-- we know that they will get tortured, and they may talk.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "So we moved.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "OK, my mother and father-- well, my father was born in Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "So he has an accent.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So it was not easy for-- to make him false paper, I had to go to the-- I don't know.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "It's called-- it's some kind of library-- and find a-- a white Russian, who-- who is about my father, you know, height.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And my father looked like the pope-- blue-- blue eyes, and very blond, and the same age.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Sometime it takes days to find this kind of paper.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And finally, my parents left to-- to Carros outside of Nice.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And my brother finally, he went to the Maquis for a while.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And things happened, and-- and he had to come back.",
      "word_count": 10
    }
  ],
