  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "You see, all [INAUDIBLE] we agreed that all fighters what's in here in our [INAUDIBLE] we had a hundred people probably.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "About 60 or 70.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "So probably about 70.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "They were armed.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So the thing is, we're surrounded in here.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We-- every a hundred had about four people.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We're going in every-- in every house.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "We have four people, surrounded.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "We go in.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "This was just in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And-- and we just put up the fire.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "We're taking-- we're making a fire, we threw it.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And we were burned, and we killed all of them.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was in front of the-- of the village and I was the second [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "This mean the second-- I had a machine gun.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The machine gun.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I was carrying [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And I had the-- I had the--",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The bullets.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The bullets for the machine gun.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The bullets, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Grishka Gervich was the first.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He was carrying the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Now you had-- in addition I had a-- a revolver.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, the thing is we went over there, and we took, afterwards, we took as a-- as a prisoner a guy with a white horse.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We thought maybe this is a [INAUDIBLE] from the-- from the village.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We took him across-- across the little-- not a river.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "But how do we call this?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "A little stream.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "A stream.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We made especially-- especially artificial bridge.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "What we went in here.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "But it was very narrow.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We could barely go through.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And we-- as soon as we passed by the creek, we could-- we took it easy.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And we started to shoot just to show that we are through.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "But [?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Grishka ?] by mistake picked up the-- the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And what happened in here, one of the bullet just-- [NON-ENGLISH].",
      "word_count": 11
