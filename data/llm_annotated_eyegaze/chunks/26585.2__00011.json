  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "We weren't allowed to touch anything.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "It started early in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "He would take a dress.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "And the Gestapo man would come-- a pair of underpants.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "That's how it was done.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "And imagine, of course, nobody knew.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "But I could not imagine why my mother was so nervous.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "She was very nervous.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "And we found out afterwards why.",
      "word_count": 6
    }
  ],
