{
  "stem": "3150.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "He especially was very good, not to my immediate family, but to my mother's sisters.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "He was very good to them because he created for them a place to live.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "They-- he took all the big barn and divided them and gave each one-- one had two rooms, one had one room, but they all had a roof.",
      "word_count": 28
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And I mean, he was the one that did it for them.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I think-- I believe-- which I really can wonder.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "One of my grandfathers, which I never knew-- they all passed away before I could remember-- they-- one of them had some relations with him.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I think it was my mother's father had relation.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "That's why he-- he took-- he gave them all that particular building.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "She had six sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "She was one of seven.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "One was already in America before the war, and six of them all lived-- all lived in the same shtetl.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And five of them lived under-- under the same roof, except us.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "We had-- we had our own house.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And all of them were married, and each one-- if I remember exactly, they had like-- I had 13 cousins, and only two of them survived.",
      "word_count": 26
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And only one-- one of the six sisters which were in shtetl survived.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "All the-- all the-- all the others were-- did not-- did not survive.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "On my father's side, he was one of four.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "He had two sisters, and there were two brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "One sister was still single.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Now married.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And his-- his brother, whose name was [?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "Sholem ?], he had-- he had three kids.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And his-- and his-- and his sister, whose name was [?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "Malka, ?] she had two kids, but none-- none of them survived.",
      "word_count": 12
    }
  ],
