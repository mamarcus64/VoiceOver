{
  "stem": "9415.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "No, [?",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Tobins-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Tobins ?] was the place my wife was working, and his factory was a couple blocks away from the building, on the outside of the ghetto.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My daughter--",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My daughter-- as I said, she was-- before that, she wasn't working.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She wasn't with my wife in the [?",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Tobins ?] factory.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My wife stopped working in the-- well, in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Oh, when she went away to the Polish people?",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Eight days before the uprising.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "One-- a friend came in and said, I could save your kid, your girl, and we agreed to it, and the Polish people--",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "He was a guy who was going-- going out and in the ghetto, bringing stuff and selling stuff, you know, taking out stuff from the ghetto and selling it on the Polish side.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, not-- no, I don't remember his name.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish guy, and he said, I think I can [INAUDIBLE] Polish people came.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The women-- the Polish women came, and she took the girl, my baby, away.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] Jamiolkowsky is the name.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "J-A-M-I-O-L-K-O-W-S-K-Y, Jamiolkowsky.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Janina Jamiolkowsky, her name.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No, without money.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We just put together some clothing for the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was 2 and 1/2 years old, and we gave her the clothing.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "That's all she got.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Because Warsaw had a lot of Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Half a million Jews lived in Warsaw, and there were a lot of organizations.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And when they find out what's happening to the Jews in the camps-- not only camps, but just they're killing the Jews, so they see no end, no hope.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "This was the only way to do something about it, is it resist.",
      "word_count": 13
    }
  ],
