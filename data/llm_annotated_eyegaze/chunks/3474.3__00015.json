{
  "stem": "3474.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I should go to [NON-ENGLISH SPEECH], the, the people that make the chicken kosher.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "They kill the chickens.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I wouldn't kill a chicken.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE] They has to go over the bridge.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "And there was none there.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "There was no [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "And I come back.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "And the Russians stayed there with, with machine guns.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "They say, let's go to work.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "[RUSSIAN SPEECH], Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "[RUSSIAN SPEECH].",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "I says, I just came back from the concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "Yesterday, I came back from the concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "I can't go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "Let's go to work, he says.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "I came finally-- I, I don't know how I twisted it out, out from him.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "I came back to my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "I says, we're not going to stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 25,
      "text": "We went [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 26,
      "text": "We didn't have luggage.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 27,
      "text": "We didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 28,
      "text": "We went to the railroad.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 29,
      "text": "We spent three days on the railroad tracks over there to Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "On the--",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No walking-- we went to the train.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "There was train there.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But it took us three days, three days till the train came.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We were waiting over there.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "We went to a, to a Russian, ask him, when the train coming?",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And the Russians say, [RUSSIAN SPEECH], in a minute, in a minute, any time, any time.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Three days it took them till they come, the trains.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "That's-- after the war, that's, that's how the Russian, that's how they-- it's not the United States, not a country like United States.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So then finally, we took the train to Budapest.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And wait a minute.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "My sister was already also home in Munkacs.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And in Budapest, we met the other sister.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Your sister came to-- back to the home?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "They were home, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So the three of us went back to Budapest.",
      "word_count": 9
    }
  ],
