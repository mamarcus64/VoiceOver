{
  "stem": "428.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "The youngest from us was 15, 16 years, 17 years old in the camps.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "But in the camps, it was terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Except ?] this-- you-- you lived like an animal because you lay down on that wooden bridges, we called them.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "You lay down with a-- with a human being.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "In the morning, you wake up, you touch him.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "What the hell?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "You're not moving.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He's dead.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "They were dying.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The French people, they used to die terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Somehow they have-- they can't take that-- very, very soft people.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "The strongest was the Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They-- they die a lot because the Russians, whatever food they get, he was giving away for cigarettes.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So they didn't eat.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They smoke a lot, so they die out, too.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "But you had to-- oh, brother, they used to-- always used to hear at night-- waah, waah-- they're killing, they're hitting us, always.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "But it didn't bother you.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "You went-- you went out at night.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "At night, you see somebody lays-- lays down.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And I would jump over him.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And I went my way.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "No, no, no human-- you see people lying dead.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Because we was young and healthy.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That's the strength came from.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "But after the war, I had my share of it.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I had three bypass operations, sure, at Cedars-Sinai Hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I came to visit my daughter at 1 o'clock at night.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I felt-- I wake up my daughter, Miriam.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I said, I don't feel good somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I'm not myself.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So he called up right away his friend.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And 1 o'clock at night, they took me-- they make a-- how do you call this?",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Sonogram or something like this, sonogram.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And they-- and they saw it's-- four veins were collapsed.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "The blood didn't go through.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "But I feel good.",
      "word_count": 4
    }
  ],
