{
  "stem": "293.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "He looking, and there it is written that I have a right to get out, to bring the-- so he opened the door.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And he knew we are officer.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Salute.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "Goodbye.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "I went out 6 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "I jump on trolley car.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And my, my home was exactly about five minutes by trolley car from there.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "About 6:15 I was home.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Then I burned my officer uniform except the preachers what I dyed black so I could use them.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Because I have beautiful boots, and were very good because it was October, November, December.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And it was good to have it because in this time, all the Polish people was having high boots.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I want to look pretty good like the general public.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Who you find home?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Who was--",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My mother was there.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My father was there.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And my sister was there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "They were the closest.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "All my family was intact in this time.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "This was in beginning of October 1939.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Then I found out three days later from the lady who was in-- supervisor of the apartment building where we live-- and she likes me very much, because as a single man, I was sometimes coming after 10 o'clock when the door to the building was closed and you have to ring her up.",
      "word_count": 54
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You give her a tip.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I give her a 20, 30 zlotys-- are like $5-$6 a month.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And I have a key.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And she likes me.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Always I found her a gift or something.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "She's calling me and saying, Poldie, you have to hide.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "The Gestapo is looking for you.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "They were here, and they asked me to report the minute you come over.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I start to hide different places every night.",
      "word_count": 9
    }
  ],
