{
  "stem": "26609.18",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I wanted it back, because I know-- and I lost them all, and I want to keep their name.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "So I went back to my name, went back to Furth and I worked there as a nurse.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Now it's another story, how I found my child.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You want to know the story, yes?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "When I was in Kudowa on Czechoslovakian border with those people sent by the Red Cross, Jewish people, I worked there before I had that fall.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "A woman came-- no one knew that I'm Jewish, no one.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They had a such a respect, a respect from Red Cross, no one came near to me.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I wanted to speak to Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They would, they didn't want to come to me.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "They were afraid of anyone strange.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "A woman came up to me and said, you know-- yes, and if I talked to someone, they said, why I came?",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I said, because I had a child, and I'm looking for my child.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "That's why I came up from the Red Cross to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "She came-- a woman came up to me, the first woman that came up, really, to talk.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And she said, I've heard rumors here that you had a child in Lwow.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "You are from Lwow, yes?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "I said, yes, I lived in Lwow, and I had a child, and I was so and so, I said.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And I came up here to find her, back to Poland, and that's why I came.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "She said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Your child is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And how do you-- an ordinary woman-- how do you know?",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "She was in my place.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "How do you know?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "Yes, she was a [?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Vladisava ?] Grabowienska and you called her [?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Junea, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Fredricka ?] [? for ?] [?",
      "word_count": 6
    }
  ],
