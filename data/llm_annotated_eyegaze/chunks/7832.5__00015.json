  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Each one had their separate bunks-- like a single bed with straw in it and a pillow and a blanket.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And I said, no, this is a mistake.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "This is not for us.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "This can't be.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "We can't be so lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And of course, there was only 50 of us in-- in-- that I know.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "I mean, the train was long.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "I don't know whether they all-- they couldn't have all wound up there because the camp wasn't that big.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "It was one building.",
      "word_count": 4
    }
  ],
