    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And I'm regretting that didn't [INAUDIBLE] see here again and again.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I was in German, he was in Israel [INAUDIBLE].",
