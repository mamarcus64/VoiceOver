    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "But he-- he died 64.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "He was 64 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "How was possible?",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "My wife [INAUDIBLE], my son, my son.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "You are the son of the [? martyr, ?] of the painter.",
