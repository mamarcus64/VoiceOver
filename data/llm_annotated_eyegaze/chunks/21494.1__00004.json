{
  "stem": "21494.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He had the farm, and we had this forest business, and the lumber business.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And our shul was down.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Then he built it up, renovated it.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he was like [INAUDIBLE] gabbi in shul.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Olyka-- Olyka Shul.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Olyka because Olyka had a rebbe.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They called him Olyka Rebbe like Lubavitcher rebbe, because he was from Lvov.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Olyka Rebbe-- my father was Olyka Rebbe Hasid.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And the shul was Olyka Rebbe's name.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And he used to come to the shtetl to visit the Hasidim.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He used to stay by us.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "He gave me my [INAUDIBLE], and a brucha, a blessing.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I was very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "He gave me a blessing.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I was usually a very sick child-- wild, spoiled, and sick-- a very sick child.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And he told, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "She'll grow.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "She'll be well, she'll be-- God will help her.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "She'll overcome.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "And-- [PAUSES FOR 3 SECONDS] And then he used to go back to Olyka.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "In Olyka, I had my sister married to Olyka.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "I had already a married sister with two children.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "The sister's name was Rivka.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "My brother-in-law's was Chema.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "The children was [?",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "Manya, ?] Miriam, and the boy was Chaim.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "Also they called him [?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "Munia. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Family name-- Dreishbun.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The same like from Lutsk.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Like 15, 15, 16 kilometers.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "The same.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We used to go very often.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Then my brother--",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "By-- with horses.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We had-- how you say-- [INAUDIBLE]",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "A carriage and horses.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they came every vacation, every summer, they came out on the farm.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And they came to us, like [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And then I had a brother married to [INAUDIBLE] Olyka.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And he had a wife, Hannah Glickman from [INAUDIBLE], and two children, a son, Berela, and a daughter, Ruchela.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And they used to come.",
      "word_count": 5
    }
  ],
