{
  "stem": "14429.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And we went to coffee houses.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And we had such a good time.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "But I was in love with love.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I hadn't lived yet.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And therefore, my marriage was much too fast.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I fell in love with love.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "How can you-- my father said, you're not going to America.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I said, so what?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So I'll wait until I'm 21.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So he tried to inquire who the family was.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And then he did not want to hold me back.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "He let me go.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And on the ship I turned 20.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I came to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And as a fiance, I-- on a visiting visa, I had to three months.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I got married.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And then suddenly, I got sick.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I had tuberculosis.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "It came from the war yet.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I had tuberculosis, and I had to go to the National Jewish Hospital of Denver, Colorado.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And what do you think?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "There were a number of young people in the 20s all from Europe, all from concentration camps, all with tuberculosis.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I was there for nine months.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] And then I covered.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I came back.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My father never knew.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He was not in America yet.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My father never knew.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I never let him know.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I wrote him letters to Belgium as if I would be in-- in New York, because we always tried to sort of save our father, all of us, all three.",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I never let him know that I had to tuberculosis.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "So I wrote him fictitious letters of a life that I didn't even lead.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Eventually, got well.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And then started to learn English well.",
      "word_count": 7
    }
  ],
