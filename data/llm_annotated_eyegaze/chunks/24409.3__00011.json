  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "I have to report to Lange.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "So he brought us to Lange, and he said these Jews want to-- Turi was with me-- want to report to you.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And Lange says, what is it?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And we said, if you spoke to Dr.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "Rayakovich, ?] and we are going to-- he said, oh yes.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Let them go.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And they should report within-- [PAUSES FOR 3 SECONDS] no, there was already not a time cap.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And you keep contact with us regarding the dispatch of the [INAUDIBLE], of the ship.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And we came home.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "And my brother was come-- I forgot to tell this-- to the prison while I was still there.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "When I came out, he was out there.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "He was out there waiting for me.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "Because [INAUDIBLE] had brought a message to him.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And I was with him, and [PAUSES FOR 5 SECONDS] what was the next thing?",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "We're going to have to pause now and change tape.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I think I'll have to eat now.",
      "word_count": 7
    }
  ],
