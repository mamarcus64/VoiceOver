  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "So when we came and I said to him, I brought a-- a-- the baby to his mother.",
      "word_count": 18
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "And they were together in a glazed glass cage.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I realized that Eric was right.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "What-- he says, now, don't interrupt me.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Wait till I'm finished.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "I-- I never waited till I-- he was finished.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And I'm very glad that-- that's how it-- it was meant to be.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I feel that it was my destiny.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I kept it.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Was never in hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Was always there.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "If people call, no matter where they-- when I-- [BACKGROUND NOISE] --somehow-- the-- it was revealed to the world that-- about me with the album.",
      "word_count": 25
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "The next day, I had my house-- I had a big house in Miami.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "People from all walks of life, lawyers, [PAUSES FOR 3 SECONDS] people from-- from like Random House.",
      "word_count": 17
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "From every-- you know.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "And I just didn't know-- and Eric was trying to call home, and the line is busy and busy, busy.",
      "word_count": 20
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "So he finally called the neighbor across [? it. ?] He says, [?",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Helen. ?] Go and see if Lili's all right.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "I call, and there is no answer.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And what I did is the same thing [LAUGHS] you said you-- we gonna do here.",
      "word_count": 16
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "Take off the phone from the hook.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "We're gonna take a tape break now.",
      "word_count": 7
    }
  ],
