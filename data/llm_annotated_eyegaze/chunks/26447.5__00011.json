  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Then, when we stay in America a couple of years-- I was working, I-- I will not tell all-- all the-- the-- the time what for these years, it was good, and what was bad.",
      "word_count": 35
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "No, if to compare to this life, what we got for our-- all my life, it's here excellent, better can-- cannot be.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We, one time, we sit with the wife, and we was thinking, we-- always we was talking how it was the-- the best time.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We had decided to write a letter to one friend.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "No, that's-- this story maybe I will-- I will tell this separate.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And she write us back a letter, but what-- we want to know what happened in Kolki with what-- and she write a letter, but she had read in the newspapers what it's open, a monument.",
      "word_count": 36
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "A monument For the Jewish people what was killed in Kolki.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And one lady, she was read a poem about me.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I don't know if to know to read the-- all the poem is big, no?",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I will tell you short.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The poem said how-- said how I was in the time in the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "The time when I was jumped from the truck, how it was.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I-- when we received-- when she sent the poem, we read and cry like-- like no-- I don't know what to-- for the time, what it's-- it's terrible.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And then we got letters and letters from them, and they tell us what is going on.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They invited us to come to Russia and to be-- Then it was-- they want to open the monument.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "They was looking for us, for me to bring-- to come-- to come to the Kolki, to the city.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They know me very well.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "They know [INAUDIBLE].",
      "word_count": 3
    }
  ],
