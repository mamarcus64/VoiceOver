  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The first searching really happened still in Chust before we boarded the train.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Every woman was called in in a tent.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I never, ever told this story to anybody, and not in, in the details I'm going to say it now.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I don't know why I'm doing it.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "But it must, must be said.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "There was a tent.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "There was a midwife, a non-Jewish midwife.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] There was Hungarian policemen, one or two.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "They were very tall.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And the Hungarian police, they had a high black hat with feathers.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "We used to call them-- the featherman is coming!",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "We're standing there.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And there was a bench.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And very fast, they screamed, lay her on the bench!",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "Take off your panties!",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And spread your legs!",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And, and, and the woman came and examined me internally, if I hid something.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "And I was in such a shock because I didn't know that those kinds of examinations even exist.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "I was 16 and 1/2.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "I knew about sex.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "At least, I thought I knew a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "I, I knew how to-- babies are born.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "But I had no idea that you can be examined like this.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "And she said, clean.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And I know after this, I was in such a shock.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And after days, mother asked us once, were you searched, too?",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Because she knew that we are both virgins and, and to be examined.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we told her, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And we never, ever talked about it again.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And only recently when I see so much happening in life now, I started to, to think that this is how a woman feels who is raped.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I was raped at that time, not by a man, by an old, ugly woman, anti-Semitic woman.",
      "word_count": 17
    }
  ],
