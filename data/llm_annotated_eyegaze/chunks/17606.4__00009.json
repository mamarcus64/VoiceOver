{
  "stem": "17606.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Not as a Jew, because they ordered all the reserve officers from the Polish army, and all the officers, actually, from the Polish army are mobilized immediately, we report to the nearest military unit.",
      "word_count": 34
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "So I didn't go at the beginning.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But my group from the land-- [PAUSES FOR 4 SECONDS] the land of the army did give out the list of the officers.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "They surrendered.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "There was a battle of one surrendered, one group did not surrender.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "They was waiting for the orders from London.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "My group surrendered with the list.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "So they didn't take me as Jan-- Joseph Greenblatt, but as Jan Bednarczyk, who was the son of John and Maria [NON-ENGLISH], born in [NON-ENGLISH].",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "My mother was [NON-ENGLISH] and the village of [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "It's the outskirt of Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "They took me as-- and I went as Captain Jan Bednarczyk into the army.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Then I was military commander after the-- after the war ended, I was the military commander of the city of Gliwice, was occupied territory.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "It's the annexed territory.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "They call it liberated territory, because at one time it was Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And I was in charge of the city for Polish questions.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And I was also signing the documents for the so-called Greek Jews who were interned in Poland in the concentration camps and returning home.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And this, I used to sign for them.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I have a cousin in Israel now, in the [NON-ENGLISH], who met-- [NON-ENGLISH] about whom I was talking before.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She met her on the ship from Italy to Israel, and they started to talk each other, and [NON-ENGLISH], my cousin, said you were in Betar in Warsaw?",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Said, my-- I had a cousin who was one of the leaders of the Betar in Warsaw.",
      "word_count": 17
    }
  ],
