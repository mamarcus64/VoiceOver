{
  "stem": "1020.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 33,
      "text": "And he go back and he said, tell your friends and the other swines that we will follow.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 34,
      "text": "Well, I couldn't-- I couldn't go back the same path I went.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 35,
      "text": "But I had to go back to Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 36,
      "text": "When I came back, I used to belong to a Zionist organization, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 37,
      "text": "When I start to tell them what I was told in Germany, when I was slapped by going back, they thought that I'm bringing propaganda and I'm going to panic the Jewish people.",
      "word_count": 33
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 38,
      "text": "And nobody believed that somebody like me-- 16 years of age-- could come up with such a lie-- that is what I was told.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 39,
      "text": "But unfortunate, it happened that they did follow.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 40,
      "text": "And it was too late to believe.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We went home every Saturday afternoon, all the children go home to their parents.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We had to come back in the evening, up to age 14. 15, we slept in the orphanage-- but as of limited space.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "When we become 14, they located us to Jewish people.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Let's say, was a-- a woman, a widow-- she had an extra room, they paid for it from the Jewish community that she gave us-- like, me and another friend, not far from the orphanage, which we located.",
      "word_count": 38
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But food and all the other things-- clothing-- we had in the orphanage.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And at nighttime, we went to sleep over there.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Was your sister also placed in the orphanage?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, my sister was already four years older than I am.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But she had a bad life.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She had to get married at 17, because of the stepfather.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "A very Jewish orthodox life.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "A matter of fact, two-- two and a half-- two and a half years ago, I went back to Poland to my hometown, with my son.",
      "word_count": 26
    }
  ],
