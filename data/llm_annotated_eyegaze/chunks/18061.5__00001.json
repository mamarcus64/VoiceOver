{
  "stem": "18061.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 183.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "That from our own people, people who worked, since I was there until I escaped from there, I never saw that one of them were taken into the gas chamber, beside which some people, even my brother-in-law of mine, they need people in the second camp.",
      "word_count": 46
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And in that camp, they cut off in the morning, marching to the place where we had breakfast, cut off 20-30 people.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And they took to the second camp.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Now, many-- I want to mention that-- many, many in our camp, camp number I, in every barrack going out in the morning, we find two, three dead, committed suicide.",
      "word_count": 30
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Because they couldn't take any longer.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "They would string, with a shirt. spme of them, they had tablets.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "There were quite a number of doctors, which they had tablets with them.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I would like to mention also some of my friends, very brave of them, they were chosen to stay to work together with us.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "One of them was a close friend of mine who was also a barber.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Let me get that.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] I get you the name in a-- in a few minutes.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They choose him that he should stay and work, him and another one.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "That's separate, not all-- not both together.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They refused it.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And they run into the gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "One of them was Shlomo Dorfman.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And the other was-- [PAUSES FOR 3 SECONDS] gee, I don't remember the name of them, the--",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "To the gas chamber.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "When they-- when they took men in, they took off their clothes, and they run in with the men to the gas chamber, two of them.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    }
  ],
