  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "If I be the [? tent, ?] they come to [? the tent-- ?] the [? tent-- ?] it out, I'll be dead.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "I did it.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Everybody fight themself.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Who know?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My cousin, he took my bread.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He don't care about me.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I am hungry all day.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "All day, more than a day.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Oh, I don't-- I don't know it.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I'm in the [? tent. ?] I was afraid, and I did it.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Then when-- then when they took to checking who's got good for work, I went out, they took me to work.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "From this time on, they send-- they send out from Majdanek.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They gave us a bread on the way to go there.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where they send us.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They send us to-- to Skarzysko.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "There-- over there was a factory, ammunition factory.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "I go with-- with the truth.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Sometime the truth's not good to tell.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "I tell I'm a tailor.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I think I can work here.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "Maybe they need it for a tailor.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They give me worst.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "Was two camps over there-- A, B, C.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "The worst camps was C.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "They give me to C.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "Still in trouble.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Still in trouble.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "My wife was in different.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "She was in A.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My wife over there.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "First of all, [INAUDIBLE] first time, I went over there.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "They do the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "They make [INAUDIBLE], this and this.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Give you [? to dress. ?] Over there, it was more-- [? it's in ?] the camp.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Over there the leaders was Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Now, when you left Majdanek--",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Skarzysko was a longer time.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Longer time.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "What it look like?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
