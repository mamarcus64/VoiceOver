  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "And she also found a piece--",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, well, the older people were taken.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And so she always found some paper from chicory.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You know what chicory is, when you-- and she, and she put the chicory on his, on his cheeks so to give him color, you know, that papers.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Because we didn't have rouge or anything.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So it was the chicory that gave him healthy-looking cheeks and, and the soot that gave him black hair.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But well, the idea was not to.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But if somebody looked old and sick, they would take him.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
  ],
