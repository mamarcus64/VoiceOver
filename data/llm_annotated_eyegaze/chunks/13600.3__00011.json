  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And these four people of us, each one of us looked so typical Jewish, non-military type, that we had decided to divide our group of four, two and two.",
      "word_count": 33
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 9,
      "text": "And so not to-- the attention shouldn't be so obvious.",
      "word_count": 10
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 10,
      "text": "Anyway, so the police came up, a police officer.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 11,
      "text": "Secret police, [NON-ENGLISH] it was called at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Yes, this is abbreviation.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "A fellow took the documents, started looking.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "And I nearly lost my soul.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "Because I knew it could be end of my life.",
      "word_count": 10
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "He looked at me, and he said in Russian-- he said in Russian-- you're going to Lviv, and Lviv to Krakow?",
      "word_count": 21
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "Which means the other side.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "You want to over the border.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] I said, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 7,
      "text": "He shook my hands, and just gave a sign that he's Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Otherwise, after train, to jail, and the end.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "So you had to be lucky quite a few times.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "Not once.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
