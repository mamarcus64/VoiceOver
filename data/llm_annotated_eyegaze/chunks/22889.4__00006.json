{
  "stem": "22889.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "There's no Jewish people who live in that town, from this town, from 3,000 in a small town like that, with a beautiful synagogue.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They made a movie theater from our synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "With Talmud Torah, a Jewish school, cheder.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "You know, it was a very organized thing.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Not even a single Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Right after liberation, after I came-- so six of us, friend of mine, where you going to go?",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "There's no place to go.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Want to go back home, look for-- I don't know what happened to my mother, to my sister.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I knew what happened to my dad, and I knew what happened to my brother, because Ihad seen what happened to my brother.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So I want to go back, look for relatives.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But I couldn't go, because I had to go to American consul with my signing the papers.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "So six friend of mine went without me.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They didn't want to wait for me, not a day.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They went without me.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Soon as they arrive in Nowy Targ, stay overnight-- so the people came in, [NON-ENGLISH], they call themself Army [NON-ENGLISH], an organization, anti-Semite.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "They killed them all.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "They throw the bodies in the gutter, in the sidewalk, and put a sign on them-- Hitler won't finish you up, we will.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "We don't want you here.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Right after the war, 1946.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So if I would've gone, probably I would've been one of them, too.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Let's go back to August 30, 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And you were sent out from Nowy Targ.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I was sent out from Nowy Targ.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We left on the trucks, because it was only 13 miles-- 13 kilometers to Czarny Dunajec.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We all worked on it, for the Hobag worker.",
      "word_count": 9
    }
  ],
