{
  "stem": "7722.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I don't want to save myself, probably I had sinned.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "[CRYING] I'll take the punishment.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So in the night time, when it was dark, I ran away.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They were shooting at me, and it so happened I was lucky they didn't hit me.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So I ran away, and I was running and running and running.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't know where I came in at the woods.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I came in over there, and over there was a natural hole over there.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what you call this in English.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, not a ditch.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They call it different in English.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I forgot the term.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Cave like.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "So I went in over there and I was laying over there.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] What I was-- oh, yeah, I have to tell you.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You see, I forgot.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And the-- and this-- when we had the kerosene, I had to manage Ukrainian men who worked for me 20-- 15 or 20 years.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He was over there-- he was over there-- he used to pump out the system.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "He used to fill up the barrels.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "You see, we used to sell the kerosene by steel barrels.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Each barrel had 200 liters.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "We used to sell to the-- to the stores.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And they sold the-- by the liter.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "He was working for me, for us.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "His name was oh, god, my god.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "OK, I forgot.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "I cannot recall.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "A Ukraine, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I gave him away before that they made the ghetto, I gave him away a lot of things of ours-- I gave them away.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I also hid in his place-- I don't remember, 400, two-- two barrels or steel barrels, or-- or three.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I hid 400 or 600 liter of kerosene in his place.",
      "word_count": 11
    }
  ],
