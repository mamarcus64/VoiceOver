  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And they used-- you have to lay it one after the other, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They should blow up after the-- one after the other.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Because you have to take it a lot of-- it-- it was kilometers.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And so we did it.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And this was like, we blow it up.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And it was blow-- we were already on the base, and it was still blowing up.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And lot of people got killed in this business.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "But not by me.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHTER] I mean it.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And you know what?",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "They say, this guy is-- is lucky.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "I am a lucky guy.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "So everybody went to go with me.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "It wasn't luck.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, the big army was the Russian, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And the fighting thing, to blow up, you know, with-- we didn't have no-- should blow up the things.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You know, we didn't have no tanks.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have no-- but-- but they came-- we-- we came from one side and they came from the other side.",
      "word_count": 21
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And then we took him-- I was the first one with the-- he went to the-- the Russian again.",
      "word_count": 19
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And I took the place where-- where I told you, I tell you, the-- the seventh floor thing was there.",
      "word_count": 20
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Because I knew it.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I took for us, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "I-- The building with the elevator.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And there was this General over there.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "A-- a-- a General.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "He was from the-- from the-- Royal Air, the General from Lithuania.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So I said, you got a job for me?",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I seemed authentic.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "He gave me a job.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "So you know what-- what's now you got a job in Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "You got a job.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "But you don't have no pay.",
      "word_count": 6
    }
  ],
