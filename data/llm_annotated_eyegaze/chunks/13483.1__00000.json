{
  "stem": "13483.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My name's Michael Sheridan.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in London, 2nd of November, 1917.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "What does that make me?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "That makes me 77, or 78, 77, 78.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Young, yes. 78, young.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was born in a district called Whitechapel, in London.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I was born to Mother and Father, came from, originally, from Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "My father was a butcher.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "My mother was a normal Jewish housewife.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I'm one of seven children.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I am a twin.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I have two sisters and four brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Three of my brothers are now demised.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "I went to a normal elementary school in London, and left school when I was 14 years of age.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "I initially helped my father in his-- in his butcher shop.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "But I didn't like that, as I was interested in electronic-- radio at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "I went to work for a radio firm in Hackney, London.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "During that time, I became a Young Communist.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And I belonged to a Young Communist League, mainly because of the rabid anti-Semitism that was preached by the British Union of Fascists at that time.",
      "word_count": 26
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And I think, mostly young Jewish boys who I was surrounded by or lived near us, we all joined the Young Communist League, because it was mainly the party that opposed Oswald Mosely at the time.",
      "word_count": 36
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "During that time, the Spanish Civil War broke out in 1936.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "I wanted to volunteer to go to Spain, but my mother put her foot down on that right away.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] We had a premonition that war was going to break out with Germany, mainly because of the Spanish Civil War.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And I volunteered and joined the British Army.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "It was the 22nd of March, 1939.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
