  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "So those Nazis going, looking, I pretended.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "I bended out, pretending I'm washing something in the river.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And there were swamps.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't get on the bike to come near me.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And they left me and then I started wandering.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And I came across, was across to that village where I was born.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I knew the area.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I went to somebody I knew right there and then.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "She had maybe 10 barrels of water changing before she could see a person there.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "That's how I was covered up, and with that kind of smell and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "But, still, to let me in the house, she was afraid, so I had to get on going.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "She gave me something to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And a piece of bread to get along.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And then when my wandering started in the village.",
      "word_count": 9
    }
  ],
