  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "How old was he at that time?",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "If-- if it is, let us say, in 1919, 1919, and he was born in-- in 14 years earlier there, 19 and 14.",
      "word_count": 23
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "So he must have been 33 or 34.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So I and my brother, we were taking care of him.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "She-- that maid of ours was not, at at that particular evening, in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And my father didn't know what was going on with him because he had terribly high fever.",
      "word_count": 17
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "But at that time, they, they decided that since they were telling that Budyonny gave permission to, to the soldiers to take whatever they want in this--",
      "word_count": 27
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "--White City.",
      "word_count": 2
    }
  ],
