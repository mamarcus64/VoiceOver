{
  "stem": "21482.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I was with a group of girls, and he was with a group of guys.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And we met and talked together.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And then he started to come and court me.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And of course, we get married very young because my mother wanted to go back to Poland to get married.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "My stepfather went back to Poland to be-- His son was in Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He was in a sanitarium.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "He had tuberculosis of the hip.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I was a-- I worked as a clerk in the United Nations Relief and Rehabilitation office.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I was an interpreter.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I typed [PAUSES FOR 3 SECONDS] and some work.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I got married because I didn't want to go back to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "My-- Mark had a cousin came, and he had a little apartment, you know, in this-- we had-- we were living in buildings that were vacated by the German army.",
      "word_count": 30
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But again, everybody had a room.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So we had a small room.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And my cousin had a smaller room, and he only had a two-room apartment.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So in his kitchen, we got married.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Had four people who were standing with the chuppa, and I had just 10 people.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Enough for a-- enough for the minyan.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And it was a very small wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I got two wedding gifts.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I got a pocketbook-- a leather pocketbook-- from Mark's cousin, and a tablecloth from my girlfriend's parents.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I had a girlfriend who survived with her mother, and after the war, she found her father and a brother who survived.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "So there were a few miracles.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And of course, my-- my girlfriend, Sonia, and her sister survived together.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "So we were all together in the displaced person camp in Linz.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And we went to school.",
      "word_count": 5
    }
  ],
