{
  "stem": "18575.7",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I always attracted to it.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And I got one day 'Dear John' letter.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And that's the first time I got into depression.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I was shocked.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "I left everything.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "In fact, what happened-- I was working as a serviceman in Denver.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And the company I was working for went bankrupt.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "It was a [INAUDIBLE] company.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "It was a New York company.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So I and another fellow in the company bought out, at $0.10 on $1-- they gave it to us, you know, just to continue.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And we ran the service in sales-- small, small, on a small way.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But I left everything and I went to New York.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And of course, she was ready to get married.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So I was gone.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "So I stayed with my friends.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And I wound up in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I lived with my friend when I got greetings from the president for induction in Korean War-- in Korean War, yes.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Early '50s.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember it.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I went for examination.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I passed at A1.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And they gave you two weeks or three weeks to straighten out your business.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "So I went to New Jersey, where my cousin, that same cousin that found in [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They lived in Asbury Park.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Just to-- I quit my job.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I gave up my room.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I'm going to to stay with them in Asbury Park.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And one of their friends was a major in US Army, psychiatrist.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And his television went kaput, [? plat. ?] And I was telling him I was serviceman.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He says, can you look at my television?",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So I went to his-- in Fort Mammoth, which is right here.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He stayed there-- and fix his television.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And we are talking, and I said, I'm getting to the Army.",
      "word_count": 12
    }
  ],
