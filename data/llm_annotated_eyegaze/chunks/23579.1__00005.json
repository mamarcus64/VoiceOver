{
  "stem": "23579.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "The dinner was-- you see, my father-- we had two [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "This is farms.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "One farm was ours.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And the other farm was [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "From the Polack.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And my father was making cheeses, like from Holland, you have the round cheeses.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And they were coming from Vilna, from Warsaw with the trucks to take away the cheeses.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Now, he was buying meat for the Polish army.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So we had everything.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We had meat, there were cheeses, and butter, and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "There was not a thing that we didn't have it.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Was that your father's business?",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "That's my father's business was, right.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Cheese, and meat.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And we had the chickens and [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We didn't sell it.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "The meat was send off to the Polish army.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "The cheeses were sent off to the big stores in Vilna and Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But there is enough was for us too.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "We had enough, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "We had two kibbutzim for [NON-ENGLISH] in Novogrudok.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And my father and mother, they gave to them two houses, from [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And they were sending them bread, and butter, and cheeses.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "My whole family brothers, they were [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We had about three houses.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "So when the people moved out from there, my brother, [INAUDIBLE], said, Papi, we need the house for the kibbutz.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "They're coming from all over the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "We need a house.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "He said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "You know what?",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Take the house and make a kibbutz.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And that was a kibbutz.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "This was across our house.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And when come Monday, or Thursday when [NON-ENGLISH], you know, when everybody was coming to the market, they were sending him cheeses, and butter, and whatever they needed, and bread, everything.",
      "word_count": 31
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my mother loved movies, and loved reading.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She was reading a lot.",
      "word_count": 5
    }
  ],
