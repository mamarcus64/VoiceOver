{
  "stem": "9987.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But in high school, it was impossible.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Me, wanted an education, not going to the gymnasium, and I was good in math-- I went to a private accounting school for two or two and a half years.",
      "word_count": 30
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I finished accounting with top grades, first one in my class.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "In Krosno.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And after I finished accounting, I tried to get a job.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Impossible.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "The city had a population of approximately 12,000 people.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Out of this were approximately 3,000 to 4,000 Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "The Jews lived all in the center of town, and all the way around were Poles, Christians.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "All the small businesses, all the-- all kind of trades in town were all Jewish.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "All the way around, the Poles were-- had all different type of farmers and educators, and a lot of professions.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Jews, primarily, in Krosno, were involved in-- in grocery stores, tailor shops, barbers, shoemakers, and all kinds of other trades.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Well, I tried to get a job.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "But in Poland, at that time, nobody needed to keep any books for tax purposes.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "The only people had to keep books were big companies, or banks.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "They had a few Polish banks in town that would not hire any Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "They had one Jewish bank, that the only time you could get a job in a Jewish bank, as a bookkeeper or as an accountant, if their father was rich, he was a director of the bank.",
      "word_count": 37
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "Or you could get a job in a big factory only if their father was a director of the factory.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "Unfortunately, my father was not a director and he wasn't rich.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "So I couldn't get a job doing what I really wanted to do.",
      "word_count": 13
    }
  ],
