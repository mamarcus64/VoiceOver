  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I feel that's the best thing I've done, almost the best thing I've done since the liberation.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "But I don't know whether other people told you this story.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We-- About two years ago, all the 45-- I belong to the 45 Aid Society, which is the boys and girls who came over after the war, who are now helping those who need.",
      "word_count": 34
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We have decided to have a Torah written on behalf of us.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We all contributed X amount of money.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Last year, we had a lovely-- the guy who actually wrote the Torah is one-- a son of our-- one of our boys.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And he had unfinished letters, unfinished words.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He asked all of us, in turn, the names of our fathers.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Like, my father's name was David.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "So he had a [? dalit ?] and he directed my hand to finish this word which was missing, the D, the [? dalit ?] in front.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And we had a lovely, lovely day.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "It was in the-- one of the shuls in [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They're making a plaque, which is going to be hung in [INAUDIBLE] Shul with all our parents' names probably sometime this year.",
      "word_count": 22
    }
  ],
