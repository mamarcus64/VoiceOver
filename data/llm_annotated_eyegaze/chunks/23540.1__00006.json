{
  "stem": "23540.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I think we have two bags, that's it, I think.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "But I don't know how to come over there.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Maybe we come by horse, because I have the horses in the-- in the factory, you know, maybe they took us over there.",
      "word_count": 23
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "My husband, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "They went to ghettos, too, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Not together.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I'm-- we don't live together.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "But my auntie was over there.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] where's-- my husband's family was, too, in the ghetto, yes.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "His mother, his grandmother.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Can you describe to me what was the mood in the ghetto?",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] We have been, I tell you, very lucky when I read now about which-- which ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "You know, the book-- what's his name, I don't remember the name.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "It was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I mean, it was small ghetto, but nobody was hungry.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "You know, everybody managed to do something.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "We can go to the city.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "You can drink something.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "You know, it was still alive, I think, to the end.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Whatever it was.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "I mean, horse sausage.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "My husband wants sausage, and he realize later that this is from the horse.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "But it was still, was all right.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "Meat, we have everything.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "It was a bakery downstairs.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "I take two [NON-ENGLISH] over there.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "You know, bread you have.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "It was-- it was-- thank god we have everything.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], Jewish policemen.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And some Germans, but I never saw them.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Very well.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see them.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I mean, they have been a few of them in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "But nobody do nothing to me.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And that's it, very good.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "To work.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I was going to work, too.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Cleaning in the [PAUSES FOR 3 SECONDS] Luftwaffe commander.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Luftwaffe.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Offices, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "We leave early.",
      "word_count": 3
    }
  ],
