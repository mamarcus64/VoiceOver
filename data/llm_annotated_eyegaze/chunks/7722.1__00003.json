{
  "stem": "7722.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Really-- really-- really, where I did grow up, I did in Mizocz.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean, whose home?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Oh, oh, we were in that time-- my older brother-- my older brother, in between time, he married his first cousin, and he lived in [NON-ENGLISH], [NON-ENGLISH], he lived over there with his-- with his family.",
      "word_count": 36
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And-- and the rest, all of us, my older brother with his family, with three children, he lived with us, because we built a two-story home.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And they were-- in-- in this home, there were two apartments we rented out.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "In one apartment lived my-- my older-- the-- the second brother, he lived with his family with three children.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And in one apartment lived my younger-- the next to me, my sister Baila, with her-- with her husband and one child they have.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "His name was Yankel, the boy name.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I wasn't married.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I was single.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I lived, and my parents were-- were alive.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "We lived all together, except my older brother, who was-- it's approximately where-- where he lived from-- from Mizocz probably 230 or 40 miles.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know the real English term.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "In Polish or Russian, they called them a [NON-ENGLISH]-- my father was a wood specialist.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "What do you mean?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They came-- they were big companies who bought forest from the barons, from the big landowners.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They didn't buy the land.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "There were just the trees on the land.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they had to exploit it to make different kinds from these trees.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "My father could give-- he could-- let's say if the company that he worked for them, if they told him here is 20 acres or 50 acres of forest, give me an estimate how much this approximately can bring so we will know how much to offer.",
      "word_count": 47
    }
  ],
