{
  "stem": "25591.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And I-- I persuaded the president that it will be a feather in the cap of the University of Washington if they also will teach Hungarian.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And he was a very nice fellow.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "His name was Raymond Allen.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And he said, well, we will hire you as our young instructor of Hungarian language and literature.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Then my problem came to find students because who would want in-- in-- in Seattle, which is a Scandinavian area?",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we succeeded in-- in recruiting a number of students.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I think I was the youngest faculty member in the history of that university.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Started to teach, I believe, in January of '48.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I basically taught from January of '48 until the fall of '80, when I was elected to Congress.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I did a few other things in between, but basically I-- I was in university teaching for 32 years.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "For 10 years, first I established and I directed the study abroad program for the state university and college system in California.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I've been privileged to serve in Congress now for 16 years.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I'm about to begin my 17th year.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I view politics as public service.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I-- I realize that people are cynical about government and politics.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I am not.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I-- I-- I believe with Winston Churchill that democracy is the worst form of government except all others that have been tried.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And if decent and honest people don't get into public life, somebody else will get into public life, so I am passionately committed to public life.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "One of my great joys was that our-- our younger daughter's husband, who is a professional architect, was convinced by me to do this and was elected to the Congress of the United States.",
      "word_count": 34
    }
  ],
