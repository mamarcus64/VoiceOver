{
  "stem": "7600.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "He had a-- a-- a store where he made the coats and jackets out of fur, and to order, and some of them were not to order.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And they could-- you could go in there and  buy a fur coat or had one made to order.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He had a large sort of like a sewing room in the back of the store.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "The store was beautiful, as I said.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "It was in the nicest part, most like Rodeo Drive or Saks Fifth Avenue, Saks Fifth Avenue.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It was in the nicest part of the town, and that was his main store.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And then he-- then he had a couple of other stores.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "One was in [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Essen, ?] which is a little town right around-- not too far from there.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And [NON-ENGLISH] is another town around there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I think he had three stores.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "There may have been another one.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "We did very well.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We never had a house.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But we lived in a very large apartment and we had a live-in maid.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And while we were young, we had what they call a-- a French-- what do you call that?",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Somebody who took care of the children.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Forgot the name of it.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "If she-- if she could be, she was French.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And if not, she was German.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But mostly, she was French, a mademoiselle, that took just care of the children.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And they all lived with us.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "They each had their own room.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And as I said, my-- my grandmother did most of the cooking.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So the-- the one that took care of the house just did the cleaning [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And we had a beautiful apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And we had-- we used to go on trips down the Rhine on a boat, which I remember to this day.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They were wonderful.",
      "word_count": 3
    }
  ],
