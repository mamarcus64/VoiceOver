{
  "stem": "26790.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "But I want to tell you-- before I went to the Red Army, I was call up the Polish army.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I have to go in a different place, a different little town, where the Polish army officers was there.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "As I was coming there the Polish army, I saw the bloody anti-Semite, like was before the war.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Make me sick.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And I hear when they call up somebody to go to the office to fix the papers, they call two names, like Jim, John, something like that, two names.",
      "word_count": 29
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "When they call my name, they call only Ganc, not Mojsze.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Because Mojsze, you know Mojsze what was?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Mojsze the man which he brought in the, the Ten Commandment.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "They don't want to mention this name.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "They called Ganc.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I went to the office, the men.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "They asked me on Polish language, what's your name?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I said, Mojsze Ganc.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "He said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Mojsze Ganc.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Don't want it.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Don't need it.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "Sent me home.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Of course, I got a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "A few weeks later, in June, I got a Yiddish name.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "A few weeks later, I call again.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The same thing.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "But after that, they called me the Red Army.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "The Red Army, as I told you before, I was two weeks, only two weeks training how to shoot a rife, how to shoot a machine gun on the front.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I was on the front in Ukraine, and Russia, White Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Till 1944, our army was in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Our regiment was, was in a little forest not far from the town where I used to be-- I met Leja and she was coming from, from, from where she was going from [?",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Pole, ?] they may meet.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "In little town, I were there.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I, I, I, I was in a forest.",
      "word_count": 8
    }
  ],
