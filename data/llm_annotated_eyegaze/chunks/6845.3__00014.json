  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I'll come, and I will sleep next to you.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I went and lied-- sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I mean it's like, take one animal and another animal in a-- in a barn.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I mean, that was, what was it?",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "That's where we were, in some kind of a barn.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And so I waited.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And sure enough, somebody starts to come up to her, in the night.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "All I had with me is my red dish, my red metal dish, my eating [? piece. ?] That-- always, wherever we went, we took it with us.",
      "word_count": 28
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And what can I do for this woman?",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "So I started to hit her with my red metal dish.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And, and, and we're--",
      "word_count": 4
    }
  ],
