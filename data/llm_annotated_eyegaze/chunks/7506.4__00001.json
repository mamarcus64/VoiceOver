{
  "stem": "7506.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "Special circumstances like the diamond transport, all the people that were connected as by profession with diamonds.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "There were people with passes in their passports for Peru, for other South American countries. people that had obtained those passes in Holland through the Peruvian or other South American embassies by financial means as a hope of being able to be spared going to the work camps in the East.",
      "word_count": 51
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "There were people with Palestine [GERMAN], [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "There were people in actual fact that left Bergen-Belsen and went to Palestine during the war.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They were let go because at that time, Palestine was under British mandate.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Because Britain, after the end of the First World War, had the mandate to govern Palestine.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So the connection with England gave them the opportunity to be sent out of the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we and the other Jewish people that were in the Sternlager, we were there principally because of the diamond transport, but also because my mother had the British nationality at birth, as did her sister, because my Uncle Sam was not in the diamond business, yet my aunt was in the Sternlager, because of the British connection of my aunt.",
      "word_count": 61
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, I do not remember anyone that was left to go out of the camp to go to a neutral country.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "No, I do not.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Not at that time.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "No, I don't.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I remember at one time seeing other men, shaven heads, giving the communist salute, which is this, through the barbed wire.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We in the camp, we had our own clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "We had my overcoat with my number, which was sewn on, which was 2409.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "None of us had a number in our arm because it was not like the other camps.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "It was a special camp for special people.",
      "word_count": 8
    }
  ],
