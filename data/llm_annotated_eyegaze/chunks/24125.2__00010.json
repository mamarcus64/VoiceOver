  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So that was the-- up to the liberation, I would say, that I was with him.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "It was a small one.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Very small.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And thank God that they were forming then, so I could join them.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I would say, maybe a thousand or fifteen hundred.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Mixed.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Mixed.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, we had as-- as young as 17, 16.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "You know, so they were mixed.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Older were pretty old, too.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I would say, at least 50 years old-- well, I don't know. 50, 60.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Maybe they looked old, but they were old.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "No families.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I would say, half and half.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Or maybe, Russian-- more Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "More Russian, I think.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "From Russia and other partisans and killing Germans and getting a lot of ammunition.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "So these were our sources.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And clothes-- we tried to get from villages.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "From villages.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
