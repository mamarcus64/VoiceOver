{
  "stem": "19807.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 92.7,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "But we studied everything in Hebrew and the same subject we study in Bulgarian.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "So after that, a commission, we had to pass a test in front of a commission of the education department.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We always passed it with flying colors, even though we were taxed, studying both subjects, most of the subjects in Hebrew, as well as in English.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "It was not like in America when kids go to cheder, and after the age of 13, luckily if they continue after that.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And I hope my grandkids continue after that.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "But in-- in Bulgaria, you spoke Hebrew fluently.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "You-- you spoke it.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "You-- you conversed with it.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "When teachers came into the room, they spoke to you in Hebrew.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So the subject [NON-ENGLISH], the history of our-- of-- of our people, we studied in Hebrew.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Tanakh, the Torah, we studied in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But we did not study it phonetically here, just to remember it by memory.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We knew.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I can recite to you today, like, when the-- Isaiah.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Can tell you right now, very quickly, [HEBREW].",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That's 60 years ago, 58 years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Very little, unfortunately.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Very, very little.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I was fortunate to spend only one summer with my paternal grandmother.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I always resented the fact that I had no grandparents.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "By the time I was born, my maternal grandparents had passed away.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And my grandfather had passed away.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Although I very, very vaguely remember my great-grandfather, that we called affectionately Papuchi.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Bulgarian.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Bulgarian.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Very well-educated, my mother was a teacher.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "She was one of the first ladies to-- to graduate high school at those days, which was very, very progressive.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Esther.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Esther.",
      "word_count": 1
    }
  ],
