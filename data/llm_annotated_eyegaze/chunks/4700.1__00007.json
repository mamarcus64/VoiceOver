{
  "stem": "4700.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "So there were a lot of Jews who were really on the bread line in Prague.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And it was very, very difficult.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "There were-- after Hitler came, then after the war broke out, there were-- practically every week, there were new laws what we weren't allowed to do.",
      "word_count": 26
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "We got smaller rations.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "We only got the staples and in smaller quantities.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "We were only allowed to show up in certain shops, after a certain time, when practically everything was sold out.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, 5:30 or whatever. 5 o'clock in the afternoon.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "So it was rather tenuous.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I must say, a lot of our neighbors were very decent.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They'd bring us things after dark, maybe a fish or maybe a piece of meat or maybe four eggs.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Because they didn't have much either.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "But they still could go to the country and bring-- if they had relations somewhere--",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "--they could bring things in.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Whereas we couldn't leave the city.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "There was a curfew at 8, and we were not allowed to leave the city.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "We were not allowed to use public transport.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "At first, only in the last carriage and later not at all.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "We were not allowed to enter parks, sit on a bench, and go-- of course, go to theaters, concerts, or anything like that.",
      "word_count": 23
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And people in Prague complained they can't get into the church on Sunday, because the bloody Jews listened to the music.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was the only place they could go to.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And there was always beautiful--",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Organ music.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "--organ music.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So the Jews went into the church.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So instead of concerts, they used to go 10 o'clock in the morning to the--",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "There were three or four churches that had good music.",
      "word_count": 10
    }
  ],
