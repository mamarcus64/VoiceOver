  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "But it was always with one ear open, one eye open, because you didn't know where else you're going to be the next moment, because we were always in hiding.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "This was a hiding element of three to four years for Jewish children all over Europe, my country being Belgium.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I did not know nothing about my mother and father.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Only after I met them.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And then we-- and we got together.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And then I'm going to tell you now a little bit about the two of them.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Because they are dead, I must speak for them now to keep the Wagschal name and the honor of them also having been Holocaust survivors in this beautiful foundation and for the world.",
      "word_count": 33
    }
  ],
