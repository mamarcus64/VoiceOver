{
  "stem": "26576.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "The French police were not nice at all.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And so we were sitting and waiting.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "We didn't know what will happen to my father.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "We didn't know where-- we couldn't move anyway without-- so we were sitting, like and waiting on what's going to happen.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "Once again, from the start-- we had to start again from the beginning.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "At this point of time, I studied French.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "I went to [FRENCH] Francaise, because I thought I'll need a language.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "And I also went to the Ord.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "Ord was doing a wonderful job.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "They we're training people without-- without a trade, they were teaching.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "There were engineers.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "I, you know went for a dressmaking course.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 48,
      "text": "I never had a needle in my hand, I knew that I need some kind of-- I'll need something when we come to wherever.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 49,
      "text": "So I went and I finished.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 50,
      "text": "And it was very-- later on in life, I found it very useful, because I used-- when we came to Australia, I worked.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 51,
      "text": "In meantime, we were already-- my father-- one day, completely unexpected, my father turned up.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely not.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know where-- my mother was crying bitterly, you couldn't get her out of the room.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We were living in a terrible, small-- you know, in Paris, in a hotel room.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "In a very cheap hotel.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "In one room.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And we were sitting and waiting.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And out of the blue, my father turned up.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "You see, this is the point.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He went to the Joint, and he was told that we are-- we were living in a real [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We had already, at that stage, we had already a little room.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And-- and we were very happy.",
      "word_count": 6
    }
  ],
