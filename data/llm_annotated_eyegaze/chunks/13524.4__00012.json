{
  "stem": "13524.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "We had to undress, and they were looking through, walking in between us.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Who has not been still fairly well-padded was taken out on the side.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And women whose breasts were already flat and hanging were taken out of the rows of people and put aside.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Lots of people were taken away, and they sure did go to Auschwitz for extermination.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "Luckily I was left alone.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "But of-- one of the Blockalteste, whose daughter was young girl-- her name was Lillian Ingber.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And the Blockalteste was Lehrer.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "It must have been second marriage, because Lilke Ingber was her daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "Or maybe she was her niece, I'm not totally sure.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Look, it's 50 years ago.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "All I know that Blockalteste felt so sure that, because she's Blockalteste and she was already going back to the block-- they were organizing us-- she went through back to see if that girl is taken to live, that she was not taken to Auschwitz.",
      "word_count": 45
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "And they caught her.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "One SS took her.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And into the Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "She didn't survive.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "She went to Auschwitz while the young girl, to this day, is alive, lives in Canada.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You know, moment like that, it just-- that lives with me.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Lots of moments, horrifying, live with me.",
      "word_count": 7
    }
  ],
