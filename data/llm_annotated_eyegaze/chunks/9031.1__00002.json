{
  "stem": "9031.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We can't understand what happening.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And we can't go outside.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And we need that have-- my mother, she can't go to buy something-- food.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It was a-- terrible thing.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we can't-- we kids, we can't understand what happening.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Why did she-- we have this to-- this-- this experience for us?",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We have a house for us family.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "In this house-- this was a big house.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "In the same house it was lives my father's parents and my father's youngest brother, with the wife and kids.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "In-- in this house was 11 people.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We have four rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My grandmother, she was two rooms.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And my father's younger brother-- he have three rooms.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "This was a terrible condition.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We did not have what to eat, what to drink.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We did not have place where to stay.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Because a lot of people-- they-- they did not have place to came in.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "The Lithuanian, in this place where we was, where the-- the German is, they close-- they have the special place for the Jewish, in ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "The people was more than apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And somebody is outside, and inside.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And we was-- we came in ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We was-- did not have where to live.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And we was-- the first two months, we was living in a place where neighbors-- they gave to us a room, where they hold it before food, in this room.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "But we was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "It's not outside.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "It's something.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "We have something on-- from-- from the raining, from the sun, something to close us, to be in life.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "This was like-- in Yiddish, I can say a [YIDDISH], a special place for food.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It's not apartment.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "It's nothing there.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Only-- only food was, before.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "But later on, they did not have nothing.",
      "word_count": 8
    }
  ],
