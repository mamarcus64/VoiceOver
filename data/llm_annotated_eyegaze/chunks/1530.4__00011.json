{
  "stem": "1530.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 21.3,
  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "But we're very proud of him.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And he's a beautiful human being.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's--",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "--it's--",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "--it's, it's because I am really so Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Even-- I'm trying to deny it, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "I mean, I-- my heritage was beautiful.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "I can't live like that anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "But my heart and soul is totally Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "And on--",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but I didn't go in.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I waited outside.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "I never saw a movie.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "I-- if there is a Nazi appearing on television, Bob cuts it off because I can't take it.",
      "word_count": 18
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "I can't take anything that has to do with the past.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "I am totally locked in.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "It's very difficult.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "But I can't come out of myself.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "He's a friend of my brother's and my sister's.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And I-- no, I never would read anything about the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "Izabel said, well, why don't you come with me?",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "Yesterday they had a meeting for Anne Frank.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "I said, I don't go anywhere.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "But I am going to appear today.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "It was so difficult.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
