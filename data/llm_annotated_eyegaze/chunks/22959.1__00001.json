{
  "stem": "22959.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We were a very close family, very close family.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My father spent lots of time with us, teaching us, talking to us, visiting with us.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My mother was also a very intelligent, nice woman.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "She spent-- spent lot of time with us.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Helping us to read books, to enjoy the books, to analyze the books.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Helping us certain activities in our little town.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Like giving us dancing lessons, taking us to different places.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "It was a nice family life together.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we did have lots of activities.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We spend lots of time at our Yiddish school in Zdzieciol, where we participated in different-- in shows, in-- in performances, and so on, and so forth.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I had good friends.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We did lots of things together, we were skiing, skating, belonging to a chorus, walking around-- really enjoyed.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But after I graduated from my Yiddish elementary school, it was time to move on.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And my aim was to attend a gymnasium.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We did not have a gymnasium in our town.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "A gymnasium means, high school-- equivalent of high school, plus junior college.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But there was a beautiful gymnasium in Vilna.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I could not afford to go to Vilna, so I applied for a scholarship, and I won a scholarship.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And I cannot tell you the joy, the happiness, what my family experience when I won the scholarship.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And I left for Vilna, and attended the Real-Gymnasium in Vilna.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It was a Yiddish Real-Gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Vilna was a beautiful city in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Vilna was considered the cradle of Jewish literature.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "In Vilna we had a Real-Gymnasium.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "In Vilna you had the YIVO, the Yidisher Visnshaftlekher Institut.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Jewish Scientific Institute, where research work was going on the Jewish language.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "In Vilna we had the-- the greatest library in Poland, Strashun Library.",
      "word_count": 12
    }
  ],
