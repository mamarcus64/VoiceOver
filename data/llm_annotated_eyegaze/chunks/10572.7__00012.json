  "elapsed_s": 1.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And something that occurs to me that I never mentioned and I think was a real important turning point for me.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "When I first came, after basic training, in Camp Lee, I had a-- I was assigned to a new prisoner of war camp in Camp Lee.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And the first time I went through the camp, I interrogated-- just verifying records for those PWs.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And I was interrogating them.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And, and I was very firm with them, but not-- never taking advantage of the fact that they were prisoners.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And right at that time, fortunately I had an old friend of mine who was a famous psychologist, a professor who has taught at the University of Frankfurt, Professor Dr.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Kurt Bondi, who, at that time, was professor at William Mary in Richmond, Virginia.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And he and I had been in Buchenwald together.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And he and I had been in the youth movement together.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And he had-- he could have been-- age-wise could've been my father.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And one day, I went on-- over the weekend, I went to William Mary [PAUSES FOR 4 SECONDS] and talked to him.",
      "word_count": 22
    }
  ],
