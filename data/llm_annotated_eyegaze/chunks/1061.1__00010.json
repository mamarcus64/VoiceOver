  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "That was the biggest mistake I ever made, because very soon-- it was a very hot, this September, very extremely hot.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "We were overdressed because we wore all that stuff.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "Mother said, you know, it might be cold, whatever.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "I had the worst blisters and had to take my shoes off.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "And the PS to this whole story is that after being shot at by the German airplanes that we lowering-- lowered themselves over forest, after being caught-- caught in the crossfire, we came back and found out that nothing happened in town, absolutely nothing.",
      "word_count": 44
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "One bomb fell somewhere that didn't even destroy anything.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "And that was sort of like a-- I don't know if it was a reawakening, but maybe this was a sign that things are not what they seem to be, or whatever it is that you are expecting might not really turn out that way, because in fact, that September 1939 is when whatever was planned-- anti-aircraft were digging ditches-- whatever was done, none of that was used.",
      "word_count": 68
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "People were killed by whatever happened that was not expected.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "And we came back.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "And-- and--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We went back to our home.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And everything was left.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "In fact, we ate and left everything, because you know, the evacuation was announced.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And-- and we came back, everything was there.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Everything was there.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "The only thing is, of course, that we lived on the main street.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And this is 1939, September 1939.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And we were allowed to live on that street for a few more months.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "There was no special clothes in ghetto organized in Starachowice, but what they did is they cleared that street, which was called [INAUDIBLE], named after the Polish Marshal Pilsudski.",
      "word_count": 29
    }
  ],
