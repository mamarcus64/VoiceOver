{
  "stem": "12022.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I was little when I was in-- in Nacza.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "When my father died, we used to go every day to shul to say Kaddish, my father.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I remember we always used to say Kaddish after my father.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "In-- like in Eishyshok?",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In Nacza, not always.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "When we been little, then always was a problem with a minyan.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "When we been older, then it was a problem with a minyan on our kids was bar mitzvah.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "We had half a minyan in our house.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Then they brought the Sefer Torah in our house.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And they used to make in our house the minyan.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "It was easier to make a minyan.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And when we left, they say, meaning the ghetto-- they forced us, when the German came in, they forced us to go to the ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "We took the Sefer Torah with us.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And we used to make a minyan during the-- when we was in the occupation-- in the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Every day we used to make a minyan, and everything was [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "In Nacza, about 10 families.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, about average about 50.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "A shochet.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "We have a shochet, not a rabbi.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Shochet was Lazer Feldman.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "He got [? killed ?].",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I remember what-- he went like, I think, Purim to shul.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And then he come back.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "He used to have asthma.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And then he come back.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if he got sick.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And he get pneumonia.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And they took him to a hospital in Eishyshok.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "And he been for-- for a while down there.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "When he die, Pesach, the seventh day of Pesach was my-- it's yahrzeit.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "I used to say, always yahrzeit.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "Still, I'm saying Kaddish now after my father, the seventh day of Pesach.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In Eishyshok.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My mother has a little store.",
      "word_count": 6
    }
  ],
