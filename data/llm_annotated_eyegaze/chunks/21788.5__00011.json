{
  "stem": "21788.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We left Shanghai, just like the Jews left Israel to go to the promised land.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And we left Shanghai to go to the promised land.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And we had-- some of the people knew about this and had matzoh on board.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We had haggadahs, furnished by the Armed Forces on board.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And we actually had the first night and the second night Seder on board, with white tablecloths.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "There actually was an altercation.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "The dining room was also used for showing movies at night.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "Those two nights, there weren't any movies, and some people complained.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "You know how it is.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "But those were very, very nice days aboard ship.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "Had a good time.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Had good weather.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "I understand there were some of these ships, at a later date, that had to work in the kitchen.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "They actually had to paint some of the superstructure.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "We were passengers, and we had a good time.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "We arrived 15 to 18 days later in-- the date escaped me, but it was April of 1947, in San Francisco.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The last night on board, we stayed up.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "We had to see the Golden Gate Bridge, which we saw at about 4 or 5 o'clock in the morning.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And it was golden.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And then, we landed in one of the cays in-- in San Francisco.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We were met, again, by the American Allied Campaign Society, and we were given quarters in hotels.",
      "word_count": 17
    }
  ],
