{
  "stem": "1550.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember the exact time.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We arrived at home.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "On our street in the middle of the street, there is a big pile of Torah scrolls and curtains and all stuff from the synagogue.",
      "word_count": 25
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "It was all burning.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "A big fire, you know, all these Torah scrolls and prayer books, a big pile.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "It was all burning.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "But there was nobody there.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So these people had thrown all this stuff on the street.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "It was burning.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "So we knocked on the-- by the way, the apartment house door was locked.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So we rang the bell.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "The janitor came.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "She unlocked the door, and she let us in and she locked the door again.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And that was what saved us.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "What she did was, she locked all the doors.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And then some gang-- some of those gangsters came and said-- that's what we heard afterwards.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "They rang the bell and said, what's the-- are there Jews living here?",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And she said-- she was a Christian.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "She's said, there are no  Jews living in this building.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "Go away, go.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "Just jump in the lake.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "So they went away, and she locked the door again.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "So the door was locked all day long.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "And that's-- nothing happened in our house.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "That is not quite what happened to one of my cousins, who's all their furniture was thrown out the window, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "Have you ever heard of a thing like this?",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "Their furniture was thrown out the window.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "You know, it's unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "Anyway so that was-- that was the 10th of November.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "We used to always refer to it as the 10th of November.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "So after, after the 20th of November all Jewish businesses had to close and all the stores were smashed and all the synagogues were burned and smashed.",
      "word_count": 27
    }
  ],
