{
  "stem": "26358.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I brought him in hospital there in the ghetto, and I left him.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Well I need to come back.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I came back to the concentration camp, back where I was.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And I need to go see my sister in the other camp.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "She was [NON-ENGLISH] camp.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Was easier.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "That was an easier camp there.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "Was not so strict with us, where I was.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "There was more children too.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "As I told her-- no, I went Wednesday.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "That was Tuesday night they was killed.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "Wednesday I [? no ?] went.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "I came back and I was exhausted.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And the girls want me to eat something, and I can not eat nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "Thursday morning I got up and I told the boys and girls to cover me.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And they covered.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "They said, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "Everything be OK here.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "And I went to see my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And I told her, my brother's in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "When they go-- they used to go with the truck once a week to the ghetto and the concentration camp-- to both.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "It's to bring clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "The Germans used to bring pictures.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "I used to take home stuff.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And I said very loudly, is I told her what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "I no ate from Tuesday 12 o' clock I don't touch nothing Wednesday.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "Thursday night I came back to my sister, and walking in the kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And I fainted.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "[PAUSES FOR 3 SECONDS] My brother came to help.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "Picked me up.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "And he went and made me a shot of whiskey to bring me back alive.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "He say.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "Don't cry.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "Nothing help.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "I'm around, and I watch you.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "And I say, nobody can [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "My mother and my father.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "And I was very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "Like a week nobody can talk to me.",
      "word_count": 8
    }
  ],
