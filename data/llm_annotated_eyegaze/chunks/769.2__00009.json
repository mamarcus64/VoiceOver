{
  "stem": "769.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "Anyway, I went to school, to the called the institute-- the Institute for Agriculture Institute.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "I was learning there and I feel very good, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "I got a shirt-- I sold it.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "I got a tie-- I sold it.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "Used to leave-- hungered a little, or we got a roof over our head.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "We sleep like in shelves there.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "I remember like now eight people in a small room, with the cupboard, the clothing cupboards and maybe a small-- Me look for friend.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "Me got Ukrainian friend, Jewish friend.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "There were only two-- we feel sorry for the war was now coming, and we wanted to fit into the people.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "We've got no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "We wanted to live.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Probably yes.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I said this to somebody, I have a brother in America.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "After the war I will go there, and they're so good in America.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I said this.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Probably I said this one.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And Ukraine girl, I still remember Mashosja her name, she wanted to marry me.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I rejected, because my mind was to go to America.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "She is Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And I rejected her-- I rejected even to go out with her.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "One night in the time, sleeping in the dormitory, the dormitory, I'm sorry, the pronouncing is--",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Then come some, in civil clothing, and they wake me up.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "You Peretz Rotenburg?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Come on down.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Shh, he said, don't say nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Shh-- it's the middle of the night.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I say, what?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Come on down.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And when I went down, and looking down, I saw he with a gun revolver-- and the Russian, the undercover there with gun, with revolver was so bent there, like from leather made or some-- not a [INAUDIBLE], leather, but holding the gun there.",
      "word_count": 44
    }
  ],
