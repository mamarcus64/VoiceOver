{
  "stem": "9908.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "We did the sewing that she can go in the morning to the shop, bring her production, and she gets her soup.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "How old was your mother then?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "48 years old.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So now we are in ghetto for two years.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "You-- you meet people today-- even in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We went to work.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And you meet them today, feet like that, swollen, full of fluid.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I-- I met some people from our city, or even from Lodz.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They said, oh, who are-- I said, how is he?",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "How is he?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Today you talk to them, tomorrow you find out he's dead, because there was no food, and the water accumulate.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "A lot of people died of tuberculosis.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "So now we are in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "We're doing all the work for my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "She always used to tell me-- to tell me, [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "It means, you are a saint, what you're doing for me.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I did more, because my sister was still young.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And I was the oldest, so I felt I-- I had the responsibility.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "So all of a sudden, my mother took sick-- very ill.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "We went-- a doctor came to the office, to the house-- Jewish doctor.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And he said my mother has fluid in her lungs.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "She-- she will not survive.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "So one day, I brought over a lady.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "I don't know if she was a nurse, but she did it.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And she-- and she sucked out fluid from my mother's lungs-- yellow fluid.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "And it was TB.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "It was tuberculosis.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "I saw this water.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "I-- and she was sitting on her back.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "She was sitting, and the needle was here.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My sister and myself, we ran to a store, and we bought her a apple to eat, to refresh herself.",
      "word_count": 20
    }
  ],
