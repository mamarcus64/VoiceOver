    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "And the night, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "For one week in the morning, then--",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "--one week in the nighttime.",
