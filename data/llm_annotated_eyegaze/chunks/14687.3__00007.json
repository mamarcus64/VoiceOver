  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I suffered too much, and I cried too much.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And where I'm still crying, especially when I came out from the concentration.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "They used to see me at night to tell the stories.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I used to cry all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Even once I was in Rome, in the bicycle, and they see me.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "They say, why you crying?",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "They told me in Italian.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "I said, because I was there.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Because they were showing their arm, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I said, I was there.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "I can't believe it-- such a beautiful girl like you.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "I said, yes, I was there, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "Can you just tell me, during the time that you were in the second camp, which was called--",
      "word_count": 18
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Is that-- what do you call?",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "To-- to 'Stelevic'.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "What do you call?",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Auschwitz.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "To-- what do you-- 'Stelevi'-- in the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "They took us in the factory.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "The camp, yeah, in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No, what is the name I told you there?",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
