  "elapsed_s": 1.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "When the war broke out, he was a commandant of all security forces in Warsaw, police, [? open, ?] secret, et cetera.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was arrested by Gestapo, because he created some conspiracy in the police.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "The Germans discovered it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And he was already arrested, May 1940, and sent to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Because at that time, Auschwitz already existed.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Spent in Auschwitz 11 months, and then was released in 1941.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Joined underground immediately and worked through the end of the war in the Polish underground.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "When the war ended, of course, he was afraid of his life.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "Because of the communist regime-- went abroad, eventually came to the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "My father, I hardly remember him.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Only I remember my mother, who, as far as I remember, died 1934 or '35.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "OK, we'll stop here.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE]",
      "word_count": 1
    }
  ],
