{
  "stem": "14320.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "You know, the toll-- the-- the-- And when this was melted, they made little boxes-- wooden boxes and attach with all kind, you know, batteries and-- and they put this toll in these boxes and this was the-- the bomb.",
      "word_count": 40
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And with those bomb, they went on the railroad at night, under the tracks, they put under the tracks.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And when the-- the train from Germany went every hour on the hour with ammunition, with soldiers, with food. and-- and the partisan put those bomb under the tracks, and-- and they explode.",
      "word_count": 33
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I told you from beginning, we have to go at night and find food.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And then after a while, the Ukrainian people support us.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And one night I saw two airplanes threw a lot of things like clothes, some kind of food, you know, the Communist.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And we survived.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Potatoes in the morning, potatoes at night.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Twice a day I cook potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Potatoes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have meat.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "We didn't-- from beginning, just potatoes, but no salt.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Potatoes and water and that's all.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "From beginning, we-- we make fires and bake potatoes.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "This was our food.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "We didn't have bread, just potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "Very few.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "We made the-- yes, from logs.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You put like this and this-- and this was our-- they called the [NON-ENGLISH], you know, tent.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "There was groups-- a lot of groups and all kind commanders, Russians.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Russian commanders.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And we have the headquarters, you know, they used to come every evening to tell us what is going on on the front.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They have radios too.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Very disciplined.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Fine.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "The best.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "There were not much discipline.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "This is to take care of the guards.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Some people, you know, to change guards every two hours.",
      "word_count": 10
    }
  ],
