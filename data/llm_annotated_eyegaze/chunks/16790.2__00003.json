{
  "stem": "16790.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "A lot of the people were not seasick, so there were a lot of people out and they had these-- these-- these deck chairs and you could sit there and you could get-- they would serve bouillon.",
      "word_count": 37
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I remember drinking some bouillon and eating crackers.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And I'd check up on my mother and grandmother and sister, oh, maybe two or three times a day to see- see how they were doing.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And they were moaning and groaning down-- down in the cabin.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They weren't happy at all.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "But they-- my sister still gets motion sickness.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know about that.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't one of them.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] I didn't do that.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I-- I do remember finding a toy and-- and throwing it overboard and thinking that, I wonder if anybody will ever find this before it sinks.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But that's-- I think that's the only mischievous thing I did.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "It was a little toy wooden mallet.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "But I didn't know about the soaping, no.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was-- yes, I was aware of him.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And I saw him walking, but I-- he's not going to bother with a seven-year-old child, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He was not a very tall man, I-- I remember that.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He looked very distinguished.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "But so did the other officers on the ship.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "But no, I had no dealings with him.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I did look in on the religious service.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to see what-- what was going on.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was just that I-- I went in.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was in in one of the-- one of the rooms.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "It was not in the main hall, but it was in one of the side rooms.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And it was a morning service.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I did not count toward the quorum because I hadn't been bar mitzvahed.",
      "word_count": 14
    }
  ],
