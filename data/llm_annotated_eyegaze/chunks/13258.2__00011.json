{
  "stem": "13258.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "There was-- had been a, a straight hit in the lumberyard.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And there were dead horses on the street, all over the place.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And the place looked just terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "And we drove through a sand desert.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "We came to a town where we were able-- Modliborzyce, where we were able to buy some bread and slept overnight in the car.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Because as we were on the way to Lublin, we were told they don't let any people into Lublin.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "Lublin is being bombed by the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "It doesn't make any sense to go there.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So we drove us to a town called Bilgoraj, B-I-L-G-O-R-A-J-- notorious.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "All the Jews from there were killed later on.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "It was a predominantly Jewish town.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Somebody took us in for a few hours to wash up a little bit.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And then we took a nightmarish train ride on a narrow-gage railroad on platform cars, which were shaking like the devil.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And there was nothing to hold on to.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And we ended up in another notorious-- later place, called Belzec.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That's where we met the main railroad.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "There, as we crossed the street, a car passed by and stopped, and a guy came out and was calling my father's name.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was at Jew who was an officer in the Polish intelligence.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "He had been in the Polish intelligence in the war against the Soviets.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And those veterans had gotten later on, regardless if they were Jews or not, some privileges.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And he had gotten a license to buy scrap iron from military sources and from government places and sell them.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "So that's how my father knew him, from the scrap-iron business.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "But when the war started, he had been drafted again.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "He was English intelligence.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And he said to my father, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Guttmann, Dr.",
      "word_count": 2
    }
  ],
