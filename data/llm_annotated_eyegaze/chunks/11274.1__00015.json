  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And on the deck there were benches there and you had to pay something to go and listen to the, to the concert.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And he dedicated it-- every Wednesday that was in the fall usually-- every Wednesday he dedicated all of the money to the poor people.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So we were allowed to go to Krynica, for example.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And we could-- we didn't have a radio, and we didn't have a gramophone, so there wasn't much music.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So this music-- and why we go, we went to Krynica, they played, they played music there, there, too, and in one of the places where the mineral water was.",
      "word_count": 30
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Can you spell that for me, Krynica?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Krynica, K-R-Y-N-I-C-A.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "You would pronounce it 'Krynicka.' But the c is pronounced in Polish as 'Krynitsa.'",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
