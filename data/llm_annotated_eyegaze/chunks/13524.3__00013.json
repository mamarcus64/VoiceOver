  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "From then on, my father went very depressed, didn't want to go to work, didn't want to eat.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "The bread which he received, changed for cigarettes.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "And that was very tragic for me, to watch that.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "It sort of continued for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "When he did go to work, he used to fall over, because he has not eaten.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 29,
      "text": "He was beaten, he was kicked.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 30,
      "text": "He developed ulcers on his leg, varicose veins, ulcers, which in best of times is difficult to heal.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And he just couldn't go to work anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We're just going to stop and change the tape.",
      "word_count": 9
    }
  ],
