  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They propose me we-- we will married you here.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "What, we will find a girl.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "How it will be, no-- I was thinking, no, I-- I want to see, see to go what happened at-- maybe something is alive, maybe something-- somebody I will find.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And I stay with him a couple weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Then I was thinking, let me go.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And that-- when I was leaving from the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "It was a lady-- she was working-- she was working in hospital, how it's-- a med-- a med--",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Technician, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And she gave me- I told her what I will through, Kiev.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She give me address to her sister in Kiev.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I say, I will be in Kiev-- no, to have enough time like this, to have others to come to stay for a one hour, it's good, too.",
      "word_count": 28
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I t-- I told her, yes, I will come to your sister.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And I'll give you-- no, I'll say hello from you, and that.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I came to Kiev, and I come to-- I find her sister.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And I told her what I'm [INAUDIBLE], that I was in [INAUDIBLE], and I saw your sister.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Then, you know how it's-- begin to talk, begin to talk.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And she said, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I have a girl.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I know her.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "She's working with my husband, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "She's working on the railroad.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I say, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Meet me with her.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And one day, she met-- we went and she-- and I met with my wife in Kiev.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I tell-- told her the story-- I'm in cre-- crutch-- cre-- crutches.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "No, I'm young.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "No, I cannot work.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "It's very, very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And the first time, I remember the moment when she was working the railroad, and I told her, I will-- I will go with you.",
      "word_count": 25
    }
  ],
