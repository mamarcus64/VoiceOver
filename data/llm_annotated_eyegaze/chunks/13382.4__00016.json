  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "Can you accommodate me for one night?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "It's funny.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "He said, you know, I mean, such a good friends.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "And they're sort of-- I say, I promise you, it's only one night.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "I won't cause you any trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "They say, the trouble is not you, but the trouble is our son.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "I said, what's your son?",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "The son is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 20,
      "text": "And also, we are parents.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 21,
      "text": "Young people do [? this. ?] We couldn't prevent him.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 22,
      "text": "And if he comes home, because that was his room and bed.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 23,
      "text": "But on the end, I stayed overnight there.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 24,
      "text": "OK.",
      "word_count": 1
    }
  ],
