{
  "stem": "2833.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 62,
      "text": "And the girl, one girl in our group who was from the village where we stayed overnight on-- outside, and her parents, who were a mixed marriage, were living there.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 63,
      "text": "And she begged us to help her to get up to the little window and-- so she can slide through, throw herself out on the other side and get away.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 64,
      "text": "And we were scared that some others, you know, in other cars or so would see her.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 65,
      "text": "But she said she doesn't care if they shoot her, but she, she has to try.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 66,
      "text": "So we did.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 67,
      "text": "Four of us put our hands together, said we are strong.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 68,
      "text": "She wasn't that heavy anymore anyway.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 69,
      "text": "And she made it.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 70,
      "text": "She slid through, dropped on the side.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 71,
      "text": "And after the war, I met her in Prague, and she said she went to a house, which was facing the train.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 72,
      "text": "And I said, you know, we thought we saw a-- all of a sudden, a little light and then dark again.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 73,
      "text": "Somebody had opened the door or whatever.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 74,
      "text": "She said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 75,
      "text": "They took her in, and the next morning they called her mother over.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 76,
      "text": "And her mother took her home and she was hiding her till the end of the war.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 77,
      "text": "She had gotten away with it.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 78,
      "text": "We got to Mauthausen.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 79,
      "text": "And Mauthausen is up the hill.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 80,
      "text": "You have to walk quite a long time up to the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 81,
      "text": "So we were not in the best of shape anymore, but we managed.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 82,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No shoes, no-- still the same thing.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "No shoes.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "My first shoes I got when I-- after the liberation.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Always that same little skimpy little dressing gown.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was like voile, you know, like very thin material that you would have in summer, flowery, you know, with ruffles.",
      "word_count": 21
    }
  ],
