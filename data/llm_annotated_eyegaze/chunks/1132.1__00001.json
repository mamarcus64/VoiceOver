  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So this is something that she has never forgot-- forgotten, and was determined that her children will be college graduates and that they will have a university type education.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It's interesting that even my grandfather on my mother's side was an attorney.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I come from a family where it's third generation of educated people.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And my mother of-- also was brought up in Budapest, so her ties to the city were very strong.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And this is where I was born and raised.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "It would be interesting to understand my story to also to register the fact that my father was a veteran of World War I.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "He spent close to six years as a prisoner of war in Siberia.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "They took him when he was 18 in the Austro-Hungarian army, and they gave-- he was given up on as a survivor.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And six years later, all of a sudden, he showed back up at his parents' house.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "He came back and he was snow white.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "My mother never knew him in any other way.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "His hair was snow white, and this is my only recollection of him as a man who was always had white hair.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] So that is an interesting, in a way, of background of where I'm coming from.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "I have a sister who is eight years older than I am, so I was always the baby of the family, and for a long time was handled as such.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "My sister also got married very young.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "She got married when she was 18, and she was out of the house.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "So from that time on, by the time I was 10, I was an on-- really brought up as an only child.",
      "word_count": 22
    }
  ],
