  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And the ghetto was created in place where it is most, by square meter, occupied places.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "German created ghetto push everybody from the other small town there, and created terrible situation.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "Up to do this moment, you know, was not food, was not supply.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And on-- and on each place where you cross the ghetto and Aryan part, was one gendarme, one Polish [PAUSES FOR 4 SECONDS] policeman, and-- before the war, policeman, and also one Jewish policeman dressed the same like Polish guys.",
      "word_count": 40
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "A little bit different.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And you go through the border, through the gates.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "If gendarme see you and you have something that was sticking out-- you know?",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Or many people from ghetto going to work in-- for German-- in Aryan part.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And the people bring sometime food.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Hide the food in-- any place.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "If you was catch like this, you was beaten.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish people was beaten very bad.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And if you are Christian and going single, for example, and you have something, and gendarme see you, you were arrested and sent to Polish prison.",
      "word_count": 26
    }
  ],
