{
  "stem": "8703.7",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "It was from all the political parties, about 600 people.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "We had to go through France with the trains, and we're going to France.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "I was asking all the papers.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "They said it's OK.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "We went, 600 people.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "When we came to the border at the French zone over there in Austria, we had to cross-- we had to go through France.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "The police stopped us, checking the papers.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "And for some reason they didn't like the papers.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "Papers were officially to another country.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "And they said you're not going to go there.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "You're not going to cross through France.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "You have to go back to where you came from, everybody.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "I said, we don't go back.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "We have no place already.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "We lost our place.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "Wherever we were, we can't go back.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "The only place we can go is forward, but not back.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "Anyway, you'll have to go.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "And it started, you know, and arguing.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "You have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "I said, we're not going to go.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "So it started a fight.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "They tried to put us back to the train, you know, to the-- and we, we, we didn't want to go back.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "I put in a stiff fight.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "My little brave sister was in front of me.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "And I was the last one to fight them back, the police.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "And we said that we're not going to go in.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "They called in 300 additional policemen, French policeman.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 48,
      "text": "And they wanted to force us, to take us in one by one.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "But we fought them.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 50,
      "text": "And when they saw that they can't do nothing with me, they hit me with the back of the rifle.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 51,
      "text": "And they hit me on my head.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 52,
      "text": "And I was very-- started bleeding very badly.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 53,
      "text": "And they-- and I was wounded.",
      "word_count": 6
    }
  ],
