{
  "stem": "3380.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They were the same kind of people like we were.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I will tell you, I did not-- I think my parents used to help them, whatever they could.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Because they didn't have even what we had.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they were also religious people.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And I know on every Saturday, my mother-- whenever she cooked, she cooked for them, too.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "All the radios were confiscated the first moment they came in.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We had no Jewish papers.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We only know what we know what we find in German papers.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Lots of Jewish people could read the German newspaper.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So we got that kind of information.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And you know, we also find out things.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "We still have contact with Poles.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "So the Poles didn't have any radios either.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They took away from the Poles also the radios.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "But we would know what was going on.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "We would see, like in 1940, that he was attacking you the Western world-- that France was occupied, Belgium, Holland.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "I mean, that was very well-publicized.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "We were aware of everything that was going on without having the radios and without having the newspaper.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Because we were not locked in.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "You see, we had contact with the Polish people.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "My family didn't have any contact.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "But others did.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In 1941, people came escaped from Konin to our town.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And they claimed that they buried their parents in Chelmno.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We hear those stories.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "You know, nobody ever would want to believe those things.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Nobody wants to even listen to them.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Nobody wants to hear those stores.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "What do you mean they're going to take people?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I said.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And they tried to convince us that they buried their parents.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And we didn't want to believe them.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We chased them out.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "That was the Jewish police-- they find out.",
      "word_count": 8
    }
  ],
