{
  "stem": "7415.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, the prostitute was really-- didn't give me food.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And not that I-- I was such a big eater, but I remember really going-- and she was quite punitive.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Because once she was putting an egg, and I tried to have a little bit of this egg.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And she punished me.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "She put, I think, all salt, it was in the salt [PAUSES FOR 3 SECONDS] container on this egg, and told me for the punishment, you will eat that.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't see my mother often.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I always worried that she will be killed.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And one day, when the woman of the house was away, [PAUSES FOR 3 SECONDS] somebody rang the door, and I had the feeling it's my mother.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "So I was very, very quietly [PAUSES FOR 3 SECONDS] lying down next to the door, and I heard my mother's voice-- 'Olenka.' So I opened the door.",
      "word_count": 28
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I told my mother that I don't want to be in this place.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "That the woman is really bad for me.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And I also kind of felt bad about not having hair, like you know, [LAUGHS] being completely shaven.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And-- and my mother took me to another place.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "At this time, my first name was Bozenka, and my last name was Goscinska.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And she took me to a place where there was-- [PAUSES FOR 3 SECONDS] man died.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "He was a conductor of trains.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And he left three kids.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "The oldest maybe-- they weren't kids, they were young adults.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "One boy, maybe age of 18, and two girls, the oldest was maybe 25.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And they-- they really liked Bozenka, and I liked this people.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I pleased them.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "That was the time when I had my communion as a Christian girl, praying to Jesus Christ.",
      "word_count": 17
    }
  ],
