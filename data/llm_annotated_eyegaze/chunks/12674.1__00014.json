{
  "stem": "12674.1",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "She said, no, she said you have an academic education and you should know much better than I do.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "He says, do you have an academic education?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "She said, of course I do.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "You know that.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "He said, why are you angry at the child? she told you the truth.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "So that was my father.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "What kind of schooling did you have?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have any schooling.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I went to an elementary school, which lasted until-- well, the elementary school in Vienna at the time-- still is-- was four years.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "It didn't have a name.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "It was in a street, which was called Treustrasse.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And I went to the school in Treustrasee, which was about two blocks from my house.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And it was an all girls school.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Girls and boys didn't all go to school together in Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And then at 10, I went to an eight-year high school.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "It was called the gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And from there you could get into college.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "But I only went there for a year and a half, because in 1938 all the Jewish children were told that they could no longer go to public school.",
      "word_count": 29
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And that was my education.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And the rest was home made.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, I did have Jewish education.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My father was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But he was special.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He said, God gave her a brain even though she was a girl.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Let her use it.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And he allowed me to go to school.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I went to a place for girls, which was called Beth Jakov and we learned [?",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Komisch ?] as a girl, which was very, very unusual in the 1930s in Europe in a religious home.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "It was very unusual.",
      "word_count": 4
    }
  ],
