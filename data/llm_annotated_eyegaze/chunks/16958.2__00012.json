{
  "stem": "16958.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "I have here, hiding, [POLISH], his name.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "[POLISH] grandson.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "Which he had-- this forest belonged to him.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "The field belong.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "A very rich man.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 19,
      "text": "His grandson, which was my close friend.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 20,
      "text": "And I have an idea.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 21,
      "text": "You know, he was a hunter.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 22,
      "text": "He was hunting once and he was shooting a fox.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 23,
      "text": "And the fox, this-- he was running, and the fox disappear in a hole.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 24,
      "text": "And he came down and sees a hole there.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 25,
      "text": "Says, why don't you go down there and check.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 26,
      "text": "Maybe there is something inside there.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 27,
      "text": "So-- [DRINKS]",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So my brother came home.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And he says what [POLISH] told him.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So on the 1st of May, 1943, on a Sunday, [PAUSES FOR 4 SECONDS] me-- I-- I could walk already.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Me and my brother and this [POLISH], [POLISH], and another man neighbor, Josel Dodek, and Mendel Dodek-- five of us-- we went to see-- to explore what's there.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We came there.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We brought with us shovel and axe, ropes, candles.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we-- now I'll to explain you the way the cave was looking from outside.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "It was a little road.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And at the right side was a forest.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And it was fields hilly up all around.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And it was like a valley.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "The valley was about 200 feet wide, maybe 200 feet long.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "A valley.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "Low.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "Has to go down, down.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And as we come to the end, there was a big ravine about 40 feet deep, and maybe about 40 feet or 30 feet wide.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "And you see there water is dripping down.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And big stones there.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "Water dripping down.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "And we had to go down there.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "Somehow, we-- we were young.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "We were-- didn't take us time, and we were down there.",
      "word_count": 11
    }
  ],
