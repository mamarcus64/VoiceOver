{
  "stem": "5228.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.4,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "We came, we went out, and they started to separate us then. and And my-- I was holding my grandma by the hand while she's-- you know, she was-- I think she was 80 years old, maybe even more.",
      "word_count": 39
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "But she was still-- And then I met a man there by the train.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "He was with his striped suit on.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "This was Jewish men's-- what they was in camp, too.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And he pushed her on one side and pushed me on the other side.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And she started to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "And she said, I've got 72 children, I mean, with grandchildren, with grand-grandchildren, and you're the one what's left, and you are leaving me alone here.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "I think guard, they just kicked me and then pushed me, and that's it.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "And they took them right in gas chambers, all the old people.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "There was a mother with four or five boys with us on this.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "They took her children and I think her husband, too, still-- straight in-- in gas chamber.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "Well, they-- they pushed her away from the children.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "They took just the children.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "She went with me, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She lives now in California.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I know her very good.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I know her before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Come and they took us to a place, they cut off the hair to one hair.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Her ?] got one hair, they cut off.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "It's-- I got long hair when I was there, and I always was-- still got two or three hairs.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I was imagining how long my hair was.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Without hair, they ask us undress.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "We undressed.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Naked.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "They took us in shower, naked.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "It was going all like this.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "I was-- and then from the shower, they-- they count us, how many, somebody didn't run away.",
      "word_count": 17
    }
  ],
