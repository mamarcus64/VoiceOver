  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "French and Russian he used to teach.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Now, I think, he's retired because he got some relatives there.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They died, and he-- he pick up his-- he could live without working.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He's not working now.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But he goes to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "He goes-- he comes to me for-- it was for two weeks, he comes to me, stay with me.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Just happened-- just happened that I went to an eye doctor, just recently, a month ago.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "The eye doctor's name is Getz, the same name what my friend's name.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "So I told him I have a very close friend by the name of Ira Getz.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So he told me from where is he?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "So I told him from this and this town in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So he told me, it's possible I am related to him.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I'm a town further, 11 kilometer from Gorlitz, he is.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "So I gave him his name, and I call him up.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And they got in touch.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And they are some far away relatives.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "But that guy, that doctor, I wouldn't recognize.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "He was-- because the camp, I told him what camps what I was, so he know everything about this.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "So I didn't know that he was in the camps too.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But when I talk to that-- my friend in New York, he told me that he was in the same camps what I was.",
      "word_count": 24
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And he became a doctor when he came after the war, and he has an office, eye doctor.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "So right across the street where I live, Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Getz, it's a small world.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Sure, I tell you right away a miracle from Prokocim.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I told you, I think, already when they-- yeah, I told you already this.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "This, I told you.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "It's miracles.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "It's miracles.",
      "word_count": 2
    }
  ],
