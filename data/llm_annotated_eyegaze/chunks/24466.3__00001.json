{
  "stem": "24466.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I remember this quite rightly.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I didn't want, for instance, to work.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And it was on a Monday.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "There were two lieutenants, one of the name Habik.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And the other's name was Lavatchek.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And they were assigned [PAUSES FOR 4 SECONDS] as the people [PAUSES FOR 4 SECONDS] from the [INAUDIBLE] east.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And they-- that's in [INAUDIBLE], was in Riga.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And they ask everything was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "They [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They took over.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "That combined.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "The [INAUDIBLE] that combined the [SPEAKING GERMAN] in Vilna.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't went to work.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] They ask-- that was Habik or Lavatchek-- the people who was the technical manager here?",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And they find out that a gentleman, Kaufman-- was-- Before you go on, could you just spell their names for me please?",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Habik-- H-A-B-I-K-- Habik.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And the other's was Lavatchek-- L-A-V-A-T-C-H-E-K.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I beg you?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "They was in the-- in the general Wehrmacht.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Wehrmact, the Wehrmacht took over.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Actually, the Wehrmacht took over that combine.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I was.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And they're sending under officer.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And the name, because he was-- I was with-- and the name was [PAUSES FOR 3 SECONDS] Martin Hanze.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "M-A-R-T-I-N, Martin, the first name.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Hanze-- H-A-N-Z-E.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Hanze.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Hanze.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "That was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He came.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They asked-- they find out that-- Habik find out where I'm living from the people there in the factory.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He came to me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Now, I will say this in German, yeah?",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Came in.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[SPEAKING GERMAN]",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I am Kaufman.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[SPEAKING GERMAN]",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I said, to him, yes, I was the one.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[SPEAKING GERMAN]",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I accent this, Herr Kaufman.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Mister.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] [SPEAKING GERMAN] And I went to him.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Be so good, Mister Kaufman.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The lieutenant, Habik and Lieutenant Lavatchek want to talk to you.",
      "word_count": 11
    }
  ],
