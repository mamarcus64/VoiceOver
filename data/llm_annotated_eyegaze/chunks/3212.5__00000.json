{
  "stem": "3212.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Gleiwitz, and--",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we came to a forest.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And suddenly, there was a big square in front of us.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The SS with the machines were running to be ahead of us, and they start shooting at us.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They put the machine guns down and start shooting in the people, to kill.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "For no reason.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Walter and me, we ran away, because we were right by the forest.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "After the square was the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We ran away, Walter and me, we ran in the forest.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And we met there an elderly guy that ran away from Yugoslavia.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And he says, children, from where are you?",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "So we said, we are from Austria, Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He says, you are from Vienna?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "You know what?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "We'll walk to Vienna.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And if we had stopped, if we had stayed there, we would be freed two days later from the Russians.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "So we start walking.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "We came to a street.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Oops, the SS captured us again.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "Again to march.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "We are marched all the way to-- to Tresen.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Walter and me, we ran away in Tresen.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "On the road, many times, when I wanted to sit down, Walter grabbed me and picked me up.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "When Walter want to sit down, I grabbed him.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Because whoever was sitting down, couldn't walk, they shot him.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "During the march-- even before-- whoever couldn't walk, they shot him and threw him in the ditch on the side of the road.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "In Tresen, Walter and me, we ran away.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "We were swollen.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Everything was infected, our bodies, from the-- from laying in the-- in the beds, on the wood and all that.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We went into a house.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was a house from, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "In Tresen, Germans, they asked us, what you doing here?",
      "word_count": 10
    }
  ],
