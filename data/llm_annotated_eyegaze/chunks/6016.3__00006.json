{
  "stem": "6016.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And some Jews from the gathering-- from the Federation in [INAUDIBLE] broke us some matzos.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So it was a little-- it was another experience.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "But it paid off because we were not sent back to Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And then I-- my sister got married without me.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, being in Bergen-Belsen after the liberation, we met different people and everyone searched for everyone else.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I knew that one brother passed away-- got killed.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But the other brother-- I didn't-- I knew which camp he was, but later on, I found out that this camp was very, very, very bad camp.",
      "word_count": 27
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He was in Gross-Rosen.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And Theresienstadt too.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "So we didn't here anything.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Occasionally we heard from someone that they were together with him in a camp.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise, no.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "The parents-- we knew that they were in-- in Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And from 1943 to '45-- '43 was the worst year in-- in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "The crematoriums were very busy that time.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "So there was a-- and my father was-- was not very young-- he wasn't old.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "But he wasn't in any camp either.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "So we gather that he must have been cremated.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "At the beginning, no.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "My husband especially said that he doesn't want to be in Europe anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So he aimed to go with the family.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "From Paris-- from Paris the family from Mexico wanted us.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And my husband wanted to go to a-- to a warm climate country.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Because his-- his father passed away.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "There was a heart condition.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "A heart condition.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So he was afraid that maybe he has a heart condition too.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "So he said he doesn't want to be in any cold climate living.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "So Mexico was very well, and we were wanted over there.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "But it was very hard to get into Mexico.",
      "word_count": 9
    }
  ],
