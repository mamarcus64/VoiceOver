{
  "stem": "11075.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "They're going to send us to Auschwitz, or maybe some-- maybe to Chelmno, or maybe to Gross-Rosen.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But we have to be prepared.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So don't stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "If you-- If you ran away already a couple of places, and you are alive, you know, don't stop.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And where do you want to go?",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I said, I want to go to Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "In Krakow, I know.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "So he gave me the money and he said, you know what?",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Go at night.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Take the railroad, and don't talk to nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Sit down on the corner, if you have room, and make believe that you are sleeping.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Just make believe that you are sleeping.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "All right, so I did.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "Why did you want  to go back to Krakow?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "To Krakow?",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Because in Krakow, you know-- he mentioned to me, you know, Oskar Schindler mentioned to me, when you ever will be in Krakow, if you will be in Plaszow, if you will be in ghetto, I will be able to do something.",
      "word_count": 42
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Because I know that he has already the key from the factory.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The-- my-- my-- somebody came, you know, to the place where we were standing.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And he said, you know, he found-- found already the prosthesis from the leg.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "That's for sure your father's.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They went to Chelmno, to a different concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They went all to straight to death, you know, to a grave, with my two-- my little two sisters, you know, everybody.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So I left Sandomierz, and I went and stayed to Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Krakow, was a whole night.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I went to-- to the railroad station, and I bought a ticket, and I went straight to Krakow, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It took a whole night, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I came to Krakow in the morning.",
      "word_count": 7
    }
  ],
