{
  "stem": "16106.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And the peasant came running in white.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "He said, disperse, disperse, fast, fast, fast.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "The Pole-- the Russian pilot-- oh, they-- they had their places already stacked out.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "They know where to go.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And me he put in bed with his daughter, like a sister.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "But the Germans came, and they had [INAUDIBLE] they were looking for and laughing and kidding, and I had the [INAUDIBLE].",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And he came out and tried to bribe the German with hams and sausages.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And the German was like laughing at me, snickering at me.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I said-- well, who are you?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "What are you?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Where is your passport?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I said I-- up on the truck.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "We go to prison to Karthaus, was the next biggest city.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Karthaus.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And on the trucks they had some already-- some unlucky souls.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And there was one Hungarian girl from, from the Kaiserwald.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I remember her from there.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And there was a whole [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And she looked at me.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I looked at her.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Did as if we don't know each other.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "We got into prison, in a cell, the whole lot.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And they-- one could see from the window that they put out people one by one and, and, and whatever.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "They executed them, what have you.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And then the door-- we were less and less in the cell.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I only know we were less and less.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The Hungarian girl I remember.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "A, a boy, a, a blonde boy, me, and more, other people.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "You know, it's all-- you, you, you-- it is so strange.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "You don't know how.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "You think I sat there, I counted?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH] would have counted.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "He always knows how many.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I know how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "We were, we were-- this whole truck.",
      "word_count": 7
    }
  ],
