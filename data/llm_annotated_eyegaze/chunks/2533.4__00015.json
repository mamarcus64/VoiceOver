{
  "stem": "2533.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Then they didn't have bags of blood.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "That was just the hospital staff was supplying the blood.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And then somehow I got through it.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "When I got back, Andrew didn't recognize me.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "He was only 13 months old.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "He used to call me auntie.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "But one day he looked at my face and he said, Mama.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "And from that moment on, he didn't leave me.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "And I wasn't even strong enough to look after him then.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "But he was always with me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "And one thing he didn't like, when I was just to lie down during the night for a nap.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "He used to cry his head off.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "He thought at nighttime, that is enough to lie and lie.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "So I used to lie on a couch.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 22,
      "text": "That was all right, but not on bed.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "That's what they told me in the clinic.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I suffered a lot with it.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "But it was almost a miracle that Andrew was born and they didn't straightaway detect it.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "I had the appendix removed, and it didn't make any difference.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "It was still bad.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Because we tried a lot of other places.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We tried the United States, but my cousin and other friends, they couldn't get any affidavits for us.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And we needed from the American people that they will guarantee a place of stay, where to live and work.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I applied to-- they wanted us to go to Sweden.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And I said, no, that's too close to Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And then Venezuela was taken, I said, no, it's a little bit out of the-- and then all of a sudden, Australia came along.",
      "word_count": 24
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And I learned at school a lot about Australia.",
      "word_count": 9
    }
  ],
