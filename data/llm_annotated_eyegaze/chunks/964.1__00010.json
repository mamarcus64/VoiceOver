{
  "stem": "964.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "What do you think the rabbi did?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He took a taxi.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He left us high and dry.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "He ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "He, he, he drove away.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "This is the rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "Do you remember the rabbi's name?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember now.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I think [?",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Lipshitz ?] was it, another guy.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, this was the fact.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We, we-- he ran away.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "We were there.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And so what do I do?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I, I-- mine brothers had already girlfriends.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "They left with their girlfriends.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "The oldest brother was married already, so he left with his wife.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And we figure like this.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Mother-- my mother was what? 50 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "Who would bother old women?",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "So I took my old-- my younger brother.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "We put two breads in, in, in a-- in a sack, and we walked away from town.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "You know, there's another irony in life.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "While we walked, we walked about 50-40 kilometers from town and I was sitting on the side of the road and eating my bread.",
      "word_count": 24
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And there, I have to go back.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I have to tell you this.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "This has to be for-- to history.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "People-- people will learn something.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "When we were hungry, when we were going hungry, my mother had a cousin there.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "He was a rich man, a very rich man.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "In those days he had already two houses in [INAUDIBLE] himself.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "He had a beautiful, big, big house in our town, and the house was covered with tiles.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "This was unique in those days.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "In his house lived the bishop.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "Imagine, in, in 1936 he, he brought in a, a, a, a decorator to decorate his, his apartment.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "So that's how rich he was.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, when we were going hungry, my, my, my mother-- I [INAUDIBLE].",
      "word_count": 13
    }
  ],
