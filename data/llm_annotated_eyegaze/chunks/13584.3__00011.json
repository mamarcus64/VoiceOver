{
  "stem": "13584.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "And she very often used to go to school with a half of a potato and a piece of herring, because that's all what they could afford.",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "It was long before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 3 SECONDS] So poor they were.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And when-- when after the war, some anti-Semites used to say-- and even today-- oh, Jews, they all rich.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "[SIGHS] I don't know what to answer.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "Sometimes I know, sometimes I don't want to answer. 95% of Jews were very poor.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 3 SECONDS] My mother used to-- when she was 15, she-- bits and pieces.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "When 15, she used to sing [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And her sister-- my mother used to tell me her sister was singing much better than even than she did.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "She used to go out when she was 12 or 13, and she used to-- it was not plumbing in this city, in this [NON-ENGLISH].",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "She used to go-- she was very strong woman.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "Apparently, during the war it was shown that she was strong.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "She was strong carrying those watermelons on her shoulders, strong.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "She used to go and pump the water for people who need the water.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "They used to give her a few pennies, because she helped them to pump the water.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 40,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 41,
      "text": "[SIGHS] [PAUSES FOR 3 SECONDS] I-- it's bits and piece-- pieces of my-- of my life, of my parent's life.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 42,
      "text": "[SIGHS] Yes, please, yeah.",
      "word_count": 4
    }
  ],
