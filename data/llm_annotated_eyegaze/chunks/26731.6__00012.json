  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Here it was just in between.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But in Germany you didn't interrupt the service, for-- at least in the [INAUDIBLE] synagogue.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Now it was, actually-- and I met Ethel there.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Meet your spouse at the Hillel House.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "See, actually what happened, it was Sunday night.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And the fraternity didn't serve, and they came to the Hillel House to have some food.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And I go downstairs, and tell him, now look he is [?",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Milkik ?] and he is [?",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Frakik ?].",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And don't mix them up.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "I go upstairs.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "Five minutes later, I come down.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "They had them all mixed up.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "And there was a redhead there said, tell me about it.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "And I complained about her.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "That was Ethel.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And that's how you met your future wife.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
