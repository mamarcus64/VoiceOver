{
  "stem": "543.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And we said to each other, my sister-in-law, let us try.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Maybe we can stay alive.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Maybe the war is soon over.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "So you signed the papers, and you became part of the experiment block.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We signed the papers.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We did sign the papers that we have to-- yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So middle in the night, I hear screaming and crying.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And people with big holes in their body, and then and that.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I say to my sister-in-law, I not going to do that.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Is that the experiments doing what they do to you, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'm not going to stay here, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'd rather die right away.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "People with, you know, no leg, You know, it was awful.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "It was like a nightmare.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "So I said to my sister-in-law, I, I not going to do that.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "We tell them tomorrow morning, we want to go.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "So at least we gassed, but it is not-- you're going to die anyway.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "They said after three months, the people around as, they told, after three months, they can't use you anymore.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You go anyway.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "They take the trucks, and they take you away.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They don't let you live.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "So in the morning, we get up.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We said to the people, now let us-- I say to the, to the guy there.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I said, no, we'd like to go with the other ones.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "You signed, and you have to stay.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So we were frightened like anything, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I was so afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Unbelievable.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And I said to the lady-- and the other said, no they don't always do-- there's some, some experiments are not that bad, you know?",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And try, you know, and some doctors try to-- not that hard.",
      "word_count": 12
    }
  ],
