{
  "stem": "22959.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They found little jobs, like, like, in the office where the leaders used to work, [PAUSES FOR 3 SECONDS] like, to work for the Germans, to clean, to wash, [PAUSES FOR 4 SECONDS] like, people who had their occupations.",
      "word_count": 39
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I was a student.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So I did not have my occupation.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "But people who had their occupations, like, for instance, a carpenter who could-- who could produce, who could, see, work for the Germans, who could make-- who could make boots for them-- shoes.",
      "word_count": 33
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They felt they had a better chance to survive.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And they did have a better chance to survive.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "The first-- during the first selections, they took all the elderly people.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "They took the young ones.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "I remember they took away from us my grandma.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And she did not-- she did not know German.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "But she was begging him.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "She said, [SPEAKING GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "I am a grandmother.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "But they just took her.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I was there with my mother and father and my grandmother.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They tore away my grandmother from us.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And, and we-- and we-- and she begged, and we begged.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But they took her.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And we were left, my mother, father, my brother and sister.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That was the first action.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "The first action.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And then we went back to our quarters.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We were-- we were-- they asked us to gather at a certain place in our town.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And they told us that they're going to check our documents.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "But instead, they took the elderly.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They took the young children.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They took them away.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And we were left.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And we went back to our quarters.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They didn't tell us anything.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They just tore her away from us and took her away.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And that was the last time when I saw my grandmother.",
      "word_count": 11
    }
  ],
