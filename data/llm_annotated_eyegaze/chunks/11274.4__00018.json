{
  "stem": "11274.4",
  "chunk_idx": 18,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And before that day, I-- Danka was very-- getting very depressed.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And-- and she sort of-- even that little piece of bread she almost didn't want to chew up.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And I was getting worried about it.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And I woke her up one day.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I said to her, Danka, what-- what is it that you are acting differently than you did at the beginning?",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "What can you act here?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Then it's not worth living here.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "She said, this is not life.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I'm gonna be--",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I said, then I'm in the same boat with you.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "No, you're not.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "You look a lot better than I.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And if they're going to be chosen for that, they're going to choose me and not going to choose you.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I'm not afraid to die alone.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I don't want you-- I-- I would be glad if you're alive, but I'm worried only about the trip to the gas chambers.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "I see how, after the selections-- by the way, in the meantime, selections are going on.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "They're choosing the weaker ones, what they think is weaker-- just putting it on this way.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "That was all life was worth.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And they're throwing out on flatbeds, throwing up those that are chosen to die.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And she said, I saw them, how throw them up on the flatbeds.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And it's horrible, just like rotten potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "That's the way they treat them.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "She said, and I'm afraid of that.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "You give me your hand.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "I said, here's a holy book.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "And God is everywhere, I said.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "And Mom and Dad are standing right here.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "I swear to you.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "If I'm going to be chosen, I'll go with you.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "You're not going to be alone.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "We're going to die together.",
      "word_count": 5
    }
  ],
