  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Some barracks, not ours, had work.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They went to the [NON-ENGLISH], to the clothes, where it was so much clothing and teeth, and baby's clothes, and-- and-- Tallis and Tefillin, from the men, for religious people, everything was in the-- how you call that, [NON-ENGLISH]?",
      "word_count": 39
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Piles.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So there was barracks with women who went to pick-- separate the shoes, separate the dresses, separate the teeth, separate the hair.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They pick the hair, what they cut off from the people, they-- they use-- they had use of it.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They sold them.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They made brushes.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They made different kind of things.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "So that was barracks who worked.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "That was the arbeitslager.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And but our barrack didn't work.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "That's why they pick-- after six weeks they came in the barrack.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "And they picked whoever they want for work.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "They picked out and shipped us to another city.",
      "word_count": 9
    }
  ],
