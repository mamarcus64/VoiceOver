{
  "stem": "33.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 170,
      "text": "And we couldn't talk to anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 171,
      "text": "But we did see people.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 172,
      "text": "And we saw cities.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 173,
      "text": "They were all in pretty bad shape, because this was November of 1944.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 174,
      "text": "They were all bombed out.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 175,
      "text": "We stayed about eight days in Braunschweig, which was a non-Jewish women's camp, because from there, they took us to various camps where we were needed.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 176,
      "text": "I was taken to a small town, called Salzwedel -- S-A-L-Z-W-E-D-E-L.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 177,
      "text": "It's about 80 kilometers south of Hamburg, very close to another death camp or a big working camp, Bergen-Belsen.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 178,
      "text": "Basically another extermination camp.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 179,
      "text": "Salzwedel was a very small camp.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 180,
      "text": "Only 1,200 women.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 181,
      "text": "All but four Belgium ladies who must have gotten there by mistake.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 182,
      "text": "All the rest of them Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 183,
      "text": "I was supposed to work, of course, in this little clinic.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 184,
      "text": "But the nurse who already worked there wanted the job for her sister.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 185,
      "text": "So by the time I got there, I didn't have the job.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 186,
      "text": "I guess I was still the little shattered dummy that I was six months before.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 187,
      "text": "I really couldn't stand up for my rights.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 188,
      "text": "We didn't have any rights.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 189,
      "text": "And we worked in ammunition factory manufacturing bullets that was very close to the camp.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 190,
      "text": "I suppose the camp was built there for that purpose.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 191,
      "text": "We worked a-- 12-hour shifts, 6:00 in the morning to 6:00 at night, or 6:00 at night to 6:00 in the morning.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 192,
      "text": "At the very beginning, I worked in the so-called potato peeling and vegetable peeling room next to the kitchen, separate from the kitchen.",
      "word_count": 23
    }
  ],
