  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] Anyways, [PAUSES FOR 3 SECONDS] and sure enough after that, they are [INAUDIBLE] something.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "My rash went away, and I sort of knew that she must have been talking about me.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "This kind of thing, just sort of we believed in-- in-- in that time.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "Any signs of something, it was because of this or that or-- And now I'm still not happy staying here in Miedzyrzecz.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "I want to go to Korzec, the city that was close to my town.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "And I think this time I was hitchhiking already.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "I wasn't afraid-- I did-- I wasn't afraid already to hitchhike, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "I would get some rides to go in to the other city, to Korzec.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "And I come to Korzec, and again some people-- survivors came out.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "And [PAUSES FOR 3 SECONDS] somebody-- I don't think they knew my family, just-- just they were Jewish people, and everybody wants to help everybody.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "And I stayed with some-- with some lady there.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "And then one day she tells me, this family want to meet you, because they heard where you were hiding, and they were-- they were hiding under the ground [PAUSES FOR 3 SECONDS] in the same village.",
      "word_count": 37
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "Anyways, I went to meet them, meet this family, and their name was Primac, [?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "Kayla ?] and [NON-ENGLISH] Primac, and they had a son named Sam.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "They called him [?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "Shoma. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And they were very-- very excited to see me, because on this farm where I was, the next farmer, like I say, they were hiding under the ground, and I would-- would be walking over them, you know?",
      "word_count": 38
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "How-- where were they actually hiding?",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "You mean ?] under the ground?",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They had-- was it like a bunker or--",
      "word_count": 8
    }
  ],
