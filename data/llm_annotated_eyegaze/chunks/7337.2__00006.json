  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But on the-- on the day of the funeral of my mother, a German [PAUSES FOR 4 SECONDS] official arrived with a written guarantee giving my father a guaranteed return, to leave Germany again, if he would come in and open the safe in which he said his money was.",
      "word_count": 50
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And my father said, well, you can see we've just come back from a funeral.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I'll come back when things sort out-- settle down.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And this man was genuinely embarrassed, [PAUSES FOR 5 SECONDS] because he realized that [PAUSES FOR 3 SECONDS] my mother had died.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And in France, when there's a death in the-- in the home, the building is draped in black.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "They don't have [NON-ENGLISH], they have undertakers.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] And my father left him on the basis, when I'm ready to come back.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "I'll come back.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "But he had no intention of ever doing it.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "In any case, there was no money in the safe.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "The safe was empty.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My father had very good friends-- they were Polish Jews-- [PAUSES FOR 5 SECONDS] who had the same sort of business as he had in Germany.",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They'd been friends for many, many years.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "In fact, they used to go on holiday every year together.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And he had arranged for them that [PAUSES FOR 6 SECONDS] he would signal them somehow when we were coming out.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And they had found us a furnished flat, or a furnished apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So when we arrived, we had a home to go to.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They helped to enroll my brother and I into a boarding school [PAUSES FOR 7 SECONDS] where we went to school.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't speak French at the time.",
      "word_count": 7
    }
  ],
