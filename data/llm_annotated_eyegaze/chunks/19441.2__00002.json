{
  "stem": "19441.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 372.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They came to the transport.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So it was about 12 girls I dressed up, so many dresses I had.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "What I had, I stayed.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I left-- the-- how you say?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Where you put the-- where you put the things in?",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "The suitcase.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I left the suitcase.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And with us came the Czech gendarme, not-- they wasn't Hlinka Guard.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He couldn't-- he couldn't get over-- he never met somebody who will give away all the dresses, just because to dress up her countryman.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And he said that he will try to take me out, because his uncle is in the ministry.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And when we arrived to the place, it was named Poprad.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Then it-- it didn't look nice already.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Poprad, P-O-P-R-A-D.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Poprad.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Then it didn't look very good.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "What did it look like?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Describe it.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It-- it was, you know, a-- it was mish-mash there, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't like somebody who is continuing to the-- to the butter factory.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was nobody-- nobody knew.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Nobody was directing.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "It was a chaos.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "So he said, if you stay here another day, I am sending a telegram to my uncle.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "He should send me a telegram back, that you are exempted.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "To my bad luck, the same day we went.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And there was waiting the cattle truck and they put us in.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "So then I knew.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So you-- you were taken into a cattle truck.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "How many people in the truck with you?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "To the fullest.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Beg pardon?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was no room just to sit and no facilities for toilet facilities, just one little bucket.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And people were suffocated there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And so much-- if they had some food they ate.",
      "word_count": 10
    }
  ],
