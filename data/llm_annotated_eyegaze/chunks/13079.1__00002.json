{
  "stem": "13079.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I think there was more antipathy toward the Catholics than there was toward the Jews in Birmingham at that time.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, indeed.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Not only that, but we were not given spending money.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We had to memorize verses from the Bible in order to get our spending money.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We had no such thing as an allowance, and we performed chores as members of the family.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But any money that we acquired, we acquired by, when we were young, $0.10 a verse, later, quarter a verse, and on up to $1 a verse.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "As a matter of fact, when I was at West Point, my father said, son, if you memorize and can recite verbatim the 11th chapter of Hebrews, I'll give you $100 in gold.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "That was in December of 1931.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And I learned it.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "There were 52 verses, and I learned those verses and spoke 'em and recited them to my father, and he gave me 10 $10 gold pieces.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And I took that money and gave it back to him [LAUGHS] because I thought he needed it more than I did at that time.",
      "word_count": 25
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Presbyterian.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was president of the student body of John Herbert Phillips High School, where we had approximately 3,000 kids.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I was proud of that.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I don't know whether you would say I was qualified as a politician or not, but that was a fact.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And my brother and I had an automobile, and we rode to school, and we took a load of kids to school every day.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I was slight of build, so there was no way in the world I can play football.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I think I weighed about 90 to 100 pounds.",
      "word_count": 9
    }
  ],
