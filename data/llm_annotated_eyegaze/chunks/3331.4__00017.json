  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I didn't go back to the town.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Seven other Jews survived from my town, not-- who were not with me in the woods.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "They were in hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And they went back to my town.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "This AK took the seven Jews into a barn, and they took two members from the AK with rifles to watch on them, to shoot them.",
      "word_count": 26
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "And the reason they didn't shot them is because they knew that one more survived.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "And they went to look for him, to have all eight.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "There shouldn't be one witness.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "And they waited for him.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 10,
      "text": "Meanwhile, the guards changed.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 11,
      "text": "And when the guards changed, one of the guards was working by one of the people of the Jews in a lumber yard.",
      "word_count": 23
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 12,
      "text": "And he felt sorry.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 13,
      "text": "And he went, and he told it to a Russian officer.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 14,
      "text": "So happens that this Russian officer was a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 15,
      "text": "And he came, and he took them out, and he brought them to Rzeszow, where I already was, in Rzeszow.",
      "word_count": 20
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "And he saved them.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Because they waited till they would have the eighth one.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Then they will shoot them.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "For this reason, I am so anxious to write the book, how Jews were killed after the liberation.",
      "word_count": 18
    }
  ],
