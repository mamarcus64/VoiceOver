  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So I went there, in the old building.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "So he said, it doesn't matter.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "We were looking for you around, and were yelling at me.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "That's why I got my 10.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "That-- the same evening, when we came home after supper, my name was called.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I had to undress.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I had to lay down on the table.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And I got my 10.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And it wasn't very pleasant.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And when I went-- Thank you.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When I went, I went to get--",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We ran out of tape.",
      "word_count": 5
    }
  ],
