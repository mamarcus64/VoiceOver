  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And in turn, we would try to continue to learn whatever and as much as we possibly could.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "But it wasn't very much under these conditions.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "As I said, life was becoming much more difficult as time went on.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "In 1940, end of 1940, the Nazi raids began.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "The Nazis would come.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "You know, they were careful to keep the dates of the implementation of their policies secret.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "They would come suddenly without any warning, surround a section of town, and would round up people.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "Or what was even worse-- they would round them up, take them away, and we would not know what they did with them.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And most of the time, they would send the young people to labor camps, deep in Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "Or--",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Fine.",
      "word_count": 1
    }
  ],
