  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And sure enough, Teresa graduated from Tilden High School.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "She was graduated from Tilden High School three years after she entered it.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And I decided to shape my life.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And it took a long time for me to arrive at the point where I am now.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "All kinds of trials and tribulations, but the best thing that ever happened to me, I had to go to California, because I had a cousin there who thought that she would have a good, as they say in Yiddish, [SPEAKING YIDDISH], good, green, little refugee girl, who's going to be a servant to her, which I refused to do.",
      "word_count": 60
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I came back east again, and I came back east in 1947.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I had made some friends in California who came back east, as well.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And they wanted to meet me in New York, about a month after I had returned.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And we met, and they took me to a dance on May 15 of 1947, where I met my husband, who insisted on escorting me home, who lived only two blocks away in Brooklyn-- although we met in New York-- from where I lived with my sister.",
      "word_count": 47
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And exactly to a year, November 14, 1948, we got married.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And my daughter Judith was born in 1950.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "In June of 1951, we came to Miami.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "My son Gary was born on November 14, our anniversary, in 1951.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And I have lived happily ever after.",
      "word_count": 7
    }
  ],
