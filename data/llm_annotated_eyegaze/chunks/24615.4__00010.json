{
  "stem": "24615.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "But I heard the other Polacks tell us is-- she-- she start yelling in the Ukrainian why they-- they-- on the bandits, why they killed their brother.",
      "word_count": 27
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "So they killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "They killed the people, what we stay there, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "You didn't see this, though?",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "But you know this happened.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I heard that happen.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "You know, they didn't come back.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "You know, they didn't come back, no, [? none, either. ?]",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "None of them came back.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "We were in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "We and the [?",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Hershel ?] and the two sisters, and the son, another-- and another lady.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We didn't stay.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You know, the-- the Polacks, their neighbor, you know, they came right in.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And they took the cow.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "They had two little pigs.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "They killed it already.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "It's so long.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "You know, like we went out.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "They were cooking.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "We were eating their food.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And they-- they-- she was sitting to warm herself.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "She said, who's eating my food?",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "The cat eating my food?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "You know, we had lice.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "You know, she-- she made the oven, and she put the clothes in to kill the lice, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "I didn't take a bath.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "I never took a haircut.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "You know, my hair were almost like this.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "And-- and-- and before they killed them, you know, they killed this Polack, you know, what he talked Jewish.",
      "word_count": 19
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "But what did you do?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "Where did yo go next?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "You said you didn't stay there.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, at night-- you know, at night, when it came night, we-- we went in, you know, to bushes, me and Hershel, and the ladies, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And we waited till maybe one o'clock, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And then we started walking.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "They were closer to the city already.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Rozyszcze.",
      "word_count": 1
    }
  ],
