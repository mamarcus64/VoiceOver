{
  "stem": "5644.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 3,
      "text": "That was only to dig out enough not to slide underneath.",
      "word_count": 11
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was about 10 minutes, 15 minutes, I came along--",
      "word_count": 11
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "I went out, knowing that they're going to shoot, knowing.",
      "word_count": 10
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "But I learned something during the resistance, that's when you run away from a thing like that.",
      "word_count": 17
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 2,
      "text": "You're running in a zigzag so it's harder-- I told her to switch off the--",
      "word_count": 15
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "I told her.",
      "word_count": 3
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 1,
      "text": "She didn't took off the telephone.",
      "word_count": 6
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and--",
      "word_count": 2
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "I ran in a zigzag, and ran away from there.",
      "word_count": 10
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 1,
      "text": "I did run away.",
      "word_count": 4
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "No, not at all.",
      "word_count": 4
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 1,
      "text": "And I went-- and it was very early in the night, so I got to hide there [INAUDIBLE] again.",
      "word_count": 19
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "No, the surrounding was a field with the--",
      "word_count": 8
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "A field, a complete field, about two, three kilometers field.",
      "word_count": 10
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 1,
      "text": "So with the railway-- what do you call it?",
      "word_count": 9
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 0,
      "text": "Culvert, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 1,
      "text": "So I run.",
      "word_count": 3
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 2,
      "text": "I hid there in the old house, in the burned down house.",
      "word_count": 12
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 3,
      "text": "I hide till about 8 o'clock in the morning with the hat.",
      "word_count": 12
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 4,
      "text": "I was very, very dark, completely black from the sun.",
      "word_count": 10
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 5,
      "text": "And I went into a tram, without a penny.",
      "word_count": 9
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 0,
      "text": "Tram to my wife.",
      "word_count": 4
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 1,
      "text": "But in the tram, I played-- I start to play that I am drunk.",
      "word_count": 14
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 2,
      "text": "And I start to talk about the Germans and what they did to us.",
      "word_count": 14
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 3,
      "text": "So everyone from the front--",
      "word_count": 5
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 0,
      "text": "From that part of the tram.",
      "word_count": 6
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 0,
      "text": "--part of the tram, start to move out.",
      "word_count": 8
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 1,
      "text": "That was not the tram-- it was a tram, but that was the first-- before you come in to the covered tram.",
      "word_count": 22
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 2,
      "text": "It's only the--",
      "word_count": 3
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 0,
      "text": "--the open section.",
      "word_count": 3
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 1,
      "text": "And start to talk about the Germans bad.",
      "word_count": 8
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 2,
      "text": "And everyone, on the first stop, walked out.",
      "word_count": 8
    }
  ],
