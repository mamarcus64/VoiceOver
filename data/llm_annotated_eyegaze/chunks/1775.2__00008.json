{
  "stem": "1775.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 182.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 60,
      "text": "Don't let anybody tell you that the Germans did it alone.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 61,
      "text": "They were with them.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 62,
      "text": "They were right there in the black outfits and the black leather coats with big, you know, from, from leather made-- like you whip a horse, that thing.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 63,
      "text": "And, and they used to whip us with it, the Ukrainians.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 64,
      "text": "And they, they took the people that time.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 65,
      "text": "That was May 2nd.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 66,
      "text": "They took the-- they, they put all the soldiers around the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 67,
      "text": "And they started to take the people out.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 68,
      "text": "At that time, Saturday night, the, the soldiers, the Wehrmacht that we were working for, came and took us back to work.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 69,
      "text": "Not the following morning-- usually, they'd pick us up, you know, is, is, Monday morning.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 70,
      "text": "But they picked us up Sunday evening.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 71,
      "text": "And we should have thought about that, that something fishy is going to be happening.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 72,
      "text": "But we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 73,
      "text": "And they took us back to work.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 74,
      "text": "And all of a sudden, all hell broke loose.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 75,
      "text": "They started to get the people out from the ghetto again.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 76,
      "text": "That's when I lost the last part of the family that I had, a lot of them.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 77,
      "text": "My brother went away to Majdanek.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 78,
      "text": "My cousin went to Majdanek and another cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 79,
      "text": "And my uncle, the one that used to be like a father to me, he went to Majdanek.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 80,
      "text": "And they just took them away.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 81,
      "text": "And I was outside the ghetto, and we were hiding at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 82,
      "text": "We were in a particular place.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "There were three different places in that building where you could hide.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We had one underneath the-- what do you call it?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden, I think of a Polish name.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "The floor-- underneath the floor, we had one-- a double wall.",
      "word_count": 11
    }
  ],
