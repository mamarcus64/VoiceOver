    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes, covered with a piece of cloth.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes, after we said the four [INAUDIBLE].",
