  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And we had to drink wine from-- not from a glass, but from a [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "A [NON-ENGLISH], it means like a-- I can't describe it in the-- in the English.",
      "word_count": 15
    },
    {
