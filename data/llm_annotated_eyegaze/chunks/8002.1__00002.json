    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We had fish, gefilte fish.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "We had herring.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Of course, we had all kinds of cakes.",
