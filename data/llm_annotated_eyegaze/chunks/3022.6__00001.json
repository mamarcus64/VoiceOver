{
  "stem": "3022.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Because we all wore this, so this is-- and then we were directed to a farmhouse.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We came to the farmhouse.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And there were three other prisoners like us from another convoy that came there for the same reason.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "They heard the same story that there are Jewish women there.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And we were exchanging some information.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It was a barren room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "You could tell that the there was some pictures that the women-- that you could see the white mark, where the crucifix hung, that they took off the wall.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And after a while, these three women came in.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We have seen each other in terrible shapes.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "We saw friends dying next to us.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "We could tell when the person was going to die, how many weeks he had to live.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "We could tell.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "If your feet swell up, you had four weeks to live.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And after the swelling went down, you got two weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And with our friends, you go to the latrine, we used to follow.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Because we knew today or tomorrow he's going to die.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And we used to watch them sometimes die sitting on the latrine.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "We knew, we could tell.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "We had [GERMAN], people who were walking skeletons.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "But we were not prepared for what we have seen.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "We have never seen Jewish women emaciated, drawn faces, their heads shaven, with the long caftans.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And we started-- of course they were not our kin.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "We started the conversation.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "Two of them were from Slovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "One of them was from [SLOVAK].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "They knew nothing about our relatives.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "They were in Auschwitz, and then they were in the transport.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And they went to a factory, and then they were-- the war ended when they were on the march.",
      "word_count": 19
    }
  ],
