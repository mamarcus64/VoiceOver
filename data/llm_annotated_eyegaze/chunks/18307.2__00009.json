{
  "stem": "18307.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I was a bus girl because I couldn't-- I couldn't be a waitress because I couldn't speak English.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I was a bus girl, I was-- you name it, I did it.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I worked very hard, very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And at the end of the day-- the end of the week, Mrs.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] would leave me $10.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And all of the college boys I worked there with say, how did you manage to get $10?",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And I said, well, when her tea was hot, she wanted it cold I ran for an ice cube.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "You don't do it, [LAUGHS] you know.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And that's-- you know, I didn't speak English, so that helped.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "About 18 and a half.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "About 18 and a half.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I had no big wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I-- I think the rabbi was Rabbi Rosen.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "He passed away soon.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I got married in a polka dot dress, a navy blue polka dot dress, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And my mother-in-law, she's still living, thank god, she made-- she made a little party in her house and this was our wedding, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And-- I have a wonderful daughter today, Miriam; a wonderful granddaughter, Lisa.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Marvin, but everybody calls him Sonny.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Everybody calls him Sonny.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, he had gas stations and then he had taxi cabs.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He owned a couple of taxi cabs.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And he sold them.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "He didn't really-- it was-- it was getting too dangerous.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And now he's just-- he's retired, more or less.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "But he drives a limo once in a while, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Gives him something to do.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "He's too young to retire.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Well, when-- when I first moved to this house for-- we joined Shaare Shamayim, the synagogue around the corner.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I was [? the only chairman of ?] sisterhood of Shaare Shamayim.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It was nice.",
      "word_count": 3
    }
  ],
