{
  "stem": "6076.7",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Well, they were all withdrawn, quiet.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Herlig's lips were always white.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I call her Herlig-- Herlig.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "In the book, I changed her name.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Because her son lives in New York, and I didn't want to have nothing to do with her son.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "But I am the witness how his mother survived.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And I will say that when I called him up and told him that I'm going to write the story about his mother, he didn't answer me.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "So I didn't want to mention the real name, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "He's a lawyer now and in New York.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "He didn't want to do nothing, really.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "He was the second generation.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I was very hurt that he gave me such a cold answer, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Instead to be-- to appreciate that I want to bring out the memory from his mother, he wasn't-- I didn't think that he was so happy.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "So I let it go.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "I changed her name to Herlig.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Herlig was a big woman, husky woman.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "She was tall.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "I knew her.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "I knew her husband.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And-- but she probably-- she was in her-- when she came, she was in her fourth month.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "But what she did, she stole a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "You know what means a [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "We were wearing striped dresses.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "When we came to Leipzig, they gave us the wooden shoes, you know, the Holland shoes, they call it.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "They didn't shave our hair.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "They gave us the striped dresses, the prison dresses.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "Once in two weeks, they changed the dresses.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "We took showers, and they gave us other dresses from somebody else.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "Whatever they did, though, maybe they steamed them or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "The work was the same.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "Food was--",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Stripes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "There was gray.",
      "word_count": 3
    }
  ],
