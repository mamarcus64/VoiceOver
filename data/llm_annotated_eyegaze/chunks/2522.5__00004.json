{
  "stem": "2522.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Went to England.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "The brother of Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Kubicek by that time was well established in England.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He supported me.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "You know, I went to school, catching up on my education.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Got excellent private education in England in-- from-- from February '48 to October '48.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And in October 15, '48, I got finally an American immigration visa, which was very hard to get.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Got on a ship, a freighter ship, in Plymouth, England for $95.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I got a berth on a freighter ship.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And 13 days later, showed up in America.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "For the first 18 month, I stayed with the Kubicek family in their house.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "My first job was to-- to sell socks at the Gertz department store in Jamaica, New York for $0.65 an hour, which I thought was absolutely fantastic income.",
      "word_count": 28
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "You know, you could really live in America for $0.65 an hour in those days, I mean, luxuriously.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "You know, by my standards.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "I was told that-- that in order to be able to go to university, I need a high school diploma.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "So while I was selling socks, I also went at night to Jamaica High School for a year and got a high school diploma.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "Graduated from the high school in May of 1949.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "I applied for admission to City College, Brooklyn College, and this place called Cooper Union that everybody told me I could not possibly get into because it's so competitive, and it's free.",
      "word_count": 32
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "Whereas in Brooklyn College, at City College, you had to pay for lab fees.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "It was free, no tuition, but lab fees.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "And there was no way in the world how I was going to get $150 somehow.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "I mean, just, you know, the idea of having $150 was just beyond my imagination.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "I applied to Cooper Union.",
      "word_count": 5
    }
  ],
