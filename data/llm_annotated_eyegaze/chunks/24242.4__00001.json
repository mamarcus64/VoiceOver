  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Nevalduk ?] to us, he was given a horse-- a young, strong, healthy young man.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] I'm not going to call him by the name because people that know us and they will hear about the interview, they-- they wouldn't-- it's not right.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "I will not mention his name.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "He was given a horse.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 5 SECONDS] The horse, in order to horseback riding.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "This was like practically as good as a rifle.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "If you had a horse, a good horse, and a rifle, if you're armed, you had 80% chance of surviving life.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] He was given a horse.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "He tried-- now, picture for a-- for a moment.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "He tried-- you get on the horse in order to horseback riding, you get in from the left-hand side.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "So he tried to get on the horse, which he got on it, with his right foot.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Can you picture for a moment?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He sits on the horse with his right foot.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The young man there understood what I said.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I hope you under-- [PAUSES FOR 3 SECONDS] this is the different [PAUSES FOR 3 SECONDS] from a city person to a farmer in those days.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I'm giving an example why-- what was about my brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Of course, there were tough people in the city, but they were different.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "They grew up under different circumstances.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] This very same man, I'm giving you-- not that I heard, I saw it with my own eyes.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I started to laugh at him.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "So he gets off the horse and runs after me, wanted to hit me.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Why did-- I laughed at him all my life.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Later on, he turned out to be among the best.",
      "word_count": 10
    }
  ],
