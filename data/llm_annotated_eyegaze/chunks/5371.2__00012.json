{
  "stem": "5371.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I was healthy.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But the last selection, which was in 1943, the end of 1943, was at night.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They gave an order, all Jews are out in the-- in the main street in the camp.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And we all formed-- you know, like, we stood in six-- which was a long line, because we were mostly Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And they were-- they said they're selecting Jews to work in the crematorium.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But they did select some.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But most of them they-- they took to the gas chambers.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "At the time of this last selection, I had like little [PAUSES FOR 4 SECONDS] pus, you know, little pieces on my chest, all over my chest, here.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I was afraid that if I approach him and he sees this, then I'm a real-- a sure candidate for the gas chambers.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So I moved back as far as I could.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Slowly I moved back the rows.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I moved to the last row.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I ran.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They were chasing me, but I ran into one of the blocks where the Sonderkommando was still based in our camp.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I was hiding there, and they couldn't find me.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I-- lucky enough, they just left.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And then I went back to my-- to my block.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] We-- I worked for that time for a company, a German company by the name of Neubau.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "That was a construction company.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "We used to do all kinds of work in the camps.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "We used to fix the ovens.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "They used to split from the heat, so we used to-- in the crematoriums.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "We used to fix the ovens.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "We used to fix toilets.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "You know, there was public toilets in the camps, in the ladies' camps, in the women's camps.",
      "word_count": 17
    }
  ],
