{
  "stem": "597.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "She-- She was shivering like a-- like a leaf from-- from-- from afraid, she was afraid.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "She was very afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Scared.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Shivering like a leaf.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Until 4 o'clock. 4 o'clock we was sitting there, and my father was a smoker.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Big smoker.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "He used to smoke all week.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "But Saturday-- Friday evening, no smoke till Saturday evening at night.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "He used to cough a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "My father.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "But that time, in the attic, he didn't cough.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "Quiet.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "Everybody was quiet.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "It was late, and my sister was quiet down.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "My mother quiet her down.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "She was a kid.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "A little kid still.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "To quiet her down a little bit, she was to quiet down already.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "By 4 o'clock, we hear some voices from people.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And they said, you can go out, wherever you're hiding places.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "You can go out, because it's now, they are-- they are making a ghetto, and you have to go.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "Everybody has to go in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "That was the day from the first, you know, gathering people.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "That's the way we hide.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "We stayed alive.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "According to my mother and my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "That was May 21st.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "1942.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] Then we went out.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We came down.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "In fact, somebody was, the Ukrainian people was open.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "They used to go-- they went in all-- all the houses.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They rape, they take all the things away from the houses.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "My father saw they was taking some things from the house.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He said to my mother, I want to go down.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I know the guy.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "You shouldn't take my-- my things from the-- My mother, keep quiet!",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "They're going to discover us.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Let them take whatever they wanted.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So the windows, they drag out all the things.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Everything.",
      "word_count": 1
    }
  ],
