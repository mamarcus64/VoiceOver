{
  "stem": "14212.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "So the-- the whole thing changed for me because I was willing to go to see my brothers.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "And I gave over the kibbutz.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "And this was the kibbutz who used to be responsible for the travel and exodus.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "This kibbutz was taken over by a different Arieh.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "My Hebrew name was also Arieh.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "A different Arieh, who was the only one person who the English people brought down on a stretcher from the ship.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "And the [? only ?] woman who died on that ship was my kibbutz.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 3 SECONDS] Then I came to Stuttgart.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "Next few days I've been in Stuttgart.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "My parents, the whole family, were killed in Treblinka-- my sisters, my uncles.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "My father had five brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "The oldest brother, [NON-ENGLISH], was shot in his bed because he was a diabetic, sick.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And he couldn't go to the march, so they shot him there in bed.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "He had a wife.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "He had three daughters and a son.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "One daughter has six children.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "Two daughters survived.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "One died in Tel Aviv.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "One lives in Haifa.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "The other one has four children.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "Two children survived.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "One lives in Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And one daughter lives in Rochester, New York.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And the son with a wife, who used to be the granddaughter of the [NON-ENGLISH] rabbi, with two kids, they went to Treblinka.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And a daughter with a husband and a child, they went to Treblinka.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "Second brother had five kids.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "Four sons and a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "One son survived, lives in Berlin.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "The rest went to Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "Another uncle had six kid-- children.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "Him and his-- he was killed in Schlieben, concentration camp Schlieben.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "His five kids want to Treblinka.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "My father had an older sister, [?",
      "word_count": 7
    }
  ],
