{
  "stem": "11296.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "And, you know, it was terrible in the house-- no-- nothing to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "The other way, all the-- all the stores in the-- in the town-- in the city-- it was roped from-- from-- the Polish people broke in in all the Jewish stores.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "And they took out everything, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "There was no money.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "There was no food.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "There was nothing, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "I don't know how we survived or what the mother did.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "I really don't-- cannot tell.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "I tried to go and bring something myself, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "I went to the store, you know, whatever they-- the Polish people left potatoes.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "We picked it up, and we brought home.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So when the family came back-- and this was a very-- a tragic coming back.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Because there was still bombing, and there was still people who was trying to come back.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "The German catch them.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And there was-- they're looking for the papers, where they're going.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Nobody had passports.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Nobody know nothing what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Eventually, they-- everybody came home.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And the tragedy started.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Nope, there was no money.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "There was no work.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We were still living in our own house.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "This was 1939 till 1940, I think. 1940, in the spring, they said they're going to put all the Jews in to one place.",
      "word_count": 24
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And the town, it was not big.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "The-- the-- they picked out the most-- the-- the-- the worst part of the town-- the poorest part of the town.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "There was no streets.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "There was just stables from horses.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And they said all the Jews are going there.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So the place where we lived, we had to move out, take our belongings, whatever we still had there-- the little furnitures or things like that.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And we went on a place-- no-- no house.",
      "word_count": 9
    }
  ],
