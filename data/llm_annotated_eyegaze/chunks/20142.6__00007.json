{
  "stem": "20142.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "All depends how close was the enemy.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But there were sporadic cases that kids-- how do they got to this equipment and jumped off the balconies under-- underneath the tanks to explode them.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "There was a sight that only people who were actually witnesses could-- could describe it.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "On one side, you wanted to scream out of glory for-- for such thing.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "On the other side, you knew another youngster, innocent youngster, just sacrificed his life for this, saving some-- some other people.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I did see this on Zamenhof Street.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "There was a-- a tank was entering the ghetto through the Gesia Street.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] the [PAUSES FOR 3 SECONDS] SS men had a tank and open dome.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And a youngster jumped out out of a second- or third-store balcony with a lit bottle-- cocktail-- Molotov cocktail and just happened that he fell in front of the tank.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And the tank crushed him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "The chains of the thing-- of the tank crushed him.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "But he succeeded to-- the bottle-- the Molotov cocktail succeeded to explode and explode the tank.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "There were three Germans that jump out of the tank when they have seen it.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And they were-- the uniforms were afire.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And what happened to them, I don't really remember, didn't-- didn't care.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "But that was a glorious moment to see how a-- a child could sacrifice his life for the sake of exploding such tanks.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "That was most likely on the fifth day of the-- when the fighting began.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Fifth day-- oh, third day of the fighting, when it began.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "In other words, by the-- on 22nd of April.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We used to call this in Polish [POLISH], means 'bottle of gas.'",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "A bomb?",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Pardon me.",
      "word_count": 2
    }
  ],
