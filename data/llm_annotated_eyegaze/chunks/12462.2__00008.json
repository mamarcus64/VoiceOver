  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] The documents I found that night in Paris, just before the invasion of Norway and those afterwards, directly bore on the commission of aggressive war by the Nazis.",
      "word_count": 32
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "When Justice Jackson got the translation of these documents within the week-- he was then in London-- he was extremely pleased.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And that led to my getting-- to have something of an in with respect to finding documents, which is very funny because I was not that great a linguist or anything like that.",
      "word_count": 33
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "But you know, you-- you did the best you could.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Well, Colonel Storey had had a-- a very considerable interest-- considerable life doing special missions of one kind or another for one group or another.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He eventually became the president of the American Bar Association.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But somehow or other, OSS picked him up and wanted him to become a major deputy on the Jackson staff.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So OSS hired him.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I met him as he was going through Washington in June of 1945.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And he said, I would like you, whatever I'm going to do overseas, to be one of my assistants.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And I said, well, if you can arrange it.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So when I got, within a week or so, a notice from Paris that he wanted me to come, I was very glad, and I did go within a couple of weeks after that.",
      "word_count": 34
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "About two months.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "But during that time, I flew in to Wiesbaden and Frankfurt and back to London.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And I-- because of my background in labor and because of my OSS connections, I-- I met some labor leaders who had escaped from Germany before the Nazis grabbed them and had taken up foreign residence in Great Britain.",
      "word_count": 39
    }
  ],
