  "elapsed_s": 35.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] In Hungary, the high school is eight years.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Its called a gymnasium.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And it was extremely important.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "That's the only high school we had in Szeghalom.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They did not want to take any Jewish children to high school.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "There would be no possibility.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "There was nothing around the town anywhere in the area.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "This was the only high school.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And the principal insisted that every Jewish child who was capable, he should be admitted to school and goes through with a high school education.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And he said if that wouldn't happen, he would resign.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "The man was so important and, and so good.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And he was the friend of the minister who became the president of Hungary later that he, he really put his stamp in the school.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And all the teachers followed his, his rules and his behavior, except for my phys ed teacher that I mentioned before.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "This-- incidently, this high school principal became the Secretary for Education after the war in Hungary.",
      "word_count": 16
    }
  ],
