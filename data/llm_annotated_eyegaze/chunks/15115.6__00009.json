{
  "stem": "15115.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] Bank of Commerce made a certified check to go get the store.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Would you believe it?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I didn't have the guts, the strength, to walk from this sidewalk to this sidewalk, which was the store.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I said to myself, I'm doing something wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I'm doing something wrong, because I'll be competition with my old boss.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He was so good to me.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "He was so good to my kids.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And I'm going to go, and I'm going to kill him, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Go across the street-- I'm doing something wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "So I-- I didn't go across.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I went into the car.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I went, on Young Street, to a tavern.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And I had two doubles of Crown Royal on the rocks.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And I went in my car.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "I fall asleep.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And around 6:00, I woke up, and I come home.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "My wife says, what happened to you, dear?",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "The guy's looking for you.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "He's phoning the whole day long.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "I says, honey-- I says, you know something?",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "I'm doing something wrong.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "There's no way that I should buy this business.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "Well, OK-- says, you don't want it?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "Go and tell the guy.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "So the next day I went.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "I took three $100 bills.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "I give him $300.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "I says, here's for the trouble I give you, for Sunday that we took your stock.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "I says, I'm doing the wrong thing by buying this store.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "I don't want to go competition with my ex-boss, which he was good to me.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "He realized that.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "He took the $300, and I was happy.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "And I started doing business from my basement of the house, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "I started selling typewriters to lawyers and doctors.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "I had a friend in Montreal.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 37,
      "text": "He says, hell, I'll send you some typewriters, used electric typewriters.",
      "word_count": 11
    }
  ],
