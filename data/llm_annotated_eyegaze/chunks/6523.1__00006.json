  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "One in-- let's say one in 10, two in 10 could afford a bicycle.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Very small group of people what they could.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I myself was in a group, like I belonged to a youth movement what-- In the neighborhood-- same thing like United States.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "In United States it's like gang.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Over there was not like gang.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Was a difference because of anti-Semitic.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They fight, and we were stronger, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And not, not everybody let beat himself up, beat himself up.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I'm talking when we was kids.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it's ridiculous to tell it.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We didn't try.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We was-- kids would try to learn.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We didn't learn in school.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We learned like I-- I never want to repeat myself.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We belonged to this youth movement.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And we learned about everything, like you-- I mentioned to you.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "You like to know like we come back-- we will talk later on about this-- we come back for, for the Holocaust.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "I mentioned to you I was bitter.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "Nobody-- millions and millions been annihilated.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And nobody even know until now 50 years later come a guy with the name Spielberg woke up the people and let them know, the people, what was going on.",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I give example.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "We lot of-- the whole time, lived under pressure when it come to Jews and Gentile, lot of pressure.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "The-- we, we didn't like the Poles.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The Poles haven't liked us.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "The Poles, I think, it was a reason.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They thought we, we haven't participated in their colleges and their schools, or intellectual, we'd been more advanced is a reason.",
      "word_count": 21
    }
  ],
