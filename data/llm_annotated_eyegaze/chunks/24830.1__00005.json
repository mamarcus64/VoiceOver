{
  "stem": "24830.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Well, I thought it was big till I came back 25 years later.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "It was a very nice street.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And there was-- right in that street, there is a store called [FRENCH], which is very known, even in this country, where they serve very good food-- a special kind of food.",
      "word_count": 32
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And at the end, there was a Cinema Le Madeleine, a movie theater called Le Madeleine.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And at the very other end of the street was a department store called [FRENCH]-- the very end.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And not too far was [?",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "Le ?] Gare Saint-Lazare-- Saint-Lazare Station.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No, not the ground floor.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We live in the third floor.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "And the business-- the business was in the fifth floor-- the whole-- the whole-- you know, the whole fifth floor.",
      "word_count": 20
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "It was a big house-- I mean, a big apartment house.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And then the fifth floor was where we live-- eat and sleep.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And then my parents got some customer who didn't want to walk-- especially American customer-- they didn't want to walk three floor.",
      "word_count": 22
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "So my parents built the-- an elevator.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "It's still there when I-- [LAUGHS] that was my parents' doing.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "They built an elevator.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, the whole-- the whole house.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Well, the-- let's see-- third-- the second floor was somebody doing millinery-- doing hat.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And the four-- the fourth floor some-- it was somebody doing-- how do you call corset, brassier, and all kind of thing like this.",
      "word_count": 24
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And then we have what you call maid room.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "Maybe we had two maid room at the very top, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the sixth floor.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "I remember because it became important during the war, this-- this-- actually, when I stop-- well, we had maid.",
      "word_count": 19
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "But not-- later on, we didn't.",
      "word_count": 6
    }
  ],
