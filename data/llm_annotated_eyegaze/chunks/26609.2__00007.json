{
  "stem": "26609.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if they're still alive.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I'm not in contact now.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She [INAUDIBLE] used to write there was-- excuse me.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "There was A Polish paper, a Jewish and Polish [?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Shmela. ?] I don't know if anybody remembers it, in the Lwow.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "My mother used to write articles into the-- not many Jewish women in that time could do that.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "She used to write.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "It was in Polish language.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Jewish, they wouldn't allow it.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I don't remember-- in America, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Not in Poland, I don't remember a Jewish paper in Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "But this was-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "Shmela ?] was a Jewish paper in Polish.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "That was allowed.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And my mother used to write poems and articles.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "She used to write me a poem-- I haven't got it.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "That is so many years-- with my name, Spiegler here and over here.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "It matched up each letter, the words.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "She was really beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "Not one child was like my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "Very fair with blue eyes, blue eyed.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "And highly intelligent.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "But she met a terrible death at-- at Hitler's time.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, we were not-- the children were not brought up very religious.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No, because my mother-- my mother used to-- she didn't want to say it openly, because other people-- I remember only my mother said, when I go to the synagogue, only on the-- only because of neighbors, Jewish neighbors, because they would say she doesn't go the synagogue on Yom Tov.",
      "word_count": 51
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So she used to go on-- on high holidays.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And she came home, and she told me-- I don't know why she told me, not others.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I was young then, very young.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "She said, I can't stand it.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Those people there-- only women were, you know, with the partition, like it's different here.",
      "word_count": 15
    }
  ],
