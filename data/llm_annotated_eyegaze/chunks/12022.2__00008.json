{
  "stem": "12022.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "And I see the Russian running with trucks, by foot.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "And everywhere, they're, they're running all over.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "Then my--",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "They're running, they're running-- they, they don't know where to run.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "They are running away from the, the [INAUDIBLE] of the trucks.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE], they're running like to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And when I see-- I hear they saying, the Germans got close.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Then mine cousin said, we'll go in a village.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we'll stay overnight.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We went in the village.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Not too far away, maybe about 10, 12 kilometer, or something like that, you know-- not too far.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We went to the-- by the next day, it was so quiet, we came back.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "The Germans already in, so no use to go there.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Because the Germans is in.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Finally-- this was in the morning-- later at, at night, not before noon, before, before four o'clock, it was a sign hanging out by the Lithuanian.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They were ready to make a government with police and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Jewish not from that area got to leave the area.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "If not, they will be shot.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "I went to the mayor to allow me to stay, because the front is going.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I, I can't-- I would glad to go.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "The front is going.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "The mayor-- I come in.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "I said like hello in Lithuanian.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "He answer me and then start to speak to me in Lithuanian what I want.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "I understood him pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Oh, just I ask him, maybe you know another language to speak-- maybe Russian or German or Polish?",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He said yes.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I told him I'm Jewish and this.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I got to leave the town.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Because-- you know, and I couldn't leave because the front is going.",
      "word_count": 12
    }
  ],
