{
  "stem": "26447.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 40,
      "text": "And we hear what people, Ukraine people comes and feed the-- the animals, the horses, the-- the cows.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 41,
      "text": "You know, and I see we were saying to near to the father.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 42,
      "text": "But I can hear him and he hears me.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 43,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 44,
      "text": "I say, father, we don't hear nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 45,
      "text": "Maybe-- maybe it's something wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 46,
      "text": "We decided to come out-- out.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 47,
      "text": "When we come out from the straw and we saw they come.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 48,
      "text": "It was on the roof, the top where the straw.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 49,
      "text": "And they saw us and begin to-- to call [NON-ENGLISH], meaning in Anglo, Jews, come out.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 50,
      "text": "Well, they take out us from the hole with a ladder, we come down.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 51,
      "text": "It's a-- the Germans around.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 52,
      "text": "The father begin to talk to them in German.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 53,
      "text": "And to ask them what-- they beat the father.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 54,
      "text": "They beat me.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 55,
      "text": "They beat the rest of them.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 56,
      "text": "No, we saw that the situation, it's terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 57,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 58,
      "text": "Nothing to do.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 59,
      "text": "They take us to the ghetto-- to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 60,
      "text": "And it was, I remember, like now, it was a sunny day.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 61,
      "text": "Very-- it was summertime or it goes to the fall time.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 62,
      "text": "They take us to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 63,
      "text": "And they put us in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 64,
      "text": "And I saw that the brothers, too.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 65,
      "text": "They was looking everywhere to find more the Jews who was left-- that's from our second pogrom.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 66,
      "text": "The guy, the Jewish guy that's from Poland-- I don't remember his name.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 67,
      "text": "He said, what I have a pistol.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 68,
      "text": "You know, I don't know how [INAUDIBLE] because didn't check how.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 69,
      "text": "We will go, young people.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 70,
      "text": "We will go first.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 71,
      "text": "And maybe in the way, what they will take us.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 72,
      "text": "We will try to-- to something to come out.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 73,
      "text": "When I-- in the-- in the ghetto, in the house, I tell my father.",
      "word_count": 14
    }
  ],
