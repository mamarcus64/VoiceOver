{
  "stem": "2735.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "And we all this-- everybody dispersed.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "They were screaming high-- fall to the ground.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "Fall to the ground.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "I was with my-- one of my sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "My parents weren't with me.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "My youngest sister wasn't with me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "In a ditch, we fell in.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 36,
      "text": "And they went down with machine guns.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 37,
      "text": "And we got up.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 38,
      "text": "There were so many dead people.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 39,
      "text": "And I didn't know where my mother and father-- and where my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 40,
      "text": "Well, anyway, we found each other.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 41,
      "text": "And that's-- that was still in the beginning.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 42,
      "text": "And when we came to Novohrad-Volynskyi-- and I don't remember.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 43,
      "text": "We stayed there a few days, because I really couldn't walk at all.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 44,
      "text": "And we went on a train.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 45,
      "text": "And we stayed in the train for days.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 46,
      "text": "And one time they bombarded the railroad station, but not exactly our train.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 47,
      "text": "But you had to run and hide.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 48,
      "text": "Eventually, we left.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 49,
      "text": "And we came to a town called Kiev, which is today the capital of Ukraine.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 50,
      "text": "It's a beautiful city.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 51,
      "text": "You didn't-- you didn't feel that there is a war.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 52,
      "text": "And-- [PAUSES FOR 4 SECONDS] --we had to go with a little-- [PAUSES FOR 4 SECONDS] --with the-- this wasn't a ship, really.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 53,
      "text": "They were transporting strawberries with it, probably from one town to another one.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 54,
      "text": "They said they'll take us this, and take us somewhere else.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I-- I mean, I lost track.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I-- I-- maybe I didn't keep track all together, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "When you're with parents, you just let them think about it.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So we did it-- we'll-- that they'll take us somewhere else.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And when we left there was no place to stay, anyway.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We came to a town called Kuybyshev.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Kuybyshev was a known place, a Jewish city.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "It was a beautiful summer night.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We were so exhausted.",
      "word_count": 4
    }
  ],
