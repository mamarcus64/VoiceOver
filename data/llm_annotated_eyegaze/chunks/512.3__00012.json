  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And he says, if you don't leave, I'll kill you all here.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "So we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "But then we were sort of walking in daze, looking whether you can pick up a little food.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And we came to the railroad station where the, those cattle cars were.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And there were refugees from-- you know, Gentiles from Slavic or whatever, prisoners or whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "They had broken open some of the cattle cars.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And there was food.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "So I got two breads.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] While I was getting the two breads, I was attacked by others.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "Hungry people grabbed those two breads from me.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "And went back.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "I was able to get a piece of frozen raw fish.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "We ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "We got very sick because, first of all, our stomachs were very-- you know, we didn't have food.",
      "word_count": 18
    }
  ],
