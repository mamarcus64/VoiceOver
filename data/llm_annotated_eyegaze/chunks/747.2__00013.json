{
  "stem": "747.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "I can't even remember if they were boys or girls.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And their grandfather.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So they snatched the grandfather away.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "The four sisters were holding into the three little kids.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "When my mother saw that Mengele is making rows of five, he-- she pulled the three kids to her and pushed me to be the fifth with these four girls, the tall, good looking girls.",
      "word_count": 35
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And she meant-- she told them, I'm going to take care of the children, and you take care of Judy.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "How did she know?",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "How did she feel that this is the right thing to do?",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And I just turned to her, tell her that no, mother, I want to go with you.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "She said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "You just go with them.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And a minute later, she disappeared.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I never saw her again.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So she took the four little children with her to the gas chamber, and that's how I survived.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "These four girls were really good to me.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Until they came-- and the first selection, and we got the number.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And nobody knew that we are not sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "They were my height, and we were very close.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "They were really good to me.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And then the next thing I find myself in the bath house.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, my brother went with my father, with the men.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "The youngest-- well, I had two brothers, and my older brother was in the army already.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But the little one went with my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And the 16-year-old, Simon, went with my father.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "It just went so quick that I turned my head, I didn't see them anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "It was thousands of people came in.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And the music was playing in the corner.",
      "word_count": 8
    }
  ],
