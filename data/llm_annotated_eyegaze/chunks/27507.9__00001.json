{
  "stem": "27507.9",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "There was danger of being recognized, of being-- of being denounced to the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "There were whole sections of Polish population who were practically living the different-- the lowest criminal layers of the society.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "There were many who were now making their living out of finding the Jews who were hiding, of blackmailing them, of getting bribes or money out of them.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "And in many cases, although they were-- they were getting money out of them, they still would give them to the Germans, or to the-- or to the Polish police.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "So it was very dangerous.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "And it was-- anyway, it was-- for the Poles, it was-- to keep Jews, or to try to save Jews, was as well terribly dangerous, because, really, from that point of view, if they found-- if the Germans found that Poles are sheltering Jews, then the Poles themselves face death as well, or at least going to Auschwitz-- so mostly death, I would say.",
      "word_count": 64
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "So it was a terribly difficult decision.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "My family had some contacts on the Aryan side of Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "They heard that there was this Polish woman who was working as a house help, or maid, for my oldest uncle before the war.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "And she was-- her name was Jula.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "And she was very-- she was willing to help to save some family members.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "And she was particularly keen to save the girl, the daughter of my uncle, Damka, who was the 16-year-old girl who was with me in one of those actions.",
      "word_count": 29
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "And she was now 16 or 17.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "And Jula wanted to save her.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "And-- but she was as well prepared to save, or at least to help to save, other people as well.",
      "word_count": 20
    }
  ],
