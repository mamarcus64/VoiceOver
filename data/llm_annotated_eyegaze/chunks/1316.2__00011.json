{
  "stem": "1316.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "She was blonde-- she knew Polish, and she was grown up in the village.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "She took them out of the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "She took the trains without tickets.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And somehow, she came back to that village.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And she-- the Poles helped her.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She arranged a boy in one village with a farmer-- the girl in another village with a farmer.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And she nearby-- and so they were in touch.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And they survived.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "She told me a few things that were important.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Once, she traded something-- she used to go to the Warsaw ghetto, and buy things for cheap-- clothes for food, bring food, and bring and then sell the clothes.",
      "word_count": 29
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "So she came to the police station to trade-- and she noticed in the-- the train station, not the police-- in the train station, she noticed Germans there-- German soldiers, officers.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "She didn't know where to hide.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "There was a big dog in a dog house.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And it looks that the dog knew her.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "So she pushed her in the dog house.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "The dog was quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And she waited until they left, and she went out.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "The son told me-- he lives in Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "This farmer that he worked-- he-- attended the cows, and the swines-- he took him Sunday to the church.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "The Polish boys somehow had a feeling that he was not Polish.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And the priest from the pulpit reproached them and said they shouldn't bother him-- he's-- you know, he's Polish, and so on.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And so there were Poles that helped them.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Otherwise, they couldn't survive-- they survived.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "Oh, after she went to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "She died, I met her in Haifa.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "And she died there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "They said her daughter has two children in New York, the son has four children in Paris.",
      "word_count": 17
    }
  ],
