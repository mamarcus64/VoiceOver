{
  "stem": "14552.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And eventually, eventually, we were put on the-- the ones they could clean up, we were put on to buses.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And we were going towards Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And that was a very, very nice thing.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "The bus driver pulled up to a cherry orchard.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And he says, eat cherries, whatever you want.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "So we helped ourselves to the cherries.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And we went to Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And there the, the UNRRA, the [INAUDIBLE] has helped people.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And we were standing-- my sister and I were standing in front of a building.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And we said, what's now?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Now we have free.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] We are skin and bone.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "We have nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And there comes this gentleman.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And I had a picture of him in gray spats and morning coat with a top hat.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Real-- dressed for a-- the proper way which was at the time when you're a gentleman.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And he says, do you ladies have cigarettes for sale?",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Which was the most unlikely questions, but this was his opening statement.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And then we says, no.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We just came from Theresienstadt.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And we still spoke Czech.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And he was very interested in our story.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And then he says, look, I have a friend in the Podolski Sanatorium.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Why don't I take you there and let him examine you?",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "So he puts us into a cab.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And we were not worried that this gentleman from no place is putting us into a cab.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We went.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Meanwhile, he gave us food.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "He fed us.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And we come to this sanatorium.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And his friend looks at us, and he examine-- he puts-- gives us-- me an x-ray.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And my lungs have been infiltrated with TB.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And he says, she goes to the TB section in the sanatorium.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "My sister he put into the-- to the-- heart pavilion.",
      "word_count": 10
    }
  ],
