{
  "stem": "26790.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was only three years old.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "My grandfather was alive, but was religious people, [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And as a matter of fact, every Jewish people was half religious, full religious, they was in touch with the religious people.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Because that life was in that time, was that life.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Till I got-- until I-- till I got 16 years age, I started working, I-- every Saturday, every holiday, everything, I was-- I was nearly every day in the Jewish synagogue, every day.",
      "word_count": 33
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But when I started working, and I started to coming to the youth organization, I started to become between a working class people.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I started a little bit more away from it.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I-- as a matter of fact, I didn't have, because my father was not alive, and I didn't have any-- any celebrations like that.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He was-- like a family today, over the table, they have meals and pray the night.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have this-- these conditions.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Because my father was not alive.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "But Yiddish people in [NON-ENGLISH], they was-- all the family was come together Friday night to have celebrating Friday night Shabbat-- Shabbat meal, singing songs and everything.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "We-- I was-- as a matter of fact, I was living in the down-- downstairs, and the synagogue, my synagogue was upstairs, a little synagogue that [NON-ENGLISH], from tailors, shoemakers, tradespeople.",
      "word_count": 31
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They might come together that they make it-- they arranged to make it a synagogue.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They didn't have a rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "All we wanted, no religious or religious men from the town, from this-- from this part, there was a more arrangement, he was serving something like that, but not special service, for religious service, not a rabbi.",
      "word_count": 37
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Because it was ordinary people.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "--died.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My mother used to do homework every day, used to do homework.",
      "word_count": 12
    }
  ],
