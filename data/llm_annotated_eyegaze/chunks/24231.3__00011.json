{
  "stem": "24231.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I was helping with packaging and stuff like that and delivering packages in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And then I said, you know, that's not a job which I want to do all my life.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "So I went also on my own.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I used to live with him on Park Avenue, and then I moved into Yorkville section in-- in Manhattan.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "I got acquainted with some of the Czech fellas.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "I-- started-- I was a good soccer player, so I started to play soccer.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And [PAUSES FOR 3 SECONDS] I started to polish furniture to make some money.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "And then the Korean War broke out, and I-- I was eligible to go into Army.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "I said, well, maybe I go into the Air Force first, volunteer.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "I volunteer, I went into the Air Force.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "I stayed in the Air Force.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "I went through-- through Air Force radar-- radar school.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "And I was assigned to [INAUDIBLE] installing radars.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] On St.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Albans in Vermont, one-- one section.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And then I was discharged.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I-- then I got a job working as a technician and making fuel gauges for a company called [INAUDIBLE] I stayed with.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And in the meantime, I went to school at night to Brooklyn Polytech.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I became an engineer in this company.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "After 13 years, the company went to bankruptcy.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "I worked for Kollsman.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "I worked most of my life in defense, working anywhere from radars to radar warning systems and sonars.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And then towards the end, I was in management for a company called General Instrument.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And at the end, we were sold out to Litton, and I went into retirement.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "As I was playing soccer, I got acquainted on the field with my wife.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And we got-- we got married.",
      "word_count": 6
    }
  ],
