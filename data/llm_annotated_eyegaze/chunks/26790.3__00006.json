  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "I went into this man's work room.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "The man standing, he's doing his work.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I tell him, I want to have a talk with you about a very important matter.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "He didn't took notice what I'm saying.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "He just say, can you tell me-- He just looks on me-- He just looked on me, he just-- and he still keeps, keep working.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He put away this screwdriver or the hammer, what he hold in the hand, and he turned and he said to me-- and he started scratching with his finger on his beard, started scratching, and he yell it out, I wanted to know with who I'm talking!",
      "word_count": 47
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I tell him quietly, you talk with a young man which escaped from Poland with his girlfriend.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We was got-- we got married in the-- in the [INAUDIBLE] office.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But my girlfriend-- my wife, for she already a wife, she want to get married [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I told him three word in the Hebrew, in Hebrew.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He saw I am speaking Hebrew, that's mean I'm not something like that.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I see, hear what I'm speaking Hebrew [NON-ENGLISH] according to Jewish law.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He turned his head to me, and I tell him, the reason why I'm coming to you, ask about chuppah, you remember I brought you a Primus to fix it?",
      "word_count": 30
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "You told me, you can't fix it because it's [NON-ENGLISH], you're fasting.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "As he see what I'm talking about, he find out that it's not a monkey business.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "This is true.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He told me, can you tell me your name, and your girlfriend's name, and your parents' name, but told me your Yiddish name, and the name what you call up to the Torah?",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Not [NON-ENGLISH] name like John, Jim, something like that.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Yiddish name.",
      "word_count": 2
    }
  ],
