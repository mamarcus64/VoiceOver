{
  "stem": "5375.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "One afternoon, they grabbed them into truckloads and took them out in a field, and they shot them all up.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "When we came in at night, we saw them.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "All those elegant people with their fur coats, all butchered up.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We had to unload them from the truck, to undress them, to dig big ditches, and to lay them down.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "One with the head that way, and the other one with the head this way.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "How many more they should be getting?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The clothes-- they had to undress them completely, because the clothes could say witness that who you are.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But this way, they were pouring some kind of chemical over the bodies, that they should rot.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they should burn sooner, rot faster, you know-- they rot in the ground.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Now, we were working in the field.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "At night, I came-- it was a big pile of clothes outside.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "They let them rot there, the clothes-- fur coats, and foxes, and whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "They let them rot outside.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "They didn't-- didn't have use for them.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I used to bring in corn.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "We used to-- I used to burn the corn on the field there, by the fire.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And I filled up, under my shirt, between my shirt and my body with corn ears, burned up.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "That was our medicine, I guess, the dysentery.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "If you eat it, it pulled together your stomach, your loose stomach.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And people used to give away their daily ration of bread for an ear-- a corn of-- an ear corn.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "All Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Once they brought in in these-- one of these transports, they brought in a young boy.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He was about 17 years old-- blonde, blue eyes.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And he was crying in Hungarian.",
      "word_count": 6
    }
  ],
