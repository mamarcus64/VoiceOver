{
  "stem": "617.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And she was just as tall as I was at the time, you know, so she didn't really look as a child.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And we stayed together.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "And all that day, we were still outside.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And they brought some soup along.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And then-- then we were taken back to the same barrack for sleeping at night again.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "And in the next morning, we were really shipped out of there, like the next day.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "And we were taken-- there were trains coming right into the camp, and we were just taken to trains.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And at that time, we were asked about the names, because they were trying to put the people with the same letters, like with the same alphabet, together.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "And my sister and I, of course, we were Drummer.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And my cousin, she was married to a Drummer, so she was going to stay with us.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "But she had her sister there, who was a [NON-ENGLISH SPEECH].",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "And she says, you know, I'll give my name as [NON-ENGLISH SPEECH].",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "I want to stay with her, I don't know what's going to happen, which was the right thing.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "So we were put in one of those cars, and she went in another car.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "And the next thing, we moved, like we started traveling.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "And where we came to, our cars were taken off in Latvia.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "And my cousin and her sister, they continued, which we found out after they went to-- to Estonia.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "They were taken to Estonia.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "And us in Latvia were taken to the camp there, to Riga.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And her sister.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It-- it-- I don't think-- think that it was a day.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't long.",
      "word_count": 3
    }
  ],
