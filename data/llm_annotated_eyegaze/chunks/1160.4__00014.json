{
  "stem": "1160.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "And he says, if they will come and want to harm me, he says, nobody's going to touch me, not myself, not my wife, not my child.",
      "word_count": 27
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "They are just going to take this capsule.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "And we are going to bed and be dead.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And nobody's going to touch us.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Nobody's going to hurt us.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And he was carrying it in the pocket.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "There were there before we came.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly where they-- when they came.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But we-- they came then.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "They were there when we arrived.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "All way-- ?] yes, my sister, they put her into the kitchen there, going to work.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "She's going to go in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I can get her some apples or the pears, because their fruit is up on the mountains.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And that's all we needed, mountain air.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "We were so hungry, and being in this beautiful place.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And my brother, my older brother, he was working with Mr.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Smith, who was with the ox.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And you know how you cut up the earth for planting.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "I don't how call this--",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Plow, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "You had to hold on the plow.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And the oxen, they were pulling them.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "We weren't guarded.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They were coming to check on up us.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They know that we are there.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And the mayor--",
      "word_count": 3
    }
  ],
