    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "We talk, still moving.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And-- but once-- once a day, we eating-- we all eat together.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Somebody-- we pay somebody to cook.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And we had one good meal together.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Yeah, we've--",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And actually, we were-- we were not unhappy.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You know, we were young.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And we love life.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And in a way, I could say-- for me, I could say, it was the best of time and it was the worst of time.",
      "word_count": 25
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
