  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "The camp will we blown up, and no one will come out alive.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "It's up to yourself.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "You could hide, easy.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "I know people that hid, and they came out of it.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And we were the thousands in appell.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "Back to the barrack.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "There's nothing there.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "They start marching.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Only German, oh yes.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Well, Dutch and German, there's not a great deal of difference.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "You picked up your words.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I could speak some German.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I could speak German, if I'd learned in school.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And-- and-- I could speak good English.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I mean, you know, it makes a little bit-- we were quite well educated over there, Holland.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "It makes a difference.",
      "word_count": 4
    }
  ],
