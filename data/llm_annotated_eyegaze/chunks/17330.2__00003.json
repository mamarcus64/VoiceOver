{
  "stem": "17330.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 582.4,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I found somebody who had an-- an home what was originally from the welfare.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And there were 20 old people and children from parents who worked in Germany or split-up parents and neglected children, about 30 kids.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Anyway, I talked in one of those nurses to stay with me.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And then I went back to my own flat.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And we decided that in case the German came, I would say I'm due any minute.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "I was so enormous, so I could easily say that.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "But I didn't know where to put the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Nobody wanted the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And that man what was caught the same time as my mom [PAUSES FOR 4 SECONDS] suggested to me to leave it at her doorstep.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "But I said no.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "I don't take the risk, because if somebody find out-- she brought a lot of kids into hiding.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "And I said no, I can't do that, because that is too risky.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And then he was born on a Sunday.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "And on the Wednesday, I had to go in in that home and do-- induce the birth.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "So on Sunday, he was born.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "24th of January '43.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In that home.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "On the [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And then the sixth day, somebody from the underground movement came-- so he was six days old-- drove me back to the place where I was hiding and took the baby with them.",
      "word_count": 33
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know where or what or who, nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Underground movement.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a friend of my father worked in underground movement.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And on the day he was born, he said, I found a spot for him.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Isdein.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The Bolognese [INAUDIBLE], yes, we had to pay, but it was not so much.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "But that woman, that Jewish woman had cinemas.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
