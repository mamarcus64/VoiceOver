{
  "stem": "9601.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "And about 2, 3 o'clock in the afternoon, guess who comes to the barn with-- they didn't-- or the-- the man that owns the barn comes there with a team of horses.",
      "word_count": 32
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "And he opens up the barn, but surprise-- surprises us right on the threshing floor.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "He start hollering and screaming, Jews in my barn.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And my-- my father and my uncle grabbed him.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "They knew him.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "And they say, come on in.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "Be quiet.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "Don't make-- you know, you're going to kill us and yourself too.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "Somehow he quiet down.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "They promised him they're going to disappear tonight.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "He's praying.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "He got down on his knees.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We left.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My father found a place with this Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Stakh-- Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Stakh Denishchuk.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "You know, you know Polish word 'Stach,' Stanley?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "That's the man.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Stach-- Stakh, that's a nice Ukrainian name, Stakh, that's--",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And he found a-- he has a place for us, and we're going to go there tonight.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "You know, when the snow is, who know, places 12 feet, 6 feet, 10 feet, and you have to have a hike of maybe 7, 8 kilometers, because you have to go outside the village.",
      "word_count": 35
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You don't want to go through the village in the winter.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We get there.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And where we going to be?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We're going to be on the-- in the attic of a pigsty.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But it-- it's not completely ready.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Only part of the attic is full with straw.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "You know, because they put for the winter straw to act-- to act as an insulator.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "So we get in.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We stayed in it about three or four days in one side.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We finally arranged to have the straw for the other side.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "But he would not-- so we were sitting [? on ?] that-- over there already.",
      "word_count": 15
    }
  ],
