{
  "stem": "20686.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lodz in the year 1922.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "On the 8th of August.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "On the 8th of August.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Who was in your family?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We were a family of five, my parents and my two sisters.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And we lived in a one-room apartment, the five of us.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My parents were working people.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Naturally, we were a working-class family.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Life was hard, but we were a happy family.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] My father was a political-orientated man, and so was my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And although things were very difficult materially, I cannot remember my parents not singing.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] We also were readers.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "All of our family read constantly.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "We belonged to libraries.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "But we also had a small bookshelf.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And I remember when father, whenever he bought a book, it was like a-- a celebration at home.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Mother put an extra piece of meat on the plate.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "When we had a book, everybody had the book.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "It was something like an extra member came into the family.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My father, Gershon, Gershon Rosenberg.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And my mother, Masha.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had a sister, Pola, and then, Ida, the younger one.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I was actually the youngest member of the family.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My sister, the younger one, was four years older than me.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And the older one, eight years older than me.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "So actually when the-- when the war broke out, my younger sister was 21.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And my older sister was 25.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She was already married, and had a little baby, [INAUDIBLE] was her name.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He was a textile-- a weaver in a textile factory, and so was my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They both worked in one factory for about 30 years.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] And they eked out a living from-- from being factory people, factory hand.",
      "word_count": 17
    }
  ],
