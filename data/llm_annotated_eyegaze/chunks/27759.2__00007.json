    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "You got some of the older people that are still living there, had lived through it, still resent what we did.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "But we had to do it.",
