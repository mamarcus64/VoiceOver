    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "We had no-- no other alternative but to do it.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, we headed to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Sainte-Genevieve-des-Bois, many towns, little small towns and hamlets that we went and crossed through.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] army.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I was an officer's orderly.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Because my eyes, they see the commanding officer told me my eyes was too weak, too bad to be out there on the battlefield.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And so most of the time I spent around guarding the command post with the soldiers that were at camp, once the other soldiers went out and worked.",
