  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 52,
      "text": "I still remember a quarter of a pound of horse meat or pork meat per person a month, if we could get it.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 53,
      "text": "Stood in lines for it for hours.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 54,
      "text": "People killed each other for it.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 55,
      "text": "They were usually from diseased animals who had died natural death or been shot.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 56,
      "text": "We had a quarter of a pound of some kind of fat a month per person, some flour, sugar, one loaf of bread, small loaf like this, per person a week.",
      "word_count": 31
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 57,
      "text": "When they got potatoes or grains or beans in-- or whatever fresh, kohlrabi and turnips, as a rule, that were half rotten, sometimes some onions, we would get them.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 58,
      "text": "I remember once, there were beets.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 59,
      "text": "And--",
      "word_count": 1
    }
  ],
