{
  "stem": "9031.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And they kill-- some-- they killed it.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And they put in the people, like in life-- they don't care.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "It's for two days, they killed all the people, 12,000 people.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish people, they don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They tell them to work.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They do these, the holes.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And about 500 people they killed.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They-- together with these people were they help, they do the holes.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Later, they take other people.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "The other people do the holes.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "They bring again 500 people.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And they kill together these people, what they helped to do the holes.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And they do this to everybody what they help, and everybody-- every-- they killed all the people, 12,000-- 12,000 people.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "After, when I find out it was my mother they killed, I go to visiting my sister.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She was living about 15 minutes from this place where I was, and my family live.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And she can't understand what happening, why did she-- I've been here, where I was when they took mother.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I tell them, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I was in another place in this meantime.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And [PAUSES FOR 4 SECONDS] my sister, she left me living together with my sister.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "In this meantime, my youngest brother is coming.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And she can't again understand.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "She ask him.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "He tell the same, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Because they-- they-- when they took the-- the people to the place to killed, sometimes they go-- go do in this side.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Go do in this side.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And he was going in the side.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "He saw that his mother is not here.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "He say, I have-- I don't know what-- what happened when I was separate from my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1941, in October 28.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I stayed with my sister two years.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Also in the ghetto.",
      "word_count": 4
    }
  ],
