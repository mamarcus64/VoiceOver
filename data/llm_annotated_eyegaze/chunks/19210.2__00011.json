  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "My father and mother didn't want us to go at the time because, you know, we were a very close-knit family.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But I-- I said, no, I gotta go.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "What influenced me even perhaps not less so was when I was taking Hebrew lessons at Mrs.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Torjman, ?] she had pictures at the willing wall of Jerusalem, of [INAUDIBLE] and many other pictures of Eretz Israel in her kitchen wall.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I always wanted to go and see the-- the Wailing Wall.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "But I was influenced-- when I saw that so many children were leaving for Eretz, I wanted to go to Eretz, too.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My brother and my cousin, Nissim.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He died in Israel, too.",
      "word_count": 5
    }
  ],
