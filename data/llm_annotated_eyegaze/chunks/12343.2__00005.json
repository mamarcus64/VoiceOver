{
  "stem": "12343.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Well, I said, [INAUDIBLE] my wife, what's going to you?",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So many years ago.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Got the past very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Then in Majdanek, come to Majdanek, was a sign.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They opened the doors.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And I said, can I get a drink?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "They said, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "You get a drink.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "It's gonna be right away.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We call them [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "You can go into gas chamber.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "But [INAUDIBLE] was a sign over there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "[SPEAKING GERMAN], in Majdanek.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The work in Majdanek was not work over there.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Was hard labor.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They take me with another man, take a board on my-- my shoulder, the other-- the other side from the other shoulder and put on rocks and this.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They run after this with-- with a-- with a stick, a rubber stick like this, knocked [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Then they took us-- one time took us out from there, took us out from the Majdanek to work.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I forgot the name of it.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Over there was Jewish living.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I was over there to clean up this place.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "That's-- oh boy.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Everything was [? hot even. ?] Children's-- children's bed, everything, and food-- [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "They took them away to Majdanek, to burn.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "[INAUDIBLE], Majdanek was a-- the-- the-- the women's place, another barrack, another place.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I used to go to the wires and talk.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "In Majdanek, they give us work.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "You're never going to believe that kind of work.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "We used to clean off the toilets, put it over [? one, ?] and clean the [INAUDIBLE] on the fields.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And I used to go and do it like this to make it soft, the ground, from the toilets with these men.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "Men did the work thing.",
      "word_count": 5
    }
  ],
