{
  "stem": "24409.9",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he called the embassy in Pretoria, or the consulate in Cape Town, and he found out they have quota numbers for a Czech to emigrate into Palestine-- into America.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Imagine-- do you see how the State Department tried to keep people out for a price.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "You had to be born-- you went by the place of your birth.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "What person born in Czechoslovakia will apply at the consulate in Johannesburg-- that's what it was-- in Johannesburg to go into America?",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "That's a quota number.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And they said that you need an affidavit, too.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I said, who has to give the affidavit?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Says, any American citizen that is substantial, this is very important.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "I said, you are substantial.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "You can give-- [INAUDIBLE] you can give me the affidavit.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "He was taken aback for a moment.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "Then he said, you are right.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "And he was ready to give me the affidavit.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "But this works very much against the purposes of this woman.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "She said, with the affidavit, and with the quota number, he'll have to wait years before he gets into America now.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "He can't get it.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "If you really want to get him into America, he has to get another kind of visa.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "He says, what other kinds of visa are?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Says visitor's visa and a transit visa, she said.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "I'll give you a visitor's visa.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "I said, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "They says, but this is only for a limited time.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "You will learn the right way to make it permanent.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "I said, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "And why didn't the visitor's visa come up?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 28,
      "text": "Yeah, she told him you can't give him a visitor visa.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 29,
      "text": "A visitor must have the possibility to return to own country.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 30,
      "text": "I said, that's no problem.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 31,
      "text": "Give me a transit visa.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "I'll have that.",
      "word_count": 3
    }
  ],
