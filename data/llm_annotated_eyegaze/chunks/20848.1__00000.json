{
  "stem": "20848.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "L-U-S-I-A H-A-B-E-R-F-E-L-D.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was born-- my maiden name was Hasman-- H-A-S-M-A-N.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was Liza.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I am-- in my birth certificate, it's Liza-- L-I-Z-A.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I have a Hebrew name.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My name is Leah in Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was born on the 18th of October, 1931.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm 64, I'll be soon 65.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lodz, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father's name was, in Polish, Adas, Adas Hasman.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And what can I-- there is such a lot I can tell you about my father, but when you say who my father was, he was a very wonderful human being.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I think that I really owe my survival-- my early survival-- to my father.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In the early years, we had a shop, a clothing shop, in one of-- in the principal city, Lodz-- very beautiful shop.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And that's how-- and my mother was working in it, as well.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we lived behind the shop.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "So actually, you know, I was there in the evening, because the telephone was between the shop and our apartment.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "There was a little room.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No, I was too young.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I was not allowed to come into the shop during the day.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Adela Hasman.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had a brother who was five years younger than me.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And his name was Rysio.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Do you want me to spell it for you, the Polish name?",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- R-Y-S-I-O-- Richard, Rysio.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Very sort of vaguely I remember it, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We had-- as I said to you before, we had this apartment behind the shop.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But it was a very lovely apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I remember that the furniture in our home was red, and we had parquet floor, and we had carpet squares.",
      "word_count": 21
    }
  ],
