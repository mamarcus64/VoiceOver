{
  "stem": "20609.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And on Saturday, we had a special cashier booth during the week, and then on Saturday he pulls the cash register over on the other side and I worked also the counter and I made some tips then.",
      "word_count": 38
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So one Saturday, the dishwasher comes to me, a black guy, and says I'm the-- he says, I'm the union-- I'm the union whatever the-- shop steward, the union shop steward.",
      "word_count": 31
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "He says, would you like to join the union?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I says, well, what does it cost?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "He said, well, it costs $50.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I said, I don't have $50.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He said, don't worry about it.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We take it out like $5 a month or something like that.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I says, well, what does it do for me?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "He says, well, minimum scale is $75 a week.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I said, you're kidding.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "So I said, yeah. where do I sign?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "The next Monday-- the following Monday my boss comes in and who there already, the business agent from the union.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "He says, he now gets $75 a week.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And the guy comes, what are you-- what did you join the union for?",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I says, I don't know what I was doing.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "So now he closed the register over on that side.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "Now he says, this is your job on this side six days a week.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And I was getting seven-- and now I hours making tips also.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So it turned out to be good job.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So I stayed there for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And then somebody told me about Florida.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He says, I'm going down to Florida.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "By the way, my-- my cousin, I lived with her and she-- one day I came home in the beginning with a-- with a-- with the Jewish paper, [NON-ENGLISH], in German.",
      "word_count": 31
    }
  ],
