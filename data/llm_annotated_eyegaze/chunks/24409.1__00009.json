    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "I was the leader by the name that I-- I was the only name, to which people could refer.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "I was a lawyer, so I presented something.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "Other people there at that time, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "I don't recall, now.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "We had five or six people.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "Yeah, Eric Wolfe, Eric Wolfe was not a member of the group.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "But he was in charge [INAUDIBLE] he was an [INAUDIBLE] of the Betar, with whom we cooperated.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And he organized everything in the Betar.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
