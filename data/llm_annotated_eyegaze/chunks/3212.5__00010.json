{
  "stem": "3212.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "In January '46, I found out I have an uncle, that he left in 1940 from Vienna.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "That he had to leave in 24 hours.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I found out my aunt died on the boat.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I found him and a cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I left the kibbutz.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I went to Haifa.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Bat Galim, it's called, a little village.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And in 1947, I went on my-- I went to the Israeli-- to the-- still the British, but I went to the Israeli army.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Free-- on my free own will, I didn't have to go.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And in Bat Galim, I met friends and girls--",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I met my wife right then in '48. '47, '48.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "One of my friends that lived in the same city-- I didn't have nobody-- when I was in the army, I-- I-- his parents adopted me like a son.",
      "word_count": 29
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I ate there, I slept with him.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And there was a group of people, boys and girls.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And between his sister's friend was my wife, Menora, that I met then.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My wife was an Israeli-born sabra.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I was three years in the Israeli army, and I was freed in 1950.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "In 1950, I came to my parents-- my wife's parents.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And that time my wife became an Israeli soldier too for five, six months.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And then was talking that if you get married, the girls, they let them out from the army.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I came to her parents, I says, listen, I want to get married.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have nothing, really.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So they said, why you want to marry now?",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Marry later, and this.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But, in the end, they-- we got married in January-- no, no, no, not January.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "December 1950. 26th of the December, 1950, we married.",
      "word_count": 9
    }
  ],
