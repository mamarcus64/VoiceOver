{
  "stem": "3150.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we had a guide who was in charge of the whole, the whole thing.",
      "word_count": 15
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And, and they split us up into groups, you know, on the boats.",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "These are going to Montreal.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "They're going to Toronto.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "They're going to Winnipeg.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "You know, it's-- it was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "And somehow I was the one that went to Montreal.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "20, 25, maybe.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "A, a lot of--",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "All the same age.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "They had to be within, you know, under, under 18.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Maybe a few of them made themselves younger, you know, but there, there were not too many over 20.",
      "word_count": 19
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "It was a pretty good time in Montreal.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "I mean, you know, we went-- we went-- I went to work, and I went to night, night school.",
      "word_count": 19
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "They set, they set us up with, with families, with Jewish families.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And they paid for the room.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And they set up each one with, with a different family.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I stayed with, I stayed with a family in-- [INAUDIBLE], I think it was.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And my-- and I stayed there not long, though, really.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "I went on my own.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "I really didn't want to live this way, so I-- I had a-- one of my friends and myself, we went out on our own, so we moved away from the families.",
      "word_count": 32
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I thought it was Lieberman [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Probably about four or five months.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "And then myself and a friend, we went on our own, so we got our own place, and--",
      "word_count": 18
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Harry Lieberman.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "He was--",
      "word_count": 2
    }
  ],
