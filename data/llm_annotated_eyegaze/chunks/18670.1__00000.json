{
  "stem": "18670.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon--",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My name is Kurt, K-U-R-T, Saunders, S-A-U-N-D-E-R-S.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Kurt also, and it was Schatzker, S-C-H-A-T-Z-K-E-R.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't have any other names, except that my legal American name is Kent, K-E-N-T.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "[HEBREW]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Not 'til I came to America.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "An [INAUDIBLE] man called me here Kurtle Turtle.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born on June 11, 1919 in Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I am now 77 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Do you want me to spell it the German way?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In German, it's spelled W-I-E-N.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "In English, it's spelled V like Victor, I-E-N-N-A.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Austria.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "In German, it's Osterreich.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "My parents, both of them were born in what's Poland today, which was Galicia.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "In America, they call them Galic, right, Galicianas.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "That's where they were born.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But they moved to Vienna, when, in my father's case, his mother died at a young age and he was left behind.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And his father, who was a rabbi, moved to Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And then my father, at a young age-- he was 11 years-- followed to Vienna.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "My mother had a very similar story.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Her mother died.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Her father remarried and left his two children, a son and a daughter, in Vienna with a brother who had-- didn't have any children.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And he came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "That was in 1904.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Then he brought his family, the children of the second marriage, to America.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So I have mishpacha here.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Not my father's side, but on my mother's side I have mishpacha here.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And what did your father do in Vienna?",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "What was his occupation?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "After the First World War, he started off-- things were kind of rough in Austria.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They'd lost the war.",
      "word_count": 4
    }
  ],
