    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, we waited there and we waited there and we waited there.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And then they put us in police cars and they took us to the station.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We all got in the train and towards evening, the train took off.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And I think we took about three days to get to Alexanderplatz in Berlin.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "When we got there-- enough?",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Finish what you were saying.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "We're going to finish the tape now.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "We're going to change tapes now.",
      "word_count": 6
