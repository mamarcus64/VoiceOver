{
  "stem": "2590.1",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And she said that my parents were good to her, but what would happen to her children if she would be killed.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I could understand her, too.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And one day, she used to hit me so much.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I said, so kill me already.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "But she said, no, I cannot do it.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I am a Christian, she said.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I cannot kill you.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And one day, it was Sunday.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "She was home.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And I was sitting in the attic.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And she came out and she said that her boy, Boloch, the six-year-old boy, he didn't know that I am a Jewish girl.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "That he said that the Germans are looking for a Jewish girl.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "And she said I should run.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And I didn't believe her and I didn't want to.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And she started to cross herself.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And she said if everything will happen, you'll come back.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And I was ready to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And then I recall that I have some money.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "So I took the money and I went down.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "When I ran down the staircase, there was an exit to the right and one to the left.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And I wanted to go to the right, but, somehow, my instinct told me to go to the left.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "And as soon as I left, I saw two Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "The-- SS man coming up.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "And if they would have just took one look at me, they would know who I am because I looked like a crazy woman, you know, with messy hair, long and short.",
      "word_count": 32
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "Because she always pulled me, for a year and two months, you know, pulled me by my hair.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "And my dress was all torn.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I'm white as a ghost.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "And I ran.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "And I went to her sister, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "But the two sisters weren't on speaking terms.",
      "word_count": 8
    }
  ],
