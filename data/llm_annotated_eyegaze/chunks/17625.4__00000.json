{
  "stem": "17625.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "He gave us advice as how to do it.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "You know, he learned us how to do it.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He had experience in this.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And said it should be easier to work.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "He took-- I'll pay you with-- with-- with the soap water and add a little bit of water.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "It should be-- should go slide through it and then put all the bodies on top of it.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And then one picks up from the back, and two guys-- two guys by the first stick, two guys by the other stick-- with that it was five people picked up the five-- the-- the three bodies, put them on the rails.",
      "word_count": 42
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And the sixth one had a fork, which attached to the back of the-- of the body.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And when the rail was inside in the oven, he held back this here, and they moved out-- out to this-- this-- this-- this fixture.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And this was 15 bodies.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "It took 20 minutes-- 15 ovens, 3 bodies, 20 minutes.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Wholesale.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My shift was [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Oh, my shift?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My shift changed.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Once, night shift.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Once, day shift.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "That's how it was.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Night shift and day shift.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Night shift-- so it wasn't I'm night, all the-- all the time, night.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "One day, one night.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "But-- but-- but we were one kommando.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "There were-- there were more than one kommando.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "There were many kommandos, many kapos.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "But shifts, each-- each-- each kommando from one kapo had two shifts, night shift and day shift.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "To the block.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Our block was-- our block was blocked.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "There was a-- there was a-- a-- what do you call it?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "A guard.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Not a SS guard, but from the block, a guard.",
      "word_count": 10
    }
  ],
