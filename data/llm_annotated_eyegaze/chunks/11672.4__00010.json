      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I said, I want to stay here.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I never want to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Said, no.",
      "word_count": 2
