    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "I went back to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "This is true.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "In a month, the American Embassy of Warsaw sent me a letter to come over.",
