  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And the-- also the front, the things, the happenings on the-- on the front with Russia, when they were-- when Stalin said that my best general is General Winter, start affecting the German-- the German composure and the German-- the German strength, in the sense that suddenly it came Stalingrad, and it came, you know, all the defeats that they had on the-- on the eastern front.",
      "word_count": 67
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Things have-- the mood of the Germans have start changing.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And they were start being pushed back to-- little by little, their victory became actually start more sounding as a defeat.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "So they tried-- but the Nazis and Hitler placed more importance to the killing and to the annihilation of the Jews than to-- than-- than what happened, really, in the front.",
      "word_count": 31
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So things have start changing dramatically.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And this was-- we were now toward the end of 1943.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "[BACKROUNDN NOISE] Terrific.",
      "word_count": 3
    }
