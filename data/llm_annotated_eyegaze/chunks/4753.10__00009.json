  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And after 12 years, the full circle got on him, and 1945, April 30th, when Hitler finally believed that the war is over, and he lost, he told his ministers that he will shoot himself, and they should pour gasoline over his body and burn him.",
      "word_count": 46
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And that's exactly what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And I think that is a very good message for people who are hating and giving, you know, orders to other people to be killed, to see where they end up.",
      "word_count": 31
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I would like to just add something-- that regardless, I did go through concentration camp and all the tremendous disappointment what I suffered from people and from life.",
      "word_count": 29
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I still believe the majority of peoples are good.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And there are evil people, and they are the one that we have to stop.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And that is the job for the good people, because they will win by the end.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
