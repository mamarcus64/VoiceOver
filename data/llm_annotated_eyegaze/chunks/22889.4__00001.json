{
  "stem": "22889.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I felt so bad, because I was with his son in the camp and I told him about his dad.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I buried him myself.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "There was another incident, for me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "It was a name-- her name was Gutfreind, Frau Gutfreind.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They used to have a-- they used to sell soft goods, material for clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "She was a older lady then, she was-- must've been in her 70s.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "They took her to the woods, out of town, and they shot her.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "So me and my friend, we were assigned to bury her down there, right there.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So after the war, when I was in Israel, I talked to her son, you know, about it.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "She had a son, and the son had a grandson, lived in Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I told him where she was buried.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So they went to Poland there, they got the remains, and buried her in the Jewish cemetery.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They found her, because I buried her down there myself.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Then I used to work for one fellow, his name-- not myself, there were bunch of us work for him-- we used to put his sign on the roads, like you see here, different sign.",
      "word_count": 35
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "His name was Scheda.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He was a German fellow from Sudetenland, from Czechoslovakia.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He was the worst fellow I ever seen, these days, before I went to camp.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "He was such a sadist.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "For no reason whatsoever, he used to beat us to beat the heck out of-- but he always used to like me, somehow.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I had to go early in the morning to his house, in wintertime, make fire.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "We had no heating like we have here, in United States.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Everything was burning wood in the stoves.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And I had to start the burning the wood.",
      "word_count": 9
    }
  ],
