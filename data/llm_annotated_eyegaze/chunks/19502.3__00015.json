  "elapsed_s": 57.2,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "But I was very-- you know, it-- it's like a weight was all my life on the chest.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And it's now, when it comes Erev-- Erev Shavuot, I have it the same way.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "I don't need a calendar to remind me or so on.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "I just-- it's a weight.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "It's over there [INAUDIBLE], you know.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "No matter what, it's-- you cannot-- you are so scarred inside, that it's very hard to-- to-- to explain the feeling that you carry with you.",
      "word_count": 26
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "It's very-- we also ruin our kids this way, we hang on so much, because we lost so much, you know, that we hang on to them.",
      "word_count": 27
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "I know I did.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "You know, they're ready to leave home, because you hang on.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Don't go here.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And don't go there.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You will get hurt, you'll-- you know, but afraid to lose what we have, because what-- what do we have now except the children?",
      "word_count": 24
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They're our life.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "It's the end of tape.",
      "word_count": 5
    }
  ],
