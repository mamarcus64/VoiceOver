  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And she married.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Her married name's Loebl.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She's a year and a half older.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The-- she went to the same kind of school, but for girls.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't co-ed.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The schools were separate.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And she left Germany after the-- after the Kristallnacht, you know, when all the Jewish stores and all the establishments were destroyed, and ours also.",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And my father was sent to a concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And when he came out-- they were-- they were kept for two weeks only.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "But he-- when he came out, he was broken.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He was in, in Buchenwald concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And they really-- they broke him there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "You know, they, they beat them and, and, and marched and tortured them and-- he came out at a-- he had a stroke.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "He was already around 60.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "Yeah, 61.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And he never recuperated from that.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And he died a year later.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "But before he died, my parents made my sister leave the country.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "My sister, by the way, was-- before Hitler came to power-- she was engaged to a-- to a Gentile.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "But [PAUSES FOR 5 SECONDS] very much to the [PAUSES FOR 3 SECONDS] dislike of my parents.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] But she got engaged to him, and they became used to him.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And, and I liked him because he had a beautiful motorbike, you see.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "I liked my, my sister's fiance because he had a beautiful motorbike, you see.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "[LAUGHS] And-- but then, then he had to leave town because he was working for the government, and he couldn't be engaged to a Jewish girl having that government job.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "So he, he got-- he got transferred to another town.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "And then they met-- and they met clandestinely always.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "And yeah.",
      "word_count": 2
    }
  ],
