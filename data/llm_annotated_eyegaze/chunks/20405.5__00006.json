{
  "stem": "20405.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "One day, they took us to cut some trees, some trunks of the trees.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And we made kind of a tool to smash the-- the ashes.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And they made us build a kind of a cement on the floor outside of the crematorium, outside, I mean, in the same place, of cement.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And all the ashes, all those bones burning, burned bones, they were coming to this place.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And about 10, 20, 30 of us with this kind of a tool of the trunks of the trees, they were smashing the-- those-- with those bones and making ashes.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "All this time, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, Dario and me, we were working crematorium three.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And my brother was in crematorium two, because my brother knew how to speak Poland, just-- just like that in German.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And they knew about the revolution we were talking about.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And my brother wanted to have me and Dario and his brother in crematorium two, not to work in crematorium three, to be together over there.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So one day, he was very acquainted with a kapo, my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "One day, they took Dario and me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They knew we were singing, Dario and me, together and to have some-- some fun with us in the crematorium two, because my brother told them that they sing and so, and so, and so, and so.",
      "word_count": 37
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They took us to crematorium two-- two.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And we were working together over there, together.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I remember it over there was 18 persons.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "They were prisoner of [INAUDIBLE], or war.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how they brought him over there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "The only name I remember of those guys, because he got killed from the German, and I tell you how.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "This morning, I remember his name.",
      "word_count": 6
    }
  ],
