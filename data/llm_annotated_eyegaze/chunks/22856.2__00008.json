  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Even if he had to belong to the-- unless they are paid, I mean, to the Nazi group, because that was an order.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "If he wanted to go with his ideas, he had to belong to the party.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "But he was a great sympathizer.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And he did not believe for one moment that-- that Germany will win the war.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "From the beginning, he belonged to that sort of well-orientated people that Germany will lose the war.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Always in German, in plain German language.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Many of them, probably because there are some similarities between Jewish jargon.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "But many people understood because they were studying the language as a additional language to the Polish.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Some people had a chance to pick up French language.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "But I picked German.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember that was an order.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Because it was self-- If you didn't understand and you didn't follow the order, you were hit or shot.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
