  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "While I was working in the-- on the-- [PAUSES FOR 5 SECONDS] military police of the factory, I had a girlfriend, and her father had a Russian girlfriend-- that happened to be the secretary of the Communist Party-- one of the secretaries.",
      "word_count": 42
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And he was in charge of all the forest, all the forest and all the mines in the state.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So I came to say goodbye to her, that I'm going away, because I'm in trouble.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She said, let's talk to father.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "So we went to talk to the father.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And the father said, you know, they just freed all the Polish citizens from the camps.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Because when the Russians came to us in '41, we had a lot of refugees from Poland, from the other side of the Polish--of the Russian border.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And that one night, they put them all into trains and took them to Siberia to-- to come up to the northern-- to the Arctic.",
      "word_count": 25
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And the all worked in forests cutting wood in the forest, and worked in mines.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Shall I stop?",
      "word_count": 3
    }
  ],
