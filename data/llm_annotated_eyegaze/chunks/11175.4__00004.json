{
  "stem": "11175.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "They shot them, all of them, in the-- into the-- the-- into the graves.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "After the shooting, they are told, the-- the Ukrainian told us we should go pick up that bread what they have and take-- take from them, that we should have some bread to eat.",
      "word_count": 34
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The Ukrainian SS.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The SS-- they worked together as a-- as a team, although most of them, Ukrainian.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "The-- a job like this, it was the Ukrainian that did it.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And they shot them.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "What can you do?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "You cannot do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] The-- the fact is, you're never taking the-- the gypsies over to that-- to the graves with the children on their back and-- and finish them out there.",
      "word_count": 29
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I'd been there in that camp, in that Taunton barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I was there about six, seven weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "During the six, seven weeks, there was every days less, less, and less people remained in that barrack that would come out.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "They shot them.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "That's no--",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And that other-- the other-- so we had-- let me show you something.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have-- I don't have to work too hard, [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "This is Treblinka.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "You're coming in from the gate, from here.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You come in from the gate here.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "This is the administrations place.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "The administration from the SS, they have here.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "This is the place for the people who are working.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I'd been-- and that Taunton barrack is one of this-- I don't know how-- all of this barracks, you see, was the Taunton barrack.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "When they took them out-- you see the double-- you see, this in the double fence.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And this side was not a double fence.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Here, is the double fence, you see?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We went out one morning to work.",
      "word_count": 7
    }
  ],
