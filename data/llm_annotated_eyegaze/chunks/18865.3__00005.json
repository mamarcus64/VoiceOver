{
  "stem": "18865.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 419.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I went to the Bloomsbury House which was the HIAS organization in London.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I applied.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I was already in England, and it helped that I was there.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And I applied just for my parents and sister.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "That's all they gave me permission for.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And then they told me-- and I filled out the application, and when I brought it back to the man to the-- in the office, the clerk, he said, put it in this basket, we'll take care of it.",
      "word_count": 39
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And I said, no, you won't.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "I said, I want the signature today.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I'm not leaving until everything is signed and I know that it will go straight through to Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "My father was-- was promised that if my-- if he could leave Germany within 24 hours, that he would be able to leave.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I wanted to further this and to allow this to materialize.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "They wouldn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "They wouldn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I said, I'm not leaving.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "They were-- still said, this is-- this is the-- you know, they were also former Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "They all spoke German.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And they-- they were still very German about everything.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "I-- so I sat down on the floor, on the-- in the outside, on the-- in the waiting hall, a cold, marble floor.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And-- and there I sat.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And then it was 5 o'clock, and they were ready to close.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And they came out, and they were going to-- and they told me to leave.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "And I said, I'm not leaving.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "And I said, you know, if you try to get me out, I'll scream so loud that every newspaper in England is going to write about it.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "I want this permit today.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "And I got it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "I got it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "They did it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "They wanted this passed out of there.",
      "word_count": 7
    }
  ],
