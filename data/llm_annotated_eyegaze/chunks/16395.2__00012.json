{
  "stem": "16395.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "But they burned the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "There was a big fire.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "So we all-- they knew that people are hiding-- so we all went to go come out from the-- from the hiding places.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "We all went-- this was the last one.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "This was May '43.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And that time we went to Majdanek.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We came out to-- from the hiding place and they took us again.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They took us to the same place.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "We were sat down and what wasn't that many people really like the first time.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But it was because they brought all these new people from different towns.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Maybe 1,000 this time.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We sat again the same day, all day.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And all-- by the evening, they took us to the-- to the trains.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Just what I wore.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Just what I wore.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "No, I didn't wait-- take nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "We were cold maybe.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I was working for the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "They used to come into the ghetto and take us out in the morning and bring us back at night.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Still the same thing, clean for the Germans in-- in the kitchen or in the kitchen where they gave us food, too.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And we were sitting.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We went into the-- to the train.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "The following morning, the train started going but this time nobody jumped.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't-- it was almost like you were resignated, you didn't care anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You went through so much, and you can take so much.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Nobody jumped the train.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Maybe five hours later, we came to a camp.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] We came to a camp, so it was a selection.",
      "word_count": 14
    }
  ],
