{
  "stem": "18960.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 24.6,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "There was one Ukrainian teacher, I remember, too.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Because Ukrainian was taught also as a-- as a language a couple hours a week.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "We had to write and read Ukrainian also as a second language.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Because of the-- because of the Ukrainian population in the area, the Polish government was accommodating the Ukrainian population by teaching the general population Ukrainian.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Drohobycz was a district town where Schodnica was located.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Drohobycz had a population of approximately 40,000 to 50,000, out of which about 20,000 were Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Drohobycz had the biggest oil refinery in Poland called Polmin.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And the-- and that refinery, there was another refinery also called Galicia.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And-- and the third refinery was Nafta.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But Polmin was the biggest refinery in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Was refining the production of oil to the gasoline from-- you know, from-- and other byproducts, other petroleum byproducts.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And was-- it's pretty important industrial center in Poland, was supplying fuel to entire country.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "It was the only area where oil was produced in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Was enough for the production for-- for supplying oil for the whole country.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The public school was in Schodnica.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The public school was in Schodnica.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "But when I finished public school, about the age of 13 or 14, I-- I-- I had to go to-- to-- to a so-called gymnasium.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "It was in in-- lyceum.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Lyceum, which was a middle school, high school.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And where you graduated to be accepted to a university.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Actually, the equivalent of the baccalaureate or the graduation of the high school, of lyceum, in-- in Poland was equivalent to two years of college in America.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "So we had a little jump start.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Those years that I went in Drohobycz to gymnasium were very-- many happy years.",
      "word_count": 14
    }
  ],
