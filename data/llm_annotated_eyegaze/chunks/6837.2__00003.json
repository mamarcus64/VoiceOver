{
  "stem": "6837.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "How could we?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "This is not for human beings.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "But anyhow, we got hungry.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have enough from it.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They gave us once a day, a little slice.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And that had to be.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And the suppertime-- lunchtime, also something very dark liquid, and again, first, before supper, it was suppertime.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And that was the day we stood in line most of the time.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "We went to the bunk.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We talked between us, you know, the girls, and--",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "About well, in the beginning, what's going to be?",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And then we went to the past and everybody had a story about the family, about, you know, different things.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "There were women who were newlyweds.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And there were women who had children, babies, and they were separated.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "So they were crying all night.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Like my sister, she cried all night.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "She-- she had nightmares and she was thinking about the child.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And we didn't want to believe it, but she didn't know what's happened to the child.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And it was very, very difficult times.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And, and we were there for six weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "We didn't go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "We didn't do any work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "We were just standing.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Even when they had to tell-- Appell, it was called, and they called us to stay.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "It was raining.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "We had no nothing to cover us, just a dress.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And we were tired of standing.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "So we used to take turns.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "Something-- somebody from the front came to the back to lay-- to-- to sit down a little bit or to bend down.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And, and to put the dress, picked up from the back to cover our shoulders because we were very cold.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "But they not wasn't supposed to see us.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "We're not allowed to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "So we changed.",
      "word_count": 3
    }
  ],
