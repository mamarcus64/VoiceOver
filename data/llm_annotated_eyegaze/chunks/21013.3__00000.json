{
  "stem": "21013.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, after I escaped from the children's nursery in Kennington Oval in London, I was brought to a lovely family in Sussex, in the country, which is south of London.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And the lady, Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Marjorie Rosevere, hugged me and kissed me.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I was so afraid to be taken out of London, because I said, how will I escape?",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "How will I know where to run or where to go?",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "But after I met her, I was perfectly at ease.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And I was with them for three months.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "They had a daughter my age.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "Her name is Brenda.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And my foster-- they asked me to call them aunt and uncle, and I did.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And my uncle died at age 80 and my foster mother, Marjorie, is now 103 years old.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And I go to visit her every two years and sent them food packages all through the war.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "We're very close.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And that's really my family.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And then they-- when their son was coming home from college, they needed the room and sent me to a cousin of theirs, Muriel Blakey, in a little village near [BACKROUND NOISE] the one I lived in, which was Copthorne.",
      "word_count": 40
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And then I stayed with this other family.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And they took in seven evacuee childrens-- children out of London.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "And I helped take care of them.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "And there was a pair of twins.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "And the little runt of the litter, Freddy, absolutely adored me.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "And subsequently, years later, I saw them again when they were gray-haired men.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And I remember he came to us from London and he had a running ear.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "He had an ear infection.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And after seeing him-- not seeing him for 30 years-- no, 40 years-- the first thing I said to him, how is your ear?",
      "word_count": 24
    }
  ],
