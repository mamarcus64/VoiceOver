{
  "stem": "1413.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "There are also on that list people who are from [NON-ENGLISH], you know, who are the-- I think now that I think that I-- I think the word for [NON-ENGLISH] is Dutch.",
      "word_count": 32
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "She must have gotten the paper in the Netherlands.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My sisters?",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My oldest sister was sent away while I was in Westerbork-- I saw her in Westerbork.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "My second oldest sister, I saw in Westerbork.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "My other sister-- one of the two sister I didn't see.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And neither did I see my fourth sister, only the two oldest and my youngest brother in Westerbork.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "None of them came back, only the youngest child of my youngest sister.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I never lived with my wife because I got married one day.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I got sent away the next day.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was taken away?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You mean, who, from my family?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "From my family?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I had to work there.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Till the day that I was sent away.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "When I was sent away?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Finally, I was sent away November 16, 1942.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "To Annaburg, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I don't want to mislead you.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But my memory, 1951 I got a paper here but it's in Dutch, from the government.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "At that time, I stated the dates and how long I was there.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And if you give me a chance to look up the paper, I can tell you exactly--",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "It was maybe 10 days or so.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "To Klein Mangersdorf.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Same length of time, maybe seven, eight, 10 days.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I got it on paper.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "From Klein Mangersdorf, we went to Blechhammer.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "From December 4, 1942 to January 21, 1945.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "From 21st of January, 1945.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no-- the trouble started when we left January the 21st.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We walked for 14 days up to Gross-Rosen.",
      "word_count": 8
    }
  ],
