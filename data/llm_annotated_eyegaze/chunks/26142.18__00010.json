  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "In 1947, I was released from the hospital and sent to Geretsried, where I, where I got a job with the UNRRA, the UNRRA, United Nations Refugee Relief organization.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "The UNRRA later was changed to, to the IRO, International Refugee Organization.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "And I worked for them in the camp, in the DP camp, Geretsried, until, until the last-- until I decided.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 38,
      "text": "Yeah, in 1948, '47, my wife came as an-- not an inmate-- as a, came to, to, to the camp.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 39,
      "text": "I was already at that time the camp leader.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 40,
      "text": "And she got, got employment in our, in the office.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 41,
      "text": "And that's how, how we met in, in 1948.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 42,
      "text": "In 1948, we got married.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 43,
      "text": "And in 1948-- for that alone, it was worthwhile to, to survive.",
      "word_count": 12
    }
  ],
