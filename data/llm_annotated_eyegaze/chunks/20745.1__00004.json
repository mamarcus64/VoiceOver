{
  "stem": "20745.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Matel Spiegelstein.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We have to wear our armband with a Jewish star-- a white armband with a blue Jewish star, and we could not walk all over.",
      "word_count": 25
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We had to walk in a certain-- I mean, to-- in a certain place.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, not no more-- no businesses.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, he didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They-- whatever they had, they could buy bread, and have it-- I think they-- whatever they had-- money left or whatever.",
      "word_count": 21
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "They all promised us, if [INAUDIBLE] then, they'll hide us.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "The all promised because we heard what's going on, and we knew.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] We got some food from the Gentiles too.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They were in the farms.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "They had flour, you know, they-- whatever.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "We-- we didn't do nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "We just got together with the people, you know, during the day.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "At night, we weren't allowed to go out.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they met to daven.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "All-- all-- only in the neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "There never was a room-- any room.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "The shul was burned-- the shtiebel-- everything.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Next?",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "My father sent me away to a-- a village.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "He knew the people, and I used to help in the kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Kopina-- K-O-P-I-N-A.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I helped out in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I peeled potatoes.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "The men was working, I used-- were working-- and I used to bring out water for them to drink and food sometimes-- whatever they needed.",
      "word_count": 25
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Jews separate, and Gentiles-- they were from before, but they were-- worked separate.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And Ukrainians were watching us, and there one from Estonia also watching us.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I would say about a year.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "There were no Jews in this farm-- only the people who came from our town to work.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "What happened-- one day-- I-- I didn't sleep in the kitchen where everybody slept.",
      "word_count": 14
    }
  ],
