{
  "stem": "210.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And-- and I stop in front of the house where we live.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And he wanted me to, you know, go with him to-- for-- to a restaurant or something.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "I said, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "I'm going home to my, you know, to my friend's house.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "But he walked with me till my friend's house.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And-- and I told him, this is where my friends live.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I said goodbye, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I went into my friend's house, and he-- and he went away.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And the next day, I was sitting in my friend's house, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And somebody comes to the door.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "You know, I was sitting in the living room on the couch.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And somebody comes to the door.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And my friend goes to open the door.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And somehow, I don't even know if I told this man my name, but apparently, I did, or he saw it, or whatever.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And he asked if I lived here.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And they say yes.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And they come in.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They come in.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "My-- my girlfriend comes in.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And she says, [NON-ENGLISH], there's a-- a-- a gentleman, and he is asking if you live here.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I said, I don't know anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I didn't meet anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I-- you know.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And-- and, you know, and I ran to see who it is.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And it was my man that I later married after two months.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "From this time on, he just wouldn't leave me.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "He lived-- at that time he didn't live in-- in Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "He lived in Opoczno, which was quite, you know-- which-- which was a, you know, like a smaller town.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And he wouldn't leave my side.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And I really wasn't ready to get married.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "I didn't want to get married, because it was just two months after the war.",
      "word_count": 15
    }
  ],
