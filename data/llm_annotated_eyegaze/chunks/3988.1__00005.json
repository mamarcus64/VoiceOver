{
  "stem": "3988.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "We used to go in-- in and buy bread from the baker, stale bread, because it was cheaper.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "It was two days older, so got it cheaper.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And used to take a big bowl, used to heat up a pot of water, and cut the bread up in little squares, you know, and put the bread in, a little drop of salt, you know, put the hot water in, and that was the hot meal.",
      "word_count": 48
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "You know, and we was happy.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, not-- not too good.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I was more interested in sports, you know, than in school.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You know, but I had to go.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "You see, like, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So-- but I wasn't too bad, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Well, I said-- as I said before, I mean, with the--",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, but the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Well, he went to the villages.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And there was, you know, they dealt with-- with the Polish people.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But that's it, only business.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Otherwise, you know, you went separate.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "We went separate.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "In other words, no-- no-- no dealing, no friendship with the Polish people.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I was a rough kid.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I did lots of things in town.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Oh, plenty of times.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Plenty of times.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, we used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "When I was a kid, you used to steal pigeons.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know, you used to go at night.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Pigeons can't fly at night.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We used to go at night and get up on top of the rafters, you know, on the balconies.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I'd go under the rafters, that's where they-- they-- they stay, you know, sleep.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And we used to steal the pigeons, you know, at night.",
      "word_count": 11
    }
  ],
