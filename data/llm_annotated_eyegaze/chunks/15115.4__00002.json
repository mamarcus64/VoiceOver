{
  "stem": "15115.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Just take the bodies and put them in and burn them and-- that was it.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "But they were not killing.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "You know, there was no gas chamber or anything.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "That's just for dead people.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Till they built the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "It didn't take long.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They built a hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "But this was just in the beginning.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "Where somebody was really sick, you know, they were-- and then I was very, very fortunate.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I got into the kitchen, working into the kitchen as a kartoffelschaler.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Kartoffelschaler means peeling potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Just for the kitchen.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Like prepare the food for the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And it was called kartoffelschaler to just peel potatoes all day long.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And it was good.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "It was inside, you know, winter time.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "It was good.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And I kept there for-- I was working there for quite awhile.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And then they built up a hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And for awhile, it was very good.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "We thought, well, things are getting brighter for us in Warschau ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "We could-- we didn't have a bad SS group.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "It was sort of a medium German soldiers looking after the particular camp.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "And the boys, they found a lot of gold.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "They used to trade it in, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "We used to even had-- like you could buy things.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "After all the trouble, it was terrific.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "And I used to work in the kitchen, and I used to go twice a week into the Warsaw city with a German and a truck and bring the bread for the prisoners.",
      "word_count": 33
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And then I used to have gold with me, different things.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "So I used to tell the German, can I go to the store?",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So the German came with me to the store.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I used to buy cheeses and even vodka.",
      "word_count": 8
    }
  ],
