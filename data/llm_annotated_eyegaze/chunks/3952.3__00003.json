{
  "stem": "3952.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz, we didn't do any work.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We were kind of separated.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We were kind of isolated, until they took us to-- took us to the train to take us to Wolfsberg.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We didn't see anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We-- we only saw-- when we walked out of the bath barrack, of that barrack that held the bath, we walked out, we saw women.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "A little bit further, we saw women all sheared their hair off.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And on every woman, I thought, this is this sister, this is the other sister.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't really-- I mean, they were dressed also in these pajamas.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't recognize them without their hair.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "But everybody was imagining, this is my sister, this is my sister, the other is my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "You would imagine.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "But my mother, I understand, wasn't even there.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And my younger sister wasn't even there.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "She didn't even reach the bath, because they took them to-- straight to the crematorium.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Just-- just once-- once one of the guys asked the kapo-- when we were standing in line, the kapos were watching us.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He asked the kapo, is there a way out of here?",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He said, you see there?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "He showed the smoke.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He showed the chimney.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "He said, yeah, there is.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Through there, there is a way out of here.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But there was a way out.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "They took us out from Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "They took us out by train.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "They took us.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And they transported us to-- about five, six-- after five, six hours train, and we came to a place called Wolfsberg.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] Now, this was in Niederschlesien in lower Silesia.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "It was about 38 kilometers, which you later found out-- about 38 kilometers from Breslau, a town called Breslau.",
      "word_count": 19
    }
  ],
