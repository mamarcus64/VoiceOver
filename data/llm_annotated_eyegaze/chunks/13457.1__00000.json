{
  "stem": "13457.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is-- last name is Kohn, K-- K-O-H-N.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "First name is Zev, Z-E-V.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Polish, I had a nickname, nickname of Yesha.--",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "July 13, 1930.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Close to 66.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father was physician.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We lived in a big apartment on Targowa Street, which was a main thoroughfare on the part-- east part of Warsaw.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And, and I had one sister who is 10 years older than I am.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And my father had his office in the apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And at the age of six, I went to school.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Samuel was the name of my father and Helena, my mother, and Miriam, my sister.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We were not observant.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My father was going to synagogue, but I don't remember going with my father to synagogue in my childhood in Warsaw.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We-- I would call we were assimilated.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We're talking Polish at home.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I don't remem-- there was Seder.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But I don't remember the-- I know there were matzos.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "This I do remember.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, there was a big Jewish community.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And my father was one of the leaders of the Jewish community.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I was too little.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I didn't come into contact with the community.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Should I continue on my own now?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "At the age of six, I went to school, to primary school, which was about three, four blocks away, maybe five blocks away.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "It was a Polish school.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "That is to say that the students and faculty of the school were Poles.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And I was maybe the only-- certainly, the only Jew in the class.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And maybe even the only Jew in the primary school.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And my first recollections are of being abused both, both by teachers and students all the time, particularly during the breaks.",
      "word_count": 21
    }
  ],
