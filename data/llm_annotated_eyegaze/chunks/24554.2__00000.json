    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I go to-- I [INAUDIBLE].",
