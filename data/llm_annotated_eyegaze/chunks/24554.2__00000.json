    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "It was in [NON-ENGLISH], Not far from [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "So I go with the train every morning there.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And in the afternoon, home.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And after four years, I finish.",
