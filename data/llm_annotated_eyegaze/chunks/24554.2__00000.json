    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The business-- it was a secondary school.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "You must go up to 14 years, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "After 14 years, you go out from the school or go further in the higher school.",
