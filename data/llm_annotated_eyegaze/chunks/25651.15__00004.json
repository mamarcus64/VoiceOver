{
  "stem": "25651.15",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And then she, she disappeared.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And he-- this man was full of good sense, you know, sort of-- he said, well, we can't telephone because the telephones don't work yet-- you know, international telephone-- we'll send a telegram to your address to tell your father where you are.",
      "word_count": 43
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Perhaps a telegram will reach him.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And next morning, you must-- tomorrow morning, you must go to the Ministry of Interior and ask who is-- no, you must to go to the English Embassy.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "They'll know about this transport of children.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So I went to the embassy and they looked at me like mad, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Do you know your, your father's address?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Of course, I didn't.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I told them this story.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And I was told politely, you know, find your father's address, then come back to us.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "But meanwhile-- and they knew nothing about this transport of children.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Can you just tell me very briefly what happened please?",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, the next thing that-- the next idea was that I should go through the Ministry of Interior and ask, you know, who is organizing the transport of children from Terezin to England?",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So I go to the Ministry of Interior and it's all new, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Prague had only just been liberated.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I walk into the building, and the man at the gate asks me what I want.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I explain, and he says, hmm.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And he tells me like this-- it's in colloquial Prague Czech, so it's very funny the way he said it.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Because he says, look, this place is full of people.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "They've all just come from all over the place and nobody knows what anybody else is doing in this building.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I don't even know where to send you.",
      "word_count": 8
    }
  ],
