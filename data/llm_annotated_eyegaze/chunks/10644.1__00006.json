  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Medicine is now here in the United States, with malpractices business, it's in the dog house, especially my specialty, obstetrics and gynecology, which was before, very, very respected-- respected became one of the worst specialties.",
      "word_count": 35
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They help me very much but how-- as much they could.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, they-- they had a small business, and they helped me with very little money.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I had to-- to-- to be a teacher, you know, be tutoring-- tutoring to make-- to make my money in Vilna.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you know, not salary-- everything from [INAUDIBLE] the high school and the-- not good in mathematics, fine, not good in-- in Polish language, fine, not good in Latin language, fine-- everything, you know.",
      "word_count": 34
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Latin was one of the most important languages.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I-- training.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I was-- six year--",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "My mother's brother from Vyazma, too, [? won-- ?] went to-- entered the gymnasia and then, you know, was admitted to Moscow medical school.",
      "word_count": 24
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And he became a doctor, and-- and he became an obstetrician-gynecologist.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And then somehow, influenced-- oh, my uncle is in obstetrics, let me go and be in obstetrics.",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "That is-- that is number one, and then, you know, just simple life.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Life dictated.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "I graduated.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "I had to go for one year to Polish Army as a doctor.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "I was involved in all the--",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "All the-- all the years-- all the years I was involved.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "In Vilna, I was involved in-- in-- it was called, you know, the Union of Jewish Medical Students.",
      "word_count": 18
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "In Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "No, in Polish it was-- it was [?",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Radovski ?] Club Medical.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Something like this.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Because the Polish didn't-- didn't accept us.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And we had somehow had representation for the-- before the dean and-- and professors.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "So you have to have a representation.",
      "word_count": 7
    }
  ],
