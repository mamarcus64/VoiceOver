{
  "stem": "12462.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "After I finished editing the Nuremberg Trials, I became associate counsel, the number two counsel, in the Salary Stabilization Board, which is a part of the total stabilization pattern at that time.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And Telford Taylor knew I was on that job.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And when he was asked to be the administrator by President Truman of the Small Defense Plants Administration, he, very soon thereafter, asked me to become assistant administrator.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And that was in 1951, or the beginning of '52.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I [CLEARS THROAT] largely was engaged in real estate ventures and in the-- the Potomac Construction Company out in Potomac, Maryland and around Potomac, Maryland.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Sprecher and I bought some land.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And we developed the Ridgeland Farm Estates.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And we made quite a bit of money doing that.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was later.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I became deputy chairman [CLEARS THROAT] of the Democratic National Committee.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In 1957.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I continued in that position, until-- until the Kennedy team came in after the convention, when Kennedy was made the nominee.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And then, I was replaced as deputy chief counsel-- or deputy administrator of the Democratic National Committee.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And I was-- my job then was-- a fellow by the name of Ralph Dungan, who later became president of the main university in New Jersey, what is it?",
      "word_count": 29
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Rutgers?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I had become interested in behavioral science.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I had begun to study a good deal in holding conferences with behavioral scientists, who went out with me [CLEARS THROAT] to help train a bunch of leading Democrats, who would be able to do a better job than they were doing before in relating to people, in developing leaders in the Democratic Party.",
      "word_count": 55
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And this received a fair amount of attention at the Democratic National Convention in 1959, or just before Kennedy was elected.",
      "word_count": 21
    }
  ],
