{
  "stem": "15115.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I had a lot of what I sold in stores in Germany, I made into dollars.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I brought in 50 watches, an accordion, a typewriter.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "You name it, I brought it-- a Leica camera.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I brought everything with me, so I wasn't, you know, suffering.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And finally, but after two months of being around, you know, everybody-- all my friends went to work, except me.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I found a nice lady here, a friend, a cousin of a friend of mine, and she-- Lucy Goldstein, nice lady.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "She died.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And she was from Greece, but born in the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But her parents were from Greece.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And so, well, she got acquainted.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She got to-- you know, got to like me.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "She says, OK, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Says, what do you want to do now?",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I says, I want to make money.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "My friends were working for $18 a week, $18, $19, $0.45 an hour.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And I was getting $18 from the Congress [INAUDIBLE] working, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So finally, I says, I want to make more money.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "So finally got me a job, six days a week, at Canada Bread, making doughnuts, and $35 an hour-- $35 a week.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "It was almost double what my friends were making.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "But it was double the hard work that I was working there, making doughnuts by hand.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And over there, I-- I learned the English language.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I was the only Jew ever worked in this particular factory, and nobody knew I was Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And I had all Irish people working there, bakers-- old people, 60, 65.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they were all, you know, good people, all old people.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I was the youngest kids there, working in a bakery.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "What I was doing, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "In the meantime, they were teaching me English.",
      "word_count": 8
    }
  ],
