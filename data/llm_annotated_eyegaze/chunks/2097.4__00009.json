{
  "stem": "2097.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And we decided all, we have to walk out from the factory.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Because this factory is 16 hours a day and seven days a week.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And or they take us.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So we walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "I went to work in an office.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And my husband went to work for somebody else.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "I was always going evening, in school, to update my self to the American standards.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I took key punch computer, [PAUSES FOR 4 SECONDS] accounting, and bookkeeping, all kind of courses.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "I went to St.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "John's University.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "I learned Lotus 123 programming.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "I learned dBase iii, also at St.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "John's.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "I learned Word Perfect 5.1 at LaGuardia Community College where I earned 15 credits.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "And I need a lot more.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "But just I can't take it.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And-- and presently, I'm learning Window-- soft-- Windows-- [INAUDIBLE] Window-- Window-- Micro--",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Windows--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Micro--",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Microsoft Windows.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Thank you for helping me out.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember the name.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I got a job for about six weeks at a-- I'm a secretary at the Jewish center.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My children, I push them always, to learn.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And because I know nothing else worth in the world, nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Everything is perishable except what you have in your hand, profession, or what you have in your hand.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "My daughter, she finished the college.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She has a master's degree in chemistry.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And our son wanted to be a doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I helped him.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't get an American-- in America school.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Because he is a foreign-born, and he couldn't make it an A.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And at the time was the law only with A grades were able, somebody, to go to medical school.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "If you-- except the minority.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Since he's white, he wasn't considered minority, even he was a new emigrate.",
      "word_count": 13
    }
  ],
