{
  "stem": "23942.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I, I think-- I think her name was also Gittel.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother's name was Chaya.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And, and she was-- she came from a very, very, very distinguished, good family.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Her parents were-- her father was a [NON-ENGLISH] from Lizhensk, which is a very known-- in Polish, it's Lezajsk.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But in Jewish, people called it Lizhensk.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And Rav Elimelech was buried in that town.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Until today, people come and visit the grave.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And my grandmother was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And her parents owned land in the nearby village-- smaller than a village, it's it's called [PAUSES FOR 3 SECONDS] [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "My father used to pronounce it [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "But it wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "When I went back, I realized it started with a R, and it was [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And-- and it's a-- it's smaller than a village.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And, and that's where they owned land, my grandmother's parents.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And their name was Katz.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And they came from a very good family.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Because not every family owned land.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And I still have the, the amount of land they owned.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "I have a deed.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "Because my father sent for it from America to, to, to claim for it.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And he couldn't get it.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "But they were landowners.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "And they were-- they were from very good stock, from the [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "In other words, my grandmother was a [NON-ENGLISH] from a very good family.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And she was a very, very strong lady.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "I don't-- have never met anybody that I-- when I came to-- like her.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And when I came to America, I was-- I was very young.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I said, who am I going to model myself after?",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Because I wanted-- I felt since I survived, maybe God had meant special something-- had special something to choose-- I should become something.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I should do something with my life.",
      "word_count": 7
    }
  ],
