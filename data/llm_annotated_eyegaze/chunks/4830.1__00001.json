  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father was born in 1883, in a small Hungarian village called [NON-ENGLISH], and moved to Budapest in 1895.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In school, he was, [PAUSES FOR 3 SECONDS] I think, studying to become a teacher, but part-time, he worked in a bookstore.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And he liked books so much of that, although he finished his studies, he continued in the book trade and worked with an uncle who was in the book trade, and opened his own bookshop in 1901.",
      "word_count": 37
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He was very young when he started.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And he did this as long as he was alive.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My mother was also born in the country, in a small place called [NON-ENGLISH], and they got married in 1923.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And after one year, my older brother was born.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My name was unusual in Hungary.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It's also unusual here.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And my mother, when she was carrying me, read a book from Selma Lagerlof, who is a Scandinavian writer, and was very fashionable at the time, and she decided that if I will be a boy, then my name will be Norbert because this was a hero in that book.",
      "word_count": 50
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And this is how it happened, against strong resistance of my father, who felt that, for a Jewish boy, the name Norbert is not appropriate.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And I think he was right.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I grew up in a very religious household.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] He was a bit more religious than most people here, in respect of-- for example, he kept his business closed on Saturdays.",
      "word_count": 26
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And he was orthodox.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "In Hungary, there were two large Jewish community-- orthodox and [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The orthodox was very traditional, keeping all the traditions, including, for example, a very embarrassing memory of my childhood.",
      "word_count": 19
    }
  ],
