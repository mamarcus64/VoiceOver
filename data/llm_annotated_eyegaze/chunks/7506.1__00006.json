  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES] The family that we had, that I had personally, was in Holland, my father's side, and in England, my mother's side.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Because my mother's parents and grandmother and that part of the family had left Holland at the turn of the century, in the early 1900s.",
      "word_count": 25
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They had left Holland and settled in England.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And as a matter of fact, my mother and father were first cousins and have the same surname, last name.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "My mother's maiden name is Rabbie.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "My mother's married name is Rabbie.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "They were first cousins.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "So the family that I knew and had was half in Holland and half in England.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Well, as a matter of fact, my sister Helen and I used to spend every other summer in England to visit my mother's mother, my grandmother; and my mother's grandmother, my great grandmother; and my mother's brothers and sisters and cousins who lived in England.",
      "word_count": 45
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "In 1939, [PAUSES] my sister Helen and I were on such a visit to my grandparents.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "To my grandmother.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know my grandfather, my mother's father, as he had died in 1918 in England.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "We were on such a visit in the summer holidays in 1939.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES] It was time for our visit to end, because we had to go back to school.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And my grandmother, my mother's mother, brought my sister and I back to Amsterdam, because that is where we lived.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES] While my grandmother was there in August, visiting my mother and one of my mother's sisters, who had also married a Dutch man and who lived in Holland, my grandmother was notified by the British embassy in Amsterdam that she should immediately return to England because of there was a danger of war.",
      "word_count": 54
    }
  ],
