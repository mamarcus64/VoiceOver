{
  "stem": "14687.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "You see, like my cousin, she got it here.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "Myself, I did like this.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "And you can't.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "They didn't go by alphabet, you know, Just you were there in [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Queuing, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "I think so.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "A little bit, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And then after, we didn't get-- after of this, we didn't get any more.",
      "word_count": 14
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "We didn't get about our hair.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "But we were [INAUDIBLE] when we are going to come out from this thing.",
      "word_count": 14
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "And sometimes we hear the sirens.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "You know, maybe they were coming to-- to--",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "And then we used to say, oh, maybe we'll be lucky.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And after, we didn't know nothing there.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "After we went from Auschwitz--",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "We prayed always God to help us to go out from there.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "But the Ashkenazi people [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "They used to-- I don't know where they used to get the little candles, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "And Friday night, they used to light the candle.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "And they were reading in Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "[SOBBING] And we used to cry too much, because we-- we saw them praying, you see.",
      "word_count": 16
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "These people, they were all the time in shul.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "We, in Rhodes-- Rhodes, the young people, we never went much, you know, like here.",
      "word_count": 15
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 5,
      "text": "And then-- So you mean the Polish people were more religious than you?",
      "word_count": 13
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "More religious.",
      "word_count": 2
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "They were praying and crying, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And then we used to cry a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "We used to think about our father, how they did the [NON-ENGLISH] Friday nights, you know, all these things, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we became friends.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes they were nice.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Other people they were-- I tell you just now.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "When we were in Auschwitz, these people they used to work in the kitchen.",
      "word_count": 14
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "They used to have sisters and friends.",
      "word_count": 7
    }
  ],
