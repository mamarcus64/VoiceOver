{
  "stem": "2391.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And then of course, gradually, you discovered what had happened, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And all the people who didn't make it.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And my father's family was practically wiped out.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "All my friends, you know, were all dead, school friends.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Hardly anybody had survived.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And when we finally came-- somebody mentioned to my father, he says you know, you're the first family-- Jewish family-- I see where the four members are still around-- father, mother, daughter.",
      "word_count": 32
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was very unusual.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Either the children were dead, the parents were dead.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I mean, I can give you stories.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Like one of my best friends, she was sent with a group to-- from Belgium to Switzerland for safety.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "When she came back, her parents were gone, never came back.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And there were, you know-- I worked after-- we still lived in France.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I was in Paris to- to take a-- to take a class, a private class of fashion illustration.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I was-- for a while I did fashion illustration, fashion designing in Paris.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I was working with a famous fashion artist at the time.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And for room and board, I stayed-- the [INAUDIBLE] actually provided my scholarship for that.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I stayed-- for room and board, I worked at an orphanage, a Jewish orphanage in Paris that was sponsored by Mrs.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Rothschild, the Rothschild family.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "They were all girls, a girl orphanage, all from the Holocaust, orphans.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "The youngest was two and the oldest was 16.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And it was crowded.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "I don't know how many there were.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And I was in charge of looking after one group of-- of girls.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was 18.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "That was the same year in fall we went back to Belgium.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We were still in France at that time.",
      "word_count": 8
    }
  ],
