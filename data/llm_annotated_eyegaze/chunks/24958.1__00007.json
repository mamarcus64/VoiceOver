{
  "stem": "24958.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The first day, we went to the shelter.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We were sitting there until bomb-- the bomb signal of the bombs went off.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And then we went upstairs to our-- I had only a furnished-- furnished rooms.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And my-- I had a girl, like a-- for-- for the-- for my boy, so she came from Katowice.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "I said, go home.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Maybe home, you're going to be more safe.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "She was not Jewish, so I said, you are not safe with us.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "You better go home.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So she left, and we were there a short time.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And then we are-- it was very, very hard, very hard.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "It was-- we couldn't go nowheres, and we had to wear armbands with the David star on it.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And you couldn't go to stores, so it was a very, very tough life, very tough.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Did all-- what happened to your husband and his-- and his being a musician, a violinist?",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Did that stop?",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He couldn't-- he stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "He couldn't play anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Day to day.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We lived day to day.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "We ate up our-- we ate from our little savings, which we [? ate ?] until we left Krakow.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they [INAUDIBLE] Krakow, I remember that in the middle of the night there was knocking on the door, very hard knocking.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they came, and they took us.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And they put us in a-- in some kind of a school or somewhere, and then they put us on a train.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And the-- the train went somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "In the middle of the night, the train stopped.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "It was winter.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "It was maybe November, November 1939.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And the train stopped in-- in-- on a field.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "The snow was up to the knees, and we didn't know where we are.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And the train left, and they left us.",
      "word_count": 8
    }
  ],
