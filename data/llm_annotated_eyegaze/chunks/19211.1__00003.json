{
  "stem": "19211.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Because I was Jewish, I think, mostly because I was Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And they were-- we know that because they just-- he wouldn't stop beating me.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "People kept screaming there, telling him to stop.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He wouldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "He beat me over the face and all that.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He was anti-Semitic.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "That particular guy lived close to our school where I went to.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And I knew-- we knew that he was anti-Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "It must have been around 1936.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was about, what, eight years old, seven, eight years old.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "You're talking only Jewish people?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You're talking--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "--general?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In general, they used to have stores, different-- there was a whole, full street-- a whole street of different stores, like grocery stores and also linens.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I remember photographic equipment and other things, just a variety of things.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "It was like a big shopping center-- was what we call now a shopping center.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "It was a whole street of stores.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And that's what a lot of the people that I remember were in that business.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "There were some professionals that worked in other fields.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "There were [LAUGHS] only two, three doctors in the whole city.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "One was Jewish, and two were Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I remember my doctor was a Polish guy.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And he was very good to me.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "He was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "When I was sick, he used to come to me and make house calls.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And he was a good doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I remember him.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He was Polish, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And there was another doctor which was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know him that well.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But he used to take care-- he was my family doctor.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My father's-- was an accountant.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And he-- the reason we moved to Radziwillow because there were three large flour mills, very huge flour mills.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They supplied the whole region with flour.",
      "word_count": 7
    }
  ],
