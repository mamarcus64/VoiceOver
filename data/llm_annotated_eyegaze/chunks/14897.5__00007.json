{
  "stem": "14897.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "So I came and lived in my uncle's apartment and went to school and graduated with a degree in chemical engineering.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I worked in New York for several years.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And eventually, in-- in '55, 1955, my husband and I-- we got married, and we moved to Buffalo, where he worked for the then Allied Chemical, and which later became Allied Signal.",
      "word_count": 32
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He's a chemical engineer, and I graduated as a chemical engineer.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We met at work.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And we had two boys in Buffalo.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And eventually, he was transferred to this area, and we moved to this house, where we are now close to 30 years, and where I became-- went back to school, got the certification for high school teaching, and became a physics and chemistry teacher and worked for 26 years at Livingston High School and retired two years ago.",
      "word_count": 58
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We actually-- I retired to keep busy with other things.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Because you know, when I started working, I had a lot of energy for other things.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I had other-- as a matter of fact, I even had a little business.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I was doing technical translations on the side, while I was teaching and running the house, and transporting the kids to Sunday school and Hebrew school and various lessons and so on.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We did some traveling.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And my hobbies at the time were playing some bridge.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And-- but I didn't have too much time, as you can see.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, I did not.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I-- but towards the end of my work, we became interested, my husband and I-- the last 12 years or so, we became interested in ballroom dancing.",
      "word_count": 27
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And eventually, we danced competitively and-- we have a--",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there's a whole-- a whole series of trophies. --shelf over there.",
      "word_count": 12
    }
  ],
