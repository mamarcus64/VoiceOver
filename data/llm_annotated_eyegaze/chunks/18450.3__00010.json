{
  "stem": "18450.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "I don't know how-- who they picked, how they picked.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "But just, you now, they said after there you have to go to Ulm.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "And they took us, and they put us again in cars, and they brought us to Ulm.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I just told you.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very much.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Wherever you went, you felt it.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "You felt tense.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And I was very sensitive to it, very sensitive.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I just-- like I was the first one to leave.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I says, I'm not staying here one minute.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I didn't care.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "But some did.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "They work, sold, whatever they made, had dollars.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I just didn't care.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- my mother went because I went.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I mean she was-- she just was afraid for me, to lose me.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I was just going, not knowing where, but I was going.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was the war.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And you really didn't had contact with people too much.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "You didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I mean, you didn't go out in a place.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "You were occupied to find a piece of bread, or a little bit of soup or something else, or a dead cockroach even to eat.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "You-- I mean, it was on the last agenda, politic wasn't in your-- in your mind.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Berlin, like I said, we stayed for three months, and we were in army barracks, in the-- what's-- not the UNRRA-- or the HIAS supplied us with food.",
      "word_count": 28
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That's the Jewish HIAS.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I guess it's the HIAS.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And the UNRRA I think.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So they supplied us with food, a kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You went there, and you had some food.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes, you did.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Well, they were very friendly by that time.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "You know, they were afraid to open their mouth.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "They were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The Germans.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Very much.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "They were really afraid.",
      "word_count": 4
    }
  ],
