{
  "stem": "10272.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Emil Jacoby.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "E-M-I-L J-A-C-O-B-Y.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born Jacobovitz, J-A-C-O-B-O-V-I-T-Z.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born on October the 10th, 1923.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a village named Terebla, T-E-R-E-B-L-A, Terebla, in an area called, at that time, Carpatoros, which belonged to Czechoslovakia.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name-- he was born Mendel Jacobovitz.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] His father's name was [?",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Lieb ?] Jacobovitz, and his mother was [?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Chendel ?].",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They lived in a very, very small village, [?",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Chandrov ?], not far from Bushtina, where we lived after my father married my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "They moved from Terebla to Bushtina.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Bushtina's a bigger city, a bigger town, than all  those small villages.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "My father, as a young boy, he [PAUSES FOR 4 SECONDS] emigrated to the United States to help his family.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And he stayed in the United States as a naturalized citizen, American citizen.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "He stayed in Chicago, Illinois for almost 20 years.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "I don't remember the exact years, but between 15 and 20 years he was there. 17, maybe 18, years.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "He came back after World War I to visit his hometown.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And he married-- it was before World War I-- to visit his hometown.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And he married a girl from Terebla by the name of Leia.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And he went back to the United States to take her out, to send her the papers.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "In the meantime, war broke out-- World War I broke out-- and he couldn't get her home to take her out.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So he was waiting until the war was over.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "By the time the war got over, World War I, his wife bore a girl, a daughter for him, and his wife passed away.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was some kind of an illness.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I don't know what was the illness she was suffering.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And she passed away.",
      "word_count": 4
    }
  ],
