{
  "stem": "13238.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she did.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Every Friday she was doing cooking and-- and preparing for the evening, for the Shabbat.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And not even that, but she was baking sometimes cakes, and delivering to the poor people in the building, too.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But this was happening practically every Friday.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, actually, it was always a festivity in our home for preparation, because naturally, we saw it-- my mother was cooking, preparing.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The parents were trying, always, to buy new shoes for the kids, or a suit, or anything in order to look good.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And normally, we were going to the synagogue, spending the holidays, coming home, having lunch, and visiting our members of family.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Together, we were 63 family member in the city of Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And we were extremely close, because we were seeing each other practically on daily basis with many, many of our family.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Passover was a big festivity, because my late mother, she was preparing, always, food, all kinds of specialities, because this was always remembered by us as the days of eating, getting together with the family, and enjoying our life.",
      "word_count": 39
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Purim was another holiday where my mother was preparing all kinds of baskets, sending to the family.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Their delivery, naturally, was by my brother, myself, for which I remember like today.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They were always tipping us with a few cent at the time.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And this was going on practically on yearly basis.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I went to a public school for seven years.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And was not far where I used to live.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It took me approximately 10 to 12 minutes walking.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I used to like very much the school, because there were many, many kids my age.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "What we had many things in common.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "We used to play soccer.",
      "word_count": 5
    }
  ],
