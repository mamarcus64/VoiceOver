  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Renee.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Warren Courtland Dunn.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "W-A-R-R-E-N, middle name, C-O-U-R-T-L-A-N-D, last name, D-U-N-N.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Fort Lewis, Washington, July 14, 1924.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father's name is Clarence, middle name, Albert, Dunn.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He, most of his career, was in the military.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And he went in when he was 17 and shortly after the-- his induction into the military, he was assigned as a-- an instructor of ROTC, Reserve Officers Training Corps, in Pullman, Washington at the Washington State College, now Washington State University, and spent from, I think it was 1926 to 1930 there in Pullman.",
      "word_count": 55
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And then he was reassigned to Santa Barbara, California in the-- in the same job as an ROTC instructor.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "In fact, he was Director of ROTC at Santa Barbara High School.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And that's where I was really brought up, was in-- in Santa Barbara.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "So he spent most of his military career, or a lot of it, in Santa Barbara as an ROTC instructor.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "When World War II started, he had been a-- a reserve officer.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "He got his commission then in 1942 and was reassigned to Southern California, where he was the so-called Professor of Military Science and Tactics at Hollywood High School and Fremont High Schools and Van Nuys High School, where I resumed my education.",
      "word_count": 42
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "That was traumatic.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHS] Having to move from all my friends in Santa Barbara, and in my-- in my senior year, and go to school at Van Nuys High School and make new friends, but I-- I did.",
      "word_count": 35
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And I really enjoyed my senior year in-- in Van Nuys, as reluctant as I was to move.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "But then he-- he continued on as-- in this job at these three high schools.",
      "word_count": 15
    }
  ],
