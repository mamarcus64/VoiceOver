{
  "stem": "23626.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She says, what's the matter with you?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Are you OK?",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I had those pictures in my mouth.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And as soon as we came out, I said, I'm OK.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "But I have the pictures in my mouth-- Mom, Dad, Adam.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "She says, why would you do a thing like that?",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "They would kill you.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But I had my pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And we have the faces of our parents.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "For I'm grateful, otherwise I wouldn't even remember how they look, probably.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They gave us little dresses that were sheer, nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "No underwear, no socks, no stockings, little Dutch clogs.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "It was freezing.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "End of November in Poland was very, very cold, very cold.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "It was freezing.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "There was nothing whatsoever for a girl, for a sanitary needs for her.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "There was no toilet paper, nothing whatsoever.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "It was so cold.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We lost it later.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They supposedly put something in the coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "From the beginning, we did, but then something happened.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And people were saying that they do put something in the coffee to stop the period.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "[SIGHS] In the morning, we were taken to Birkenau.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And we were examined by Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Mengele.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "They called him the Angel of Death.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He told us to take off  the little sheer dress, looked us over.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "The one that didn't look so healthy went to one side.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "They asked the age.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "He asked the age.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "To be honest with you, from the three weeks that I was in Birkenau, I think that we were undressed maybe three, four, times-- three times.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "But we also were called out in the middle of the night outside in the freezing cold to be counted.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "And we couldn't even hold onto each other, because they were counting us while they were searching the barracks.",
      "word_count": 19
    }
  ],
