  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Look how I remember.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Rakhmiel Lazofsky.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I liked his brother better.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "His brother, Philip, was older, Fievel.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "I liked his brother better.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "But he must have liked me, but I was my mother's pride and joy.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "Once coming out of the-- we all ate together, you know, in the dining room.",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "Rakhmiel threw snowballs at me, and I went running to my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 9,
      "text": "I don't know whether a snowball hit me in the head or whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And you touched my mother's child.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "She went to him, and he didn't-- his mother died during the war.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "He was only him and his brother.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "No more?",
      "word_count": 2
    }
  ],
