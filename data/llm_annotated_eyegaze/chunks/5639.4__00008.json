{
  "stem": "5639.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No, the work was device, like everything else in Auschwitz, to demean you, to deprive you of their last vestige of humanity, although it was none of them left.",
      "word_count": 29
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Auschwitz was just more than work or torture.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Auschwitz was the-- how shall I tell you?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Auschwitz was the place where you were naked-- emotionally naked, spiritually naked, and of course physically naked.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "You came to that place.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You knew that you won't get out of it.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "You didn't have to pretend.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Look, there were the four chimneys.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The informations in '44 told us that Jews are being exterminated.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And here you come to a place that has got four glowing chimneys, day and night.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "The air is putrid with a smell that you cannot identify.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Who ever of us smelt a smell of burning human flesh?",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "You don't look human anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I have got a tattoo.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Do you want to see it?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes I was among the one--",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I have to look it up.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "That's also choice of my memory that I elect.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "It's A25441.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "My girlfriend who survived has got her last digit O.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "She was before me.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "She has A2544O.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I was behind her, 441.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So you were numb.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "You were completely numb.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "If I recall something from Auschwitz, my only concern was to retrieve my cloak from the mud and put one foot in front off the other.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "We had to be on the move.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We were in quarantine, [? alright?].",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "We were on a quarantine.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "We were housed, lodged, collected, lived.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "There is not an adjective or a word in a human language, no matter whether its English, or Spanish, or whatever who could describe the conditions in Auschwitz because they were not human conditions.",
      "word_count": 34
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, how I got out of Auschwitz.",
      "word_count": 7
    }
  ],
