  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "He said, Fishers.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "Isn't that surprising?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "We think about it often.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "We think about it quite often.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what happened to him anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But it was one of these nice people to help us, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "But back to Oederan, we had to do hard labor.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We had to take-- [PAUSES FOR 6 SECONDS] what do you call where lorries go on or trains?",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Tracks.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Train tracks.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The, the tracks.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We had to carry tracks.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "We had to do this.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "We had to do the-- very hard labor and very little food in us.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And when, when it was a little warmer, and the factory really didn't work very much anymore, I had somebody that brought me to a man who was a mason.",
      "word_count": 30
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And he taught me how to put up a house, and I had to be his helper.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And I did that for a little while.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And then one day we were told we  will have to leave, and we had-- we had to go back.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "We had to be shipped someplace else.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In April.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Of '45.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Back to Theresienstadt.",
      "word_count": 3
    }
  ],
