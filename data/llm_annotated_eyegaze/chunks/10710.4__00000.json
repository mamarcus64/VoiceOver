{
  "stem": "10710.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I have a paper that I'd like to bring to you.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Now the group which was going to Brunnlitz, the men had to go through the concentration camp Gross Rosen.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "About 700 men.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And the 300 women were supposed to go to Brunnlitz.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They would have had to go through Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So our group went through Gross Rosen.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "After we had the shower, after they cleaned us-- this was we were still standing naked without the shirts.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "We were standing naked, 700 men in November.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It was below zero.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how we survived.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "We were standing in front of the crematorium.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I saw the chimney, and I saw the things coming out of the chimney.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "We were sure we were going to the crematorium.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Because Schindler wasn't there.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "Schindler went to Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "We're standing there maybe for more than an hour, maybe two hours.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And just with-- everybody was cuddled to his self.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "It was freezing.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Suddenly, a man on a white horse, a German SS man comes in, and he says to the watches, the [NON-ENGLISH SPEECH] who was watching us.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "He says, those are Schindler Juden.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "Put them right away in the barrack otherwise the [NON-ENGLISH SPEECH] is going to be full of sick tomorrow.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "Those people are going to Schindler.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "They are not supposed to stay here like this.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So they gave us some kind to put on, such a long shirts.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And they put us in the barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So there were no beds.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "It was just plain, empty barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "With the barrack would maybe hold 200 people.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "They squished 700 people.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "We were sitting like one in the other.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Like this we were sitting.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "But at least it wasn't cold because we were warm one for the other.",
      "word_count": 14
    }
  ],
