{
  "stem": "5740.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We stand in-- we stood in a queue for, for Red, Red Cross, or [NON-ENGLISH] or railway.",
      "word_count": 17
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And we knew what's, what's given today here and what was given today here.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And we ate, three times, breakfast and, three times, lunch and, three times, dinner.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And we didn't need any money to travel, because they seen that we are from the camps.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "On the train, on the bus, on the railway, we could go anywhere we wanted with nothing.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "I think this part of the story, I leave for my husband, because he--",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "In Prague.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And we went back to this big hall, and we slept on the floor with the 50 people, together.",
      "word_count": 19
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And when we were there, they-- and-- we, we were given some money.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Everybody was given-- from the concentration camps-- some money.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Wedding breakfast.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Potato salad and bread with red sugar.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "This is, this is-- now I'll tell you the story from Prague.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "When, when we-- then we got married, and my husband went to the Austrian consulate.",
      "word_count": 15
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And we got permission to go, on this and this day, back to Vienna.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "That was another few days to wait, so we stayed together with that group of people that we were in the French colony.",
      "word_count": 23
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "And one day, a Frenchman comes in, and he calls to my Walter, Walter, Walter.",
      "word_count": 15
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "And that was his commander when he was in the French army.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And he recognized him.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And he said, what are you doing here, and who is that blonde?",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "He said, we just got married.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "And you live here?",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "So he said, we have no money to go anywhere else.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "So he said, come on with me.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "He booked us in, in the top hotel in Prague.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I, I remember, the room was green.",
      "word_count": 7
    }
  ],
