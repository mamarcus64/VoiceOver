{
  "stem": "182.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 179.6,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And they prolonged the period when you had to get the citizenship in order to six months.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "But hardly three months passed by, then came a thing that all the people who don't have the citizenship, they will be deported.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "And they took 500 people from the villages and from our town.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "And they took us to the city hall, and we were sitting there in a basement and a few hours.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And then they put us on trains.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Very little, hardly anything.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Or, I think nothing, because I remembered it, I didn't have any clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Somebody gave me a night shirt.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And out of that they made me a dress, and that was my wardrobe.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My mother, my father, and my brother and I, and they-- they put us on a-- they took us to the train station and into cattle cars, and we were on our way.",
      "word_count": 33
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We went all the way to the border of Poland and Hungary.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "About 30 women, men, and children.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my mother, you know-- when you are 16-years-old and you are with your mother and father and you didn't have a chance to see the world before, even if you are in a cattle car-- we did have a bench to sit on.",
      "word_count": 44
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "The train is rolling and you open the doors and you look out and you see beautiful forests and you see villages go by-- I can't say that-- my mother and father, I'm sure they worried.",
      "word_count": 36
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't worry one bit.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And it wasn't an unpleasant experience.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Then we arrived and they put us in a lumber yard.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The lumber yard, it had a big, big building.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] They-- they put us in cattle cars, and we arrive to this big lumber yard.",
      "word_count": 17
    }
  ],
