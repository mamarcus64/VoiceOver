  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "That was out of the question.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I mean, if you had a, a boyfriend, we did homework together.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "We went to the movies together.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "Ozzy ?] used to cook for me sometimes.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "Ozzy ?] was a good cook.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "It was rather a nice situation.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "When I was-- when I was sick from school and stayed home, they came and brought homework and, and helped one.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "Ozzy ?] helped me with all my homework because he was a genius.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "He was very clever.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "And I, I never understood the trigonometry and geometry.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "But 'cause I was [?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "Ozzy's ?] friend-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "Zelkin's ?] friend-- that Professor [?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 24,
      "text": "Lang ?] said, I will not have you fail.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "Anybody who's [?",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "Zelkin's ?] friend will not fail in maths.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "Here you go again.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I passed.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We had some religious education in school.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "But it was extremely-- it was not taken seriously.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "The poor rabbi had-- didn't have a good time with us.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "We were not very respectful.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "I don't think we were.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "But we, I-- we, we-- my parents did the usual holiday thing.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "We had Pesach.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "We went-- we had it together with our neighbors, with the Edelsteins, who were in the [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And there was this old grandpa with a beautiful red velvet hat, embroidered.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "He sat in a [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And he brought the fish.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And they had the lemonade, because of course, they had the lemonade factory.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And I was sitting with a back to the kitchen because I was the youngest and I had to say the, the [? koshiot. ?] You know, the-- of course.",
      "word_count": 30
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "And then when something was missing on the table, they sent me out to the cold kitchen to bring in.",
      "word_count": 20
    }
  ],
