{
  "stem": "3449.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "When you saw a German truck run up, or-- or cars with some militia, I ran right away for-- for a hiding place.",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I didn't run home.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I ran-- always on my mind, to run away to hide.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I don't know what's going to happen later, but hide.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "I remember one incident.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "There was couple of shots.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And I saw Germans with a truck.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And I said, well that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "I ran up a tree.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "I hid in a tree.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "I figured if I don't see them, they don't see me.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "You know, that type of thing.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And I was there for about an hour, until I saw it was OK.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "Than I climbed down.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "A few times that happened.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And there were a lot of rumors.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "But it's going to be next week.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "It's going to be five days later.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "It's going to be next month.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "So you got tired of hiding, out of that quick hiding thing.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Because where do you run, first of all?",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "You see what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "My aunt-- she's still alive here-- my mother's sister-- she was working for a Ukrainian.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "It's best if you could work for somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You see, then you're busy.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "You were not designated to take away.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "You were busy.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "So she worked for this Ukrainian family.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "He was in the Ukrainian militia, working for the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "She had a gun.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And he liked her.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "And he said to her, Jenny you better-- there's something I don't like, something is going to happen.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "They told us to check our rifles.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "They told us a certain day.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "And there's no reason, unless they are thinking of-- of something serious this time.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "I don't think it's a rumor.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "I'll let you know what else I can find out.",
      "word_count": 10
    }
  ],
