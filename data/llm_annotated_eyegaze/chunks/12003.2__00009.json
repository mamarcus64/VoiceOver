  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And I was told that I bared somebody else's number already that did not have the A series, that there were 26,284 people before me that were tattoo, but without the A number.",
      "word_count": 33
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how factual this is.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I tried.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "When I came first United States in 1949, I made some wonderful friends with young people that used to go to Michigan State University.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, they didn't know much about survivors in concentration camps and the numbers.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I was invited to formal dances.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I was young and so happy to be alive.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "When I was invited, [PAUSES FOR 4 SECONDS] I was trying to cover this up with makeup at first I was ashamed of it.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "The young people didn't understand.",
      "word_count": 5
    }
  ],
