{
  "stem": "2350.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "We didn't know where we going.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 5 SECONDS] So we came into a barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "Take everything off.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "So we got undressed.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "Put everything away, whatever you carry.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "I was holding onto my toothbrush like to dear God.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "Everything, even the toothbrush.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "I had big, long braids, as you see here on the picture.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "They opened them up if there is nothing hidden in the braids, you know, gold or, or diamonds.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 5 SECONDS] So they opened up my hair.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And we were standing naked-- completely, just, you know-- [PAUSES FOR 4 SECONDS]",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And they tattooed our arms.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And this was my name for the last, next two years, 56065.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] We were tattooed according to ABC, so I was Butnick.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I was from the early people.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "My sister had 69, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "She was in line with me.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Can you see it?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Finished?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] And then they told us to walk through the street completely naked.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know if I should put my hair to the front or to the back or to hide myself.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Men were walking around.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We were completely regarded as-- completely we lost all our dignity.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They took away all the dignity from us.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And then we went-- the men were shaving us with some stuff.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And then we went into the sauna.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And we didn't know what's going to happen.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] So we showered.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And after the shower, they told us to walk out of there for clothing.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I got a evening dress, a black.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "My sister had a red baby dress.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And my other sister had some kind of another child's dress, my older sister.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They shaved our hair.",
      "word_count": 4
    }
  ],
