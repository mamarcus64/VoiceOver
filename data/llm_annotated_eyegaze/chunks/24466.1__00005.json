{
  "stem": "24466.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And I went to work for Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "Zorkarat, in Lublin.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "That was close until the war broke out.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Mostly sole leather.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Sole leather.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Sole, sole leathers.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "For the shoes.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Some had been for the military use.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Broke out.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Knowing what happens to the Jews when [NON-ENGLISH] was in Germany, after 1933-- I was very worrying, what the time will bring, especially for Jews.",
      "word_count": 25
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Lublin, I left two months before the war broke out.",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "I went for my holidays, to Krinica.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I was in Radom with my father when the war broke out.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "To describe this, I said when the war started.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Is that correct?",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "I remember the whole town was bombarded.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "There was people-- we were frightened.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And life was miserable.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "At that time?",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "I was talking to my father.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Because young people know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And first thing what I done, I went to the-- I was trying-- because I was in the reserve, actually, not contingent, they are calling this.",
      "word_count": 26
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "And I went to the-- [PAUSES FOR 4 SECONDS] that was the [NON-ENGLISH], commander.",
      "word_count": 14
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "Commander of [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "And I was trying to go to the army, and to fight the Germans with a lot of my friends, school mates.",
      "word_count": 22
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "And the answer was when we will need you, we will notify you.",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "And that was the answer.",
      "word_count": 5
    }
  ],
